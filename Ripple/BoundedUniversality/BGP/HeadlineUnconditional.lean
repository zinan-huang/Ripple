theorem paper3S4_edge_zu_envelope_NW (w j : ℕ) (i : Fin d_U) :
    ∀ t ∈ Icc (selectorMUWriteReadTime j) (selectorMUZOffStart j),
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3S4EdgeZUBoundNW := by
  have hws0 : 0 ≤ selectorMUWriteStartTime j :=
    selectorMUWriteStartTime_nonneg j
  have hwswr : selectorMUWriteStartTime j ≤ selectorMUWriteReadTime j :=
    selectorMUWriteStart_le_read j
  have hwr0 : 0 ≤ selectorMUWriteReadTime j := le_trans hws0 hwswr
  have hwrz : selectorMUWriteReadTime j ≤ selectorMUZOffStart j :=
    paper3NW4_wr_le_zOffStart j
  have hC0 : 0 ≤ paper3F1CwinDefN := paper3F1CwinDefN_nonneg
  have hD0 := D_U_nonneg
  have hr : r_LE_U = 1 / 1000 := rfl
  -- u level on the edge window
  have hu_lvl : ∀ t ∈ Icc (selectorMUWriteReadTime j)
      (selectorMUZOffStart j), ∀ k : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u t k| ≤ 2 * D_U + 1 := by
    intro t ht k
    have htube := paper3SegC_edge_tube_NW w j t
      ⟨le_trans hwswr ht.1, ht.2⟩ k
    have henc := paper3NW4_enc_abs (paper3F1Cfg w j) k
    have hsplit : |((paper3HeadlineSolFamNW w) w).u t k| ≤
        |((paper3HeadlineSolFamNW w) w).u t k -
          stackMachineEncodingU.enc (paper3F1Cfg w j) k| +
        |stackMachineEncodingU.enc (paper3F1Cfg w j) k| := by
      have h := abs_sub_le (((paper3HeadlineSolFamNW w) w).u t k)
        (stackMachineEncodingU.enc (paper3F1Cfg w j) k) (0 : ℝ)
      simpa using h
    rw [hr] at htube
    linarith
  -- branch hull for the mix target on the edge window
  have hmix_lvl : ∀ t ∈ Icc (selectorMUWriteReadTime j)
      (selectorMUZOffStart j),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
          ((paper3HeadlineSolFamNW w) w).lam t i| ≤
        2 * D_U + 4000 * D_U * (5 * D_U + 2) := by
    intro t ht
    have hbr : ∀ (i' : Fin d_U) (v : UniversalLocalView),
        |BranchData.evalBranch (branchU v)
            (((paper3HeadlineSolFamNW w) w).u t) i'| ≤
          2 * D_U + 4000 * D_U * (5 * D_U + 2) := by
      intro i' v
      have htube := paper3SegC_edge_tube_NW w j t
        ⟨le_trans hwswr ht.1, ht.2⟩ i'
      have hx : |((paper3HeadlineSolFamNW w) w).u t i' -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i'| ≤
          5 * D_U + 2 := by
        rw [hr] at htube
        linarith
      exact paper3NW4_eval_abs_of_coord_bound v i'
        (paper3F1Cfg w j) hx
    exact paper3NW_mixTarget_abs_le_of_branch_abs w w
      (le_trans hwr0 ht.1) hbr i
  -- z entry level at `wr j` from the Seg C window envelope
  have hz_entry : |((paper3HeadlineSolFamNW w) w).z
      (selectorMUWriteReadTime j) i| ≤
      paper3F1CwinDefN + (2 * D_U + 1) := by
    have henv := paper3SegC_envelope_NW w j i (selectorMUWriteReadTime j)
