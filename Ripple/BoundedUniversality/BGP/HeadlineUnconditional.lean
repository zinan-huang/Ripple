        ((paper3HeadlineSolFamNW wg) w).G (selectorMUSelectStartTime j))) ≤
      2 ^ (paper3HeadlineM + 1) *
        Real.exp (-((bgpParamsNW wg).cα * selectorMUSelectStartTime j)) := by
  set sol := (paper3HeadlineSolFamNW wg) w with hsol
  set a := selectorMUSelectStartTime j with ha_def
  have ha0 : 0 ≤ a :=
    le_trans (selectorMUWriteStartTime_nonneg j)
      (selectorMUWriteStart_le_selectStart j)
  have hgap0 : (0 : ℝ) < gap := by linarith
  have hg1 : (1 : ℝ) ≤ ((paper3WarmGainQNW wg : ℚ) : ℝ) := by
    have h1 : (1734736490 : ℚ) ≤ paper3WarmGainCNW wg :=
      paper3WarmGainCNW_ge_base wg
    have h2 : paper3WarmGainCNW wg ≤ paper3WarmGainQNW wg := by
      have hpow : (1 : ℚ) ≤ (6 : ℚ) ^ wg :=
        one_le_pow₀ (by norm_num : (1 : ℚ) ≤ 6)
      have hC0 := paper3WarmGainCNW_nonneg wg
      unfold paper3WarmGainQNW
      nlinarith
    have h3 : (1 : ℚ) ≤ paper3WarmGainQNW wg := by linarith
    exact_mod_cast h3
  have hcα : 0 ≤ (bgpParamsNW wg).cα := by
    rw [bgpParamsNW_cα_def]
    have := bgpScaleWR_pos wg
    nlinarith
