      gg τ ∈ Icc (-(max E B)) (max E B) := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans ha0 hτ.1
    have hkkp := hkk_pos τ hτ0
    have hkZnn := (hkZ_pos τ hτ0).le
    have hkUnn := (hkU_pos τ hτ0).le
    have hmu := hB i τ hτ
    have habs : |gg τ| ≤ B := by
      dsimp only [gg]
      rw [abs_div, abs_of_pos hkkp, abs_mul, abs_of_nonneg hkZnn,
        div_le_iff₀ hkkp]
      have h1 : kZ τ * |selectorMixTarget branchU
          ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i| ≤ kZ τ * B :=
        mul_le_mul_of_nonneg_left hmu hkZnn
      dsimp only [kk]
      nlinarith [mul_nonneg hBnn hkUnn]
    have hle : |gg τ| ≤ max E B := le_trans habs (le_max_right E B)
    exact Set.mem_Icc.mpr (abs_le.mp hle)
  have hy0 : y (selectorMUZOffEnd j) ∈ Icc (-(max E B)) (max E B) := by
    have hle : |y (selectorMUZOffEnd j)| ≤ max E B :=
      le_trans (hE i) (le_max_left E B)
    exact Set.mem_Icc.mpr (abs_le.mp hle)
  have hfin := paper3N_trapping_on_Icc_cOn y gg kk haT
    hkk_cont.continuousOn hgg_cOn hy_ode hknn hgg_range hy0
  have habs_fin : |y (selectorMUWriteStartTime (j + 1))| ≤ max E B :=
    abs_le.mpr (Set.mem_Icc.mp hfin)
  simpa [y] using habs_fin

