    (C := Csrc) (G := ((paper3HeadlineSolFam wg) w).G)
    (cg := paper3S13cgF wg) (reset := paper3S13crF)
    ht.1 hgapL0 hCsrc0 ((paper3HeadlineSolFam wg) w).cont_G
    (fun s hs => by
      have hs0 : 0 ≤ s := le_trans ha0 hs.1
      have h := ((paper3HeadlineSolFam wg) w).G_hasDeriv s
        (selectorSchedule_domain_of_nonneg_structural s hs0)
      exact (by simpa [paper3S13cgF] using h :
        HasDerivAt ((paper3HeadlineSolFam wg) w).G (paper3S13cgF wg s) s))
    (paper3S13cgF_continuous wg) paper3S13crF_continuous
    (fun s _hs => paper3S13crF_nonneg s)
    (fun s hs => by
      have hsIcc : s ∈ Icc a b := ⟨hs.1, le_trans hs.2 ht.2⟩
      have h1 := paper3S13crF_le_one s
      have h2 := hCsrc_ratio s hsIcc
      linarith)).2
  have hint_eq : (∫ s in a..t,
      Real.exp ((selectorReplicatorGapVal paper3HeadlineEta
          paper3HeadlineEta_pos * Lsafe) *
        (((paper3HeadlineSolFam wg) w).G s -
          ((paper3HeadlineSolFam wg) w).G a)) * paper3S13crF s * (1 : ℝ)) =
      ∫ s in a..t,
        Real.exp ((selectorReplicatorGapVal paper3HeadlineEta
            paper3HeadlineEta_pos * Lsafe) *
