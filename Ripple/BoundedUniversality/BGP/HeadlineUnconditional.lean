    exact mul_nonneg
      (mul_nonneg
        (pow_nonneg (by nlinarith [Real.neg_one_le_cos t]) paper3HeadlineM)
        (by norm_num [paper3HeadlineKappa]))
      hCreset_nonneg
  have hweight_nonneg : ∀ t ∈ Icc a b, 0 ≤ weight t := by
    intro t ht
    dsimp [weight, selectorMUHoffGateCoeff, sol]
    exact selector_replicator_gateZ_integrand_nonneg
      ((paper3HeadlineSolFam wg) w)
      selectorSchedule_domain_of_nonneg_structural
      (by norm_num [bgpParams38])
      (hI_nonneg t ht)
  have hweight_bound : ∀ t ∈ Icc a b, weight t ≤ Cw * cg t := by
    intro t ht
    simpa [weight, Cw, cg, a, b, rmin, D, sol] using
      paper3HeadlineHoffGateCoeff_left_le_gain_ratio
        (wg := wg) (w := w) (j := j) (t := t)
        (by simpa [a, b] using ht)
  have hbad_bound :
      ∀ t ∈ Icc a b,
        bad t ≤
          B0 * Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) +
            (∫ s in a..t,
              Real.exp ((gap * Lsafe) * ((sol w).G s - (sol w).G a)) *
                reset s) *
              Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) := by
    intro t ht
    have hduh :=
      selectorMU_old_new_badMass_duhamel_bound_on_Icc
        (sol := paper3HeadlineSolFam wg)
        (paper3HeadlineBoxInputs wg)
        (paper3WarmGainQ_nonneg wg)
        w j
        (a := a) (b := b) (gap := gap) (Lsafe := Lsafe)
        hab hI_nonneg hgap_nonneg hgapL_pos
        (by simpa [a, b, sol] using hsafe_floor)
        (by simpa [a, b, sol, gap] using hpair)
        t ht
    have hdecay_nonneg :
        0 ≤ Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) :=
      (Real.exp_pos _).le
    have hinit :
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => ((paper3HeadlineSolFam wg) w).lam v a) *
          Real.exp (-((gap * Lsafe) *
            (((paper3HeadlineSolFam wg) w).G t -
              ((paper3HeadlineSolFam wg) w).G a))) ≤
        B0 * Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) := by
      exact mul_le_mul_of_nonneg_right
        (by simpa [a, sol] using hBa)
        hdecay_nonneg
    have hduh' :
        bad t ≤
          (Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
              (fun v => ((paper3HeadlineSolFam wg) w).lam v a) *
            Real.exp (-((gap * Lsafe) *
              (((paper3HeadlineSolFam wg) w).G t -
                ((paper3HeadlineSolFam wg) w).G a))) +
          (∫ s in a..t,
            Real.exp ((gap * Lsafe) *
                (((paper3HeadlineSolFam wg) w).G s -
                  ((paper3HeadlineSolFam wg) w).G a)) *
              (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
                (paper3HeadlineKappa : ℝ)) *
              Creset) *
            Real.exp (-((gap * Lsafe) *
              (((paper3HeadlineSolFam wg) w).G t -
                ((paper3HeadlineSolFam wg) w).G a))) := by
      simpa [bad, reset, sol, gap, a, Creset, mul_assoc] using hduh
    simpa [reset, sol, gap, a, Creset, mul_assoc] using
      (le_trans hduh' (add_le_add hinit le_rfl))
  have hmain :=
    paper3WeightedBadMassDuhamelIntegral_le
      (a := a) (b := b) (gap := gap * Lsafe) (C := Cw) (B0 := B0)
      (G := (sol w).G) (cg := cg) (weight := weight) (reset := reset)
      (bad := bad)
      hab hgapL_pos hCw_nonneg hB0_nonneg (sol w).cont_G hGder
      hcg_cont hweight_cont hreset_cont hbad_cont hcg_nonneg
      hreset_nonneg hweight_nonneg hweight_bound hbad_bound
  simpa [sol, gap, a, b, rmin, D, Cw, Creset, weight, reset, bad,
    mul_assoc, mul_left_comm, mul_comm] using hmain

/-- The concrete left-edge reset source has at most unit mass over a window of
length `π / 6`. -/
theorem paper3HeadlineLeftResetIntegral_le_pi_six
    (w j : ℕ) :
    let Creset : ℝ :=
      ((Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
        (Fintype.card UniversalLocalView : ℝ)
    (∫ s in (selectorMUInterReadStart j)..(selectorMUZOffStart j),
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ)) * Creset) ≤
      Real.pi / 6 := by
  classical
  dsimp
  let a : ℝ := selectorMUInterReadStart j
  let b : ℝ := selectorMUZOffStart j
  let Creset : ℝ :=
    ((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)
  have hab : a ≤ b := by
    simpa [a, b] using selectorMUInterReadStart_le_zOffStart j
  have hden_pos : (0 : ℝ) < Fintype.card UniversalLocalView := by
    exact_mod_cast
      (Fintype.card_pos_iff.mpr ⟨defaultLocalViewU⟩ :
        0 < Fintype.card UniversalLocalView)
  have hCreset_nonneg : 0 ≤ Creset := by
    dsimp [Creset]
    exact div_nonneg (Nat.cast_nonneg _) hden_pos.le
  have hCreset_le_one : Creset ≤ 1 := by
    have hcard_le :
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card ≤
          Fintype.card UniversalLocalView := by
      exact Finset.card_le_univ _
    have hnum_le :
        ((Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) ≤
          (Fintype.card UniversalLocalView : ℝ) := by
      exact_mod_cast hcard_le
    calc
      Creset ≤ (Fintype.card UniversalLocalView : ℝ) /
          (Fintype.card UniversalLocalView : ℝ) := by
            dsimp [Creset]
            exact div_le_div_of_nonneg_right hnum_le hden_pos.le
      _ = 1 := div_self hden_pos.ne'
  have hcont : Continuous fun s : ℝ =>
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ)) * Creset := by
    exact ((((continuous_const.add Real.continuous_cos).div_const 2).pow
      paper3HeadlineM).mul continuous_const).mul continuous_const
  have hpoint : ∀ s ∈ Icc a b,
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ)) * Creset ≤ 1 := by
    intro s _hs
    have hbase_nonneg : 0 ≤ (1 + Real.cos s) / 2 := by
      nlinarith [Real.neg_one_le_cos s]
    have hbase_le_one : (1 + Real.cos s) / 2 ≤ 1 := by
      nlinarith [Real.cos_le_one s]
    have hpow_nonneg :
        0 ≤ ((1 + Real.cos s) / 2) ^ paper3HeadlineM :=
      pow_nonneg hbase_nonneg paper3HeadlineM
    have hpow_le_one :
        ((1 + Real.cos s) / 2) ^ paper3HeadlineM ≤ 1 := by
      simpa using
        (pow_le_one₀ (n := paper3HeadlineM) hbase_nonneg hbase_le_one)
    have hkappa_nonneg : 0 ≤ (paper3HeadlineKappa : ℝ) := by
      norm_num [paper3HeadlineKappa]
    have hkappa_le_one : (paper3HeadlineKappa : ℝ) ≤ 1 := by
      norm_num [paper3HeadlineKappa]
    have hpulse_nonneg :
        0 ≤ ((1 + Real.cos s) / 2) ^ paper3HeadlineM *
          (paper3HeadlineKappa : ℝ) :=
      mul_nonneg hpow_nonneg hkappa_nonneg
    have hpulse_le_one :
        ((1 + Real.cos s) / 2) ^ paper3HeadlineM *
          (paper3HeadlineKappa : ℝ) ≤ 1 := by
      calc
        ((1 + Real.cos s) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ)
            ≤ 1 * (paper3HeadlineKappa : ℝ) :=
              mul_le_mul_of_nonneg_right hpow_le_one hkappa_nonneg
        _ ≤ 1 * 1 := mul_le_mul_of_nonneg_left hkappa_le_one
          (by norm_num : (0 : ℝ) ≤ 1)
        _ = 1 := by norm_num
    calc
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
          (paper3HeadlineKappa : ℝ)) * Creset
          ≤ 1 * Creset :=
            mul_le_mul_of_nonneg_right hpulse_le_one hCreset_nonneg
      _ ≤ 1 * 1 := mul_le_mul_of_nonneg_left hCreset_le_one
        (by norm_num : (0 : ℝ) ≤ 1)
      _ = 1 := by norm_num
  calc
    (∫ s in a..b,
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ)) * Creset)
        ≤ ∫ _s in a..b, (1 : ℝ) := by
          exact intervalIntegral.integral_mono_on hab
            (hcont.intervalIntegrable a b)
            (continuous_const.intervalIntegrable a b) hpoint
    _ = b - a := by
          simp [intervalIntegral.integral_const]
    _ = Real.pi / 6 := by
          simp [a, b, selectorMUInterReadStart, selectorMUWriteReadTime,
            selectorMUZOffStart]
          ring

set_option maxHeartbeats 1500000 in
/-- Left-edge old/new bad-mass producer in headline scalar form. -/
theorem paper3HeadlineLeftOldNewBadMassHoffIntegral_le_hoffRate
    (wg w j : ℕ) {B0 Lsafe : ℝ}
    (hgapL_pos :
      0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        Lsafe)
    (hB0_nonneg : 0 ≤ B0)
    (hsafe_floor : ∀ t ∈
      Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
      Lsafe ≤
        (insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView)).sum
          (fun u => ((paper3HeadlineSolFam wg) w).lam u t))
    (hpair : ∀ t ∈
      Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
      ∀ v : UniversalLocalView,
        v ∉ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
    (hBa :
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => ((paper3HeadlineSolFam wg) w).lam v
            (selectorMUInterReadStart j)) ≤ B0) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUInterReadStart j
    let b : ℝ := selectorMUZOffStart j
    let D : ℝ := ((1 / 2 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    (∫ t in a..b,
      selectorMUHoffGateCoeff sol w t *
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => (sol w).lam v t)) ≤
      ((B0 + Real.pi / 6) / ((gap * Lsafe) * D)) *
        paper3HoffRate j := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let a : ℝ := selectorMUInterReadStart j
  let b : ℝ := selectorMUZOffStart j
  let rmin : ℝ := (1 / 4 : ℝ)
  let D : ℝ := ((1 / 2 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  let Cw : ℝ := Real.exp (-(rmin * a)) / D
  let Creset : ℝ :=
    ((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)
  let reset : ℝ → ℝ := fun t =>
    (((1 + Real.cos t) / 2) ^ paper3HeadlineM *
      (paper3HeadlineKappa : ℝ)) * Creset
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 1 / 2) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hden_pos : 0 < gap * Lsafe := by
    simpa [gap] using hgapL_pos
  have hCw_nonneg : 0 ≤ Cw := by
    dsimp [Cw]
    exact div_nonneg (Real.exp_pos _).le hD_pos.le
  have hcoef_nonneg : 0 ≤ Cw / (gap * Lsafe) :=
    div_nonneg hCw_nonneg hden_pos.le
  have hBsum_nonneg : 0 ≤ B0 + Real.pi / 6 := by
    nlinarith [hB0_nonneg, Real.pi_pos]
  have hduh :
      (∫ t in a..b,
        selectorMUHoffGateCoeff sol w t *
          (Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => (sol w).lam v t)) ≤
        B0 * (Cw / (gap * Lsafe)) +
          (Cw / (gap * Lsafe)) * ∫ s in a..b, reset s := by
    simpa [sol, gap, a, b, rmin, D, Cw, Creset, reset,
      mul_assoc, mul_left_comm, mul_comm] using
      paper3HeadlineLeftOldNewBadMassHoffIntegralDuhamel
        (wg := wg) (w := w) (j := j) (B0 := B0) (Lsafe := Lsafe)
        hgapL_pos hB0_nonneg hsafe_floor hpair hBa
  have hreset :
      (∫ s in a..b, reset s) ≤ Real.pi / 6 := by
    simpa [a, b, reset, Creset, paper3HeadlineKappa, mul_assoc,
      mul_left_comm, mul_comm] using
      paper3HeadlineLeftResetIntegral_le_pi_six (w := w) (j := j)
  have hduh_delta :
      (∫ t in a..b,
        selectorMUHoffGateCoeff sol w t *
          (Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => (sol w).lam v t)) ≤
        (B0 + Real.pi / 6) * (Cw / (gap * Lsafe)) := by
    calc
      (∫ t in a..b,
        selectorMUHoffGateCoeff sol w t *
          (Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => (sol w).lam v t))
          ≤ B0 * (Cw / (gap * Lsafe)) +
              (Cw / (gap * Lsafe)) * ∫ s in a..b, reset s := hduh
      _ ≤ B0 * (Cw / (gap * Lsafe)) +
              (Cw / (gap * Lsafe)) * (Real.pi / 6) := by
            exact add_le_add le_rfl
              (mul_le_mul_of_nonneg_left hreset hcoef_nonneg)
      _ = (B0 + Real.pi / 6) * (Cw / (gap * Lsafe)) := by ring
  have hCw_rate :
      Cw ≤ (1 / D) * paper3HoffRate j := by
    change Real.exp (-(rmin * a)) / D ≤ (1 / D) * paper3HoffRate j
    simpa [a, rmin, D] using
      paper3HeadlineLeftWeightRatio_le_hoffRate wg j
  have hdiv_rate :
      Cw / (gap * Lsafe) ≤
        ((1 / D) * paper3HoffRate j) / (gap * Lsafe) :=
    div_le_div_of_nonneg_right hCw_rate hden_pos.le
  have hrate_bound :
      (B0 + Real.pi / 6) * (Cw / (gap * Lsafe)) ≤
        (B0 + Real.pi / 6) *
          (((1 / D) * paper3HoffRate j) / (gap * Lsafe)) :=
    mul_le_mul_of_nonneg_left hdiv_rate hBsum_nonneg
  have halg :
      (B0 + Real.pi / 6) *
          (((1 / D) * paper3HoffRate j) / (gap * Lsafe)) =
        ((B0 + Real.pi / 6) / ((gap * Lsafe) * D)) *
          paper3HoffRate j := by
    simp only [div_eq_mul_inv, one_mul, mul_inv_rev]
    ring
  exact le_trans hduh_delta (le_trans hrate_bound (le_of_eq halg))

/-- Pointwise post-select Hoff-gate coefficient as a multiple of the replicator
common gain `G'`.  The multiplier decays from the shifted select start. -/
theorem paper3HeadlineHoffGateCoeff_postSelect_le_gain_ratio
    (wg w j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUSelectStartTime j)
        (selectorMUEarlyWriteSubStart j)) :
    let rmin : ℝ := (1 - Real.sqrt 2 / 2) / 2
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t ≤
      (Real.exp (-(rmin * selectorMUSelectStartTime j)) / D) *
        (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t))) := by
  dsimp
  let sol := paper3HeadlineSolFam wg
  let rmin : ℝ := (1 - Real.sqrt 2 / 2) / 2
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 3 / 4) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hrmin_nonneg : 0 ≤ rmin := by
    dsimp [rmin]
    have hsqrt_le_two : Real.sqrt 2 ≤ 2 := by
      nlinarith [Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2),
        Real.sqrt_nonneg (2 : ℝ)]
    nlinarith
  have hsel_nonneg : 0 ≤ selectorMUSelectStartTime j :=
    le_trans (selectorMUWriteStartTime_nonneg j) (selectorMUWriteStart_le_selectStart j)
  have ht_nonneg : 0 ≤ t := le_trans hsel_nonneg ht.1
  have hα : (sol w).α t = Real.exp (bgpParams38.cα * t) :=
    (sol w).alpha_eq_exp selectorSchedule_domain_of_nonneg_structural ht_nonneg
  have hμlin : (sol w).μ t = (sol w).μ 0 + bgpParams38.cμ * t :=
    (sol w).mu_eq_linear selectorSchedule_domain_of_nonneg_structural ht_nonneg
  have hμ : (sol w).μ t = bgpParams38.cμ * t := by
    rw [hμlin, (sol w).μ_at_zero]
    simp [bgpParams38]
  have hr : rmin ≤ rPulse bgpParams38.L t :=
    paper3HeadlinePostSelect_rPulse_ge_sqrt2_complement j ht
  have htr : t * rmin ≤ (sol w).μ t * rPulse bgpParams38.L t := by
    rw [hμ]
    exact paper3Headline_t_mul_rmin_le_cmu_mul_rPulse ht_nonneg hr
  have hbGate :
      bGateZ bgpParams38.L ((sol w).μ t) t ≤ Real.exp (-(t * rmin)) := by
    unfold bGateZ
    exact Real.exp_le_exp.mpr (neg_le_neg htr)
  have hsin : (1 : ℝ) / 2 ≤ Real.sin t :=
    paper3HeadlinePostSelect_sin_ge_half j ht
  have hsin_base : (3 / 4 : ℝ) ≤ (1 + Real.sin t) / 2 := by
    linarith
  have hsin_pow :
      ((3 / 4 : ℝ) ^ paper3HeadlineM) ≤
        ((1 + Real.sin t) / 2) ^ paper3HeadlineM := by
    exact pow_le_pow_left₀ (by norm_num) hsin_base paper3HeadlineM
  have hD_le :
      D ≤ ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          ((paper3WarmGainQ wg : ℚ) : ℝ) := by
    dsimp [D]
    exact mul_le_mul_of_nonneg_right hsin_pow (paper3WarmGainQ_nonneg wg)
  have hDexp_le :
      D * Real.exp (bgpParams38.cα * t) ≤
        ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t)) := by
    calc
      D * Real.exp (bgpParams38.cα * t) ≤
          (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
            ((paper3WarmGainQ wg : ℚ) : ℝ)) *
              Real.exp (bgpParams38.cα * t) :=
            mul_le_mul_of_nonneg_right hD_le (Real.exp_pos _).le
      _ = ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t)) := by ring
  have hdecay :
      Real.exp (-(t * rmin)) ≤
        Real.exp (-(rmin * selectorMUSelectStartTime j)) := by
    refine Real.exp_le_exp.mpr ?_
    have hmul := mul_le_mul_of_nonneg_left ht.1 hrmin_nonneg
    nlinarith [hmul]
  have hcoeff_nonneg :
      0 ≤ Real.exp (-(rmin * selectorMUSelectStartTime j)) / D :=
    div_nonneg (Real.exp_pos _).le hD_pos.le
  calc
    selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t
        = Real.exp (bgpParams38.cα * t) *
            bGateZ bgpParams38.L ((sol w).μ t) t := by
          simp [selectorMUHoffGateCoeff, sol, hα, bgpParams38]
    _ ≤ Real.exp (bgpParams38.cα * t) * Real.exp (-(t * rmin)) := by
          exact mul_le_mul_of_nonneg_left hbGate (Real.exp_pos _).le
    _ ≤ Real.exp (bgpParams38.cα * t) *
          Real.exp (-(rmin * selectorMUSelectStartTime j)) := by
          exact mul_le_mul_of_nonneg_left hdecay (Real.exp_pos _).le
    _ = (Real.exp (-(rmin * selectorMUSelectStartTime j)) / D) *
          (D * Real.exp (bgpParams38.cα * t)) := by
          field_simp [hD_pos.ne']
    _ ≤ (Real.exp (-(rmin * selectorMUSelectStartTime j)) / D) *
          (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
            (((paper3WarmGainQ wg : ℚ) : ℝ) *
              Real.exp (bgpParams38.cα * t))) := by
          exact mul_le_mul_of_nonneg_left hDexp_le hcoeff_nonneg

/-- The full active select-to-hold window remains inside the active q-gate
window. -/
theorem paper3HeadlineActive_sin_ge_half
    (j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUSelectStartTime j)
        (selectorMUWriteHoldTime j)) :
    (1 : ℝ) / 2 ≤ Real.sin t := by
  have hgate : t ∈ Set.Icc
      (2 * Real.pi * (j : ℝ) + Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + Real.pi / 2) := by
    constructor
    · have hstart := le_trans (selectorMUWriteStart_le_selectStart j) ht.1
      simpa [selectorMUWriteStartTime] using hstart
    · simpa [selectorMUWriteHoldTime] using ht.2
  exact sin_ge_half_of_gate_window j hgate

/-- On the full active select-to-hold window, the reset source is bounded by a
decaying multiple of the active gain.  This is the pointwise ratio input for
the q-free Duhamel square estimate. -/
theorem paper3HeadlineActive_reset_le_selectStartDecay_mul_activeCg
    (wg j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUSelectStartTime j)
        (selectorMUWriteHoldTime j)) :
    selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa t ≤
      Real.exp (-(bgpParams38.cα * selectorMUSelectStartTime j)) *
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) t := by
  let S : ℝ := selectorMUSelectStartTime j
  let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) * q
  let pulse : ℝ := ((1 + Real.sin t) / 2) ^ paper3HeadlineM
  have hcr_le_one :
      selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa t ≤ 1 := by
    have hcos_nonneg : 0 ≤ (1 + Real.cos t) / 2 := by
      nlinarith [Real.neg_one_le_cos t]
    have hcos_le_one : (1 + Real.cos t) / 2 ≤ 1 := by
      nlinarith [Real.cos_le_one t]
    have hpow :
        ((1 + Real.cos t) / 2) ^ paper3HeadlineM ≤ 1 :=
      pow_le_one₀ hcos_nonneg hcos_le_one
    simpa [selectorMU_activeCr, paper3HeadlineKappa] using hpow
  have hD_ge_one : (1 : ℝ) ≤ D := by
    simpa [D, q, paper3HeadlineKappa] using paper3HeadlineHScale wg
  have hD_nonneg : 0 ≤ D := le_trans zero_le_one hD_ge_one
  have hsin : (1 : ℝ) / 2 ≤ Real.sin t :=
    paper3HeadlineActive_sin_ge_half j ht
  have hsin_base : (3 / 4 : ℝ) ≤ (1 + Real.sin t) / 2 := by
    linarith
  have hpulse_floor :
      ((3 / 4 : ℝ) ^ paper3HeadlineM) ≤ pulse := by
    simpa [pulse] using
      pow_le_pow_left₀ (by norm_num : (0 : ℝ) ≤ 3 / 4) hsin_base
        paper3HeadlineM
  have hq_nonneg : 0 ≤ q := by
    simpa [q] using paper3WarmGainQ_nonneg wg
  have hD_le_pulse_q : D ≤ pulse * q := by
    dsimp [D]
    exact mul_le_mul_of_nonneg_right hpulse_floor hq_nonneg
  have hα_nonneg : 0 ≤ bgpParams38.cα := by
    norm_num [bgpParams38]
  have hshift_nonneg : 0 ≤ t - S := by
    dsimp [S]
    linarith [ht.1]
  have hexp_shift_ge_one : (1 : ℝ) ≤ Real.exp (bgpParams38.cα * (t - S)) := by
    rw [← Real.exp_zero]
    exact Real.exp_le_exp.mpr (mul_nonneg hα_nonneg hshift_nonneg)
  have hpulse_q_nonneg : 0 ≤ pulse * q :=
    le_trans hD_nonneg hD_le_pulse_q
  have hone_le :
      (1 : ℝ) ≤ pulse * q * Real.exp (bgpParams38.cα * (t - S)) := by
    calc
      (1 : ℝ) ≤ D := hD_ge_one
      _ ≤ pulse * q := hD_le_pulse_q
      _ ≤ pulse * q * Real.exp (bgpParams38.cα * (t - S)) := by
        simpa using
          (le_mul_of_one_le_right hpulse_q_nonneg hexp_shift_ge_one)
  have hrewrite :
      Real.exp (-(bgpParams38.cα * S)) *
          selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) t =
        pulse * q * Real.exp (bgpParams38.cα * (t - S)) := by
    calc
      Real.exp (-(bgpParams38.cα * S)) *
          selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) t
          =
        pulse * q *
          (Real.exp (-(bgpParams38.cα * S)) *
            Real.exp (bgpParams38.cα * t)) := by
            dsimp [selectorMU_activeCg, pulse, q]
            ring
      _ = pulse * q * Real.exp (bgpParams38.cα * (t - S)) := by
            rw [← Real.exp_add]
            congr 1
            ring
  calc
    selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa t ≤ 1 := hcr_le_one
    _ ≤ pulse * q * Real.exp (bgpParams38.cα * (t - S)) := hone_le
    _ = Real.exp (-(bgpParams38.cα * S)) *
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) t := hrewrite.symm

/-- Crude active-window Hoff/gain ratio on `[SelectStart, WriteHold]`.

Unlike the post-select prefix bound, this has no Hoff-decaying factor:
`rPulse` can vanish at `WriteHold`, so the only uniform estimate is
`bGateZ ≤ 1`. -/
theorem paper3HeadlineHoffGateCoeff_active_le_gain_ratio_crude
    (wg w j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUSelectStartTime j)
        (selectorMUWriteHoldTime j)) :
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t ≤
      (1 / D) *
        (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t))) := by
  dsimp
  let sol := paper3HeadlineSolFam wg
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 3 / 4) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hsel_nonneg : 0 ≤ selectorMUSelectStartTime j :=
    le_trans (selectorMUWriteStartTime_nonneg j) (selectorMUWriteStart_le_selectStart j)
  have ht_nonneg : 0 ≤ t := le_trans hsel_nonneg ht.1
  have hα : (sol w).α t = Real.exp (bgpParams38.cα * t) :=
    (sol w).alpha_eq_exp selectorSchedule_domain_of_nonneg_structural ht_nonneg
  have hμlin : (sol w).μ t = (sol w).μ 0 + bgpParams38.cμ * t :=
    (sol w).mu_eq_linear selectorSchedule_domain_of_nonneg_structural ht_nonneg
  have hμ : (sol w).μ t = bgpParams38.cμ * t := by
    rw [hμlin, (sol w).μ_at_zero]
    simp [bgpParams38]
  have hbGate : bGateZ bgpParams38.L ((sol w).μ t) t ≤ 1 := by
    rw [hμ]
    exact bGateZ_le_one bgpParams38.L
      (mul_nonneg (by norm_num [bgpParams38] : 0 ≤ bgpParams38.cμ) ht_nonneg) t
  have hsin : (1 : ℝ) / 2 ≤ Real.sin t :=
    paper3HeadlineActive_sin_ge_half j ht
  have hsin_base : (3 / 4 : ℝ) ≤ (1 + Real.sin t) / 2 := by
    linarith
  have hsin_pow :
      ((3 / 4 : ℝ) ^ paper3HeadlineM) ≤
        ((1 + Real.sin t) / 2) ^ paper3HeadlineM := by
    exact pow_le_pow_left₀ (by norm_num) hsin_base paper3HeadlineM
  have hD_le :
      D ≤ ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          ((paper3WarmGainQ wg : ℚ) : ℝ) := by
    dsimp [D]
    exact mul_le_mul_of_nonneg_right hsin_pow (paper3WarmGainQ_nonneg wg)
  have hDexp_le :
      D * Real.exp (bgpParams38.cα * t) ≤
        ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t)) := by
    calc
      D * Real.exp (bgpParams38.cα * t) ≤
          (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
            ((paper3WarmGainQ wg : ℚ) : ℝ)) *
              Real.exp (bgpParams38.cα * t) :=
            mul_le_mul_of_nonneg_right hD_le (Real.exp_pos _).le
      _ = ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t)) := by ring
  have hcoeff_nonneg : 0 ≤ (1 : ℝ) / D :=
    div_nonneg zero_le_one hD_pos.le
  calc
    selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t
        = Real.exp (bgpParams38.cα * t) *
            bGateZ bgpParams38.L ((sol w).μ t) t := by
          simp [selectorMUHoffGateCoeff, sol, hα, bgpParams38]
    _ ≤ Real.exp (bgpParams38.cα * t) * 1 := by
          exact mul_le_mul_of_nonneg_left hbGate (Real.exp_pos _).le
    _ = (1 / D) * (D * Real.exp (bgpParams38.cα * t)) := by
          field_simp [hD_pos.ne']
    _ ≤ (1 / D) *
          (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
            (((paper3WarmGainQ wg : ℚ) : ℝ) *
              Real.exp (bgpParams38.cα * t))) := by
          exact mul_le_mul_of_nonneg_left hDexp_le hcoeff_nonneg

/-- The post-select weight/gain ratio is no larger than the canonical Hoff
decay.  This is the same exponential comparison as the recovery prefix, with
`SelectStart ≥ WriteStart`. -/
theorem paper3HeadlinePostSelectWeightRatio_le_hoffRate
    (wg j : ℕ) :
    let rmin : ℝ := (1 - Real.sqrt 2 / 2) / 2
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    Real.exp (-(rmin * selectorMUSelectStartTime (j + 1))) / D ≤
      (1 / D) * paper3HoffRate j := by
  dsimp
  let rmin : ℝ := (1 - Real.sqrt 2 / 2) / 2
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 3 / 4) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hrmin_nonneg : 0 ≤ rmin := by
    dsimp [rmin]
    have hsqrt_le_two : Real.sqrt 2 ≤ 2 := by
      nlinarith [Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 2),
        Real.sqrt_nonneg (2 : ℝ)]
    nlinarith
  have hselect_ge_write :
      selectorMUWriteStartTime (j + 1) ≤ selectorMUSelectStartTime (j + 1) :=
    selectorMUWriteStart_le_selectStart (j + 1)
  have hprod :
      rmin * selectorMUWriteStartTime (j + 1) ≤
        rmin * selectorMUSelectStartTime (j + 1) :=
    mul_le_mul_of_nonneg_left hselect_ge_write hrmin_nonneg
  have hdecay :
      Real.exp (-(rmin * selectorMUSelectStartTime (j + 1))) ≤
        Real.exp (-(rmin * selectorMUWriteStartTime (j + 1))) :=
    Real.exp_le_exp.mpr (by linarith)
  have hdiv :
      Real.exp (-(rmin * selectorMUSelectStartTime (j + 1))) / D ≤
        Real.exp (-(rmin * selectorMUWriteStartTime (j + 1))) / D :=
    div_le_div_of_nonneg_right hdecay hD_pos.le
  exact le_trans hdiv (by
    simpa [rmin, D] using paper3HeadlineRecoveryWeightRatio_le_hoffRate wg j)

/-- The explicit reset source on the post-select prefix has length at most
`π/12`. -/
theorem paper3HeadlinePostSelectResetIntegral_le_pi_twelve
    (j : ℕ) :
    (∫ s in (selectorMUSelectStartTime (j + 1))..
        (selectorMUEarlyWriteSubStart (j + 1)),
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ))) ≤
      Real.pi / 12 := by
  let a : ℝ := selectorMUSelectStartTime (j + 1)
  let b : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  have hab : a ≤ b := by
    simpa [a, b] using selectorMUSelectStart_le_earlySubStart (j + 1)
  have hcont : Continuous fun s : ℝ =>
      ((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ) := by
    fun_prop
  have hpoint : ∀ s ∈ Icc a b,
      ((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ) ≤ 1 := by
    intro s _hs
    have hbase_nonneg : 0 ≤ (1 + Real.cos s) / 2 := by
      nlinarith [Real.neg_one_le_cos s]
    have hbase_le : (1 + Real.cos s) / 2 ≤ 1 := by
      nlinarith [Real.cos_le_one s]
    have hpow :
        ((1 + Real.cos s) / 2) ^ paper3HeadlineM ≤ 1 :=
      pow_le_one₀ hbase_nonneg hbase_le
    simpa [paper3HeadlineKappa] using hpow
  have hlen :
      b - a ≤ Real.pi / 12 := by
    have hwidth_eq : b - a = Real.pi / 12 - selectorMURecoveryDelta := by
      simp [a, b, selectorMUSelectStartTime, selectorMUEarlyWriteSubStart,
        selectorMUWriteStartTime]
      ring
    rw [hwidth_eq]
    linarith [selectorMURecoveryDelta_pos.le]
  calc
    (∫ s in a..b,
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ)))
        ≤ ∫ _s in a..b, (1 : ℝ) := by
          exact intervalIntegral.integral_mono_on hab
            (hcont.intervalIntegrable a b)
            (continuous_const.intervalIntegrable a b) hpoint
    _ = b - a := by
          simp [intervalIntegral.integral_const]
    _ ≤ Real.pi / 12 := hlen

/-- Pointwise prewrite Hoff-gate bound.  This is not an offphase estimate:
`sin t` lies in `[0, 1/2]`, giving `rPulse 1 t ≥ 1/4`. -/
theorem paper3HeadlineHoffGateCoeff_prewrite_le_exp_eighth
    (wg w j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1))) :
    selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t ≤
      Real.exp ((50 : ℝ) * t) := by
  let sol := paper3HeadlineSolFam wg
  have ht_nonneg : 0 ≤ t := by
    have hz : 0 ≤ selectorMUZOffEnd j := by
      unfold selectorMUZOffEnd
      positivity
    exact le_trans hz ht.1
  have hα : (sol w).α t = Real.exp (bgpParams38.cα * t) :=
    (sol w).alpha_eq_exp selectorSchedule_domain_of_nonneg_structural ht_nonneg
  have hμlin : (sol w).μ t = (sol w).μ 0 + bgpParams38.cμ * t :=
    (sol w).mu_eq_linear selectorSchedule_domain_of_nonneg_structural ht_nonneg
  have hμ : (sol w).μ t = bgpParams38.cμ * t := by
    rw [hμlin, (sol w).μ_at_zero]
    simp [bgpParams38]
  have hr : (1 / 4 : ℝ) ≤ rPulse bgpParams38.L t :=
    paper3HeadlinePrewrite_rPulse_ge_quarter j ht
  have htr : (250 : ℝ) * t ≤ (sol w).μ t * rPulse bgpParams38.L t := by
    rw [hμ]
    have hmul := mul_le_mul_of_nonneg_left hr ht_nonneg
    calc
      (250 : ℝ) * t = (1000 : ℝ) * (t * (1 / 4 : ℝ)) := by ring
      _ ≤ (1000 : ℝ) * (t * rPulse bgpParams38.L t) :=
          mul_le_mul_of_nonneg_left hmul (by norm_num : (0 : ℝ) ≤ 1000)
      _ = (bgpParams38.cμ * t) * rPulse bgpParams38.L t := by
          norm_num [bgpParams38]
          ring
  have hbGate :
      bGateZ bgpParams38.L ((sol w).μ t) t ≤ Real.exp (-((250 : ℝ) * t)) := by
    unfold bGateZ
    exact Real.exp_le_exp.mpr (neg_le_neg htr)
  calc
    selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t
        = Real.exp (bgpParams38.cα * t) *
            bGateZ bgpParams38.L ((sol w).μ t) t := by
          simp [selectorMUHoffGateCoeff, sol, hα, bgpParams38]
    _ ≤ Real.exp (bgpParams38.cα * t) * Real.exp (-((250 : ℝ) * t)) := by
          exact mul_le_mul_of_nonneg_left hbGate (Real.exp_pos _).le
    _ = Real.exp ((50 : ℝ) * t) := by
          rw [← Real.exp_add]
          norm_num [bgpParams38]
          ring

/-- Integral form of the prewrite Hoff-gate bound. -/
theorem paper3HeadlineHoffGateCoeff_prewrite_integral_le_exp_eighth
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    let a : ℝ := selectorMUZOffEnd j
    let b : ℝ := selectorMUWriteStartTime (j + 1)
    (∫ t in a..b, selectorMUHoffGateCoeff sol w t) ≤
      (Real.pi / 6) * Real.exp ((50 : ℝ) * b) := by
  dsimp
  let sol := paper3HeadlineSolFam wg
  let a : ℝ := selectorMUZOffEnd j
  let b : ℝ := selectorMUWriteStartTime (j + 1)
  have hab : a ≤ b := by
    simpa [a, b] using selectorMUZOffEnd_le_writeStart_succ j
  have hcont : Continuous fun t : ℝ => selectorMUHoffGateCoeff sol w t := by
    simpa [selectorMUHoffGateCoeff, sol] using
      selector_replicator_gateZ_integrand_continuous ((paper3HeadlineSolFam wg) w)
  have hpoint : ∀ t ∈ Icc a b,
      selectorMUHoffGateCoeff sol w t ≤ Real.exp ((50 : ℝ) * b) := by
    intro t ht
    have hgate := paper3HeadlineHoffGateCoeff_prewrite_le_exp_eighth
      (wg := wg) (w := w) (j := j) (t := t)
      (by simpa [a, b] using ht)
    have hExp : Real.exp ((50 : ℝ) * t) ≤ Real.exp ((50 : ℝ) * b) := by
      exact Real.exp_le_exp.mpr
        (mul_le_mul_of_nonneg_left ht.2 (by norm_num : (0 : ℝ) ≤ 50))
    exact le_trans (by simpa [sol] using hgate) hExp
  calc
    (∫ t in a..b, selectorMUHoffGateCoeff sol w t)
        ≤ ∫ _t in a..b, Real.exp ((50 : ℝ) * b) := by
          exact intervalIntegral.integral_mono_on hab
            (hcont.intervalIntegrable a b)
            (continuous_const.intervalIntegrable a b)
            hpoint
    _ = (b - a) * Real.exp ((50 : ℝ) * b) := by
          simp [intervalIntegral.integral_const]
    _ = (Real.pi / 6) * Real.exp ((50 : ℝ) * b) := by
          rw [show b - a = Real.pi / 6 by
            simp [a, b, selectorMUZOffEnd, selectorMUWriteStartTime]]

/-- Reset-weighted prewrite Hoff-gate factor.  This is the concrete discharge
needed for the reset-source part of the weighted Duhamel split. -/
theorem paper3HeadlinePrewriteResetGateFactor_le_pi_six_hoffRate
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
        (∫ t in selectorMUZOffEnd j..selectorMUWriteStartTime (j + 1),
          selectorMUHoffGateCoeff sol w t) ≤
      (Real.pi / 6) * paper3HoffRate j := by
  dsimp
  let sol := paper3HeadlineSolFam wg
  have hInt0 := paper3HeadlineHoffGateCoeff_prewrite_integral_le_exp_eighth
    (wg := wg) (w := w) (j := j)
  have hInt :
      (∫ t in selectorMUZOffEnd j..selectorMUWriteStartTime (j + 1),
          selectorMUHoffGateCoeff sol w t) ≤
        (Real.pi / 6) *
          Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1)) := by
    simpa [sol] using hInt0
  have hmul :
      Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          (∫ t in selectorMUZOffEnd j..selectorMUWriteStartTime (j + 1),
            selectorMUHoffGateCoeff sol w t) ≤
        Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          ((Real.pi / 6) *
            Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1))) :=
    mul_le_mul_of_nonneg_left hInt
      (Real.exp_pos (-(bgpParams38.cα * selectorMUZOffEnd j))).le
  refine le_trans hmul ?_
  have harg :
      -(bgpParams38.cα * selectorMUZOffEnd j) +
          (50 : ℝ) * selectorMUWriteStartTime (j + 1) ≤
        -paper3HoffExponent j := by
    have hπ_nonneg : 0 ≤ Real.pi := Real.pi_pos.le
    have hj_nonneg : 0 ≤ (j : ℝ) := by exact_mod_cast Nat.zero_le j
    norm_num [paper3HoffExponent, selectorMUZOffEnd,
      selectorMUWriteStartTime, bgpParams38]
    nlinarith [hπ_nonneg, hj_nonneg]
  calc
    Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
        ((Real.pi / 6) *
          Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1)))
        = (Real.pi / 6) *
            (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
              Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1))) := by
          ring_nf
    _ = (Real.pi / 6) *
          Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j) +
            (50 : ℝ) * selectorMUWriteStartTime (j + 1)) := by
          rw [← Real.exp_add]
    _ ≤ (Real.pi / 6) * Real.exp (-paper3HoffExponent j) := by
          exact mul_le_mul_of_nonneg_left (Real.exp_le_exp.mpr harg) (by positivity)

/-- Version of the reset-weighted gate factor with the headline Hoff rate
itself; `π/6 ≤ 1` absorbs the harmless interval-length constant. -/
theorem paper3HeadlinePrewriteResetGateFactor_le_hoffRate
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
        (∫ t in selectorMUZOffEnd j..selectorMUWriteStartTime (j + 1),
          selectorMUHoffGateCoeff sol w t) ≤
      paper3HoffRate j := by
  dsimp
  have h := paper3HeadlinePrewriteResetGateFactor_le_pi_six_hoffRate wg w j
  have hpi6 : Real.pi / 6 ≤ (1 : ℝ) := by
    nlinarith [Real.pi_lt_four]
  have hrate_nonneg : 0 ≤ paper3HoffRate j := (Real.exp_pos _).le
  exact le_trans (by simpa using h)
    (by simpa using mul_le_mul_of_nonneg_right hpi6 hrate_nonneg)

/-- The finite old/new bad-set source coefficient is nonnegative. -/
theorem paper3HeadlinePrewriteOldNewCreset_nonneg
    (w j : ℕ) :
    0 ≤
      (((Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
        (Fintype.card UniversalLocalView : ℝ)) := by
  have hden_pos : (0 : ℝ) < Fintype.card UniversalLocalView := by
    exact_mod_cast
      (Fintype.card_pos_iff.mpr ⟨defaultLocalViewU⟩ :
        0 < Fintype.card UniversalLocalView)
  exact div_nonneg (Nat.cast_nonneg _) hden_pos.le

/-- The finite old/new bad-set source coefficient is at most one. -/
theorem paper3HeadlinePrewriteOldNewCreset_le_one
    (w j : ℕ) :
    (((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)) ≤ 1 := by
  classical
  have hden_pos : (0 : ℝ) < Fintype.card UniversalLocalView := by
    exact_mod_cast
      (Fintype.card_pos_iff.mpr ⟨defaultLocalViewU⟩ :
        0 < Fintype.card UniversalLocalView)
  have hcard_le :
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card ≤
        Fintype.card UniversalLocalView := by
    exact Finset.card_le_univ _
  have hnum_le :
      ((Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) ≤
        (Fintype.card UniversalLocalView : ℝ) := by
    exact_mod_cast hcard_le
  calc
    (((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ))
        ≤ (Fintype.card UniversalLocalView : ℝ) /
            (Fintype.card UniversalLocalView : ℝ) := by
          exact div_le_div_of_nonneg_right hnum_le hden_pos.le
    _ = 1 := div_self hden_pos.ne'

/-- Algebraic discharge of the reset-source part of the prewrite Duhamel
split, conditional on a genuine reset-weighted Hoff-gate factor bound. -/
theorem paper3HeadlinePrewriteOldNewResetContribution_le_hoffRate_of_gateFactor
    (wg w j : ℕ) {Lsafe Cpre : ℝ}
    (hgapL_pos :
      0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        Lsafe)
    (hgateFactor :
      Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          (∫ t in selectorMUZOffEnd j..selectorMUWriteStartTime (j + 1),
            selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t) ≤
        Cpre * paper3HoffRate j) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUZOffEnd j
    let b : ℝ := selectorMUWriteStartTime (j + 1)
    let Creset : ℝ :=
      ((Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
        (Fintype.card UniversalLocalView : ℝ)
    let resetBd : ℝ :=
      (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
        (gap * Lsafe)
    resetBd * (∫ t in a..b, selectorMUHoffGateCoeff sol w t) ≤
      (Cpre / (gap * Lsafe)) * paper3HoffRate j := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let a : ℝ := selectorMUZOffEnd j
  let b : ℝ := selectorMUWriteStartTime (j + 1)
  let Creset : ℝ :=
    ((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)
  have hCreset_nonneg : 0 ≤ Creset := by
    simpa [Creset] using paper3HeadlinePrewriteOldNewCreset_nonneg w j
  have hCreset_le_one : Creset ≤ 1 := by
    simpa [Creset] using paper3HeadlinePrewriteOldNewCreset_le_one w j
  have hden_pos : 0 < gap * Lsafe := by
    simpa [gap] using hgapL_pos
  have hden_nonneg : 0 ≤ gap * Lsafe := hden_pos.le
  have hcoeff_le : Creset / (gap * Lsafe) ≤ 1 / (gap * Lsafe) :=
    div_le_div_of_nonneg_right hCreset_le_one hden_nonneg
  have hcoeff_nonneg : 0 ≤ Creset / (gap * Lsafe) :=
    div_nonneg hCreset_nonneg hden_nonneg
  have hone_div_nonneg : 0 ≤ 1 / (gap * Lsafe) :=
    div_nonneg zero_le_one hden_nonneg
  have hab : a ≤ b := by
    simpa [a, b] using selectorMUZOffEnd_le_writeStart_succ j
  have ha_nonneg : 0 ≤ a := by
    dsimp [a]
    unfold selectorMUZOffEnd
    positivity
  have hgateIntegral_nonneg :
      0 ≤ ∫ t in a..b, selectorMUHoffGateCoeff sol w t := by
    apply intervalIntegral.integral_nonneg hab
    intro t ht
    have ht_nonneg : 0 ≤ t := le_trans ha_nonneg ht.1
    dsimp [sol, selectorMUHoffGateCoeff]
    exact selector_replicator_gateZ_integrand_nonneg
      ((paper3HeadlineSolFam wg) w)
      selectorSchedule_domain_of_nonneg_structural
      (by norm_num [bgpParams38])
      ht_nonneg
  have hF_nonneg :
      0 ≤ Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
        (∫ t in a..b, selectorMUHoffGateCoeff sol w t) :=
    mul_nonneg (Real.exp_pos _).le hgateIntegral_nonneg
  have hgateFactor' :
      Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          (∫ t in a..b, selectorMUHoffGateCoeff sol w t) ≤
        Cpre * paper3HoffRate j := by
    simpa [sol, a, b] using hgateFactor
  have hmul :
      (Creset / (gap * Lsafe)) *
          (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
            (∫ t in a..b, selectorMUHoffGateCoeff sol w t)) ≤
        (1 / (gap * Lsafe)) * (Cpre * paper3HoffRate j) :=
    mul_le_mul hcoeff_le hgateFactor' hF_nonneg hone_div_nonneg
  calc
    ((Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
          (gap * Lsafe)) *
        (∫ t in a..b, selectorMUHoffGateCoeff sol w t)
        =
      (Creset / (gap * Lsafe)) *
        (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          (∫ t in a..b, selectorMUHoffGateCoeff sol w t)) := by
          field_simp [hden_pos.ne']
    _ ≤ (1 / (gap * Lsafe)) * (Cpre * paper3HoffRate j) := hmul
    _ = (Cpre / (gap * Lsafe)) * paper3HoffRate j := by
          field_simp [hden_pos.ne']

/-- Concrete reset-source contribution after discharging the prewrite
reset-weighted Hoff-gate factor. -/
theorem paper3HeadlinePrewriteOldNewResetContribution_le_hoffRate
    (wg w j : ℕ) {Lsafe : ℝ}
    (hgapL_pos :
      0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        Lsafe) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUZOffEnd j
    let b : ℝ := selectorMUWriteStartTime (j + 1)
    let Creset : ℝ :=
      ((Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
        (Fintype.card UniversalLocalView : ℝ)
    let resetBd : ℝ :=
      (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
        (gap * Lsafe)
    resetBd * (∫ t in a..b, selectorMUHoffGateCoeff sol w t) ≤
      (1 / (gap * Lsafe)) * paper3HoffRate j := by
  refine
    paper3HeadlinePrewriteOldNewResetContribution_le_hoffRate_of_gateFactor
      (wg := wg) (w := w) (j := j) (Lsafe := Lsafe) (Cpre := 1)
      hgapL_pos ?_
  simpa using paper3HeadlinePrewriteResetGateFactor_le_hoffRate wg w j

/-- The accumulated replicator gain is nondecreasing on the prewrite prefix. -/
theorem paper3HeadlinePrewrite_G_increment_nonneg
    (wg w j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1))) :
    0 ≤ ((paper3HeadlineSolFam wg) w).G t -
      ((paper3HeadlineSolFam wg) w).G (selectorMUZOffEnd j) := by
  let sol := paper3HeadlineSolFam wg
  let a : ℝ := selectorMUZOffEnd j
  have ha_nonneg : 0 ≤ a := by
    dsimp [a]
    unfold selectorMUZOffEnd
    positivity
  have hacc := selector_replicator_gain_accumulation (sol w) ht.1
    (fun _ : ℝ => (0 : ℝ))
    (fun s hs =>
      selectorSchedule_domain_of_nonneg_structural s
        (le_trans ha_nonneg hs.1))
    (by fun_prop)
    continuous_const
    (fun s _hs => by
      simpa [sol] using
        selector_replicator_chiGate_gain_nonneg
          (Mcy := paper3HeadlineM) (g₀ := paper3WarmGainQ wg)
          (paper3WarmGainQ_nonneg wg) s)
  simpa [a] using hacc

/-- Concrete transport contribution bound, once the `ZOffEnd` initial bad mass
has the same reset exponential factor as the prewrite source. -/
theorem paper3HeadlinePrewriteOldNewTransportContribution_le_hoffRate_of_initialResetBound
    (wg w j : ℕ) {B0 Lsafe C0 : ℝ}
    (hgapL_pos :
      0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        Lsafe)
    (hB0_nonneg : 0 ≤ B0)
    (hC0_nonneg : 0 ≤ C0)
    (hB0_reset :
      B0 ≤ C0 * Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j))) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUZOffEnd j
    let b : ℝ := selectorMUWriteStartTime (j + 1)
    B0 *
      (∫ τ in a..b,
        selectorMUHoffGateCoeff sol w τ *
          Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a)))) ≤
      C0 * paper3HoffRate j := by
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let a : ℝ := selectorMUZOffEnd j
  let b : ℝ := selectorMUWriteStartTime (j + 1)
  let k : ℝ → ℝ := fun τ => selectorMUHoffGateCoeff sol w τ
  let decay : ℝ → ℝ := fun τ =>
    Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a)))
  have hab : a ≤ b := by
    simpa [a, b] using selectorMUZOffEnd_le_writeStart_succ j
  have ha_nonneg : 0 ≤ a := by
    dsimp [a]
    unfold selectorMUZOffEnd
    positivity
  have hgapL_nonneg : 0 ≤ gap * Lsafe := by
    simpa [gap] using hgapL_pos.le
  have hk_cont : Continuous k := by
    dsimp [k, selectorMUHoffGateCoeff, sol]
    exact selector_replicator_gateZ_integrand_continuous
      ((paper3HeadlineSolFam wg) w)
  have hG_cont : Continuous fun τ : ℝ => (sol w).G τ := (sol w).cont_G
  have hsub_cont :
      Continuous fun τ : ℝ => (sol w).G τ - (sol w).G a :=
    hG_cont.sub continuous_const
  have hscaled_cont :
      Continuous fun τ : ℝ =>
        -((gap * Lsafe) * ((sol w).G τ - (sol w).G a)) :=
    (continuous_const.mul hsub_cont).neg
  have hdecay_cont : Continuous decay := by
    dsimp [decay]
    exact Real.continuous_exp.comp hscaled_cont
  have htransport_int : IntervalIntegrable (fun τ => k τ * decay τ)
      MeasureTheory.volume a b :=
    (hk_cont.mul hdecay_cont).intervalIntegrable a b
  have hgate_int : IntervalIntegrable k MeasureTheory.volume a b :=
    hk_cont.intervalIntegrable a b
  have hpoint : ∀ τ ∈ Icc a b, k τ * decay τ ≤ k τ := by
    intro τ hτ
    have hτ_nonneg : 0 ≤ τ := le_trans ha_nonneg hτ.1
    have hk_nonneg : 0 ≤ k τ := by
      dsimp [k, selectorMUHoffGateCoeff, sol]
      exact selector_replicator_gateZ_integrand_nonneg
        ((paper3HeadlineSolFam wg) w)
        selectorSchedule_domain_of_nonneg_structural
        (by norm_num [bgpParams38])
        hτ_nonneg
    have hGdiff :
        0 ≤ (sol w).G τ - (sol w).G a := by
      simpa [sol, a, b] using
        paper3HeadlinePrewrite_G_increment_nonneg
          (wg := wg) (w := w) (j := j) (t := τ)
          (by simpa [a, b] using hτ)
    have hmul_nonneg :
        0 ≤ (gap * Lsafe) * ((sol w).G τ - (sol w).G a) :=
      mul_nonneg hgapL_nonneg hGdiff
    have hdecay_le_one : decay τ ≤ 1 := by
      dsimp [decay]
      calc
        Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a)))
            ≤ Real.exp 0 := Real.exp_le_exp.mpr (by linarith)
        _ = 1 := Real.exp_zero
    exact mul_le_of_le_one_right hk_nonneg hdecay_le_one
  have htransport_le_gate :
      (∫ τ in a..b, k τ * decay τ) ≤ ∫ τ in a..b, k τ :=
    intervalIntegral.integral_mono_on hab htransport_int hgate_int hpoint
  have hgateIntegral_nonneg : 0 ≤ ∫ τ in a..b, k τ := by
    apply intervalIntegral.integral_nonneg hab
    intro τ hτ
    have hτ_nonneg : 0 ≤ τ := le_trans ha_nonneg hτ.1
    dsimp [k, selectorMUHoffGateCoeff, sol]
    exact selector_replicator_gateZ_integrand_nonneg
      ((paper3HeadlineSolFam wg) w)
      selectorSchedule_domain_of_nonneg_structural
      (by norm_num [bgpParams38])
      hτ_nonneg
  have hstep1 :
      B0 * (∫ τ in a..b, k τ * decay τ) ≤
        B0 * (∫ τ in a..b, k τ) :=
    mul_le_mul_of_nonneg_left htransport_le_gate hB0_nonneg
  have hstep2 :
      B0 * (∫ τ in a..b, k τ) ≤
        (C0 * Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j))) *
          (∫ τ in a..b, k τ) :=
    mul_le_mul_of_nonneg_right hB0_reset hgateIntegral_nonneg
  have hgateFactor :
      Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          (∫ τ in a..b, k τ) ≤ paper3HoffRate j := by
    simpa [k, sol, a, b] using
      paper3HeadlinePrewriteResetGateFactor_le_hoffRate wg w j
  have hstep3 :
      (C0 * Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j))) *
          (∫ τ in a..b, k τ) ≤
        C0 * paper3HoffRate j := by
    calc
      (C0 * Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j))) *
          (∫ τ in a..b, k τ)
          =
        C0 * (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          (∫ τ in a..b, k τ)) := by ring
      _ ≤ C0 * paper3HoffRate j :=
        mul_le_mul_of_nonneg_left hgateFactor hC0_nonneg
  calc
    B0 * (∫ τ in a..b, k τ * decay τ)
        ≤ B0 * (∫ τ in a..b, k τ) := hstep1
    _ ≤ (C0 * Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j))) *
        (∫ τ in a..b, k τ) := hstep2
    _ ≤ C0 * paper3HoffRate j := hstep3

/-- Prewrite old/new bad-mass Hoff integral in headline scalar form. -/
theorem paper3HeadlinePrewriteOldNewBadMassHoffIntegral_le_hoffRate
    (wg w j : ℕ)
    (hinit :
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => ((paper3HeadlineSolFam wg) w).lam v
            (selectorMUZOffEnd j)) ≤
        Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)))
    (hbad_half :
      ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => ((paper3HeadlineSolFam wg) w).lam v t) ≤ (1 / 2 : ℝ))
    (htubes :
      ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
        UTube r_LE_U (solMUReplStaticCfg w j)
          (((paper3HeadlineSolFam wg) w).u t) ∧
        UTube r_LE_U (solMUReplStaticCfg w (j + 1))
          (((paper3HeadlineSolFam wg) w).u t)) :
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    (∫ τ in (selectorMUZOffEnd j)..(selectorMUWriteStartTime (j + 1)),
      selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w τ *
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => ((paper3HeadlineSolFam wg) w).lam v τ)) ≤
      (1 + 1 / (gap * (1 / 2 : ℝ))) * paper3HoffRate j := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let a : ℝ := selectorMUZOffEnd j
  let b : ℝ := selectorMUWriteStartTime (j + 1)
  let Creset : ℝ :=
    ((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)
  let resetBd : ℝ :=
    (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
      (gap * (1 / 2 : ℝ))
  let prewriteBad : ℝ :=
    ∫ τ in a..b,
      selectorMUHoffGateCoeff sol w τ *
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => (sol w).lam v τ)
  let prewriteTransport : ℝ :=
    Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
      (∫ τ in a..b,
        selectorMUHoffGateCoeff sol w τ *
          Real.exp (-((gap * (1 / 2 : ℝ)) * ((sol w).G τ - (sol w).G a))))
  let prewriteReset : ℝ :=
    resetBd * (∫ τ in a..b, selectorMUHoffGateCoeff sol w τ)
  have hbad_floor :
      ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => ((paper3HeadlineSolFam wg) w).lam v t) ≤
          1 - (1 / 2 : ℝ) := by
    intro t ht
    have hhalf : (1 - (1 / 2 : ℝ)) = (1 / 2 : ℝ) := by norm_num
    rw [hhalf]
    exact hbad_half t ht
  have hsafe_floor :=
    paper3HeadlinePrewriteSafeMass_floor_of_badMass_le
      (wg := wg) (w := w) (j := j) (Lsafe := (1 / 2 : ℝ)) hbad_floor
  have hpair :=
    paper3HeadlinePrewrite_pairwiseGap_of_old_new_tubes
      (wg := wg) (w := w) (j := j) htubes
  have hduh :=
    paper3HeadlinePrewriteOldNewBadMassHoffIntegralDuhamelSplit
      (wg := wg) (w := w) (j := j)
      (B0 := Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)))
      (Lsafe := (1 / 2 : ℝ))
      paper3Headline_gap_mul_half_pos hsafe_floor hpair hinit
  have hduh' : prewriteBad ≤ prewriteTransport + prewriteReset := by
    simpa [prewriteBad, prewriteTransport, prewriteReset, resetBd, sol, gap,
      a, b, Creset, mul_assoc, mul_left_comm, mul_comm] using hduh
  have htransport :
      prewriteTransport ≤ paper3HoffRate j := by
    simpa [prewriteTransport, sol, gap, a, b, one_mul] using
      paper3HeadlinePrewriteOldNewTransportContribution_le_hoffRate_of_initialResetBound
        (wg := wg) (w := w) (j := j)
        (B0 := Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)))
        (Lsafe := (1 / 2 : ℝ)) (C0 := 1)
        paper3Headline_gap_mul_half_pos (Real.exp_pos _).le
        (by norm_num) (by simp)
  have hreset :
      prewriteReset ≤ (1 / (gap * (1 / 2 : ℝ))) * paper3HoffRate j := by
    simpa [prewriteReset, resetBd, sol, gap, a, b, Creset] using
      paper3HeadlinePrewriteOldNewResetContribution_le_hoffRate
        (wg := wg) (w := w) (j := j) (Lsafe := (1 / 2 : ℝ))
        paper3Headline_gap_mul_half_pos
  have hpre :
      prewriteBad ≤
        paper3HoffRate j +
          (1 / (gap * (1 / 2 : ℝ))) * paper3HoffRate j := by
    nlinarith [hduh', htransport, hreset]
  calc
    (∫ τ in (selectorMUZOffEnd j)..(selectorMUWriteStartTime (j + 1)),
      selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w τ *
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => ((paper3HeadlineSolFam wg) w).lam v τ))
        = prewriteBad := by simp [prewriteBad, sol, a, b]
    _ ≤ paper3HoffRate j +
          (1 / (gap * (1 / 2 : ℝ))) * paper3HoffRate j := hpre
    _ = (1 + 1 / (gap * (1 / 2 : ℝ))) * paper3HoffRate j := by ring

/-- The write-start reset-tail decay is pointwise below the Hoff exponential
rate up to the fixed factor `exp (π/16)`. -/
theorem paper3Headline_resetTail_decay_le_hoffRate
    (j : ℕ) :
    Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime j)) ≤
      Real.exp (Real.pi / 16) * paper3HoffRate j := by
  rw [paper3HoffRate, ← Real.exp_add]
  refine Real.exp_le_exp.mpr ?_
  have hj : 0 ≤ (j : ℝ) := by exact_mod_cast Nat.zero_le j
  have hpi : 0 ≤ Real.pi := Real.pi_pos.le
  norm_num [paper3HoffExponent, selectorMUWriteStartTime, bgpParams38]
  nlinarith [mul_nonneg hpi hj]

/-- The reset-tail comparison after division by the positive selector gap. -/
theorem paper3Headline_resetTail_div_gap_decay_le_hoffRate
    (j : ℕ) :
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime j)) / gap ≤
      (Real.exp (Real.pi / 16) / gap) * paper3HoffRate j := by
  dsimp
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have h := paper3Headline_resetTail_decay_le_hoffRate j
  have hmul :=
    mul_le_mul_of_nonneg_right h (inv_nonneg.mpr hgap_pos.le)
  simpa [gap, div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using hmul

/-- The full active reset-source Duhamel convolution has a q-free
`L^2(activeCg dt)` bound on the select-to-hold interval.  This is the square
replacement for the coarse reset-tail absorber: it uses the Duhamel
cancellation before taking any active-gain integral supremum. -/
theorem paper3Headline_activeResetDuhamel_cg_square_le_hoffRate
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let S : ℝ := selectorMUSelectStartTime (j + 1)
    let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
    let Csq : ℝ :=
      (Real.exp (Real.pi / 16) / gap) * ((1 / gap) * (Real.pi / 3))
    (∫ τ in S..Htime,
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
        (((∫ s in S..τ,
          Real.exp (gap * ((sol w).G s - (sol w).G S)) *
            selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s) *
          Real.exp (-(gap * ((sol w).G τ - (sol w).G S)))) ^ 2)) ≤
      Csq * paper3HoffRate j := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let S : ℝ := selectorMUSelectStartTime (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let cg : ℝ → ℝ := fun τ =>
    selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  let reset : ℝ → ℝ := fun τ =>
    selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ
  let C : ℝ := Real.exp (-(bgpParams38.cα * S))
  let R : ℝ := ∫ s in S..Htime, reset s
  let Hrate : ℝ := paper3HoffRate j
  let Csq : ℝ :=
    (Real.exp (Real.pi / 16) / gap) * ((1 / gap) * (Real.pi / 3))
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hSH : S ≤ Htime := by
    exact le_of_lt (by
      simpa [S, Htime] using selectorMUSelectStart_lt_hold (j + 1))
  have hS_nonneg : 0 ≤ S := by
    exact le_trans (selectorMUWriteStartTime_nonneg (j + 1))
      (by simpa [S] using selectorMUWriteStart_le_selectStart (j + 1))
  have hG_cont : Continuous fun τ : ℝ => (sol w).G τ := (sol w).cont_G
  have hGder : ∀ τ ∈ Icc S Htime, HasDerivAt (sol w).G (cg τ) τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans hS_nonneg hτ.1
    simpa [cg, sol] using
      (sol w).G_hasDeriv τ (solMURepl_static_hdom_nonneg τ hτ0)
  have hcg_cont : Continuous cg := by
    simpa [cg] using
      selectorMU_activeCg_continuous paper3HeadlineM (paper3WarmGainQ wg)
  have hreset_cont : Continuous reset := by
    dsimp [reset, selectorMU_activeCr]
    fun_prop
  have hcg_nonneg : ∀ τ ∈ Icc S Htime, 0 ≤ cg τ := by
    intro τ _hτ
    dsimp [cg, selectorMU_activeCg]
    have hsin_base_nonneg : 0 ≤ (1 + Real.sin τ) / 2 := by
      nlinarith [Real.neg_one_le_sin τ]
    exact mul_nonneg (pow_nonneg hsin_base_nonneg paper3HeadlineM)
      (mul_nonneg (paper3WarmGainQ_pos wg).le (Real.exp_pos _).le)
  have hreset_nonneg : ∀ τ ∈ Icc S Htime, 0 ≤ reset τ := by
    intro τ _hτ
    dsimp [reset, selectorMU_activeCr]
    have hcos_base_nonneg : 0 ≤ (1 + Real.cos τ) / 2 := by
      nlinarith [Real.neg_one_le_cos τ]
    exact mul_nonneg (pow_nonneg hcos_base_nonneg paper3HeadlineM)
      (by norm_num [paper3HeadlineKappa])
  have hC_nonneg : 0 ≤ C := by
    dsimp [C]
    exact (Real.exp_pos _).le
  have hreset_bound : ∀ τ ∈ Icc S Htime, reset τ ≤ C * cg τ := by
    intro τ hτ
    simpa [reset, cg, C, S, Htime] using
      paper3HeadlineActive_reset_le_selectStartDecay_mul_activeCg
        (wg := wg) (j := j + 1) (t := τ) hτ
  have hsquare_raw :=
    forward_prefix_reset_decay_square_integral_le
      (a := S) (b := Htime) (gap := gap) (C := C)
      (G := (sol w).G) (cg := cg) (reset := reset)
      hSH hgap_pos hC_nonneg hG_cont hGder hcg_cont hreset_cont
      hcg_nonneg hreset_nonneg hreset_bound
  have hR_nonneg : 0 ≤ R := by
    dsimp [R]
    exact intervalIntegral.integral_nonneg hSH hreset_nonneg
  have hR_le : R ≤ Real.pi / 3 := by
    have hpoint : ∀ s ∈ Icc S Htime, reset s ≤ (1 : ℝ) := by
      intro s _hs
      have hcos_base_nonneg : 0 ≤ (1 + Real.cos s) / 2 := by
        nlinarith [Real.neg_one_le_cos s]
      have hcos_base_le_one : (1 + Real.cos s) / 2 ≤ 1 := by
        nlinarith [Real.cos_le_one s]
      have hpow :
          ((1 + Real.cos s) / 2) ^ paper3HeadlineM ≤ 1 :=
        pow_le_one₀ hcos_base_nonneg hcos_base_le_one
      simpa [reset, selectorMU_activeCr, paper3HeadlineKappa] using hpow
    have hconst :
        (∫ _s in S..Htime, (1 : ℝ)) = Htime - S := by
      simp [intervalIntegral.integral_const]
    have hlen : Htime - S ≤ Real.pi / 3 := by
      have hlen_eq :
          Htime - S = Real.pi / 3 - selectorMURecoveryDelta := by
        dsimp [Htime, S, selectorMUWriteHoldTime, selectorMUSelectStartTime,
          selectorMUWriteStartTime]
        ring
      rw [hlen_eq]
      linarith [selectorMURecoveryDelta_pos.le]
    calc
      R ≤ ∫ _s in S..Htime, (1 : ℝ) := by
        exact intervalIntegral.integral_mono_on hSH
          (hreset_cont.intervalIntegrable S Htime)
          (continuous_const.intervalIntegrable S Htime) hpoint
      _ = Htime - S := hconst
      _ ≤ Real.pi / 3 := hlen
  have hC_le : C ≤ Real.exp (Real.pi / 16) * Hrate := by
    let W : ℝ := selectorMUWriteStartTime (j + 1)
    have hα_nonneg : 0 ≤ bgpParams38.cα := by
      norm_num [bgpParams38]
    have hW_le_S : W ≤ S := by
      simpa [W, S] using selectorMUWriteStart_le_selectStart (j + 1)
    have hmul : bgpParams38.cα * W ≤ bgpParams38.cα * S :=
      mul_le_mul_of_nonneg_left hW_le_S hα_nonneg
    have hselect_decay :
        C ≤ Real.exp (-(bgpParams38.cα * W)) := by
      dsimp [C]
      exact Real.exp_le_exp.mpr (by linarith)
    have hwrite :
        Real.exp (-(bgpParams38.cα * W)) ≤
          Real.exp (Real.pi / 16) * paper3HoffRate (j + 1) := by
      simpa [W] using paper3Headline_resetTail_decay_le_hoffRate (j + 1)
    have hsucc :
        Real.exp (Real.pi / 16) * paper3HoffRate (j + 1) ≤
          Real.exp (Real.pi / 16) * Hrate := by
      exact mul_le_mul_of_nonneg_left (paper3HoffRate_succ_le j)
        (Real.exp_pos _).le
    exact hselect_decay.trans (hwrite.trans hsucc)
  have hleft_le :
      C / gap ≤ (Real.exp (Real.pi / 16) * Hrate) / gap :=
    div_le_div_of_nonneg_right hC_le hgap_pos.le
  have hright_le :
      (1 / gap) * R ≤ (1 / gap) * (Real.pi / 3) :=
    mul_le_mul_of_nonneg_left hR_le (by positivity)
  have hright_nonneg : 0 ≤ (1 / gap) * R :=
    mul_nonneg (by positivity) hR_nonneg
  have hleft_target_nonneg :
      0 ≤ (Real.exp (Real.pi / 16) * Hrate) / gap := by
    exact div_nonneg
      (mul_nonneg (Real.exp_pos _).le (by dsimp [Hrate, paper3HoffRate]; positivity))
      hgap_pos.le
  have hprod :
      (C / gap) * ((1 / gap) * R) ≤
        ((Real.exp (Real.pi / 16) * Hrate) / gap) *
          ((1 / gap) * (Real.pi / 3)) :=
    mul_le_mul hleft_le hright_le hright_nonneg hleft_target_nonneg
  calc
    (∫ τ in S..Htime,
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
        (((∫ s in S..τ,
          Real.exp (gap * ((sol w).G s - (sol w).G S)) *
            selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s) *
          Real.exp (-(gap * ((sol w).G τ - (sol w).G S)))) ^ 2))
        ≤ (C / gap) * ((1 / gap) * R) := by
          simpa [sol, gap, S, Htime, cg, reset, C, R] using hsquare_raw.2
    _ ≤ ((Real.exp (Real.pi / 16) * Hrate) / gap) *
          ((1 / gap) * (Real.pi / 3)) := hprod
    _ = Csq * Hrate := by
          dsimp [Csq]
          ring

/-- Active reset-source Duhamel square bound restricted to the active suffix
`[E,H]`.  It is the `[S,H]` source estimate plus nonnegative interval
monotonicity. -/
theorem paper3Headline_activeResetDuhamel_cg_square_suffix_le_hoffRate
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let S : ℝ := selectorMUSelectStartTime (j + 1)
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
    let Csq : ℝ :=
      (Real.exp (Real.pi / 16) / gap) * ((1 / gap) * (Real.pi / 3))
    (∫ τ in E..Htime,
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
        (((∫ s in S..τ,
          Real.exp (gap * ((sol w).G s - (sol w).G S)) *
            selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s) *
          Real.exp (-(gap * ((sol w).G τ - (sol w).G S)))) ^ 2)) ≤
      Csq * paper3HoffRate j := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let S : ℝ := selectorMUSelectStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let cg : ℝ → ℝ := fun τ =>
    selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  let source : ℝ → ℝ := fun τ =>
    (∫ s in S..τ,
      Real.exp (gap * ((sol w).G s - (sol w).G S)) *
        selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s) *
      Real.exp (-(gap * ((sol w).G τ - (sol w).G S)))
  let squareFun : ℝ → ℝ := fun τ => cg τ * (source τ) ^ 2
  let Csq : ℝ :=
    (Real.exp (Real.pi / 16) / gap) * ((1 / gap) * (Real.pi / 3))
  have hSE : S ≤ E := by
    simpa [S, E] using selectorMUSelectStart_le_earlySubStart (j + 1)
  have hEH : E ≤ Htime := by
    simpa [E, Htime] using selectorMUEarlySubStart_le_writeHold (j + 1)
  have hSH : S ≤ Htime := le_trans hSE hEH
  have hG_cont : Continuous fun τ : ℝ => (sol w).G τ := (sol w).cont_G
  have hcg_cont : Continuous cg := by
    simpa [cg] using
      selectorMU_activeCg_continuous paper3HeadlineM (paper3WarmGainQ wg)
  have hreset_cont : Continuous fun s : ℝ =>
      Real.exp (gap * ((sol w).G s - (sol w).G S)) *
        selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s := by
    dsimp [selectorMU_activeCr]
    fun_prop
  have hK_cont : Continuous fun τ : ℝ =>
      ∫ s in S..τ,
        Real.exp (gap * ((sol w).G s - (sol w).G S)) *
          selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s := by
    exact continuous_iff_continuousAt.mpr fun τ =>
      (intervalIntegral.integral_hasDerivAt_right
        (hreset_cont.intervalIntegrable S τ)
        (hreset_cont.stronglyMeasurableAtFilter _ _)
        hreset_cont.continuousAt).continuousAt
  have hsource_cont : Continuous source := by
    dsimp [source]
    exact hK_cont.mul
      (Real.continuous_exp.comp
        ((continuous_const.mul (hG_cont.sub continuous_const)).neg))
  have hsquare_cont : Continuous squareFun := by
    dsimp [squareFun]
    exact hcg_cont.mul (hsource_cont.pow 2)
  have hsource_nonneg_ae :
      0 ≤ᵐ[MeasureTheory.volume.restrict (Ioc S Htime)] squareFun := by
    filter_upwards [MeasureTheory.ae_restrict_mem measurableSet_Ioc] with τ hτ
    have hcg_nonneg : 0 ≤ cg τ := by
      dsimp [cg, selectorMU_activeCg]
      have hsin_base_nonneg : 0 ≤ (1 + Real.sin τ) / 2 := by
        nlinarith [Real.neg_one_le_sin τ]
      exact mul_nonneg (pow_nonneg hsin_base_nonneg paper3HeadlineM)
        (mul_nonneg (paper3WarmGainQ_pos wg).le (Real.exp_pos _).le)
    dsimp [squareFun]
    exact mul_nonneg hcg_nonneg (sq_nonneg _)
  have hsub :
      (∫ τ in E..Htime, squareFun τ) ≤ ∫ τ in S..Htime, squareFun τ := by
    apply intervalIntegral.integral_mono_interval
    · exact hSE
    · exact hEH
    · exact le_rfl
    · exact hsource_nonneg_ae
    · exact hsquare_cont.intervalIntegrable S Htime
  have hfull :=
    paper3Headline_activeResetDuhamel_cg_square_le_hoffRate wg w j
  exact le_trans
    (by simpa [sol, gap, S, E, Htime, cg, source, squareFun] using hsub)
    (by simpa [sol, gap, S, Htime, Csq] using hfull)

