  · exact hz_piece1_abs t ⟨ht.1, htT⟩ i
  · exact hz_piece2_abs t ⟨le_of_lt (lt_of_not_ge htT), ht.2⟩ i

theorem paper3S2_handoff_mz2_NW (w j : ℕ) {δs M1 : ℝ}
    (hδs0 : 0 ≤ δs) (hδs_le : δs ≤ r_LE_U / 5)
    (hM10 : 0 ≤ M1) (hM1_le : M1 ≤ r_LE_U / 5)
    (hz_b : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤ δs)
    (hmix1 : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
        (2 * Real.pi * (j : ℝ) + Real.pi),
      ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
            ((paper3HeadlineSolFamNW w) w).lam t i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤ M1) :
    ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + Real.pi)
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6),
      ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
            ((paper3HeadlineSolFamNW w) w).lam t i -
          ((paper3HeadlineSolFamNW w) w).z t i| ≤
            paper3S2HandoffMixZGuard := by
  have hbT : 2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6 ≤
      2 * Real.pi * (j : ℝ) + Real.pi := by
    linarith [Real.pi_pos]
  have hT0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + Real.pi := by
    positivity
  have hCzCu : paper3S2HandoffCz ≤ paper3S2HandoffCu := by
    unfold paper3S2HandoffCz paper3S2HandoffCu
    linarith
  have hz_box := paper3S2_handoff_z_box_NW w j
    hδs0 hδs_le hM10 hM1_le hz_b hmix1
  have hu_box : ∀ t ∈ Icc
      (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6),
      ∀ k : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).u t k| ≤ paper3S2HandoffCu := by
    intro t ht k
    exact paper3NW_S2_handoff_u_box w w j k
      (Cz := paper3S2HandoffCz) (Cu := paper3S2HandoffCu)
      hCzCu (paper3S2_handoff_u_b_abs_NW w j k)
      (fun τ hτ => hz_box τ hτ k) t ht
  intro t ht i
  have ht_full : t ∈ Icc
      (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) :=
    ⟨le_trans hbT ht.1, ht.2⟩
  exact paper3S2_handoff_mixz_abs_le_guard w j
    (le_trans hT0 ht.1) (fun k => hu_box t ht_full k) i
    (hz_box t ht_full i)

/-- A finite coordinate box on `u` gives a uniform absolute branch-evaluation
box.  This is the plain affine Lipschitz bound for `branchU`; unlike
`branchU_evalBranch_abs_le_two_D_U`, it does not assume an encoding tube. -/
theorem paper3Headline_branchU_eval_abs_le_of_u_abs_box
    {Ubox : ℝ} (hUbox : 0 ≤ Ubox) :
    ∃ B : ℝ, 2 * D_U ≤ B ∧
      ∀ x : Fin d_U → ℝ,
        (∀ i : Fin d_U, |x i| ≤ Ubox) ->
        ∀ i : Fin d_U, ∀ v : UniversalLocalView,
          |BranchData.evalBranch (branchU v) x i| ≤ B := by
  classical
  let term : UniversalLocalView → Fin d_U → ℝ := fun v i =>
    |BranchData.evalBranch (branchU v) (fun _ => (0 : ℝ)) i| +
      BranchAction.multiplier B_U ((branchU v).action i) * Ubox
  let B0 : ℝ := ∑ v : UniversalLocalView, ∑ i : Fin d_U, term v i
  have hterm_nonneg :
      ∀ v : UniversalLocalView, ∀ i : Fin d_U, 0 ≤ term v i := by
    intro v i
    exact add_nonneg (abs_nonneg _)
      (mul_nonneg
        (by
          simpa [BranchAction.multiplier] using
            abs_nonneg (((branchU v).action i).scale : ℝ))
        hUbox)
  have hB0_nonneg : 0 ≤ B0 := by
    dsimp [B0]
    exact Finset.sum_nonneg (fun v _ =>
      Finset.sum_nonneg (fun i _ => hterm_nonneg v i))
  refine ⟨2 * D_U + B0, ?_, ?_⟩
  · nlinarith [D_U_nonneg, hB0_nonneg]
  · intro x hx i v
    let a := BranchData.evalBranch (branchU v) x i
    let b := BranchData.evalBranch (branchU v) (fun _ => (0 : ℝ)) i
    let m := BranchAction.multiplier B_U ((branchU v).action i)
    have hm_nonneg : 0 ≤ m := by
      simpa [m, BranchAction.multiplier] using
        abs_nonneg (((branchU v).action i).scale : ℝ)
    have hlip : |a - b| ≤ m * |x i - (0 : ℝ)| := by
      simpa [a, b, m] using
        BranchData.coord_lipschitz (by norm_num [B_U])
          (branchU v) x (fun _ => (0 : ℝ)) i
    have hbranch :
        |a| ≤ |b| + m * Ubox := by
      calc
        |a| = |(a - b) + b| := by congr 1; ring
        _ ≤ |a - b| + |b| := abs_add_le _ _
        _ ≤ m * |x i - (0 : ℝ)| + |b| := by
          linarith [hlip]
        _ ≤ m * Ubox + |b| := by
          have hx0 : |x i - (0 : ℝ)| ≤ Ubox := by
            simpa using hx i
          nlinarith [mul_le_mul_of_nonneg_left hx0 hm_nonneg]
        _ = |b| + m * Ubox := by ring
    have hterm_le_B0 : term v i ≤ B0 := by
      have hinner :
          term v i ≤ ∑ j : Fin d_U, term v j :=
        Finset.single_le_sum
          (fun j _ => hterm_nonneg v j) (Finset.mem_univ i)
      have houter :
          (∑ j : Fin d_U, term v j) ≤ B0 := by
        dsimp [B0]
        exact Finset.single_le_sum
          (fun v' _ =>
            Finset.sum_nonneg (fun j _ => hterm_nonneg v' j))
          (Finset.mem_univ v)
      exact hinner.trans houter
    have hterm_eq : term v i = |b| + m * Ubox := rfl
    calc
      |BranchData.evalBranch (branchU v) x i| = |a| := rfl
      _ ≤ |b| + m * Ubox := hbranch
      _ = term v i := by rw [hterm_eq]
      _ ≤ B0 := hterm_le_B0
      _ ≤ 2 * D_U + B0 := by nlinarith [D_U_nonneg]

/-- Existing finite-horizon `z/u` a-priori bounds discharge the all-prefix
branch-coordinate box needed by the `z` trapping route.

The endpoint `t = 0` is handled from the concrete initial encoding; positive
times use `paper3HeadlineSolFam_ZUFiniteCoordBound` on the slightly larger
horizon `writeStart + 1`. -/
theorem paper3Headline_prefix_branch_abs_box
    (wg w j : ℕ) :
    ∃ B : ℝ, 2 * D_U ≤ B ∧
      ∀ t,
        t ∈ Icc (0 : ℝ) (selectorMUWriteStartTime (j + 1)) ->
        ∀ i : Fin d_U, ∀ v : UniversalLocalView,
          |BranchData.evalBranch (branchU v)
              (((paper3HeadlineSolFam wg) w).u t) i| ≤ B := by
  classical
  let S : ℝ := selectorMUWriteStartTime (j + 1)
  let T : ℝ := S + 1
  have hS_nonneg : 0 ≤ S := by
    simpa [S] using selectorMUWriteStartTime_nonneg (j + 1)
  have hT_pos : 0 < T := by
    dsimp [T]
    linarith
  rcases paper3HeadlineSolFam_ZUFiniteCoordBound wg w T hT_pos with
    ⟨M, hM_pos, hzu⟩
  let Ubox : ℝ := max M (2 * D_U)
  have hUbox_nonneg : 0 ≤ Ubox := le_trans hM_pos.le (le_max_left M (2 * D_U))
  rcases paper3Headline_branchU_eval_abs_le_of_u_abs_box
      (Ubox := Ubox) hUbox_nonneg with
    ⟨B, hB_init, hbranch_of_u⟩
  refine ⟨B, hB_init, ?_⟩
  intro t ht
  apply hbranch_of_u
  intro i
  rcases eq_or_lt_of_le ht.1 with ht_zero | ht_pos
  · subst t
    have hu0 := (paper3HeadlineSolFam_initial_values wg w).2.1 i
    rw [hu0]
    exact (paper3Headline_init_z_abs_le_two_D_U w i).trans
      (le_max_right M (2 * D_U))
  · have htT : t ∈ Ico (0 : ℝ) T := by
      refine ⟨ht_pos.le, ?_⟩
      dsimp [T, S]
      linarith [ht.2]
    exact (hzu t htT i).2.trans (le_max_left M (2 * D_U))

/-- Fully internal finite-horizon producer for the write-start `z` absolute
box.  The constant is intentionally existential and coarse; the point is that
the remaining prefix branch condition is now discharged by the existing
finite-coordinate a-priori bound, not by write-window UTube or `Bpre`. -/
theorem paper3Headline_writeStart_z_abs_le_of_finite_coord_bound
    (wg w j : ℕ) :
    ∃ B : ℝ, 2 * D_U ≤ B ∧
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFam wg) w).z
            (selectorMUWriteStartTime (j + 1)) i| ≤ B := by
  rcases paper3Headline_prefix_branch_abs_box wg w j with
    ⟨B, hB_init, hbranch_abs⟩
  exact ⟨B, hB_init,
    paper3Headline_writeStart_z_abs_le_of_branch_abs_on_prefix
      (wg := wg) (w := w) (j := j) (B := B) hB_init hbranch_abs⟩

/-- Prefix branch boxes also give a coarse all-coordinate inter-read amplitude
for the z-source term.  This is finite-horizon and intentionally coarse; it
discharges the local `mixTarget-z` boundedness condition without adding a new
residual assumption. -/
theorem paper3Headline_interRead_mixTarget_sub_z_abs_le_of_branch_abs_on_prefix
    (wg w j : ℕ) {B : ℝ}
    (hinit_le : 2 * D_U ≤ B)
    (hbranch_abs : ∀ t,
      t ∈ Icc (0 : ℝ) (selectorMUWriteStartTime (j + 1)) ->
      ∀ i : Fin d_U, ∀ v : UniversalLocalView,
        |BranchData.evalBranch (branchU v)
            (((paper3HeadlineSolFam wg) w).u t) i| ≤ B) :
    ∀ τ ∈ Icc (selectorMUWriteReadTime j)
        (selectorMUWriteStartTime (j + 1)), ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
          ((paper3HeadlineSolFam wg) w).lam τ i -
        ((paper3HeadlineSolFam wg) w).z τ i| ≤ 2 * B := by
  intro τ hτ i
  have hB0 : 0 ≤ B := by
    have hD0 : 0 ≤ 2 * D_U := mul_nonneg (by norm_num) D_U_nonneg
    exact le_trans hD0 hinit_le
  have hτ0 : 0 ≤ τ := by
    exact le_trans
      (le_trans (selectorMUWriteStartTime_nonneg j)
        (selectorMUWriteStart_le_read j)) hτ.1
  have hτ_prefix :
      τ ∈ Icc (0 : ℝ) (selectorMUWriteStartTime (j + 1)) :=
    ⟨hτ0, hτ.2⟩
  have hmix_abs_prefix :
      ∀ t,
        t ∈ Icc (0 : ℝ) (selectorMUWriteStartTime (j + 1)) ->
        ∀ i : Fin d_U,
          |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
              ((paper3HeadlineSolFam wg) w).lam t i| ≤ B :=
    paper3Headline_selectorMixTarget_abs_le_of_branch_abs_on_prefix
      (wg := wg) (w := w) (j := j) hbranch_abs
  have hmix_abs :
      |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
          ((paper3HeadlineSolFam wg) w).lam τ i| ≤ B :=
    hmix_abs_prefix τ hτ_prefix i
  have hz_abs :
      |((paper3HeadlineSolFam wg) w).z τ i| ≤ B := by
    refine
      paper3Headline_z_abs_le_of_mix_abs_box
        (wg := wg) (w := w) (T := τ) (Zbox := B) hτ0 ?_ ?_ i
    · intro k
      exact (paper3Headline_init_z_abs_le_two_D_U w k).trans hinit_le
    · intro s hs k
      exact hmix_abs_prefix s ⟨hs.1, le_trans hs.2 hτ_prefix.2⟩ k
  calc
    |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
        ((paper3HeadlineSolFam wg) w).lam τ i -
      ((paper3HeadlineSolFam wg) w).z τ i|
        ≤ |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
              ((paper3HeadlineSolFam wg) w).lam τ i| +
          |((paper3HeadlineSolFam wg) w).z τ i| := by
            simpa [sub_eq_add_neg, abs_neg] using
              abs_add_le
                (selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
                  ((paper3HeadlineSolFam wg) w).lam τ i)
                (-((paper3HeadlineSolFam wg) w).z τ i)
    _ ≤ B + B := add_le_add hmix_abs hz_abs
    _ = 2 * B := by ring

theorem paper3Headline_interRead_mixTarget_sub_z_abs_le_of_finite_coord_bound
    (wg w j : ℕ) :
    ∃ Bamp : ℝ, 0 ≤ Bamp ∧
      ∀ τ ∈ Icc (selectorMUWriteReadTime j)
          (selectorMUWriteStartTime (j + 1)), ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
            ((paper3HeadlineSolFam wg) w).lam τ i -
          ((paper3HeadlineSolFam wg) w).z τ i| ≤ Bamp := by
  rcases paper3Headline_prefix_branch_abs_box wg w j with
    ⟨B, hB_init, hbranch_abs⟩
  have hB0 : 0 ≤ B := by
    have hD0 : 0 ≤ 2 * D_U := mul_nonneg (by norm_num) D_U_nonneg
    exact le_trans hD0 hB_init
  refine ⟨2 * B, mul_nonneg (by norm_num) hB0, ?_⟩
  exact
    paper3Headline_interRead_mixTarget_sub_z_abs_le_of_branch_abs_on_prefix
      (wg := wg) (w := w) (j := j) (B := B) hB_init hbranch_abs

theorem
    paper3Headline_interRead_sourceCap_le_const_hoffRate_of_eventually_exp_amp
    (wg w : ℕ) {Camp a : ℝ}
    (hCamp_nonneg : 0 ≤ Camp)
    (hamp_eventually :
      ∀ᶠ j in atTop,
        ∀ τ ∈ Icc (selectorMUWriteReadTime j)
            (selectorMUWriteStartTime (j + 1)), ∀ i : Fin d_U,
          |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
              ((paper3HeadlineSolFam wg) w).lam τ i -
            ((paper3HeadlineSolFam wg) w).z τ i| ≤
              Camp * Real.exp (a * selectorMUWriteStartTime (j + 1))) :
    ∃ Csrc : ℝ, 0 ≤ Csrc ∧ ∀ j : ℕ,
      ∃ Bamp : ℝ,
        0 ≤ Bamp ∧
        (∀ τ ∈ Icc (selectorMUWriteReadTime j)
            (selectorMUWriteStartTime (j + 1)), ∀ i : Fin d_U,
          |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
              ((paper3HeadlineSolFam wg) w).lam τ i -
            ((paper3HeadlineSolFam wg) w).z τ i| ≤ Bamp) ∧
        Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            selectorInterReadSourceCap Bamp j ≤
          Csrc * paper3HoffRate j := by
  classical
  let Benv : ℕ → ℝ := fun j =>
    Camp * Real.exp (a * selectorMUWriteStartTime (j + 1))
  have hBenv_nonneg : ∀ j : ℕ, 0 ≤ Benv j := by
    intro j
    dsimp [Benv]
    exact mul_nonneg hCamp_nonneg (Real.exp_pos _).le
  rcases
    paper3Headline_interReadSourceCap_le_const_hoffRate_of_eventually_exp_writeStart_bound
      Benv hCamp_nonneg hBenv_nonneg
      (Filter.Eventually.of_forall (fun j => by rfl)) with
    ⟨Cenv, hCenv_nonneg, henv_source⟩
  rcases Filter.eventually_atTop.mp hamp_eventually with ⟨N, hNamp⟩
  let Bpre : ℕ → ℝ := fun j =>
    Classical.choose
      (paper3Headline_interRead_mixTarget_sub_z_abs_le_of_finite_coord_bound
        wg w j)
  have hBpre_spec :
      ∀ j : ℕ,
        0 ≤ Bpre j ∧
        ∀ τ ∈ Icc (selectorMUWriteReadTime j)
            (selectorMUWriteStartTime (j + 1)), ∀ i : Fin d_U,
          |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
              ((paper3HeadlineSolFam wg) w).lam τ i -
            ((paper3HeadlineSolFam wg) w).z τ i| ≤ Bpre j := by
    intro j
    dsimp [Bpre]
    exact
      Classical.choose_spec
        (paper3Headline_interRead_mixTarget_sub_z_abs_le_of_finite_coord_bound
          wg w j)
  let prefixRatio : ℕ → ℝ := fun j =>
    (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
      selectorInterReadSourceCap (Bpre j) j) / paper3HoffRate j
  let Cprefix : ℝ := (Finset.range N).sum prefixRatio
  have hprefix_nonneg : 0 ≤ Cprefix := by
    dsimp [Cprefix, prefixRatio]
    exact Finset.sum_nonneg (fun j _hj =>
      div_nonneg
        (mul_nonneg (Real.exp_pos _).le
          (selectorInterReadSourceCap_nonneg (hBpre_spec j).1 j))
        (paper3HoffRate_pos j).le)
  let Csrc : ℝ := Cenv + Cprefix
  refine ⟨Csrc, by dsimp [Csrc]; nlinarith, ?_⟩
  intro j
  by_cases hj : j < N
  · refine ⟨Bpre j, (hBpre_spec j).1, (hBpre_spec j).2, ?_⟩
    have hjmem : j ∈ Finset.range N := by
      simpa using hj
    have hterm_nonneg :
        ∀ k ∈ Finset.range N, 0 ≤ prefixRatio k := by
      intro k _hk
      dsimp [prefixRatio]
      exact div_nonneg
        (mul_nonneg (Real.exp_pos _).le
          (selectorInterReadSourceCap_nonneg (hBpre_spec k).1 k))
        (paper3HoffRate_pos k).le
    have hratio_le : prefixRatio j ≤ Cprefix := by
      dsimp [Cprefix]
      exact Finset.single_le_sum hterm_nonneg hjmem
    have hmul :=
      mul_le_mul_of_nonneg_right hratio_le (paper3HoffRate_pos j).le
    have hcancel :
        prefixRatio j * paper3HoffRate j =
          Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            selectorInterReadSourceCap (Bpre j) j := by
      dsimp [prefixRatio]
      field_simp [(paper3HoffRate_pos j).ne']
    calc
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap (Bpre j) j
          ≤ Cprefix * paper3HoffRate j := by
            simpa [hcancel] using hmul
      _ ≤ Csrc * paper3HoffRate j := by
            dsimp [Csrc]
            exact mul_le_mul_of_nonneg_right
              (by nlinarith [hCenv_nonneg]) (paper3HoffRate_pos j).le
  · have hjge : N ≤ j := le_of_not_gt hj
    refine ⟨Benv j, hBenv_nonneg j, ?_, ?_⟩
    · simpa [Benv] using hNamp j hjge
    · calc
        Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            selectorInterReadSourceCap (Benv j) j
            ≤ Cenv * paper3HoffRate j := henv_source j
        _ ≤ Csrc * paper3HoffRate j := by
            dsimp [Csrc]
            exact mul_le_mul_of_nonneg_right
              (by nlinarith [hprefix_nonneg]) (paper3HoffRate_pos j).le

theorem
    paper3Headline_activeQSS_Rstart_le_const_hoffRate_of_tail_and_sourceWitness
    (wg w : ℕ) (tail : ℕ → ℝ) {Ctail Csrc : ℝ}
    (hCtail_nonneg : 0 ≤ Ctail)
    (hCsrc_nonneg : 0 ≤ Csrc)
    (htail : ∀ j : ℕ,
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          tail j ≤
        Ctail * paper3HoffRate j)
    (hsource : ∀ j : ℕ,
      ∃ Bamp : ℝ,
        0 ≤ Bamp ∧
        (∀ τ ∈ Icc (selectorMUWriteReadTime j)
            (selectorMUWriteStartTime (j + 1)), ∀ i : Fin d_U,
          |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
              ((paper3HeadlineSolFam wg) w).lam τ i -
            ((paper3HeadlineSolFam wg) w).z τ i| ≤ Bamp) ∧
        Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            selectorInterReadSourceCap Bamp j ≤
          Csrc * paper3HoffRate j) :
    ∃ Cstart : ℝ, 0 ≤ Cstart ∧ ∀ j : ℕ,
      ∃ Bamp : ℝ,
        0 ≤ Bamp ∧
        (∀ τ ∈ Icc (selectorMUWriteReadTime j)
            (selectorMUWriteStartTime (j + 1)), ∀ i : Fin d_U,
          |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
              ((paper3HeadlineSolFam wg) w).lam τ i -
            ((paper3HeadlineSolFam wg) w).z τ i| ≤ Bamp) ∧
        Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            (((tail j + selectorInterReadSourceCap Bamp j) + r_LE_U) +
              (D_U - 2)) ≤
          Cstart * paper3HoffRate j := by
  rcases paper3Headline_activeQSS_Rstart_fixed_part_le_const_hoffRate with
    ⟨Cfixed, hCfixed_nonneg, hfixed⟩
  refine ⟨Ctail + Csrc + Cfixed, by nlinarith, ?_⟩
  intro j
  rcases hsource j with ⟨Bamp, hBamp0, hamp, hsrc⟩
  refine ⟨Bamp, hBamp0, hamp, ?_⟩
  calc
    Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
        (((tail j + selectorInterReadSourceCap Bamp j) + r_LE_U) +
          (D_U - 2))
        =
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          tail j +
        Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap Bamp j +
        Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          (r_LE_U + (D_U - 2)) := by ring
    _ ≤ Ctail * paper3HoffRate j + Csrc * paper3HoffRate j +
          Cfixed * paper3HoffRate j := by
        exact add_le_add (add_le_add (htail j) hsrc) (hfixed j)
    _ = (Ctail + Csrc + Cfixed) * paper3HoffRate j := by ring

theorem paper3Headline_D_U_sub_two_nonneg :
    0 ≤ D_U - 2 := by
  have hD : (8 : ℝ) ≤ D_U := paper3Headline_D_U_ge_eight
  linarith

theorem paper3Headline_nextCfg_encDiff_le_D_U_sub_two
    (w j : ℕ) :
    ∀ i : Fin d_U,
      |(confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ) -
        (confEncU (solMUReplStaticCfg w (j + 1)) i : ℝ)| ≤ D_U - 2 := by
  intro i
  have h :=
    enc_step_abs_diff_le_D_U_sub_two (solMUReplStaticCfg w (j + 1)) i
  simpa [stackMachineEncodingU_enc_eq, solMUReplStaticCfg_step w (j + 1)]
    using h

/-- Convert a write-start tube around the current static configuration into a
write-start tube around the next static configuration by paying only the
coarse adjacent-encoding displacement.  This is intentionally a large, q-free
radius; it does not assert that the next write target has already been tracked
at the start of its write window. -/
theorem paper3Headline_writeStart_z_to_next_of_current_start
    (wg w j : ℕ) {Rcur Rstart : ℝ}
    (hz_current : ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        (confEncU (solMUReplStaticCfg w (j + 1)) i : ℝ)| ≤ Rcur)
    (hRstart : Rcur + (D_U - 2) ≤ Rstart) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        (confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)| ≤ Rstart := by
  intro i
  have henc := paper3Headline_nextCfg_encDiff_le_D_U_sub_two w j i
  have htri :
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        (confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)| ≤
        Rcur + (D_U - 2) := by
    calc
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        (confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)|
          = |(((paper3HeadlineSolFam wg) w).z
                (selectorMUWriteStartTime (j + 1)) i -
              (confEncU (solMUReplStaticCfg w (j + 1)) i : ℝ)) +
              ((confEncU (solMUReplStaticCfg w (j + 1)) i : ℝ) -
                (confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ))| := by
              ring_nf
      _ ≤ |((paper3HeadlineSolFam wg) w).z
              (selectorMUWriteStartTime (j + 1)) i -
            (confEncU (solMUReplStaticCfg w (j + 1)) i : ℝ)| +
          |(confEncU (solMUReplStaticCfg w (j + 1)) i : ℝ) -
            (confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)| :=
            abs_add_le _ _
      _ ≤ Rcur + (D_U - 2) :=
            add_le_add (hz_current i)
              (by simpa [abs_sub_comm] using henc)
  exact le_trans htri hRstart

/-- Active-suffix pointwise `u`-RHS bound from a prefix `|z-u|` envelope.
The active suffix is a subinterval of the write prefix, and the q-gate
offphase gives the exponential factor already used by the prefix-drift proof. -/
theorem paper3Headline_activeSuffix_uDerivRHS_abs_le_of_prefix_zu
    (wg w j : ℕ) {Bpre : ℝ}
    (hBpre0 : 0 ≤ Bpre)
    (hzu : ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime (j + 1))
        (selectorMUWriteHoldTime (j + 1)),
      |((paper3HeadlineSolFam wg) w).z t i -
        ((paper3HeadlineSolFam wg) w).u t i| ≤ Bpre) :
    let sol := paper3HeadlineSolFam wg
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
    ∀ τ ∈ Set.Icc E Htime, ∀ i : Fin d_U,
      |selectorMU_uDerivRHS sol w τ i| ≤
        Bpre * Real.exp
          (-(selectorUSettledRate * selectorMUWriteStartTime (j + 1))) := by
  dsimp
  intro τ hτ i
  have hstart :
      selectorMUWriteStartTime (j + 1) ≤
        selectorMUEarlyWriteSubStart (j + 1) :=
    selectorMUWriteStart_le_earlySubStart (j + 1)
  have hprefix :
      τ ∈ Icc (selectorMUWriteStartTime (j + 1))
          (selectorMUWriteHoldTime (j + 1)) :=
    ⟨le_trans hstart hτ.1, hτ.2⟩
  have ha0 : 0 ≤ selectorMUWriteStartTime (j + 1) :=
    selectorMUWriteStartTime_nonneg (j + 1)
  have hτ0 : 0 ≤ τ := le_trans ha0 hprefix.1
  have hατ :
      ((paper3HeadlineSolFam wg) w).α τ = Real.exp (bgpParams38.cα * τ) := by
    rw [((paper3HeadlineSolFam wg) w).alpha_eq_exp
      selectorSchedule_domain_of_nonneg_structural hτ0]
  have hμτ :
      ((paper3HeadlineSolFam wg) w).μ τ = bgpParams38.cμ * τ := by
    rw [((paper3HeadlineSolFam wg) w).mu_eq_linear
      selectorSchedule_domain_of_nonneg_structural hτ0,
      ((paper3HeadlineSolFam wg) w).μ_at_zero]
    simp [bgpParams38]
  have hsin : (1 : ℝ) / 2 ≤ Real.sin τ :=
    sin_window_ge (j + 1)
      (by simpa [selectorMUWriteStartTime] using hprefix.1)
      (by
        have hτ_read : τ ≤ selectorMUWriteReadTime (j + 1) :=
          le_trans hprefix.2 (selectorMUWriteHold_le_read (j + 1))
        simpa [selectorMUWriteReadTime] using hτ_read)
  have hcoef0 :
      0 ≤ bgpParams38.A * ((paper3HeadlineSolFam wg) w).α τ *
        bGateU bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ := by
    rw [hατ]
    exact mul_nonneg
      (mul_nonneg (by norm_num [bgpParams38]) (Real.exp_pos _).le)
      (bGateU_pos bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ).le
  have hcoef_le :
      bgpParams38.A * ((paper3HeadlineSolFam wg) w).α τ *
          bGateU bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ
        ≤ Real.exp (-(selectorUSettledRate * τ)) := by
    have h :=
      gateU_integrand_le_settled_exp_repl
        (sol := ((paper3HeadlineSolFam wg) w)) (A := (1 : ℝ))
        (cμ := bgpParams38.cμ) (cα := bgpParams38.cα)
        hτ0 (by norm_num) (by norm_num [bgpParams38]) (by norm_num [bgpParams38])
        hατ hμτ hsin
    rw [show selectorUSettledRate
          = bgpParams38.cμ * (3 / 4 : ℝ) ^ bgpParams38.L - bgpParams38.cα from by
        norm_num [selectorUSettledRate, bgpParams38]]
    simpa [bgpParams38] using h
  have hdec :
      Real.exp (-(selectorUSettledRate * τ))
        ≤ Real.exp
          (-(selectorUSettledRate * selectorMUWriteStartTime (j + 1))) := by
    apply Real.exp_le_exp.mpr
    have hmul :
        selectorUSettledRate * selectorMUWriteStartTime (j + 1) ≤
          selectorUSettledRate * τ :=
      mul_le_mul_of_nonneg_left hprefix.1 selectorUSettledRate_pos.le
    linarith
  calc
    |selectorMU_uDerivRHS (paper3HeadlineSolFam wg) w τ i|
        = (bgpParams38.A * ((paper3HeadlineSolFam wg) w).α τ *
            bGateU bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ) *
            |((paper3HeadlineSolFam wg) w).z τ i -
              ((paper3HeadlineSolFam wg) w).u τ i| := by
          rw [selectorMU_uDerivRHS, abs_mul, abs_of_nonneg hcoef0]
    _ ≤ Real.exp (-(selectorUSettledRate * τ)) * Bpre :=
          mul_le_mul hcoef_le (hzu i τ hprefix) (abs_nonneg _)
            (Real.exp_pos _).le
    _ ≤ Real.exp
          (-(selectorUSettledRate * selectorMUWriteStartTime (j + 1))) * Bpre :=
          mul_le_mul_of_nonneg_right hdec hBpre0
    _ = Bpre *
          Real.exp
            (-(selectorUSettledRate * selectorMUWriteStartTime (j + 1))) := by
          ring

/-- Active-suffix pointwise `u`-RHS bound with the concrete finite prefix
`|z-u|` envelope.  This packages the existing F1 prefix producer in the exact
shape needed by payoff-speed variation estimates. -/
theorem paper3Headline_activeSuffix_uDerivRHS_abs_le_prefixBpre
    (wg w j : ℕ) :
    ∃ Bpre : ℝ,
      0 ≤ Bpre ∧
      (let sol := paper3HeadlineSolFam wg
       let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
       let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
       ∀ τ ∈ Set.Icc E Htime, ∀ i : Fin d_U,
        |selectorMU_uDerivRHS sol w τ i| ≤
          Bpre * Real.exp
            (-(selectorUSettledRate * selectorMUWriteStartTime (j + 1)))) := by
  rcases paper3HeadlineF1_prefix_zu_bound wg w with ⟨Bpre, hBpre0, hzu⟩
  refine ⟨Bpre (j + 1), hBpre0 (j + 1), ?_⟩
  dsimp
  exact
    paper3Headline_activeSuffix_uDerivRHS_abs_le_of_prefix_zu
      (wg := wg) (w := w) (j := j) (Bpre := Bpre (j + 1))
      (hBpre0 (j + 1)) (fun i t ht => hzu (j + 1) i t ht)

/-- Pure finite-sum algebra for the active forcing surface: if all payoff gaps
are nonnegative, the active gap is zero, and every loser gap is bounded by
`Delta`, then the filtered forcing sum is controlled by `cg * loserMass^2`.
This is the pointwise square mechanism used by the active-branch outlet. -/
theorem paper3_filtered_forcing_pointwise_le_delta_loser_square
    {V : Type} [Fintype V] [DecidableEq V]
    (c : V) (lam gap : V → ℝ) (cg Delta : ℝ)
    (hlam_nonneg : ∀ v : V, 0 ≤ lam v)
    (hcg_nonneg : 0 ≤ cg)
    (hdelta_nonneg : ∀ v : V, 0 ≤ gap v)
    (hdelta_self : gap c = 0)
    (hdelta_upper : ∀ v : V, v ≠ c → gap v ≤ Delta) :
    let S : Finset V := Finset.univ.filter (fun v : V => v ≠ c)
    S.sum (fun v => |cg * (∑ x : V, lam x * gap x) * lam v|) ≤
      Delta * (cg * (S.sum (fun v => lam v)) ^ 2) := by
  classical
  dsimp
  let S : Finset V := Finset.univ.filter (fun v : V => v ≠ c)
  let meanGap : ℝ := ∑ x : V, lam x * gap x
  let L : ℝ := S.sum (fun v => lam v)
  have hmean_nonneg : 0 ≤ meanGap := by
    dsimp [meanGap]
    exact Finset.sum_nonneg
      (fun x _hx => mul_nonneg (hlam_nonneg x) (hdelta_nonneg x))
  have hL_nonneg : 0 ≤ L := by
    dsimp [L]
    exact Finset.sum_nonneg (fun v _hv => hlam_nonneg v)
  have hA_nonneg : 0 ≤ cg * meanGap := mul_nonneg hcg_nonneg hmean_nonneg
  have hmean_if :
      meanGap = ∑ x : V, if x = c then 0 else lam x * gap x := by
    dsimp [meanGap]
    refine Finset.sum_congr rfl ?_
    intro x _hx
    by_cases hxc : x = c
    · subst hxc
      simp [hdelta_self]
    · simp [hxc]
  have hmean_filter : meanGap = S.sum (fun x => lam x * gap x) := by
    rw [hmean_if]
    dsimp [S]
    rw [Finset.sum_filter]
    refine Finset.sum_congr rfl ?_
    intro x _hx
    by_cases hxc : x = c <;> simp [hxc]
  have hmean_le : meanGap ≤ Delta * L := by
    rw [hmean_filter]
    calc
      S.sum (fun x => lam x * gap x)
          ≤ S.sum (fun x => lam x * Delta) := by
              refine Finset.sum_le_sum ?_
              intro x hx
              exact mul_le_mul_of_nonneg_left
                (hdelta_upper x (Finset.mem_filter.mp hx).2)
                (hlam_nonneg x)
      _ = L * Delta := by
              dsimp [L]
              rw [Finset.sum_mul]
      _ = Delta * L := by ring
  have hforcing_eq :
      S.sum (fun v => |cg * meanGap * lam v|) =
        (cg * meanGap) * L := by
    calc
      S.sum (fun v => |cg * meanGap * lam v|)
          = S.sum (fun v => (cg * meanGap) * lam v) := by
              refine Finset.sum_congr rfl ?_
              intro v _hv
              rw [abs_of_nonneg (mul_nonneg hA_nonneg (hlam_nonneg v))]
      _ = (cg * meanGap) * L := by
              dsimp [L]
              exact (Finset.mul_sum S (fun v : V => lam v)
                (cg * meanGap)).symm
  have hfactor_nonneg : 0 ≤ cg * L := mul_nonneg hcg_nonneg hL_nonneg
  calc
    S.sum (fun v => |cg * (∑ x : V, lam x * gap x) * lam v|)
        = S.sum (fun v => |cg * meanGap * lam v|) := by simp [meanGap]
    _ = (cg * meanGap) * L := hforcing_eq
    _ = (cg * L) * meanGap := by ring
    _ ≤ (cg * L) * (Delta * L) :=
        mul_le_mul_of_nonneg_left hmean_le hfactor_nonneg
    _ = Delta * (cg * L ^ 2) := by ring

noncomputable def paper3S4aForcingCoeffNW
    (w j : ℕ) (_v : UniversalLocalView) : ℝ :=
  ((paper3WarmGainQNW w : ℚ) : ℝ) *
    (paper3S4aLoserCoeffNW w j) ^ 2

theorem paper3S4aForcingCoeffNW_nonneg
    (w j : ℕ) (v : UniversalLocalView) :
    0 ≤ paper3S4aForcingCoeffNW w j v := by
  unfold paper3S4aForcingCoeffNW
  exact mul_nonneg (paper3WarmGainQNW_nonneg_real w) (sq_nonneg _)

/-- Pointwise S4a forcing decay at the genuine running clock rate.  The two
loser factors are reduced to `loserMass²`; the active gain cancels exactly one
of their two `exp (-cα*t)` factors. -/
theorem paper3S4a_forcing_pointwise_exp_NW
    (w j : ℕ) (v : UniversalLocalView)
    (hv : v ≠ localViewU (solMUReplStaticCfg w j))
    (τ : ℝ)
    (hτ : τ ∈ Icc (selectorMUInterReadStart j) (selectorMUZOffStart j)) :
    |selectorMU_activeCgP (p := bgpParamsNW w) paper3HeadlineM
          (paper3WarmGainQNW w) τ *
        (∑ x : UniversalLocalView,
          ((paper3HeadlineSolFamNW w) w).lam x τ *
            (universalPval paper3HeadlineEta paper3HeadlineEta_pos
                (localViewU (solMUReplStaticCfg w j))
                (((paper3HeadlineSolFamNW w) w).u τ) -
              universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                (((paper3HeadlineSolFamNW w) w).u τ))) *
        ((paper3HeadlineSolFamNW w) w).lam v τ| ≤
      paper3S4aForcingCoeffNW w j v *
        Real.exp (-((bgpParamsNW w).cα * τ)) := by
  classical
  let sol := (paper3HeadlineSolFamNW w) w
  let cview : UniversalLocalView := localViewU (solMUReplStaticCfg w j)
  let lam : UniversalLocalView → ℝ := fun x => sol.lam x τ
  let gapf : UniversalLocalView → ℝ := fun x =>
    universalPval paper3HeadlineEta paper3HeadlineEta_pos cview (sol.u τ) -
      universalPval paper3HeadlineEta paper3HeadlineEta_pos x (sol.u τ)
  let cg : ℝ := selectorMU_activeCgP (p := bgpParamsNW w)
    paper3HeadlineM (paper3WarmGainQNW w) τ
  let Sbad : Finset UniversalLocalView :=
    Finset.univ.filter (fun x : UniversalLocalView => x ≠ cview)
  let Bmass : ℝ := Sbad.sum lam
  have hτ0 : 0 ≤ τ := by
    exact le_trans
      (le_trans (selectorMUWriteStartTime_nonneg j)
        (selectorMUWriteStart_le_read j)) hτ.1
  have hlam0 : ∀ x : UniversalLocalView, 0 ≤ lam x := by
    intro x
    exact paper3NW_lam_nonneg_forward w w x τ hτ0
  have hcg0 : 0 ≤ cg := by
    dsimp [cg, selectorMU_activeCgP]
    exact mul_nonneg
      (pow_nonneg (by nlinarith [Real.neg_one_le_sin τ]) _)
      (mul_nonneg (paper3WarmGainQNW_nonneg_real w) (Real.exp_pos _).le)
  have hgap0 : ∀ x : UniversalLocalView, 0 ≤ gapf x := by
    intro x
    by_cases hx : x = cview
    · subst x
      simp [gapf]
    · have hfloor := paper3S4a_gapFloor_NW w j x
        (by simpa [cview] using hx) τ hτ
      dsimp [gapf, cview, sol]
      linarith
  have hgap_self : gapf cview = 0 := by simp [gapf]
  have hgap_upper : ∀ x : UniversalLocalView, x ≠ cview → gapf x ≤ 1 := by
    intro x hx
    have hut := paper3SegC_edge_tube_NW w j τ
      ⟨le_trans (selectorMUWriteStart_le_read j) hτ.1, hτ.2⟩
    exact paper3Headline_universalPval_sub_le_one_of_utube
      (fun i => hut i) cview x
  have hsum := paper3_filtered_forcing_pointwise_le_delta_loser_square
    cview lam gapf cg (1 : ℝ) hlam0 hcg0 hgap0 hgap_self hgap_upper
  have hvS : v ∈ Sbad := by
    exact Finset.mem_filter.mpr
      ⟨Finset.mem_univ v, by simpa [cview] using hv⟩
  have hsingle : |cg * (∑ x : UniversalLocalView, lam x * gapf x) * lam v| ≤
      Sbad.sum (fun x => |cg * (∑ y : UniversalLocalView,
        lam y * gapf y) * lam x|) := by
    exact Finset.single_le_sum
      (fun x _hx => abs_nonneg
        (cg * (∑ y : UniversalLocalView, lam y * gapf y) * lam x)) hvS
  have hforcing :
      |cg * (∑ x : UniversalLocalView, lam x * gapf x) * lam v| ≤
        cg * Bmass ^ 2 := by
    have hsum' : Sbad.sum (fun x => |cg *
        (∑ y : UniversalLocalView, lam y * gapf y) * lam x|) ≤
        cg * Bmass ^ 2 := by
      simpa [Sbad, Bmass] using hsum
    exact hsingle.trans hsum'
  have hhold_read : selectorMUWriteHoldTime j ≤ selectorMUInterReadStart j := by
    unfold selectorMUWriteHoldTime selectorMUInterReadStart
      selectorMUWriteReadTime
    linarith [Real.pi_pos]
  have hB := paper3S4a_loser_mass_timelocal_NW w j τ
    ⟨le_trans hhold_read hτ.1, hτ.2⟩
  have hB' : Bmass ≤ paper3S4aLoserCoeffNW w j *
      Real.exp (-((bgpParamsNW w).cα * τ)) := by
    simpa [Bmass, Sbad, lam, cview, sol] using hB
  have hB0 : 0 ≤ Bmass := by
    dsimp [Bmass, Sbad]
    exact Finset.sum_nonneg (fun x _ => hlam0 x)
  have hBsq : Bmass ^ 2 ≤
      (paper3S4aLoserCoeffNW w j *
        Real.exp (-((bgpParamsNW w).cα * τ))) ^ 2 :=
    pow_le_pow_left₀ hB0 hB' 2
  have hcg_le : cg ≤ ((paper3WarmGainQNW w : ℚ) : ℝ) *
      Real.exp ((bgpParamsNW w).cα * τ) := by
    have habs := selectorMU_activeCg_abs_le_exp_gainP
      (p := bgpParamsNW w) paper3HeadlineM (paper3WarmGainQNW w) τ
    rw [abs_of_nonneg hcg0,
      abs_of_nonneg (paper3WarmGainQNW_nonneg_real w)] at habs
    exact habs
  have hprod : cg * Bmass ^ 2 ≤
      (((paper3WarmGainQNW w : ℚ) : ℝ) *
        Real.exp ((bgpParamsNW w).cα * τ)) *
      (paper3S4aLoserCoeffNW w j *
        Real.exp (-((bgpParamsNW w).cα * τ))) ^ 2 := by
    exact mul_le_mul hcg_le hBsq (sq_nonneg _)
      (mul_nonneg (paper3WarmGainQNW_nonneg_real w) (Real.exp_pos _).le)
  have hexpc : Real.exp ((bgpParamsNW w).cα * τ) *
      Real.exp (-((bgpParamsNW w).cα * τ)) = 1 := by
    rw [← Real.exp_add]
    simp
  calc
    |selectorMU_activeCgP (p := bgpParamsNW w) paper3HeadlineM
          (paper3WarmGainQNW w) τ *
        (∑ x : UniversalLocalView, sol.lam x τ *
          (universalPval paper3HeadlineEta paper3HeadlineEta_pos cview (sol.u τ) -
            universalPval paper3HeadlineEta paper3HeadlineEta_pos x (sol.u τ))) *
        sol.lam v τ|
        = |cg * (∑ x : UniversalLocalView, lam x * gapf x) * lam v| := by rfl
    _ ≤ cg * Bmass ^ 2 := hforcing
    _ ≤ (((paper3WarmGainQNW w : ℚ) : ℝ) *
          Real.exp ((bgpParamsNW w).cα * τ)) *
        (paper3S4aLoserCoeffNW w j *
          Real.exp (-((bgpParamsNW w).cα * τ))) ^ 2 := hprod
    _ = paper3S4aForcingCoeffNW w j v *
          Real.exp (-((bgpParamsNW w).cα * τ)) := by
      unfold paper3S4aForcingCoeffNW
      calc
        (((paper3WarmGainQNW w : ℚ) : ℝ) *
              Real.exp ((bgpParamsNW w).cα * τ)) *
            (paper3S4aLoserCoeffNW w j *
              Real.exp (-((bgpParamsNW w).cα * τ))) ^ 2 =
          (((paper3WarmGainQNW w : ℚ) : ℝ) *
              (paper3S4aLoserCoeffNW w j) ^ 2) *
            (Real.exp ((bgpParamsNW w).cα * τ) *
              Real.exp (-((bgpParamsNW w).cα * τ))) *
            Real.exp (-((bgpParamsNW w).cα * τ)) := by ring
        _ = (((paper3WarmGainQNW w : ℚ) : ℝ) *
              (paper3S4aLoserCoeffNW w j) ^ 2) *
            Real.exp (-((bgpParamsNW w).cα * τ)) := by rw [hexpc]; ring

theorem paper3S4_card_le_gain_NW (w : ℕ) :
    (Fintype.card UniversalLocalView : ℝ) ≤
      ((paper3WarmGainQNW w : ℚ) : ℝ) := by
  have hcardQ := cardUniversalLocalView_le_warmGainCNW w
  have hpow : (1 : ℚ) ≤ (6 : ℚ) ^ w := one_le_pow₀ (by norm_num)
  have hCN0 := paper3WarmGainCNW_nonneg w
  have hCNQ : paper3WarmGainCNW w ≤ paper3WarmGainQNW w := by
    unfold paper3WarmGainQNW
    nlinarith
  exact_mod_cast hcardQ.trans hCNQ

/-- The double-exponential homogeneous coefficient is already below the
running reset coefficient.  This scalar comparison is what removes the warm
gain from the forcing budget instead of having to upper-bound it. -/
theorem paper3S4aInitialCoeffNW_le_reset (w j : ℕ) :
    paper3S4aInitialCoeffNW w j ≤ paper3S4ResetCoeffNW w := by
  let S : ℝ := (bgpScaleW w : ℝ)
  let g : ℝ := ((paper3WarmGainQNW w : ℚ) : ℝ)
  let c : ℝ := (bgpParamsNW w).cα
  let sel : ℝ := selectorMUSelectStartTime j
  let hold : ℝ := selectorMUWriteHoldTime j
  let len : ℝ := Real.pi / 3 - selectorMURecoveryDelta
  let A : ℝ := (15 / 16 : ℝ) * (3 / 4 : ℝ) ^ paper3HeadlineM * g * len
  have hS : (5184 : ℝ) ≤ S := by
    change (5184 : ℝ) ≤ (bgpScaleW w : ℝ)
    exact paper3NW4_S_ge w
  have hS0 : 0 < S := by
    change (0 : ℝ) < (bgpScaleW w : ℝ)
    exact bgpScaleWR_pos w
  have hg : 0 < g := by
    change (0 : ℝ) < ((paper3WarmGainQNW w : ℚ) : ℝ)
    exact paper3WarmGainQNW_pos_real w
  have hc : 0 < c := by
    change (0 : ℝ) < (bgpParamsNW w).cα
    exact bgpParamsNW_cα_pos w
  have hsel0 : 0 ≤ sel := by
    dsimp [sel]
    exact le_trans (selectorMUWriteStartTime_nonneg j)
      (selectorMUWriteStart_le_selectStart j)
  have hlen0 : 0 ≤ len := by
    dsimp [len]
    rw [show selectorMURecoveryDelta = (1 / 100000 : ℝ) by rfl]
    linarith [Real.pi_gt_three]
  have hlen2 : len ≤ 2 := by
    dsimp [len]
    rw [show selectorMURecoveryDelta = (1 / 100000 : ℝ) by rfl]
    linarith [Real.pi_lt_four]
  have hq : (1 / 1000 : ℝ) ≤
      (15 / 16 : ℝ) * (3 / 4 : ℝ) ^ paper3HeadlineM * len := by
    dsimp [len]
    rw [show selectorMURecoveryDelta = (1 / 100000 : ℝ) by rfl]
