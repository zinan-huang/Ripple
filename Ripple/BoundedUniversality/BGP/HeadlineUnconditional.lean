          ((paper3HeadlineSolFamN wg) w).lam τ i -
        ((paper3HeadlineSolFamN wg) w).u τ i :=
    (((paper3HeadlineSolFamN wg) w).cont_mixTarget i).sub
      (((paper3HeadlineSolFamN wg) w).cont_u i)
