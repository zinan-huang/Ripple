    have h2 : ((MachineInstance.depthHeightU w 0 i : ℕ) : ℤ) ≤
        ((MachineInstance.inputDepthU w : ℕ) : ℤ) := by
      exact_mod_cast Finset.le_sup
        (f := fun j : Fin d_U => MachineInstance.depthHeightU w 0 j)
        (Finset.mem_univ i)
    have h3 : ((MachineInstance.inputDepthU w : ℕ) : ℤ) ≤
        ((MachineInstance.inputLenU 1 w + 30 : ℕ) : ℤ) := by
