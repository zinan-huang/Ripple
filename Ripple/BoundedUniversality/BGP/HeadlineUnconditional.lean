/-- On the old-winner S4a window the active gain, multiplied by the payoff
gap, dominates the clock rate `cα`. -/
theorem paper3S4a_gap_mul_cg_ge_calpha_NW
    (w j : ℕ) {gap s : ℝ}
    (hgap : (15 : ℝ) / 16 ≤ gap)
    (hs : s ∈ Icc (selectorMUSelectStartTime j) (selectorMUZOffStart j)) :
    (bgpParamsNW w).cα ≤ gap * paper3NW4cg w s := by
  have hsin : 0 ≤ Real.sin s :=
    paper3NW4_sin_nonneg_writeToZOff j
      (le_trans (selectorMUWriteStart_le_selectStart j) hs.1) hs.2
  have hpow : (1 / 2 : ℝ) ^ paper3HeadlineM ≤
      ((1 + Real.sin s) / 2) ^ paper3HeadlineM := by
    apply pow_le_pow_left₀ (by norm_num)
    linarith
  have hs0 : 0 ≤ s := by
    exact le_trans
      (le_trans (selectorMUWriteStartTime_nonneg j)
        (selectorMUWriteStart_le_selectStart j)) hs.1
  have hcα0 : 0 ≤ (bgpParamsNW w).cα := (bgpParamsNW_cα_pos w).le
  have hexp : 1 ≤ Real.exp ((bgpParamsNW w).cα * s) :=
    Real.one_le_exp (mul_nonneg hcα0 hs0)
  have hg0 : (0 : ℝ) ≤ ((paper3WarmGainQNW w : ℚ) : ℝ) :=
    paper3WarmGainQNW_nonneg_real w
  have hcg : (1 / 2 : ℝ) ^ paper3HeadlineM *
        ((paper3WarmGainQNW w : ℚ) : ℝ) ≤ paper3NW4cg w s := by
    unfold paper3NW4cg
    calc
      (1 / 2 : ℝ) ^ paper3HeadlineM *
          ((paper3WarmGainQNW w : ℚ) : ℝ)
          ≤ ((1 + Real.sin s) / 2) ^ paper3HeadlineM *
              ((paper3WarmGainQNW w : ℚ) : ℝ) :=
        mul_le_mul_of_nonneg_right hpow hg0
      _ ≤ ((1 + Real.sin s) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQNW w : ℚ) : ℝ) *
                Real.exp ((bgpParamsNW w).cα * s)) := by
        apply mul_le_mul_of_nonneg_left
        · simpa using mul_le_mul_of_nonneg_left hexp hg0
        · exact pow_nonneg (by linarith [Real.neg_one_le_sin s]) _
  have hS : (0 : ℝ) < (bgpScaleW w : ℝ) := bgpScaleWR_pos w
  have hS1 : (1 : ℝ) ≤ (bgpScaleW w : ℝ) := bgpScaleWR_ge_one w
  have hS6 : (bgpScaleW w : ℝ) ≤ (bgpScaleW w : ℝ) ^ 6 := by
    have hpow5 : (1 : ℝ) ≤ (bgpScaleW w : ℝ) ^ 5 :=
      one_le_pow₀ hS1
    calc
      (bgpScaleW w : ℝ) = (bgpScaleW w : ℝ) * 1 := by ring
      _ ≤ (bgpScaleW w : ℝ) * (bgpScaleW w : ℝ) ^ 5 :=
        mul_le_mul_of_nonneg_left hpow5 hS.le
      _ = (bgpScaleW w : ℝ) ^ 6 := by ring
  have hqscale :
      (1734736490 : ℝ) * (bgpScaleW w : ℝ) ^ 6 ≤
        ((paper3WarmGainQNW w : ℚ) : ℝ) := by
    have hpow6 : (1 : ℝ) ≤ (6 : ℝ) ^ w := one_le_pow₀ (by norm_num)
    calc
      (1734736490 : ℝ) * (bgpScaleW w : ℝ) ^ 6 =
          ((1734736490 : ℝ) * (bgpScaleW w : ℝ) ^ 6) * 1 := by ring
      _ ≤ ((1734736490 : ℝ) * (bgpScaleW w : ℝ) ^ 6) * (6 : ℝ) ^ w :=
        mul_le_mul_of_nonneg_left hpow6 (by positivity)
      _ = ((paper3WarmGainQNW w : ℚ) : ℝ) := by
        unfold paper3WarmGainQNW paper3WarmGainCNW
        push_cast
        ring
  have hscale_gain :
      (bgpParamsNW w).cα ≤ (15 / 16 : ℝ) *
        ((1 / 2 : ℝ) ^ paper3HeadlineM *
          ((paper3WarmGainQNW w : ℚ) : ℝ)) := by
    rw [bgpParamsNW_cα_def]
    have hp : (1 / 2 : ℝ) ^ paper3HeadlineM = 1 / 1048576 := by
      norm_num [paper3HeadlineM]
    rw [hp]
    nlinarith [hqscale]
  have hbase0 : 0 ≤ (1 / 2 : ℝ) ^ paper3HeadlineM *
      ((paper3WarmGainQNW w : ℚ) : ℝ) :=
    mul_nonneg (pow_nonneg (by norm_num) _) hg0
  calc
    (bgpParamsNW w).cα ≤ (15 / 16 : ℝ) *
        ((1 / 2 : ℝ) ^ paper3HeadlineM *
          ((paper3WarmGainQNW w : ℚ) : ℝ)) := hscale_gain
    _ ≤ gap * ((1 / 2 : ℝ) ^ paper3HeadlineM *
          ((paper3WarmGainQNW w : ℚ) : ℝ)) :=
      mul_le_mul_of_nonneg_right hgap hbase0
    _ ≤ gap * paper3NW4cg w s :=
      mul_le_mul_of_nonneg_left hcg (by linarith)

/-- The reset-source Duhamel convolution retains the running physical-time
decay `exp (-cα*t)` on S4a. -/
theorem paper3S4a_reset_duhamel_timelocal_NW
    (w j : ℕ) {gap t : ℝ}
    (hgap : (15 : ℝ) / 16 ≤ gap)
    (ht : t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUZOffStart j)) :
    (∫ s in (selectorMUSelectStartTime j)..t,
        Real.exp (gap *
          (((paper3HeadlineSolFamNW w) w).G s -
            ((paper3HeadlineSolFamNW w) w).G (selectorMUSelectStartTime j))) *
          (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
            ((paper3HeadlineKappa : ℚ) : ℝ))) *
        Real.exp (-gap *
          (((paper3HeadlineSolFamNW w) w).G t -
            ((paper3HeadlineSolFamNW w) w).G (selectorMUSelectStartTime j))) ≤
      paper3S4ResetCoeffNW w *
        Real.exp (-((bgpParamsNW w).cα * t)) := by
  let sol := (paper3HeadlineSolFamNW w) w
  let a := selectorMUSelectStartTime j
  let c := (bgpParamsNW w).cα
  let cg : ℝ → ℝ := paper3NW4cg w
  let reset : ℝ → ℝ := fun s =>
    ((1 + Real.cos s) / 2) ^ paper3HeadlineM *
      ((paper3HeadlineKappa : ℚ) : ℝ)
  have hat : a ≤ t :=
    le_trans (selectorMUSelectStart_lt_hold j).le ht.1
  have hgap0 : 0 < gap := by linarith
  have hc : 0 < c := by simpa [c] using bgpParamsNW_cα_pos w
  have ha0 : 0 ≤ a :=
    le_trans (selectorMUWriteStartTime_nonneg j)
      (selectorMUWriteStart_le_selectStart j)
  have hmajor : ∀ s ∈ Icc a t,
      reset s ≤ (gap * cg s - c) *
        (paper3S4ResetCoeffNW w * Real.exp (-(c * s))) := by
    intro s hs
    have hsZ : s ≤ selectorMUZOffStart j := le_trans hs.2 ht.2
    have hswin : s ∈ Icc (selectorMUSelectStartTime j)
        (selectorMUZOffStart j) := ⟨hs.1, hsZ⟩
    have hgain := paper3S4a_gap_mul_cg_ge_calpha_NW w j hgap hswin
    have hreset_le : reset s ≤ 1 := by
      dsimp [reset]
      norm_num [paper3HeadlineKappa]
      exact pow_le_one₀ (by nlinarith [Real.neg_one_le_cos s])
        (by nlinarith [Real.cos_le_one s])
    have hs_half : (1 / 2 : ℝ) ≤ s := by
      have hπ := Real.pi_gt_three
      have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
      have hjterm : 0 ≤ 2 * Real.pi * (j : ℝ) := by positivity
      have hsel := hs.1
      unfold a selectorMUSelectStartTime selectorMUWriteStartTime at hsel
      linarith [selectorMURecoveryDelta_pos]
    have hcexp : c * Real.exp (-(c * s)) ≤ 1 := by
      have hcs0 : 0 ≤ c * s := mul_nonneg hc.le (by linarith)
      have hmul := Real.mul_exp_neg_le_exp_neg_one (c * s)
      have hexp1 : Real.exp (-(1 : ℝ)) ≤ 1 / 2 := by
        rw [Real.exp_neg, inv_le_comm₀ (by positivity) (by norm_num)]
        have := Real.add_one_le_exp (1 : ℝ)
        linarith
      have hleft : c * Real.exp (-(c * s)) ≤
          2 * ((c * s) * Real.exp (-(c * s))) := by
        have hnonneg := mul_nonneg hc.le (Real.exp_pos (-(c * s))).le
        nlinarith [mul_nonneg (sub_nonneg.mpr hs_half) hnonneg]
      linarith
    have hC0 := paper3S4ResetCoeffNW_nonneg w
    have hC1 := paper3S4ResetCoeffNW_le_one w
    have hsub : 1 ≤ (gap * cg s - c) *
        (paper3S4ResetCoeffNW w * Real.exp (-(c * s))) := by
      have hsin := paper3NW4_sin_nonneg_writeToZOff j
        (le_trans (selectorMUWriteStart_le_selectStart j) hs.1) hsZ
      have hpow : (1 / 2 : ℝ) ^ paper3HeadlineM ≤
          ((1 + Real.sin s) / 2) ^ paper3HeadlineM := by
        apply pow_le_pow_left₀ (by norm_num)
        linarith
      have hg : (0 : ℝ) < ((paper3WarmGainQNW w : ℚ) : ℝ) :=
        paper3WarmGainQNW_pos_real w
      have hcancel :
          gap * ((1 / 2 : ℝ) ^ paper3HeadlineM *
            (((paper3WarmGainQNW w : ℚ) : ℝ) * Real.exp (c * s))) *
              (paper3S4ResetCoeffNW w * Real.exp (-(c * s))) =
            gap * 8 := by
        rw [paper3S4ResetCoeffNW]
        have hexpc : Real.exp (c * s) * Real.exp (-(c * s)) = 1 := by
          rw [← Real.exp_add]
          simp
        field_simp
        norm_num [paper3HeadlineM]
        calc
          (1 / 1048576 : ℝ) * Real.exp (c * s) * 8388608 *
                Real.exp (-(c * s))
              = 8 * (Real.exp (c * s) * Real.exp (-(c * s))) := by ring
          _ = 8 := by rw [hexpc]; ring
      have hcg_lower : (1 / 2 : ℝ) ^ paper3HeadlineM *
          (((paper3WarmGainQNW w : ℚ) : ℝ) * Real.exp (c * s)) ≤ cg s := by
        unfold cg paper3NW4cg c
        exact mul_le_mul_of_nonneg_right hpow
          (mul_nonneg (paper3WarmGainQNW_nonneg_real w) (Real.exp_pos _).le)
      have hfactor0 : 0 ≤
          paper3S4ResetCoeffNW w * Real.exp (-(c * s)) :=
        mul_nonneg hC0 (Real.exp_pos _).le
      have hmain := mul_le_mul_of_nonneg_right
        (mul_le_mul_of_nonneg_left hcg_lower hgap0.le) hfactor0
      have hcost : c * (paper3S4ResetCoeffNW w * Real.exp (-(c * s))) ≤ 1 := by
        have hfac0 : 0 ≤ c * Real.exp (-(c * s)) :=
          mul_nonneg hc.le (Real.exp_pos _).le
        have hmul := mul_le_mul_of_nonneg_left hC1 hfac0
        calc
          c * (paper3S4ResetCoeffNW w * Real.exp (-(c * s))) =
              (c * Real.exp (-(c * s))) * paper3S4ResetCoeffNW w := by ring
          _ ≤ (c * Real.exp (-(c * s))) * 1 := hmul
          _ ≤ 1 := by simpa using hcexp
      rw [hcancel] at hmain
      nlinarith
    exact le_trans hreset_le hsub
  have hsuper :=
    forward_reset_integral_mul_decay_le_exp_supersolution
      (a := a) (t := t) (gap := gap) (c := c)
      (C := paper3S4ResetCoeffNW w)
      (G := sol.G) (cg := cg) (reset := reset)
      hat hgap0 hc (paper3S4ResetCoeffNW_nonneg w)
      sol.cont_G
      (fun s hs => by
        have hs0 : 0 ≤ s := le_trans ha0 hs.1
        simpa [cg, sol] using paper3NW4_G_hasDeriv w w hs0)
      (paper3NW4cg_cont w)
      (by dsimp [reset]; fun_prop)
      hmajor
  simpa [sol, a, c, cg, reset, neg_mul] using hsuper

noncomputable def paper3S4aInitialCoeffNW (w j : ℕ) : ℝ :=
