      ((((paper3HeadlineSolFamN wg) w).cont_μ.mul hq).neg)
  have hkZ_cont : Continuous kZ :=
    (continuous_const.mul ((paper3HeadlineSolFamN wg) w).cont_α).mul
      hgateZ_cont
  have hkU_cont : Continuous kUf :=
