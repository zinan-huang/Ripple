    rw [abs_le]
    constructor
    · nlinarith [t1.1, t2.1, t3.1]
    · nlinarith [t1.2, t2.2, t3.2]
  -- segment-A trap: |z| ≤ C0 on [wr, zOffStart]
  have hzA : ∀ τ ∈ Icc (selectorMUWriteReadTime j)
      (selectorMUZOffStart j), ∀ i : Fin d_U,
      |sol.z τ i| ≤ paper3F1MixC0NW := by
    intro τ hτ i
    have hg_range : ∀ σ ∈ Icc (selectorMUWriteReadTime j) τ,
        selectorMixTarget branchU sol.u sol.lam σ i ∈
          Icc (-paper3F1MixC0NW) paper3F1MixC0NW := by
      intro σ hσ
      have hm := hmixT σ ⟨le_trans hws_wr hσ.1, le_trans hσ.2 hτ.2⟩ i
      rw [abs_le] at hm
      unfold paper3F1MixC0NW
      constructor
      · linarith [hm.1]
      · linarith [hm.2]
    have hya : sol.z (selectorMUWriteReadTime j) i ∈
        Icc (-paper3F1MixC0NW) paper3F1MixC0NW := by
      have hz := abs_le.mp (hzwr i)
      exact ⟨hz.1, hz.2⟩
    have htrap := paper3N_trapping_on_Icc
      (fun σ => sol.z σ i)
      (fun σ => selectorMixTarget branchU sol.u sol.lam σ i)
      (fun σ => (bgpParamsNW w).A * sol.α σ *
        bGateZ (bgpParamsNW w).L (sol.μ σ) σ)
      (lo := -paper3F1MixC0NW) (hi := paper3F1MixC0NW)
      (a := selectorMUWriteReadTime j) (T := τ) hτ.1
      (paper3NW4_zKernel_continuous w w)
      (sol.cont_mixTarget i)
      (fun σ hσ => sol.z_hasDeriv σ
        (selectorSchedule_domain_of_nonneg_structural σ
          (le_trans hwr0 hσ.1)) i)
      (fun σ hσ => paper3NW4_zKernel_nonneg w w (le_trans hwr0 hσ.1))
      hg_range hya
    rw [abs_le]
    exact ⟨htrap.1, htrap.2⟩
  -- segment-A mix−z box
  have hboxA : ∀ τ ∈ Icc (selectorMUWriteReadTime j)
      (selectorMUZOffStart j), ∀ i : Fin d_U,
      |selectorMixTarget branchU sol.u sol.lam τ i - sol.z τ i| ≤
        paper3F1MixCrudeBoxNW := by
    intro τ hτ i
    have h1 := hmixT τ ⟨le_trans hws_wr hτ.1, hτ.2⟩ i
    have h2 := hzA τ hτ i
    have h3 := paper3F1MixCrudeBoxNW_ge_segA
    have h4 := paper3NW4_abs_sub_le_add
      (a := selectorMixTarget branchU sol.u sol.lam τ i) (b := sol.z τ i)
    linarith
  -- z and u values at the z-off start
  have hzsA : ∀ i : Fin d_U, |sol.z (selectorMUZOffStart j) i| ≤
      paper3F1MixC0NW :=
    fun i => hzA (selectorMUZOffStart j) ⟨hwr_zs, le_refl _⟩ i
  have huzs : ∀ i : Fin d_U, |sol.u (selectorMUZOffStart j) i| ≤
      paper3F1MixC0NW := by
    intro i
    have h1 := hT (selectorMUZOffStart j) ⟨le_trans hws_wr hwr_zs,
      le_refl _⟩ i
    have h2 := paper3NW4_enc_abs (paper3F1Cfg w j) i
    have t1 := abs_le.mp h1
    have t2 := abs_le.mp h2
    unfold paper3F1MixC0NW
    rw [abs_le]
    constructor
    · nlinarith [t1.1, t2.1, hCwin0]
    · nlinarith [t1.2, t2.2, hCwin0]
  -- the conditional mix−z bound on a segment-B prefix carrying the
  -- z-displacement box
  have hprefix : ∀ b' ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
      (∀ s ∈ Icc (selectorMUZOffStart j) b', ∀ i : Fin d_U,
        |sol.z s i - sol.z (selectorMUZOffStart j) i| ≤ 1) →
      ∀ s ∈ Icc (selectorMUZOffStart j) b', ∀ i : Fin d_U,
        |selectorMixTarget branchU sol.u sol.lam s i - sol.z s i| ≤
          paper3F1MixCrudeBoxNW := by
    intro b' hb' hzpre s hs i
    have hs0 : 0 ≤ s := le_trans hzs0 hs.1
    -- z box on the prefix
    have hzbox : ∀ σ ∈ Icc (selectorMUZOffStart j) s, ∀ iv : Fin d_U,
        |sol.z σ iv| ≤ paper3F1MixC0NW + 1 := by
      intro σ hσ iv
      have h1 := hzpre σ ⟨hσ.1, le_trans hσ.2 hs.2⟩ iv
      have h2 := hzsA iv
      have h3 := abs_le.mp h1
      have h4 := abs_le.mp h2
      rw [abs_le]
      constructor <;> nlinarith [h3.1, h3.2, h4.1, h4.2]
    -- u trapped toward z on the prefix
    have hubox : ∀ iv : Fin d_U,
        |sol.u s iv| ≤ paper3F1MixC0NW + 1 := by
      intro iv
      have hg_range : ∀ σ ∈ Icc (selectorMUZOffStart j) s,
          sol.z σ iv ∈
            Icc (-(paper3F1MixC0NW + 1)) (paper3F1MixC0NW + 1) := by
        intro σ hσ
        have hz := abs_le.mp (hzbox σ hσ iv)
        exact ⟨hz.1, hz.2⟩
      have hya : sol.u (selectorMUZOffStart j) iv ∈
          Icc (-(paper3F1MixC0NW + 1)) (paper3F1MixC0NW + 1) := by
        have hu := abs_le.mp (huzs iv)
        constructor
        · linarith [hu.1]
        · linarith [hu.2]
      have htrap := paper3N_trapping_on_Icc
        (fun σ => sol.u σ iv)
        (fun σ => sol.z σ iv)
        (fun σ => (bgpParamsNW w).A * sol.α σ *
          bGateU (bgpParamsNW w).L (sol.μ σ) σ)
        (lo := -(paper3F1MixC0NW + 1)) (hi := paper3F1MixC0NW + 1)
        (a := selectorMUZOffStart j) (T := s) hs.1
        (paper3NW4_uKernel_continuous w w)
        (sol.cont_z iv)
        (fun σ hσ => sol.u_hasDeriv σ
          (selectorSchedule_domain_of_nonneg_structural σ
            (le_trans hzs0 hσ.1)) iv)
        (fun σ hσ => paper3NW4_uKernel_nonneg w w (le_trans hzs0 hσ.1))
        hg_range hya
      rw [abs_le]
      exact ⟨htrap.1, htrap.2⟩
    -- affine branch hull over the coordinate box
    have hmixB : |selectorMixTarget branchU sol.u sol.lam s i| ≤
        2 * D_U + 4000 * D_U * (paper3F1MixC0NW + 1 + 2 * D_U) := by
      refine paper3NW_mixTarget_abs_le_of_branch_abs w w hs0 ?_ i
      intro iw v
      refine paper3NW4_eval_abs_of_coord_bound_gen v iw (paper3F1Cfg w j)
        (R := paper3F1MixC0NW + 1 + 2 * D_U) ?_ ?_
      · nlinarith [hC0nn, D_U_nonneg]
      · have h1 := abs_le.mp (hubox iw)
        have h2 := abs_le.mp (paper3NW4_enc_abs (paper3F1Cfg w j) iw)
        rw [abs_le]
        constructor
        · nlinarith [h1.1, h2.1]
        · nlinarith [h1.2, h2.2]
    -- assemble
    have hz := abs_le.mp (hzbox s ⟨hs.1, le_refl s⟩ i)
    have t1 := abs_le.mp hmixB
    unfold paper3F1MixCrudeBoxNW
    rw [abs_le]
    constructor
    · nlinarith [t1.1, hz.1, hC0nn, D_U_nonneg]
    · nlinarith [t1.2, hz.2, hC0nn, D_U_nonneg]
  -- SEGMENT B first-exit: the z-displacement box holds on the whole window
  have hzB : ∀ s ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
      ∀ i : Fin d_U,
      |sol.z s i - sol.z (selectorMUZOffStart j) i| ≤ 1 := by
    by_contra hcon
    push_neg at hcon
    obtain ⟨tb, htb, i0, hi0⟩ := hcon
    set Bad : Set ℝ := Icc (selectorMUZOffStart j) tb ∩
      ⋃ i : Fin d_U, {s : ℝ |
        (1 : ℝ) ≤ |sol.z s i - sol.z (selectorMUZOffStart j) i|}
      with hBadDef
    have hclosed : IsClosed Bad := by
      refine isClosed_Icc.inter (isClosed_iUnion_of_finite fun i => ?_)
      exact isClosed_le continuous_const
        (((sol.cont_z i).sub continuous_const).abs)
    have htb_mem : tb ∈ Bad :=
      ⟨⟨htb.1, le_refl tb⟩, Set.mem_iUnion.mpr ⟨i0, hi0.le⟩⟩
    have hne : Bad.Nonempty := ⟨tb, htb_mem⟩
    have hbdd : BddBelow Bad := ⟨selectorMUZOffStart j, fun s hs => hs.1.1⟩
    have hmem_inf : sInf Bad ∈ Bad := hclosed.csInf_mem hne hbdd
    have hZinf : selectorMUZOffStart j ≤ sInf Bad :=
      le_csInf hne fun b hb => hb.1.1
    have hinf_tb : sInf Bad ≤ tb := csInf_le hbdd htb_mem
    have hinfE : sInf Bad ≤ selectorMUZOffEnd j :=
      le_trans hinf_tb htb.2
    have hZlt : selectorMUZOffStart j < sInf Bad := by
      rcases lt_or_eq_of_le hZinf with h | h
      · exact h
      · exfalso
        obtain ⟨i, hi⟩ := Set.mem_iUnion.mp hmem_inf.2
        rw [← h] at hi
        simp only [Set.mem_setOf_eq, sub_self, abs_zero] at hi
        linarith
    have hzpre : ∀ s ∈ Icc (selectorMUZOffStart j) (sInf Bad),
        ∀ i : Fin d_U,
        |sol.z s i - sol.z (selectorMUZOffStart j) i| ≤ 1 := by
      intro s hs i
      rcases lt_or_eq_of_le hs.2 with hlt | heq
      · by_contra hgt
        push_neg at hgt
        have hmem : s ∈ Bad :=
          ⟨⟨hs.1, le_trans hs.2 hinf_tb⟩,
            Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
        exact absurd (csInf_le hbdd hmem) (not_le.mpr hlt)
      · have hf : Continuous fun τ : ℝ =>
            |sol.z τ i - sol.z (selectorMUZOffStart j) i| :=
          ((sol.cont_z i).sub continuous_const).abs
        have hev : ∀ᶠ τ in nhdsWithin (sInf Bad) (Set.Iio (sInf Bad)),
            |sol.z τ i - sol.z (selectorMUZOffStart j) i| ≤ 1 := by
          filter_upwards [Ioo_mem_nhdsLT hZlt] with τ hτ
          by_contra hgt
          push_neg at hgt
          have hmem : τ ∈ Bad :=
            ⟨⟨hτ.1.le, le_trans hτ.2.le hinf_tb⟩,
              Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
          exact absurd (csInf_le hbdd hmem) (not_le.mpr hτ.2)
        have hlim := le_of_tendsto
          (hf.continuousWithinAt
            (s := Set.Iio (sInf Bad)) (x := sInf Bad)) hev
        rw [heq]
        exact hlim
    obtain ⟨i, hi⟩ := Set.mem_iUnion.mp hmem_inf.2
    simp only [Set.mem_setOf_eq] at hi
    have hmz := hprefix (sInf Bad) ⟨hZinf, hinfE⟩ hzpre
    have hsin : ∀ τ ∈ Icc (selectorMUZOffStart j) (sInf Bad),
        Real.sin τ ≤ 0 := by
      intro τ hτ
      have h1 : 2 * Real.pi * (j : ℝ) + Real.pi ≤ τ := by
        have h1' := hτ.1
        unfold selectorMUZOffStart at h1'
        linarith
      have h2 : τ ≤ 2 * Real.pi * (j : ℝ) + 2 * Real.pi := by
        have h3 := le_trans hτ.2 hinfE
        unfold selectorMUZOffEnd at h3
        push_cast at h3
        linarith
      exact sin_window_nonpos j h1 h2
    have hdrift := paper3NW4_z_drift_of_sin_nonpos w w i
      (Bmz := paper3F1MixCrudeBoxNW) paper3F1MixCrudeBoxNW_nonneg
      hzs0 hsin (fun τ hτ => hmz τ hτ i) (sInf Bad) ⟨hZinf, le_refl _⟩
    have hkill := paper3F1MixCrudeBoxNW_freeze_lt_one w j
    have hlt : |sol.z (sInf Bad) i - sol.z (selectorMUZOffStart j) i| < 1 :=
      lt_of_le_of_lt hdrift hkill
    linarith
  -- combine the two segments
  intro i τ hτ
  rcases le_total τ (selectorMUZOffStart j) with hcase | hcase
  · exact hboxA τ ⟨hτ.1, hcase⟩ i
  · exact hprefix (selectorMUZOffEnd j) ⟨hzs_ze, le_refl _⟩ hzB τ
      ⟨hcase, hτ.2⟩ i

/-- **Prewrite-tail `|mix − u|` box** (part 2 of the mixture-box discharge):
the tail u-tube (`paper3NW4_tail_tube`) releases the third-tube branch hull,
so `|mix| ≤ 2·D_U` and `|u| ≤ 2·D_U + 1/3` on `[zOffEnd j, ws (j+1)]`. -/
theorem paper3F1_interRead_mix_u_tail_NW (w j : ℕ)
    (htube0 : ∀ i,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN)
    (hwin : ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3F1CwinDefN) :
    ∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1)),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
          ((paper3HeadlineSolFamNW w) w).lam τ i -
        ((paper3HeadlineSolFamNW w) w).u τ i| ≤ 5 * D_U := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  set sol := (paper3HeadlineSolFamNW w) w with hsol
  have hD8 := paper3Headline_D_U_ge_eight
  have hze0 : 0 ≤ selectorMUZOffEnd j := by
    unfold selectorMUZOffEnd
    nlinarith [Real.pi_pos, (Nat.cast_nonneg j : (0 : ℝ) ≤ (j : ℝ))]
  have htail := paper3NW4_tail_tube w w j htube0 hwin
  intro i τ hτ
  have hτ0 : 0 ≤ τ := le_trans hze0 hτ.1
  have hmix : |selectorMixTarget branchU sol.u sol.lam τ i| ≤ 2 * D_U := by
    refine paper3NW_mixTarget_abs_le_of_branch_abs w w hτ0 ?_ i
    intro iw v
    exact branchU_evalBranch_abs_le_two_D_U_of_third_tube
      (fun ix => htail τ hτ ix) v iw
  have hu : |sol.u τ i| ≤ 2 * D_U + 1 / 3 := by
    have h1 := abs_le.mp (htail τ hτ i)
    have h2 := abs_le.mp (paper3NW4_enc_abs (paper3F1Cfg w (j + 1)) i)
    rw [abs_le]
    constructor
    · linarith [h1.1, h2.1]
    · linarith [h1.2, h2.2]
  have h1 := abs_le.mp hmix
  have h2 := abs_le.mp hu
  rw [abs_le]
  constructor
  · nlinarith [h1.1, h2.2]
  · nlinarith [h1.2, h2.1]


/-- The N boundary error is the write-start `trackingErr` of the N family. -/
theorem paper3F1BoundaryErrNW_eq_trackingErr
    (w j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErrNW w j i =
      trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i := rfl

theorem paper3F1BoundaryErrNW_le_writeStart_zu_add_zerr
    (w : ℕ) (j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErrNW w j i ≤
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i| +
      |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| := by
  have h := abs_sub_le
    (((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i)
    (((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i)
    (stackMachineEncodingU.enc (paper3F1Cfg w j) i)
  unfold paper3F1BoundaryErrNW
  exact h

/-- Positive part of the exact one-step excess at the N family. -/
def paper3F1EtaNW (w : ℕ) : ℕ → Fin d_U → ℝ :=
  fun j i =>
    max (0 : ℝ)
      (paper3F1BoundaryErrNW w (j + 1) i -
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          paper3F1BoundaryErrNW w j i)

theorem paper3F1EtaNW_nonneg (w : ℕ) :
    ∀ j i, 0 ≤ paper3F1EtaNW w j i := by
  intro j i
  unfold paper3F1EtaNW
  exact le_max_left _ _

theorem paper3F1NW_weightedDefect_summable_of_eta_geometric
    (w : ℕ) (i : Fin d_U) {Cη lamη : ℝ}
    (hβlt : Real.log (B_U : ℝ) < lamη)
    (hηgeo : ∀ j, paper3F1EtaNW w j i ≤
      Cη * Real.exp (-lamη * (j : ℝ))) :
    Summable (fun j =>
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1EtaNW w) j i) := by
  refine weightedDefect_summable_of_parts (B_U : ℝ) (paper3F1Depth w)
    (paper3F1EtaNW w) i
    (Cdep := Real.exp (Real.log (B_U : ℝ) *
      (MachineInstance.inputLenU 1 w : ℝ)))
    (Cη := Cη) (β := Real.log (B_U : ℝ)) (lamη := lamη)
    ?_ hβlt ?_ ?_ ?_ hηgeo
  · exact (Real.exp_pos _).le
  · intro j
    exact zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _
  · exact paper3F1Depth_zpow_succ_le_exp w i
  · intro j
    exact paper3F1EtaNW_nonneg w j i

theorem paper3F1SrcCoreNW_nonneg (w : ℕ) :
    ∀ j i, 0 ≤ paper3F1SrcCoreNW w j i := by
  intro j i
  unfold paper3F1SrcCoreNW
  exact le_max_left _ _

/-- The raw one-cycle multiplier step is algebraic for the N canonical
positive-part source. -/
theorem paper3F1_boundaryErrNW_succ_le_mult_add_srcCoreNW
    (w j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErrNW w (j + 1) i ≤
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErrNW w j i + paper3F1SrcCoreNW w j i := by
  have h : paper3F1BoundaryErrNW w (j + 1) i -
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErrNW w j i ≤ paper3F1SrcCoreNW w j i := by
    unfold paper3F1SrcCoreNW
    exact le_max_right _ _
  linarith

/-- **The N joint per-cycle core** — the `Paper3F1JointStepCore` sibling at
the N family, N tube radius, and `bgpScale`-scaled envelope ceiling. -/
structure Paper3F1JointStepCoreNW (w : ℕ) where
  Cwin : ℝ
  Csrc : ℝ
  Ezu : ℕ → ℝ
  hCwin0 : 0 ≤ Cwin
  hCwin_le : Cwin ≤ (bgpScale : ℝ) * Real.exp (200 : ℝ)
  hCsrc0 : 0 ≤ Csrc
  hE0 : ∀ i : Fin d_U,
    |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime 0) i -
      ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime 0) i| ≤
      Ezu 0
  hwin_of : ∀ j,
    (∀ i, paper3F1BoundaryErrNW w j i ≤ paper3F1TubeRadiusN Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).u t i| ≤ Cwin
  hnext_of : ∀ j,
    (∀ i, paper3F1BoundaryErrNW w j i ≤ paper3F1TubeRadiusN Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        ((paper3HeadlineSolFamNW w) w).u
          (selectorMUWriteStartTime (j + 1)) i| ≤ Ezu (j + 1)
  hsrc_geo_of : ∀ j,
    (∀ i, paper3F1BoundaryErrNW w j i ≤ paper3F1TubeRadiusN Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i, paper3F1SrcCoreNW w j i ≤
      Csrc * Real.exp (-(2 : ℝ) * (j : ℝ))
  hbudget_half : ∀ i,
    paper3F1W0NW w i + paper3F1GeomCap w Csrc ≤ r_LE_U / 2

/-- The explicit N endpoint recurrence (RETIMED, 2026-07-10):
`Ezu 0 = bgpScale·e^{199}`,
`Ezu (j+1) = max (e^{-massN_j}·(max (Ezu j) (bgpScale·e^{198}) + bgpScale)
+ 1) (10·bgpScale)`, where `massN_j = selectorInterReadUActiveMassLowerNW w j`
is the N-scaled inter-read u-kernel mass.  The first branch is the
`wr j → zOffEnd j` transport (contraction on the read box, retimed source
cap `≤ 1`); the second is the `5·D_U ≤ 10·bgpScale` prewrite mix box
threaded through the no-slop trapping `paper3NW_prewrite_zu_hold` on
`[zOffEnd j, ws (j+1)]`. -/
noncomputable def paper3F1EzuDefNW (w : ℕ) : ℕ → ℝ
  | 0 => (bgpScale : ℝ) * Real.exp (199 : ℝ)
  | j + 1 =>
      max (Real.exp (-(selectorInterReadUActiveMassLowerNW w j)) *
          (max (paper3F1EzuDefNW w j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
            (bgpScale : ℝ)) + 1)
        (10 * (bgpScale : ℝ))

theorem paper3F1EzuDefNW_zero (w : ℕ) :
    paper3F1EzuDefNW w 0 = (bgpScale : ℝ) * Real.exp (199 : ℝ) := rfl

theorem paper3F1EzuDefNW_succ (w : ℕ) (j : ℕ) :
    paper3F1EzuDefNW w (j + 1) =
      max (Real.exp (-(selectorInterReadUActiveMassLowerNW w j)) *
          (max (paper3F1EzuDefNW w j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
            (bgpScale : ℝ)) + 1)
        (10 * (bgpScale : ℝ)) := rfl

theorem paper3F1EzuDefNW_nonneg (w : ℕ) (j : ℕ) : 0 ≤ paper3F1EzuDefNW w j := by
  cases j with
  | zero =>
      rw [paper3F1EzuDefNW_zero w]
      positivity
  | succ j =>
      rw [paper3F1EzuDefNW_succ w]
      have hs0 : (0 : ℝ) ≤ 10 * (bgpScale : ℝ) := by positivity
      exact le_trans hs0 (le_max_right _ _)

/-- Staged bound on the N endpoint recurrence: `+2·bgpScale` growth for the
first five cycles, then contraction (the N mass linear bound
`selectorInterReadUActiveMassLowerNW_ge_linear w` has the same `2j - 8` shape
as the fixed one). -/
theorem paper3F1EzuDefNW_le_staged (w : ℕ) (j : ℕ) :
    paper3F1EzuDefNW w j ≤
      (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 2 * ((min j 5 : ℕ) : ℝ)) := by
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hs1 : (1 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_one
  induction j with
  | zero =>
      rw [paper3F1EzuDefNW_zero w]
      norm_num
  | succ j ih =>
      have hW0 : 0 ≤ max (paper3F1EzuDefNW w j)
          ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ) := by
        have h1 := le_max_right (paper3F1EzuDefNW w j)
          ((bgpScale : ℝ) * Real.exp (198 : ℝ))
        have h2 : (0 : ℝ) ≤ (bgpScale : ℝ) * Real.exp (198 : ℝ) := by
          positivity
        linarith
      have hexp198 : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) :=
        Real.exp_le_exp.mpr (by norm_num)
      have hmin_nn : (0 : ℝ) ≤ 2 * ((min j 5 : ℕ) : ℝ) := by positivity
      by_cases hj : j < 5
      · -- growth regime: `e^{-massN_j} ≤ 1`, `+2·bgpScale` per cycle
        have hq1 : Real.exp (-(selectorInterReadUActiveMassLowerNW w j)) ≤ 1 := by
          have h0 := selectorInterReadUActiveMassLowerNW_nonneg w j
          calc Real.exp (-(selectorInterReadUActiveMassLowerNW w j))
              ≤ Real.exp 0 := Real.exp_le_exp.mpr (by linarith)
            _ = 1 := Real.exp_zero
        have hmin_succ : ((min (j + 1) 5 : ℕ) : ℝ) =
            ((min j 5 : ℕ) : ℝ) + 1 := by
          have h : min (j + 1) 5 = min j 5 + 1 := by omega
          rw [h]; push_cast; ring
        have hWle : max (paper3F1EzuDefNW w j)
            ((bgpScale : ℝ) * Real.exp (198 : ℝ)) ≤
            (bgpScale : ℝ) *
              (Real.exp (199 : ℝ) + 2 * ((min j 5 : ℕ) : ℝ)) := by
          refine max_le ih ?_
          have : Real.exp (198 : ℝ) ≤
              Real.exp (199 : ℝ) + 2 * ((min j 5 : ℕ) : ℝ) := by linarith
          exact mul_le_mul_of_nonneg_left this hs0.le
        have h200 : (200 : ℝ) ≤ Real.exp (199 : ℝ) := by
          have := Real.add_one_le_exp (199 : ℝ)
          linarith
        rw [paper3F1EzuDefNW_succ w, hmin_succ]
        have hmul := mul_le_mul_of_nonneg_right hq1 hW0
        rw [one_mul] at hmul
        apply max_le
        · nlinarith [hmul, hWle]
        · nlinarith [h200, hs0.le, hmin_nn]
      · -- contraction regime: `e^{-massN_j} ≤ e^{-2}`
        push_neg at hj
        have hjR : (5 : ℝ) ≤ (j : ℝ) := by exact_mod_cast hj
        have hq : Real.exp (-(selectorInterReadUActiveMassLowerNW w j)) ≤
            Real.exp (-2 : ℝ) := by
          apply Real.exp_le_exp.mpr
          have h := selectorInterReadUActiveMassLowerNW_ge_linear w j
          linarith
        have hq7 : Real.exp (-2 : ℝ) * 7 ≤ 1 := by
          have h7 : (7 : ℝ) ≤ Real.exp 2 := by
            have h1 : (2.7182818283 : ℝ) < Real.exp 1 := Real.exp_one_gt_d9
            have h2 : Real.exp (2 : ℝ) = Real.exp 1 * Real.exp 1 := by
              rw [← Real.exp_add]; norm_num
            nlinarith [Real.exp_pos 1]
          have hE : Real.exp (-2 : ℝ) * Real.exp (2 : ℝ) = 1 := by
            rw [← Real.exp_add]; norm_num
          have hmono :=
            mul_le_mul_of_nonneg_left h7 (Real.exp_pos (-2 : ℝ)).le
          rw [hE] at hmono
          exact hmono
        have hmin5 : ((min j 5 : ℕ) : ℝ) = 5 := by
          have h : min j 5 = 5 := by omega
          rw [h]; norm_num
        have hminS : ((min (j + 1) 5 : ℕ) : ℝ) = 5 := by
          have h : min (j + 1) 5 = 5 := by omega
          rw [h]; norm_num
        have hEj : paper3F1EzuDefNW w j ≤
            (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by
          rw [hmin5] at ih
          linarith
        have hbig : (1 : ℝ) ≤ Real.exp (199 : ℝ) := by
          have := Real.add_one_le_exp (199 : ℝ)
          linarith
        have hWle : max (paper3F1EzuDefNW w j)
            ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ) ≤
            (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 11) := by
          have h198 : (bgpScale : ℝ) * Real.exp (198 : ℝ) ≤
              (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by
            have : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) + 10 := by
              linarith
            exact mul_le_mul_of_nonneg_left this hs0.le
          have hmax := max_le hEj h198
          nlinarith [hmax]
        -- the closed numeric core: `e^{-2}·(E+11) + 1 ≤ E + 10` at `E = e^{199}`
        have hXE : Real.exp (-2 : ℝ) * Real.exp (199 : ℝ) * 7 ≤
            Real.exp (199 : ℝ) := by
          nlinarith [hq7, (Real.exp_pos (199 : ℝ)).le]
        have hcore : Real.exp (-2 : ℝ) * (Real.exp (199 : ℝ) + 11) + 1 ≤
            Real.exp (199 : ℝ) + 10 := by
          nlinarith [hXE, hq7, hbig]
        have hqW : Real.exp (-(selectorInterReadUActiveMassLowerNW w j)) *
            (max (paper3F1EzuDefNW w j)
              ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ)) ≤
            Real.exp (-2 : ℝ) *
              ((bgpScale : ℝ) * (Real.exp (199 : ℝ) + 11)) :=
          mul_le_mul hq hWle hW0 (Real.exp_pos (-2 : ℝ)).le
        have hscaled := mul_le_mul_of_nonneg_left hcore hs0.le
        rw [paper3F1EzuDefNW_succ w, hminS]
        apply max_le
        · nlinarith [hqW, hscaled, hs1]
        · nlinarith [hbig, hs0.le]

theorem paper3F1EzuDefNW_le_ten (w : ℕ) (j : ℕ) :
    paper3F1EzuDefNW w j ≤ (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by
  have h := paper3F1EzuDefNW_le_staged w j
  have hm : ((min j 5 : ℕ) : ℝ) ≤ 5 := by
    exact_mod_cast min_le_right j 5
  have hs0 : (0 : ℝ) ≤ (bgpScale : ℝ) := by positivity
  nlinarith [h, hm, hs0]

/-- Every per-cycle N window envelope fits below the explicit `CwinN`. -/
theorem paper3F1EzuDefNW_window_le (w : ℕ) (j : ℕ) :
    max (paper3F1EzuDefNW w j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
      (bgpScale : ℝ) ≤ paper3F1CwinDefN := by
  have hs0 : (0 : ℝ) ≤ (bgpScale : ℝ) := by positivity
  have h1 := paper3F1EzuDefNW_le_ten w j
  have h2 : (bgpScale : ℝ) * Real.exp (198 : ℝ) ≤
      (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by
    have : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) + 10 := by
      have := Real.exp_le_exp.mpr (by norm_num : (198 : ℝ) ≤ 199)
      linarith
    exact mul_le_mul_of_nonneg_left this hs0
  have h := max_le h1 h2
  unfold paper3F1CwinDefN paper3F1CwinDef
  nlinarith [h]

/-- Pointwise u-kernel bound on the write window at the N rates: `sin ≥ 1/2`
gives `qPulse ≥ 3/4` at `L = 1`, hence
`A·α·bGateU ≤ e^{−450·bgpScale·τ}`. -/
theorem paper3NW_writeWindow_uKernel_le_exp (w j : ℕ) {τ : ℝ}
    (h1 : selectorMUWriteStartTime j ≤ τ)
    (h2 : τ ≤ selectorMUWriteReadTime j) :
    (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
        bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ ≤
      Real.exp (-(450 * (bgpScale : ℝ) * τ)) := by
  have hτ0 : 0 ≤ τ := le_trans (selectorMUWriteStartTime_nonneg j) h1
  have hα := paper3HeadlineSolFamNW_alpha w w hτ0
  have hμ := paper3HeadlineSolFamNW_mu w w hτ0
  rw [hα, hμ]
  simp only [(bgpParamsNW_A_eq w), one_mul, (bgpParamsNW_L_eq w)]
  unfold bGateU qPulse
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  have hsin : (1 : ℝ) / 2 ≤ Real.sin τ :=
    sin_window_ge j (by simpa [selectorMUWriteStartTime] using h1)
      (by simpa [selectorMUWriteReadTime] using h2)
  have hq : (3 : ℝ) / 4 ≤ ((1 + Real.sin τ) / 2) ^ 1 := by
    rw [pow_one]; linarith
  have hsW : (0 : ℝ) < (bgpScaleW w : ℝ) := bgpScaleWR_pos w
  have hssW : (bgpScale : ℝ) ≤ (bgpScaleW w : ℝ) := bgpScaleR_le_bgpScaleWR w
  rw [(bgpParamsNW_cα_def w), (bgpParamsNW_cμ_def w)]
  nlinarith [mul_le_mul_of_nonneg_left hq
    (mul_nonneg (mul_nonneg (by norm_num : (0 : ℝ) ≤ 1000) hsW.le) hτ0),
    mul_nonneg hsW.le hτ0,
    mul_le_mul_of_nonneg_right hssW hτ0]

/-- Integral-form u-freeze on the write window prefix `[ws j, t]`. -/
theorem paper3NW_u_drift_on_write_window (w j : ℕ) (i : Fin d_U)
    {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) {t : ℝ}
    (ht : t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteReadTime j))
    (hzu : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t,
      |((paper3HeadlineSolFamNW w) w).z τ i -
        ((paper3HeadlineSolFamNW w) w).u τ i| ≤ Bzu) :
    |((paper3HeadlineSolFamNW w) w).u t i -
        ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| ≤
      Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
          selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) := by
  have hsW : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hc : (0 : ℝ) < 450 * (bgpScale : ℝ) := by nlinarith
  have hws0 : 0 ≤ selectorMUWriteStartTime j :=
    selectorMUWriteStartTime_nonneg j
  have hgate_cont : Continuous fun τ : ℝ =>
      bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ := by
    unfold bGateU
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamNW w) w).cont_μ.mul
        (qPulse_continuous (bgpParamsNW w).L)).neg)
  have hgc : Continuous fun τ : ℝ =>
      (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
          bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ *
        (((paper3HeadlineSolFamNW w) w).z τ i -
          ((paper3HeadlineSolFamNW w) w).u τ i) :=
    ((continuous_const.mul ((paper3HeadlineSolFamNW w) w).cont_α).mul
        hgate_cont).mul
      ((((paper3HeadlineSolFamNW w) w).cont_z i).sub
        (((paper3HeadlineSolFamNW w) w).cont_u i))
  have hy : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t,
      HasDerivAt (fun s => ((paper3HeadlineSolFamNW w) w).u s i)
        ((bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
            bGateU (bgpParamsNW w).L
              (((paper3HeadlineSolFamNW w) w).μ τ) τ *
          (((paper3HeadlineSolFamNW w) w).z τ i -
            ((paper3HeadlineSolFamNW w) w).u τ i)) τ :=
    fun τ hτ => ((paper3HeadlineSolFamNW w) w).u_hasDeriv τ
      (selectorSchedule_domain_of_nonneg_structural τ (le_trans hws0 hτ.1)) i
  have hhold := hold_bound_integral
    (fun s => ((paper3HeadlineSolFamNW w) w).u s i)
    (fun τ => (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
        bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ *
      (((paper3HeadlineSolFamNW w) w).z τ i -
        ((paper3HeadlineSolFamNW w) w).u τ i))
    (selectorMUWriteStartTime j) t ht.1 hgc hy
  have hpt : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t,
      |(bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
          bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ *
        (((paper3HeadlineSolFamNW w) w).z τ i -
          ((paper3HeadlineSolFamNW w) w).u τ i)| ≤
      Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ)) := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans hws0 hτ.1
    have hτwin : τ ≤ selectorMUWriteReadTime j := le_trans hτ.2 ht.2
    have hker_nonneg : 0 ≤
        (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
          bGateU (bgpParamsNW w).L
            (((paper3HeadlineSolFamNW w) w).μ τ) τ := by
      have hα := paper3HeadlineSolFamNW_alpha w w hτ0
      rw [hα]
      simp only [(bgpParamsNW_A_eq w), one_mul]
      exact mul_nonneg (Real.exp_pos _).le
        (bGateU_pos (bgpParamsNW w).L _ τ).le
    rw [abs_mul, abs_of_nonneg hker_nonneg]
    calc (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
          bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ *
        |((paper3HeadlineSolFamNW w) w).z τ i -
          ((paper3HeadlineSolFamNW w) w).u τ i|
        ≤ Real.exp (-(450 * (bgpScale : ℝ) * τ)) * Bzu :=
          mul_le_mul (paper3NW_writeWindow_uKernel_le_exp w j hτ.1 hτwin)
            (hzu τ hτ) (abs_nonneg _) (Real.exp_pos _).le
      _ = Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ)) := by ring
  have hEnvCont : Continuous fun τ : ℝ =>
      Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ)) :=
    continuous_const.mul
      (Real.continuous_exp.comp (continuous_const.mul continuous_id).neg)
  have hmono := intervalIntegral.integral_mono_on ht.1
    (hgc.abs.intervalIntegrable (μ := MeasureTheory.volume)
      (selectorMUWriteStartTime j) t)
    (hEnvCont.intervalIntegrable (μ := MeasureTheory.volume)
      (selectorMUWriteStartTime j) t) hpt
  have hmass : (∫ τ in (selectorMUWriteStartTime j)..t,
      Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ))) ≤
      Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
          selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) := by
    rw [intervalIntegral.integral_const_mul]
    exact mul_le_mul_of_nonneg_left
      (paper3N_exp_mass_from_le hc ht.1) hBzu0
  calc |((paper3HeadlineSolFamNW w) w).u t i -
        ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i|
      ≤ ∫ τ in (selectorMUWriteStartTime j)..t,
          |(bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
              bGateU (bgpParamsNW w).L
                (((paper3HeadlineSolFamNW w) w).μ τ) τ *
            (((paper3HeadlineSolFamNW w) w).z τ i -
              ((paper3HeadlineSolFamNW w) w).u τ i)| := hhold
    _ ≤ ∫ τ in (selectorMUWriteStartTime j)..t,
          Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ)) := hmono
    _ ≤ Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
          selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) := hmass

/-- **F1-N DECOMPOSED ANALYTIC INPUT (1/5): the within-window relaxation
bootstrap at N rates and `bgpScale`-scaled hulls.**  The `bgpParams38`
sibling's route (docstring of `paper3F1_window_relaxation_bootstrap`)
transfers verbatim with rate `450·bgpScale`
(`u_drift_on_write_prefix_window_NW w` / `u_drift_on_settled_window_NW w`) and the
branch-eval hull `|evalBranch| ≤ B_U·|u| + O(D_U) ≤ bgpScale·e^{198}` — the
scaled hull is what makes this statement N-sound (`D_U ≤ 2·bgpScale`). -/
theorem paper3F1_window_relaxation_bootstrap_NW (w : ℕ)
    :
    ∀ (j : ℕ) (E : ℝ), 0 ≤ E →
      E ≤ (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) →
      (∀ i, paper3F1BoundaryErrNW w j i ≤ r_LE_U) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| ≤
          E) →
      ∀ i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamNW w) w).z t i -
          ((paper3HeadlineSolFamNW w) w).u t i| ≤
          max E ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ) := by
  classical
  intro j E hE0 hEle htube0 hE
  have hs4 : (4 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_four
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hD8 := paper3N_D_U_ge_eight
  have hDle := D_U_le_two_bgpScale
  have h198 : (199 : ℝ) ≤ Real.exp (198 : ℝ) := by
    linarith [Real.add_one_le_exp (198 : ℝ)]
  have hws0 : 0 ≤ selectorMUWriteStartTime j :=
    selectorMUWriteStartTime_nonneg j
  set L : ℝ := max E ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ)
    with hLdef
  have hmaxE := le_max_left E ((bgpScale : ℝ) * Real.exp (198 : ℝ))
  have hmaxS := le_max_right E ((bgpScale : ℝ) * Real.exp (198 : ℝ))
  have hL0 : 0 ≤ L := by
    rw [hLdef]
    nlinarith [hmaxE, hE0, hs0]
  have hLle : L ≤ (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 11) := by
    have hexpm : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) + 10 := by
      have := Real.exp_le_exp.mpr (by norm_num : (198 : ℝ) ≤ 199)
      linarith
    have h1 : (bgpScale : ℝ) * Real.exp (198 : ℝ) ≤
        (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by nlinarith
    have hmax := max_le hEle h1
    rw [hLdef]
    nlinarith [hmax]
  have htube0' : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U := by
    intro i
    have h := htube0 i
    unfold paper3F1BoundaryErrNW at h
    exact h
  have henc : ∀ i : Fin d_U,
      |stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ 2 * D_U := by
    intro i
    rw [stackMachineEncodingU_enc_eq]
    exact paper3N_confEncU_abs_le_two_D_U _ i
  -- the conditional interior estimate: under the `L`-box up to `t`, the
  -- coupled pair actually sits `bgpScale/2`-deep inside the exit level
  have hcore : ∀ t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
      (∀ τ ∈ Icc (selectorMUWriteStartTime j) t, ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z τ i -
          ((paper3HeadlineSolFamNW w) w).u τ i| ≤ L) →
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z t i -
          ((paper3HeadlineSolFamNW w) w).u t i| ≤
          max E ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + 1 / 2 := by
    intro t ht hbox
    have hdrift : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t, ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).u τ i -
          ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| ≤
          1 / 8 := by
      intro τ hτ i
      have hτwin : τ ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteReadTime j) := ⟨hτ.1, le_trans hτ.2 ht.2⟩
      have hd := paper3NW_u_drift_on_write_window w j i hL0 hτwin
        (fun σ hσ => hbox σ ⟨hσ.1, le_trans hσ.2 hτ.2⟩ i)
      exact le_trans hd (paper3N_writeWindow_drift_le_eighth j hL0 hLle)
    have hutube : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t, ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).u τ i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ (1 / 3 : ℝ) := by
      intro τ hτ i
      have h1 := hdrift τ hτ i
      have h2 := htube0' i
      have hrv : r_LE_U = 1 / 1000 := rfl
      calc |((paper3HeadlineSolFamNW w) w).u τ i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i|
          ≤ |((paper3HeadlineSolFamNW w) w).u τ i -
              ((paper3HeadlineSolFamNW w) w).u
                (selectorMUWriteStartTime j) i| +
            |((paper3HeadlineSolFamNW w) w).u
                (selectorMUWriteStartTime j) i -
              stackMachineEncodingU.enc (paper3F1Cfg w j) i| :=
            abs_sub_le _ _ _
        _ ≤ 1 / 8 + r_LE_U := add_le_add h1 h2
        _ ≤ 1 / 3 := by rw [hrv]; norm_num
    have hmix : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t, ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
            ((paper3HeadlineSolFamNW w) w).lam τ i| ≤ 2 * D_U := by
      intro τ hτ
      exact paper3NW_mixTarget_abs_le_of_branch_abs w w
        (le_trans hws0 hτ.1)
        (fun i v => branchU_evalBranch_abs_le_two_D_U_of_third_tube
          (fun k => hutube τ hτ k) v i)
    intro i
    have hzt : ((paper3HeadlineSolFamNW w) w).z t i ∈
        Icc (min (((paper3HeadlineSolFamNW w) w).z
              (selectorMUWriteStartTime j) i) (-(2 * D_U)))
          (max (((paper3HeadlineSolFamNW w) w).z
