        (3 / 4 : ℝ) ^ paper3HeadlineM *
          (((paper3WarmGainQNW wg : ℚ) : ℝ) *
            Real.exp ((bgpParamsNW wg).cα *
              selectorMUSelectStartTime j)) ≤ paper3NW4cg wg s := by
      intro s hs
      have hgate : s ∈
          Set.Icc (2 * Real.pi * (j : ℝ) + Real.pi / 6)
