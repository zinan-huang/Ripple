    -- u box on the prefix by forward invariance
    have hupre : ∀ i : Fin d_U, ∀ s ∈ Icc
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) (sInf Bad),
        |((paper3HeadlineSolFamNW w) w).u s i| ≤ paper3S2GuardCu := by
      intro i
      have hCzCu : paper3S2GuardCz ≤ paper3S2GuardCu := by
        unfold paper3S2GuardCz paper3S2GuardCu
        linarith
      have hbox := relaxation_box_invariant
        (fun τ => ((paper3HeadlineSolFamNW w) w).u τ i)
        (fun τ => ((paper3HeadlineSolFamNW w) w).z τ i)
        (fun τ => (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
          bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ)
        (lo := -paper3S2GuardCu) (hi := paper3S2GuardCu) hta
        (paper3NW4_uKernel_continuous w w)
        (((paper3HeadlineSolFamNW w) w).cont_z i)
        (fun t ht => ((paper3HeadlineSolFamNW w) w).u_hasDeriv t
          (selectorSchedule_domain_of_nonneg_structural t
            (le_trans ha0 ht.1)) i)
        (fun t ht => paper3NW4_uKernel_nonneg w w (le_trans ha0 ht.1))
        (fun t ht => by
          have hz := hzpre t ht i
