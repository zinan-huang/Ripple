    linarith [hi1, hdrift, hcap, hza, hmargin, hsplit]
  -- u box on the whole window from the closed z box
  have hu_all : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3S2GuardCu := by
    intro t ht i
    have hbox := relaxation_box_invariant
      (fun τ => ((paper3HeadlineSolFamNW w) w).u τ i)
      (fun τ => ((paper3HeadlineSolFamNW w) w).z τ i)
      (fun τ => (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
        bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ)
      (lo := -paper3S2GuardCu) (hi := paper3S2GuardCu) hab
      (paper3NW4_uKernel_continuous w w)
      (((paper3HeadlineSolFamNW w) w).cont_z i)
      (fun s hs => ((paper3HeadlineSolFamNW w) w).u_hasDeriv s
        (selectorSchedule_domain_of_nonneg_structural s
          (le_trans ha0 hs.1)) i)
      (fun s hs => paper3NW4_uKernel_nonneg w w (le_trans ha0 hs.1))
      (fun s hs => by
        have hz := hz_all s hs i
        rw [abs_le] at hz
        unfold paper3S2GuardCz at hz
        constructor
        · unfold paper3S2GuardCu
          linarith [hz.1]
        · unfold paper3S2GuardCu
          linarith [hz.2])
      (by
        have hu := hu_entry i
        rw [abs_le] at hu
        exact ⟨by linarith [hu.1], by linarith [hu.2]⟩)
    have hu := hbox t ht
    rw [abs_le]
    exact ⟨by linarith [hu.1], by linarith [hu.2]⟩
