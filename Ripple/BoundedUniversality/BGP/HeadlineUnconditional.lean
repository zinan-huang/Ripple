            Real.exp ((bgpParamsNW wg).cα *
              selectorMUSelectStartTime j))) =
        (3 / 4 : ℝ) ^ paper3HeadlineM *
          (((paper3WarmGainQNW wg : ℚ) : ℝ) *
            Real.exp ((bgpParamsNW wg).cα *
              selectorMUSelectStartTime j)) *
          (selectorMUWriteHoldTime j - selectorMUSelectStartTime j) := by
      rw [intervalIntegral.integral_const]
      ring
    have hlen : selectorMUWriteHoldTime j - selectorMUSelectStartTime j =
