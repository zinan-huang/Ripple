      |selectorMixTarget branchU sol.u sol.lam τ i| ≤ 2 * D_U := by
    intro τ hτ i
    have hτ0 : 0 ≤ τ :=
      le_trans (selectorMUWriteStartTime_nonneg j) hτ.1
    refine paper3NW_mixTarget_abs_le_of_branch_abs w w hτ0 ?_ i
    intro iw v
    exact branchU_evalBranch_abs_le_two_D_U
      (fun ix => hT τ hτ ix) v iw
  -- z entry at read time
  have hzwr : ∀ i : Fin d_U, |sol.z (selectorMUWriteReadTime j) i| ≤
      paper3F1MixC0NW := by
    intro i
    have h1 := hwin i (selectorMUWriteReadTime j) ⟨hws_wr, le_refl _⟩
