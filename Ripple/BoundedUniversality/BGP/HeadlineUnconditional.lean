theorem paper3S4_absRHS_le_badPair_sum
    (wg w j : ℕ) (c : UniversalLocalView)
    (hc : c = localViewU (solMUReplStaticCfg w j) ∨
      c = localViewU (solMUReplStaticCfg w (j + 1)))
    (henc : selectorMUHaltEncConstW solMUReplStaticCfg w j)
    {τ : ℝ} (hτ0 : 0 ≤ τ) :
    |SelectorReplicatorDynSol.mixTargetDerivRHS
        ((paper3HeadlineSolFam wg) w) τ haltCoordU| ≤
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
        (fun v =>
          |selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
              (Fintype.card UniversalLocalView : ℝ)⁻¹ -
            selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
                (paper3HeadlineSolFam wg) w c v τ *
              ((paper3HeadlineSolFam wg) w).lam v τ +
            selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
              (∑ x : UniversalLocalView,
                ((paper3HeadlineSolFam wg) w).lam x τ *
                  (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
                      (((paper3HeadlineSolFam wg) w).u τ) -
                    universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                      (((paper3HeadlineSolFam wg) w).u τ))) *
              ((paper3HeadlineSolFam wg) w).lam v τ|) := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  have hM : stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 2)) haltCoordU =
      stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) haltCoordU := by
    simpa [selectorMUHaltEncConstW, selectorMUHaltEncConst] using henc
  have hBeq :
      BranchData.evalBranch (branchU (localViewU (solMUReplStaticCfg w j)))
        (((paper3HeadlineSolFam wg) w).u τ) haltCoordU =
      BranchData.evalBranch (branchU (localViewU (solMUReplStaticCfg w (j + 1))))
        (((paper3HeadlineSolFam wg) w).u τ) haltCoordU := by
    rw [branchU_haltCoord_exact_independent, branchU_haltCoord_exact_independent,
      solMUReplStaticCfg_step, solMUReplStaticCfg_step]
    exact hM.symm
  have hkill : ∀ v : UniversalLocalView,
      (v = localViewU (solMUReplStaticCfg w j) ∨
        v = localViewU (solMUReplStaticCfg w (j + 1))) →
      BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFam wg) w).u τ) haltCoordU -
        BranchData.evalBranch (branchU c)
          (((paper3HeadlineSolFam wg) w).u τ) haltCoordU = 0 := by
    intro v hv
    rcases hv with rfl | rfl
    · rcases hc with rfl | rfl
      · exact sub_self _
      · exact sub_eq_zero_of_eq hBeq
    · rcases hc with rfl | rfl
      · exact sub_eq_zero_of_eq hBeq.symm
      · exact sub_self _
  have hcenter :=
    selectorMU_mixTargetDerivRHS_halt_eq_centered_lam_of_boxInputs
      (sol := paper3HeadlineSolFam wg) (paper3HeadlineBoxInputs wg) w
      (τ := τ) hτ0 c
  have hode : ∀ v : UniversalLocalView,
      HasDerivAt (((paper3HeadlineSolFam wg) w).lam v)
        ((((1 + Real.cos τ) / 2) ^ paper3HeadlineM *
            ((paper3HeadlineKappa : ℚ) : ℝ)) *
          (1 / (Fintype.card UniversalLocalView : ℝ) -
            ((paper3HeadlineSolFam wg) w).lam v τ)
        + (((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
            (((paper3WarmGainQ wg : ℚ) : ℝ) *
