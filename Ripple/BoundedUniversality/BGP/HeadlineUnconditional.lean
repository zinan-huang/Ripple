      Real.exp (-(20 * (bgpScaleW wg : ℝ))) :=
    mul_nonneg (Real.exp_pos _).le (Real.exp_pos _).le
  have hcoef0 : (0 : ℝ) ≤ 4 * D_U + 3 := by nlinarith
  calc (4 * D_U + 3) *
