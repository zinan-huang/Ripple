    intro v
    simpa [selectorSchedule] using
      ((paper3HeadlineSolFam wg) w).lam_hasDeriv v τ
        (by simpa [selectorSchedule] using hτ0)
  have hg : ∀ v : UniversalLocalView,
      HasDerivAt (((paper3HeadlineSolFam wg) w).lam v)
        (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
            (Fintype.card UniversalLocalView : ℝ)⁻¹ -
          selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
              (paper3HeadlineSolFam wg) w c v τ *
            ((paper3HeadlineSolFam wg) w).lam v τ +
          selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
            (∑ x : UniversalLocalView,
              ((paper3HeadlineSolFam wg) w).lam x τ *
                (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
                    (((paper3HeadlineSolFam wg) w).u τ) -
                  universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                    (((paper3HeadlineSolFam wg) w).u τ))) *
            ((paper3HeadlineSolFam wg) w).lam v τ) τ := by
    intro v
    have h :=
      selectorMU_lam_hasDerivAt_gapTrackingResidual_add_meanGap_of_boxInputs
        (sol := paper3HeadlineSolFam wg) (paper3HeadlineBoxInputs wg) w hτ0 c v
    simpa [selectorMU_activeCr, selectorMU_activeCg, selectorMU_activeSink]
      using h
  calc |SelectorReplicatorDynSol.mixTargetDerivRHS
          ((paper3HeadlineSolFam wg) w) τ haltCoordU|
      = |∑ v : UniversalLocalView,
          ((((1 + Real.cos τ) / 2) ^ paper3HeadlineM *
                ((paper3HeadlineKappa : ℚ) : ℝ) *
              (1 / (Fintype.card UniversalLocalView : ℝ) -
                ((paper3HeadlineSolFam wg) w).lam v τ) +
            ((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQ wg : ℚ) : ℝ) *
                Real.exp (bgpParams38.cα * τ)) *
              ((paper3HeadlineSolFam wg) w).lam v τ *
                (universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                    (((paper3HeadlineSolFam wg) w).u τ) -
                  ∑ x : UniversalLocalView,
                    ((paper3HeadlineSolFam wg) w).lam x τ *
                      universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                        (((paper3HeadlineSolFam wg) w).u τ))) *
            (BranchData.evalBranch (branchU v)
                (((paper3HeadlineSolFam wg) w).u τ) haltCoordU -
              BranchData.evalBranch (branchU c)
                (((paper3HeadlineSolFam wg) w).u τ) haltCoordU))| := by
        rw [hcenter]
    _ ≤ ∑ v : UniversalLocalView,
          |((((1 + Real.cos τ) / 2) ^ paper3HeadlineM *
                ((paper3HeadlineKappa : ℚ) : ℝ) *
              (1 / (Fintype.card UniversalLocalView : ℝ) -
                ((paper3HeadlineSolFam wg) w).lam v τ) +
            ((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQ wg : ℚ) : ℝ) *
                Real.exp (bgpParams38.cα * τ)) *
              ((paper3HeadlineSolFam wg) w).lam v τ *
                (universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                    (((paper3HeadlineSolFam wg) w).u τ) -
                  ∑ x : UniversalLocalView,
                    ((paper3HeadlineSolFam wg) w).lam x τ *
                      universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                        (((paper3HeadlineSolFam wg) w).u τ))) *
            (BranchData.evalBranch (branchU v)
                (((paper3HeadlineSolFam wg) w).u τ) haltCoordU -
              BranchData.evalBranch (branchU c)
                (((paper3HeadlineSolFam wg) w).u τ) haltCoordU))| :=
        Finset.abs_sum_le_sum_abs _ _
    _ = (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v =>
            |((((1 + Real.cos τ) / 2) ^ paper3HeadlineM *
                  ((paper3HeadlineKappa : ℚ) : ℝ) *
                (1 / (Fintype.card UniversalLocalView : ℝ) -
                  ((paper3HeadlineSolFam wg) w).lam v τ) +
              ((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
                (((paper3WarmGainQ wg : ℚ) : ℝ) *
                  Real.exp (bgpParams38.cα * τ)) *
                ((paper3HeadlineSolFam wg) w).lam v τ *
                  (universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                      (((paper3HeadlineSolFam wg) w).u τ) -
                    ∑ x : UniversalLocalView,
                      ((paper3HeadlineSolFam wg) w).lam x τ *
                        universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                          (((paper3HeadlineSolFam wg) w).u τ))) *
              (BranchData.evalBranch (branchU v)
                  (((paper3HeadlineSolFam wg) w).u τ) haltCoordU -
                BranchData.evalBranch (branchU c)
                  (((paper3HeadlineSolFam wg) w).u τ) haltCoordU))|) := by
        refine (Finset.sum_filter_of_ne ?_).symm
        intro v _ hne
        constructor
        · rintro rfl
          exact hne (by rw [hkill _ (Or.inl rfl), mul_zero, abs_zero])
        · rintro rfl
          exact hne (by rw [hkill _ (Or.inr rfl), mul_zero, abs_zero])
    _ ≤ (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v =>
            |selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
                (Fintype.card UniversalLocalView : ℝ)⁻¹ -
              selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
                  (paper3HeadlineSolFam wg) w c v τ *
                ((paper3HeadlineSolFam wg) w).lam v τ +
              selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
                (∑ x : UniversalLocalView,
                  ((paper3HeadlineSolFam wg) w).lam x τ *
                    (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
                        (((paper3HeadlineSolFam wg) w).u τ) -
                      universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                        (((paper3HeadlineSolFam wg) w).u τ))) *
                ((paper3HeadlineSolFam wg) w).lam v τ|) := by
        refine Finset.sum_le_sum ?_
        intro v _
        rw [(hode v).unique (hg v), abs_mul]
        exact mul_le_of_le_one_right (abs_nonneg _)
          (branchU_haltCoord_spread_le_one v c
            (((paper3HeadlineSolFam wg) w).u τ))

