/--
Concrete shifted warm-gain headline frontier.

All structural field hypotheses are fixed to the concrete Paper 3 values.  The
-/
theorem paper3_headline_unconditional_of_late_start
    (init_presented :
      ∃ f : ℕ → Fin (selectorDim d_U UniversalLocalView + 1) → ℤ × ℕ,
        Computable f ∧
        ∀ w i, (f w i).2 ≠ 0 ∧
          selectorReplicatorSphereInitQ d_U UniversalLocalView selectorInitX0 w
            (paper3WarmGainQ w) i =
            (f w i).1 / ((f w i).2 : ℚ))
    (init_zero :
      ∀ (w : ℕ)
        (sol : MUReplicatorSolW paper3HeadlineEta paper3HeadlineEta_pos
          paper3HeadlineM paper3HeadlineKappa paper3WarmGainQ w)
        (La : SelectorReplicatorHaltLatchSol sol
          (fun _ : (Fin d_U → ℝ) => (0 : ℝ)) 0 paper3HeadlineR),
          ((selectorReplicatorSphereInitQ d_U UniversalLocalView selectorInitX0 w
              (paper3WarmGainQ w) 0 : ℚ) : ℝ) =
            ((∑ i : Fin (selectorDim d_U UniversalLocalView),
                selectorReplicatorTupleTraj sol La ((paper3WarmGainQ w : ℚ) : ℝ)
                  0 i ^ 2) - 1) /
              ((∑ i : Fin (selectorDim d_U UniversalLocalView),
                selectorReplicatorTupleTraj sol La ((paper3WarmGainQ w : ℚ) : ℝ)
                  0 i ^ 2) + 1))
    (init_succ :
      ∀ (w : ℕ)
        (sol : MUReplicatorSolW paper3HeadlineEta paper3HeadlineEta_pos
          paper3HeadlineM paper3HeadlineKappa paper3WarmGainQ w)
        (La : SelectorReplicatorHaltLatchSol sol
          (fun _ : (Fin d_U → ℝ) => (0 : ℝ)) 0 paper3HeadlineR)
        (i : Fin (selectorDim d_U UniversalLocalView)),
          ((selectorReplicatorSphereInitQ d_U UniversalLocalView selectorInitX0 w
              (paper3WarmGainQ w) i.succ : ℚ) : ℝ) =
            2 * selectorReplicatorTupleTraj sol La ((paper3WarmGainQ w : ℚ) : ℝ) 0 i /
              ((∑ k : Fin (selectorDim d_U UniversalLocalView),
