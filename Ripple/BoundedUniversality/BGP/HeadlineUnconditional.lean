          have hmem : τ ∈ Bad :=
            ⟨⟨hτ.1.le, le_trans hτ.2.le htle⟩,
              Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
          exact absurd (csInf_le hbdd hmem) (not_le.mpr hτ.2)
