/-- Conditional sharp prewrite Duhamel bound for the old/new bad mass.

The `ZOffEnd` initial bound, safe-mass floor, and pairwise payoff gap are kept
as explicit hypotheses; these are the genuine producers still needed for the
no-middle Hoff edge route. -/
theorem paper3HeadlinePrewriteOldNewBadMassDuhamelSharp
    (wg w j : ℕ) {B0 Lsafe : ℝ}
    (hgapL_pos :
      0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        Lsafe)
    (hsafe_floor : ∀ t ∈
      Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      Lsafe ≤
        (insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView)).sum
          (fun u => ((paper3HeadlineSolFam wg) w).lam u t))
    (hpair : ∀ t ∈
      Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      ∀ v : UniversalLocalView,
        v ∉ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
    (hBa :
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => ((paper3HeadlineSolFam wg) w).lam v
            (selectorMUZOffEnd j)) ≤ B0) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUZOffEnd j
    let b : ℝ := selectorMUWriteStartTime (j + 1)
    ∀ t ∈ Icc a b,
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => (sol w).lam v t)
        ≤
      B0 * Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) +
        (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          (((Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
            (Fintype.card UniversalLocalView : ℝ))) / (gap * Lsafe) := by
  classical
  dsimp
  intro t ht
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let Creset : ℝ :=
    ((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)
  have hab :
      selectorMUZOffEnd j ≤ selectorMUWriteStartTime (j + 1) :=
    selectorMUZOffEnd_le_writeStart_succ j
  have ha_nonneg : 0 ≤ selectorMUZOffEnd j := by
    unfold selectorMUZOffEnd
    positivity
  have hI_nonneg :
      ∀ t ∈ Icc (selectorMUZOffEnd j)
          (selectorMUWriteStartTime (j + 1)), 0 ≤ t := by
    intro t ht
    exact le_trans ha_nonneg ht.1
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hgap_nonneg : 0 ≤ gap := hgap_pos.le
  have hgapL_pos' : 0 < gap * Lsafe := by
    simpa [gap] using hgapL_pos
  have hduh :=
    selectorMU_old_new_badMass_duhamel_bound_on_Icc
      (sol := paper3HeadlineSolFam wg)
      (paper3HeadlineBoxInputs wg)
      (paper3WarmGainQ_nonneg wg)
      w j
      (a := selectorMUZOffEnd j)
      (b := selectorMUWriteStartTime (j + 1))
      (gap := gap)
      (Lsafe := Lsafe)
      hab
      hI_nonneg
      hgap_nonneg
      hgapL_pos'
      hsafe_floor
      (by
        intro t ht v hv u hu
        simpa [gap] using hpair t ht v hv u hu)
      t ht
  have hsrc :=
    paper3HeadlinePrewriteOldNewSourceDecayWithGapEff
      (wg := wg) (w := w) (j := j)
      (gapEff := gap * Lsafe) hgapL_pos' t ht
  have hdecay_nonneg :
      0 ≤
        Real.exp (-((gap * Lsafe) *
          (((paper3HeadlineSolFam wg) w).G t -
            ((paper3HeadlineSolFam wg) w).G (selectorMUZOffEnd j)))) :=
    (Real.exp_pos _).le
  calc
    (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
        (fun v => ((paper3HeadlineSolFam wg) w).lam v t)
        ≤
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => ((paper3HeadlineSolFam wg) w).lam v
            (selectorMUZOffEnd j)) *
          Real.exp (-((gap * Lsafe) *
            (((paper3HeadlineSolFam wg) w).G t -
              ((paper3HeadlineSolFam wg) w).G (selectorMUZOffEnd j)))) +
        (∫ s in (selectorMUZOffEnd j)..t,
          Real.exp ((gap * Lsafe) *
              (((paper3HeadlineSolFam wg) w).G s -
                ((paper3HeadlineSolFam wg) w).G (selectorMUZOffEnd j))) *
            (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
              (paper3HeadlineKappa : ℝ)) *
            Creset) *
          Real.exp (-((gap * Lsafe) *
            (((paper3HeadlineSolFam wg) w).G t -
              ((paper3HeadlineSolFam wg) w).G (selectorMUZOffEnd j)))) := by
          simpa [sol, gap, Creset, mul_assoc] using hduh
    _ ≤
      B0 *
          Real.exp (-((gap * Lsafe) *
            (((paper3HeadlineSolFam wg) w).G t -
              ((paper3HeadlineSolFam wg) w).G (selectorMUZOffEnd j)))) +
        (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
          (gap * Lsafe) := by
          exact add_le_add
            (mul_le_mul_of_nonneg_right hBa hdecay_nonneg)
            (by
              simpa [sol, gap, Creset, mul_assoc, mul_left_comm, mul_comm]
                using hsrc)
    _ =
      B0 *
          Real.exp (-((gap * Lsafe) *
            (((paper3HeadlineSolFam wg) w).G t -
              ((paper3HeadlineSolFam wg) w).G (selectorMUZOffEnd j)))) +
        (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
          (((Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
            (Fintype.card UniversalLocalView : ℝ))) / (gap * Lsafe) := by
          simp [Creset]

