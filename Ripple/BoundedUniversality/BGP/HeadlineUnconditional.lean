  no contraction at small `j`), so the piece is doubly-exponentially dead
  (`paper3N_earlyPiece_arith`): `≤ 1/2`.
* `[U0 j, zOffEnd j]` (`sin ≤ 0`): N leak
  `gateZ_integrand_le_offphase_exp_N` (`≤ e^{−200·bgpScale·τ}`), weight
  `≤ 1`, mass `≤ 1/(200·bgpScale)`: `≤ 1/20`.

The `|mix − z|` box (`5·D_U`) is consumed as an explicit HYPOTHESIS: the
crude `CwinN` window data cannot produce ANY inter-read box (the u-copy
imports z's `O(bgpScale·e^{200})` window displacement into `u` and the
branch evaluations amplify by `B_U` per cycle — only the settled one-cycle
machinery tames it).  It is discharged through
`Paper3F1InterReadMixBoxNW` below.  The prewrite tail is handled by the
no-slop trapping `paper3NW_prewrite_zu_hold`, NOT by this integral. -/
theorem paper3F1_interRead_source_cap_NW (w : ℕ)
    :
    ∀ j : ℕ,
      (∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUWriteReadTime j)
          (selectorMUZOffEnd j),
        |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
            ((paper3HeadlineSolFamNW w) w).lam τ i -
          ((paper3HeadlineSolFamNW w) w).z τ i| ≤ paper3F1MixCrudeBoxNW) →
      ∀ i : Fin d_U,
        (∫ τ in (selectorMUWriteReadTime j)..(selectorMUZOffEnd j),
          Real.exp (-(∫ s in τ..(selectorMUZOffEnd j),
            (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α s *
              bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ s) s)) *
          |(bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
            bGateZ (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ *
            (selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
                ((paper3HeadlineSolFamNW w) w).lam τ i -
              ((paper3HeadlineSolFamNW w) w).z τ i)|) ≤ 1 := by
  intro j hbox i
  have hπ := Real.pi_pos
  have hs0 : (0 : ℝ) < (bgpScaleW w : ℝ) := bgpScaleWR_pos w
  have hs1 : (1 : ℝ) ≤ (bgpScaleW w : ℝ) := bgpScaleWR_ge_one w
  have hDle : (D_U : ℝ) ≤ 2 * (bgpScaleW w : ℝ) := D_U_le_two_bgpScaleW w
  have hB0 : (0 : ℝ) ≤ paper3F1MixCrudeBoxNW :=
    paper3F1MixCrudeBoxNW_nonneg
  let a : ℝ := selectorMUWriteReadTime j
  let m : ℝ := selectorMUUActiveStart j
  let b : ℝ := selectorMUZOffEnd j
  let kU : ℝ → ℝ := fun s =>
    (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α s *
      bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ s) s
  let src : ℝ → ℝ := fun τ =>
    (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
      bGateZ (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ *
      (selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
          ((paper3HeadlineSolFamNW w) w).lam τ i -
        ((paper3HeadlineSolFamNW w) w).z τ i)
  let F : ℝ → ℝ := fun τ => Real.exp (-(∫ s in τ..b, kU s)) * |src τ|
  have ha0 : 0 ≤ a := by
    dsimp only [a]
    unfold selectorMUWriteReadTime
    nlinarith [hπ, (Nat.cast_nonneg j : (0 : ℝ) ≤ (j : ℝ))]
  have hm0 : 0 ≤ m := by
    dsimp only [m]
    unfold selectorMUUActiveStart
    nlinarith [hπ, (Nat.cast_nonneg j : (0 : ℝ) ≤ (j : ℝ))]
  have ham : a ≤ m := by
    dsimp only [a, m]
    unfold selectorMUWriteReadTime selectorMUUActiveStart
    linarith
  have hmb : m ≤ b := by
    dsimp only [m, b]
    unfold selectorMUUActiveStart selectorMUZOffEnd
    push_cast
    linarith
  have hU1b : selectorMUUActiveEnd j ≤ b := by
    dsimp only [b]
    unfold selectorMUUActiveEnd selectorMUZOffEnd
    push_cast
    linarith
  have hU10 : 0 ≤ selectorMUUActiveEnd j := by
    unfold selectorMUUActiveEnd
    nlinarith [hπ, (Nat.cast_nonneg j : (0 : ℝ) ≤ (j : ℝ))]
  have hgateU_cont : Continuous fun s : ℝ =>
      bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ s) s := by
    have hq : Continuous fun s : ℝ => qPulse (bgpParamsNW w).L s := by
      simp only [qPulse]
      exact ((continuous_const.add Real.continuous_sin).div_const 2).pow
        (bgpParamsNW w).L
    simp only [bGateU]
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamNW w) w).cont_μ.mul hq).neg)
  have hkU_cont : Continuous kU :=
    (continuous_const.mul ((paper3HeadlineSolFamNW w) w).cont_α).mul
      hgateU_cont
  have hkU_nonneg : ∀ s : ℝ, 0 ≤ s → 0 ≤ kU s := by
    intro s hs0'
    have hαs := paper3HeadlineSolFamNW_alpha w w hs0'
    dsimp only [kU]
    rw [hαs, (bgpParamsNW_A_eq w), one_mul]
    have hg : (0 : ℝ) ≤ bGateU (bgpParamsNW w).L
        (((paper3HeadlineSolFamNW w) w).μ s) s := by
      simp only [bGateU]
      exact (Real.exp_pos _).le
    exact mul_nonneg (Real.exp_pos _).le hg
  have hsrc_cont : Continuous src := by
    have hr : Continuous fun t : ℝ => rPulse (bgpParamsNW w).L t := by
      simp only [rPulse]
      exact ((continuous_const.sub Real.continuous_sin).div_const 2).pow
        (bgpParamsNW w).L
    have hgateZ : Continuous fun t : ℝ =>
        bGateZ (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ t) t := by
      simp only [bGateZ]
      exact Real.continuous_exp.comp
        ((((paper3HeadlineSolFamNW w) w).cont_μ.mul hr).neg)
    have hAα : Continuous fun t : ℝ =>
        (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α t :=
      continuous_const.mul ((paper3HeadlineSolFamNW w) w).cont_α
    have hdiff : Continuous fun t : ℝ =>
        selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
            ((paper3HeadlineSolFamNW w) w).lam t i -
          ((paper3HeadlineSolFamNW w) w).z t i :=
      (((paper3HeadlineSolFamNW w) w).cont_mixTarget i).sub
        (((paper3HeadlineSolFamNW w) w).cont_z i)
    dsimp only [src]
    exact (hAα.mul hgateZ).mul hdiff
  have hkU_int : ∀ x y : ℝ, IntervalIntegrable kU MeasureTheory.volume x y :=
    fun x y => hkU_cont.intervalIntegrable x y
  have hprim_cont : Continuous fun τ : ℝ => ∫ s in (0 : ℝ)..τ, kU s := by
    apply continuous_iff_continuousAt.mpr
    intro t
    exact (intervalIntegral.integral_hasDerivAt_right (hkU_int 0 t)
      (hkU_cont.stronglyMeasurableAtFilter _ _)
      hkU_cont.continuousAt).continuousAt
  have hWeq : ∀ τ : ℝ, (∫ s in τ..b, kU s) =
      (∫ s in (0 : ℝ)..b, kU s) - ∫ s in (0 : ℝ)..τ, kU s := by
    intro τ
    have h := intervalIntegral.integral_add_adjacent_intervals
      (hkU_int 0 τ) (hkU_int τ b)
    linarith
  have hW_cont : Continuous fun τ : ℝ =>
      Real.exp (-(∫ s in τ..b, kU s)) := by
    have hfun : (fun τ : ℝ => Real.exp (-(∫ s in τ..b, kU s))) =
        fun τ : ℝ => Real.exp (-((∫ s in (0 : ℝ)..b, kU s) -
          ∫ s in (0 : ℝ)..τ, kU s)) := by
      funext τ
      rw [hWeq τ]
    rw [hfun]
    exact Real.continuous_exp.comp ((continuous_const.sub hprim_cont).neg)
  have hF_cont : Continuous F := hW_cont.mul hsrc_cont.abs
  have hsplit : (∫ τ in a..b, F τ) =
      (∫ τ in a..m, F τ) + ∫ τ in m..b, F τ :=
    (intervalIntegral.integral_add_adjacent_intervals
      (hF_cont.intervalIntegrable a m) (hF_cont.intervalIntegrable m b)).symm
  -- the strong u-active weight kill on the early piece
  have hX175 : Real.exp (175 * (bgpScaleW w : ℝ)) ≤
      Real.exp (50 * (bgpScaleW w : ℝ) * m) := by
    apply Real.exp_le_exp.mpr
    dsimp only [m]
    unfold selectorMUUActiveStart
    have hπ3 : (3 : ℝ) < Real.pi := Real.pi_gt_three
    have hjnn : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith [mul_nonneg (mul_nonneg hs0.le Real.pi_pos.le) hjnn,
      mul_nonneg hs0.le (sub_nonneg.mpr hπ3.le)]
  have hmid : (2 * Real.pi / 3) * Real.exp (50 * (bgpScaleW w : ℝ) * m) ≤
      ∫ s' in m..(selectorMUUActiveEnd j), kU s' := by
    have hmU1 : m ≤ selectorMUUActiveEnd j := by
      dsimp only [m]
      unfold selectorMUUActiveStart selectorMUUActiveEnd
      linarith
    have hpoint : ∀ s' ∈ Icc m (selectorMUUActiveEnd j),
        Real.exp (50 * (bgpScaleW w : ℝ) * m) ≤ kU s' := by
      intro s' hs'
      exact paper3NW_uActive_kernel_ge w j hs'.1 hs'.2
    have hmono := intervalIntegral.integral_mono_on hmU1
      _root_.intervalIntegrable_const
      (hkU_cont.intervalIntegrable (μ := MeasureTheory.volume) m
        (selectorMUUActiveEnd j)) hpoint
    have hconst : (∫ _s' in m..(selectorMUUActiveEnd j),
        Real.exp (50 * (bgpScaleW w : ℝ) * m)) =
        (selectorMUUActiveEnd j - m) *
          Real.exp (50 * (bgpScaleW w : ℝ) * m) := by
      rw [intervalIntegral.integral_const, smul_eq_mul]
    have hlen : selectorMUUActiveEnd j - m = 2 * Real.pi / 3 := by
      dsimp only [m]
      unfold selectorMUUActiveStart selectorMUUActiveEnd
      ring
    calc (2 * Real.pi / 3) * Real.exp (50 * (bgpScaleW w : ℝ) * m)
        = (selectorMUUActiveEnd j - m) *
            Real.exp (50 * (bgpScaleW w : ℝ) * m) := by rw [hlen]
      _ = ∫ _s' in m..(selectorMUUActiveEnd j),
            Real.exp (50 * (bgpScaleW w : ℝ) * m) := hconst.symm
      _ ≤ ∫ s' in m..(selectorMUUActiveEnd j), kU s' := hmono
  have hweight_early : ∀ τ ∈ Icc a m,
      Real.exp (-(∫ s' in τ..b, kU s')) ≤
        Real.exp (-(2 * Real.pi / 3 *
          Real.exp (50 * (bgpScaleW w : ℝ) * m))) := by
    intro τ hτ
    apply Real.exp_le_exp.mpr
    have hτ0' : 0 ≤ τ := le_trans ha0 hτ.1
    have hIleft : 0 ≤ ∫ s' in τ..m, kU s' := by
      apply intervalIntegral.integral_nonneg hτ.2
      intro s' hs'
      exact hkU_nonneg s' (le_trans hτ0' hs'.1)
    have hIright : 0 ≤ ∫ s' in (selectorMUUActiveEnd j)..b, kU s' := by
      apply intervalIntegral.integral_nonneg hU1b
      intro s' hs'
      exact hkU_nonneg s' (le_trans hU10 hs'.1)
    have hadd1 : (∫ s' in τ..m, kU s') +
        (∫ s' in m..(selectorMUUActiveEnd j), kU s') =
        ∫ s' in τ..(selectorMUUActiveEnd j), kU s' :=
      intervalIntegral.integral_add_adjacent_intervals (hkU_int τ m)
        (hkU_int m (selectorMUUActiveEnd j))
    have hadd2 : (∫ s' in τ..(selectorMUUActiveEnd j), kU s') +
        (∫ s' in (selectorMUUActiveEnd j)..b, kU s') =
        ∫ s' in τ..b, kU s' :=
      intervalIntegral.integral_add_adjacent_intervals
        (hkU_int τ (selectorMUUActiveEnd j)) (hkU_int (selectorMUUActiveEnd j) b)
    linarith [hmid]
  have hAαgZ_nonneg : ∀ τ : ℝ, 0 ≤ τ →
      0 ≤ (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
        bGateZ (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ := by
    intro τ hτ0'
    have hα := paper3HeadlineSolFamNW_alpha w w hτ0'
    rw [hα, (bgpParamsNW_A_eq w), one_mul]
    have hg : (0 : ℝ) ≤ bGateZ (bgpParamsNW w).L
        (((paper3HeadlineSolFamNW w) w).μ τ) τ := by
      simp only [bGateZ]
      exact (Real.exp_pos _).le
    exact mul_nonneg (Real.exp_pos _).le hg
  have hsrc_early : ∀ τ ∈ Icc a m, |src τ| ≤
      Real.exp (50 * (bgpScaleW w : ℝ) * m) * (paper3F1MixCrudeBoxNW) := by
    intro τ hτ
    have hτ0' : 0 ≤ τ := le_trans ha0 hτ.1
    have hsin : Real.sin τ ≤ 1 / 2 :=
      paper3N_sin_le_half_interRead j hτ.1 hτ.2
    have hgate := paper3NW_gateZ_integrand_le_halfphase w hτ0' hsin
    have hmz := hbox i τ ⟨hτ.1, le_trans hτ.2 hmb⟩
    have hexp_mono : Real.exp (50 * (bgpScaleW w : ℝ) * τ) ≤
        Real.exp (50 * (bgpScaleW w : ℝ) * m) := by
      apply Real.exp_le_exp.mpr
      nlinarith [hτ.2, hs0.le]
    dsimp only [src]
    rw [abs_mul, abs_of_nonneg (hAαgZ_nonneg τ hτ0')]
    calc (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
          bGateZ (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ *
          |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
              ((paper3HeadlineSolFamNW w) w).lam τ i -
            ((paper3HeadlineSolFamNW w) w).z τ i|
        ≤ Real.exp (50 * (bgpScaleW w : ℝ) * τ) * (paper3F1MixCrudeBoxNW) :=
          mul_le_mul hgate hmz (abs_nonneg _) (Real.exp_pos _).le
      _ ≤ Real.exp (50 * (bgpScaleW w : ℝ) * m) * (paper3F1MixCrudeBoxNW) :=
          mul_le_mul_of_nonneg_right hexp_mono hB0
  have hearly : (∫ τ in a..m, F τ) ≤ 1 / 2 := by
    have hpoint : ∀ τ ∈ Icc a m, F τ ≤
        Real.exp (-(2 * Real.pi / 3 *
            Real.exp (50 * (bgpScaleW w : ℝ) * m))) *
          (Real.exp (50 * (bgpScaleW w : ℝ) * m) * (paper3F1MixCrudeBoxNW)) := by
      intro τ hτ
      exact mul_le_mul (hweight_early τ hτ) (hsrc_early τ hτ)
        (abs_nonneg _) (Real.exp_pos _).le
    have hmono := intervalIntegral.integral_mono_on ham
      (hF_cont.intervalIntegrable (μ := MeasureTheory.volume) a m)
      _root_.intervalIntegrable_const hpoint
    have hlen : m - a = Real.pi / 3 := by
      dsimp only [a, m]
      unfold selectorMUWriteReadTime selectorMUUActiveStart
      ring
    have hconst : (∫ _τ in a..m,
        (Real.exp (-(2 * Real.pi / 3 *
            Real.exp (50 * (bgpScaleW w : ℝ) * m))) *
          (Real.exp (50 * (bgpScaleW w : ℝ) * m) * (paper3F1MixCrudeBoxNW)))) =
        Real.exp (-(2 * Real.pi / 3 *
            Real.exp (50 * (bgpScaleW w : ℝ) * m))) *
          (Real.exp (50 * (bgpScaleW w : ℝ) * m) * (paper3F1MixCrudeBoxNW)) *
          (Real.pi / 3) := by
      rw [intervalIntegral.integral_const, smul_eq_mul, hlen]
      ring
    have hBle : paper3F1MixCrudeBoxNW ≤
        Real.exp (230 * (bgpScaleW w : ℝ)) := by
      have h1 := paper3F1MixCrudeBoxNW_le_exp
      have h2 : Real.exp (230 * (bgpScale : ℝ)) ≤
          Real.exp (230 * (bgpScaleW w : ℝ)) :=
        Real.exp_le_exp.mpr (by nlinarith [bgpScaleR_le_bgpScaleWR w])
      linarith
    have harith := paper3NW_earlyPiece_arith_big hs1 hB0 hBle hX175
    calc (∫ τ in a..m, F τ)
        ≤ ∫ _τ in a..m,
            (Real.exp (-(2 * Real.pi / 3 *
                Real.exp (50 * (bgpScaleW w : ℝ) * m))) *
              (Real.exp (50 * (bgpScaleW w : ℝ) * m) * (paper3F1MixCrudeBoxNW))) := hmono
      _ = Real.exp (-(2 * Real.pi / 3 *
            Real.exp (50 * (bgpScaleW w : ℝ) * m))) *
          (Real.exp (50 * (bgpScaleW w : ℝ) * m) * (paper3F1MixCrudeBoxNW)) *
          (Real.pi / 3) := hconst
      _ ≤ 1 / 2 := harith
  have hlate : (∫ τ in m..b, F τ) ≤ 1 / 2 := by
    have hpoint : ∀ τ ∈ Icc m b, F τ ≤
        Real.exp (-(200 * (bgpScaleW w : ℝ) * τ)) * (paper3F1MixCrudeBoxNW) := by
      intro τ hτ
      have hτ0' : 0 ≤ τ := le_trans hm0 hτ.1
      have hWle1 : Real.exp (-(∫ s' in τ..b, kU s')) ≤ 1 := by
        rw [show (1 : ℝ) = Real.exp 0 from Real.exp_zero.symm]
        apply Real.exp_le_exp.mpr
        have hI : 0 ≤ ∫ s' in τ..b, kU s' := by
          apply intervalIntegral.integral_nonneg hτ.2
          intro s' hs'
          exact hkU_nonneg s' (le_trans hτ0' hs'.1)
        linarith
      have hτlow : 2 * Real.pi * j + Real.pi ≤ τ := by
        have h1 : selectorMUUActiveStart j ≤ τ := hτ.1
        unfold selectorMUUActiveStart at h1
        linarith
      have hτhigh : τ ≤ 2 * Real.pi * j + 2 * Real.pi := by
        have h2 : τ ≤ selectorMUZOffEnd j := hτ.2
        unfold selectorMUZOffEnd at h2
        push_cast at h2
        linarith
      have hsin : Real.sin τ ≤ 0 := sin_window_nonpos j hτlow hτhigh
      have hgate := gateZ_integrand_le_offphase_exp_NW w
        ((paper3HeadlineSolFamNW w) w) hτ0' hsin
      have hmz := hbox i τ ⟨le_trans ham hτ.1, hτ.2⟩
      have habs : |src τ| ≤
          Real.exp (-(200 * (bgpScaleW w : ℝ) * τ)) * (paper3F1MixCrudeBoxNW) := by
        dsimp only [src]
        rw [abs_mul, abs_of_nonneg (hAαgZ_nonneg τ hτ0')]
        exact mul_le_mul hgate hmz (abs_nonneg _) (Real.exp_pos _).le
      calc F τ ≤ 1 * |src τ| :=
            mul_le_mul_of_nonneg_right hWle1 (abs_nonneg _)
        _ = |src τ| := one_mul _
        _ ≤ Real.exp (-(200 * (bgpScaleW w : ℝ) * τ)) * (paper3F1MixCrudeBoxNW) := habs
    have hg_cont : Continuous fun τ : ℝ =>
        Real.exp (-(200 * (bgpScaleW w : ℝ) * τ)) * (paper3F1MixCrudeBoxNW) := by
      have hexp_cont : Continuous fun τ : ℝ =>
          Real.exp (-(200 * (bgpScaleW w : ℝ) * τ)) :=
        Real.continuous_exp.comp
          ((continuous_const.mul continuous_id).neg)
      exact hexp_cont.mul continuous_const
    have hmono := intervalIntegral.integral_mono_on hmb
      (hF_cont.intervalIntegrable (μ := MeasureTheory.volume) m b)
      (hg_cont.intervalIntegrable (μ := MeasureTheory.volume) m b) hpoint
    have hmass : (∫ τ in m..b, Real.exp (-(200 * (bgpScaleW w : ℝ) * τ))) ≤
        Real.exp (-(200 * (bgpScaleW w : ℝ) * m)) / (200 * (bgpScaleW w : ℝ)) :=
      paper3N_exp_mass_from_le (by positivity) hmb
    have hsplit_mul : (∫ τ in m..b,
        Real.exp (-(200 * (bgpScaleW w : ℝ) * τ)) * (paper3F1MixCrudeBoxNW)) =
        (∫ τ in m..b, Real.exp (-(200 * (bgpScaleW w : ℝ) * τ))) *
          (paper3F1MixCrudeBoxNW) := by
      rw [intervalIntegral.integral_mul_const]
    have hEle1 : Real.exp (-(200 * (bgpScaleW w : ℝ) * m)) ≤ 1 := by
      rw [show (1 : ℝ) = Real.exp 0 from Real.exp_zero.symm]
      apply Real.exp_le_exp.mpr
      nlinarith [hm0, hs0.le]
    have hfin : (∫ τ in m..b, Real.exp (-(200 * (bgpScaleW w : ℝ) * τ))) *
        (paper3F1MixCrudeBoxNW) ≤ 1 / 2 := by
      have hInn : 0 ≤ ∫ τ in m..b, Real.exp (-(200 * (bgpScaleW w : ℝ) * τ)) := by
        apply intervalIntegral.integral_nonneg hmb
        intro τ _
        exact (Real.exp_pos _).le
      have h1 : (∫ τ in m..b, Real.exp (-(200 * (bgpScaleW w : ℝ) * τ))) *
          (paper3F1MixCrudeBoxNW) ≤
          (Real.exp (-(200 * (bgpScaleW w : ℝ) * m)) /
            (200 * (bgpScaleW w : ℝ))) * (paper3F1MixCrudeBoxNW) :=
        mul_le_mul_of_nonneg_right hmass hB0
      have hm3 : (3 : ℝ) ≤ m := by
        dsimp only [m]
        unfold selectorMUUActiveStart
        nlinarith [Real.pi_gt_three, (Nat.cast_nonneg j : (0 : ℝ) ≤ (j : ℝ)),
          Real.pi_pos]
      have hkill := paper3NW_freeze_kill_generic bgpScaleR_ge_four
        (bgpScaleR_le_bgpScaleWR w) hm3
      have hCle := paper3F1MixCrudeBoxNW_le_exp
      have hexp0 := (Real.exp_pos (-(200 * (bgpScaleW w : ℝ) * m))).le
      have hden : (0 : ℝ) < 200 * (bgpScaleW w : ℝ) := by
        nlinarith [bgpScaleWR_pos w]
      have h2 : (Real.exp (-(200 * (bgpScaleW w : ℝ) * m)) /
          (200 * (bgpScaleW w : ℝ))) * (paper3F1MixCrudeBoxNW) ≤ 1 / 2 := by
        have h1' : (Real.exp (-(200 * (bgpScaleW w : ℝ) * m)) /
            (200 * (bgpScaleW w : ℝ))) * (paper3F1MixCrudeBoxNW) ≤
            (Real.exp (-(200 * (bgpScaleW w : ℝ) * m)) /
              (200 * (bgpScaleW w : ℝ))) *
              Real.exp (230 * (bgpScale : ℝ)) := by
          apply mul_le_mul_of_nonneg_left hCle
          positivity
        have h2' : (Real.exp (-(200 * (bgpScaleW w : ℝ) * m)) /
            (200 * (bgpScaleW w : ℝ))) *
              Real.exp (230 * (bgpScale : ℝ)) =
            Real.exp (230 * (bgpScale : ℝ)) *
              Real.exp (-(200 * (bgpScaleW w : ℝ) * m)) /
              (200 * (bgpScaleW w : ℝ)) := by
          ring
        linarith [hkill, h2'.le, h2'.ge]
      linarith
    calc (∫ τ in m..b, F τ)
        ≤ ∫ τ in m..b, Real.exp (-(200 * (bgpScaleW w : ℝ) * τ)) * (paper3F1MixCrudeBoxNW) :=
          hmono
      _ = (∫ τ in m..b, Real.exp (-(200 * (bgpScaleW w : ℝ) * τ))) *
            (paper3F1MixCrudeBoxNW) := hsplit_mul
      _ ≤ 1 / 2 := hfin
  have hgoal : (∫ τ in a..b, F τ) ≤ 1 := by
    rw [hsplit]
    linarith
  exact hgoal

/-- **THE INTER-READ MIXTURE BOX, AS A NAMED HYPOTHESIS (F1-N input 6).**
TRUE at the actual N solutions, but NOT derivable from the crude
boundary-tube + window-envelope data (which admit an
`O(bgpScale·e^{200})`-displaced `z` at read time whose u-copy the branch
evaluations then amplify by `B_U` per cycle).  The discharge is the
one-cycle settled machinery (Leg B: write-window λ-concentration
⟹ `z` settled `≈ enc(cfg (j+1))` at `wr j`; then the copy keeps all stack
coordinates inside the `[−1, 1]` hull where
`branchU_evalBranch_abs_le_two_D_U`-type bounds give `|mix| ≤ 2·D_U`, and
interval trapping keeps `|z|, |u| ≤ 3·D_U` through the inter-read).

Field 1: `|mix − z| ≤ 5·D_U` on `[wr j, zOffEnd j]` (feeds the retimed
source cap).  Field 2: `|mix − u| ≤ 5·D_U` on `[zOffEnd j, ws (j+1)]`
(feeds the no-slop prewrite trapping `paper3NW_prewrite_zu_hold`). -/
def Paper3F1InterReadMixBoxNW (w : ℕ) : Prop :=
  ∀ j : ℕ,
    (∀ i, paper3F1BoundaryErrNW w j i ≤
      paper3F1TubeRadiusN paper3F1CwinDefN) →
    (∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3F1CwinDefN) →
    (∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUWriteReadTime j)
        (selectorMUZOffEnd j),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
          ((paper3HeadlineSolFamNW w) w).lam τ i -
        ((paper3HeadlineSolFamNW w) w).z τ i| ≤ paper3F1MixCrudeBoxNW) ∧
    (∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1)),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
          ((paper3HeadlineSolFamNW w) w).lam τ i -
        ((paper3HeadlineSolFamNW w) w).u τ i| ≤ 5 * D_U)

/-- **The inter-read mixture box, DISCHARGED** at the word-coupled family:
part 1 crudely (`paper3F1MixCrudeBoxNW` on `[wr j, zOffEnd j]`), part 2 via
the tail tube (`5·D_U` on the prewrite tail). -/
theorem paper3F1_interRead_mixBox_NW (w : ℕ) :
    Paper3F1InterReadMixBoxNW w := by
  intro j htube hwin
  have htube' : ∀ i,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN := by
    intro i
    have h := htube i
    unfold paper3F1BoundaryErrNW at h
    exact h
  exact ⟨paper3F1_interRead_mix_z_crude_NW w j htube' hwin,
    paper3F1_interRead_mix_u_tail_NW w j htube' hwin⟩

/-- **THE JOINT F1-NW CORE, ASSEMBLED — NO NAMED HYPOTHESES.**  All five
analytic inputs are PROVED at the word-coupled family ((1/5)–(3/5) as the NW
clones above, (4/5)/(5/5) as `paper3F1_src_geo_quantitative_NW` /
`paper3F1_W0_quarter_NW`), and the inter-read mixture box is DISCHARGED
(`paper3F1_interRead_mixBox_NW`).  The endpoint recurrence `hnext_of` now runs
in two legs: the retimed transport
`selector_replicator_zOffEnd_zu_of_read_zu_and_interRead_source_NW w` with the
kernel-mass comparison `selectorInterRead_kernel_le_uActiveMass_NW_zOff w`
(read box contracts, source `≤ 1`), then the no-slop prewrite trapping
`paper3NW_prewrite_zu_hold` across `[zOffEnd j, ws (j+1)]` (the ctrl-jump
pre-write is absorbed by the `5·D_U ≤ 10·bgpScale` mix box, the second
branch of the `max` in `paper3F1EzuDefNW w`). -/

theorem paper3F1_joint_step_core_NW (w : ℕ)
    :
    ∃ core : Paper3F1JointStepCoreNW w, core.Cwin = paper3F1CwinDefN := by
  obtain ⟨Csrc, hCsrc0, hcap, hsrc⟩ := paper3F1_src_geo_quantitative_NW w
  have hb := paper3F1_window_relaxation_bootstrap_NW w
  have hE0 := paper3F1_cycle0_endpoint_NW w
  have hsrcCap := paper3F1_interRead_source_cap_NW w
  have hs1 : (1 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_one
  -- the cycle-`j` window envelope released by the bootstrap at the
  -- recurrence endpoint
  have hwin_all : ∀ j : ℕ,
      (∀ i, paper3F1BoundaryErrNW w j i ≤
        paper3F1TubeRadiusN paper3F1CwinDefN) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| ≤
          paper3F1EzuDefNW w j) →
      ∀ i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamNW w) w).z t i -
          ((paper3HeadlineSolFamNW w) w).u t i| ≤
          max (paper3F1EzuDefNW w j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
            (bgpScale : ℝ) :=
    fun j htube hend =>
      hb j (paper3F1EzuDefNW w j) (paper3F1EzuDefNW_nonneg w j)
        (paper3F1EzuDefNW_le_ten w j)
        (fun i => le_trans (htube i) paper3F1TubeRadiusN_CwinDefN_le) hend
  refine ⟨{ Cwin := paper3F1CwinDefN
            Csrc := Csrc
            Ezu := paper3F1EzuDefNW w
            hCwin0 := paper3F1CwinDefN_nonneg
            hCwin_le := paper3F1CwinDefN_le_scale_exp200
            hCsrc0 := hCsrc0
            hE0 := ?_
            hwin_of := ?_
            hnext_of := ?_
            hsrc_geo_of := ?_
            hbudget_half := ?_ }, rfl⟩
  · -- hE0
    intro i
    rw [paper3F1EzuDefNW_zero w]
    exact hE0 i
  · -- hwin_of
    intro j htube hend i t ht
    exact le_trans (hwin_all j htube hend i t ht)
      (paper3F1EzuDefNW_window_le w j)
  · -- hnext_of
    intro j htube hend i
    have hwin := hwin_all j htube hend
    have hread : ∀ i' : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteReadTime j) i' -
          ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteReadTime j) i'| ≤
          max (paper3F1EzuDefNW w j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
            (bgpScale : ℝ) :=
      fun i' => hwin i' (selectorMUWriteReadTime j)
        ⟨selectorMUWriteStart_le_read j, le_refl _⟩
    have hwinC : ∀ i' : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamNW w) w).z t i' -
          ((paper3HeadlineSolFamNW w) w).u t i'| ≤ paper3F1CwinDefN :=
      fun i' t ht => le_trans (hwin i' t ht) (paper3F1EzuDefNW_window_le w j)
    obtain ⟨hboxZ, hboxU⟩ := paper3F1_interRead_mixBox_NW w j htube hwinC
    have hsource := hsrcCap j hboxZ
    have htrans :=
      selector_replicator_zOffEnd_zu_of_read_zu_and_interRead_source_NW w
        (paper3HeadlineSolFamNW w) w j hread hsource
    have hτmem : selectorMUWriteReadTime j ∈
        Icc (selectorMUWriteReadTime j) (selectorMUUActiveStart j) := by
      constructor
      · exact le_refl _
      · unfold selectorMUWriteReadTime selectorMUUActiveStart
        linarith [Real.pi_pos]
    have hker := selectorInterRead_kernel_le_uActiveMass_NW_zOff w
      ((paper3HeadlineSolFamNW w) w) j hτmem
    have hBread0 : 0 ≤ max (paper3F1EzuDefNW w j)
        ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ) := by
      have h1 := le_max_right (paper3F1EzuDefNW w j)
        ((bgpScale : ℝ) * Real.exp (198 : ℝ))
      have h2 : (0 : ℝ) ≤ (bgpScale : ℝ) * Real.exp (198 : ℝ) := by
        positivity
      have h3 : (0 : ℝ) ≤ (bgpScale : ℝ) := by positivity
      linarith
    have hmul := mul_le_mul_of_nonneg_right hker hBread0
    -- endpoint at `zOffEnd j`: contraction on the read box + retimed cap
    have hzOff : ∀ i' : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUZOffEnd j) i' -
          ((paper3HeadlineSolFamNW w) w).u (selectorMUZOffEnd j) i'| ≤
          Real.exp (-(selectorInterReadUActiveMassLowerNW w j)) *
            (max (paper3F1EzuDefNW w j)
              ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ)) + 1 := by
      intro i'
      have h := htrans i'
      linarith [h, hmul]
    -- prewrite hold across `[zOffEnd j, ws (j+1)]` (no-slop trapping)
    have hhold := paper3NW_prewrite_zu_hold w j hzOff hboxU i
    have hDle : (D_U : ℝ) ≤ 2 * (bgpScale : ℝ) := D_U_le_two_bgpScale
    have hmax_le : max (Real.exp (-(selectorInterReadUActiveMassLowerNW w j)) *
          (max (paper3F1EzuDefNW w j)
            ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ)) + 1)
        ((5 : ℝ) * D_U) ≤ paper3F1EzuDefNW w (j + 1) := by
      rw [paper3F1EzuDefNW_succ w]
      exact max_le_max (le_refl _) (by linarith)
    exact le_trans hhold hmax_le
  · -- hsrc_geo_of
    intro j htube hend i
    have hwinC : ∀ i' : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamNW w) w).z t i' -
          ((paper3HeadlineSolFamNW w) w).u t i'| ≤ paper3F1CwinDefN :=
      fun i' t ht => le_trans (hwin_all j htube hend i' t ht)
        (paper3F1EzuDefNW_window_le w j)
    exact hsrc j htube hwinC i
  · -- hbudget_half
    intro i
    have h1 := paper3F1_W0_quarter_NW w i
    linarith [hcap]

/-- **The N invariant-threaded tube induction**: the write-start boundary
tube AND the write-start `z-u` endpoint hold at every cycle of the N family,
given a joint core.  Mirrors `paper3F1_joint_tube_and_endpoint`; the generic
engine `paper3F1_tube_and_invariant_of_conditional_step_normalized` is reused
(it is family-agnostic in the coordinate function `u`). -/
theorem paper3F1_joint_tube_and_endpoint_NW (w : ℕ)
    (core : Paper3F1JointStepCoreNW w) :
    ∀ j, (∀ i, paper3F1BoundaryErrNW w j i ≤
        paper3F1TubeRadiusN core.Cwin) ∧
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamNW w) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j) := by
  have hreserve_half :
      δuWritePrefixN core.Cwin 0 + δuSettledN core.Cwin 0 ≤ r_LE_U / 2 :=
    paper3F1_delta_reserveN_of_envelope_le core.hCwin_le
  have hbudget_geom : ∀ i,
      paper3F1W0NW w i + paper3F1GeomCap w core.Csrc ≤
        paper3F1TubeRadiusN core.Cwin := by
    intro i
    have h := core.hbudget_half i
    unfold paper3F1TubeRadiusN
    linarith
  have hq1 : Real.exp (Real.log (B_U : ℝ) - 2) < 1 := by
    rw [Real.exp_lt_one_iff]
    linarith [log_B_U_lt_two]
  have hcap_nonneg : 0 ≤ paper3F1GeomCap w core.Csrc := by
    unfold paper3F1GeomCap
    have hden : 0 < 1 - Real.exp (Real.log (B_U : ℝ) - 2) := by linarith
    have hfrac : 0 ≤ 1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2)) := by
      positivity
    exact mul_nonneg (mul_nonneg (Real.exp_pos _).le core.hCsrc0) hfrac
  have hW0nn : 0 ≤ paper3F1W0NW w haltCoordU := by
    unfold paper3F1W0NW
    exact mul_nonneg
      (zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _)
      (abs_nonneg _)
  have hrtube_nonneg : 0 ≤ paper3F1TubeRadiusN core.Cwin :=
    le_trans (add_nonneg hW0nn hcap_nonneg) (hbudget_geom haltCoordU)
  have hW0_le : ∀ i : Fin d_U, paper3F1W0NW w i ≤
      paper3F1TubeRadiusN core.Cwin - paper3F1GeomCap w core.Csrc := by
    intro i
    linarith [hbudget_geom i]
  have hdepth : ∀ j (i : Fin d_U),
      paper3F1Depth w (j + 1) i =
        paper3F1Depth w j i - selectorMUCoarseDelta (paper3F1Cfg w) j i :=
    selectorMUCurrentDepthStep_concrete
      (cfg := paper3F1Cfg w) (fun j => solMUReplStaticCfg_step w j)
  have hbase : ∀ i : Fin d_U,
      (B_U : ℝ) ^ paper3F1Depth w 0 i *
        trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
          selectorMUWriteStartTime 0 i ≤
        paper3F1TubeRadiusN core.Cwin - paper3F1GeomCap w core.Csrc := by
    intro i
    have h := hW0_le i
    unfold paper3F1W0NW at h
    rw [paper3F1BoundaryErrNW_eq_trackingErr] at h
    exact h
  have hstep' : ∀ j (i : Fin d_U),
      trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
          selectorMUWriteStartTime (j + 1) i ≤
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
            selectorMUWriteStartTime j i + paper3F1SrcCoreNW w j i := by
    intro j i
    have hraw : trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime (j + 1) i ≤
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
            selectorMUWriteStartTime j i + paper3F1SrcCoreNW w j i := by
      have h := paper3F1_boundaryErrNW_succ_le_mult_add_srcCoreNW w j i
      simpa only [paper3F1BoundaryErrNW_eq_trackingErr] using h
    exact trackingErr_succ_le_of_multiplier_step
      ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
      selectorMUWriteStartTime
      (m := fun j i => stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i)
      (s := paper3F1SrcCoreNW w)
      (delta := selectorMUCoarseDelta (paper3F1Cfg w)) j i
      (paper3F1_coordMultiplier_le_BUpow_coarseDelta w j i) hraw
  have hη_dom' : ∀ j,
      (∀ i, trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i ≤ paper3F1TubeRadiusN core.Cwin) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamNW w) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j) →
      ∀ i, paper3F1SrcCoreNW w j i ≤
        core.Csrc * Real.exp (-(2 : ℝ) * (j : ℝ)) := by
    intro j htube hend i
    have hb : ∀ i', paper3F1BoundaryErrNW w j i' ≤
        paper3F1TubeRadiusN core.Cwin := by
      intro i'
      rw [paper3F1BoundaryErrNW_eq_trackingErr]
      exact htube i'
    exact core.hsrc_geo_of j hb hend i
  have hPstep : ∀ j,
      (∀ i, trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i ≤ paper3F1TubeRadiusN core.Cwin) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamNW w) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j) →
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z
            (selectorMUWriteStartTime (j + 1)) i -
          ((paper3HeadlineSolFamNW w) w).u
            (selectorMUWriteStartTime (j + 1)) i| ≤ core.Ezu (j + 1) := by
    intro j htube hend
    have hb : ∀ i', paper3F1BoundaryErrNW w j i' ≤
        paper3F1TubeRadiusN core.Cwin := by
      intro i'
      rw [paper3F1BoundaryErrNW_eq_trackingErr]
      exact htube i'
    exact core.hnext_of j hb hend
  have hreserve : ∀ j (i : Fin d_U),
      (paper3F1TubeRadiusN core.Cwin - paper3F1GeomCap w core.Csrc) +
        Real.exp (Real.log (B_U : ℝ) *
            (MachineInstance.inputLenU 1 w : ℝ)) * core.Csrc *
          (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) ≤
        paper3F1TubeRadiusN core.Cwin * (B_U : ℝ) ^ paper3F1Depth w j i := by
    intro j i
    have hdep_nonneg : 0 ≤ paper3F1Depth w j i :=
      selectorMU_depthU_nonneg (paper3F1Cfg w) j i
    have hpow_ge_one : (1 : ℝ) ≤ (B_U : ℝ) ^ paper3F1Depth w j i :=
      (one_le_zpow_iff_right₀
        (by norm_num [B_U] : (1 : ℝ) < (B_U : ℝ))).mpr hdep_nonneg
    have hcancel : (paper3F1TubeRadiusN core.Cwin -
          paper3F1GeomCap w core.Csrc) +
        Real.exp (Real.log (B_U : ℝ) *
            (MachineInstance.inputLenU 1 w : ℝ)) * core.Csrc *
          (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) =
        paper3F1TubeRadiusN core.Cwin := by
      unfold paper3F1GeomCap
      ring
    rw [hcancel]
    calc paper3F1TubeRadiusN core.Cwin
        = paper3F1TubeRadiusN core.Cwin * 1 := (mul_one _).symm
      _ ≤ paper3F1TubeRadiusN core.Cwin *
            (B_U : ℝ) ^ paper3F1Depth w j i :=
          mul_le_mul_of_nonneg_left hpow_ge_one hrtube_nonneg
  have hjoint :=
    paper3F1_tube_and_invariant_of_conditional_step_normalized
      (P := fun j => ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamNW w) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j)
      ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
      selectorMUWriteStartTime
      (k := (B_U : ℝ)) (r := paper3F1TubeRadiusN core.Cwin)
      selectorMU_B_U_real_gt_one
      (paper3F1Depth w) (selectorMUCoarseDelta (paper3F1Cfg w))
      (paper3F1SrcCoreNW w)
      (W0 := paper3F1TubeRadiusN core.Cwin - paper3F1GeomCap w core.Csrc)
      (L := (MachineInstance.inputLenU 1 w : ℝ))
      (Cη := core.Csrc) (lam := 2)
      core.hCsrc0 log_B_U_lt_two
      hdepth (fun j i => paper3F1Depth_succ_le_inputLenU w i j)
      hbase core.hE0 hPstep hstep'
      (paper3F1SrcCoreNW_nonneg w) hη_dom' hreserve
  intro j
  obtain ⟨htube, hend⟩ := hjoint j
  refine ⟨fun i => ?_, hend⟩
  rw [paper3F1BoundaryErrNW_eq_trackingErr]
  exact htube i

/-- **F1-N LEG A: the all-cycle window `z-u` envelope with its reserve**, at
the N family (mirrors `paper3F1_envelope_with_reserve`). -/
theorem paper3F1_envelope_with_reserve_NW (w : ℕ)
    :
    ∃ Cwin : ℝ, 0 ≤ Cwin ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamNW w) w).z t i -
          ((paper3HeadlineSolFamNW w) w).u t i| ≤ Cwin) ∧
      δuWritePrefixN Cwin 0 + δuSettledN Cwin 0 ≤ r_LE_U / 2 := by
  rcases paper3F1_joint_step_core_NW w with ⟨core, hCwinEq⟩
  have hje := paper3F1_joint_tube_and_endpoint_NW w core
  exact ⟨core.Cwin, core.hCwin0,
    fun j i t ht => core.hwin_of j (hje j).1 (hje j).2 i t ht,
    paper3F1_delta_reserveN_of_envelope_le core.hCwin_le⟩

/-- **F1-N LEG B+C: tube-conditional source decay and the quantitative
budget, unconditionalized** (mirrors
`paper3F1_src_geo_and_budget_of_envelope`). -/
theorem paper3F1_src_geo_and_budget_NW (w : ℕ)
    :
    ∃ Csrc CW0 : ℝ, 0 ≤ Csrc ∧ 0 ≤ CW0 ∧
      (∀ j i, paper3F1SrcCoreNW w j i ≤
        Csrc * Real.exp (-(2 : ℝ) * (j : ℝ))) ∧
      (∀ i, paper3F1W0NW w i ≤ CW0) ∧
      CW0 + paper3F1GeomCap w Csrc ≤ r_LE_U / 2 := by
  rcases paper3F1_joint_step_core_NW w with ⟨core, hCwinEq⟩
  have hje := paper3F1_joint_tube_and_endpoint_NW w core
  have hsrc_all : ∀ j i, paper3F1SrcCoreNW w j i ≤
      core.Csrc * Real.exp (-(2 : ℝ) * (j : ℝ)) :=
    fun j i => core.hsrc_geo_of j (hje j).1 (hje j).2 i
  have hW0nn : 0 ≤ paper3F1W0NW w haltCoordU := by
    unfold paper3F1W0NW
    exact mul_nonneg
      (zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _)
      (abs_nonneg _)
  refine ⟨core.Csrc, r_LE_U / 2 - paper3F1GeomCap w core.Csrc,
    core.hCsrc0, ?_, fun j i => hsrc_all j i, fun i => ?_, by linarith⟩
  · linarith [core.hbudget_half haltCoordU]
  · linarith [core.hbudget_half i]

/-- **N weighted-defect summability from the joint core**: the positive-part
excess `paper3F1EtaNW` is dominated by the canonical source `paper3F1SrcCoreNW`
(the exact-multiplier comparison term is at most the `B_U^delta` one), whose
geometric decay at rate `2 > log 6` beats the depth weight. -/
theorem paper3F1EtaNW_le_srcCoreNW (w : ℕ) :
    ∀ j i, paper3F1EtaNW w j i ≤ paper3F1SrcCoreNW w j i := by
  intro j i
  have herr_nonneg : 0 ≤ paper3F1BoundaryErrNW w j i := abs_nonneg _
  have hcmp :
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErrNW w j i ≤
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          paper3F1BoundaryErrNW w j i :=
    mul_le_mul_of_nonneg_right
      (paper3F1_coordMultiplier_le_BUpow_coarseDelta w j i) herr_nonneg
  unfold paper3F1EtaNW
  refine max_le (paper3F1SrcCoreNW_nonneg w j i) ?_
  have hsrc : paper3F1BoundaryErrNW w (j + 1) i -
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErrNW w j i ≤ paper3F1SrcCoreNW w j i := by
    unfold paper3F1SrcCoreNW
    exact le_max_right _ _
  linarith

theorem paper3F1NW_weightedDefect_summable (w : ℕ)
    :
    ∀ i, Summable (fun j =>
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1EtaNW w) j i) := by
  obtain ⟨Csrc, _, _, _, hsrc_all, _, _⟩ :=
    paper3F1_src_geo_and_budget_NW w
  intro i
  refine paper3F1NW_weightedDefect_summable_of_eta_geometric w i
    (Cη := Csrc) (lamη := 2) log_B_U_lt_two (fun j => ?_)
  exact le_trans (paper3F1EtaNW_le_srcCoreNW w j i) (hsrc_all j i)

/-- **The sharp weighted-budget projection at radius `r_LE_U/60`** (Q4163
§3.5): the same generic engine as `paper3F1_joint_tube_and_endpoint_NW`, run
with `r := r_LE_U/60` and `W0 := r_LE_U/60 − GeomCap` (unconditional source
and W0 caps supplied as hypotheses; the endpoint invariant is threaded
through the SAME core, whose conditional fields are unlocked by weakening
the sharp tube `≤ r_LE_U/60` to the coarse `TubeRadiusN core.Cwin ≥
r_LE_U/2`). -/
theorem paper3F1_joint_writeStart_sharp_NW (w : ℕ)
    (core : Paper3F1JointStepCoreNW w)
    {Csrc : ℝ}
    (hCsrc0 : 0 ≤ Csrc)
    (hsrc_all : ∀ j i, paper3F1SrcCoreNW w j i ≤
      Csrc * Real.exp (-(2 : ℝ) * (j : ℝ)))
    (hW0 : ∀ i, paper3F1W0NW w i ≤ r_LE_U / 120)
    (hgeom : paper3F1GeomCap w Csrc ≤ r_LE_U / 120) :
    ∀ j i, paper3F1BoundaryErrNW w j i ≤ r_LE_U / 60 := by
  have hr0 : (0 : ℝ) ≤ r_LE_U := by norm_num [r_LE_U]
  have hreserve_half :
      δuWritePrefixN core.Cwin 0 + δuSettledN core.Cwin 0 ≤ r_LE_U / 2 :=
    paper3F1_delta_reserveN_of_envelope_le core.hCwin_le
  have h60_le : r_LE_U / 60 ≤ paper3F1TubeRadiusN core.Cwin := by
    unfold paper3F1TubeRadiusN
    linarith
  have hdepth : ∀ j (i : Fin d_U),
      paper3F1Depth w (j + 1) i =
        paper3F1Depth w j i - selectorMUCoarseDelta (paper3F1Cfg w) j i :=
    selectorMUCurrentDepthStep_concrete
      (cfg := paper3F1Cfg w) (fun j => solMUReplStaticCfg_step w j)
  have hbase : ∀ i : Fin d_U,
      (B_U : ℝ) ^ paper3F1Depth w 0 i *
        trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
          selectorMUWriteStartTime 0 i ≤
        r_LE_U / 60 - paper3F1GeomCap w Csrc := by
    intro i
    have h := hW0 i
    unfold paper3F1W0NW at h
    rw [paper3F1BoundaryErrNW_eq_trackingErr] at h
    linarith
  have hstep' : ∀ j (i : Fin d_U),
      trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
          selectorMUWriteStartTime (j + 1) i ≤
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
            selectorMUWriteStartTime j i + paper3F1SrcCoreNW w j i := by
    intro j i
    have hraw : trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime (j + 1) i ≤
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
            selectorMUWriteStartTime j i + paper3F1SrcCoreNW w j i := by
      have h := paper3F1_boundaryErrNW_succ_le_mult_add_srcCoreNW w j i
      simpa only [paper3F1BoundaryErrNW_eq_trackingErr] using h
    exact trackingErr_succ_le_of_multiplier_step
      ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
      selectorMUWriteStartTime
      (m := fun j i => stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i)
      (s := paper3F1SrcCoreNW w)
      (delta := selectorMUCoarseDelta (paper3F1Cfg w)) j i
      (paper3F1_coordMultiplier_le_BUpow_coarseDelta w j i) hraw
  have hPstep : ∀ j,
      (∀ i, trackingErr ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i ≤ r_LE_U / 60) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamNW w) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j) →
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z
            (selectorMUWriteStartTime (j + 1)) i -
          ((paper3HeadlineSolFamNW w) w).u
            (selectorMUWriteStartTime (j + 1)) i| ≤ core.Ezu (j + 1) := by
    intro j htube hend
    have hb : ∀ i', paper3F1BoundaryErrNW w j i' ≤
        paper3F1TubeRadiusN core.Cwin := by
      intro i'
      rw [paper3F1BoundaryErrNW_eq_trackingErr]
      exact le_trans (htube i') h60_le
    exact core.hnext_of j hb hend
  have hreserve : ∀ j (i : Fin d_U),
      (r_LE_U / 60 - paper3F1GeomCap w Csrc) +
        Real.exp (Real.log (B_U : ℝ) *
            (MachineInstance.inputLenU 1 w : ℝ)) * Csrc *
          (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) ≤
        r_LE_U / 60 * (B_U : ℝ) ^ paper3F1Depth w j i := by
    intro j i
    have hdep_nonneg : 0 ≤ paper3F1Depth w j i :=
      selectorMU_depthU_nonneg (paper3F1Cfg w) j i
    have hpow_ge_one : (1 : ℝ) ≤ (B_U : ℝ) ^ paper3F1Depth w j i :=
      (one_le_zpow_iff_right₀
        (by norm_num [B_U] : (1 : ℝ) < (B_U : ℝ))).mpr hdep_nonneg
    have hcancel : (r_LE_U / 60 - paper3F1GeomCap w Csrc) +
        Real.exp (Real.log (B_U : ℝ) *
            (MachineInstance.inputLenU 1 w : ℝ)) * Csrc *
          (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) =
        r_LE_U / 60 := by
      unfold paper3F1GeomCap
      ring
    rw [hcancel]
    calc r_LE_U / 60
        = r_LE_U / 60 * 1 := (mul_one _).symm
      _ ≤ r_LE_U / 60 * (B_U : ℝ) ^ paper3F1Depth w j i :=
          mul_le_mul_of_nonneg_left hpow_ge_one (by norm_num [r_LE_U])
  have hjoint :=
    paper3F1_tube_and_invariant_of_conditional_step_normalized
      (P := fun j => ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamNW w) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j)
      ((paper3HeadlineSolFamNW w) w).u (paper3F1Cfg w)
      selectorMUWriteStartTime
      (k := (B_U : ℝ)) (r := r_LE_U / 60)
      selectorMU_B_U_real_gt_one
      (paper3F1Depth w) (selectorMUCoarseDelta (paper3F1Cfg w))
      (paper3F1SrcCoreNW w)
      (W0 := r_LE_U / 60 - paper3F1GeomCap w Csrc)
      (L := (MachineInstance.inputLenU 1 w : ℝ))
      (Cη := Csrc) (lam := 2)
      hCsrc0 log_B_U_lt_two
      hdepth (fun j i => paper3F1Depth_succ_le_inputLenU w i j)
      hbase core.hE0 hPstep hstep'
      (paper3F1SrcCoreNW_nonneg w) (fun j _ _ i => hsrc_all j i) hreserve
  intro j i
  obtain ⟨htube, _⟩ := hjoint j
  rw [paper3F1BoundaryErrNW_eq_trackingErr]
  exact htube i

/-- **THE SHARP F1 WRITE-START EXPORT** (Q4163): every cycle's write-start
boundary error is within `r_LE_U/60` — the S2 `M₁` `epsIn` interface, no S2
induction (Q4161).  The coarse joint unconditionalizes the sharp source
caps; the sharp weighted-budget projection reruns the SAME engine at
`r_LE_U/60`. -/
theorem paper3F1_writeStart_sharp_NW (w : ℕ) :
    ∀ j : ℕ, ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U / 60 := by
  rcases paper3F1_joint_step_core_NW w with ⟨core, hCwinEq⟩
  have hje := paper3F1_joint_tube_and_endpoint_NW w core
  rcases paper3F1_src_geo_quantitative_sharp_NW w with
    ⟨Csrc, hCsrc0, hgeom, hsrcOf⟩
  have htube_all : ∀ j, ∀ i, paper3F1BoundaryErrNW w j i ≤
      paper3F1TubeRadiusN paper3F1CwinDefN := by
    intro j i
    have h := (hje j).1 i
    rwa [hCwinEq] at h
  have hwin_all : ∀ j, ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3F1CwinDefN := by
    intro j i t ht
    have h := core.hwin_of j (hje j).1 (hje j).2 i t ht
    rwa [hCwinEq] at h
  have hsrc_all : ∀ j i, paper3F1SrcCoreNW w j i ≤
      Csrc * Real.exp (-(2 : ℝ) * (j : ℝ)) :=
    fun j i => hsrcOf j (htube_all j) (hwin_all j) i
  have hexport := paper3F1_joint_writeStart_sharp_NW w core hCsrc0
    hsrc_all (paper3F1_W0_sharp_NW w) hgeom
  intro j i
  have h := hexport j i
  unfold paper3F1BoundaryErrNW at h
  exact h

/-- Six-times façade for the S2 `M₁` `hentry`/`hstart` hypothesis:
`∀ j i, 6·|u(ws j) − enc(cfg j)| ≤ r_LE_U/10` (i.e. `epsIn := r_LE_U/60`,
`6·epsIn = r_LE_U/10`). -/
theorem paper3F1_writeStart_sharp_NW_six (w j : ℕ) :
    ∀ i : Fin d_U,
      6 * |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U / 10 := by
  intro i
  have h := paper3F1_writeStart_sharp_NW w j i
  have hr : r_LE_U = 1 / 1000 := rfl
  rw [hr] at h ⊢
  linarith

/-! ### Seg C: the diagonal full write-window u-tube (minimal quarantine seam)

`Paper3F1FullUTubeResidualNW w` is the per-word DIAGONAL full write-window
u-tube demanded by the headline analytic discharge (design: Q4136 §3 minimal
version): prefix (`Ico ws→hold`) + tail (`Icc hold→read`) around the static
configuration orbit `solMUReplStaticCfg w j`, radius `r_LE_U`, at the
word-coupled family `paper3HeadlineSolFamNW w`.  It carries a SINGLE word
index `w` — no off-diagonal `(wg, w)` data is manufactured (the legacy
`SelectorMUWriteFullUTubeResidual (paper3HeadlineSolFamNW wg)` target would
demand every word for each gain and is exactly the quarantined off-diagonal
debt; see `Paper3AnalyticResidualDischarge.ofResiduals`, whose body discards
all off-diagonal cases).

Both faces are produced from ONE coherent joint core
(`paper3F1_joint_step_core_NW`):

* the all-cycle write-start boundary tube at radius
  `paper3F1TubeRadiusN core.Cwin = r_LE_U − δuWritePrefixN Cwin 0 −
  δuSettledN Cwin 0` (`paper3F1_joint_tube_and_endpoint_NW`) — the radius
  already RESERVES the cycle-0 prefix+settled drift out of the readout tube;
* the all-cycle window `z−u` envelope `core.Cwin` (`core.hwin_of`);
* the whole-window u-drift (`paper3NW_u_drift_on_write_window`, coarse
  N-scale rate `450·bgpScale`), whose envelope
  `Cwin·e^{−450·S·ws j}/(450·S)` fits inside the reserved
  `δuWritePrefixN Cwin 0` alone (`paper3SegC_drift_le_reserveN` below), so
  the ledger `tube + drift ≤ (r − δuWP − δuS) + δuWP ≤ r` closes with the
  settled reserve to spare — one ledger, no quarter spent twice. -/

/-- The whole-window u-drift envelope at any cycle `j` fits the cycle-`0`
N-rate prefix reserve: `Bzu·e^{−450·S·ws j}/(450·S) ≤ δuWritePrefixN Bzu 0`
(the mass factor `1/(450·S) ≤ 1 ≤ π/3` and the exponent is monotone in `j`). -/
theorem paper3SegC_drift_le_reserveN {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu)
    (j : ℕ) :
    Bzu * (Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime j)) /
        (450 * (bgpScale : ℝ))) ≤ δuWritePrefixN Bzu 0 := by
  have hS1 : (1 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_one
  have hc1 : (1 : ℝ) ≤ 450 * (bgpScale : ℝ) := by nlinarith
  have hc : (0 : ℝ) < 450 * (bgpScale : ℝ) := by linarith
  have hws_mono : selectorMUWriteStartTime 0 ≤ selectorMUWriteStartTime j := by
    unfold selectorMUWriteStartTime
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    push_cast
    nlinarith [Real.pi_pos]
  have hexp_le :
      Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime j)) ≤
        Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime 0)) := by
    apply Real.exp_le_exp.mpr
    nlinarith [mul_le_mul_of_nonneg_left hws_mono hc.le]
  have hchain :
      Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime j)) /
          (450 * (bgpScale : ℝ)) ≤
        (Real.pi / 3) *
          Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime 0)) := by
    have h1 :
        Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime j)) /
            (450 * (bgpScale : ℝ)) ≤
          Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime j)) :=
      div_le_self (Real.exp_pos _).le hc1
    have h2 : (1 : ℝ) ≤ Real.pi / 3 := by
      nlinarith [Real.pi_gt_three]
    have h3 :
        Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime 0)) ≤
          (Real.pi / 3) *
            Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime 0)) :=
      le_mul_of_one_le_left (Real.exp_pos _).le h2
    exact le_trans h1 (le_trans hexp_le h3)
  have hres :
      Bzu * ((Real.pi / 3) *
          Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime 0))) =
        δuWritePrefixN Bzu 0 := by
    unfold δuWritePrefixN
    rw [selectorUSettledRate_N_eq]
  calc Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
        selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ)))
      ≤ Bzu * ((Real.pi / 3) *
          Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime 0))) :=
        mul_le_mul_of_nonneg_left hchain hBzu0
    _ = δuWritePrefixN Bzu 0 := hres

/-- **Seg C workhorse (slack form): the all-cycle full write-window u-tube
with the settled reserve UNSPENT.**  For every cycle `j` and every
`t ∈ [ws j, wr j]`, the solution's `u` is within
`r_LE_U − δuSettledN paper3F1CwinDefN 0` of the cycle-`j` static
configuration: boundary tube (radius `paper3F1TubeRadiusN Cwin`, which
reserves BOTH cycle-0 drifts) + whole-window drift (fits inside the prefix
reserve alone) — the settled reserve is exported as entry slack for the
downstream edge tubes (S4 gap floors). -/
theorem paper3SegC_utube_win_slack_NW (w : ℕ) :
    ∀ j : ℕ, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).u t i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
          r_LE_U - δuSettledN paper3F1CwinDefN 0 := by
  classical
  rcases paper3F1_joint_step_core_NW w with ⟨core, hCwinEq⟩
  have hje := paper3F1_joint_tube_and_endpoint_NW w core
  intro j t ht i
  have hwin : ∀ i' : Fin d_U, ∀ τ ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z τ i' -
        ((paper3HeadlineSolFamNW w) w).u τ i'| ≤ core.Cwin :=
    fun i' τ hτ => core.hwin_of j (hje j).1 (hje j).2 i' τ hτ
  have hdrift := paper3NW_u_drift_on_write_window w j i core.hCwin0 ht
    (fun τ hτ => hwin i τ ⟨hτ.1, le_trans hτ.2 ht.2⟩)
  have htube0 : paper3F1BoundaryErrNW w j i ≤
      paper3F1TubeRadiusN core.Cwin := (hje j).1 i
  have hres := paper3SegC_drift_le_reserveN core.hCwin0 j
  have hsplit :
      |((paper3HeadlineSolFamNW w) w).u t i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        |((paper3HeadlineSolFamNW w) w).u t i -
            ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| +
          paper3F1BoundaryErrNW w j i := by
    unfold paper3F1BoundaryErrNW
    exact abs_sub_le _ _ _
  have hradius : paper3F1TubeRadiusN core.Cwin =
      r_LE_U - δuWritePrefixN core.Cwin 0 - δuSettledN core.Cwin 0 := rfl
  calc |((paper3HeadlineSolFamNW w) w).u t i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i|
      ≤ |((paper3HeadlineSolFamNW w) w).u t i -
            ((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i| +
          paper3F1BoundaryErrNW w j i := hsplit
    _ ≤ core.Cwin * (Real.exp (-(450 * (bgpScale : ℝ) *
            selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) +
          paper3F1TubeRadiusN core.Cwin := add_le_add hdrift htube0
    _ ≤ δuWritePrefixN core.Cwin 0 +
          (r_LE_U - δuWritePrefixN core.Cwin 0 - δuSettledN core.Cwin 0) := by
        rw [hradius]
        linarith [hres]
    _ = r_LE_U - δuSettledN core.Cwin 0 := by ring
    _ = r_LE_U - δuSettledN paper3F1CwinDefN 0 := by rw [hCwinEq]

/-- **Seg C all-cycle window `z−u` envelope at the NAMED constant**
`paper3F1CwinDefN` (the joint core's canonical choice, exposed through the
`∃`-identity of `paper3F1_joint_step_core_NW`). -/
theorem paper3SegC_envelope_NW (w : ℕ) :
    ∀ (j : ℕ) (i : Fin d_U), ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3F1CwinDefN := by
  rcases paper3F1_joint_step_core_NW w with ⟨core, hCwinEq⟩
  have hje := paper3F1_joint_tube_and_endpoint_NW w core
  intro j i t ht
  have h := core.hwin_of j (hje j).1 (hje j).2 i t ht
  rwa [hCwinEq] at h

/-- **Seg C workhorse: the all-cycle full write-window u-tube at the
word-coupled family** (spends the settled reserve of the slack form). -/
theorem paper3SegC_utube_win_NW (w : ℕ) :
    ∀ j : ℕ, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      UTube r_LE_U (solMUReplStaticCfg w j)
        (((paper3HeadlineSolFamNW w) w).u t) := by
  intro j t ht i
  have hset0 : 0 ≤ δuSettledN paper3F1CwinDefN 0 :=
    δuSettledN_nonneg paper3F1CwinDefN_nonneg 0
  have h := paper3SegC_utube_win_slack_NW w j t ht i
  calc |((paper3HeadlineSolFamNW w) w).u t i -
        (confEncU (solMUReplStaticCfg w j) i : ℝ)|
      = |((paper3HeadlineSolFamNW w) w).u t i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| := rfl
    _ ≤ r_LE_U - δuSettledN paper3F1CwinDefN 0 := h
    _ ≤ r_LE_U := by linarith

/-- **Seg C edge tube: the readout tube persists through the z-off prefix**
`[ws j, zOffStart j] = [2πj+π/6, 2πj+π]` — the S4a gap-floor window
`[wr j, 2πj+π]` is contained in it.  Produced by the tube-maintenance
engine at the joint core's canonical envelope. -/
theorem paper3SegC_edge_tube_NW (w j : ℕ) :
    ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).u t i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U := by
  rcases paper3F1_joint_step_core_NW w with ⟨core, hCwinEq⟩
  have hje := paper3F1_joint_tube_and_endpoint_NW w core
  have htube0 : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN := by
    intro i
    have h := (hje j).1 i
    rw [hCwinEq] at h
    exact h
  have hwin : ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3F1CwinDefN := by
    intro i t ht
    have h := core.hwin_of j (hje j).1 (hje j).2 i t ht
    rwa [hCwinEq] at h
  exact (paper3NW4_tube_maintenance w w j htube0 hwin).1

/-- **Pairwise payoff-gap floor from a single-configuration tube, at the
word-coupled family** (NW sibling of
`paper3Headline_pairwiseGap_of_single_tube`, stated directly as the
winner-minus-loser lower bound). -/
theorem paper3SegC_pairwiseGap_of_single_tube_NW
    (w k : ℕ) {a b : ℝ}
    (htube :
      ∀ t ∈ Icc a b,
        UTube r_LE_U (solMUReplStaticCfg w k)
          (((paper3HeadlineSolFamNW w) w).u t)) :
    ∀ t ∈ Icc a b,
      ∀ v : UniversalLocalView,
        v ≠ localViewU (solMUReplStaticCfg w k) →
        selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos ≤
          universalPval paper3HeadlineEta paper3HeadlineEta_pos
              (localViewU (solMUReplStaticCfg w k))
              (((paper3HeadlineSolFamNW w) w).u t) -
            universalPval paper3HeadlineEta paper3HeadlineEta_pos v
              (((paper3HeadlineSolFamNW w) w).u t) := by
  classical
  intro t ht v hvne
  have hmargins :=
    universal_selector_margins_of_tube
      (eta := paper3HeadlineEta) (heta := paper3HeadlineEta_pos)
      (c := solMUReplStaticCfg w k)
      (Z := ((paper3HeadlineSolFamNW w) w).u t)
      (htube t ht) paper3HeadlineHerr
  have hwin :
      1 / 2 -
          (gateSelectorAtomsCoordN
            (universalGateAtoms paper3HeadlineEta paper3HeadlineEta_pos)).errSel ≤
        universalPval paper3HeadlineEta paper3HeadlineEta_pos
          (localViewU (solMUReplStaticCfg w k))
          (((paper3HeadlineSolFamNW w) w).u t) := by
    simpa [universalPval] using hmargins.1
  have hloser :
      universalPval paper3HeadlineEta paper3HeadlineEta_pos v
          (((paper3HeadlineSolFamNW w) w).u t) ≤
        -(1 / 2 -
          (gateSelectorAtomsCoordN
            (universalGateAtoms paper3HeadlineEta paper3HeadlineEta_pos)).errSel) := by
    simpa [universalPval] using hmargins.2 v hvne
  dsimp [selectorReplicatorGapVal]
  linarith

/-- **S4a-NW analytic input: the left-edge payoff-gap floor at the
word-coupled family** (NW restatement of `paper3S4a_gapFloor`, diagonal):
on `[wr j, 2πj+π]` the u-state stays in the cycle-`j` readout tube (Seg C
edge tube), so the old winner keeps the pairwise payoff gap `≥ 1/2` over
every other view. -/
theorem paper3S4a_gapFloor_NW (w j : ℕ) :
    ∀ v : UniversalLocalView, v ≠ localViewU (solMUReplStaticCfg w j) →
    ∀ τ ∈ Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
      (1 / 2 : ℝ) ≤
        universalPval paper3HeadlineEta paper3HeadlineEta_pos
            (localViewU (solMUReplStaticCfg w j))
            (((paper3HeadlineSolFamNW w) w).u τ) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFamNW w) w).u τ) := by
  intro v hv τ hτ
  have hsub : Icc (selectorMUInterReadStart j) (selectorMUZOffStart j) ⊆
      Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j) :=
    Icc_subset_Icc_left (selectorMUWriteStart_le_read j)
  have htube : ∀ t ∈ Icc (selectorMUInterReadStart j)
      (selectorMUZOffStart j),
      UTube r_LE_U (solMUReplStaticCfg w j)
        (((paper3HeadlineSolFamNW w) w).u t) := by
    intro t ht i
    exact paper3SegC_edge_tube_NW w j t (hsub ht) i
  have hgap := paper3SegC_pairwiseGap_of_single_tube_NW w j htube τ hτ v hv
  have hhalf := paper3S13_gapVal_ge_half
  linarith

/-- **Seg C seam: the per-word diagonal full write-window u-tube record**
(Q4136 §3 minimal quarantine version).  Exactly what the headline analytic
discharge consumes: prefix and settled-tail tubes around the cycle-`j`
static configuration (`solMUReplStaticCfg w j`, NOT `j+1`), single word
index throughout. -/
structure Paper3F1FullUTubeResidualNW (w : ℕ) : Prop where
  hutube_prefix :
    ∀ j : ℕ, ∀ t ∈ Ico (selectorMUWriteStartTime j)
        (selectorMUWriteHoldTime j),
      UTube r_LE_U (solMUReplStaticCfg w j)
        (((paper3HeadlineSolFamNW w) w).u t)
  hutube_tail :
    ∀ j : ℕ, ∀ t ∈ Icc (selectorMUWriteHoldTime j)
        (selectorMUWriteReadTime j),
      UTube r_LE_U (solMUReplStaticCfg w j)
        (((paper3HeadlineSolFamNW w) w).u t)

/-- Rate-free gluing: prefix (`Ico`) + tail (`Icc`) = full write window
(`Ico`, open at `writeRead`). -/
theorem Paper3F1FullUTubeResidualNW.hutube_win {w : ℕ}
    (R : Paper3F1FullUTubeResidualNW w) :
    ∀ j : ℕ, ∀ t ∈ Ico (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      UTube r_LE_U (solMUReplStaticCfg w j)
        (((paper3HeadlineSolFamNW w) w).u t) := by
  intro j t ht
  by_cases h : t < selectorMUWriteHoldTime j
  · exact R.hutube_prefix j t ⟨ht.1, h⟩
  · exact R.hutube_tail j t ⟨le_of_not_gt h, le_of_lt ht.2⟩

/-- **Seg C producer: the diagonal full write-window u-tube holds at every
word.**  This is the global headline object `∀ w, …` with ONE input index —
it never introduces an unprovable `(wg, w)` pair. -/
theorem paper3F1FullUTubeResidualNW_all :
    ∀ w : ℕ, Paper3F1FullUTubeResidualNW w := by
  intro w
  refine ⟨?_, ?_⟩
  · intro j t ht
    exact paper3SegC_utube_win_NW w j t
      ⟨ht.1, le_trans (le_of_lt ht.2) (selectorMUWriteHold_le_read j)⟩
  · intro j t ht
    exact paper3SegC_utube_win_NW w j t
      ⟨le_trans (selectorMUWriteStart_le_hold j) ht.1, ht.2⟩

/-- **The NW instantiation of the parameter-generic analytic discharge
record** (Q4149 Step 2): warm-gain family with word-coupled parameters
`bgpParamsNW wg`, solution family `paper3HeadlineSolFamNW`. -/
abbrev Paper3AnalyticResidualDischargeNW :=
  Paper3AnalyticResidualDischargeP (fun wg => bgpParamsNW wg)
    (fun wg => paper3WarmGainQNW wg) (fun wg => paper3HeadlineSolFamNW wg)

/-- **Direct diagonal constructor for the NW discharge** (Q4149 Step 2):
the `hutube_win` field is CLOSED by the Seg C seam
(`paper3F1FullUTubeResidualNW_all`); the Hoff and NextWrite fields stay
explicit arguments until the Seg E / Seg D producers land.  This
deliberately does NOT route through
`Paper3AnalyticResidualDischarge.ofResiduals` — that constructor's
`∀ wg, SelectorMUWriteFullUTubeResidual (solByWarmGain wg)` premise is
exactly the quarantined off-diagonal debt. -/
def paper3AnalyticResidualDischargeNW_of_diagonal
    (p_hoff :
      ∀ w j, selectorMUHaltEncConst (solMUReplStaticCfg w) j → ∀ t ∈
        Icc (selectorMUInterReadStart j) (selectorMUNextWriteStart j),
          |((paper3HeadlineSolFamNW w) w).z t haltCoordU -
            ((paper3HeadlineSolFamNW w) w).z
              (selectorMUInterReadStart j) haltCoordU| ≤
              selectorReplicatorHoldEnvelope j)
    (δnext : ℕ → ℕ → ℝ)
    (hδnext : ∀ w, Tendsto (δnext w) atTop (𝓝 0))
    (hδnext_nonneg : ∀ w j, 0 ≤ δnext w j)
    (hnextWrite :
      ∀ w j, ∀ t ∈ Icc (selectorMUNextWriteStart j) (selectorMUNextRead j),
        |((paper3HeadlineSolFamNW w) w).z t haltCoordU -
          stackMachineEncodingU.enc
            (solMUReplStaticCfg w (j + 2)) haltCoordU| ≤
            δnext w j) :
    Paper3AnalyticResidualDischargeNW where
  hutube_win := fun w => (paper3F1FullUTubeResidualNW_all w).hutube_win
  p_hoff := p_hoff
  δnext := δnext
  hδnext := hδnext
  hδnext_nonneg := hδnext_nonneg
  hnextWrite := hnextWrite

/-! ### S2-NW: the post-handoff crude guard box (design: Q4148)

Origin-centered ASYMMETRIC guard on the post-handoff lower-half window
`[2πj+7π/6, 2πj+2π]`: `|z_i| ≤ 2·D_U+1`, `|u_i| ≤ 2·D_U+2` (levels shifted
by the repo encoding hull `|enc| ≤ 2·D_U`, `paper3NW4_enc_abs`).  This is
NOT a tube around an encoding — the encoding enters only through the entry
premise.  Joint bootstrap with a z-side-ONLY first exit:

* while `z` is in its box, `u` is trapped in the LARGER box
  (`relaxation_box_invariant` — the open u-gate is stabilizing because its
  target `z` lies in the smaller box; never bound `∫kU` here);
* the `u` box gives the crude affine branch hull
  (`paper3NW4_eval_abs_of_coord_bound`), hence with simplex convexity a
  finite `|mix−z|` source `paper3S2MixZGuard` — NO concentration/loser-mass
  input (λ movement is irrelevant to a convex hull);
* the whole window sits in the lower half-period
  (`sin_nonpos_on_lower_half`), so the suppressed z-gate mass
  (`paper3NW4_z_drift_of_sin_nonpos`) keeps the `z` displacement below the
  one-unit guard margin: `entry ≤ 2D+δ_handoff`, displacement `≤ r/4`,
  `δ_handoff + r/4 < 1`. -/

noncomputable def paper3S2GuardCz : ℝ := 2 * D_U + 1

noncomputable def paper3S2GuardCu : ℝ := 2 * D_U + 2

/-- Crude affine branch hull at the `Cu` guard box
(= the `paper3NW4_eval_abs_of_coord_bound` constant). -/
noncomputable def paper3S2BranchGuard : ℝ :=
  2 * D_U + 4000 * D_U * (5 * D_U + 2)

noncomputable def paper3S2MixZGuard : ℝ :=
  paper3S2BranchGuard + paper3S2GuardCz

theorem paper3S2MixZGuard_nonneg : 0 ≤ paper3S2MixZGuard := by
  unfold paper3S2MixZGuard paper3S2BranchGuard paper3S2GuardCz
  nlinarith [D_U_nonneg]

/-- Branch hull from the origin-centered `Cu` guard box: every branch
evaluation is within `paper3S2BranchGuard` (the guard box sits inside the
`5·D_U+2` coordinate window of the affine evaluation lemma around any
configuration encoding). -/
theorem paper3S2_branch_abs_le_guard (w j : ℕ) {t : ℝ}
    (hu : ∀ k : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u t k| ≤ paper3S2GuardCu) :
    ∀ (i : Fin d_U) (v : UniversalLocalView),
      |BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFamNW w) w).u t) i| ≤ paper3S2BranchGuard := by
  intro i v
  have henc := paper3NW4_enc_abs (solMUReplStaticCfg w (j + 1)) i
  have hui := hu i
  have hx : |((paper3HeadlineSolFamNW w) w).u t i -
      stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤
      5 * D_U + 2 := by
    have htri := abs_sub (((paper3HeadlineSolFamNW w) w).u t i)
      (stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i)
    unfold paper3S2GuardCu at hui
    have hD0 := D_U_nonneg
    linarith
  have h := paper3NW4_eval_abs_of_coord_bound v i
    (solMUReplStaticCfg w (j + 1)) hx
  unfold paper3S2BranchGuard
  exact h

/-- Crude `|mix − z|` source bound on the guard box: convex hull of the
branch evaluations plus the `z` guard level. -/
theorem paper3S2_mixz_abs_le_guard (w j : ℕ) {t : ℝ} (ht0 : 0 ≤ t)
    (hu : ∀ k : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u t k| ≤ paper3S2GuardCu)
    (i : Fin d_U)
    (hz : |((paper3HeadlineSolFamNW w) w).z t i| ≤ paper3S2GuardCz) :
    |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
        ((paper3HeadlineSolFamNW w) w).lam t i -
      ((paper3HeadlineSolFamNW w) w).z t i| ≤ paper3S2MixZGuard := by
  have hmix := paper3NW_mixTarget_abs_le_of_branch_abs w w ht0
    (fun i' v => paper3S2_branch_abs_le_guard w j hu i' v) i
  have htri := abs_sub
    (selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
      ((paper3HeadlineSolFamNW w) w).lam t i)
    (((paper3HeadlineSolFamNW w) w).z t i)
  unfold paper3S2MixZGuard
  linarith

/-- **Word-coupled exponential kill for the first-exit displacement**: the
crude `mix−z` source through the lower-half z-gate mass is far below a
quarter of the readout tube. -/
theorem paper3S2_firstExit_z_drift_cap_NW (w j : ℕ) :
    paper3S2MixZGuard *
        Real.exp (-(200 * (bgpScaleW w : ℝ) *
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) /
        (200 * (bgpScaleW w : ℝ)) ≤ r_LE_U / 4 := by
  have hπ3 := Real.pi_gt_three
  have hS := paper3NW4_S_ge w
  have hSpos : (0 : ℝ) < (bgpScaleW w : ℝ) := bgpScaleWR_pos w
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) := by
    have := Real.pi_pos
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith
  have hD := paper3NW4_DU_le_exp w
  have hD0 := D_U_nonneg
  have hE1 : (1 : ℝ) ≤ Real.exp (bgpScaleW w : ℝ) := by
    have := Real.add_one_le_exp (bgpScaleW w : ℝ)
    linarith
  have h28 : (28005 : ℝ) ≤ Real.exp (bgpScaleW w : ℝ) := by
    have hq := paper3NW4_sq_quarter_le_exp
      (by linarith : (0 : ℝ) ≤ (bgpScaleW w : ℝ))
    nlinarith [sq_nonneg ((bgpScaleW w : ℝ) - 5184)]
  -- Step 1: the guard constant fits in `e^{3S}`
  have hguard : paper3S2MixZGuard ≤ Real.exp (3 * (bgpScaleW w : ℝ)) := by
    have hDD : D_U * D_U ≤
        Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ) :=
      mul_le_mul hD hD hD0 (Real.exp_pos _).le
    have hEE : (0 : ℝ) ≤
        Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ) :=
      mul_nonneg (Real.exp_pos _).le (Real.exp_pos _).le
    have h3 : Real.exp (3 * (bgpScaleW w : ℝ)) =
        Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ) *
          Real.exp (bgpScaleW w : ℝ) := by
      rw [← Real.exp_add, ← Real.exp_add]
      ring_nf
    have hcube : 28005 *
        (Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ)) ≤
        Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ) *
          Real.exp (bgpScaleW w : ℝ) := by
      nlinarith [h28, hEE]
    have hDsq : 20000 * (D_U * D_U) ≤ 20000 *
        (Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ)) := by
      nlinarith [hDD]
    have hDlin : 8004 * D_U ≤ 8004 *
        (Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ)) := by
      nlinarith [hD, hE1, hD0]
    have h1E : (1 : ℝ) ≤
        Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ) := by
      nlinarith [hE1]
    unfold paper3S2MixZGuard paper3S2BranchGuard paper3S2GuardCz
    rw [h3]
    linarith
  -- Step 2: exponent domination on the window entry
  have hexp_a : Real.exp (-(200 * (bgpScaleW w : ℝ) *
      (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) ≤
      Real.exp (-(700 * (bgpScaleW w : ℝ))) := by
    apply Real.exp_le_exp.mpr
    have ha35 : (3.5 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 := by
      nlinarith
    nlinarith [mul_le_mul_of_nonneg_left ha35
      (by linarith : (0 : ℝ) ≤ 200 * (bgpScaleW w : ℝ))]
  have hprod : paper3S2MixZGuard * Real.exp (-(200 * (bgpScaleW w : ℝ) *
      (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) ≤
      Real.exp (3 * (bgpScaleW w : ℝ)) *
        Real.exp (-(700 * (bgpScaleW w : ℝ))) :=
    mul_le_mul hguard hexp_a (Real.exp_pos _).le (Real.exp_pos _).le
  have hsum : Real.exp (3 * (bgpScaleW w : ℝ)) *
      Real.exp (-(700 * (bgpScaleW w : ℝ))) =
      Real.exp (3 * (bgpScaleW w : ℝ) - 700 * (bgpScaleW w : ℝ)) := by
    rw [← Real.exp_add]
    ring_nf
  have hkill : Real.exp (3 * (bgpScaleW w : ℝ) - 700 * (bgpScaleW w : ℝ)) ≤
      Real.exp (-(200 : ℝ)) := by
    apply Real.exp_le_exp.mpr
    nlinarith [hS]
  have hfinal : Real.exp (-(200 : ℝ)) ≤ r_LE_U / 4 := by
    have hq := paper3NW4_sq_quarter_le_exp (by norm_num : (0 : ℝ) ≤ (200 : ℝ))
    have h10000 : (10000 : ℝ) ≤ Real.exp (200 : ℝ) := by nlinarith
    have hinv : Real.exp (-(200 : ℝ)) * Real.exp (200 : ℝ) = 1 := by
      rw [← Real.exp_add]
      norm_num
    have hx0 : (0 : ℝ) ≤ Real.exp (-(200 : ℝ)) := (Real.exp_pos _).le
    have hr : r_LE_U = 1 / 1000 := rfl
    rw [hr]
    nlinarith [mul_le_mul_of_nonneg_left h10000 hx0, hinv]
  have hdivle : paper3S2MixZGuard * Real.exp (-(200 * (bgpScaleW w : ℝ) *
      (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) /
      (200 * (bgpScaleW w : ℝ)) ≤
      paper3S2MixZGuard * Real.exp (-(200 * (bgpScaleW w : ℝ) *
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) := by
    apply div_le_self
    · exact mul_nonneg paper3S2MixZGuard_nonneg (Real.exp_pos _).le
    · nlinarith [hS]
  calc paper3S2MixZGuard * Real.exp (-(200 * (bgpScaleW w : ℝ) *
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) /
        (200 * (bgpScaleW w : ℝ))
      ≤ paper3S2MixZGuard * Real.exp (-(200 * (bgpScaleW w : ℝ) *
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) := hdivle
    _ ≤ Real.exp (3 * (bgpScaleW w : ℝ)) *
          Real.exp (-(700 * (bgpScaleW w : ℝ))) := hprod
    _ = Real.exp (3 * (bgpScaleW w : ℝ) - 700 * (bgpScaleW w : ℝ)) := hsum
    _ ≤ Real.exp (-(200 : ℝ)) := hkill
    _ ≤ r_LE_U / 4 := hfinal

/-- **The Q4148 window-box record**: origin-centered asymmetric guard on
the post-handoff window `[2πj+7π/6, 2πj+2π]`. -/
structure Paper3S2WindowBoxNW (w j : ℕ) : Prop where
  hz : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z t i| ≤ paper3S2GuardCz
  hu : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3S2GuardCu

/-- **S2-NW crude guard box by z-side first exit** (Q4148, the last of the
three "genuinely new math" items of the corrected S2 ledger).  Entry data
comes from the landed handoff pair at `2πj+7π/6`. -/
theorem paper3S2_window_firstExit_box_NW (w j : ℕ) {δh : ℝ}
    (hδh0 : 0 ≤ δh) (hδh_le : δh ≤ 9 * r_LE_U / 20)
    (hz_entry : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i -
        stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤ δh)
    (hu_entry : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i| ≤ paper3S2GuardCu) :
    Paper3S2WindowBoxNW w j := by
  classical
  have hπ := Real.pi_pos
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) := by
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith
  have ha0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 := by linarith
  have hab : 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 ≤
      2 * Real.pi * (j : ℝ) + 2 * Real.pi := by linarith
  -- entry z level: `|z(a)| ≤ 2D + δh`
  have hz_a : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i| ≤ 2 * D_U + δh := by
    intro i
    have henc := paper3NW4_enc_abs (solMUReplStaticCfg w (j + 1)) i
    have hze := hz_entry i
    have hsplit : |((paper3HeadlineSolFamNW w) w).z
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i| ≤
        |((paper3HeadlineSolFamNW w) w).z
            (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i -
          stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| +
        |stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| := by
      have h := abs_sub_le
        (((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i)
        (stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i)
        (0 : ℝ)
      simpa using h
    linarith
  -- the guard margin: entry + displacement stays strictly inside
  have hmargin : 2 * D_U + δh + r_LE_U / 4 < paper3S2GuardCz := by
    unfold paper3S2GuardCz
    have hr : r_LE_U = 1 / 1000 := rfl
    rw [hr] at hδh_le ⊢
    linarith
  -- z box on the whole window by first exit
  have hz_all : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z t i| ≤ paper3S2GuardCz := by
    by_contra hcon
    push_neg at hcon
    obtain ⟨tb, htb, i0, hi0⟩ := hcon
    set Bad : Set ℝ := Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) tb ∩
      ⋃ i : Fin d_U, {s : ℝ |
        paper3S2GuardCz ≤ |((paper3HeadlineSolFamNW w) w).z s i|}
      with hBadDef
    have hclosed : IsClosed Bad := by
      refine isClosed_Icc.inter (isClosed_iUnion_of_finite fun i => ?_)
      exact isClosed_le continuous_const
        ((((paper3HeadlineSolFamNW w) w).cont_z i).abs)
    have htb_mem : tb ∈ Bad :=
      ⟨⟨htb.1, le_refl tb⟩, Set.mem_iUnion.mpr ⟨i0, hi0.le⟩⟩
    have hne : Bad.Nonempty := ⟨tb, htb_mem⟩
    have hbdd : BddBelow Bad :=
      ⟨2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6, fun s hs => hs.1.1⟩
    have htmem : sInf Bad ∈ Bad := hclosed.csInf_mem hne hbdd
    have hta : 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 ≤ sInf Bad :=
      le_csInf hne fun s hs => hs.1.1
    have htle : sInf Bad ≤ tb := csInf_le hbdd htb_mem
    have htb_b : tb ≤ 2 * Real.pi * (j : ℝ) + 2 * Real.pi := htb.2
    have ht_b : sInf Bad ≤ 2 * Real.pi * (j : ℝ) + 2 * Real.pi :=
      le_trans htle htb_b
    have hτ0 : (0 : ℝ) ≤ sInf Bad := le_trans ha0 hta
    have htpos : 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 < sInf Bad := by
      rcases lt_or_eq_of_le hta with h | h
      · exact h
      · exfalso
        obtain ⟨i, hi⟩ := Set.mem_iUnion.mp htmem.2
        rw [← h] at hi
        simp only [Set.mem_setOf_eq] at hi
        have hza := hz_a i
        have hr : r_LE_U = 1 / 1000 := rfl
        have hr4 : (0 : ℝ) ≤ r_LE_U / 4 := by rw [hr]; norm_num
        linarith [hmargin]
    -- prefix z box up to and including the first-exit time
    have hzpre : ∀ s ∈ Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
        (sInf Bad), ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z s i| ≤ paper3S2GuardCz := by
      intro s hs i
      rcases lt_or_eq_of_le hs.2 with hlt | heq
      · by_contra hgt
        push_neg at hgt
        have hmem : s ∈ Bad :=
          ⟨⟨hs.1, le_trans hs.2 htle⟩, Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
        exact absurd (csInf_le hbdd hmem) (not_le.mpr hlt)
      · have hf : Continuous fun τ : ℝ =>
            |((paper3HeadlineSolFamNW w) w).z τ i| :=
          (((paper3HeadlineSolFamNW w) w).cont_z i).abs
        have hev : ∀ᶠ τ in nhdsWithin (sInf Bad) (Set.Iio (sInf Bad)),
            |((paper3HeadlineSolFamNW w) w).z τ i| ≤ paper3S2GuardCz := by
          filter_upwards [Ioo_mem_nhdsLT htpos] with τ hτ
          by_contra hgt
