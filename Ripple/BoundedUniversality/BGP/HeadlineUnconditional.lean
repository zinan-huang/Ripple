theorem paper3HeadlineHCardTwo : 2 ≤ Fintype.card UniversalLocalView := by
  have hle : Fintype.card Bool ≤ Fintype.card UniversalLocalView :=
    Fintype.card_le_of_injective
      (fun b : Bool => cond b paper3HeadlineViewSome paper3HeadlineViewNone)
      (by
        intro a b h
        cases a <;> cases b <;>
          simp [paper3HeadlineViewSome, paper3HeadlineViewNone] at h ⊢)
  simpa using hle

