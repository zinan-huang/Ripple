    have h1 : (5184 : ℝ) ≤ c * (bgpScaleW wg : ℝ) := by nlinarith
    have h2 : (6 : ℝ) ≤ 2 * Real.pi := by linarith
    have h3 := mul_le_mul h1 h2 (by linarith) (by nlinarith)
    linarith
  have hkey := mul_le_mul_of_nonneg_right hfac hj
