  have hUnew := (htubes t ht).2
  have hgap_le :
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos ≤
        selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := le_rfl
  have h :=
    universalPval_pairwise_gap_bad_to_old_new_of_tubes
      (eta := paper3HeadlineEta) (heta := paper3HeadlineEta_pos)
      (cold := solMUReplStaticCfg w j)
      (cnew := solMUReplStaticCfg w (j + 1))
      (Z := ((paper3HeadlineSolFam wg) w).u t)
      (gap := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
      paper3HeadlineHerr hgap_le hUold hUnew v
      (by simpa using hv) u (by simpa using hu)
  simpa using h

/-- Left-edge version of the safe-mass floor bridge. -/
theorem paper3HeadlineLeftSafeMass_floor_of_badMass_le
    (wg w j : ℕ) {Lsafe : ℝ}
    (hbad :
      ∀ t ∈ Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => ((paper3HeadlineSolFam wg) w).lam v t) ≤ 1 - Lsafe) :
    ∀ t ∈ Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
      Lsafe ≤
        (insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView)).sum
          (fun u => ((paper3HeadlineSolFam wg) w).lam u t) := by
  classical
  intro t ht
  let safe : Finset UniversalLocalView :=
    insert (localViewU (solMUReplStaticCfg w j))
      ({localViewU (solMUReplStaticCfg w (j + 1))} :
        Finset UniversalLocalView)
  let bad : Finset UniversalLocalView :=
    Finset.univ.filter (fun v : UniversalLocalView => v ∉ safe)
  let f : UniversalLocalView → ℝ := fun v => ((paper3HeadlineSolFam wg) w).lam v t
  have ha_nonneg : 0 ≤ selectorMUInterReadStart j := by
    unfold selectorMUInterReadStart selectorMUWriteReadTime
    positivity
  have ht_nonneg : 0 ≤ t := le_trans ha_nonneg ht.1
  have hsum : (∑ v : UniversalLocalView, f v) = 1 := by
    simpa [f] using paper3Headline_lam_sum_forward wg w t ht_nonneg
  have hpartition :
      (∑ v : UniversalLocalView, f v) = bad.sum f + safe.sum f := by
    simpa [bad, f] using
      paper3_sum_univ_filter_not_mem_add_sum
        (V := UniversalLocalView) safe f
  have hbad_t :
      bad.sum f ≤ 1 - Lsafe := by
    simpa [bad, safe, f, not_or] using hbad t ht
  have htotal : bad.sum f + safe.sum f = 1 := by
    rw [← hpartition, hsum]
  linarith

/-- Left-edge version of the pairwise payoff-gap bridge. -/
theorem paper3HeadlineLeft_pairwiseGap_of_old_new_tubes
    (wg w j : ℕ)
    (htubes :
      ∀ t ∈ Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
        UTube r_LE_U (solMUReplStaticCfg w j)
          (((paper3HeadlineSolFam wg) w).u t) ∧
        UTube r_LE_U (solMUReplStaticCfg w (j + 1))
          (((paper3HeadlineSolFam wg) w).u t)) :
    ∀ t ∈ Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
      ∀ v : UniversalLocalView,
        v ∉ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := by
  classical
  intro t ht v hv u hu
  have hUold := (htubes t ht).1
  have hUnew := (htubes t ht).2
  have hgap_le :
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos ≤
        selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := le_rfl
  have h :=
    universalPval_pairwise_gap_bad_to_old_new_of_tubes
      (eta := paper3HeadlineEta) (heta := paper3HeadlineEta_pos)
      (cold := solMUReplStaticCfg w j)
      (cnew := solMUReplStaticCfg w (j + 1))
      (Z := ((paper3HeadlineSolFam wg) w).u t)
      (gap := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
      paper3HeadlineHerr hgap_le hUold hUnew v
      (by simpa using hv) u (by simpa using hu)
  simpa using h

/-- Singleton-safe payoff-gap bridge from one `UTube`.

This is the reusable local ingredient needed by the non-dual route: when the
safe set is the singleton local view of one configuration, a single tube around
that configuration gives the concrete selector payoff gap against every view
outside the singleton. -/
theorem paper3Headline_pairwiseGap_of_single_tube
    (wg w k : ℕ) {a b : ℝ}
    (htube :
      ∀ t ∈ Icc a b,
        UTube r_LE_U (solMUReplStaticCfg w k)
          (((paper3HeadlineSolFam wg) w).u t)) :
    ∀ t ∈ Icc a b,
      ∀ v : UniversalLocalView,
        v ∉ ({localViewU (solMUReplStaticCfg w k)} :
          Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ ({localViewU (solMUReplStaticCfg w k)} :
          Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := by
  classical
  intro t ht v hv u hu
  have hu_eq : u = localViewU (solMUReplStaticCfg w k) := by
    simpa using hu
  subst u
  have hvne : v ≠ localViewU (solMUReplStaticCfg w k) := by
    simpa using hv
  have hmargins :=
    universal_selector_margins_of_tube
      (eta := paper3HeadlineEta) (heta := paper3HeadlineEta_pos)
      (c := solMUReplStaticCfg w k)
      (Z := ((paper3HeadlineSolFam wg) w).u t)
      (htube t ht) paper3HeadlineHerr
  have hwin :
      1 / 2 -
          (gateSelectorAtomsCoordN
            (universalGateAtoms paper3HeadlineEta paper3HeadlineEta_pos)).errSel ≤
        universalPval paper3HeadlineEta paper3HeadlineEta_pos
          (localViewU (solMUReplStaticCfg w k))
          (((paper3HeadlineSolFam wg) w).u t) := by
    simpa [universalPval] using hmargins.1
  have hloser :
      universalPval paper3HeadlineEta paper3HeadlineEta_pos v
          (((paper3HeadlineSolFam wg) w).u t) ≤
        -(1 / 2 -
          (gateSelectorAtomsCoordN
            (universalGateAtoms paper3HeadlineEta paper3HeadlineEta_pos)).errSel) := by
    simpa [universalPval] using hmargins.2 v hvne
  have hgap_le :
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos ≤
        universalPval paper3HeadlineEta paper3HeadlineEta_pos
            (localViewU (solMUReplStaticCfg w k))
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) := by
    dsimp [selectorReplicatorGapVal]
    linarith
  linarith

/-- Prewrite singleton-safe payoff gap around the next configuration. -/
theorem paper3HeadlinePrewrite_pairwiseGap_singleton_new_of_tube
    (wg w j : ℕ)
    (htube :
      ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
        UTube r_LE_U (solMUReplStaticCfg w (j + 1))
          (((paper3HeadlineSolFam wg) w).u t)) :
    ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      ∀ v : UniversalLocalView,
        v ∉ ({localViewU (solMUReplStaticCfg w (j + 1))} :
          Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ ({localViewU (solMUReplStaticCfg w (j + 1))} :
          Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := by
  simpa using
    paper3Headline_pairwiseGap_of_single_tube
      (wg := wg) (w := w) (k := j + 1)
      (a := selectorMUZOffEnd j)
      (b := selectorMUWriteStartTime (j + 1)) htube

/-- Propagate the new winner's `1/card` floor across the prewrite window.

The remaining input is the endpoint floor at `selectorMUZOffEnd j`; the tube
assumption supplies the payoff gap needed by the barrier theorem on the open
part of the interval. -/
theorem paper3Headline_prewrite_newWinner_floor_of_zOffEnd_floor
    (wg w j : ℕ)
    (hstart :
      1 / (Fintype.card UniversalLocalView : ℝ) ≤
        ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w (j + 1)))
          (selectorMUZOffEnd j))
    (htube :
      ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
        UTube r_LE_U (solMUReplStaticCfg w (j + 1))
          (((paper3HeadlineSolFam wg) w).u t)) :
    ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      1 / (Fintype.card UniversalLocalView : ℝ) ≤
        ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w (j + 1))) t := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  let solFam := paper3HeadlineSolFam wg
  let a := selectorMUZOffEnd j
  let b := selectorMUWriteStartTime (j + 1)
  let vstar := localViewU (solMUReplStaticCfg w (j + 1))
  have hab : a ≤ b := by
    simpa [a, b] using selectorMUZOffEnd_le_writeStart_succ j
  have ha_nonneg : 0 ≤ a := by
    dsimp [a, selectorMUZOffEnd]
    positivity
  have hsum_forward := paper3Headline_lam_sum_forward wg w
  have hlam_forward := paper3Headline_lam_nonneg_forward wg w
  have hgap0 : 0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos :=
    solMURepl_static_hgap0 paper3HeadlineEta paper3HeadlineEta_pos paper3HeadlineHerr
  have hpair :=
    paper3HeadlinePrewrite_pairwiseGap_singleton_new_of_tube
      (wg := wg) (w := w) (j := j) htube
  have hgap_floor :
      ∀ v : UniversalLocalView, v ≠ vstar →
        ∀ t ∈ Ico a b,
          universalPval paper3HeadlineEta paper3HeadlineEta_pos v
              ((solFam w).u t) -
            universalPval paper3HeadlineEta paper3HeadlineEta_pos vstar
              ((solFam w).u t) ≤ 0 := by
    intro v hv t ht
    have htIcc_ab : t ∈ Icc a b := Ico_subset_Icc_self ht
    have htIcc :
        t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)) := by
      simpa [a, b] using htIcc_ab
    have hv_not :
        v ∉ ({localViewU (solMUReplStaticCfg w (j + 1))} :
          Finset UniversalLocalView) := by
      simpa [vstar] using hv
    have hvstar_mem :
        vstar ∈ ({localViewU (solMUReplStaticCfg w (j + 1))} :
          Finset UniversalLocalView) := by
      simp [vstar]
    have hle_neg :=
      hpair t htIcc v hv_not vstar hvstar_mem
    have hnonpos : -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos ≤ 0 :=
      neg_nonpos.mpr hgap0.le
    exact le_trans (by simpa [solFam, vstar] using hle_neg) hnonpos
  have hfloor :=
    replicator_winner_floor_on_interval
      (sol := solFam w) vstar (a := a) (b := b) hab
      (fun t ht => solMURepl_static_hdom_nonneg t
        (le_trans ha_nonneg ht.1))
      (fun t _ht => (paper3HeadlineBoxInputs wg).hcr_nonneg t)
      (fun t _ht =>
        mul_nonneg
          (pow_nonneg (by nlinarith [Real.neg_one_le_sin t]) _)
          (mul_nonneg (paper3WarmGainQ_pos wg).le (Real.exp_pos _).le))
      hgap_floor
      (fun t ht => hsum_forward t (le_trans ha_nonneg ht.1))
      (fun v t ht => hlam_forward v t (le_trans ha_nonneg ht.1))
      (by simpa [a, vstar, solFam] using hstart)
  intro t ht
  have ht_ab : t ∈ Icc a b := by
    simpa [a, b] using ht
  simpa [a, b, vstar, solFam] using hfloor t ht_ab

/-- File-local interval-parametric winner recovery, used for the middle
`[ZOffStart, ZOffEnd]` endpoint floor. -/
theorem paper3Headline_replicator_winner_recovery_at_endpoint
    {d B : ℕ} {V : Type} [Fintype V] [Nonempty V]
    {p : DynGateParams} {sched : PhaseSchedule} {branch : V → BranchData d B}
    {chiReset chiGate kappa gain : ℝ → ℝ} {readoutP : V → (Fin d → ℝ) → ℝ}
    (sol : SelectorReplicatorDynSol d B V p sched branch
      chiReset chiGate kappa gain readoutP)
    (vstar : V) {s t crMin crMax cgMin gap b : ℝ} {K : ℕ}
    (hN2 : 2 ≤ Fintype.card V)
    (hcrMin_pos : 0 < crMin)
    (hcrMin_le_crMax : crMin ≤ crMax)
    (hcgMin_nonneg : 0 ≤ cgMin)
    (hgap_nonneg : 0 ≤ gap)
    (hb_eq : b = cgMin * gap / 2 - crMax)
    (hb_pos : 0 < b)
    (hbDelta : (K : ℝ) ≤ b * (t - s))
    (hpow : 1 + b / crMin ≤ (2 : ℝ) ^ K)
    (hst : s ≤ t)
    (hdom : ∀ u ∈ Icc s t, u ∈ sched.domain)
    (hcr_bounds : ∀ u ∈ Icc s t,
      crMin ≤ chiReset u * kappa u ∧ chiReset u * kappa u ≤ crMax)
    (hcg_min : ∀ u ∈ Icc s t, cgMin ≤ chiGate u * gain u)
    (hgap_floor :
      ∀ v : V, v ≠ vstar → ∀ u ∈ Ico s t,
        readoutP v (sol.u u) - readoutP vstar (sol.u u) ≤ 0)
    (havg_gap :
      ∀ u ∈ Ico s t,
        gap * (1 - sol.lam vstar u) ≤
          readoutP vstar (sol.u u) -
            ∑ w : V, sol.lam w u * readoutP w (sol.u u))
    (hsum : ∀ u ∈ Icc s t, (∑ w : V, sol.lam w u) = 1)
    (hlam_nonneg : ∀ v : V, ∀ u ∈ Icc s t, 0 ≤ sol.lam v u) :
    1 / (Fintype.card V : ℝ) ≤ sol.lam vstar t := by
  classical
  let invCard : ℝ := 1 / (Fintype.card V : ℝ)
  have htIcc : t ∈ Icc s t := right_mem_Icc.mpr hst
  have hsIcc : s ∈ Icc s t := left_mem_Icc.mpr hst
  have hNpos_nat : 0 < Fintype.card V :=
    lt_of_lt_of_le (by decide : 0 < 2) hN2
  have hNpos : 0 < (Fintype.card V : ℝ) := by
    exact_mod_cast hNpos_nat
  have hinv_nonneg : 0 ≤ invCard := by
    dsimp [invCard]
    positivity
  have hinv_half : invCard ≤ 1 / 2 := by
    dsimp [invCard]
    have hN2R : (2 : ℝ) ≤ (Fintype.card V : ℝ) := by
      exact_mod_cast hN2
    exact one_div_le_one_div_of_le (by norm_num : (0 : ℝ) < 2) hN2R
  by_contra hnot
  have hlt : sol.lam vstar t < invCard :=
    lt_of_not_ge (by simpa [invCard] using hnot)
  have hbelow : ∀ u ∈ Icc s t, sol.lam vstar u < invCard := by
    intro u hu
    by_contra hnotu
    have hinit : invCard ≤ sol.lam vstar u := le_of_not_gt hnotu
    have hdom_sub : ∀ r ∈ Icc u t, r ∈ sched.domain := by
      intro r hr
      exact hdom r ⟨le_trans hu.1 hr.1, hr.2⟩
    have hcr_nonneg_sub : ∀ r ∈ Icc u t, 0 ≤ chiReset r * kappa r := by
      intro r hr
      have hrfull : r ∈ Icc s t := ⟨le_trans hu.1 hr.1, hr.2⟩
      exact le_trans hcrMin_pos.le ((hcr_bounds r hrfull).1)
    have hcg_nonneg_sub : ∀ r ∈ Icc u t, 0 ≤ chiGate r * gain r := by
      intro r hr
      have hrfull : r ∈ Icc s t := ⟨le_trans hu.1 hr.1, hr.2⟩
      exact le_trans hcgMin_nonneg (hcg_min r hrfull)
    have hgap_sub :
        ∀ v : V, v ≠ vstar → ∀ r ∈ Ico u t,
          readoutP v (sol.u r) - readoutP vstar (sol.u r) ≤ 0 := by
      intro v hv r hr
      exact hgap_floor v hv r ⟨le_trans hu.1 hr.1, hr.2⟩
    have hsum_sub : ∀ r ∈ Icc u t, (∑ w : V, sol.lam w r) = 1 := by
      intro r hr
      exact hsum r ⟨le_trans hu.1 hr.1, hr.2⟩
    have hlam_sub : ∀ v : V, ∀ r ∈ Icc u t, 0 ≤ sol.lam v r := by
      intro v r hr
      exact hlam_nonneg v r ⟨le_trans hu.1 hr.1, hr.2⟩
    have hfloor := replicator_winner_floor_on_interval
      (sol := sol) vstar hu.2
      hdom_sub hcr_nonneg_sub hcg_nonneg_sub hgap_sub hsum_sub hlam_sub
      (by simpa [invCard] using hinit)
    have ht_ge := hfloor t (right_mem_Icc.mpr hu.2)
    exact (not_lt_of_ge (by simpa [invCard] using ht_ge)) hlt
  have hlin := linear_ode_lower_bound
    (a := crMin * invCard) (b := b)
    (mul_nonneg hcrMin_pos.le hinv_nonneg) hb_pos hst
    ((sol.cont_lam vstar).continuousOn)
    (fun u hu => by
      let lam : ℝ := sol.lam vstar u
      let cr : ℝ := chiReset u * kappa u
      let cg : ℝ := chiGate u * gain u
      let pdiff : ℝ :=
        readoutP vstar (sol.u u) -
          ∑ w : V, sol.lam w u * readoutP w (sol.u u)
      refine ⟨cr * (invCard - lam) + cg * lam * pdiff, ?_, ?_⟩
      · have huIcc : u ∈ Icc s t := Ico_subset_Icc_self hu
        simpa [cr, cg, pdiff, lam, invCard, mul_assoc] using
          sol.lam_hasDeriv vstar u (hdom u huIcc)
      · have huIcc : u ∈ Icc s t := Ico_subset_Icc_self hu
        have hcrL : crMin ≤ cr := by
          simpa [cr] using (hcr_bounds u huIcc).1
        have hcrU : cr ≤ crMax := by
          simpa [cr] using (hcr_bounds u huIcc).2
        have hcgL : cgMin ≤ cg := by
          simpa [cg] using hcg_min u huIcc
        have hcg_nonneg : 0 ≤ cg := le_trans hcgMin_nonneg hcgL
        have hlam0 : 0 ≤ lam := by
          simpa [lam] using hlam_nonneg vstar u huIcc
        have hlt_inv : lam < invCard := by
          simpa [lam] using hbelow u huIcc
        have hle_inv : lam ≤ invCard := le_of_lt hlt_inv
        have hlam_half : lam ≤ 1 / 2 := le_trans hle_inv hinv_half
        have hhalf : (1 : ℝ) / 2 ≤ 1 - lam := by linarith
        have hone_minus_nonneg : 0 ≤ 1 - lam := by linarith
        have hgap_factor_nonneg : 0 ≤ gap * (1 - lam) :=
          mul_nonneg hgap_nonneg hone_minus_nonneg
        have hpdiff_lb : gap * (1 - lam) ≤ pdiff := by
          simpa [pdiff, lam] using havg_gap u hu
        have hpdiff_nonneg : 0 ≤ pdiff :=
          le_trans hgap_factor_nonneg hpdiff_lb
        have hreset_lower :
            crMin * invCard - crMax * lam ≤ cr * (invCard - lam) := by
          have hleft :
              crMin * invCard - crMax * lam ≤ crMin * invCard - crMin * lam := by
            have hmul : crMin * lam ≤ crMax * lam :=
              mul_le_mul_of_nonneg_right hcrMin_le_crMax hlam0
            linarith
          have hright : crMin * (invCard - lam) ≤ cr * (invCard - lam) :=
            mul_le_mul_of_nonneg_right hcrL (sub_nonneg.mpr hle_inv)
          have hrewrite :
              crMin * invCard - crMin * lam = crMin * (invCard - lam) := by
            ring
          linarith
        have hgrowth_core :
            cgMin * gap / 2 * lam ≤ cgMin * lam * (gap * (1 - lam)) := by
          have hC : 0 ≤ cgMin * gap * lam :=
            mul_nonneg (mul_nonneg hcgMin_nonneg hgap_nonneg) hlam0
          have hmul := mul_le_mul_of_nonneg_left hhalf hC
          nlinarith
        have hgrowth_mid :
            cgMin * lam * (gap * (1 - lam)) ≤ cg * lam * pdiff := by
          have hA : cgMin * lam ≤ cg * lam :=
            mul_le_mul_of_nonneg_right hcgL hlam0
          have h1 := mul_le_mul_of_nonneg_right hA hgap_factor_nonneg
          have hcg_lam_nonneg : 0 ≤ cg * lam := mul_nonneg hcg_nonneg hlam0
          have h2 := mul_le_mul_of_nonneg_left hpdiff_lb hcg_lam_nonneg
          nlinarith
        have hgrowth :
            cgMin * gap / 2 * lam ≤ cg * lam * pdiff :=
          le_trans hgrowth_core hgrowth_mid
        have htarget :
            crMin * invCard + b * lam =
              (crMin * invCard - crMax * lam) + (cgMin * gap / 2 * lam) := by
          rw [hb_eq]
          ring
        calc
          crMin * invCard + b * lam
              = (crMin * invCard - crMax * lam) +
                  (cgMin * gap / 2 * lam) := htarget
          _ ≤ cr * (invCard - lam) + cg * lam * pdiff :=
              add_le_add hreset_lower hgrowth)
    (by exact hlam_nonneg vstar s hsIcc)
  have hlower := hlin t htIcc
  have hexp_big : 1 + b / crMin ≤ Real.exp (b * (t - s)) :=
    hpow.trans (recovery_exp_ge_two_pow_of_nat_le K hbDelta)
  have hfactor :
      1 ≤ crMin / b * (Real.exp (b * (t - s)) - 1) :=
    recovery_factor_ge_one hcrMin_pos hb_pos hexp_big
  have hlower_floor :
      invCard ≤ (crMin * invCard) / b *
          (Real.exp (b * (t - s)) - 1) := by
    have hmul := mul_le_mul_of_nonneg_left hfactor hinv_nonneg
    have hrewrite :
        invCard * (crMin / b * (Real.exp (b * (t - s)) - 1)) =
          (crMin * invCard) / b *
            (Real.exp (b * (t - s)) - 1) := by
      ring
    nlinarith
  exact (not_lt_of_ge (le_trans hlower_floor hlower)) hlt

/-- Regenerate the new winner's `1/card` floor at `ZOffEnd` from recovery inputs
on the middle window `[ZOffStart, ZOffEnd]`.

This isolates the remaining analytic gap: supplying the middle-window payoff
floor gap and averaged gap for the next configuration. -/
theorem paper3Headline_zOffEnd_newWinner_floor_of_middle_recovery_inputs
    (wg w j : ℕ)
    {crMin crMax cgMin gap b : ℝ} {K : ℕ}
    (hcrMin_pos : 0 < crMin)
    (hcrMin_le_crMax : crMin ≤ crMax)
    (hcgMin_nonneg : 0 ≤ cgMin)
    (hgap_nonneg : 0 ≤ gap)
    (hb_eq : b = cgMin * gap / 2 - crMax)
    (hb_pos : 0 < b)
    (hbDelta : (K : ℝ) ≤
      b * (selectorMUZOffEnd j - selectorMUZOffStart j))
    (hpow : 1 + b / crMin ≤ (2 : ℝ) ^ K)
    (hcr_bounds :
      ∀ u ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
        crMin ≤ ((1 + Real.cos u) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ) ∧
          ((1 + Real.cos u) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ) ≤ crMax)
    (hcg_min :
      ∀ u ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
        cgMin ≤ ((1 + Real.sin u) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * u)))
    (hgap_floor :
      ∀ v : UniversalLocalView,
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)) →
        ∀ u ∈ Ico (selectorMUZOffStart j) (selectorMUZOffEnd j),
          universalPval paper3HeadlineEta paper3HeadlineEta_pos v
              (((paper3HeadlineSolFam wg) w).u u) -
            universalPval paper3HeadlineEta paper3HeadlineEta_pos
              (localViewU (solMUReplStaticCfg w (j + 1)))
              (((paper3HeadlineSolFam wg) w).u u) ≤ 0)
    (havg_gap :
      ∀ u ∈ Ico (selectorMUZOffStart j) (selectorMUZOffEnd j),
        gap *
            (1 - ((paper3HeadlineSolFam wg) w).lam
              (localViewU (solMUReplStaticCfg w (j + 1))) u) ≤
          universalPval paper3HeadlineEta paper3HeadlineEta_pos
              (localViewU (solMUReplStaticCfg w (j + 1)))
              (((paper3HeadlineSolFam wg) w).u u) -
            ∑ v : UniversalLocalView,
              ((paper3HeadlineSolFam wg) w).lam v u *
                universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                  (((paper3HeadlineSolFam wg) w).u u)) :
    1 / (Fintype.card UniversalLocalView : ℝ) ≤
      ((paper3HeadlineSolFam wg) w).lam
        (localViewU (solMUReplStaticCfg w (j + 1)))
        (selectorMUZOffEnd j) := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  let solFam := paper3HeadlineSolFam wg
  let s := selectorMUZOffStart j
  let t := selectorMUZOffEnd j
  let vstar := localViewU (solMUReplStaticCfg w (j + 1))
  have hst : s ≤ t := by
    simpa [s, t] using selectorMUZOffStart_le_zOffEnd j
  have hs_nonneg : 0 ≤ s := by
    dsimp [s, selectorMUZOffStart]
    positivity
  have hsum_forward := paper3Headline_lam_sum_forward wg w
  have hlam_forward := paper3Headline_lam_nonneg_forward wg w
  have hendpoint :=
    paper3Headline_replicator_winner_recovery_at_endpoint
      (sol := solFam w)
      (vstar := vstar)
      (s := s) (t := t)
      (crMin := crMin) (crMax := crMax) (cgMin := cgMin)
      (gap := gap) (b := b) (K := K)
      paper3HeadlineHCardTwo
      hcrMin_pos hcrMin_le_crMax hcgMin_nonneg hgap_nonneg
      hb_eq hb_pos
      (by simpa [s, t] using hbDelta)
      hpow hst
      (fun u hu => solMURepl_static_hdom_nonneg u
        (le_trans hs_nonneg hu.1))
      (fun u hu => by
        simpa [s, t] using hcr_bounds u (by simpa [s, t] using hu))
      (fun u hu => by
        simpa [s, t] using hcg_min u (by simpa [s, t] using hu))
      (fun v hv u hu => by
        simpa [solFam, s, t, vstar] using
          hgap_floor v (by simpa [vstar] using hv) u
            (by simpa [s, t] using hu))
      (fun u hu => by
        simpa [solFam, s, t, vstar] using
          havg_gap u (by simpa [s, t] using hu))
      (fun u hu => hsum_forward u (le_trans hs_nonneg hu.1))
      (fun v u hu => hlam_forward v u (le_trans hs_nonneg hu.1))
  simpa [solFam, t, vstar] using hendpoint

/-- Left-edge singleton-safe payoff gap around the current configuration. -/
theorem paper3HeadlineLeft_pairwiseGap_singleton_old_of_tube
    (wg w j : ℕ)
    (htube :
      ∀ t ∈ Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
        UTube r_LE_U (solMUReplStaticCfg w j)
          (((paper3HeadlineSolFam wg) w).u t)) :
    ∀ t ∈ Icc (selectorMUInterReadStart j) (selectorMUZOffStart j),
      ∀ v : UniversalLocalView,
        v ∉ ({localViewU (solMUReplStaticCfg w j)} :
          Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ ({localViewU (solMUReplStaticCfg w j)} :
          Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := by
  simpa using
    paper3Headline_pairwiseGap_of_single_tube
      (wg := wg) (w := w) (k := j)
      (a := selectorMUInterReadStart j) (b := selectorMUZOffStart j) htube

theorem paper3Headline_selectStart_floor_of_utube
    (wg w : ℕ)
    (hutube_win : ∀ j, ∀ t ∈ Set.Ico (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      UTube r_LE_U (solMUReplStaticCfg w j)
        (((paper3HeadlineSolFam wg) w).u t)) :
    ∀ j,
      1 / (Fintype.card UniversalLocalView : ℝ) ≤
        ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w j))
          (selectorMUSelectStartTime j) := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  let solFam := paper3HeadlineSolFam wg
  have hgap0 : 0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos :=
    solMURepl_static_hgap0 paper3HeadlineEta paper3HeadlineEta_pos paper3HeadlineHerr
  have hsum_forward := paper3Headline_lam_sum_forward wg w
  have hlam_forward := paper3Headline_lam_nonneg_forward wg w
  intro j
  have hgap_floor :
      ∀ v : UniversalLocalView, v ≠ localViewU (solMUReplStaticCfg w j) →
        ∀ u ∈ Ico (selectorMUWriteStartTime j) (selectorMUSelectStartTime j),
          universalPval paper3HeadlineEta paper3HeadlineEta_pos v ((solFam w).u u) -
            universalPval paper3HeadlineEta paper3HeadlineEta_pos
              (localViewU (solMUReplStaticCfg w j)) ((solFam w).u u) ≤ 0 := by
    intro v hv u hu
    have hgap_full :=
      selector_replicator_hgap_of_utube
        (sol := fun _ : ℕ => solFam w)
        (cfg := fun _ j => solMUReplStaticCfg w j)
        paper3HeadlineHerr
        (fun _ j t ht => hutube_win j t ht)
    have hu_full : u ∈ Ico (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j) :=
      ⟨hu.1, lt_of_lt_of_le hu.2 (selectorMUSelectStart_le_read j)⟩
    have hnonpos :
        -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos ≤ 0 :=
      neg_nonpos.mpr hgap0.le
    exact le_trans
      (by
        simpa using hgap_full 0 j v hv u hu_full)
      hnonpos
  have havg_gap :
      ∀ u ∈ Ico (selectorMUWriteStartTime j) (selectorMUSelectStartTime j),
        paper3RecoveryGap wg j *
            (1 - (solFam w).lam (localViewU (solMUReplStaticCfg w j)) u) ≤
          universalPval paper3HeadlineEta paper3HeadlineEta_pos
              (localViewU (solMUReplStaticCfg w j)) ((solFam w).u u) -
            ∑ v : UniversalLocalView,
              (solFam w).lam v u *
                universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                  ((solFam w).u u) := by
    intro u hu
    have hu_full : u ∈ Ico (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j) :=
      ⟨hu.1, lt_of_lt_of_le hu.2 (selectorMUSelectStart_le_read j)⟩
    exact
      selector_replicator_havg_gap_of_utube
        (eta := paper3HeadlineEta) (heta := paper3HeadlineEta_pos)
        (lam := fun v : UniversalLocalView => (solFam w).lam v u)
        (u := (solFam w).u u)
        (c := solMUReplStaticCfg w j)
        (gap := paper3RecoveryGap wg j)
        paper3HeadlineHerr
        (hutube_win j u hu_full)
        (paper3RecoveryGap_le_gapVal wg j)
        (hsum_forward u (le_trans (selectorMUWriteStartTime_nonneg j) hu.1))
        (fun v => hlam_forward v u
          (le_trans (selectorMUWriteStartTime_nonneg j) hu.1))
  exact
    replicator_winner_recovery_at_selectStart
      (sol := solFam w)
      (vstar := localViewU (solMUReplStaticCfg w j))
      (j := j)
      (crMin := paper3RecoveryCrMin wg j)
      (crMax := paper3RecoveryCrMax wg j)
      (cgMin := paper3RecoveryCgMin wg j)
      (gap := paper3RecoveryGap wg j)
      (b := paper3RecoveryB wg j)
      paper3HeadlineHCardTwo
      (paper3RecoveryCrMin_pos wg j)
      (paper3RecoveryCrMin_le_crMax wg j)
      (paper3RecoveryCgMin_nonneg wg j)
      (paper3RecoveryGap_nonneg wg j)
      (paper3RecoveryB_eq wg j)
      (paper3RecoveryB_pos wg j)
      (paper3RecoveryBDelta wg j)
      (paper3RecoveryPow wg j)
      (fun u hu => solMURepl_static_hdom_nonneg u
        (le_trans (selectorMUWriteStartTime_nonneg j) hu.1))
      (paper3RecoveryCrBounds wg j)
      (paper3RecoveryCgMinLe wg j)
      hgap_floor
      havg_gap
      (fun u hu => hsum_forward u
        (le_trans (selectorMUWriteStartTime_nonneg j) hu.1))
      (fun v u hu => hlam_forward v u
        (le_trans (selectorMUWriteStartTime_nonneg j) hu.1))

/-- Step 3 / F1: coupled prefix/tail analytic inputs for the concrete full
write-window `u`-tube.

The prefix and tail budgets cannot be proved independently: `u_drift_on_settled_window`
is additive, so the prefix weighted cap must reserve the settled-tail
`δuSettled` drift at `selectorMUWriteHoldTime`.  The initial weighted estimate is
also a boundary estimate at `selectorMUWriteStartTime 0`, not merely the time-zero
initial condition. -/
abbrev paper3F1Cfg (w : ℕ) : ℕ → UConf :=
  fun j => solMUReplStaticCfg w j

abbrev paper3F1Depth (w : ℕ) : ℕ → Fin d_U → ℤ :=
  MachineInstance.depthU (paper3F1Cfg w)

theorem paper3F1Depth_succ_le_inputLenU (w : ℕ) (i : Fin d_U) :
    ∀ j, (paper3F1Depth w (j + 1) i : ℝ) ≤
      (MachineInstance.inputLenU 1 w : ℝ) + (j : ℝ) := by
  intro j
  simpa [paper3F1Depth, paper3F1Cfg, solMUReplStaticCfg, MachineInstance.cU]
    using depthU_cU_succ_le_inputLenU_unconditional
      (C_U := 1) (by norm_num) w i j

theorem paper3F1Depth_zpow_succ_le_exp (w : ℕ) (i : Fin d_U) :
    ∀ j, (B_U : ℝ) ^ paper3F1Depth w (j + 1) i ≤
      Real.exp (Real.log (B_U : ℝ) *
          (MachineInstance.inputLenU 1 w : ℝ)) *
        Real.exp (Real.log (B_U : ℝ) * (j : ℝ)) := by
  intro j
  have hBpos : 0 < (B_U : ℝ) := by norm_num [B_U]
  have hBone : 1 ≤ (B_U : ℝ) := by norm_num [B_U]
  have hdepth := paper3F1Depth_succ_le_inputLenU w i j
  calc
    (B_U : ℝ) ^ paper3F1Depth w (j + 1) i
        = (B_U : ℝ) ^ ((paper3F1Depth w (j + 1) i : ℤ) : ℝ) := by
            rw [Real.rpow_intCast]
    _ ≤ (B_U : ℝ) ^
          ((MachineInstance.inputLenU 1 w : ℝ) + (j : ℝ)) := by
            exact Real.rpow_le_rpow_of_exponent_le hBone hdepth
    _ = Real.exp (Real.log (B_U : ℝ) *
          ((MachineInstance.inputLenU 1 w : ℝ) + (j : ℝ))) := by
            rw [Real.rpow_def_of_pos hBpos]
    _ = Real.exp (Real.log (B_U : ℝ) *
          (MachineInstance.inputLenU 1 w : ℝ)) *
        Real.exp (Real.log (B_U : ℝ) * (j : ℝ)) := by
            rw [← Real.exp_add]
            congr 1
            ring

theorem paper3F1Depth_growthRate_pos :
    0 < Real.log (B_U : ℝ) := by
  exact Real.log_pos (by norm_num [B_U] : (1 : ℝ) < (B_U : ℝ))

def paper3F1BoundaryErr (wg w : ℕ) (j : ℕ) (i : Fin d_U) : ℝ :=
  |((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i -
    stackMachineEncodingU.enc (paper3F1Cfg w j) i|

theorem paper3F1BoundaryErr_le_writeStart_zu_add_zerr
    (wg w : ℕ) (j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErr wg w j i ≤
      |((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i| +
      |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| := by
  have h := abs_sub_le
    (((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i)
    (((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i)
    (stackMachineEncodingU.enc (paper3F1Cfg w j) i)
  simpa [paper3F1BoundaryErr] using h

/-- Exact initial weighted boundary for the F1 prefix budget. -/
def paper3F1W0 (wg w : ℕ) : Fin d_U → ℝ :=
  fun i => (B_U : ℝ) ^ paper3F1Depth w 0 i * paper3F1BoundaryErr wg w 0 i

/-- Positive part of the exact one-step excess.  With this choice, the
`MURecur_repl` field is algebraic; the real work is proving this excess is
small enough for the coupled cap. -/
def paper3F1Eta (wg w : ℕ) : ℕ → Fin d_U → ℝ :=
  fun j i =>
    max (0 : ℝ)
      (paper3F1BoundaryErr wg w (j + 1) i -
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          paper3F1BoundaryErr wg w j i)

theorem paper3F1Eta_nonneg (wg w : ℕ) :
    ∀ j i, 0 ≤ paper3F1Eta wg w j i := by
  intro j i
  unfold paper3F1Eta
  exact le_max_left _ _

theorem paper3F1_weightedDefect_summable_of_eta_geometric
    (wg w : ℕ) (i : Fin d_U) {Cη lamη : ℝ}
    (hβlt : Real.log (B_U : ℝ) < lamη)
    (hηgeo : ∀ j, paper3F1Eta wg w j i ≤
      Cη * Real.exp (-lamη * (j : ℝ))) :
    Summable (fun j =>
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1Eta wg w) j i) := by
  refine weightedDefect_summable_of_parts (B_U : ℝ) (paper3F1Depth w)
    (paper3F1Eta wg w) i
    (Cdep := Real.exp (Real.log (B_U : ℝ) *
      (MachineInstance.inputLenU 1 w : ℝ)))
    (Cη := Cη) (β := Real.log (B_U : ℝ)) (lamη := lamη)
    ?_ hβlt ?_ ?_ ?_ hηgeo
  · exact (Real.exp_pos _).le
  · intro j
    exact zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _
  · exact paper3F1Depth_zpow_succ_le_exp w i
  · intro j
    exact paper3F1Eta_nonneg wg w j i

theorem paper3F1_weightedDefect_summable_of_eta_geometric_all
    (wg w : ℕ) {Cη lamη : Fin d_U → ℝ}
    (hβlt : ∀ i, Real.log (B_U : ℝ) < lamη i)
    (hηgeo : ∀ j i, paper3F1Eta wg w j i ≤
      Cη i * Real.exp (-(lamη i) * (j : ℝ))) :
    ∀ i, Summable (fun j =>
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1Eta wg w) j i) := by
  intro i
  exact paper3F1_weightedDefect_summable_of_eta_geometric
    wg w i (hβlt i) (fun j => hηgeo j i)

theorem paper3F1Eta_le_boundaryErr_succ (wg w : ℕ) :
    ∀ j i, paper3F1Eta wg w j i ≤ paper3F1BoundaryErr wg w (j + 1) i := by
  intro j i
  unfold paper3F1Eta
  refine max_le ?_ ?_
  · exact abs_nonneg _
  · have hpow_nonneg :
        0 ≤ (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i :=
      zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _
    have herr_nonneg : 0 ≤ paper3F1BoundaryErr wg w j i := abs_nonneg _
    nlinarith [mul_nonneg hpow_nonneg herr_nonneg]

theorem paper3F1Eta_le_next_writeStart_zu_add_zerr (wg w : ℕ) :
    ∀ j i, paper3F1Eta wg w j i ≤
      |((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime (j + 1)) i -
        ((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime (j + 1)) i| +
      |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime (j + 1)) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| := by
  intro j i
  exact le_trans (paper3F1Eta_le_boundaryErr_succ wg w j i)
    (paper3F1BoundaryErr_le_writeStart_zu_add_zerr wg w (j + 1) i)

theorem paper3F1Eta_geometric_of_writeStart_succ_endpoint_errors
    (wg w : ℕ) {Czu Cz lam : Fin d_U → ℝ}
    (hzu_geo : ∀ j i,
      |((paper3HeadlineSolFam wg) w).u
          (selectorMUWriteStartTime (j + 1)) i -
        ((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| ≤
        Czu i * Real.exp (-(lam i) * (j : ℝ)))
    (hzerr_geo : ∀ j i,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
        Cz i * Real.exp (-(lam i) * (j : ℝ))) :
    ∀ j i, paper3F1Eta wg w j i ≤
      (Czu i + Cz i) * Real.exp (-(lam i) * (j : ℝ)) := by
  intro j i
  have hη := paper3F1Eta_le_next_writeStart_zu_add_zerr wg w j i
  have hend := add_le_add (hzu_geo j i) (hzerr_geo j i)
  calc
    paper3F1Eta wg w j i
        ≤ |((paper3HeadlineSolFam wg) w).u
              (selectorMUWriteStartTime (j + 1)) i -
            ((paper3HeadlineSolFam wg) w).z
              (selectorMUWriteStartTime (j + 1)) i| +
          |((paper3HeadlineSolFam wg) w).z
              (selectorMUWriteStartTime (j + 1)) i -
            stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| := hη
    _ ≤ Czu i * Real.exp (-(lam i) * (j : ℝ)) +
          Cz i * Real.exp (-(lam i) * (j : ℝ)) := hend
    _ = (Czu i + Cz i) * Real.exp (-(lam i) * (j : ℝ)) := by
          ring

theorem paper3F1_weightedDefect_summable_of_writeStart_succ_endpoint_geometric
    (wg w : ℕ) {Czu Cz lam : Fin d_U → ℝ}
    (hβlt : ∀ i, Real.log (B_U : ℝ) < lam i)
    (hzu_geo : ∀ j i,
      |((paper3HeadlineSolFam wg) w).u
          (selectorMUWriteStartTime (j + 1)) i -
        ((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| ≤
        Czu i * Real.exp (-(lam i) * (j : ℝ)))
    (hzerr_geo : ∀ j i,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
        Cz i * Real.exp (-(lam i) * (j : ℝ))) :
    ∀ i, Summable (fun j =>
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1Eta wg w) j i) := by
  exact paper3F1_weightedDefect_summable_of_eta_geometric_all
    (Cη := fun i => Czu i + Cz i) (lamη := lam)
    wg w hβlt
    (paper3F1Eta_geometric_of_writeStart_succ_endpoint_errors
      wg w hzu_geo hzerr_geo)

/-- **Primitive multiplier-step input for the F1 weighted defect.**

This replaces the retired `Paper3F1EndpointGeometricInputs` package, whose
`hzerr_geo` field (`|z(ws(j+1)) - enc(cfg(j+1))| ≤ Cz·e^{-lam·j}`) is not
derivable — and is quantitatively false as a route: the branch family
`branchU` gives each local view *its own* machine step's action
(`branchActionForCoordU`), so on a coordinate where the winner's action is
`stay` the loser views still push/pop or write different constants.  The
settled write target `mixTarget` therefore sits at distance
`≈ Rspread·epsLam(j)` from `enc(cfg(j+1))` every cycle, and the boundary error
converges to the *accumulated* loser drift `Σ_j epsLam(j)·O(1)` — a generally
nonzero limit.  Only the per-cycle **increment** decays, not the error itself.

The correct primitive is the raw one-cycle multiplier step

  `BErr(j+1,i) ≤ mult(j,i) · BErr(j,i) + src(j,i)`,

with the branch diagonal multiplier absorbed by the coarse stack delta
(`mult(j,i) ≤ B_U^{delta(j,i)}` — the `branchU` contract: pop ≤ `B_U = k^1`,
push `= 1/B_U = k^{-1}`, stay/replace ≤ `1 = k^0`) and a source `src`
collecting only the genuinely decaying terms: the loser-mass mixture radius
`Rspread·epsLam(j)`, the settled/early write contraction residuals, the
multiplier times the intra-window `u`-drift, and the `z-u` endpoint transport.
The positive-part excess `paper3F1Eta` then discards the entire comparison
term (`paper3F1Eta_le_src_of_multiplier_step` below — this is
`DirectTrackingInduction.trackingExcess_le_source_of_multiplier_step` in the
`trackingErr` language), so the geometric requirement falls on `src` alone,
which decays at rate `lam = 2 > log B_U = log 6`
(`WriteHoldRecurrence.log_B_U_lt_two`).  The bounded-tube contribution
`mult·ρu` never has to decay. -/
structure Paper3F1MultiplierStepInputs (wg w : ℕ) where
  mult : ℕ → Fin d_U → ℝ
  src : ℕ → Fin d_U → ℝ
  Csrc : Fin d_U → ℝ
  lam : Fin d_U → ℝ
  hβlt : ∀ i, Real.log (B_U : ℝ) < lam i
  hsrc_nonneg : ∀ j i, 0 ≤ src j i
  hmult_le : ∀ j i,
    mult j i ≤ (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i
  hraw : ∀ j i,
    paper3F1BoundaryErr wg w (j + 1) i ≤
      mult j i * paper3F1BoundaryErr wg w j i + src j i
  hsrc_geo : ∀ j i, src j i ≤ Csrc i * Real.exp (-(lam i) * (j : ℝ))
  /- Uniform all-cycle write-window `z-u` envelope: one constant bounding
  `|z-u|` on every full write window `[ws j, wr j]` (covering both the
  prefix `[ws j, wh j]` and the settled tail `[wh j, wr j]`).  Discharge
  shares the producers of `hraw`: the endpoint `|z-u|` at `ws (j+1)` is
  geometric at rate `2`
  (`WriteHoldRecurrence.writeStart_zu_geometric_of_transport` — a merely
  bounded read-time `|z-u|` box suffices, the inter-read u-active kernel
  mass supplies the geometric factor), and inside each window the qPulse
  off-phase relaxation keeps `|z-u|` within endpoint value plus intra-window
  increment; a geometric endpoint sequence plus uniformly controlled window
  increments has a finite supremum over all cycles
  (`CoupledEndpointDecay.exists_bound_of_tendsto_zero_nonneg` shape).  Note
  the window `|z-u|` itself need not (and does not) tend to `0` — during the
  write the `z` channel jumps to the next target while `u` is gate-frozen —
  only *boundedness* is asserted. -/
  Cwin : ℝ
  hCwin0 : 0 ≤ Cwin
  hzu_win : ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
    |((paper3HeadlineSolFam wg) w).z t i -
      ((paper3HeadlineSolFam wg) w).u t i| ≤ Cwin
  /- The irreducible quantitative F1 budget: the total weighted budget
  `W0 + Σ' weightedDefect` leaves the cycle-`0` prefix and settled reserves
  of the window envelope inside `r_LE_U`.  Route: with `Csrc`, `lam = 2` the
  tail sum has the closed geometric cap
  `∑' weightedDefect ≤ e^{log B_U·(|w|+1)}·Csrc/(1 - e^{log B_U - 2})`
  (`DirectTrackingInduction.weightedMajorant_le_geomCap` shape, via
  `paper3F1Depth_zpow_succ_le_exp`), so it suffices that
  `W0 i + cap ≤ r_LE_U - δuWritePrefix Cwin 0 - δuSettled Cwin 0` — a
  numeric inequality once `W0` (the cycle-0 boundary error) and `Csrc` are
  made quantitative.  The reserve terms are tiny
  (`δu· ≈ Cwin·(π/3)·e^{-450·π/6}`), so this is essentially
  `W0 + cap ≤ r_LE_U - o(1)`.  Only the cycle-`0` reserves are asked for:
  the cycle-`j` reserves follow by monotonicity
  (`paper3F1_uniform_budget_reserve_of_global_zu`). -/
  hbudget : ∀ i,
    paper3F1W0 wg w i +
        ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
          (paper3F1Eta wg w) m i ≤
      r_LE_U - δuWritePrefix Cwin 0 - δuSettled Cwin 0

/-- **The excess is bounded by the source alone.**  Under the raw multiplier
step with `mult ≤ B_U^delta`, the positive-part excess `paper3F1Eta` discards
the whole comparison term: the (non-decaying) boundary error only ever enters
through `mult·BErr(j) ≤ B_U^delta·BErr(j)`, which the `max` absorbs.  This is
the `HeadlineUnconditional` instance of
`DirectTrackingInduction.trackingExcess_le_source_of_multiplier_step`. -/
theorem paper3F1Eta_le_src_of_multiplier_step
    (wg w : ℕ) (H : Paper3F1MultiplierStepInputs wg w) :
    ∀ j i, paper3F1Eta wg w j i ≤ H.src j i := by
  intro j i
  have herr_nonneg : 0 ≤ paper3F1BoundaryErr wg w j i := abs_nonneg _
  have hcmp :
      H.mult j i * paper3F1BoundaryErr wg w j i ≤
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          paper3F1BoundaryErr wg w j i :=
    mul_le_mul_of_nonneg_right (H.hmult_le j i) herr_nonneg
  have hraw := H.hraw j i
  unfold paper3F1Eta
  refine max_le (H.hsrc_nonneg j i) ?_
  linarith

/-- Geometric envelope for the excess out of the multiplier-step inputs. -/
theorem paper3F1Eta_geometric_of_multiplier_step
    (wg w : ℕ) (H : Paper3F1MultiplierStepInputs wg w) :
    ∀ j i, paper3F1Eta wg w j i ≤
      H.Csrc i * Real.exp (-(H.lam i) * (j : ℝ)) := by
  intro j i
  exact (paper3F1Eta_le_src_of_multiplier_step wg w H j i).trans
    (H.hsrc_geo j i)

/-- Weighted-defect summability from the multiplier-step inputs: the excess is
dominated by the geometric source, whose rate beats the depth weight. -/
theorem paper3F1_weightedDefect_summable_of_multiplier_step
    (wg w : ℕ) (H : Paper3F1MultiplierStepInputs wg w) :
    ∀ i, Summable (fun j =>
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1Eta wg w) j i) :=
  paper3F1_weightedDefect_summable_of_eta_geometric_all
    (Cη := H.Csrc) (lamη := H.lam) wg w H.hβlt
    (paper3F1Eta_geometric_of_multiplier_step wg w H)

/- `paper3F1_multiplier_step_inputs` is proved further below (after the
finite-horizon tail/prefix producers), by reduction to the single
tube-conditional analytic core `Paper3F1ConditionalStepCore`: the
circularity-breaking normalized weighted induction and the closed geometric
cap on the weighted-defect tail are discharged there; only the conditional
per-cycle window estimates and the quantitative cycle-`0` budget remain. -/

theorem paper3F1Eta_tendsto_zero_of_boundaryErr_succ
    (wg w : ℕ)
    (hboundary :
      ∀ i, Tendsto (fun j => paper3F1BoundaryErr wg w (j + 1) i) atTop (𝓝 0)) :
    ∀ i, Tendsto (fun j => paper3F1Eta wg w j i) atTop (𝓝 0) := by
  intro i
  exact squeeze_zero
    (fun j => paper3F1Eta_nonneg wg w j i)
    (fun j => paper3F1Eta_le_boundaryErr_succ wg w j i)
    (hboundary i)

theorem paper3F1Eta_tendsto_zero_of_excess_tendsto_zero
    (wg w : ℕ) (i : Fin d_U)
    (h : Tendsto
      (fun j : ℕ =>
        paper3F1BoundaryErr wg w (j + 1) i -
          (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
            paper3F1BoundaryErr wg w j i)
      atTop (𝓝 0)) :
    Tendsto (fun j : ℕ => paper3F1Eta wg w j i) atTop (𝓝 0) := by
  have h0 : Tendsto (fun _ : ℕ => (0 : ℝ)) atTop (𝓝 (0 : ℝ)) :=
    tendsto_const_nhds
  have hmax := h0.max h
  simpa [paper3F1Eta] using hmax

theorem paper3F1Eta_tendsto_zero_of_eventual_le
    (wg w : ℕ) (i : Fin d_U) (ζ : ℕ → ℝ)
    (hζ : Tendsto ζ atTop (𝓝 0))
    (hη_le : ∀ᶠ j in atTop, paper3F1Eta wg w j i ≤ ζ j) :
    Tendsto (fun j : ℕ => paper3F1Eta wg w j i) atTop (𝓝 0) := by
  have hη_nonneg : ∀ᶠ j in atTop, 0 ≤ paper3F1Eta wg w j i :=
    Filter.Eventually.of_forall (fun j => paper3F1Eta_nonneg wg w j i)
  exact squeeze_zero' hη_nonneg hη_le hζ

theorem paper3F1Eta_tendsto_zero_of_writeStart_succ_zu_and_zerr
    (wg w : ℕ) (i : Fin d_U)
    (hzu : Tendsto
      (fun j : ℕ =>
        |((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime (j + 1)) i -
          ((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime (j + 1)) i|)
      atTop (𝓝 0))
    (hz : Tendsto
      (fun j : ℕ =>
        |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime (j + 1)) i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i|)
      atTop (𝓝 0)) :
    Tendsto (fun j : ℕ => paper3F1Eta wg w j i) atTop (𝓝 0) := by
  let ζ : ℕ → ℝ := fun j =>
    |((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime (j + 1)) i -
      ((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime (j + 1)) i| +
    |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime (j + 1)) i -
      stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i|
  have hζ : Tendsto ζ atTop (𝓝 0) := by
    simpa [ζ] using hzu.add hz
  refine paper3F1Eta_tendsto_zero_of_eventual_le wg w i ζ hζ ?_
  exact Filter.Eventually.of_forall
    (fun j => paper3F1Eta_le_next_writeStart_zu_add_zerr wg w j i)

theorem paper3F1Eta_tendsto_zero_of_writeStart_succ_endpoint_errors
    (wg w : ℕ)
    (hzu : ∀ i : Fin d_U, Tendsto
      (fun j : ℕ =>
        |((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime (j + 1)) i -
          ((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime (j + 1)) i|)
      atTop (𝓝 0))
    (hz : ∀ i : Fin d_U, Tendsto
      (fun j : ℕ =>
        |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime (j + 1)) i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i|)
      atTop (𝓝 0)) :
    ∀ i : Fin d_U, Tendsto (fun j : ℕ => paper3F1Eta wg w j i) atTop (𝓝 0) := by
  intro i
  exact paper3F1Eta_tendsto_zero_of_writeStart_succ_zu_and_zerr
    wg w i (hzu i) (hz i)

theorem paper3F1_hinit (wg w : ℕ) :
    MUWeighted_repl ((paper3HeadlineSolFam wg) w)
      (fun j => stackMachineEncodingU.enc (paper3F1Cfg w j))
      (B_U : ℝ) (paper3F1Depth w)
      (selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
        (paper3F1Eta wg w)) 0 := by
  intro i
  simp [muBoundaryError_repl, selectorMUWriteStartTime, selectorMUWboundPrefix,
    WboundPrefix, paper3F1W0, paper3F1BoundaryErr, paper3F1Depth]

theorem paper3F1_hrecur (wg w : ℕ) :
    ∀ j,
      MUWeighted_repl ((paper3HeadlineSolFam wg) w)
        (fun j => stackMachineEncodingU.enc (paper3F1Cfg w j))
        (B_U : ℝ) (paper3F1Depth w)
        (selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
          (paper3F1Eta wg w)) j →
      MURecur_repl ((paper3HeadlineSolFam wg) w)
        (fun j => stackMachineEncodingU.enc (paper3F1Cfg w j))
        (B_U : ℝ) (selectorMUCoarseDelta (paper3F1Cfg w))
        (paper3F1Eta wg w) j := by
  intro j _hw i
  have hmax :
      paper3F1BoundaryErr wg w (j + 1) i -
          (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
            paper3F1BoundaryErr wg w j i ≤
        paper3F1Eta wg w j i := by
    unfold paper3F1Eta
    exact le_max_right _ _
  have hle :
      paper3F1BoundaryErr wg w (j + 1) i ≤
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          paper3F1BoundaryErr wg w j i + paper3F1Eta wg w j i := by
    linarith
  simpa [MURecur_repl, muBoundaryError_repl, selectorMUWriteStartTime,
    paper3F1BoundaryErr, paper3F1Cfg] using hle

theorem selectorMUWriteHoldTime_nonneg (j : ℕ) :
    0 ≤ selectorMUWriteHoldTime j :=
  le_trans (selectorMUWriteStartTime_nonneg j) (selectorMUWriteStart_le_hold j)

def paper3F1TailHorizon (j : ℕ) : ℝ :=
  selectorMUWriteReadTime j + 1

theorem paper3F1TailHorizon_pos (j : ℕ) :
    0 < paper3F1TailHorizon j := by
  have hread0 : 0 ≤ selectorMUWriteReadTime j :=
    le_trans (selectorMUWriteStartTime_nonneg j) (selectorMUWriteStart_le_read j)
  unfold paper3F1TailHorizon
  linarith

noncomputable def paper3F1TailM (wg w j : ℕ) : ℝ :=
  Classical.choose
    (paper3HeadlineSolFam_ZUFiniteCoordBound wg w
      (paper3F1TailHorizon j) (paper3F1TailHorizon_pos j))

theorem paper3F1TailM_spec (wg w j : ℕ) :
    0 < paper3F1TailM wg w j ∧
      ∀ t ∈ Ico (0 : ℝ) (paper3F1TailHorizon j), ∀ i : Fin d_U,
        |((paper3HeadlineSolFam wg) w).z t i| ≤ paper3F1TailM wg w j ∧
          |((paper3HeadlineSolFam wg) w).u t i| ≤ paper3F1TailM wg w j := by
  unfold paper3F1TailM
  exact
    Classical.choose_spec
      (paper3HeadlineSolFam_ZUFiniteCoordBound wg w
        (paper3F1TailHorizon j) (paper3F1TailHorizon_pos j))

/-- First useful F1 field producer: on each settled tail window, the existing
finite-horizon z/u coordinate bound gives a noncomputable all-coordinate
`|z-u|` envelope.  This does not use the downstream full `u`-tube. -/
theorem paper3HeadlineF1_tail_zu_bound (wg w : ℕ) :
    ∃ Bzu : ℕ → ℝ,
      (∀ j, 0 ≤ Bzu j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteHoldTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤ Bzu j) := by
  refine ⟨fun j => 2 * paper3F1TailM wg w j, ?_, ?_⟩
  · intro j
    have hM := (paper3F1TailM_spec wg w j).1
    linarith
  · intro j i t ht
    have hspec := (paper3F1TailM_spec wg w j).2
    have ht0 : 0 ≤ t := le_trans (selectorMUWriteHoldTime_nonneg j) ht.1
    have htT : t < paper3F1TailHorizon j := by
      unfold paper3F1TailHorizon
      linarith [ht.2]
    have hz := (hspec t ⟨ht0, htT⟩ i).1
    have hu := (hspec t ⟨ht0, htT⟩ i).2
    have htri :
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤
          |((paper3HeadlineSolFam wg) w).z t i| +
            |((paper3HeadlineSolFam wg) w).u t i| := by
      have h := abs_sub_le
        (((paper3HeadlineSolFam wg) w).z t i) 0
        (((paper3HeadlineSolFam wg) w).u t i)
      simpa using h
    linarith

/-- Settled-tail `u` drift obtained from the finite settled-tail `|z-u|`
envelope.  This gives the j-dependent tail reserve used by the coupled cap. -/
theorem paper3HeadlineF1_tail_u_drift_bound (wg w : ℕ) :
    ∃ Bzu : ℕ → ℝ,
      (∀ j, 0 ≤ Bzu j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteHoldTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤ Bzu j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteHoldTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFam wg) w).u t i -
          ((paper3HeadlineSolFam wg) w).u (selectorMUWriteHoldTime j) i| ≤
            δuSettled (Bzu j) j) := by
  rcases paper3HeadlineF1_tail_zu_bound wg w with ⟨Bzu, hBzu0, hzu⟩
  refine ⟨Bzu, hBzu0, hzu, ?_⟩
  intro j i t ht
  exact
    u_drift_on_settled_window
      ((paper3HeadlineSolFam wg) w) j i (hBzu0 j)
      selectorSchedule_domain_of_nonneg_structural
      (hzu j i) t ht

/-- Prefix-window finite `|z-u|` envelope.  This is the source needed to
instantiate the prefix `u`-drift lemma; it is finite-horizon only and does not
assert the eventual boundedness needed for the final F1 cap. -/
theorem paper3HeadlineF1_prefix_zu_bound (wg w : ℕ) :
    ∃ Bpre : ℕ → ℝ,
      (∀ j, 0 ≤ Bpre j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteHoldTime j),
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤ Bpre j) := by
  refine ⟨fun j => 2 * paper3F1TailM wg w j, ?_, ?_⟩
  · intro j
    have hM := (paper3F1TailM_spec wg w j).1
    linarith
  · intro j i t ht
    have hspec := (paper3F1TailM_spec wg w j).2
    have ht0 : 0 ≤ t := le_trans (selectorMUWriteStartTime_nonneg j) ht.1
    have htT : t < paper3F1TailHorizon j := by
      unfold paper3F1TailHorizon
      have hhold_read : selectorMUWriteHoldTime j ≤ selectorMUWriteReadTime j :=
        selectorMUWriteHold_le_read j
      linarith [ht.2, hhold_read]
    have hz := (hspec t ⟨ht0, htT⟩ i).1
    have hu := (hspec t ⟨ht0, htT⟩ i).2
    have htri :
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤
          |((paper3HeadlineSolFam wg) w).z t i| +
            |((paper3HeadlineSolFam wg) w).u t i| := by
      have h := abs_sub_le
        (((paper3HeadlineSolFam wg) w).z t i) 0
        (((paper3HeadlineSolFam wg) w).u t i)
      simpa using h
    linarith

/-- Prefix-window `u` drift obtained from the finite prefix `|z-u|` envelope.
The bound is j-dependent; a final F1 `εhold` still needs a uniform/asymptotic
control theorem for this envelope. -/
theorem paper3HeadlineF1_prefix_u_drift_bound (wg w : ℕ) :
    ∃ Bpre : ℕ → ℝ,
      (∀ j, 0 ≤ Bpre j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteHoldTime j),
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤ Bpre j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteHoldTime j),
        |((paper3HeadlineSolFam wg) w).u t i -
          ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤
            δuWritePrefix (Bpre j) j) := by
  rcases paper3HeadlineF1_prefix_zu_bound wg w with ⟨Bpre, hBpre0, hzu⟩
  refine ⟨Bpre, hBpre0, hzu, ?_⟩
  intro j i t ht
  exact
    u_drift_on_write_prefix_window
      ((paper3HeadlineSolFam wg) w) j i (hBpre0 j)
      selectorSchedule_domain_of_nonneg_structural
      (hzu j i) t ht

theorem paper3F1_hhold_of_uniform_prefix_zu
    (wg w : ℕ) {Czu : ℝ} (hCzu0 : 0 ≤ Czu)
    (hzu : ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteHoldTime j),
      |((paper3HeadlineSolFam wg) w).z t i -
        ((paper3HeadlineSolFam wg) w).u t i| ≤ Czu) :
    ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteHoldTime j),
      |((paper3HeadlineSolFam wg) w).u t i -
        ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤
          δuWritePrefix Czu 0 := by
  intro j i t ht
  have hdrift :=
    u_drift_on_write_prefix_window
      ((paper3HeadlineSolFam wg) w) j i hCzu0
      selectorSchedule_domain_of_nonneg_structural (hzu j i) t ht
  have hstart0 : selectorMUWriteStartTime 0 ≤ selectorMUWriteStartTime j := by
    unfold selectorMUWriteStartTime
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith [Real.pi_pos, hj]
  have hscaled :
      selectorUSettledRate * selectorMUWriteStartTime 0 ≤
        selectorUSettledRate * selectorMUWriteStartTime j :=
    mul_le_mul_of_nonneg_left hstart0 selectorUSettledRate_pos.le
  have hexp :
      Real.exp (-(selectorUSettledRate * selectorMUWriteStartTime j)) ≤
        Real.exp (-(selectorUSettledRate * selectorMUWriteStartTime 0)) :=
    Real.exp_le_exp.mpr (by linarith)
  have hdelta :
      δuWritePrefix Czu j ≤ δuWritePrefix Czu 0 := by
    dsimp [δuWritePrefix]
    have hcoef : 0 ≤ Czu * (Real.pi / 3) :=
      mul_nonneg hCzu0 (by positivity)
    nlinarith [mul_le_mul_of_nonneg_left hexp hcoef]
  exact hdrift.trans hdelta

theorem paper3F1_hhold_of_bounded_prefix_zu
    (wg w : ℕ) (Bpre : ℕ → ℝ) {Czu : ℝ}
    (hCzu0 : 0 ≤ Czu)
    (hBpre_le : ∀ j, Bpre j ≤ Czu)
    (hzu : ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteHoldTime j),
      |((paper3HeadlineSolFam wg) w).z t i -
        ((paper3HeadlineSolFam wg) w).u t i| ≤ Bpre j) :
    ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteHoldTime j),
      |((paper3HeadlineSolFam wg) w).u t i -
        ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤
          δuWritePrefix Czu 0 := by
  refine paper3F1_hhold_of_uniform_prefix_zu wg w hCzu0 ?_
  intro j i t ht
  exact (hzu j i t ht).trans (hBpre_le j)

/-- Remaining F1 analytic surface after fixing the initial boundary budget and
one-step excess canonically. -/
structure Paper3HeadlineF1CanonicalWordAnalyticResidual (wg w : ℕ) where
  εhold : ℝ
  Bzu : ℕ → ℝ
  hη_tendsto_zero : ∀ i, Tendsto (fun j => paper3F1Eta wg w j i) atTop (𝓝 0)
  hhold : ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteHoldTime j),
    |((paper3HeadlineSolFam wg) w).u t i -
      ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤ εhold
  hBzu0 : ∀ j, 0 ≤ Bzu j
  hzu_tail : ∀ j i, ∀ t ∈ Icc (selectorMUWriteHoldTime j)
      (selectorMUWriteReadTime j),
    |((paper3HeadlineSolFam wg) w).z t i -
      ((paper3HeadlineSolFam wg) w).u t i| ≤ Bzu j
  hcap_tail : ∀ j i,
    selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
        (paper3F1Eta wg w) j i ≤
      (r_LE_U - εhold - δuSettled (Bzu j) j) *
        (B_U : ℝ) ^ paper3F1Depth w j i

/-- Diagonal F1 residual: the headline only consumes the word whose warm-gain
index is the same word. -/
abbrev Paper3HeadlineF1CanonicalWordAnalyticResidualDiag (wg : ℕ) :=
  Paper3HeadlineF1CanonicalWordAnalyticResidual wg wg

theorem paper3F1_hcap_tail_of_normalized
    (wg w : ℕ) (εhold : ℝ) (Bzu : ℕ → ℝ)
    (hnorm : ∀ j i,
      selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
          (paper3F1Eta wg w) j i /
        (B_U : ℝ) ^ paper3F1Depth w j i ≤
          r_LE_U - εhold - δuSettled (Bzu j) j) :
    ∀ j i,
      selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
          (paper3F1Eta wg w) j i ≤
        (r_LE_U - εhold - δuSettled (Bzu j) j) *
          (B_U : ℝ) ^ paper3F1Depth w j i := by
  intro j i
  have hpow_pos : 0 < (B_U : ℝ) ^ paper3F1Depth w j i :=
    zpow_pos (by norm_num [B_U] : (0 : ℝ) < (B_U : ℝ)) _
  exact (div_le_iff₀ hpow_pos).mp (hnorm j i)

theorem paper3F1_weightedDefect_nonneg (wg w : ℕ) :
    ∀ i m,
      0 ≤ weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1Eta wg w) m i := by
  intro i m
  unfold weightedDefect
  exact mul_nonneg
    (zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _)
    (paper3F1Eta_nonneg wg w m i)

theorem paper3F1Eta_le_weightedDefect (wg w : ℕ) :
    ∀ j i, paper3F1Eta wg w j i ≤
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1Eta wg w) j i := by
  intro j i
  have hη0 : 0 ≤ paper3F1Eta wg w j i :=
    paper3F1Eta_nonneg wg w j i
  have hdepth_nonneg : 0 ≤ paper3F1Depth w (j + 1) i := by
    simpa [paper3F1Depth] using
      selectorMU_depthU_nonneg (paper3F1Cfg w) (j + 1) i
  have hpow_ge_one :
      (1 : ℝ) ≤ (B_U : ℝ) ^ paper3F1Depth w (j + 1) i :=
    (one_le_zpow_iff_right₀
      (by norm_num [B_U] : (1 : ℝ) < (B_U : ℝ))).mpr hdepth_nonneg
  have hmul :=
    mul_le_mul_of_nonneg_right hpow_ge_one hη0
  simpa [weightedDefect, one_mul] using hmul

theorem paper3F1Eta_tendsto_zero_of_weightedDefect_summable
    (wg w : ℕ)
    (hTsum : ∀ i,
      Summable (fun m =>
        weightedDefect (B_U : ℝ) (paper3F1Depth w)
          (paper3F1Eta wg w) m i)) :
    ∀ i, Tendsto (fun j => paper3F1Eta wg w j i) atTop (𝓝 0) := by
  intro i
  have hdefect :
      Tendsto
        (fun j =>
          weightedDefect (B_U : ℝ) (paper3F1Depth w)
            (paper3F1Eta wg w) j i) atTop (𝓝 0) :=
    (hTsum i).tendsto_atTop_zero
  exact squeeze_zero
    (fun j => paper3F1Eta_nonneg wg w j i)
    (fun j => paper3F1Eta_le_weightedDefect wg w j i)
    hdefect

theorem paper3F1_hcap_tail_of_tsum_cap
    (wg w : ℕ) (εhold : ℝ) (Bzu : ℕ → ℝ)
    (hTsum : ∀ i,
      Summable (fun m =>
        weightedDefect (B_U : ℝ) (paper3F1Depth w)
          (paper3F1Eta wg w) m i))
    (hcap_tsum : ∀ j i,
      paper3F1W0 wg w i +
          ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
            (paper3F1Eta wg w) m i ≤
        (r_LE_U - εhold - δuSettled (Bzu j) j) *
          (B_U : ℝ) ^ paper3F1Depth w j i) :
    ∀ j i,
      selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
          (paper3F1Eta wg w) j i ≤
        (r_LE_U - εhold - δuSettled (Bzu j) j) *
          (B_U : ℝ) ^ paper3F1Depth w j i := by
  intro j i
  have hprefix :=
    WboundPrefix_le_cap (paper3F1W0 wg w) (B_U : ℝ)
      (paper3F1Depth w) (paper3F1Eta wg w) i
      (paper3F1_weightedDefect_nonneg wg w i) (hTsum i) j
  have hprefix' :
      selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
          (paper3F1Eta wg w) j i ≤
        paper3F1W0 wg w i +
          ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
            (paper3F1Eta wg w) m i := by
    simpa [selectorMUWboundPrefix] using hprefix
  exact hprefix'.trans (hcap_tsum j i)

theorem paper3F1_hcap_tail_of_tsum_normalized
    (wg w : ℕ) (εhold : ℝ) (Bzu : ℕ → ℝ)
    (hTsum : ∀ i,
      Summable (fun m =>
        weightedDefect (B_U : ℝ) (paper3F1Depth w)
          (paper3F1Eta wg w) m i))
    (hnorm_tsum : ∀ j i,
      (paper3F1W0 wg w i +
            ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
              (paper3F1Eta wg w) m i) /
          (B_U : ℝ) ^ paper3F1Depth w j i ≤
        r_LE_U - εhold - δuSettled (Bzu j) j) :
    ∀ j i,
      selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
          (paper3F1Eta wg w) j i ≤
        (r_LE_U - εhold - δuSettled (Bzu j) j) *
          (B_U : ℝ) ^ paper3F1Depth w j i := by
  refine paper3F1_hcap_tail_of_normalized wg w εhold Bzu ?_
  intro j i
  have hprefix :=
    WboundPrefix_le_cap (paper3F1W0 wg w) (B_U : ℝ)
      (paper3F1Depth w) (paper3F1Eta wg w) i
      (paper3F1_weightedDefect_nonneg wg w i) (hTsum i) j
  have hpow_pos : 0 < (B_U : ℝ) ^ paper3F1Depth w j i :=
    zpow_pos (by norm_num [B_U] : (0 : ℝ) < (B_U : ℝ)) _
  have hdiv :
      selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
          (paper3F1Eta wg w) j i /
          (B_U : ℝ) ^ paper3F1Depth w j i ≤
        (paper3F1W0 wg w i +
            ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
              (paper3F1Eta wg w) m i) /
          (B_U : ℝ) ^ paper3F1Depth w j i := by
    exact div_le_div_of_nonneg_right
      (by simpa [selectorMUWboundPrefix] using hprefix) hpow_pos.le
  exact hdiv.trans (hnorm_tsum j i)

theorem paper3F1_hcap_tail_of_eta_geometric_tsum_normalized
    (wg w : ℕ) (εhold : ℝ) (Bzu : ℕ → ℝ)
    {Cη lamη : Fin d_U → ℝ}
    (hβlt : ∀ i, Real.log (B_U : ℝ) < lamη i)
    (hηgeo : ∀ j i, paper3F1Eta wg w j i ≤
      Cη i * Real.exp (-(lamη i) * (j : ℝ)))
    (hnorm_tsum : ∀ j i,
      (paper3F1W0 wg w i +
            ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
              (paper3F1Eta wg w) m i) /
          (B_U : ℝ) ^ paper3F1Depth w j i ≤
        r_LE_U - εhold - δuSettled (Bzu j) j) :
    ∀ j i,
      selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
          (paper3F1Eta wg w) j i ≤
        (r_LE_U - εhold - δuSettled (Bzu j) j) *
          (B_U : ℝ) ^ paper3F1Depth w j i := by
  exact paper3F1_hcap_tail_of_tsum_normalized wg w εhold Bzu
    (paper3F1_weightedDefect_summable_of_eta_geometric_all
      wg w hβlt hηgeo)
