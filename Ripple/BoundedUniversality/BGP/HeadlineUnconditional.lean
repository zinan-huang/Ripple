    paper3S13crF_continuous hGder hBder
  intro t ht
  have hduh_t := hduh t ht
  have hsrc := (forward_reset_integral_mul_decay_le
    (a := a) (b := t)
    (gap := selectorReplicatorGapVal paper3HeadlineEta
