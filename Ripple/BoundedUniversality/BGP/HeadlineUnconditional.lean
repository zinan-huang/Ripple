box, and recovery hypotheses.

This bypasses the full cycle invariant and carries only the actual analytic
data consumed by `muReplicatorLateStartHaltFactsAt_shifted`: the write-window
`UTube`, the off-field self-hold integral, and the next-write window estimate.
-/
theorem paper3_headline_unconditional_of_utube_hoff_nextWrite
    (hutube_win : ∀ wg j, ∀ t ∈ Set.Ico (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      UTube r_LE_U (solMUReplStaticCfg wg j)
        (((paper3HeadlineSolFam wg) wg).u t))
    (p_hoff : ∀ wg j, selectorMUHaltEncConst (solMUReplStaticCfg wg) j →
      ∀ t ∈ Icc (selectorMUInterReadStart j) (selectorMUNextWriteStart j),
        |((paper3HeadlineSolFam wg) wg).z t haltCoordU -
          ((paper3HeadlineSolFam wg) wg).z
            (selectorMUInterReadStart j) haltCoordU| ≤
          selectorReplicatorHoldEnvelope j)
    (δnext : ℕ → ℕ → ℝ)
    (hδnext : ∀ wg, Tendsto (δnext wg) atTop (𝓝 0))
    (hδnext_nonneg : ∀ wg j, 0 ≤ δnext wg j)
    (hnextWrite : ∀ wg j, ∀ t ∈ Icc (selectorMUNextWriteStart j)
        (selectorMUNextRead j),
      |((paper3HeadlineSolFam wg) wg).z t haltCoordU -
        stackMachineEncodingU.enc (solMUReplStaticCfg wg (j + 2)) haltCoordU| ≤
          δnext wg j) :
    ∃ P : Ripple.BoundedUniversality.GPAC.PIVP ℚ,
      Nonempty (EventualThresholdSimulation P undecidableMachine) := by
  refine paper3_headline_unconditional_of_late_start_only ?_
  intro wg
  exact
    muReplicatorLateStartHaltFactsAt_shifted
      (sol := paper3HeadlineSolFam wg) (w := wg)
      (boxInputs := paper3HeadlineBoxInputs wg)
      paper3HeadlineHerr
      (by norm_num [paper3HeadlineKappa])
      (paper3WarmGainQ_pos wg)
      (paper3HeadlineHScale wg)
      (paper3RecoveryCrMin wg) (paper3RecoveryCrMax wg)
      (paper3RecoveryCgMin wg) (paper3RecoveryGap wg)
      (paper3RecoveryB wg) (paper3RecoveryK wg)
      paper3HeadlineHCardTwo
      (paper3RecoveryCrMin_pos wg) (paper3RecoveryCrMin_le_crMax wg)
      (paper3RecoveryCgMin_nonneg wg) (paper3RecoveryGap_nonneg wg)
      (paper3RecoveryGap_le_gapVal wg) (paper3RecoveryB_eq wg)
      (paper3RecoveryB_pos wg) (paper3RecoveryBDelta wg)
      (paper3RecoveryPow wg) (paper3RecoveryCrBounds wg)
      (paper3RecoveryCgMinLe wg)
      (hutube_win wg)
      (Bz := fun _ => (1 : ℝ)) (Bzmax := (1 : ℝ))
      (δnext := δnext wg) (holdPrefix := fun _ => (1 : ℝ))
      (by intro j; norm_num)
      (Filter.Eventually.of_forall fun j => le_rfl)
      (hδnext wg)
      (hδnext_nonneg wg)
      (by intro j; norm_num)
      (paper3HeadlinePHzStartUnit wg wg)
      (by
        intro j henc t ht
        exact p_hoff wg j henc t ht)
      (hnextWrite wg)
      (paper3HeadlineFiniteHoldUnit wg wg)

