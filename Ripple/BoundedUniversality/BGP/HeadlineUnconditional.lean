    have hgateZ : Continuous fun t : ℝ =>
        bGateZ (bgpParamsNW sW).L ((sol w).μ t) t := by
      simp only [bGateZ]
      exact Real.continuous_exp.comp ((((sol w).cont_μ).mul hr).neg)
