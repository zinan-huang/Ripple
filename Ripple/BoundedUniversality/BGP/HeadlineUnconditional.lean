/-- The word-coupled warm gain dominates `1`. -/
theorem paper3NW4_warm_ge_one (wg : ℕ) :
    (1 : ℝ) ≤ ((paper3WarmGainQNW wg : ℚ) : ℝ) := by
  have h1 : (1734736490 : ℚ) ≤ paper3WarmGainCNW wg :=
    paper3WarmGainCNW_ge_base wg
  have h2 : paper3WarmGainCNW wg ≤ paper3WarmGainQNW wg := by
    have hpow : (1 : ℚ) ≤ (6 : ℚ) ^ wg :=
      one_le_pow₀ (by norm_num : (1 : ℚ) ≤ 6)
    have hC0 := paper3WarmGainCNW_nonneg wg
    unfold paper3WarmGainQNW
    nlinarith
  have h3 : (1 : ℚ) ≤ paper3WarmGainQNW wg := by linarith
  exact_mod_cast h3

/-- `2^{21} ≤ e^{15}`. -/
theorem paper3NW4_two_pow_le_exp :
    (2 : ℝ) ^ (paper3HeadlineM + 1) ≤ Real.exp (15 : ℝ) := by
  have h20 := paper3NW4_exp_three_ge
