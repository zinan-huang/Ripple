            (paper3HeadlineSolFam wg) w c v τ *
          ((paper3HeadlineSolFam wg) w).lam v τ +
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
          (∑ x : UniversalLocalView,
            ((paper3HeadlineSolFam wg) w).lam x τ *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
                  (((paper3HeadlineSolFam wg) w).u τ) -
                universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                  (((paper3HeadlineSolFam wg) w).u τ))) *
          ((paper3HeadlineSolFam wg) w).lam v τ|)
    (fun v _ => ((hg_cont v).abs.intervalIntegrable
      (μ := MeasureTheory.volume) a b))
  calc (∫ τ in a..b,
      |SelectorReplicatorDynSol.mixTargetDerivRHS
        ((paper3HeadlineSolFam wg) w) τ haltCoordU|)
      ≤ _ := hmono
    _ = _ := hswap

/-- Bad-view QSS anchor mass: with a payoff gap `≥ 1/2` at the anchor,
`sin ≥ 0` there, and the anchor late enough that the warm-gain exponent beats
the Hoff exponent, the summed quasi-steady-state levels of the bad views fit
in `1/32` of the Hoff edge budget, uniformly in the cycle index. -/
theorem paper3S4_qssAnchor_sum_le_budget_div_32
    (wg w j : ℕ) (c : UniversalLocalView) {a : ℝ}
    (hsin : 0 ≤ Real.sin a)
    (hexp : 400 * Real.pi * (j : ℝ) + 200 * Real.pi ≤ 300 * a)
    (hgap : ∀ v : UniversalLocalView,
      v ≠ localViewU (solMUReplStaticCfg w j) →
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)) →
        (1 / 2 : ℝ) ≤
          universalPval paper3HeadlineEta paper3HeadlineEta_pos c
              (((paper3HeadlineSolFam wg) w).u a) -
            universalPval paper3HeadlineEta paper3HeadlineEta_pos v
              (((paper3HeadlineSolFam wg) w).u a)) :
    (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
      (fun v =>
        |selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c v a|) ≤
      selectorMUHoffEdgeBudget3992 j / 32 := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  have hcα : bgpParams38.cα = 300 := by norm_num [bgpParams38]
  have hg0_pos : (0 : ℝ) < ((paper3WarmGainQ wg : ℚ) : ℝ) := paper3WarmGainQ_pos wg
  have hG_pos : (0 : ℝ) <
      ((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a) :=
    mul_pos hg0_pos (Real.exp_pos _)
  have hcard_pos : (0 : ℝ) < (Fintype.card UniversalLocalView : ℝ) := by
    exact_mod_cast Fintype.card_pos
  have hfloor_pos : (0 : ℝ) < (1 / 2 : ℝ) ^ paper3HeadlineM *
      (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a)) *
      (1 / 2) := by
    have h1 : (0 : ℝ) < (1 / 2 : ℝ) ^ paper3HeadlineM := by positivity
    nlinarith
  set B : ℝ := (Fintype.card UniversalLocalView : ℝ)⁻¹ /
    ((1 / 2 : ℝ) ^ paper3HeadlineM *
      (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a)) *
      (1 / 2)) with hBdef
  have hB_nonneg : 0 ≤ B := by
    rw [hBdef]
    exact div_nonneg (inv_nonneg.mpr hcard_pos.le) hfloor_pos.le
  have hview : ∀ v ∈ (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))),
      |selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v a| ≤ B := by
    intro v hv
    obtain ⟨hv1, hv2⟩ := (Finset.mem_filter.mp hv).2
    have hsink_ge := paper3S4_sink_ge_of_gap_half wg w c v hsin (hgap v hv1 hv2)
    have hsink_pos : (0 : ℝ) < selectorMU_activeSink paper3HeadlineEta
        paper3HeadlineEta_pos (paper3HeadlineSolFam wg) w c v a :=
      lt_of_lt_of_le hfloor_pos hsink_ge
    have hcr_nonneg :
        0 ≤ selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa a := by
      unfold selectorMU_activeCr
      exact mul_nonneg
        (pow_nonneg (by nlinarith [Real.neg_one_le_cos a]) _)
        (by norm_num [paper3HeadlineKappa])
    have hcr_le_one :
        selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa a ≤ 1 := by
      unfold selectorMU_activeCr
      have hbase0 : (0 : ℝ) ≤ (1 + Real.cos a) / 2 := by
        nlinarith [Real.neg_one_le_cos a]
      have hbase1 : (1 + Real.cos a) / 2 ≤ 1 := by
        nlinarith [Real.cos_le_one a]
      have hκ : ((paper3HeadlineKappa : ℚ) : ℝ) = 1 := by
        norm_num [paper3HeadlineKappa]
      rw [hκ, mul_one]
      exact pow_le_one₀ hbase0 hbase1
    have hr_nonneg :
        0 ≤ selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa a *
          (Fintype.card UniversalLocalView : ℝ)⁻¹ :=
      mul_nonneg hcr_nonneg (inv_nonneg.mpr hcard_pos.le)
    have habs : |selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v a| =
        selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c v a := by
      unfold selectorMU_activeQSS
      exact abs_of_nonneg (div_nonneg hr_nonneg hsink_pos.le)
    rw [habs]
    unfold selectorMU_activeQSS
    rw [div_le_iff₀ hsink_pos]
    have hBfloor : B * ((1 / 2 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a)) *
        (1 / 2)) = (Fintype.card UniversalLocalView : ℝ)⁻¹ := by
      rw [hBdef]
      exact div_mul_cancel₀ _ (ne_of_gt hfloor_pos)
    calc selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa a *
        (Fintype.card UniversalLocalView : ℝ)⁻¹
        ≤ 1 * (Fintype.card UniversalLocalView : ℝ)⁻¹ :=
          mul_le_mul_of_nonneg_right hcr_le_one (inv_nonneg.mpr hcard_pos.le)
      _ = (Fintype.card UniversalLocalView : ℝ)⁻¹ := one_mul _
      _ = B * ((1 / 2 : ℝ) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a)) *
          (1 / 2)) := hBfloor.symm
      _ ≤ B * selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c v a :=
          mul_le_mul_of_nonneg_left hsink_ge hB_nonneg
  have hsum_le : (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
      (fun v =>
        |selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c v a|) ≤
      (Fintype.card UniversalLocalView : ℝ) * B := by
    calc (Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v =>
            |selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
              (paper3HeadlineSolFam wg) w c v a|)
        ≤ (Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun _ => B) := Finset.sum_le_sum hview
      _ = ((Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) * B := by
          rw [Finset.sum_const, nsmul_eq_mul]
      _ ≤ (Fintype.card UniversalLocalView : ℝ) * B := by
          refine mul_le_mul_of_nonneg_right ?_ hB_nonneg
          have hcard_le := Finset.card_filter_le
            (Finset.univ : Finset UniversalLocalView)
            (fun v => v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))
          have := Finset.card_univ (α := UniversalLocalView)
          exact_mod_cast le_trans hcard_le (le_of_eq this)
  have hcardB : (Fintype.card UniversalLocalView : ℝ) * B =
      2097152 / (((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (bgpParams38.cα * a)) := by
    rw [hBdef]
    have hpow : ((1 : ℝ) / 2) ^ paper3HeadlineM = 1 / 1048576 := by
      norm_num [paper3HeadlineM]
    rw [hpow, ← mul_div_assoc, mul_inv_cancel₀ (ne_of_gt hcard_pos),
      show (1 : ℝ) / 1048576 *
          (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a)) *
          (1 / 2) =
        (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a)) /
          2097152 from by ring,
      one_div_div]
  have hone_le : (1 : ℝ) ≤
      Real.exp (bgpParams38.cα * a - 200 * Real.pi * (2 * (j : ℝ) + 1)) := by
    apply Real.one_le_exp_iff.mpr
    rw [hcα]
    nlinarith [hexp]
  have hfinal : 2097152 / (((paper3WarmGainQ wg : ℚ) : ℝ) *
      Real.exp (bgpParams38.cα * a)) ≤
      selectorMUHoffEdgeBudget3992 j / 32 := by
    rw [paper3S13_budget_eq j,
      div_le_div_iff₀ hG_pos (by norm_num : (0 : ℝ) < 32)]
    have hg0_ge := paper3S13_g0_ge wg
    have hcoeff := paper3S13_coeff_ge_3999
    calc (2097152 : ℝ) * 32
        ≤ 3999 * (((paper3WarmGainQ wg : ℚ) : ℝ) * 1) := by nlinarith [hg0_ge]
      _ ≤ selectorMUHoffEdgeBudgetCoeff *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * a -
              200 * Real.pi * (2 * (j : ℝ) + 1))) := by
          refine mul_le_mul hcoeff ?_ ?_ (le_trans (by norm_num) hcoeff)
          · exact mul_le_mul_of_nonneg_left hone_le hg0_pos.le
          · exact mul_nonneg hg0_pos.le zero_le_one
      _ = selectorMUHoffEdgeBudgetCoeff *
          Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * a)) := by
          rw [show bgpParams38.cα * a - 200 * Real.pi * (2 * (j : ℝ) + 1) =
            -(200 * Real.pi * (2 * (j : ℝ) + 1)) + bgpParams38.cα * a from by
              ring, Real.exp_add]
          ring
  calc (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
        (fun v =>
          |selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
            (paper3HeadlineSolFam wg) w c v a|)
      ≤ (Fintype.card UniversalLocalView : ℝ) * B := hsum_le
    _ = 2097152 / (((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (bgpParams38.cα * a)) := hcardB
    _ ≤ selectorMUHoffEdgeBudget3992 j / 32 := hfinal


/-- The next halt target is Boolean in the concrete universal encoding. -/
theorem paper3Headline_next_halt_zero_or_one (w j : ℕ) :
    stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 2)) haltCoordU = 0 ∨
      stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 2)) haltCoordU = 1 := by
  rw [stackMachineEncodingU_enc_eq, confEncU_halt]
  rcases haltFlagU_eq_zero_or_one (solMUReplStaticCfg w (j + 2)) with hzero | hone
  · left
    exact_mod_cast hzero
  · right
    exact_mod_cast hone

theorem paper3Exp_pi_div_eight_le_two :
    Real.exp (Real.pi / 8) ≤ (2 : ℝ) := by
  have hpi : Real.pi / 8 < (1 / 2 : ℝ) := by
    nlinarith [Real.pi_lt_four]
  have hnonneg : 0 ≤ Real.pi / 8 := by positivity
  have hlt1 : Real.pi / 8 < (1 : ℝ) := by nlinarith
  have h := Real.exp_bound_div_one_sub_of_interval hnonneg hlt1
  have hden : (1 / (1 - Real.pi / 8) : ℝ) ≤ 2 := by
    have hlehalf : Real.pi / 8 ≤ (1 / 2 : ℝ) := le_of_lt hpi
    have hpos : 0 < (1 - Real.pi / 8 : ℝ) := by nlinarith
    rw [div_le_iff₀ hpos]
    nlinarith
  exact h.trans hden

theorem paper3Exp_pi_div_sixteen_le_two :
    Real.exp (Real.pi / 16) ≤ (2 : ℝ) := by
  have hpi : Real.pi / 16 < (1 / 2 : ℝ) := by
    nlinarith [Real.pi_lt_four]
  have hnonneg : 0 ≤ Real.pi / 16 := by positivity
  have hlt1 : Real.pi / 16 < (1 : ℝ) := by nlinarith
  have h := Real.exp_bound_div_one_sub_of_interval hnonneg hlt1
  have hden : (1 / (1 - Real.pi / 16) : ℝ) ≤ 2 := by
    have hlehalf : Real.pi / 16 ≤ (1 / 2 : ℝ) := le_of_lt hpi
    have hpos : 0 < (1 - Real.pi / 16 : ℝ) := by nlinarith
    rw [div_le_iff₀ hpos]
    nlinarith
  exact h.trans hden

/-- Coarse scalar reserve assigned to the active branch residual. -/
def paper3HeadlineActiveBranchResidualCoeff : ℝ :=
  (Fintype.card UniversalLocalView : ℝ) ^ 4 / 2

set_option maxHeartbeats 1000000 in
theorem paper3HeadlineHoffCanonicalCapSum_active_left_const
    (wg : ℕ) :
    let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let Dleft : ℝ := ((1 / 2 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    let Cread : ℝ :=
      (card - 1) * card * Real.exp (Real.pi / 8) +
        (1 + 2 * (card - 1) * (Real.exp (Real.pi / 16) / gap))
    let Cleft : ℝ :=
      (Cread + Real.pi / 6) / ((gap * (1 / 2 : ℝ)) * Dleft)
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    let Cpre : ℝ := 1 + 1 / (gap * (1 / 2 : ℝ))
    let Crecovery : ℝ :=
      (((1 / 2 : ℝ) + selectorMURecoveryDelta) /
        ((gap * (1 / 2 : ℝ)) * D))
    let Cpost : ℝ :=
      ((card - 1) * (card + Real.pi / 12)) / (gap * D)
    let Cendpoint : ℝ :=
      (card - 1) * card +
        2 * (card - 1) * (Real.exp (Real.pi / 16) / gap)
    5 * Cread + 6 * Cleft + 24 +
        3 * (Cpre + Crecovery + Cpost) + Cendpoint +
          paper3HeadlineActiveBranchResidualCoeff ≤
      selectorReplicatorHoldEnvelopeCoeff := by
  let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let Dleft : ℝ := ((1 / 2 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  let Cread : ℝ :=
    (card - 1) * card * Real.exp (Real.pi / 8) +
      (1 + 2 * (card - 1) * (Real.exp (Real.pi / 16) / gap))
  let Cleft : ℝ :=
    (Cread + Real.pi / 6) / ((gap * (1 / 2 : ℝ)) * Dleft)
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  let Cpre : ℝ := 1 + 1 / (gap * (1 / 2 : ℝ))
  let Crecovery : ℝ :=
    (((1 / 2 : ℝ) + selectorMURecoveryDelta) /
      ((gap * (1 / 2 : ℝ)) * D))
  let Cpost : ℝ :=
    ((card - 1) * (card + Real.pi / 12)) / (gap * D)
  let Cendpoint : ℝ :=
    (card - 1) * card +
      2 * (card - 1) * (Real.exp (Real.pi / 16) / gap)
  have hcard_two : (2 : ℝ) ≤ card := by
    have h : (2 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) := by
      exact_mod_cast paper3HeadlineHCardTwo
    simpa [card] using h
  have hcard_nonneg : 0 ≤ card := by linarith
  have hcard_one : (1 : ℝ) ≤ card := by linarith
  have hcardm_nonneg : 0 ≤ card - 1 := by linarith
  have hgap_lb : (15 / 16 : ℝ) ≤ gap := by
    simpa [gap, paper3RecoveryGap] using paper3RecoveryGap_ge_fifteen_sixteen wg 0
  have hgap_pos : 0 < gap := by nlinarith
  have hgap_nonneg : 0 ≤ gap := hgap_pos.le
  have hgap_half_lb : (15 / 32 : ℝ) ≤ gap * (1 / 2 : ℝ) := by nlinarith
  have hgap_half_pos : 0 < gap * (1 / 2 : ℝ) := by nlinarith
  have hDleft_one : (1 : ℝ) ≤ Dleft := by
    simpa [Dleft, paper3HeadlineKappa] using paper3HeadlineHScalePrewrite wg
  have hD_one : (1 : ℝ) ≤ D := by
    simpa [D, paper3HeadlineKappa] using paper3HeadlineHScale wg
  have hDleft_nonneg : 0 ≤ Dleft := by linarith
  have hD_nonneg : 0 ≤ D := by linarith
  have hdenleft_lb : (15 / 32 : ℝ) ≤ (gap * (1 / 2 : ℝ)) * Dleft := by
    calc
      (15 / 32 : ℝ) = (15 / 32 : ℝ) * 1 := by ring
      _ ≤ (gap * (1 / 2 : ℝ)) * Dleft :=
        mul_le_mul hgap_half_lb hDleft_one (by norm_num) (by linarith)
  have hdenleft_pos : 0 < (gap * (1 / 2 : ℝ)) * Dleft := by nlinarith
  have hdenD_lb : (15 / 16 : ℝ) ≤ gap * D := by
    calc
      (15 / 16 : ℝ) = (15 / 16 : ℝ) * 1 := by ring
      _ ≤ gap * D := mul_le_mul hgap_lb hD_one (by norm_num) hgap_nonneg
  have hdenD_pos : 0 < gap * D := by nlinarith
  have hdenrec_lb : (15 / 32 : ℝ) ≤ (gap * (1 / 2 : ℝ)) * D := by
    calc
      (15 / 32 : ℝ) = (15 / 32 : ℝ) * 1 := by ring
      _ ≤ (gap * (1 / 2 : ℝ)) * D :=
        mul_le_mul hgap_half_lb hD_one (by norm_num) (by linarith)
  have hdenrec_pos : 0 < (gap * (1 / 2 : ℝ)) * D := by nlinarith
  have he8 : Real.exp (Real.pi / 8) ≤ (2 : ℝ) :=
    paper3Exp_pi_div_eight_le_two
  have he16 : Real.exp (Real.pi / 16) ≤ (2 : ℝ) :=
    paper3Exp_pi_div_sixteen_le_two
  have he16_gap : Real.exp (Real.pi / 16) / gap ≤ (32 / 15 : ℝ) := by
    rw [div_le_iff₀ hgap_pos]
    nlinarith
  have hread1 : (card - 1) * card * Real.exp (Real.pi / 8) ≤
      2 * card ^ 2 := by
    have hbase : 0 ≤ (card - 1) * card := mul_nonneg hcardm_nonneg hcard_nonneg
    calc
      (card - 1) * card * Real.exp (Real.pi / 8) ≤
          (card - 1) * card * 2 := by
        exact mul_le_mul_of_nonneg_left he8 hbase
      _ ≤ 2 * card ^ 2 := by nlinarith
  have hread2 : 2 * (card - 1) * (Real.exp (Real.pi / 16) / gap) ≤
      5 * card := by
    have hbase : 0 ≤ 2 * (card - 1) := by nlinarith
    calc
      2 * (card - 1) * (Real.exp (Real.pi / 16) / gap) ≤
          2 * (card - 1) * (32 / 15 : ℝ) := by
        exact mul_le_mul_of_nonneg_left he16_gap hbase
      _ ≤ 5 * card := by nlinarith
  have hCread : Cread ≤ 2 * card ^ 2 + 5 * card + 1 := by
    dsimp [Cread]
    nlinarith [hread1, hread2]
  have hCread_nonneg : 0 ≤ Cread := by
    dsimp [Cread]
    positivity
  have hpi6 : Real.pi / 6 ≤ (1 : ℝ) := by nlinarith [Real.pi_lt_four]
  have hCleft_raw : Cleft ≤ (32 / 15 : ℝ) * (Cread + Real.pi / 6) := by
    dsimp [Cleft]
    rw [div_le_iff₀ hdenleft_pos]
    calc
      Cread + Real.pi / 6 =
          ((32 / 15 : ℝ) * (Cread + Real.pi / 6)) * (15 / 32 : ℝ) := by
        ring
      _ ≤ ((32 / 15 : ℝ) * (Cread + Real.pi / 6)) *
            ((gap * (1 / 2 : ℝ)) * Dleft) := by
        exact mul_le_mul_of_nonneg_left hdenleft_lb (by positivity)
  have hCleft : Cleft ≤ 5 * card ^ 2 + 11 * card + 5 := by
    have hnum : Cread + Real.pi / 6 ≤ 2 * card ^ 2 + 5 * card + 2 := by
      nlinarith
    calc
      Cleft ≤ (32 / 15 : ℝ) * (Cread + Real.pi / 6) := hCleft_raw
      _ ≤ (32 / 15 : ℝ) * (2 * card ^ 2 + 5 * card + 2) := by
        exact mul_le_mul_of_nonneg_left hnum (by norm_num)
      _ ≤ 5 * card ^ 2 + 11 * card + 5 := by nlinarith
  have hinv_gap_half : 1 / (gap * (1 / 2 : ℝ)) ≤ (32 / 15 : ℝ) := by
    rw [div_le_iff₀ hgap_half_pos]
    nlinarith
  have hCpre : Cpre ≤ 4 := by
    dsimp [Cpre]
    nlinarith
  have hrec_num_le_one : (1 / 2 : ℝ) + selectorMURecoveryDelta ≤ 1 := by
    norm_num [selectorMURecoveryDelta]
  have hrec_num_nonneg : 0 ≤ (1 / 2 : ℝ) + selectorMURecoveryDelta := by
    norm_num [selectorMURecoveryDelta]
  have hCrecovery_raw :
      Crecovery ≤ (32 / 15 : ℝ) * ((1 / 2 : ℝ) + selectorMURecoveryDelta) := by
    dsimp [Crecovery]
    rw [div_le_iff₀ hdenrec_pos]
    calc
      (1 / 2 : ℝ) + selectorMURecoveryDelta =
          ((32 / 15 : ℝ) * ((1 / 2 : ℝ) + selectorMURecoveryDelta)) *
            (15 / 32 : ℝ) := by
        ring
      _ ≤ ((32 / 15 : ℝ) * ((1 / 2 : ℝ) + selectorMURecoveryDelta)) *
            ((gap * (1 / 2 : ℝ)) * D) := by
        exact mul_le_mul_of_nonneg_left hdenrec_lb
          (mul_nonneg (by norm_num) hrec_num_nonneg)
  have hCrecovery : Crecovery ≤ 3 := by
    calc
      Crecovery ≤
          (32 / 15 : ℝ) * ((1 / 2 : ℝ) + selectorMURecoveryDelta) :=
        hCrecovery_raw
      _ ≤ (32 / 15 : ℝ) * 1 := by
        exact mul_le_mul_of_nonneg_left hrec_num_le_one (by norm_num)
      _ ≤ 3 := by norm_num
  have hpi12 : Real.pi / 12 ≤ (1 : ℝ) := by
    have h := Real.pi_lt_four
    linarith
  have hpost_num : (card - 1) * (card + Real.pi / 12) ≤ 2 * card ^ 2 := by
    have hcard_plus : card + Real.pi / 12 ≤ card + 1 := by nlinarith
    have hmul1 :
        (card - 1) * (card + Real.pi / 12) ≤ (card - 1) * (card + 1) := by
      exact mul_le_mul_of_nonneg_left hcard_plus hcardm_nonneg
    nlinarith
  have hCpost_raw :
      Cpost ≤ (16 / 15 : ℝ) * ((card - 1) * (card + Real.pi / 12)) := by
    dsimp [Cpost]
    rw [div_le_iff₀ hdenD_pos]
    have hcoef_nonneg :
        0 ≤ (16 / 15 : ℝ) * ((card - 1) * (card + Real.pi / 12)) := by
      positivity
    calc
      (card - 1) * (card + Real.pi / 12) =
          ((16 / 15 : ℝ) * ((card - 1) * (card + Real.pi / 12))) *
            (15 / 16 : ℝ) := by
        ring
      _ ≤ ((16 / 15 : ℝ) * ((card - 1) * (card + Real.pi / 12))) *
            (gap * D) := by
        exact mul_le_mul_of_nonneg_left hdenD_lb hcoef_nonneg
  have hCpost : Cpost ≤ 3 * card ^ 2 := by
    calc
      Cpost ≤ (16 / 15 : ℝ) * ((card - 1) * (card + Real.pi / 12)) :=
        hCpost_raw
      _ ≤ (16 / 15 : ℝ) * (2 * card ^ 2) := by
        exact mul_le_mul_of_nonneg_left hpost_num (by norm_num)
      _ ≤ 3 * card ^ 2 := by nlinarith [sq_nonneg card]
  have hendpoint2 :
      2 * (card - 1) * (Real.exp (Real.pi / 16) / gap) ≤ 5 * card :=
    hread2
  have hendpoint1 : (card - 1) * card ≤ card ^ 2 := by nlinarith
  have hCendpoint : Cendpoint ≤ 6 * card ^ 2 := by
    dsimp [Cendpoint]
    have h5 : 5 * card ≤ 5 * card ^ 2 := by nlinarith [sq_nonneg (card - 1)]
    nlinarith [hendpoint1, hendpoint2, h5]
  have hpoly :
      5 * Cread + 6 * Cleft + 24 + 3 * (Cpre + Crecovery + Cpost) +
          Cendpoint ≤ 55 * card ^ 2 + 91 * card + 77 := by
    nlinarith [hCread, hCleft, hCpre, hCrecovery, hCpost, hCendpoint]
  have hfinal_poly :
      55 * card ^ 2 + 91 * card + 77 ≤ card ^ 4 / 2 + 4000 := by
    nlinarith [hcard_two, sq_nonneg (card - 10), sq_nonneg (card ^ 2 - 100),
      sq_nonneg (card - 2)]
  calc
    5 * Cread + 6 * Cleft + 24 + 3 * (Cpre + Crecovery + Cpost) +
        Cendpoint + paper3HeadlineActiveBranchResidualCoeff
        ≤ (55 * card ^ 2 + 91 * card + 77) + card ^ 4 / 2 := by
          dsimp [paper3HeadlineActiveBranchResidualCoeff]
          nlinarith [hpoly]
    _ ≤ (card ^ 4 / 2 + 4000) + card ^ 4 / 2 := by
      nlinarith [hfinal_poly]
    _ = 4000 + card ^ 4 := by ring
    _ = selectorReplicatorHoldEnvelopeCoeff := by
      unfold selectorReplicatorHoldEnvelopeCoeff
      dsimp [card]

/-- Headline active branch-residual surface for next halt target `1`. -/
def paper3HeadlineActiveBranchResidualOne (wg w j : ℕ) : ℝ :=
  let sol := paper3HeadlineSolFam wg
  let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
  ∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
      (selectorMUWriteHoldTime (j + 1)),
    (∑ v : UniversalLocalView,
      (BranchData.evalBranch (branchU c) ((sol w).u τ) haltCoordU -
        BranchData.evalBranch (branchU v) ((sol w).u τ) haltCoordU) *
        |(((1 + Real.cos τ) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ)) *
            (Fintype.card UniversalLocalView : ℝ)⁻¹ -
          ((((1 + Real.cos τ) / 2) ^ paper3HeadlineM *
              (paper3HeadlineKappa : ℝ)) +
            (((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQ wg : ℚ) : ℝ) *
                Real.exp (bgpParams38.cα * τ))) *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
                  ((sol w).u τ) -
                universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                  ((sol w).u τ))) *
            (sol w).lam v τ|) +
    (((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
      (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * τ))) *
      (∑ v : UniversalLocalView,
        (sol w).lam v τ *
          (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
              ((sol w).u τ) -
            universalPval paper3HeadlineEta paper3HeadlineEta_pos v
              ((sol w).u τ))) *
      (∑ v : UniversalLocalView,
        (sol w).lam v τ *
          (BranchData.evalBranch (branchU c) ((sol w).u τ) haltCoordU -
            BranchData.evalBranch (branchU v) ((sol w).u τ) haltCoordU))

/-- Headline active branch-residual surface for next halt target `0`. -/
