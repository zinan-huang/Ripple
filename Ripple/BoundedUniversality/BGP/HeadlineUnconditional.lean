/-- The NW gain integrand of the replicator gate. -/
def paper3NW4cg (wg : ℕ) : ℝ → ℝ :=
  fun s => ((1 + Real.sin s) / 2) ^ paper3HeadlineM *
    (((paper3WarmGainQNW wg : ℚ) : ℝ) *
      Real.exp ((bgpParamsNW wg).cα * s))

theorem paper3NW4cg_cont (wg : ℕ) : Continuous (paper3NW4cg wg) := by
  unfold paper3NW4cg
  exact ((((continuous_const.add Real.continuous_sin).div_const 2).pow _).mul
    (continuous_const.mul
      (Real.continuous_exp.comp (continuous_const.mul continuous_id))))

theorem paper3NW4cg_nonneg (wg : ℕ) (s : ℝ) : 0 ≤ paper3NW4cg wg s := by
  unfold paper3NW4cg
  have hb := Real.neg_one_le_sin s
  exact mul_nonneg (pow_nonneg (by linarith) _)
    (mul_nonneg (paper3WarmGainQNW_nonneg_real wg) (Real.exp_pos _).le)

