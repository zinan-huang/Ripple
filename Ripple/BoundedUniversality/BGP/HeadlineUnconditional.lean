        |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteReadTime j) i| := by
      have h := abs_sub_le
        (((paper3HeadlineSolFamNW w) w).z (selectorMUWriteReadTime j) i)
        (((paper3HeadlineSolFamNW w) w).u (selectorMUWriteReadTime j) i)
        (0 : ℝ)
      simpa using h
    linarith
  -- z trapped in the hull box on the edge window
  have hz_lvl : ∀ t ∈ Icc (selectorMUWriteReadTime j)
      (selectorMUZOffStart j),
      |((paper3HeadlineSolFamNW w) w).z t i| ≤
        (2 * D_U + 4000 * D_U * (5 * D_U + 2)) + paper3F1CwinDefN +
          2 * D_U + 1 := by
    have hbr0 : (0 : ℝ) ≤ 2 * D_U + 4000 * D_U * (5 * D_U + 2) := by
      nlinarith
    have htrap := relax_abs_trap
      (fun τ => ((paper3HeadlineSolFamNW w) w).z τ i)
      (fun τ => selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
        ((paper3HeadlineSolFamNW w) w).lam τ i)
      (fun τ => (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
        bGateZ (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ)
      (M := (0 : ℝ))
      (δ := (2 * D_U + 4000 * D_U * (5 * D_U + 2)) + paper3F1CwinDefN +
        2 * D_U + 1)
      hwrz
      (paper3NW4_zKernel_continuous w w)
      (((paper3HeadlineSolFamNW w) w).cont_mixTarget i)
      (fun t ht => ((paper3HeadlineSolFamNW w) w).z_hasDeriv t
        (selectorSchedule_domain_of_nonneg_structural t
          (le_trans hwr0 ht.1)) i)
      (fun t ht => paper3NW4_zKernel_nonneg w w (le_trans hwr0 ht.1))
      (by
        simp only [sub_zero]
        exact le_trans hz_entry (by linarith))
      (fun t ht => by
        simp only [sub_zero]
        exact le_trans (hmix_lvl t ht) (by linarith))
    intro t ht
    simpa using htrap t ht
  intro t ht
  have hz := hz_lvl t ht
  have hu := hu_lvl t ht i
  have hsplit : |((paper3HeadlineSolFamNW w) w).z t i -
      ((paper3HeadlineSolFamNW w) w).u t i| ≤
      |((paper3HeadlineSolFamNW w) w).z t i| +
      |((paper3HeadlineSolFamNW w) w).u t i| :=
    abs_sub (((paper3HeadlineSolFamNW w) w).z t i)
      (((paper3HeadlineSolFamNW w) w).u t i)
  unfold paper3S4EdgeZUBoundNW
  linarith

/-! ### S2-NW final assembly glue (design: Q4151)

One global lower-half z-displacement allowance (`Hlower`, spent once) feeds
BOTH the copy contraction's target tube and the post-copy trapping; the
ledger is `δ_handoff (≤ 9r/20) + Hlower (≤ r/4) + Gcopy (≤ r/4) = 19r/20 < r`.
The handoff radius stays an explicit hypothesis until the Q4150 M₁ producer
and the handoff-guard supplier land (Glue 1). -/

/-- The global lower-half z displacement allowance (row H, spent once). -/
noncomputable def paper3S2LowerHalfZDriftNW (w j : ℕ) : ℝ :=
  paper3S2MixZGuard *
    Real.exp (-(200 * (bgpScaleW w : ℝ) *
      (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) /
    (200 * (bgpScaleW w : ℝ))

theorem paper3S2LowerHalfZDriftNW_nonneg (w j : ℕ) :
    0 ≤ paper3S2LowerHalfZDriftNW w j := by
  unfold paper3S2LowerHalfZDriftNW
  have hS : (0 : ℝ) < (bgpScaleW w : ℝ) := bgpScaleWR_pos w
  have h1 : (0 : ℝ) ≤ paper3S2MixZGuard *
      Real.exp (-(200 * (bgpScaleW w : ℝ) *
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6))) :=
    mul_nonneg paper3S2MixZGuard_nonneg (Real.exp_pos _).le
  exact div_nonneg h1 (by nlinarith)

/-- **Glue 2 (Q4151): one global z tube on the lower half**
`[2πj+7π/6, 2πj+2π]` — entry error + the single displacement allowance. -/
theorem paper3S2_z_tube_lower_half_NW (w j : ℕ)
    (box : Paper3S2WindowBoxNW w j) {δh : ℝ}
    (hzEntry : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i -
        stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤ δh) :
    ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
        (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW w) w).z t i -
          stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤
          δh + paper3S2LowerHalfZDriftNW w j := by
  have hπ := Real.pi_pos
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) := by
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith
  have ha0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 := by linarith
  intro t ht i
  have hmz : ∀ τ ∈ Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
          ((paper3HeadlineSolFamNW w) w).lam τ i -
        ((paper3HeadlineSolFamNW w) w).z τ i| ≤ paper3S2MixZGuard := by
    intro τ hτ
    exact paper3S2_mixz_abs_le_guard w j (le_trans ha0 hτ.1)
      (fun k => box.hu τ hτ k) i (box.hz τ hτ i)
  have hdrift := paper3NW4_z_drift_of_sin_nonpos w w i
    (a := 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
    (b := 2 * Real.pi * (j : ℝ) + 2 * Real.pi)
    paper3S2MixZGuard_nonneg ha0
    (fun τ hτ => sin_nonpos_on_lower_half j
      (by linarith [hτ.1]) (by linarith [hτ.2]))
    hmz t ht
  have hsplit : |((paper3HeadlineSolFamNW w) w).z t i -
      stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i| +
      |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i -
        stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| :=
    abs_sub_le _ _ _
  have hze := hzEntry i
  unfold paper3S2LowerHalfZDriftNW
  linarith

/-- **Glue 3 (Q4151): the S2-NW core** — the post-copy NEW-configuration
only on the handoff entry (Glue 1 / Q4150).  Route: crude box → global
lower-half z tube (row H) → copy entry `4D+2` → copy contraction (row G)
→ post-copy trapping toward the tubed z → ledger `19r/20 < r`. -/
theorem paper3S2_interRead_new_tube_NW (w j : ℕ) {δh : ℝ}
    (hδh0 : 0 ≤ δh) (hδh_le : δh ≤ 9 * r_LE_U / 20)
    (hzEntry : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i -
        stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤ δh)
    (huEntry : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i| ≤ paper3S2GuardCu) :
    ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 11 * Real.pi / 6)
        (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
      UTube r_LE_U (solMUReplStaticCfg w (j + 1))
        (((paper3HeadlineSolFamNW w) w).u t) := by
  have hπ := Real.pi_pos
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) := by
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith
  have ha0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 := by linarith
  have hd0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3 := by linarith
  have hde : 2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3 ≤
      2 * Real.pi * (j : ℝ) + 2 * Real.pi := by linarith
  have box := paper3S2_window_firstExit_box_NW w j hδh0 hδh_le hzEntry huEntry
  have hzT := paper3S2_z_tube_lower_half_NW w j box hzEntry
  have hδz0 : 0 ≤ δh + paper3S2LowerHalfZDriftNW w j :=
    add_nonneg hδh0 (paper3S2LowerHalfZDriftNW_nonneg w j)
  have hcopy_entry : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u
          (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3) i -
        stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤
        4 * D_U + 2 := by
    intro i
    have hcmem : (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3) ∈
        Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
          (2 * Real.pi * (j : ℝ) + 2 * Real.pi) :=
      ⟨by linarith, by linarith⟩
    have hu := box.hu _ hcmem i
    have henc := paper3NW4_enc_abs (solMUReplStaticCfg w (j + 1)) i
    have htri := abs_sub (((paper3HeadlineSolFamNW w) w).u
        (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3) i)
      (stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i)
    unfold paper3S2GuardCu at hu
    linarith
  have hcopy : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u
          (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3) i -
        stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤
        Real.exp (-paper3S2CopyMassLowerNW w j) * (4 * D_U + 2) +
          (δh + paper3S2LowerHalfZDriftNW w j) := by
    intro i
    exact paper3S2_u_copy_contract_NW w w j i hδz0 (hcopy_entry i)
      (fun t htc => hzT t ⟨by linarith [htc.1], by linarith [htc.2]⟩ i)
  have htrap : ∀ i : Fin d_U, ∀ t ∈ Icc
      (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3)
      (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
      |((paper3HeadlineSolFamNW w) w).u t i -
        stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| ≤
        Real.exp (-paper3S2CopyMassLowerNW w j) * (4 * D_U + 2) +
          (δh + paper3S2LowerHalfZDriftNW w j) := by
    intro i
    have hG0 : (0 : ℝ) ≤
        Real.exp (-paper3S2CopyMassLowerNW w j) * (4 * D_U + 2) :=
      mul_nonneg (Real.exp_pos _).le (by nlinarith [D_U_nonneg])
    exact relax_abs_trap
      (fun τ => ((paper3HeadlineSolFamNW w) w).u τ i)
      (fun τ => ((paper3HeadlineSolFamNW w) w).z τ i)
      (fun τ => (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
        bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ)
      (M := stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i)
      (δ := Real.exp (-paper3S2CopyMassLowerNW w j) * (4 * D_U + 2) +
        (δh + paper3S2LowerHalfZDriftNW w j))
      hde
      (paper3NW4_uKernel_continuous w w)
      (((paper3HeadlineSolFamNW w) w).cont_z i)
      (fun t ht => ((paper3HeadlineSolFamNW w) w).u_hasDeriv t
        (selectorSchedule_domain_of_nonneg_structural t
          (le_trans hd0 ht.1)) i)
      (fun t ht => paper3NW4_uKernel_nonneg w w (le_trans hd0 ht.1))
      (hcopy i)
      (fun t ht => by
        have hz := hzT t ⟨by linarith [ht.1], ht.2⟩ i
        linarith)
  have hGcap : Real.exp (-paper3S2CopyMassLowerNW w j) * (4 * D_U + 2) ≤
      r_LE_U / 4 := by
    have h := paper3S2_copy_D0_exp_neg_mass_le_quarter_NW w j
    have hcomm : Real.exp (-paper3S2CopyMassLowerNW w j) * (4 * D_U + 2) =
        (4 * D_U + 2) * Real.exp (-paper3S2CopyMassLowerNW w j) := by ring
    rw [hcomm]
    exact h
  have hHcap : paper3S2LowerHalfZDriftNW w j ≤ r_LE_U / 4 := by
    unfold paper3S2LowerHalfZDriftNW
    exact paper3S2_firstExit_z_drift_cap_NW w j
  intro t ht i
  have h := htrap i t ⟨by linarith [ht.1], ht.2⟩
  have hr : r_LE_U = 1 / 1000 := rfl
  calc |((paper3HeadlineSolFamNW w) w).u t i -
        (confEncU (solMUReplStaticCfg w (j + 1)) i : ℝ)|
      = |((paper3HeadlineSolFamNW w) w).u t i -
          stackMachineEncodingU.enc (solMUReplStaticCfg w (j + 1)) i| := rfl
    _ ≤ Real.exp (-paper3S2CopyMassLowerNW w j) * (4 * D_U + 2) +
          (δh + paper3S2LowerHalfZDriftNW w j) := h
    _ ≤ r_LE_U / 4 + (9 * r_LE_U / 20 + r_LE_U / 4) := by
        linarith [hGcap, hHcap, hδh_le]
    _ ≤ r_LE_U := by
        rw [hr]
        norm_num

/-! ### Q4149 Step 4: the NW settled analytic package (session 5)

The four mechanical suppliers for `MUReplicatorSettledAnalyticP` at
`p := bgpParamsNW w` on the diagonal word-coupled family, plus the record
instance itself.  `epsLam := paper3NW4EpsLam` (nonneg + tendsto below);
`hloser` comes from `paper3NW4_loser_mass` fed by `paper3SegC_edge_tube_NW`
(the `[wh, wr]` window sits inside the maintained `[wh, zOffStart]` window);
`Λ := paper3S2HoldMassLowerNW`, the `[wh, wr]`-window clone of
`paper3S2_writeMassLower_NW` (same `sin ≥ 1/2` argument, narrower window of
width `π/3`). -/

/-- `selectorMUSelectStartTime` grows linearly, hence `→ ∞`. -/
theorem paper3NW4_selectStart_tendsto_atTop :
    Tendsto (fun j : ℕ => selectorMUSelectStartTime j) atTop atTop := by
  have h1 : Tendsto (fun j : ℕ => 2 * Real.pi * (j : ℝ)) atTop atTop :=
    Filter.Tendsto.const_mul_atTop (by positivity) tendsto_natCast_atTop_atTop
  have h2 := Filter.tendsto_atTop_add_const_right atTop
    (Real.pi / 6 + selectorMURecoveryDelta) h1
  refine Filter.Tendsto.congr (fun j => ?_) h2
  unfold selectorMUSelectStartTime selectorMUWriteStartTime
  ring

/-- Nonnegativity of the NW per-cycle loser-mass radius. -/
theorem paper3NW4EpsLam_nonneg (wg : ℕ) :
    ∀ j, 0 ≤ paper3NW4EpsLam wg j := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  intro j
  have hcard_pos : 0 < Fintype.card UniversalLocalView :=
    Fintype.card_pos_iff.mpr inferInstance
  have hcard : (1 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) := by
    exact_mod_cast hcard_pos
  unfold paper3NW4EpsLam
  refine mul_nonneg (by linarith) (add_nonneg ?_ ?_)
  · exact mul_nonneg (by linarith) (Real.exp_pos _).le
  · exact mul_nonneg (by positivity) (Real.exp_pos _).le

/-- The NW per-cycle loser-mass radius vanishes as `j → ∞`: both the
`e^{−(15/16)·ΔGf}` term (gate-mass floor grows like `e^{cα·sel j}`) and the
`e^{−cα·sel j}` reset term decay. -/
theorem paper3NW4EpsLam_tendsto_zero (wg : ℕ) :
    Tendsto (fun j : ℕ => paper3NW4EpsLam wg j) atTop (𝓝 0) := by
  classical
  have hsel := paper3NW4_selectStart_tendsto_atTop
  have hcα : 0 < (bgpParamsNW wg).cα := bgpParamsNW_cα_pos wg
  have hscaled : Tendsto
      (fun j : ℕ => (bgpParamsNW wg).cα * selectorMUSelectStartTime j)
      atTop atTop :=
    Filter.Tendsto.const_mul_atTop hcα hsel
  have hexp2 : Tendsto
      (fun j : ℕ =>
        Real.exp (-((bgpParamsNW wg).cα * selectorMUSelectStartTime j)))
      atTop (𝓝 0) := by
    have h := Real.tendsto_exp_neg_atTop_nhds_zero.comp hscaled
    exact Filter.Tendsto.congr (fun j => rfl) h
  have hwarm : (0 : ℝ) < ((paper3WarmGainQNW wg : ℚ) : ℝ) :=
    paper3WarmGainQNW_pos_real wg
  have hwidth_pos : (0 : ℝ) < Real.pi / 3 - selectorMURecoveryDelta := by
    have hπ := Real.pi_gt_three
    have hΔ : selectorMURecoveryDelta = 1 / 100000 := rfl
    rw [hΔ]; linarith
  have hΔG : Tendsto (fun j : ℕ => paper3NW4DeltaGFloor wg j) atTop atTop := by
    have hexpA : Tendsto
        (fun j : ℕ =>
          Real.exp ((bgpParamsNW wg).cα * selectorMUSelectStartTime j))
        atTop atTop :=
      Real.tendsto_exp_atTop.comp hscaled
    have hc1 : Tendsto
        (fun j : ℕ => ((paper3WarmGainQNW wg : ℚ) : ℝ) *
          Real.exp ((bgpParamsNW wg).cα * selectorMUSelectStartTime j))
        atTop atTop :=
      Filter.Tendsto.const_mul_atTop hwarm hexpA
    have hc2 : Tendsto
        (fun j : ℕ => (3 / 4 : ℝ) ^ paper3HeadlineM *
          (((paper3WarmGainQNW wg : ℚ) : ℝ) *
            Real.exp ((bgpParamsNW wg).cα * selectorMUSelectStartTime j)))
        atTop atTop :=
      Filter.Tendsto.const_mul_atTop (by positivity) hc1
    have hc3 := Filter.Tendsto.atTop_mul_const hwidth_pos hc2
    refine Filter.Tendsto.congr (fun j => ?_) hc3
    unfold paper3NW4DeltaGFloor
    ring
  have hexp1 : Tendsto
      (fun j : ℕ => Real.exp (-(15 / 16) * paper3NW4DeltaGFloor wg j))
      atTop (𝓝 0) := by
    have hs : Tendsto
        (fun j : ℕ => (15 / 16 : ℝ) * paper3NW4DeltaGFloor wg j)
        atTop atTop :=
      Filter.Tendsto.const_mul_atTop (by norm_num) hΔG
    have h := Real.tendsto_exp_neg_atTop_nhds_zero.comp hs
    refine Filter.Tendsto.congr (fun j => ?_) h
    simp only [Function.comp_apply, neg_mul]
  have hsum : Tendsto
      (fun j : ℕ =>
        (Fintype.card UniversalLocalView : ℝ) *
            Real.exp (-(15 / 16) * paper3NW4DeltaGFloor wg j) +
          2 ^ (paper3HeadlineM + 1) *
            Real.exp (-((bgpParamsNW wg).cα * selectorMUSelectStartTime j)))
      atTop (𝓝 0) := by
    have h1 := hexp1.const_mul (Fintype.card UniversalLocalView : ℝ)
    have h2 := hexp2.const_mul ((2 : ℝ) ^ (paper3HeadlineM + 1))
    simpa using h1.add h2
  have hfinal := hsum.const_mul ((Fintype.card UniversalLocalView : ℝ) - 1)
  refine Filter.Tendsto.congr (fun j => ?_) (by simpa using hfinal)
  unfold paper3NW4EpsLam
  ring

/-- Restriction of the NW loser-mass bound to the `[wh, wr]` window consumed
by `MUReplicatorSettledAnalyticP.hloser`, with the maintained-tube hypothesis
discharged by the landed Seg C edge tube. -/
theorem paper3NW4_loser_mass_hold_window (w j : ℕ) :
    ∀ t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUWriteReadTime j),
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j))).sum
          (fun v => ((paper3HeadlineSolFamNW w) w).lam v t) ≤
      paper3NW4EpsLam w j := by
  intro t ht
  have hsub : t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUZOffStart j) := by
    refine ⟨ht.1, le_trans ht.2 ?_⟩
    unfold selectorMUWriteReadTime selectorMUZOffStart
    have hπ := Real.pi_pos
    linarith
  exact paper3NW4_loser_mass w w j (paper3SegC_edge_tube_NW w j) t hsub

/-- Named lower bound for the settled z-write mass on the NARROWER hold
window `[wh j, wr j]` (width `π/3`, `sin ≥ 1/2` throughout): the `Λ` supplier
of `MUReplicatorSettledAnalyticP`. -/
noncomputable def paper3S2HoldMassLowerNW (wg j : ℕ) : ℝ :=
  (Real.pi / 3) *
    Real.exp (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ) + Real.pi / 2))

theorem paper3S2_holdMassLower_NW (wg w j : ℕ) :
    paper3S2HoldMassLowerNW wg j ≤
      ∫ τ in (selectorMUWriteHoldTime j)..(selectorMUWriteReadTime j),
        (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
  have hπ := Real.pi_pos
  have hS : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) :=
    mul_nonneg (mul_nonneg (by norm_num) hπ.le) (Nat.cast_nonneg _)
  have hwh0 : (0 : ℝ) ≤ selectorMUWriteHoldTime j := by
    unfold selectorMUWriteHoldTime; linarith
  have hab : selectorMUWriteHoldTime j ≤ selectorMUWriteReadTime j := by
    unfold selectorMUWriteHoldTime selectorMUWriteReadTime; linarith
  have hpoint : ∀ τ ∈ Icc (selectorMUWriteHoldTime j) (selectorMUWriteReadTime j),
      Real.exp (50 * (bgpScaleW wg : ℝ) *
          (2 * Real.pi * (j : ℝ) + Real.pi / 2)) ≤
        (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans hwh0 hτ.1
    have hsin : (1 : ℝ) / 2 ≤ Real.sin τ := by
      apply sin_ge_half_of_write_window j
      constructor
      · have := hτ.1; unfold selectorMUWriteHoldTime at this; linarith
      · have := hτ.2; unfold selectorMUWriteReadTime at this; linarith
    calc Real.exp (50 * (bgpScaleW wg : ℝ) *
          (2 * Real.pi * (j : ℝ) + Real.pi / 2))
        ≤ Real.exp (50 * (bgpScaleW wg : ℝ) * τ) := by
          apply Real.exp_le_exp.mpr
          have := hτ.1; unfold selectorMUWriteHoldTime at this
          nlinarith
      _ ≤ _ := paper3NW4_zKernel_ge_of_sin_ge_half wg w hτ0 hsin
  have hconst_int : IntervalIntegrable
      (fun _ : ℝ => Real.exp (50 * (bgpScaleW wg : ℝ) *
        (2 * Real.pi * (j : ℝ) + Real.pi / 2)))
      MeasureTheory.volume (selectorMUWriteHoldTime j) (selectorMUWriteReadTime j) :=
    intervalIntegrable_const
  have hker_int : IntervalIntegrable
      (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ)
      MeasureTheory.volume (selectorMUWriteHoldTime j) (selectorMUWriteReadTime j) :=
    (paper3NW4_zKernel_continuous wg w).intervalIntegrable _ _
  have hmono := intervalIntegral.integral_mono_on hab hconst_int hker_int hpoint
  have hwidth : (∫ _ in (selectorMUWriteHoldTime j)..(selectorMUWriteReadTime j),
      Real.exp (50 * (bgpScaleW wg : ℝ) *
        (2 * Real.pi * (j : ℝ) + Real.pi / 2))) =
      paper3S2HoldMassLowerNW wg j := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
    unfold paper3S2HoldMassLowerNW selectorMUWriteHoldTime selectorMUWriteReadTime
    ring
  calc paper3S2HoldMassLowerNW wg j = _ := hwidth.symm
    _ ≤ _ := hmono

/-- The hold-window write mass grows without bound (exponentially in `j`). -/
theorem paper3S2HoldMassLowerNW_tendsto_atTop (wg : ℕ) :
    Tendsto (fun j : ℕ => paper3S2HoldMassLowerNW wg j) atTop atTop := by
  have hS : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have h1 : Tendsto (fun j : ℕ => 2 * Real.pi * (j : ℝ)) atTop atTop :=
    Filter.Tendsto.const_mul_atTop (by positivity) tendsto_natCast_atTop_atTop
  have h2 := Filter.tendsto_atTop_add_const_right atTop (Real.pi / 2) h1
  have hlin : Tendsto
      (fun j : ℕ => 50 * (bgpScaleW wg : ℝ) *
        (2 * Real.pi * (j : ℝ) + Real.pi / 2)) atTop atTop :=
