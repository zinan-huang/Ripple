  have hz : selectorMUZOffEnd j = 2 * Real.pi * ((j : ℝ) + 1) := rfl
  have hXge : 2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
      ((bgpScaleW wg : ℝ) + 3) ≤
      200 * (bgpScaleW wg : ℝ) * selectorMUZOffEnd j := by
    rw [hz]
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    have hf1 : (2 : ℝ) ≤ 200 * (bgpScaleW wg : ℝ) * (2 * Real.pi) := by
      nlinarith
    have hf2 := mul_le_mul_of_nonneg_right hf1 hj
    have hf3 : 21 * (bgpScaleW wg : ℝ) + 3 ≤
        200 * (bgpScaleW wg : ℝ) * (2 * Real.pi) := by
      nlinarith
    nlinarith [hf2, hf3]
