/-! ### NW clones of the N-parametric generic-sol helpers

Word-coupled (`bgpParamsNW sW`) siblings of the `*_N` helpers above: the δu
drift envelopes, the write/settled-window u-freeze, the u-active kernel-mass
floor, the off-phase z-gate cap and the inter-read transport.  Mechanical
rate substitution `bgpScale → bgpScaleW sW` (every sign/ratio fact of the
`(1000, 300)` design is degree-1 homogeneous in the scale). -/
noncomputable def δuWritePrefixNW (sW : ℕ) (Bzu : ℝ) (j : ℕ) : ℝ :=
  Bzu * ((Real.pi / 3) *
    Real.exp (-(selectorUSettledRate_NW sW * selectorMUWriteStartTime j)))

/-- N-parametric settled-window u-drift envelope. -/
noncomputable def δuSettledNW (sW : ℕ) (Bzu : ℝ) (j : ℕ) : ℝ :=
  Bzu * ((Real.pi / 3) *
    Real.exp (-(selectorUSettledRate_NW sW * selectorMUWriteHoldTime j)))

theorem δuWritePrefixNW_nonneg (sW : ℕ) {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) (j : ℕ) :
    0 ≤ δuWritePrefixNW sW Bzu j := by
  unfold δuWritePrefixNW
  exact mul_nonneg hBzu0
    (mul_nonneg (by positivity) (Real.exp_pos _).le)

theorem δuSettledNW_nonneg (sW : ℕ) {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) (j : ℕ) :
