theorem paper3N_abs_sum_weighted_le_of_simplex_and_abs_le
    {V : Type} [Fintype V] (lam : V → ℝ) (a : V → ℝ) {B : ℝ}
    (hlam_nonneg : ∀ v : V, 0 ≤ lam v)
    (hlam_sum : (∑ v : V, lam v) = 1)
    (ha : ∀ v : V, |a v| ≤ B) :
    |∑ v : V, lam v * a v| ≤ B := by
  calc
    |∑ v : V, lam v * a v|
        ≤ ∑ v : V, |lam v * a v| := Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ v : V, lam v * B := by
          refine Finset.sum_le_sum ?_
          intro v _hv
          rw [abs_mul, abs_of_nonneg (hlam_nonneg v)]
          exact mul_le_mul_of_nonneg_left (ha v) (hlam_nonneg v)
    _ = (∑ v : V, lam v) * B := by rw [Finset.sum_mul]
    _ = B := by rw [hlam_sum, one_mul]

/-- Pointwise u-kernel bound on `[0, π]` at the N rates:
`A·α(τ)·bGateU(μ(τ), τ) ≤ e^{−200·bgpScale·τ}`. -/
theorem paper3N_uKernel_le_exp (wg w : ℕ) {τ : ℝ}
    (h0 : 0 ≤ τ) (hπ : τ ≤ Real.pi) :
    bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
        bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ ≤
      Real.exp (-(200 * (bgpScale : ℝ) * τ)) := by
  have hα := paper3HeadlineSolFamN_alpha wg w h0
  have hμ := paper3HeadlineSolFamN_mu wg w h0
  rw [hα, hμ]
  simp only [bgpParamsN_A_eq, one_mul, bgpParamsN_L_eq]
  unfold bGateU qPulse
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  have hsin : 0 ≤ Real.sin τ := Real.sin_nonneg_of_nonneg_of_le_pi h0 hπ
  have hq : (1 : ℝ) / 2 ≤ ((1 + Real.sin τ) / 2) ^ 1 := by
    rw [pow_one]; linarith
  have hsW : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  rw [bgpParamsN_cα_def, bgpParamsN_cμ_def]
  nlinarith [mul_le_mul_of_nonneg_left hq
    (mul_nonneg (mul_nonneg (by norm_num : (0 : ℝ) ≤ 1000) hsW.le) h0),
    mul_nonneg hsW.le h0]

/-- Grönwall-style u-freeze on the N warm prefix. -/
theorem paper3N_u_drift_on_warm_prefix (wg w : ℕ) (i : Fin d_U)
    {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) {t : ℝ}
    (ht : t ∈ Icc (0 : ℝ) (Real.pi / 6))
    (hzu : ∀ τ ∈ Icc (0 : ℝ) t,
      |((paper3HeadlineSolFamN wg) w).z τ i -
        ((paper3HeadlineSolFamN wg) w).u τ i| ≤ Bzu) :
    |((paper3HeadlineSolFamN wg) w).u t i -
        ((paper3HeadlineSolFamN wg) w).u 0 i| ≤
      Bzu / (200 * (bgpScale : ℝ)) := by
  have hsW : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hc : (0 : ℝ) < 200 * (bgpScale : ℝ) := by nlinarith
  have hπ6 : Real.pi / 6 ≤ Real.pi := by linarith [Real.pi_pos]
  have hgate_cont : Continuous fun τ : ℝ =>
      bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
    unfold bGateU
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamN wg) w).cont_μ.mul
        (qPulse_continuous bgpParamsN.L)).neg)
  have hgc : Continuous fun τ : ℝ =>
      bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
        (((paper3HeadlineSolFamN wg) w).z τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i) :=
    ((continuous_const.mul ((paper3HeadlineSolFamN wg) w).cont_α).mul
        hgate_cont).mul
      ((((paper3HeadlineSolFamN wg) w).cont_z i).sub
        (((paper3HeadlineSolFamN wg) w).cont_u i))
  have hy : ∀ τ ∈ Icc (0 : ℝ) t,
      HasDerivAt (fun s => ((paper3HeadlineSolFamN wg) w).u s i)
        (bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
            bGateU bgpParamsN.L
              (((paper3HeadlineSolFamN wg) w).μ τ) τ *
          (((paper3HeadlineSolFamN wg) w).z τ i -
            ((paper3HeadlineSolFamN wg) w).u τ i)) τ :=
    fun τ hτ => ((paper3HeadlineSolFamN wg) w).u_hasDeriv τ
      (selectorSchedule_domain_of_nonneg_structural τ hτ.1) i
  have hhold := hold_bound_integral
    (fun s => ((paper3HeadlineSolFamN wg) w).u s i)
    (fun τ => bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
        bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
      (((paper3HeadlineSolFamN wg) w).z τ i -
        ((paper3HeadlineSolFamN wg) w).u τ i))
    0 t ht.1 hgc hy
  have hpt : ∀ τ ∈ Icc (0 : ℝ) t,
      |bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
        (((paper3HeadlineSolFamN wg) w).z τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i)| ≤
      Bzu * Real.exp (-(200 * (bgpScale : ℝ) * τ)) := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := hτ.1
    have hτπ : τ ≤ Real.pi := le_trans (le_trans hτ.2 ht.2) hπ6
    have hker_nonneg : 0 ≤
        bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateU bgpParamsN.L
            (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
      have hα := paper3HeadlineSolFamN_alpha wg w hτ0
      rw [hα]
      simp only [bgpParamsN_A_eq, one_mul]
      exact mul_nonneg (Real.exp_pos _).le
        (bGateU_pos bgpParamsN.L _ τ).le
    rw [abs_mul, abs_of_nonneg hker_nonneg]
    calc bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
        |((paper3HeadlineSolFamN wg) w).z τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i|
        ≤ Real.exp (-(200 * (bgpScale : ℝ) * τ)) * Bzu :=
          mul_le_mul (paper3N_uKernel_le_exp wg w hτ0 hτπ) (hzu τ hτ)
            (abs_nonneg _) (Real.exp_pos _).le
      _ = Bzu * Real.exp (-(200 * (bgpScale : ℝ) * τ)) := by ring
  have hEnvCont : Continuous fun τ : ℝ =>
      Bzu * Real.exp (-(200 * (bgpScale : ℝ) * τ)) :=
    continuous_const.mul
      (Real.continuous_exp.comp (continuous_const.mul continuous_id).neg)
  have hmono := intervalIntegral.integral_mono_on ht.1
    (hgc.abs.intervalIntegrable (μ := MeasureTheory.volume) 0 t)
    (hEnvCont.intervalIntegrable (μ := MeasureTheory.volume) 0 t) hpt
  have hmass : (∫ τ in (0 : ℝ)..t,
      Bzu * Real.exp (-(200 * (bgpScale : ℝ) * τ))) ≤
      Bzu / (200 * (bgpScale : ℝ)) := by
    rw [intervalIntegral.integral_const_mul]
    calc Bzu * ∫ τ in (0 : ℝ)..t,
          Real.exp (-(200 * (bgpScale : ℝ) * τ))
        ≤ Bzu * (1 / (200 * (bgpScale : ℝ))) :=
          mul_le_mul_of_nonneg_left (paper3NW_exp_mass_le hc ht.1) hBzu0
      _ = Bzu / (200 * (bgpScale : ℝ)) := by ring
  calc |((paper3HeadlineSolFamN wg) w).u t i -
        ((paper3HeadlineSolFamN wg) w).u 0 i|
      ≤ ∫ τ in (0 : ℝ)..t,
          |bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
              bGateU bgpParamsN.L
                (((paper3HeadlineSolFamN wg) w).μ τ) τ *
            (((paper3HeadlineSolFamN wg) w).z τ i -
              ((paper3HeadlineSolFamN wg) w).u τ i)| := hhold
    _ ≤ ∫ τ in (0 : ℝ)..t,
          Bzu * Real.exp (-(200 * (bgpScale : ℝ) * τ)) := hmono
    _ ≤ Bzu / (200 * (bgpScale : ℝ)) := hmass

/-- Forward total selector mass at the N family. -/
theorem paper3N_lam_sum_forward (wg w : ℕ) :
    ∀ t : ℝ, 0 ≤ t →
      (∑ v : UniversalLocalView,
        ((paper3HeadlineSolFamN wg) w).lam v t) = 1 := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  have hode : ∀ v : UniversalLocalView, ∀ t : ℝ, 0 ≤ t →
      HasDerivAt (((paper3HeadlineSolFamN wg) w).lam v)
        ((((1 + Real.cos t) / 2) ^ paper3HeadlineM *
              ((paper3HeadlineKappa : ℚ) : ℝ)) *
            (1 / (Fintype.card UniversalLocalView : ℝ) -
              ((paper3HeadlineSolFamN wg) w).lam v t)
          + (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQN wg : ℚ) : ℝ) *
                Real.exp (bgpParamsN.cα * t))) *
            ((paper3HeadlineSolFamN wg) w).lam v t *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                  (((paper3HeadlineSolFamN wg) w).u t)
                - ∑ u : UniversalLocalView,
                    ((paper3HeadlineSolFamN wg) w).lam u t *
                      universalPval paper3HeadlineEta paper3HeadlineEta_pos u
                        (((paper3HeadlineSolFamN wg) w).u t))) t := by
    intro v t ht
    simpa using ((paper3HeadlineSolFamN wg) w).lam_hasDeriv v t
      (selectorSchedule_domain_of_nonneg_structural t ht)
  have hsum0 : (∑ v : UniversalLocalView,
      ((paper3HeadlineSolFamN wg) w).lam v 0) = 1 := by
    have h0 := (paper3HeadlineSolFamN_initial_values wg w).2.2.1
    have hcard : (Fintype.card UniversalLocalView : ℝ) ≠ 0 := by
      exact_mod_cast Fintype.card_pos.ne'
    calc (∑ v : UniversalLocalView, ((paper3HeadlineSolFamN wg) w).lam v 0)
        = ∑ _v : UniversalLocalView,
            (1 : ℝ) / ((Fintype.card UniversalLocalView : ℚ) : ℝ) :=
          Finset.sum_congr rfl (fun v _ => by rw [h0 v])
      _ = (Fintype.card UniversalLocalView : ℝ) *
            ((1 : ℝ) / ((Fintype.card UniversalLocalView : ℚ) : ℝ)) := by
          rw [Finset.sum_const, Finset.card_univ, nsmul_eq_mul]
      _ = 1 := by
          push_cast
          field_simp
  exact replicator_sum_lam_eq_one
    (lam := fun v t => ((paper3HeadlineSolFamN wg) w).lam v t)
    (P := fun v t =>
      universalPval paper3HeadlineEta paper3HeadlineEta_pos v
        (((paper3HeadlineSolFamN wg) w).u t))
    (cr := fun t => ((1 + Real.cos t) / 2) ^ paper3HeadlineM *
      ((paper3HeadlineKappa : ℚ) : ℝ))
    (cg := fun t => ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
      (((paper3WarmGainQN wg : ℚ) : ℝ) *
        Real.exp (bgpParamsN.cα * t)))
    ((((continuous_const.add Real.continuous_cos).div_const 2).pow _).mul
      continuous_const)
    ((((continuous_const.add Real.continuous_sin).div_const 2).pow _).mul
      (continuous_const.mul
        (Real.continuous_exp.comp (continuous_const.mul continuous_id))))
    (fun v => ((paper3HeadlineSolFamN wg) w).cont_lam v)
    (fun v => universalPval_continuous_of_cont_u paper3HeadlineEta
      paper3HeadlineEta_pos v ((paper3HeadlineSolFamN wg) w).cont_u)
    hode hsum0

/-- Forward coordinatewise selector nonnegativity at the N family. -/
theorem paper3N_lam_nonneg_forward (wg w : ℕ) :
    ∀ v : UniversalLocalView, ∀ t : ℝ, 0 ≤ t →
      0 ≤ ((paper3HeadlineSolFamN wg) w).lam v t := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  have hode : ∀ v : UniversalLocalView, ∀ t : ℝ, 0 ≤ t →
      HasDerivAt (((paper3HeadlineSolFamN wg) w).lam v)
        ((((1 + Real.cos t) / 2) ^ paper3HeadlineM *
              ((paper3HeadlineKappa : ℚ) : ℝ)) *
            (1 / (Fintype.card UniversalLocalView : ℝ) -
              ((paper3HeadlineSolFamN wg) w).lam v t)
          + (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQN wg : ℚ) : ℝ) *
                Real.exp (bgpParamsN.cα * t))) *
            ((paper3HeadlineSolFamN wg) w).lam v t *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                  (((paper3HeadlineSolFamN wg) w).u t)
                - ∑ u : UniversalLocalView,
                    ((paper3HeadlineSolFamN wg) w).lam u t *
                      universalPval paper3HeadlineEta paper3HeadlineEta_pos u
                        (((paper3HeadlineSolFamN wg) w).u t))) t := by
    intro v t ht
    simpa using ((paper3HeadlineSolFamN wg) w).lam_hasDeriv v t
      (selectorSchedule_domain_of_nonneg_structural t ht)
  have hinit : ∀ v : UniversalLocalView,
      0 ≤ ((paper3HeadlineSolFamN wg) w).lam v 0 := by
    intro v
    rw [(paper3HeadlineSolFamN_initial_values wg w).2.2.1 v]
    have hcard : (0 : ℚ) < (Fintype.card UniversalLocalView : ℚ) := by
      exact_mod_cast Fintype.card_pos
    positivity
  exact replicator_lam_nonneg
    (lam := fun v t => ((paper3HeadlineSolFamN wg) w).lam v t)
    (P := fun v t =>
      universalPval paper3HeadlineEta paper3HeadlineEta_pos v
        (((paper3HeadlineSolFamN wg) w).u t))
    (cr := fun t => ((1 + Real.cos t) / 2) ^ paper3HeadlineM *
      ((paper3HeadlineKappa : ℚ) : ℝ))
    (cg := fun t => ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
      (((paper3WarmGainQN wg : ℚ) : ℝ) *
        Real.exp (bgpParamsN.cα * t)))
    ((((continuous_const.add Real.continuous_cos).div_const 2).pow _).mul
      continuous_const)
    ((((continuous_const.add Real.continuous_sin).div_const 2).pow _).mul
      (continuous_const.mul
        (Real.continuous_exp.comp (continuous_const.mul continuous_id))))
    (fun v => ((paper3HeadlineSolFamN wg) w).cont_lam v)
    (fun v => universalPval_continuous_of_cont_u paper3HeadlineEta
      paper3HeadlineEta_pos v ((paper3HeadlineSolFamN wg) w).cont_u)
    (fun t => mul_nonneg
      (pow_nonneg (by nlinarith [Real.neg_one_le_cos t]) _)
      (by norm_num [paper3HeadlineKappa]))
    hode hinit

/-- Simplex convexity reduction for the N mix target. -/
theorem paper3N_mixTarget_abs_le_of_branch_abs (wg w : ℕ)
    {t : ℝ} (ht : 0 ≤ t) {B : ℝ}
    (hbranch_abs : ∀ i : Fin d_U, ∀ v : UniversalLocalView,
      |BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFamN wg) w).u t) i| ≤ B) :
    ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam t i| ≤ B := by
  intro i
  simpa [selectorMixTarget, selectorF] using
    paper3N_abs_sum_weighted_le_of_simplex_and_abs_le
      (lam := fun v : UniversalLocalView =>
        ((paper3HeadlineSolFamN wg) w).lam v t)
      (a := fun v : UniversalLocalView =>
        BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFamN wg) w).u t) i)
      (fun v => paper3N_lam_nonneg_forward wg w v t ht)
      (paper3N_lam_sum_forward wg w t ht) (hbranch_abs i)

/-- Scalar relaxation trapping of the N `z` under a mix box. -/
theorem paper3N_z_abs_le_of_mix_abs_box (wg w : ℕ)
    {T Zbox : ℝ} (hT : 0 ≤ T)
    (hinit_abs : ∀ i : Fin d_U,
      |(((selectorInitX0 w i : ℚ) : ℝ))| ≤ Zbox)
    (hmix_abs : ∀ t, t ∈ Icc (0 : ℝ) T → ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam t i| ≤ Zbox) :
    ∀ t, t ∈ Icc (0 : ℝ) T → ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z t i| ≤ Zbox := by
  intro t ht i
  have hz0eq := (paper3HeadlineSolFamN_initial_values wg w).1 i
  have hmem : ((paper3HeadlineSolFamN wg) w).z t i ∈ Icc (-Zbox) Zbox := by
    refine scalar_relaxation_trapping_invariant
      (y := fun τ => ((paper3HeadlineSolFamN wg) w).z τ i)
      (g := fun τ =>
        selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam τ i)
      (k := fun τ =>
        bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateZ bgpParamsN.L
            (((paper3HeadlineSolFamN wg) w).μ τ) τ)
      (lo := -Zbox) (hi := Zbox) (T := t)
      ht.1
      (selector_replicator_gateZ_integrand_continuous
        ((paper3HeadlineSolFamN wg) w))
      (((paper3HeadlineSolFamN wg) w).cont_mixTarget i)
      ?_ ?_ ?_ ?_
    · intro τ hτ
      exact ((paper3HeadlineSolFamN wg) w).z_hasDeriv τ
        (selectorSchedule_domain_of_nonneg_structural τ hτ.1) i
    · intro τ hτ
      exact selector_replicator_gateZ_integrand_nonneg
        ((paper3HeadlineSolFamN wg) w)
        selectorSchedule_domain_of_nonneg_structural
        (by rw [bgpParamsN_A_eq]; norm_num) hτ.1
    · intro τ hτ
      exact abs_le.mp (hmix_abs τ ⟨hτ.1, le_trans hτ.2 ht.2⟩ i)
    · change ((paper3HeadlineSolFamN wg) w).z 0 i ∈ Icc (-Zbox) Zbox
      rw [hz0eq]
      exact abs_le.mp (hinit_abs i)
  exact abs_le.mpr hmem

/-- Under the maintained `1/3` warm-prefix u-tube, the N coupled pair stays
in a `5·D_U` box. -/
theorem paper3N_zu_box_of_third_utube (wg w : ℕ) {t : ℝ}
    (ht : t ∈ Icc (0 : ℝ) (Real.pi / 6))
    (htube : ∀ s ∈ Icc (0 : ℝ) t, ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).u s i -
        stackMachineEncodingU.enc (selectorInitConfig w) i| ≤ (1 / 3 : ℝ)) :
    ∀ s ∈ Icc (0 : ℝ) t, ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z s i -
        ((paper3HeadlineSolFamN wg) w).u s i| ≤ 5 * D_U := by
  have hmix : ∀ s, s ∈ Icc (0 : ℝ) t → ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam s i| ≤ 2 * D_U := by
    intro s hs
    exact paper3N_mixTarget_abs_le_of_branch_abs wg w hs.1
      (fun i v => branchU_evalBranch_abs_le_two_D_U_of_third_tube
        (fun j => htube s hs j) v i)
  have hz : ∀ s, s ∈ Icc (0 : ℝ) t → ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z s i| ≤ 2 * D_U :=
    paper3N_z_abs_le_of_mix_abs_box wg w ht.1
      (paper3N_init_z_abs_le_two_D_U w) hmix
  intro s hs i
  have h1 := hz s hs i
  have h2 := htube s hs i
  have h3 : |stackMachineEncodingU.enc (selectorInitConfig w) i| ≤
      2 * D_U := by
    rw [stackMachineEncodingU_enc_eq]
    exact paper3N_confEncU_abs_le_two_D_U (selectorInitConfig w) i
  have hD8 := paper3N_D_U_ge_eight
  rw [abs_le] at h1 h2 h3 ⊢
  constructor <;> [linarith [h1.1, h2.2, h3.2]; linarith [h1.2, h2.1, h3.1]]

/-- The N kernel mass beats the `5·D_U` box with a `1/6 < 1/3` margin. -/
theorem paper3N_drift_le_sixth (wg : ℕ) :
    5 * D_U / (200 * (bgpScale : ℝ)) ≤ 1 / 6 := by
  have hD := D_U_le_two_bgpScale
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  rw [div_le_iff₀ (by nlinarith : (0 : ℝ) < 200 * (bgpScale : ℝ))]
  nlinarith

/-- **The N warm-prefix `1/3`-tube bootstrap**: on `[0, π/6]` the N-family
`u` stays within `1/3` of its exact initial encoding. -/
theorem paper3N_warm_prefix_utube (wg w : ℕ) :
    ∀ t ∈ Icc (0 : ℝ) (Real.pi / 6), ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).u t i -
        stackMachineEncodingU.enc (selectorInitConfig w) i| ≤ (1 / 3 : ℝ) := by
  classical
  have hu0 : ∀ i : Fin d_U,
      ((paper3HeadlineSolFamN wg) w).u 0 i =
        stackMachineEncodingU.enc (selectorInitConfig w) i := by
    intro i
    rw [(paper3HeadlineSolFamN_initial_values wg w).2.1 i]
    exact selectorInitX0_cast_enc w i
  by_contra hcon
  push_neg at hcon
  obtain ⟨tb, htb, i0, hi0⟩ := hcon
  set Bad : Set ℝ := Icc (0 : ℝ) tb ∩
    ⋃ i : Fin d_U, {s : ℝ |
      (1 / 3 : ℝ) ≤ |((paper3HeadlineSolFamN wg) w).u s i -
        stackMachineEncodingU.enc (selectorInitConfig w) i|} with hBadDef
  have hclosed : IsClosed Bad := by
    refine isClosed_Icc.inter (isClosed_iUnion_of_finite fun i => ?_)
    exact isClosed_le continuous_const
      (((((paper3HeadlineSolFamN wg) w).cont_u i).sub
        continuous_const).abs)
  have htb_mem : tb ∈ Bad :=
    ⟨⟨htb.1, le_refl tb⟩, Set.mem_iUnion.mpr ⟨i0, hi0.le⟩⟩
  have hne : Bad.Nonempty := ⟨tb, htb_mem⟩
  have hbdd : BddBelow Bad := ⟨0, fun s hs => hs.1.1⟩
  have htmem : sInf Bad ∈ Bad := hclosed.csInf_mem hne hbdd
  have ht0 : 0 ≤ sInf Bad := le_csInf hne fun b hb => hb.1.1
  have htle : sInf Bad ≤ tb := csInf_le hbdd htb_mem
  have htπ : sInf Bad ≤ Real.pi / 6 := le_trans htle htb.2
  have htpos : 0 < sInf Bad := by
    rcases lt_or_eq_of_le ht0 with h | h
    · exact h
    · exfalso
      obtain ⟨i, hi⟩ := Set.mem_iUnion.mp htmem.2
      rw [← h] at hi
      simp only [Set.mem_setOf_eq] at hi
      rw [hu0 i, sub_self, abs_zero] at hi
      linarith
  have htube : ∀ s ∈ Icc (0 : ℝ) (sInf Bad), ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).u s i -
        stackMachineEncodingU.enc (selectorInitConfig w) i| ≤ (1 / 3 : ℝ) := by
    intro s hs i
    rcases lt_or_eq_of_le hs.2 with hlt | heq
    · by_contra hgt
      push_neg at hgt
      have hmem : s ∈ Bad :=
        ⟨⟨hs.1, le_trans hs.2 htle⟩, Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
      exact absurd (csInf_le hbdd hmem) (not_le.mpr hlt)
    · have hf : Continuous fun τ : ℝ =>
          |((paper3HeadlineSolFamN wg) w).u τ i -
            stackMachineEncodingU.enc (selectorInitConfig w) i| :=
        ((((paper3HeadlineSolFamN wg) w).cont_u i).sub
          continuous_const).abs
      have hev : ∀ᶠ τ in nhdsWithin (sInf Bad) (Set.Iio (sInf Bad)),
          |((paper3HeadlineSolFamN wg) w).u τ i -
            stackMachineEncodingU.enc (selectorInitConfig w) i| ≤
            (1 / 3 : ℝ) := by
        filter_upwards [Ioo_mem_nhdsLT htpos] with τ hτ
        by_contra hgt
        push_neg at hgt
        have hmem : τ ∈ Bad :=
          ⟨⟨hτ.1.le, le_trans hτ.2.le htle⟩,
            Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
        exact absurd (csInf_le hbdd hmem) (not_le.mpr hτ.2)
      have hlim := le_of_tendsto
        (hf.continuousWithinAt
          (s := Set.Iio (sInf Bad)) (x := sInf Bad)) hev
      rw [heq]
      exact hlim
  obtain ⟨i, hi⟩ := Set.mem_iUnion.mp htmem.2
  simp only [Set.mem_setOf_eq] at hi
  have hzu := paper3N_zu_box_of_third_utube wg w ⟨ht0, htπ⟩ htube
  have hD8 := paper3N_D_U_ge_eight
  have hdrift := paper3N_u_drift_on_warm_prefix wg w i
    (by linarith : (0 : ℝ) ≤ 5 * D_U) ⟨ht0, htπ⟩
    (fun τ hτ => hzu τ hτ i)
  rw [hu0 i] at hdrift
  have hsixth := paper3N_drift_le_sixth wg
  linarith [hi, hdrift, hsixth]

/-- Shifted mass of a decaying exponential kernel:
`∫ₐᵗ e^{−c·τ} dτ ≤ e^{−c·a}/c`. -/
theorem paper3N_exp_mass_from_le {c : ℝ} (hc : 0 < c) {a t : ℝ}
    (hat : a ≤ t) :
    (∫ τ in a..t, Real.exp (-(c * τ))) ≤ Real.exp (-(c * a)) / c := by
  have hcont : Continuous fun τ : ℝ => Real.exp (-(c * τ)) :=
    Real.continuous_exp.comp (continuous_const.mul continuous_id).neg
  have hderiv : ∀ τ ∈ Set.uIcc a t,
      HasDerivAt (fun s : ℝ => -(Real.exp (-(c * s)) / c))
        (Real.exp (-(c * τ))) τ := by
    intro τ _
    have h1 : HasDerivAt (fun s : ℝ => -(c * s)) (-c) τ := by
      simpa using ((hasDerivAt_id τ).const_mul c).neg
    have h2 : HasDerivAt (fun s : ℝ => Real.exp (-(c * s)))
        (Real.exp (-(c * τ)) * -c) τ := h1.exp
    have h3 := (h2.div_const c).neg
    have hsimp : -(Real.exp (-(c * τ)) * -c / c) = Real.exp (-(c * τ)) := by
      field_simp
    rw [← hsimp]
    exact h3
  have heq := intervalIntegral.integral_eq_sub_of_hasDerivAt hderiv
    (hcont.intervalIntegrable a t)
  rw [heq]
  have h3 : 0 < Real.exp (-(c * t)) / c := div_pos (Real.exp_pos _) hc
  linarith

/-- Interval form of the scalar relaxation trapping invariant (base point
`a` instead of `0`), by time shift. -/
theorem paper3N_trapping_on_Icc
    (y g k : ℝ → ℝ) {lo hi a T : ℝ}
    (haT : a ≤ T)
    (hk_cont : Continuous k) (hg_cont : Continuous g)
    (hy_ode : ∀ τ ∈ Icc a T, HasDerivAt y (k τ * (g τ - y τ)) τ)
    (hk_nonneg : ∀ τ ∈ Icc a T, 0 ≤ k τ)
    (hg_range : ∀ τ ∈ Icc a T, g τ ∈ Icc lo hi)
    (hya : y a ∈ Icc lo hi) :
    y T ∈ Icc lo hi := by
  have hode' : ∀ σ ∈ Icc (0 : ℝ) (T - a),
      HasDerivAt (fun σ' : ℝ => y (a + σ'))
        (k (a + σ) * (g (a + σ) - y (a + σ))) σ := by
    intro σ hσ
    have hmem : a + σ ∈ Icc a T := ⟨by linarith [hσ.1], by linarith [hσ.2]⟩
    have h1 : HasDerivAt (fun σ' : ℝ => a + σ') 1 σ := by
      simpa using (hasDerivAt_id σ).const_add a
    have h2 := (hy_ode (a + σ) hmem).comp σ h1
    simpa [Function.comp] using h2
  have hknn' : ∀ σ ∈ Icc (0 : ℝ) (T - a), 0 ≤ k (a + σ) := by
    intro σ hσ
    exact hk_nonneg (a + σ) ⟨by linarith [hσ.1], by linarith [hσ.2]⟩
  have hgr' : ∀ σ ∈ Icc (0 : ℝ) (T - a), g (a + σ) ∈ Icc lo hi := by
    intro σ hσ
    exact hg_range (a + σ) ⟨by linarith [hσ.1], by linarith [hσ.2]⟩
  have hy0' : y (a + 0) ∈ Icc lo hi := by simpa using hya
  have hshift := scalar_relaxation_trapping_invariant
    (fun σ => y (a + σ)) (fun σ => g (a + σ)) (fun σ => k (a + σ))
    (lo := lo) (hi := hi) (T := T - a)
    (by linarith)
    (hk_cont.comp (continuous_const.add continuous_id))
    (hg_cont.comp (continuous_const.add continuous_id))
    hode' hknn' hgr' hy0'
  simpa [show a + (T - a) = T from by ring] using hshift

/-- Pointwise u-kernel bound on the write window at the N rates: `sin ≥ 1/2`
gives `qPulse ≥ 3/4` at `L = 1`, hence
`A·α·bGateU ≤ e^{−450·bgpScale·τ}`. -/
theorem paper3N_writeWindow_uKernel_le_exp (wg w j : ℕ) {τ : ℝ}
    (h1 : selectorMUWriteStartTime j ≤ τ)
    (h2 : τ ≤ selectorMUWriteReadTime j) :
    bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
        bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ ≤
      Real.exp (-(450 * (bgpScale : ℝ) * τ)) := by
  have hτ0 : 0 ≤ τ := le_trans (selectorMUWriteStartTime_nonneg j) h1
  have hα := paper3HeadlineSolFamN_alpha wg w hτ0
  have hμ := paper3HeadlineSolFamN_mu wg w hτ0
  rw [hα, hμ]
  simp only [bgpParamsN_A_eq, one_mul, bgpParamsN_L_eq]
  unfold bGateU qPulse
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  have hsin : (1 : ℝ) / 2 ≤ Real.sin τ :=
    sin_window_ge j (by simpa [selectorMUWriteStartTime] using h1)
      (by simpa [selectorMUWriteReadTime] using h2)
  have hq : (3 : ℝ) / 4 ≤ ((1 + Real.sin τ) / 2) ^ 1 := by
    rw [pow_one]; linarith
  have hsW : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  rw [bgpParamsN_cα_def, bgpParamsN_cμ_def]
  nlinarith [mul_le_mul_of_nonneg_left hq
    (mul_nonneg (mul_nonneg (by norm_num : (0 : ℝ) ≤ 1000) hsW.le) hτ0),
    mul_nonneg hsW.le hτ0]

/-- Integral-form u-freeze on the write window prefix `[ws j, t]`. -/
theorem paper3N_u_drift_on_write_window (wg w j : ℕ) (i : Fin d_U)
    {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) {t : ℝ}
    (ht : t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteReadTime j))
    (hzu : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t,
      |((paper3HeadlineSolFamN wg) w).z τ i -
        ((paper3HeadlineSolFamN wg) w).u τ i| ≤ Bzu) :
    |((paper3HeadlineSolFamN wg) w).u t i -
        ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i| ≤
      Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
          selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) := by
  have hsW : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hc : (0 : ℝ) < 450 * (bgpScale : ℝ) := by nlinarith
  have hws0 : 0 ≤ selectorMUWriteStartTime j :=
    selectorMUWriteStartTime_nonneg j
  have hgate_cont : Continuous fun τ : ℝ =>
      bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
    unfold bGateU
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamN wg) w).cont_μ.mul
        (qPulse_continuous bgpParamsN.L)).neg)
  have hgc : Continuous fun τ : ℝ =>
      bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
        (((paper3HeadlineSolFamN wg) w).z τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i) :=
    ((continuous_const.mul ((paper3HeadlineSolFamN wg) w).cont_α).mul
        hgate_cont).mul
      ((((paper3HeadlineSolFamN wg) w).cont_z i).sub
        (((paper3HeadlineSolFamN wg) w).cont_u i))
  have hy : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t,
      HasDerivAt (fun s => ((paper3HeadlineSolFamN wg) w).u s i)
        (bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
            bGateU bgpParamsN.L
              (((paper3HeadlineSolFamN wg) w).μ τ) τ *
          (((paper3HeadlineSolFamN wg) w).z τ i -
            ((paper3HeadlineSolFamN wg) w).u τ i)) τ :=
    fun τ hτ => ((paper3HeadlineSolFamN wg) w).u_hasDeriv τ
      (selectorSchedule_domain_of_nonneg_structural τ (le_trans hws0 hτ.1)) i
  have hhold := hold_bound_integral
    (fun s => ((paper3HeadlineSolFamN wg) w).u s i)
    (fun τ => bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
        bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
      (((paper3HeadlineSolFamN wg) w).z τ i -
        ((paper3HeadlineSolFamN wg) w).u τ i))
    (selectorMUWriteStartTime j) t ht.1 hgc hy
  have hpt : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t,
      |bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
        (((paper3HeadlineSolFamN wg) w).z τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i)| ≤
      Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ)) := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans hws0 hτ.1
    have hτwin : τ ≤ selectorMUWriteReadTime j := le_trans hτ.2 ht.2
    have hker_nonneg : 0 ≤
        bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateU bgpParamsN.L
            (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
      have hα := paper3HeadlineSolFamN_alpha wg w hτ0
      rw [hα]
      simp only [bgpParamsN_A_eq, one_mul]
      exact mul_nonneg (Real.exp_pos _).le
        (bGateU_pos bgpParamsN.L _ τ).le
    rw [abs_mul, abs_of_nonneg hker_nonneg]
    calc bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
        |((paper3HeadlineSolFamN wg) w).z τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i|
        ≤ Real.exp (-(450 * (bgpScale : ℝ) * τ)) * Bzu :=
          mul_le_mul (paper3N_writeWindow_uKernel_le_exp wg w j hτ.1 hτwin)
            (hzu τ hτ) (abs_nonneg _) (Real.exp_pos _).le
      _ = Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ)) := by ring
  have hEnvCont : Continuous fun τ : ℝ =>
      Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ)) :=
    continuous_const.mul
      (Real.continuous_exp.comp (continuous_const.mul continuous_id).neg)
  have hmono := intervalIntegral.integral_mono_on ht.1
    (hgc.abs.intervalIntegrable (μ := MeasureTheory.volume)
      (selectorMUWriteStartTime j) t)
    (hEnvCont.intervalIntegrable (μ := MeasureTheory.volume)
      (selectorMUWriteStartTime j) t) hpt
  have hmass : (∫ τ in (selectorMUWriteStartTime j)..t,
      Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ))) ≤
      Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
          selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) := by
    rw [intervalIntegral.integral_const_mul]
    exact mul_le_mul_of_nonneg_left
      (paper3N_exp_mass_from_le hc ht.1) hBzu0
  calc |((paper3HeadlineSolFamN wg) w).u t i -
        ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i|
      ≤ ∫ τ in (selectorMUWriteStartTime j)..t,
          |bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
              bGateU bgpParamsN.L
                (((paper3HeadlineSolFamN wg) w).μ τ) τ *
            (((paper3HeadlineSolFamN wg) w).z τ i -
              ((paper3HeadlineSolFamN wg) w).u τ i)| := hhold
    _ ≤ ∫ τ in (selectorMUWriteStartTime j)..t,
          Bzu * Real.exp (-(450 * (bgpScale : ℝ) * τ)) := hmono
    _ ≤ Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
          selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) := hmass

/-- The write-window u-freeze is below `1/8` for every window-envelope-sized
box (`Bzu ≤ bgpScale·(e^{199}+11)`): the settled exponent
`450·bgpScale·ws j ≥ 75π·bgpScale ≥ 900` annihilates everything. -/
theorem paper3N_writeWindow_drift_le_eighth (j : ℕ) {Bzu : ℝ}
    (hBzu0 : 0 ≤ Bzu)
    (hBzu : Bzu ≤ (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 11)) :
    Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
        selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) ≤ 1 / 8 := by
  have hs4 : (4 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_four
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hπ3 : (3 : ℝ) ≤ Real.pi := by
    have := Real.pi_gt_three
    linarith
  have hws : Real.pi / 6 ≤ selectorMUWriteStartTime j := by
    unfold selectorMUWriteStartTime
    have h2πj : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) := by positivity
    linarith
  have hexp1 : (225 : ℝ) * (bgpScale : ℝ) ≤
      450 * (bgpScale : ℝ) * selectorMUWriteStartTime j := by
    have hmul := mul_le_mul_of_nonneg_left hws
      (by positivity : (0 : ℝ) ≤ 450 * (bgpScale : ℝ))
    nlinarith [hmul]
  have hE : Real.exp (-(450 * (bgpScale : ℝ) *
      selectorMUWriteStartTime j)) ≤
      Real.exp (-(225 * (bgpScale : ℝ))) := by
    apply Real.exp_le_exp.mpr
    linarith
  have hB : Bzu / (450 * (bgpScale : ℝ)) ≤ Real.exp (199 : ℝ) := by
    rw [div_le_iff₀ (by positivity)]
    have hexp199 : (11 : ℝ) ≤ Real.exp (199 : ℝ) := by
      have := Real.add_one_le_exp (199 : ℝ)
      linarith
    calc Bzu ≤ (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 11) := hBzu
      _ ≤ (bgpScale : ℝ) * (450 * Real.exp (199 : ℝ)) := by nlinarith
      _ = Real.exp (199 : ℝ) * (450 * (bgpScale : ℝ)) := by ring
  have hcomb : Bzu * (Real.exp (-(450 * (bgpScale : ℝ) *
      selectorMUWriteStartTime j)) / (450 * (bgpScale : ℝ))) =
      (Bzu / (450 * (bgpScale : ℝ))) *
        Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime j)) := by
    ring
  rw [hcomb]
  calc (Bzu / (450 * (bgpScale : ℝ))) *
        Real.exp (-(450 * (bgpScale : ℝ) * selectorMUWriteStartTime j))
      ≤ Real.exp (199 : ℝ) * Real.exp (-(225 * (bgpScale : ℝ))) :=
        mul_le_mul hB hE (Real.exp_pos _).le (Real.exp_pos _).le
    _ = Real.exp (199 - 225 * (bgpScale : ℝ)) := by
        rw [← Real.exp_add]
        ring_nf
    _ ≤ Real.exp (-(701 : ℝ)) := by
        apply Real.exp_le_exp.mpr
        nlinarith
    _ ≤ 1 / 8 := by
        have h8 : (8 : ℝ) ≤ Real.exp (701 : ℝ) := by
          have := Real.add_one_le_exp (701 : ℝ)
          linarith
        have hpos := Real.exp_pos (701 : ℝ)
        rw [Real.exp_neg, inv_eq_one_div,
          div_le_div_iff₀ hpos (by norm_num : (0 : ℝ) < 8)]
        linarith

/-- **F1-N DECOMPOSED ANALYTIC INPUT (1/5): the within-window relaxation
bootstrap at N rates and `bgpScale`-scaled hulls.**  The `bgpParams38`
sibling's route (docstring of `paper3F1_window_relaxation_bootstrap`)
transfers verbatim with rate `450·bgpScale`
(`u_drift_on_write_prefix_window_N` / `u_drift_on_settled_window_N`) and the
branch-eval hull `|evalBranch| ≤ B_U·|u| + O(D_U) ≤ bgpScale·e^{198}` — the
scaled hull is what makes this statement N-sound (`D_U ≤ 2·bgpScale`). -/
theorem paper3F1_window_relaxation_bootstrap_N (wg w : ℕ)
    (hdiag : wg = w := by first | rfl | assumption) :
    ∀ (j : ℕ) (E : ℝ), 0 ≤ E →
      E ≤ (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) →
      (∀ i, paper3F1BoundaryErrN wg w j i ≤ r_LE_U) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i| ≤
          E) →
      ∀ i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamN wg) w).z t i -
          ((paper3HeadlineSolFamN wg) w).u t i| ≤
          max E ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ) := by
  classical
  intro j E hE0 hEle htube0 hE
  have hs4 : (4 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_four
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hD8 := paper3N_D_U_ge_eight
  have hDle := D_U_le_two_bgpScale
  have h198 : (199 : ℝ) ≤ Real.exp (198 : ℝ) := by
    linarith [Real.add_one_le_exp (198 : ℝ)]
  have hws0 : 0 ≤ selectorMUWriteStartTime j :=
    selectorMUWriteStartTime_nonneg j
  set L : ℝ := max E ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ)
    with hLdef
  have hmaxE := le_max_left E ((bgpScale : ℝ) * Real.exp (198 : ℝ))
  have hmaxS := le_max_right E ((bgpScale : ℝ) * Real.exp (198 : ℝ))
  have hL0 : 0 ≤ L := by
    rw [hLdef]
    nlinarith [hmaxE, hE0, hs0]
  have hLle : L ≤ (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 11) := by
    have hexpm : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) + 10 := by
      have := Real.exp_le_exp.mpr (by norm_num : (198 : ℝ) ≤ 199)
      linarith
    have h1 : (bgpScale : ℝ) * Real.exp (198 : ℝ) ≤
        (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by nlinarith
    have hmax := max_le hEle h1
    rw [hLdef]
    nlinarith [hmax]
  have htube0' : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U := by
    intro i
    have h := htube0 i
    unfold paper3F1BoundaryErrN at h
    exact h
  have henc : ∀ i : Fin d_U,
      |stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ 2 * D_U := by
    intro i
    rw [stackMachineEncodingU_enc_eq]
    exact paper3N_confEncU_abs_le_two_D_U _ i
  -- the conditional interior estimate: under the `L`-box up to `t`, the
  -- coupled pair actually sits `bgpScale/2`-deep inside the exit level
  have hcore : ∀ t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
      (∀ τ ∈ Icc (selectorMUWriteStartTime j) t, ∀ i : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).z τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i| ≤ L) →
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).z t i -
          ((paper3HeadlineSolFamN wg) w).u t i| ≤
          max E ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + 1 / 2 := by
    intro t ht hbox
    have hdrift : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t, ∀ i : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).u τ i -
          ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i| ≤
          1 / 8 := by
      intro τ hτ i
      have hτwin : τ ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteReadTime j) := ⟨hτ.1, le_trans hτ.2 ht.2⟩
      have hd := paper3N_u_drift_on_write_window wg w j i hL0 hτwin
        (fun σ hσ => hbox σ ⟨hσ.1, le_trans hσ.2 hτ.2⟩ i)
      exact le_trans hd (paper3N_writeWindow_drift_le_eighth j hL0 hLle)
    have hutube : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t, ∀ i : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).u τ i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ (1 / 3 : ℝ) := by
      intro τ hτ i
      have h1 := hdrift τ hτ i
      have h2 := htube0' i
      have hrv : r_LE_U = 1 / 1000 := rfl
      calc |((paper3HeadlineSolFamN wg) w).u τ i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i|
          ≤ |((paper3HeadlineSolFamN wg) w).u τ i -
              ((paper3HeadlineSolFamN wg) w).u
                (selectorMUWriteStartTime j) i| +
            |((paper3HeadlineSolFamN wg) w).u
                (selectorMUWriteStartTime j) i -
              stackMachineEncodingU.enc (paper3F1Cfg w j) i| :=
            abs_sub_le _ _ _
        _ ≤ 1 / 8 + r_LE_U := add_le_add h1 h2
        _ ≤ 1 / 3 := by rw [hrv]; norm_num
    have hmix : ∀ τ ∈ Icc (selectorMUWriteStartTime j) t, ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
            ((paper3HeadlineSolFamN wg) w).lam τ i| ≤ 2 * D_U := by
      intro τ hτ
      exact paper3N_mixTarget_abs_le_of_branch_abs wg w
        (le_trans hws0 hτ.1)
        (fun i v => branchU_evalBranch_abs_le_two_D_U_of_third_tube
          (fun k => hutube τ hτ k) v i)
    intro i
    have hzt : ((paper3HeadlineSolFamN wg) w).z t i ∈
        Icc (min (((paper3HeadlineSolFamN wg) w).z
              (selectorMUWriteStartTime j) i) (-(2 * D_U)))
          (max (((paper3HeadlineSolFamN wg) w).z
              (selectorMUWriteStartTime j) i) (2 * D_U)) := by
      refine paper3N_trapping_on_Icc
        (fun τ => ((paper3HeadlineSolFamN wg) w).z τ i)
        (fun τ => selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam τ i)
        (fun τ => bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateZ bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ)
        (a := selectorMUWriteStartTime j) (T := t) ht.1
        (selector_replicator_gateZ_integrand_continuous
          ((paper3HeadlineSolFamN wg) w))
        (((paper3HeadlineSolFamN wg) w).cont_mixTarget i)
        ?_ ?_ ?_ ?_
      · intro τ hτ
        exact ((paper3HeadlineSolFamN wg) w).z_hasDeriv τ
          (selectorSchedule_domain_of_nonneg_structural τ
            (le_trans hws0 hτ.1)) i
      · intro τ hτ
        exact selector_replicator_gateZ_integrand_nonneg
          ((paper3HeadlineSolFamN wg) w)
          selectorSchedule_domain_of_nonneg_structural
          (by rw [bgpParamsN_A_eq]; norm_num) (le_trans hws0 hτ.1)
      · intro τ hτ
        have hm := abs_le.mp (hmix τ hτ i)
        exact ⟨le_trans (min_le_right _ _) (by linarith [hm.1]),
          le_trans hm.2 (le_max_right _ _)⟩
      · exact ⟨min_le_left _ _, le_max_left _ _⟩
    have hut := hdrift t ⟨ht.1, le_refl t⟩ i
    have hEi := hE i
    have htubei := htube0' i
    have henci := henc i
    have hrv : r_LE_U = 1 / 1000 := rfl
    rw [abs_le] at hut hEi htubei henci
    have hbig : 4 * D_U + r_LE_U + 1 / 8 + 1 / 8 ≤
        (bgpScale : ℝ) * Real.exp (198 : ℝ) + 1 / 2 := by
      rw [hrv]
      nlinarith [h198, hDle, hs4, hs0]
    rw [abs_le]
    constructor
    · have hzlo := hzt.1
      rcases le_total (((paper3HeadlineSolFamN wg) w).z
          (selectorMUWriteStartTime j) i) (-(2 * D_U)) with hcase | hcase
      · rw [min_eq_left hcase] at hzlo
        nlinarith [hEi.1, hut.2, hmaxE]
      · rw [min_eq_right hcase] at hzlo
        nlinarith [hut.2, htubei.2, henci.2, hmaxS, hbig]
    · have hzhi := hzt.2
      rcases le_total (((paper3HeadlineSolFamN wg) w).z
          (selectorMUWriteStartTime j) i) (2 * D_U) with hcase | hcase
      · rw [max_eq_right hcase] at hzhi
        nlinarith [hut.1, htubei.1, henci.1, hmaxS, hbig]
      · rw [max_eq_left hcase] at hzhi
        nlinarith [hEi.2, hut.1, hmaxE]
  -- the first-exit bootstrap at level `L`
  have htubeL : ∀ t' ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j), ∀ i' : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z t' i' -
        ((paper3HeadlineSolFamN wg) w).u t' i'| ≤ L := by
    by_contra hcon
    push_neg at hcon
    obtain ⟨tb, htb, i0, hi0⟩ := hcon
    set Bad : Set ℝ := Icc (selectorMUWriteStartTime j) tb ∩
      ⋃ i' : Fin d_U, {τ : ℝ |
        L ≤ |((paper3HeadlineSolFamN wg) w).z τ i' -
          ((paper3HeadlineSolFamN wg) w).u τ i'|} with hBadDef
    have hclosed : IsClosed Bad := by
      refine isClosed_Icc.inter (isClosed_iUnion_of_finite fun i' => ?_)
      exact isClosed_le continuous_const
        (((((paper3HeadlineSolFamN wg) w).cont_z i').sub
          (((paper3HeadlineSolFamN wg) w).cont_u i')).abs)
    have htb_mem : tb ∈ Bad :=
      ⟨⟨htb.1, le_refl tb⟩, Set.mem_iUnion.mpr ⟨i0, hi0.le⟩⟩
    have hne : Bad.Nonempty := ⟨tb, htb_mem⟩
    have hbdd : BddBelow Bad := ⟨selectorMUWriteStartTime j,
      fun s hs => hs.1.1⟩
    have htmem : sInf Bad ∈ Bad := hclosed.csInf_mem hne hbdd
    have htws : selectorMUWriteStartTime j ≤ sInf Bad :=
      le_csInf hne fun b hb => hb.1.1
    have htle : sInf Bad ≤ tb := csInf_le hbdd htb_mem
    have htwin : sInf Bad ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j) := ⟨htws, le_trans htle htb.2⟩
    have htpos : selectorMUWriteStartTime j < sInf Bad := by
      rcases lt_or_eq_of_le htws with h | h
      · exact h
      · exfalso
        obtain ⟨i', hi'⟩ := Set.mem_iUnion.mp htmem.2
        rw [← h] at hi'
        simp only [Set.mem_setOf_eq] at hi'
        have := hE i'
        rw [hLdef] at hi'
        nlinarith [hmaxE, hs4]
    have hboxstar : ∀ τ ∈ Icc (selectorMUWriteStartTime j) (sInf Bad),
        ∀ i' : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).z τ i' -
          ((paper3HeadlineSolFamN wg) w).u τ i'| ≤ L := by
      intro τ hτ i'
      rcases lt_or_eq_of_le hτ.2 with hlt | heq
      · by_contra hgt
        push_neg at hgt
        have hmem : τ ∈ Bad :=
          ⟨⟨hτ.1, le_trans hτ.2 htle⟩, Set.mem_iUnion.mpr ⟨i', hgt.le⟩⟩
        exact absurd (csInf_le hbdd hmem) (not_le.mpr hlt)
      · have hf : Continuous fun σ : ℝ =>
            |((paper3HeadlineSolFamN wg) w).z σ i' -
              ((paper3HeadlineSolFamN wg) w).u σ i'| :=
          (((((paper3HeadlineSolFamN wg) w).cont_z i').sub
            (((paper3HeadlineSolFamN wg) w).cont_u i'))).abs
        have hev : ∀ᶠ σ in nhdsWithin (sInf Bad) (Set.Iio (sInf Bad)),
            |((paper3HeadlineSolFamN wg) w).z σ i' -
              ((paper3HeadlineSolFamN wg) w).u σ i'| ≤ L := by
          filter_upwards [Ioo_mem_nhdsLT htpos] with σ hσ
          by_contra hgt
          push_neg at hgt
          have hmem : σ ∈ Bad :=
            ⟨⟨hσ.1.le, le_trans hσ.2.le htle⟩,
              Set.mem_iUnion.mpr ⟨i', hgt.le⟩⟩
          exact absurd (csInf_le hbdd hmem) (not_le.mpr hσ.2)
        have hlim := le_of_tendsto
          (hf.continuousWithinAt
            (s := Set.Iio (sInf Bad)) (x := sInf Bad)) hev
        rw [heq]
        exact hlim
    obtain ⟨i', hi'⟩ := Set.mem_iUnion.mp htmem.2
    simp only [Set.mem_setOf_eq] at hi'
    have hval := hcore (sInf Bad) htwin hboxstar i'
    rw [hLdef] at hi'
    nlinarith [hval, hs4]
  intro i t ht
  exact htubeL t ht i

/-- **F1-N DECOMPOSED ANALYTIC INPUT (2/5): the crude cycle-`0` write-start
endpoint at the scaled hull.**  `u(0) = z(0) = enc(cfg 0)` exactly
(`paper3HeadlineSolFamN_initial_values`); on `[0, π/6]` the coupled pair
stays within an `O(D_U) = O(bgpScale)` hull of the initial encoding (all
branch evaluations are `O(bgpScale)`-bounded near the encoding), so any
`O(bgpScale)` estimate lands below `bgpScale·e^{199}`.  Do NOT use the
`Classical.choose` finite-horizon box (`ZUFiniteCoordBound`) — it carries no
quantitative bound. -/
theorem paper3F1_cycle0_endpoint_N (wg w : ℕ)
    (hdiag : wg = w := by first | rfl | assumption) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime 0) i -
        ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime 0) i| ≤
        (bgpScale : ℝ) * Real.exp (199 : ℝ) := by
  intro i
  have hπ0 : (0 : ℝ) ≤ Real.pi / 6 := by linarith [Real.pi_pos]
  have hπ6 : (Real.pi / 6) ∈ Icc (0 : ℝ) (Real.pi / 6) := ⟨hπ0, le_refl _⟩
  have htube := paper3N_warm_prefix_utube wg w
  have hzu := paper3N_zu_box_of_third_utube wg w hπ6
    (fun s hs j => htube s hs j)
  have hws : selectorMUWriteStartTime 0 = Real.pi / 6 := by
    unfold selectorMUWriteStartTime
    norm_num
  rw [hws]
  have hbox := hzu (Real.pi / 6) hπ6 i
  have hD := D_U_le_two_bgpScale
  have hexp : (10 : ℝ) ≤ Real.exp (199 : ℝ) := by
    have := Real.add_one_le_exp (199 : ℝ)
    linarith
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  calc |((paper3HeadlineSolFamN wg) w).z (Real.pi / 6) i -
        ((paper3HeadlineSolFamN wg) w).u (Real.pi / 6) i|
      ≤ 5 * D_U := hbox
    _ ≤ 10 * (bgpScale : ℝ) := by linarith
    _ ≤ (bgpScale : ℝ) * Real.exp (199 : ℝ) := by nlinarith

/-! **F1-N (3/5) support toolbox** (retiming pass): the interval sine cap on
`[wr j, U0 j]`, the halfphase z-integrand growth cap, the STRONG pointwise
u-active kernel floor (the banked `selectorInterReadUActiveMassLowerN` is
`exp(300·start − 250·end)` — useless at small `j`), the early-piece
double-exponential arithmetic, and the no-slop prewrite trapping. -/

/-- `sin ≤ 1/2` on `[2πj + 5π/6, 2πj + 7π/6]` (read time to u-active
start). -/
theorem paper3N_sin_le_half_interRead (j : ℕ) {t : ℝ}
    (h1 : selectorMUWriteReadTime j ≤ t)
    (h2 : t ≤ selectorMUUActiveStart j) :
    Real.sin t ≤ 1 / 2 := by
  unfold selectorMUWriteReadTime at h1
  unfold selectorMUUActiveStart at h2
  have hπ := Real.pi_pos
  have hteq : t = (t - 2 * Real.pi * j) + (j : ℕ) * (2 * Real.pi) := by
    push_cast
    ring
  have hsin : Real.sin t = Real.sin (t - 2 * Real.pi * j) := by
    conv_lhs => rw [hteq]
    rw [Real.sin_add_nat_mul_two_pi]
  rw [hsin]
  set x := t - 2 * Real.pi * (j : ℝ) with hx
  have hx1 : 5 * Real.pi / 6 ≤ x := by
    simp only [hx]
    linarith
  have hx2 : x ≤ 7 * Real.pi / 6 := by
    simp only [hx]
    linarith
  have hcos : Real.sin x = Real.cos (x - Real.pi / 2) := by
    rw [show x - Real.pi / 2 = -(Real.pi / 2 - x) by ring, Real.cos_neg,
      Real.cos_pi_div_two_sub]
  rw [hcos]
  calc Real.cos (x - Real.pi / 2)
      ≤ Real.cos (Real.pi / 3) :=
        Real.cos_le_cos_of_nonneg_of_le_pi (by linarith) (by linarith)
          (by linarith)
    _ = 1 / 2 := Real.cos_pi_div_three

/-- Halfphase z-integrand growth cap at N rates: where `sin ≤ 1/2`,
`rPulse ≥ 1/4` at `L = 1`, so `A·α·bGateZ ≤ e^{(300−250)·bgpScale·τ}
= e^{50·bgpScale·τ}`. -/
theorem paper3N_gateZ_integrand_le_halfphase (wg w : ℕ) {τ : ℝ}
    (hτ0 : 0 ≤ τ) (hsin : Real.sin τ ≤ 1 / 2) :
    bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
        bGateZ bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ ≤
      Real.exp (50 * (bgpScale : ℝ) * τ) := by
  have hα := paper3HeadlineSolFamN_alpha wg w hτ0
  have hμ := paper3HeadlineSolFamN_mu wg w hτ0
  rw [hα, hμ]
  simp only [bgpParamsN_A_eq, one_mul, bgpParamsN_L_eq]
  unfold bGateZ rPulse
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  have hr : (1 : ℝ) / 4 ≤ ((1 - Real.sin τ) / 2) ^ 1 := by
    rw [pow_one]
    linarith
  have hsW : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  rw [bgpParamsN_cα_def, bgpParamsN_cμ_def]
  nlinarith [mul_le_mul_of_nonneg_left hr
    (mul_nonneg (mul_nonneg (by norm_num : (0 : ℝ) ≤ 1000) hsW.le) hτ0)]

/-- STRONG pointwise u-active kernel floor at N rates: on the u-active
window `sin ≤ −1/2` gives `qPulse ≤ 1/4` at `L = 1`, so
`A·α·bGateU ≥ e^{50·bgpScale·τ} ≥ e^{50·bgpScale·U0}` — a `j`-uniformly
enormous mass, unlike the banked endpoint-crossed constant. -/
theorem paper3N_uActive_kernel_ge (wg w j : ℕ) {τ : ℝ}
    (h1 : selectorMUUActiveStart j ≤ τ) (h2 : τ ≤ selectorMUUActiveEnd j) :
    Real.exp (50 * (bgpScale : ℝ) * selectorMUUActiveStart j) ≤
      bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
        bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
  have hU00 : 0 ≤ selectorMUUActiveStart j := by
    unfold selectorMUUActiveStart
    positivity
  have hτ0 : 0 ≤ τ := le_trans hU00 h1
  have hα := paper3HeadlineSolFamN_alpha wg w hτ0
  have hμ := paper3HeadlineSolFamN_mu wg w hτ0
  have hsin : Real.sin τ ≤ -(1 / 2) :=
    sin_window_le_neg_half j (by simpa [selectorMUUActiveStart] using h1)
      (by simpa [selectorMUUActiveEnd] using h2)
  have hU0τ : 50 * (bgpScale : ℝ) * selectorMUUActiveStart j ≤
      50 * (bgpScale : ℝ) * τ := by
    have hsW : (0 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_pos.le
    nlinarith
  rw [hα, hμ]
  simp only [bgpParamsN_A_eq, one_mul, bgpParamsN_L_eq]
  unfold bGateU qPulse
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  have hq : ((1 + Real.sin τ) / 2) ^ 1 ≤ (1 : ℝ) / 4 := by
    rw [pow_one]
    linarith
  have hsW : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  rw [bgpParamsN_cα_def, bgpParamsN_cμ_def]
  nlinarith [mul_le_mul_of_nonneg_left hq
    (mul_nonneg (mul_nonneg (by norm_num : (0 : ℝ) ≤ 1000) hsW.le) hτ0),
    hU0τ]

/-- Early-piece arithmetic for the retimed (3/5)-N source cap: the
double-exponential u-active weight kill beats the single-exponential
halfphase growth times any `10·bgpScale` box, times the `π/3` window
length — with astronomic room. -/
theorem paper3N_earlyPiece_arith {sR X Bv : ℝ}
    (hs1 : 1 ≤ sR) (hB0 : 0 ≤ Bv) (hBle : Bv ≤ 10 * sR)
    (hX : Real.exp (175 * sR) ≤ X) :
    Real.exp (-(2 * Real.pi / 3 * X)) * (X * Bv) * (Real.pi / 3) ≤ 1 / 2 := by
  have hs0 : (0 : ℝ) < sR := lt_of_lt_of_le one_pos hs1
  have hX0 : (0 : ℝ) < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hπ3 : (3 : ℝ) < Real.pi := Real.pi_gt_three
  have hπ4 : Real.pi ≤ 4 := Real.pi_le_four
  have h2X : Real.exp (-(2 * Real.pi / 3 * X)) ≤ Real.exp (-(2 * X)) := by
    apply Real.exp_le_exp.mpr
    nlinarith
  have hXeX : X * Real.exp (-X) ≤ 1 := by
    have h1 : X ≤ Real.exp X := by
      have := Real.add_one_le_exp X
      linarith
    have hmul : Real.exp X * Real.exp (-X) = 1 := by
      rw [← Real.exp_add]
      simp
    calc X * Real.exp (-X)
        ≤ Real.exp X * Real.exp (-X) :=
          mul_le_mul_of_nonneg_right h1 (Real.exp_pos _).le
      _ = 1 := hmul
  have hexp2 : Real.exp (-(2 * X)) = Real.exp (-X) * Real.exp (-X) := by
    rw [← Real.exp_add]
    congr 1
    ring
  have hstep1 : Real.exp (-(2 * Real.pi / 3 * X)) * (X * Bv) * (Real.pi / 3) ≤
      Real.exp (-(2 * X)) * (X * Bv) * (Real.pi / 3) := by
    have hXB : 0 ≤ X * Bv := mul_nonneg hX0.le hB0
    have hπ30 : (0 : ℝ) ≤ Real.pi / 3 := by positivity
    exact mul_le_mul_of_nonneg_right
      (mul_le_mul_of_nonneg_right h2X hXB) hπ30
  have hstep2 : Real.exp (-(2 * X)) * (X * Bv) * (Real.pi / 3) ≤
      Real.exp (-X) * Bv * (Real.pi / 3) := by
    have hcore : Real.exp (-(2 * X)) * (X * Bv) ≤ Real.exp (-X) * Bv := by
      rw [hexp2]
      calc Real.exp (-X) * Real.exp (-X) * (X * Bv)
          = (X * Real.exp (-X)) * (Real.exp (-X) * Bv) := by ring
        _ ≤ 1 * (Real.exp (-X) * Bv) :=
            mul_le_mul_of_nonneg_right hXeX
              (mul_nonneg (Real.exp_pos _).le hB0)
        _ = Real.exp (-X) * Bv := one_mul _
    exact mul_le_mul_of_nonneg_right hcore (by positivity)
  have hXbig : 175 * sR + 1 ≤ X := by
    have := Real.add_one_le_exp (175 * sR)
    linarith
  have heX : Real.exp (-X) ≤ Real.exp (-(175 * sR + 1)) :=
    Real.exp_le_exp.mpr (by linarith)
  have hπle : Real.pi / 3 ≤ 4 / 3 := by linarith
  have hstep3 : Real.exp (-X) * Bv * (Real.pi / 3) ≤
      Real.exp (-(175 * sR + 1)) * (10 * sR) * (4 / 3) := by
    have h1 : Real.exp (-X) * Bv ≤ Real.exp (-(175 * sR + 1)) * (10 * sR) :=
      mul_le_mul heX hBle hB0 (Real.exp_pos _).le
    have h2 : 0 ≤ Real.exp (-X) * Bv :=
      mul_nonneg (Real.exp_pos _).le hB0
    exact mul_le_mul h1 hπle (by positivity) (by positivity)
  have hfinal : Real.exp (-(175 * sR + 1)) * (10 * sR) * (4 / 3) ≤ 1 / 2 := by
    have hE := Real.add_one_le_exp (175 * sR + 1)
    have hy0 : (0 : ℝ) < Real.exp (-(175 * sR + 1)) := Real.exp_pos _
    have hmul1 : Real.exp (175 * sR + 1) * Real.exp (-(175 * sR + 1)) = 1 := by
      rw [← Real.exp_add]
      simp
    have hprod : (175 * sR + 2) * Real.exp (-(175 * sR + 1)) ≤ 1 := by
      calc (175 * sR + 2) * Real.exp (-(175 * sR + 1))
          ≤ Real.exp (175 * sR + 1) * Real.exp (-(175 * sR + 1)) :=
            mul_le_mul_of_nonneg_right (by linarith) hy0.le
        _ = 1 := hmul1
    nlinarith [hprod, hy0.le, mul_nonneg
      (show (0 : ℝ) ≤ 153 * sR + 2 by linarith) hy0.le]
  linarith [hstep1, hstep2, hstep3, hfinal]

/-- Interval form of the scalar relaxation trapping invariant with
interval-LOCAL continuity (base point `a`, time shift into
`scalar_relaxation_trapping_invariant_continuousOn`) — needed when the
relaxation target is a kernel quotient, continuous only where the total
kernel is positive. -/
theorem paper3N_trapping_on_Icc_cOn
    (y g k : ℝ → ℝ) {lo hi a T : ℝ}
    (haT : a ≤ T)
    (hk_cont : ContinuousOn k (Icc a T))
    (hg_cont : ContinuousOn g (Icc a T))
    (hy_ode : ∀ τ ∈ Icc a T, HasDerivAt y (k τ * (g τ - y τ)) τ)
    (hk_nonneg : ∀ τ ∈ Icc a T, 0 ≤ k τ)
    (hg_range : ∀ τ ∈ Icc a T, g τ ∈ Icc lo hi)
    (hya : y a ∈ Icc lo hi) :
    y T ∈ Icc lo hi := by
  have hmap : Set.MapsTo (fun σ : ℝ => a + σ) (Icc (0 : ℝ) (T - a))
      (Icc a T) := by
    intro σ hσ
    exact ⟨by linarith [hσ.1], by linarith [hσ.2]⟩
  have hcont_shift : Continuous fun σ : ℝ => a + σ :=
    continuous_const.add continuous_id
  have hode' : ∀ σ ∈ Icc (0 : ℝ) (T - a),
      HasDerivAt (fun σ' : ℝ => y (a + σ'))
        (k (a + σ) * (g (a + σ) - y (a + σ))) σ := by
    intro σ hσ
    have hmem : a + σ ∈ Icc a T := hmap hσ
    have h1 : HasDerivAt (fun σ' : ℝ => a + σ') 1 σ := by
      simpa using (hasDerivAt_id σ).const_add a
    have h2 := (hy_ode (a + σ) hmem).comp σ h1
    simpa [Function.comp] using h2
  have hshift := scalar_relaxation_trapping_invariant_continuousOn
    (fun σ => y (a + σ)) (fun σ => g (a + σ)) (fun σ => k (a + σ))
    (lo := lo) (hi := hi) (T := T - a)
    (by linarith)
    (by
      have := hk_cont.comp hcont_shift.continuousOn hmap
      simpa [Function.comp] using this)
    (by
      have := hg_cont.comp hcont_shift.continuousOn hmap
      simpa [Function.comp] using this)
    hode'
    (fun σ hσ => hk_nonneg (a + σ) (hmap hσ))
    (fun σ hσ => hg_range (a + σ) (hmap hσ))
    (by simpa using hya)
