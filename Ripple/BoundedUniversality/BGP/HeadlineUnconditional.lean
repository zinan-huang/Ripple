    rw [hcg_eq]
    nlinarith [hkey', hcrlam, hcrinv]
  have hduh := badMass_scalar_duhamel_bound
    (B := fun τ => 1 - ((paper3HeadlineSolFam wg) w).lam
      (localViewU (solMUReplStaticCfg w j)) τ)
    (cr := paper3S13crF) (cg := paper3S13cgF wg)
    (G := ((paper3HeadlineSolFam wg) w).G)
    (a := a) (b := b)
    (gap := selectorReplicatorGapVal paper3HeadlineEta
