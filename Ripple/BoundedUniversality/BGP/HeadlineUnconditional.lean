    (paper3HeadlineKappa : ℝ) ≤
      ((1 / 2 : ℝ) ^ paper3HeadlineM) * ((paper3WarmGainQ wg : ℚ) : ℝ) := by
  have hbase : (1 : ℝ) ≤ ((1 / 2 : ℝ) ^ 20) * (1734736490 : ℝ) := by
    norm_num
  have hpow_ge : (1 : ℝ) ≤ (((6 : ℚ) ^ wg : ℚ) : ℝ) := by
    exact_mod_cast (one_le_pow₀ (by norm_num : (1 : ℚ) ≤ 6) :
      (1 : ℚ) ≤ (6 : ℚ) ^ wg)
  have hfactor_nonneg : 0 ≤ ((1 / 2 : ℝ) ^ 20) * (1734736490 : ℝ) := by
    positivity
  calc
    (paper3HeadlineKappa : ℝ) = 1 := by norm_num [paper3HeadlineKappa]
    _ ≤ ((1 / 2 : ℝ) ^ 20) * (1734736490 : ℝ) := hbase
    _ ≤ ((1 / 2 : ℝ) ^ 20) *
        ((1734736490 : ℝ) * (((6 : ℚ) ^ wg : ℚ) : ℝ)) := by
      nlinarith
    _ = ((1 / 2 : ℝ) ^ paper3HeadlineM) * ((paper3WarmGainQ wg : ℚ) : ℝ) := by
