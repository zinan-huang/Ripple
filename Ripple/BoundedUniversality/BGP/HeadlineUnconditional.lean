      exact Real.exp_pos _
    exact mul_pos (Real.exp_pos _) hg
  have hkU_pos : ∀ τ : ℝ, 0 ≤ τ → 0 < kUf τ := by
    intro τ hτ0
    have hα := paper3HeadlineSolFamNW_alpha w w hτ0
    dsimp only [kUf]
    rw [hα, (bgpParamsNW_A_eq w), one_mul]
