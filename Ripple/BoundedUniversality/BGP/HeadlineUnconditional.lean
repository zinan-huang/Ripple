        (localViewU (solMUReplStaticCfg w j)) a) *
        Real.exp (-((selectorReplicatorGapVal paper3HeadlineEta
            paper3HeadlineEta_pos * Lsafe) *
          (((paper3HeadlineSolFam wg) w).G t -
