    have hz := ((paper3HeadlineSolFamNW w) w).z_hasDeriv τ hdom i
    have hu := ((paper3HeadlineSolFamNW w) w).u_hasDeriv τ hdom i
    have hkkne : kk τ ≠ 0 := ne_of_gt (hkk_pos τ hτ0)
    have hsub := hz.sub hu
    convert hsub using 1
    have hkkgg : kk τ * gg τ =
