    0 < ((paper3WarmGainQ w : ℚ) : ℝ) := by
  have hpow : 0 < ((6 : ℚ) ^ w : ℚ) := pow_pos (by norm_num) w
  have hmul : 0 < (paper3WarmGainQ w : ℚ) := by
    unfold paper3WarmGainQ paper3WarmGainC
    exact mul_pos (by norm_num) hpow
  exact_mod_cast hmul

theorem paper3HeadlineHScale (wg : ℕ) :
    (paper3HeadlineKappa : ℝ) ≤
      ((3 / 4 : ℝ) ^ paper3HeadlineM) * ((paper3WarmGainQ wg : ℚ) : ℝ) := by
  have hbase : (1 : ℝ) ≤ ((3 / 4 : ℝ) ^ 20) * (1734736490 : ℝ) := by
    norm_num
  have hpow_ge : (1 : ℝ) ≤ (((6 : ℚ) ^ wg : ℚ) : ℝ) := by
    exact_mod_cast (one_le_pow₀ (by norm_num : (1 : ℚ) ≤ 6) :
      (1 : ℚ) ≤ (6 : ℚ) ^ wg)
  have hfactor_nonneg : 0 ≤ ((3 / 4 : ℝ) ^ 20) * (1734736490 : ℝ) := by
    positivity
  calc
    (paper3HeadlineKappa : ℝ) = 1 := by norm_num [paper3HeadlineKappa]
    _ ≤ ((3 / 4 : ℝ) ^ 20) * (1734736490 : ℝ) := hbase
    _ ≤ ((3 / 4 : ℝ) ^ 20) *
        ((1734736490 : ℝ) * (((6 : ℚ) ^ wg : ℚ) : ℝ)) := by
      nlinarith
    _ = ((3 / 4 : ℝ) ^ paper3HeadlineM) * ((paper3WarmGainQ wg : ℚ) : ℝ) := by
      norm_num [paper3HeadlineM, paper3WarmGainQ, paper3WarmGainC]

