    (htube0 : ∀ i,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN)
    (hwin : ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z t i -
        ((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3F1CwinDefN) :
    ∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUWriteReadTime j)
        (selectorMUZOffEnd j),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
          ((paper3HeadlineSolFamNW w) w).lam τ i -
        ((paper3HeadlineSolFamNW w) w).z τ i| ≤ paper3F1MixCrudeBoxNW := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  set sol := (paper3HeadlineSolFamNW w) w with hsol
  have hπ := Real.pi_pos
  have hD8 := paper3Headline_D_U_ge_eight
  have hC0nn := paper3F1MixC0NW_nonneg
  have hCwin0 := paper3F1CwinDefN_nonneg
  have hr : r_LE_U = 1 / 1000 := rfl
  obtain ⟨hT, hD⟩ := paper3NW4_tube_maintenance w w j htube0 hwin
  -- schedule bookkeeping
  have hwr0 : 0 ≤ selectorMUWriteReadTime j := by
    unfold selectorMUWriteReadTime
    nlinarith [(Nat.cast_nonneg j : (0 : ℝ) ≤ (j : ℝ))]
  have hws_wr : selectorMUWriteStartTime j ≤ selectorMUWriteReadTime j := by
    unfold selectorMUWriteStartTime selectorMUWriteReadTime
    nlinarith
  have hwr_zs : selectorMUWriteReadTime j ≤ selectorMUZOffStart j := by
    unfold selectorMUWriteReadTime selectorMUZOffStart
    nlinarith
  have hzs_ze : selectorMUZOffStart j ≤ selectorMUZOffEnd j := by
