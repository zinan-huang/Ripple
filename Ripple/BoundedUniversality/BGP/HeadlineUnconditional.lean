    simp only [bGateZ]
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamN wg) w).cont_μ.mul hr).neg)
  have hgateU_cont : Continuous fun τ : ℝ =>
      bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
    have hq : Continuous fun τ : ℝ => qPulse bgpParamsN.L τ := by
      simp only [qPulse]
