/-- Scalar quotient estimate for the active QSS derivative after rewriting
`qss = rho / (card * (rho + Delta))`.  This is the algebraic core of the
remaining QSS-derivative discharge: it separates profile variation `rho'` from
payoff-gap variation `Delta'`. -/
theorem paper3_activeQSSDeriv_abs_le_rho_delta
    {N gamma rho rhoD delta deltaD : ℝ}
    (hN_pos : 0 < N)
    (hgamma_pos : 0 < gamma)
    (hrho_nonneg : 0 ≤ rho)
    (hdelta_gap : gamma ≤ delta) :
    |(1 / N) * ((rhoD * delta - rho * deltaD) / (rho + delta) ^ 2)| ≤
      (1 / N) * (|rhoD| / gamma + rho * |deltaD| / gamma ^ 2) := by
  let R : ℝ := rho + delta
  have hdelta_nonneg : 0 ≤ delta := le_trans hgamma_pos.le hdelta_gap
  have hR_ge_delta : delta ≤ R := by dsimp [R]; linarith
  have hR_ge_gamma : gamma ≤ R := le_trans hdelta_gap hR_ge_delta
  have hR_pos : 0 < R := lt_of_lt_of_le hgamma_pos hR_ge_gamma
  have hR2_pos : 0 < R ^ 2 := sq_pos_of_pos hR_pos
  have hgamma2_pos : 0 < gamma ^ 2 := sq_pos_of_pos hgamma_pos
  have hnum_abs :
      |rhoD * delta - rho * deltaD| ≤ |rhoD| * delta + rho * |deltaD| := by
    calc
      |rhoD * delta - rho * deltaD|
          ≤ |rhoD * delta| + |rho * deltaD| :=
              abs_sub (rhoD * delta) (rho * deltaD)
      _ = |rhoD| * delta + rho * |deltaD| := by
          rw [abs_mul, abs_mul, abs_of_nonneg hdelta_nonneg,
            abs_of_nonneg hrho_nonneg]
  have hdelta_div :
      delta / R ^ 2 ≤ 1 / gamma := by
    rw [div_le_iff₀ hR2_pos]
    field_simp [ne_of_gt hgamma_pos]
    have hmul : delta * gamma ≤ R * R :=
      mul_le_mul hR_ge_delta hR_ge_gamma hgamma_pos.le hR_pos.le
    nlinarith [hmul]
  have hR2_inv :
      1 / R ^ 2 ≤ 1 / gamma ^ 2 := by
    rw [div_le_div_iff₀ hR2_pos hgamma2_pos]
    have hsq : gamma * gamma ≤ R * R :=
      mul_le_mul hR_ge_gamma hR_ge_gamma hgamma_pos.le hR_pos.le
    nlinarith [hsq]
  have hcore :
      |(rhoD * delta - rho * deltaD) / R ^ 2| ≤
        |rhoD| / gamma + rho * |deltaD| / gamma ^ 2 := by
    calc
      |(rhoD * delta - rho * deltaD) / R ^ 2|
          = |rhoD * delta - rho * deltaD| / R ^ 2 := by
              rw [abs_div, abs_of_nonneg hR2_pos.le]
      _ ≤ (|rhoD| * delta + rho * |deltaD|) / R ^ 2 :=
              div_le_div_of_nonneg_right hnum_abs hR2_pos.le
      _ = |rhoD| * (delta / R ^ 2) +
            (rho * |deltaD|) * (1 / R ^ 2) := by
              field_simp [ne_of_gt hR2_pos]
      _ ≤ |rhoD| * (1 / gamma) +
            (rho * |deltaD|) * (1 / gamma ^ 2) := by
              exact add_le_add
                (mul_le_mul_of_nonneg_left hdelta_div (abs_nonneg rhoD))
                (mul_le_mul_of_nonneg_left hR2_inv
                  (mul_nonneg hrho_nonneg (abs_nonneg deltaD)))
      _ = |rhoD| / gamma + rho * |deltaD| / gamma ^ 2 := by
              ring
  have hNinv_nonneg : 0 ≤ 1 / N := by positivity
  calc
    |(1 / N) * ((rhoD * delta - rho * deltaD) / (rho + delta) ^ 2)|
        = (1 / N) * |(rhoD * delta - rho * deltaD) / R ^ 2| := by
            rw [abs_mul, abs_of_nonneg hNinv_nonneg]
    _ ≤ (1 / N) * (|rhoD| / gamma + rho * |deltaD| / gamma ^ 2) :=
        mul_le_mul_of_nonneg_left hcore hNinv_nonneg

/-- On the active suffix, the concrete gain coefficient keeps the fixed
`(3/4)^M` sine floor and at least the early-subwindow exponential factor. -/
theorem paper3Headline_activeCg_lower_on_active_suffix
    (wg w j : ℕ) :
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    ∀ τ ∈ Set.Icc E Htime,
      D * Real.exp (bgpParams38.cα * E) ≤
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ := by
  dsimp
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  intro τ hτ
  have hactive :
      τ ∈ Icc (selectorMUSelectStartTime (j + 1))
          (selectorMUWriteHoldTime (j + 1)) :=
    ⟨le_trans (selectorMUSelectStart_le_earlySubStart (j + 1))
        (by simpa [E] using hτ.1),
      by simpa [Htime] using hτ.2⟩
  have hsin : (1 : ℝ) / 2 ≤ Real.sin τ :=
    paper3HeadlineActive_sin_ge_half (j + 1) hactive
  have hsin_base : (3 / 4 : ℝ) ≤ (1 + Real.sin τ) / 2 := by
    linarith
  have hsin_pow :
      ((3 / 4 : ℝ) ^ paper3HeadlineM) ≤
        ((1 + Real.sin τ) / 2) ^ paper3HeadlineM :=
    pow_le_pow_left₀ (by norm_num) hsin_base paper3HeadlineM
  have hq_nonneg : 0 ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) :=
    paper3WarmGainQ_nonneg wg
  have hD_le :
      D ≤ ((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
          ((paper3WarmGainQ wg : ℚ) : ℝ) := by
    dsimp [D]
    exact mul_le_mul_of_nonneg_right hsin_pow hq_nonneg
  have hα_nonneg : 0 ≤ bgpParams38.cα := by
    norm_num [bgpParams38]
  have hexp_le :
      Real.exp (bgpParams38.cα * E) ≤
        Real.exp (bgpParams38.cα * τ) := by
    apply Real.exp_le_exp.mpr
    exact mul_le_mul_of_nonneg_left (by simpa [E] using hτ.1) hα_nonneg
  have hpowq_nonneg :
      0 ≤ ((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
          ((paper3WarmGainQ wg : ℚ) : ℝ) := by
    have hsin_base_nonneg : 0 ≤ (1 + Real.sin τ) / 2 := by
      nlinarith [Real.neg_one_le_sin τ]
    exact mul_nonneg (pow_nonneg hsin_base_nonneg paper3HeadlineM) hq_nonneg
  calc
    D * Real.exp (bgpParams38.cα * E)
        ≤ (((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
            ((paper3WarmGainQ wg : ℚ) : ℝ)) *
            Real.exp (bgpParams38.cα * E) :=
          mul_le_mul_of_nonneg_right hD_le (Real.exp_pos _).le
    _ ≤ (((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
            ((paper3WarmGainQ wg : ℚ) : ℝ)) *
            Real.exp (bgpParams38.cα * τ) :=
          mul_le_mul_of_nonneg_left hexp_le hpowq_nonneg
    _ = selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ := by
          dsimp [selectorMU_activeCg]
          ring

/-- Active-suffix full-coordinate `z` control from a write-start mismatch and
an all-coordinate mix-target bound on the active write window.  This is the
local Duhamel bridge that avoids asking for `z` to already be close on the
whole prefix: `z_after_write_bound_repl` is applied up to the queried active
time and the nonnegative write kernel only costs a factor at most one. -/
theorem paper3Headline_activeSuffix_z_close_of_writeStart_and_mix_to_cfg
    (wg w j : ℕ) (cfgTarget : UConf) {Rstart Rmix : ℝ}
    (hz_start : ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        (confEncU cfgTarget i : ℝ)| ≤ Rstart)
    (hmix : ∀ t, t ∈ Icc (selectorMUWriteStartTime (j + 1))
        (selectorMUWriteHoldTime (j + 1)) -> ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
          ((paper3HeadlineSolFam wg) w).lam t i -
        (confEncU cfgTarget i : ℝ)| ≤ Rmix) :
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
    ∀ τ ∈ Set.Icc E Htime, ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z τ i -
        (confEncU cfgTarget i : ℝ)| ≤ Rstart + Rmix := by
  dsimp
  intro τ hτ i
  let solw := (paper3HeadlineSolFam wg) w
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let M : ℝ := (confEncU cfgTarget i : ℝ)
  have hWτ : W ≤ τ := by
    exact le_trans (selectorMUWriteStart_le_earlySubStart (j + 1)) hτ.1
  have hτH : τ ≤ Htime := by
    simpa [Htime] using hτ.2
  have hdom :
      ∀ t ∈ Icc W τ, t ∈ selectorSchedule.domain := by
    intro t ht
    have hW0 : 0 ≤ W := by
      dsimp [W]
      exact selectorMUWriteStartTime_nonneg (j + 1)
    exact selectorSchedule_domain_of_nonneg_structural t (le_trans hW0 ht.1)
  have hgZ0 :
      ∀ t ∈ Icc W τ,
        0 ≤ bgpParams38.A * solw.α t *
          bGateZ bgpParams38.L (solw.μ t) t := by
    intro t ht
    have hW0 : 0 ≤ W := by
      dsimp [W]
      exact selectorMUWriteStartTime_nonneg (j + 1)
    exact selector_replicator_gateZ_integrand_nonneg solw
      selectorSchedule_domain_of_nonneg_structural
      (by norm_num [bgpParams38]) (le_trans hW0 ht.1)
  have hstab :
      ∀ t ∈ Icc W τ,
        |selectorMixTarget branchU solw.u solw.lam t i - M| ≤ Rmix := by
    intro t ht
    have ht_full :
        t ∈ Icc (selectorMUWriteStartTime (j + 1))
            (selectorMUWriteHoldTime (j + 1)) := by
      exact ⟨by simpa [W] using ht.1,
        by simpa [Htime] using le_trans ht.2 hτH⟩
    simpa [solw, M] using hmix t ht_full i
  have hzh :
      ∀ t ∈ Icc τ τ, |solw.z t i - solw.z τ i| ≤ (0 : ℝ) := by
    intro t ht
    have ht_eq : t = τ := le_antisymm ht.2 ht.1
    simp [ht_eq]
  have hz_raw :
      |solw.z τ i - M| ≤
        0 + (Real.exp (-(∫ s in W..τ,
            bgpParams38.A * solw.α s *
              bGateZ bgpParams38.L (solw.μ s) s)) *
          |solw.z W i - M| + Rmix) := by
    have hbase :=
      z_after_write_bound_repl
        (sol := solw) (s := i) (a := W) (m := τ) (b := τ)
        (M := M) (δw := Rmix) (δzh := 0)
        hWτ hdom (selector_replicator_gateZ_integrand_continuous solw)
        hgZ0 hstab hzh
    exact hbase τ ⟨le_rfl, le_rfl⟩
  have hI_nonneg :
      0 ≤ ∫ s in W..τ,
        bgpParams38.A * solw.α s * bGateZ bgpParams38.L (solw.μ s) s := by
    apply intervalIntegral.integral_nonneg hWτ
    intro t ht
    exact hgZ0 t ht
  have hexp_le_one :
      Real.exp (-(∫ s in W..τ,
        bgpParams38.A * solw.α s * bGateZ bgpParams38.L (solw.μ s) s)) ≤
        (1 : ℝ) :=
    Real.exp_le_one_iff.mpr (by linarith)
  have hctr :
      Real.exp (-(∫ s in W..τ,
          bgpParams38.A * solw.α s * bGateZ bgpParams38.L (solw.μ s) s)) *
          |solw.z W i - M| ≤ Rstart := by
    calc
      Real.exp (-(∫ s in W..τ,
          bgpParams38.A * solw.α s * bGateZ bgpParams38.L (solw.μ s) s)) *
          |solw.z W i - M|
          ≤ 1 * |solw.z W i - M| :=
            mul_le_mul_of_nonneg_right hexp_le_one (abs_nonneg _)
      _ ≤ Rstart := by
            simpa [W, M, solw] using hz_start i
  linarith

/-- Active-suffix full-coordinate `z` control retaining the homogeneous
Duhamel kernel on the write-start mismatch.  The coarser
`paper3Headline_activeSuffix_z_close_of_writeStart_and_mix_to_cfg` is obtained
by bounding this kernel by `1`; downstream Hoff-rate estimates need this sharper
form so the write contraction is not discarded too early. -/
theorem paper3Headline_activeSuffix_z_close_with_start_kernel
    (wg w j : ℕ) (cfgTarget : UConf) {Rstart Rmix : ℝ}
    (hz_start : ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        (confEncU cfgTarget i : ℝ)| ≤ Rstart)
    (hmix : ∀ t, t ∈ Icc (selectorMUWriteStartTime (j + 1))
        (selectorMUWriteHoldTime (j + 1)) -> ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
          ((paper3HeadlineSolFam wg) w).lam t i -
        (confEncU cfgTarget i : ℝ)| ≤ Rmix) :
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
    ∀ τ ∈ Set.Icc E Htime, ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z τ i -
        (confEncU cfgTarget i : ℝ)| ≤
        Real.exp (-(∫ s in (selectorMUWriteStartTime (j + 1))..τ,
            bgpParams38.A * ((paper3HeadlineSolFam wg) w).α s *
              bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ s) s)) *
          Rstart + Rmix := by
  dsimp
  intro τ hτ i
  let solw := (paper3HeadlineSolFam wg) w
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let M : ℝ := (confEncU cfgTarget i : ℝ)
  have hWτ : W ≤ τ := by
    exact le_trans (selectorMUWriteStart_le_earlySubStart (j + 1)) hτ.1
  have hτH : τ ≤ Htime := by
    simpa [Htime] using hτ.2
  have hdom :
      ∀ t ∈ Icc W τ, t ∈ selectorSchedule.domain := by
    intro t ht
    have hW0 : 0 ≤ W := by
      dsimp [W]
      exact selectorMUWriteStartTime_nonneg (j + 1)
    exact selectorSchedule_domain_of_nonneg_structural t (le_trans hW0 ht.1)
  have hgZ0 :
      ∀ t ∈ Icc W τ,
        0 ≤ bgpParams38.A * solw.α t *
          bGateZ bgpParams38.L (solw.μ t) t := by
    intro t ht
    have hW0 : 0 ≤ W := by
      dsimp [W]
      exact selectorMUWriteStartTime_nonneg (j + 1)
    exact selector_replicator_gateZ_integrand_nonneg solw
      selectorSchedule_domain_of_nonneg_structural
      (by norm_num [bgpParams38]) (le_trans hW0 ht.1)
  have hstab :
      ∀ t ∈ Icc W τ,
        |selectorMixTarget branchU solw.u solw.lam t i - M| ≤ Rmix := by
    intro t ht
    have ht_full :
        t ∈ Icc (selectorMUWriteStartTime (j + 1))
            (selectorMUWriteHoldTime (j + 1)) := by
      exact ⟨by simpa [W] using ht.1,
        by simpa [Htime] using le_trans ht.2 hτH⟩
    simpa [solw, M] using hmix t ht_full i
  have hzh :
      ∀ t ∈ Icc τ τ, |solw.z t i - solw.z τ i| ≤ (0 : ℝ) := by
    intro t ht
    have ht_eq : t = τ := le_antisymm ht.2 ht.1
    simp [ht_eq]
  have hz_raw :
      |solw.z τ i - M| ≤
        0 + (Real.exp (-(∫ s in W..τ,
            bgpParams38.A * solw.α s *
              bGateZ bgpParams38.L (solw.μ s) s)) *
          |solw.z W i - M| + Rmix) := by
    have hbase :=
      z_after_write_bound_repl
        (sol := solw) (s := i) (a := W) (m := τ) (b := τ)
        (M := M) (δw := Rmix) (δzh := 0)
        hWτ hdom (selector_replicator_gateZ_integrand_continuous solw)
        hgZ0 hstab hzh
    exact hbase τ ⟨le_rfl, le_rfl⟩
  have hctr :
      Real.exp (-(∫ s in W..τ,
          bgpParams38.A * solw.α s *
            bGateZ bgpParams38.L (solw.μ s) s)) *
          |solw.z W i - M| ≤
        Real.exp (-(∫ s in W..τ,
          bgpParams38.A * solw.α s *
            bGateZ bgpParams38.L (solw.μ s) s)) *
          Rstart := by
    exact mul_le_mul_of_nonneg_left
      (by simpa [W, M, solw] using hz_start i)
      (Real.exp_nonneg _)
  linarith

/-- The pointwise scalar major produced by the kernel-retaining active QSS
derivative estimate. -/
@[irreducible]
def paper3HeadlineActiveQSSKernelMajor
    (wg w j : ℕ) (Rstart Rmix EncB : ℝ)
    (v : UniversalLocalView) (τ : ℝ) : ℝ :=
  let sol := paper3HeadlineSolFam wg
  let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let gap : ℝ :=
    selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
  let CrD : ℝ := (paper3HeadlineM : ℝ) * |(paper3HeadlineKappa : ℝ)|
  let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
  let gateZ : ℝ → ℝ := fun t =>
    bgpParams38.A * ((sol w).α t) *
      bGateZ bgpParams38.L ((sol w).μ t) t
  let ZK : ℝ :=
    Real.exp (-(∫ s in W..τ, gateZ s)) * Rstart + Rmix
  let URhs : ℝ :=
    ((ZK + EncB) + r_LE_U) *
      Real.exp (-(selectorUSettledRate * W))
  let CgD : ℝ :=
    ((paper3HeadlineM : ℝ) + bgpParams38.cα) *
      (|((paper3WarmGainQ wg : ℚ) : ℝ)| * Real.exp (bgpParams38.cα * τ))
  let Grad : ℝ :=
    selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos c
        (fun k : Fin d_U =>
          r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|) +
      selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
        (fun k : Fin d_U =>
          r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|)
  (1 / card) *
    (CrD / gamma +
      (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (CgD * 1 +
            selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
              (Grad * URhs))) /
        gamma ^ 2)

/-- Explicit lower bound for the z-write mass accumulated before the early
active suffix, i.e. on `[WriteStart, EarlyWriteSubStart]`.  This is separate
from `selectorEarlyWriteIntLower`, which lower-bounds the later
`[EarlyWriteSubStart, WriteHold]` subwindow. -/
def paper3HeadlineWriteStartEarlyIntLower (j : ℕ) : ℝ :=
  Real.exp (bgpParams38.cα * selectorMUWriteStartTime j) *
    Real.exp (-((bgpParams38.cμ / 4) * selectorMUEarlyWriteSubStart j)) *
      (Real.pi / 12)

theorem paper3Headline_exp_linear_sub_linear_tendsto_atTop
    {m b p q : ℝ} (hm : 0 < m) (hb : 0 < b) :
    Tendsto
      (fun j : ℕ =>
        m * Real.exp (b * (j : ℝ)) - (p * (j : ℝ) + q))
      atTop atTop := by
  have hlin_exp_neg_real :
      Tendsto (fun x : ℝ => x * Real.exp (-b * x)) atTop (𝓝 0) := by
    simpa using tendsto_rpow_mul_exp_neg_mul_atTop_nhds_zero (1 : ℝ) b hb
  have hlin_exp_neg :
      Tendsto (fun j : ℕ => (j : ℝ) * Real.exp (-b * (j : ℝ)))
        atTop (𝓝 0) :=
    hlin_exp_neg_real.comp tendsto_natCast_atTop_atTop
  have hexp_neg :
      Tendsto (fun j : ℕ => Real.exp (-b * (j : ℝ))) atTop (𝓝 0) := by
    have hscaled : Tendsto (fun j : ℕ => b * (j : ℝ)) atTop atTop :=
      Filter.Tendsto.const_mul_atTop hb tendsto_natCast_atTop_atTop
    have hneg : Tendsto (fun j : ℕ => -b * (j : ℝ)) atTop atBot := by
      simpa [neg_mul] using Filter.tendsto_neg_atBot_iff.mpr hscaled
    exact Real.tendsto_exp_atBot.comp hneg
  have hratio :
      Tendsto
        (fun j : ℕ =>
          (p * (j : ℝ) + q) / ((m / 2) * Real.exp (b * (j : ℝ))))
        atTop (𝓝 0) := by
    have hsum :
        Tendsto
          (fun j : ℕ =>
            (2 * p / m) * ((j : ℝ) * Real.exp (-b * (j : ℝ))) +
              (2 * q / m) * Real.exp (-b * (j : ℝ)))
          atTop (𝓝 0) := by
      simpa using
        ((tendsto_const_nhds.mul hlin_exp_neg).add
          (tendsto_const_nhds.mul hexp_neg))
    refine hsum.congr' ?_
    filter_upwards [] with j
    have hden : ((m / 2) * Real.exp (b * (j : ℝ))) ≠ 0 := by
      positivity
    have hnegarg : -b * (j : ℝ) = -(b * (j : ℝ)) := by
      ring
    rw [hnegarg, Real.exp_neg]
    field_simp [hden, ne_of_gt hm]
  have hle_half :
      ∀ᶠ j : ℕ in atTop,
        p * (j : ℝ) + q ≤ (m / 2) * Real.exp (b * (j : ℝ)) := by
    have hlt : ∀ᶠ j : ℕ in atTop,
        (p * (j : ℝ) + q) / ((m / 2) * Real.exp (b * (j : ℝ))) < 1 :=
      hratio.eventually (Iio_mem_nhds (by norm_num : (0 : ℝ) < 1))
    filter_upwards [hlt] with j hj
    have hdenpos : 0 < (m / 2) * Real.exp (b * (j : ℝ)) := by
      positivity
    simpa [one_mul] using ((div_lt_iff₀ hdenpos).mp hj).le
  have hhalf_atTop :
      Tendsto (fun j : ℕ => (m / 2) * Real.exp (b * (j : ℝ)))
        atTop atTop := by
    have hscaled : Tendsto (fun j : ℕ => b * (j : ℝ)) atTop atTop :=
      Filter.Tendsto.const_mul_atTop hb tendsto_natCast_atTop_atTop
    have hexp : Tendsto (fun j : ℕ => Real.exp (b * (j : ℝ)))
        atTop atTop :=
      Real.tendsto_exp_atTop.comp hscaled
    exact Filter.Tendsto.const_mul_atTop (by positivity : 0 < m / 2) hexp
  refine Filter.tendsto_atTop_mono' atTop ?_ hhalf_atTop
  filter_upwards [hle_half] with j hj
  have hpos : 0 < Real.exp (b * (j : ℝ)) := Real.exp_pos _
  nlinarith [hm, hpos, hj]

theorem paper3Headline_exp_shifted_linear_sub_linear_tendsto_atTop
    {m b p q : ℝ} (hm : 0 < m) (hb : 0 < b) :
    Tendsto
      (fun j : ℕ =>
        m * Real.exp (b * ((j : ℝ) + 1)) - (p * (j : ℝ) + q))
      atTop atTop := by
  have hm' : 0 < m * Real.exp b := mul_pos hm (Real.exp_pos b)
  have hbase :=
    paper3Headline_exp_linear_sub_linear_tendsto_atTop
      (m := m * Real.exp b) (b := b) (p := p) (q := q) hm' hb
  refine hbase.congr' ?_
  filter_upwards [] with j
  rw [show b * ((j : ℝ) + 1) = b + b * (j : ℝ) by ring]
  rw [Real.exp_add]
  ring

theorem
    paper3HeadlineWriteStartEarlyIntLower_sub_linear_writeStart_tendsto_atTop
    (a : ℝ) :
    Tendsto
      (fun j : ℕ =>
        paper3HeadlineWriteStartEarlyIntLower (j + 1) -
          a * selectorMUWriteStartTime (j + 1))
      atTop atTop := by
  have hbase :=
    paper3Headline_exp_shifted_linear_sub_linear_tendsto_atTop
      (m := (Real.pi / 12) * Real.exp (-(25 * Real.pi / 2)))
      (b := 100 * Real.pi)
      (p := a * (2 * Real.pi)) (q := a * (2 * Real.pi + Real.pi / 6))
      (by positivity) (by positivity)
  refine hbase.congr' ?_
  filter_upwards [] with j
  dsimp [paper3HeadlineWriteStartEarlyIntLower, selectorMUWriteStartTime,
    selectorMUEarlyWriteSubStart]
  rw [← Real.exp_add]
  rw [show bgpParams38.cα * (2 * Real.pi * ↑(j + 1) + Real.pi / 6) +
        -((bgpParams38.cμ / 4) *
          (2 * Real.pi * ↑(j + 1) + Real.pi / 4)) =
        -(25 * Real.pi / 2) + (100 * Real.pi) * ((j : ℝ) + 1) by
      push_cast
      norm_num [bgpParams38]
      ring]
  rw [Real.exp_add]
  push_cast
  ring_nf

/-- The write-start-to-early z-write lower is strong enough to absorb any
ordinary exponential in the true write-start time. -/
theorem paper3HeadlineWriteStartEarlyIntLower_absorbs_exp_writeStart
    (a : ℝ) :
    Tendsto
      (fun j : ℕ =>
        Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Real.exp (a * selectorMUWriteStartTime (j + 1)))
      atTop (𝓝 0) := by
  have hsub :=
    paper3HeadlineWriteStartEarlyIntLower_sub_linear_writeStart_tendsto_atTop a
  have hneg :
      Tendsto
        (fun j : ℕ =>
          a * selectorMUWriteStartTime (j + 1) -
            paper3HeadlineWriteStartEarlyIntLower (j + 1))
        atTop atBot := by
    have h := Filter.tendsto_neg_atBot_iff.mpr hsub
    simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using h
  have hexp :
      Tendsto
        (fun j : ℕ =>
          Real.exp (a * selectorMUWriteStartTime (j + 1) -
            paper3HeadlineWriteStartEarlyIntLower (j + 1)))
        atTop (𝓝 0) :=
    Real.tendsto_exp_atBot.comp hneg
  refine hexp.congr' ?_
  filter_upwards [] with j
  rw [← Real.exp_add]
  ring

theorem paper3Headline_selectorInterReadSourceCap_le_exp_writeStart
    {Bamp : ℝ} (hBamp0 : 0 ≤ Bamp) (j : ℕ) :
    selectorInterReadSourceCap Bamp j ≤
      Bamp * (2 * Real.pi) *
        Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1)) := by
  let Z0 : ℝ := selectorMUZOffStart j
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let EW : ℝ := Real.exp ((50 : ℝ) * W)
  have hZ0W : Z0 ≤ W := by
    dsimp [Z0, W, selectorMUZOffStart, selectorMUWriteStartTime]
    push_cast
    linarith [Real.pi_pos]
  have hZ0_nonneg : 0 ≤ Z0 := by
    dsimp [Z0, selectorMUZOffStart]
    positivity
  have hnegZ0_le_W : -Z0 ≤ W := by
    have hW0 : 0 ≤ W := by
      simpa [W] using selectorMUWriteStartTime_nonneg (j + 1)
    linarith
  have hmass0 : 0 ≤ selectorInterReadUActiveMassLower j :=
    selectorInterReadUActiveMassLower_nonneg j
  have hmass_exp_le_one :
      Real.exp (-(selectorInterReadUActiveMassLower j)) ≤ 1 := by
    rw [Real.exp_le_one_iff]
    linarith
  have hZexp_le_W :
      Real.exp ((50 : ℝ) * Z0) ≤ EW := by
    dsimp [EW]
    exact Real.exp_le_exp.mpr
      (mul_le_mul_of_nonneg_left hZ0W (by norm_num : (0 : ℝ) ≤ 50))
  have hnegZexp_le_W :
      Real.exp (-((200 : ℝ) * Z0)) ≤ EW := by
    dsimp [EW]
    apply Real.exp_le_exp.mpr
    nlinarith [hnegZ0_le_W, hZ0_nonneg]
  have hleft :
      Real.exp (-(selectorInterReadUActiveMassLower j)) * (Real.pi / 6) *
          Real.exp ((50 : ℝ) * Z0) ≤
        (Real.pi / 6) * EW := by
    have hpair :
        Real.exp (-(selectorInterReadUActiveMassLower j)) *
            Real.exp ((50 : ℝ) * Z0) ≤ 1 * EW :=
      mul_le_mul hmass_exp_le_one hZexp_le_W (Real.exp_pos _).le zero_le_one
    have hmul := mul_le_mul_of_nonneg_left hpair (by positivity : 0 ≤ Real.pi / 6)
    calc
      Real.exp (-(selectorInterReadUActiveMassLower j)) * (Real.pi / 6) *
          Real.exp ((50 : ℝ) * Z0)
          = (Real.pi / 6) *
            (Real.exp (-(selectorInterReadUActiveMassLower j)) *
              Real.exp ((50 : ℝ) * Z0)) := by ring
      _ ≤ (Real.pi / 6) * (1 * EW) := hmul
      _ = (Real.pi / 6) * EW := by ring
  have hmid :
      Real.pi * Real.exp (-((200 : ℝ) * Z0)) ≤ Real.pi * EW :=
    mul_le_mul_of_nonneg_left hnegZexp_le_W Real.pi_pos.le
  have hright :
      (Real.pi / 6) * Real.exp ((50 : ℝ) * W) ≤ (Real.pi / 6) * EW := by
    rfl
  have hsum :
      Real.exp (-(selectorInterReadUActiveMassLower j)) * (Real.pi / 6) *
          Real.exp ((50 : ℝ) * Z0) +
        Real.pi * Real.exp (-((200 : ℝ) * Z0)) +
          (Real.pi / 6) * Real.exp ((50 : ℝ) * W) ≤
        (2 * Real.pi) * EW := by
    have hEW0 : 0 ≤ EW := by positivity
    nlinarith [hleft, hmid, hright, Real.pi_pos, hEW0]
  dsimp [selectorInterReadSourceCap, Z0, W, EW]
  have hmul := mul_le_mul_of_nonneg_left hsum hBamp0
  calc
    Bamp *
        (Real.exp (-(selectorInterReadUActiveMassLower j)) * (Real.pi / 6) *
            Real.exp (50 * selectorMUZOffStart j) +
          Real.pi * Real.exp (-(200 * selectorMUZOffStart j)) +
            Real.pi / 6 * Real.exp (50 * selectorMUWriteStartTime (j + 1)))
        ≤ Bamp * (2 * Real.pi * Real.exp (50 * selectorMUWriteStartTime (j + 1))) := hmul
    _ = Bamp * (2 * Real.pi) *
          Real.exp (50 * selectorMUWriteStartTime (j + 1)) := by ring

theorem
    paper3Headline_interReadSourceCap_scaled_div_hoffRate_le_exp_writeStart
    {Bamp : ℝ} (hBamp0 : 0 ≤ Bamp) (j : ℕ) :
    (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
        selectorInterReadSourceCap Bamp j) / paper3HoffRate j ≤
      Bamp * (2 * Real.pi) *
        (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) *
            selectorMUWriteStartTime (j + 1))) := by
  let L : ℝ := paper3HeadlineWriteStartEarlyIntLower (j + 1)
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  change
    (Real.exp (-L) * selectorInterReadSourceCap Bamp j) / paper3HoffRate j ≤
      Bamp * (2 * Real.pi) *
        (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W))
  have hcap :
      selectorInterReadSourceCap Bamp j ≤
        Bamp * (2 * Real.pi) * Real.exp ((50 : ℝ) * W) := by
    simpa [W] using
      paper3Headline_selectorInterReadSourceCap_le_exp_writeStart
        (Bamp := Bamp) hBamp0 j
  have hnum_le :
      Real.exp (-L) * selectorInterReadSourceCap Bamp j ≤
        Real.exp (-L) *
          (Bamp * (2 * Real.pi) * Real.exp ((50 : ℝ) * W)) :=
    mul_le_mul_of_nonneg_left hcap (Real.exp_pos (-L)).le
  have hinv :
      (paper3HoffRate j)⁻¹ ≤ Real.exp ((1 / 8 : ℝ) * W) := by
    simpa [W] using paper3HoffRate_inv_le_exp_writeStart j
  have hinv_nonneg : 0 ≤ (paper3HoffRate j)⁻¹ :=
    inv_nonneg.mpr (paper3HoffRate_pos j).le
  have hmaj_nonneg :
      0 ≤ Real.exp (-L) *
        (Bamp * (2 * Real.pi) * Real.exp ((50 : ℝ) * W)) := by
    positivity
  have hprod :=
    mul_le_mul hnum_le hinv hinv_nonneg hmaj_nonneg
  calc
    (Real.exp (-L) * selectorInterReadSourceCap Bamp j) / paper3HoffRate j
        = (Real.exp (-L) * selectorInterReadSourceCap Bamp j) *
            (paper3HoffRate j)⁻¹ := by
          rw [div_eq_mul_inv]
    _ ≤ (Real.exp (-L) *
          (Bamp * (2 * Real.pi) * Real.exp ((50 : ℝ) * W))) *
          Real.exp ((1 / 8 : ℝ) * W) := hprod
    _ = Bamp * (2 * Real.pi) *
          (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W)) := by
      calc
        (Real.exp (-L) *
            (Bamp * (2 * Real.pi) * Real.exp ((50 : ℝ) * W))) *
            Real.exp ((1 / 8 : ℝ) * W)
            =
          Bamp * (2 * Real.pi) *
            (Real.exp (-L) *
              (Real.exp ((50 : ℝ) * W) *
                Real.exp ((1 / 8 : ℝ) * W))) := by ring
        _ =
          Bamp * (2 * Real.pi) *
            (Real.exp (-L) *
              Real.exp ((50 : ℝ) * W + (1 / 8 : ℝ) * W)) := by
            rw [← Real.exp_add]
        _ =
          Bamp * (2 * Real.pi) *
            (Real.exp (-L) *
              Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W)) := by
            rw [show
              (50 : ℝ) * W + (1 / 8 : ℝ) * W =
                ((50 : ℝ) + (1 / 8 : ℝ)) * W by ring]

theorem
    paper3Headline_interReadSourceCap_absorbed_of_eventually_exp_writeStart_bound
    (Bamp : ℕ → ℝ) {C a : ℝ}
    (hC_nonneg : 0 ≤ C)
    (hBamp_nonneg : ∀ᶠ j in atTop, 0 ≤ Bamp j)
    (hBamp_le : ∀ᶠ j in atTop,
      Bamp j ≤ C * Real.exp (a * selectorMUWriteStartTime (j + 1))) :
    Tendsto
      (fun j : ℕ =>
        Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap (Bamp j) j)
      atTop (𝓝 0) := by
  have _hC_nonneg : 0 ≤ C := hC_nonneg
  have hmajor_tendsto :
      Tendsto
        (fun j : ℕ =>
          (C * (2 * Real.pi)) *
            (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
              Real.exp ((a + (50 : ℝ)) *
                selectorMUWriteStartTime (j + 1))))
        atTop (𝓝 0) := by
    simpa using
      tendsto_const_nhds.mul
        (paper3HeadlineWriteStartEarlyIntLower_absorbs_exp_writeStart
          (a + (50 : ℝ)))
  refine squeeze_zero' ?_ ?_ hmajor_tendsto
  · filter_upwards [hBamp_nonneg] with j hBamp0
    exact mul_nonneg (Real.exp_pos _).le
      (selectorInterReadSourceCap_nonneg hBamp0 j)
  · filter_upwards [hBamp_nonneg, hBamp_le] with j hBamp0 hBamp_bound
    have hcap :=
      paper3Headline_selectorInterReadSourceCap_le_exp_writeStart
        (Bamp := Bamp j) hBamp0 j
    have hscale_nonneg :
        0 ≤ (2 * Real.pi) *
          Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1)) := by
      positivity
    have hcap_bound :
        selectorInterReadSourceCap (Bamp j) j ≤
          (C * Real.exp (a * selectorMUWriteStartTime (j + 1))) *
            (2 * Real.pi) *
              Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1)) := by
      calc
        selectorInterReadSourceCap (Bamp j) j
            ≤ Bamp j * (2 * Real.pi) *
                Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1)) := hcap
        _ ≤ (C * Real.exp (a * selectorMUWriteStartTime (j + 1))) *
              (2 * Real.pi) *
                Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1)) := by
            have hscaled :=
              mul_le_mul_of_nonneg_right hBamp_bound hscale_nonneg
            calc
              Bamp j * (2 * Real.pi) *
                  Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1))
                  = Bamp j * ((2 * Real.pi) *
                      Real.exp ((50 : ℝ) *
                        selectorMUWriteStartTime (j + 1))) := by ring
              _ ≤ (C * Real.exp (a * selectorMUWriteStartTime (j + 1))) *
                    ((2 * Real.pi) *
                      Real.exp ((50 : ℝ) *
                        selectorMUWriteStartTime (j + 1))) := hscaled
              _ = (C * Real.exp (a * selectorMUWriteStartTime (j + 1))) *
                    (2 * Real.pi) *
                      Real.exp ((50 : ℝ) *
                        selectorMUWriteStartTime (j + 1)) := by ring
    have hmul :=
      mul_le_mul_of_nonneg_left hcap_bound
        (Real.exp_pos (-(paper3HeadlineWriteStartEarlyIntLower (j + 1)))).le
    calc
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap (Bamp j) j
          ≤ Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            ((C * Real.exp (a * selectorMUWriteStartTime (j + 1))) *
              (2 * Real.pi) *
                Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1))) := hmul
      _ = (C * (2 * Real.pi)) *
            (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
              Real.exp ((a + (50 : ℝ)) *
                selectorMUWriteStartTime (j + 1))) := by
          calc
            Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
                ((C * Real.exp (a * selectorMUWriteStartTime (j + 1))) *
                  (2 * Real.pi) *
                    Real.exp ((50 : ℝ) * selectorMUWriteStartTime (j + 1)))
                =
              (C * (2 * Real.pi)) *
                (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
                  (Real.exp (a * selectorMUWriteStartTime (j + 1)) *
                    Real.exp ((50 : ℝ) *
                      selectorMUWriteStartTime (j + 1)))) := by ring
            _ = (C * (2 * Real.pi)) *
                (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
                  Real.exp (a * selectorMUWriteStartTime (j + 1) +
                    (50 : ℝ) * selectorMUWriteStartTime (j + 1))) := by
                  rw [← Real.exp_add]
            _ = (C * (2 * Real.pi)) *
                (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
                  Real.exp ((a + (50 : ℝ)) *
                    selectorMUWriteStartTime (j + 1))) := by
                  rw [show
                    a * selectorMUWriteStartTime (j + 1) +
                      (50 : ℝ) * selectorMUWriteStartTime (j + 1) =
                    (a + (50 : ℝ)) * selectorMUWriteStartTime (j + 1) by
                      ring]

theorem
    paper3Headline_interReadSourceCap_div_hoffRate_tendsto_zero_of_eventually_exp_writeStart_bound
    (Bamp : ℕ → ℝ) {C a : ℝ}
    (hC_nonneg : 0 ≤ C)
    (hBamp_nonneg : ∀ᶠ j in atTop, 0 ≤ Bamp j)
    (hBamp_le : ∀ᶠ j in atTop,
      Bamp j ≤ C * Real.exp (a * selectorMUWriteStartTime (j + 1))) :
    Tendsto
      (fun j : ℕ =>
        (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap (Bamp j) j) / paper3HoffRate j)
      atTop (𝓝 0) := by
  have _hC_nonneg : 0 ≤ C := hC_nonneg
  have hmajor_tendsto :
      Tendsto
        (fun j : ℕ =>
          (C * (2 * Real.pi)) *
            (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
              Real.exp ((a + ((50 : ℝ) + (1 / 8 : ℝ))) *
                selectorMUWriteStartTime (j + 1))))
        atTop (𝓝 0) := by
    simpa using
      tendsto_const_nhds.mul
        (paper3HeadlineWriteStartEarlyIntLower_absorbs_exp_writeStart
          (a + ((50 : ℝ) + (1 / 8 : ℝ))))
  refine squeeze_zero' ?_ ?_ hmajor_tendsto
  · filter_upwards [hBamp_nonneg] with j hBamp0
    exact div_nonneg
      (mul_nonneg (Real.exp_pos _).le
        (selectorInterReadSourceCap_nonneg hBamp0 j))
      (paper3HoffRate_pos j).le
  · filter_upwards [hBamp_nonneg, hBamp_le] with j hBamp0 hBamp_bound
    let L : ℝ := paper3HeadlineWriteStartEarlyIntLower (j + 1)
    let W : ℝ := selectorMUWriteStartTime (j + 1)
    have hscaled :
        (Real.exp (-L) * selectorInterReadSourceCap (Bamp j) j) /
            paper3HoffRate j ≤
          Bamp j * (2 * Real.pi) *
            (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W)) := by
      simpa [L, W] using
        paper3Headline_interReadSourceCap_scaled_div_hoffRate_le_exp_writeStart
          (Bamp := Bamp j) hBamp0 j
    have hscale_nonneg :
        0 ≤ (2 * Real.pi) *
          (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W)) := by
      positivity
    have hBamp_scaled :
        Bamp j * ((2 * Real.pi) *
            (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W))) ≤
          (C * Real.exp (a * W)) *
            ((2 * Real.pi) *
              (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W))) :=
      mul_le_mul_of_nonneg_right
        (by simpa [W] using hBamp_bound) hscale_nonneg
    calc
      (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap (Bamp j) j) / paper3HoffRate j
          ≤ Bamp j * (2 * Real.pi) *
            (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
              Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) *
                selectorMUWriteStartTime (j + 1))) := by
            simpa [L, W] using hscaled
      _ = Bamp j * ((2 * Real.pi) *
            (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W))) := by
            ring
      _ ≤ (C * Real.exp (a * W)) *
            ((2 * Real.pi) *
              (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W))) := hBamp_scaled
      _ = (C * (2 * Real.pi)) *
            (Real.exp (-L) *
              Real.exp ((a + ((50 : ℝ) + (1 / 8 : ℝ))) * W)) := by
        calc
          (C * Real.exp (a * W)) *
              ((2 * Real.pi) *
                (Real.exp (-L) * Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W)))
              =
            (C * (2 * Real.pi)) *
              (Real.exp (-L) *
                (Real.exp (a * W) *
                  Real.exp (((50 : ℝ) + (1 / 8 : ℝ)) * W))) := by ring
          _ =
            (C * (2 * Real.pi)) *
              (Real.exp (-L) *
                Real.exp (a * W + ((50 : ℝ) + (1 / 8 : ℝ)) * W)) := by
              rw [← Real.exp_add]
          _ =
            (C * (2 * Real.pi)) *
              (Real.exp (-L) *
                Real.exp ((a + ((50 : ℝ) + (1 / 8 : ℝ))) * W)) := by
              rw [show
                a * W + ((50 : ℝ) + (1 / 8 : ℝ)) * W =
                  (a + ((50 : ℝ) + (1 / 8 : ℝ))) * W by ring]
      _ = (C * (2 * Real.pi)) *
            (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
              Real.exp ((a + ((50 : ℝ) + (1 / 8 : ℝ))) *
                selectorMUWriteStartTime (j + 1))) := by
            simp [L, W]

theorem
    paper3Headline_interReadSourceCap_le_hoffRate_eventually_of_eventually_exp_writeStart_bound
    (Bamp : ℕ → ℝ) {C a : ℝ}
    (hC_nonneg : 0 ≤ C)
    (hBamp_nonneg : ∀ᶠ j in atTop, 0 ≤ Bamp j)
    (hBamp_le : ∀ᶠ j in atTop,
      Bamp j ≤ C * Real.exp (a * selectorMUWriteStartTime (j + 1))) :
    ∀ᶠ j in atTop,
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap (Bamp j) j ≤ paper3HoffRate j := by
  have hratio :=
    paper3Headline_interReadSourceCap_div_hoffRate_tendsto_zero_of_eventually_exp_writeStart_bound
      Bamp hC_nonneg hBamp_nonneg hBamp_le
  have hratio_lt_one :
      ∀ᶠ j in atTop,
        (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap (Bamp j) j) / paper3HoffRate j < 1 :=
    hratio.eventually (Iio_mem_nhds (by norm_num : (0 : ℝ) < 1))
  filter_upwards [hratio_lt_one] with j hj
  have hrate_pos : 0 < paper3HoffRate j := paper3HoffRate_pos j
  have hmul := (div_lt_iff₀ hrate_pos).mp hj
  linarith

theorem paper3Headline_eventually_le_hoffRate_to_const_hoffRate
    (f : ℕ → ℝ)
    (hf0 : ∀ j : ℕ, 0 ≤ f j)
    (hevent : ∀ᶠ j in atTop, f j ≤ paper3HoffRate j) :
    ∃ C : ℝ, 0 ≤ C ∧ ∀ j : ℕ, f j ≤ C * paper3HoffRate j := by
  rcases Filter.eventually_atTop.mp hevent with ⟨N, hN⟩
  let Cprefix : ℝ :=
    (Finset.range N).sum (fun k => f k / paper3HoffRate k)
  let C : ℝ := max 1 Cprefix
  refine ⟨C, ?_, ?_⟩
  · dsimp [C]
    exact le_max_of_le_left zero_le_one
  intro j
  by_cases hj : j < N
  · have hjmem : j ∈ Finset.range N := by
      simpa using hj
    have hterm_nonneg :
        ∀ k ∈ Finset.range N, 0 ≤ f k / paper3HoffRate k := by
      intro k _hk
      exact div_nonneg (hf0 k) (paper3HoffRate_pos k).le
    have hterm_le_sum :
        f j / paper3HoffRate j ≤ Cprefix := by
      dsimp [Cprefix]
      exact Finset.single_le_sum hterm_nonneg hjmem
    have hterm_le_C : f j / paper3HoffRate j ≤ C :=
      hterm_le_sum.trans (le_max_right 1 Cprefix)
    have hmul :=
      mul_le_mul_of_nonneg_right hterm_le_C (paper3HoffRate_pos j).le
    have hcancel :
        (f j / paper3HoffRate j) * paper3HoffRate j = f j := by
      field_simp [(paper3HoffRate_pos j).ne']
    simpa [hcancel] using hmul
  · have hjge : N ≤ j := le_of_not_gt hj
    have hCge : 1 ≤ C := le_max_left 1 Cprefix
    calc
      f j ≤ paper3HoffRate j := hN j hjge
      _ = 1 * paper3HoffRate j := by ring
      _ ≤ C * paper3HoffRate j :=
          mul_le_mul_of_nonneg_right hCge (paper3HoffRate_pos j).le

theorem paper3Headline_tendsto_div_hoffRate_zero_to_const_hoffRate
    (f : ℕ → ℝ)
    (hf0 : ∀ j : ℕ, 0 ≤ f j)
    (hlim :
      Tendsto (fun j : ℕ => f j / paper3HoffRate j) atTop (𝓝 0)) :
    ∃ C : ℝ, 0 ≤ C ∧ ∀ j : ℕ, f j ≤ C * paper3HoffRate j := by
  have hevent : ∀ᶠ j in atTop, f j ≤ paper3HoffRate j := by
    have hratio_lt_one :
        ∀ᶠ j in atTop, f j / paper3HoffRate j < 1 :=
      hlim.eventually (Iio_mem_nhds (by norm_num : (0 : ℝ) < 1))
    filter_upwards [hratio_lt_one] with j hj
    have hrate_pos : 0 < paper3HoffRate j := paper3HoffRate_pos j
    have hmul := (div_lt_iff₀ hrate_pos).mp hj
    linarith
  exact paper3Headline_eventually_le_hoffRate_to_const_hoffRate f hf0 hevent

theorem
    paper3Headline_interReadSourceCap_le_const_hoffRate_of_eventually_exp_writeStart_bound
    (Bamp : ℕ → ℝ) {C a : ℝ}
    (hC_nonneg : 0 ≤ C)
    (hBamp_nonneg_all : ∀ j : ℕ, 0 ≤ Bamp j)
    (hBamp_le : ∀ᶠ j in atTop,
      Bamp j ≤ C * Real.exp (a * selectorMUWriteStartTime (j + 1))) :
    ∃ Csrc : ℝ, 0 ≤ Csrc ∧ ∀ j : ℕ,
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          selectorInterReadSourceCap (Bamp j) j ≤
        Csrc * paper3HoffRate j := by
  let f : ℕ → ℝ := fun j =>
    Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
      selectorInterReadSourceCap (Bamp j) j
  have hf0 : ∀ j : ℕ, 0 ≤ f j := by
    intro j
    dsimp [f]
    exact mul_nonneg (Real.exp_pos _).le
      (selectorInterReadSourceCap_nonneg (hBamp_nonneg_all j) j)
  have hlim :
      Tendsto (fun j : ℕ => f j / paper3HoffRate j) atTop (𝓝 0) := by
    simpa [f] using
      paper3Headline_interReadSourceCap_div_hoffRate_tendsto_zero_of_eventually_exp_writeStart_bound
        Bamp hC_nonneg (Filter.Eventually.of_forall hBamp_nonneg_all)
        hBamp_le
  exact
    paper3Headline_tendsto_div_hoffRate_zero_to_const_hoffRate f hf0 hlim

theorem
    paper3Headline_tailZU_div_hoffRate_tendsto_zero_of_settledSlack
    (Bzu I : ℕ → ℝ)
    (hBzu0 : ∀ j : ℕ, 0 ≤ Bzu j)
    (hδ : ∀ j : ℕ, δuSettled (Bzu j) j ≤ r_LE_U)
    (hI_nonneg : ∀ j : ℕ, 0 ≤ I j) :
    Tendsto
      (fun j : ℕ =>
        (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Real.exp (-(I j)) * Bzu j) / paper3HoffRate j)
      atTop (𝓝 0) := by
  let Ctail0 : ℝ := r_LE_U / (Real.pi / 3)
  have hCtail0_nonneg : 0 ≤ Ctail0 := by
    dsimp [Ctail0]
    exact div_nonneg r_LE_U_pos.le (by positivity)
  have hmajor_tendsto :
      Tendsto
        (fun j : ℕ =>
          Ctail0 *
            (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
              Real.exp ((selectorUSettledRate + (1 / 8 : ℝ)) *
                selectorMUWriteStartTime (j + 1))))
        atTop (𝓝 0) := by
    simpa only [mul_zero] using
      tendsto_const_nhds.mul
      (paper3HeadlineWriteStartEarlyIntLower_absorbs_exp_writeStart
        (selectorUSettledRate + (1 / 8 : ℝ)))
  refine squeeze_zero' ?_ ?_ hmajor_tendsto
  · filter_upwards [] with j
    exact div_nonneg
      (mul_nonneg
        (mul_nonneg (Real.exp_pos _).le (Real.exp_pos _).le)
        (hBzu0 j))
      (paper3HoffRate_pos j).le
  · filter_upwards [] with j
    let L : ℝ := paper3HeadlineWriteStartEarlyIntLower (j + 1)
    let W : ℝ := selectorMUWriteStartTime (j + 1)
    let Hold : ℝ := selectorMUWriteHoldTime j
    have hIexp_le_one : Real.exp (-(I j)) ≤ (1 : ℝ) := by
      rw [Real.exp_le_one_iff]
      linarith [hI_nonneg j]
    have hcoef_pos :
        0 < (Real.pi / 3) *
          Real.exp (-(selectorUSettledRate * Hold)) := by
      positivity
    have hBzu_div :
        Bzu j ≤
          r_LE_U /
            ((Real.pi / 3) *
              Real.exp (-(selectorUSettledRate * Hold))) := by
      refine (le_div_iff₀ hcoef_pos).mpr ?_
      simpa [δuSettled, Hold, mul_assoc, mul_left_comm, mul_comm] using hδ j
    have hBzu_div_eq :
        r_LE_U /
            ((Real.pi / 3) *
              Real.exp (-(selectorUSettledRate * Hold))) =
          Ctail0 * Real.exp (selectorUSettledRate * Hold) := by
      dsimp [Ctail0]
      rw [Real.exp_neg]
      have hpi_ne : Real.pi / 3 ≠ 0 := by positivity
      have hexp_ne : Real.exp (selectorUSettledRate * Hold) ≠ 0 :=
        Real.exp_ne_zero _
      field_simp [hpi_ne, hexp_ne]
    have hrate_nonneg : 0 ≤ selectorUSettledRate := by
      norm_num [selectorUSettledRate, bgpParams38]
    have hHold_le_W : Hold ≤ W := by
      dsimp [Hold, W, selectorMUWriteHoldTime, selectorMUWriteStartTime]
      push_cast
      linarith [Real.pi_pos]
    have harg_le :
        selectorUSettledRate * Hold ≤ selectorUSettledRate * W :=
      mul_le_mul_of_nonneg_left hHold_le_W hrate_nonneg
    have hBzu_le_W :
        Bzu j ≤ Ctail0 * Real.exp (selectorUSettledRate * W) := by
      calc
        Bzu j ≤
            r_LE_U /
              ((Real.pi / 3) *
                Real.exp (-(selectorUSettledRate * Hold))) := hBzu_div
        _ = Ctail0 * Real.exp (selectorUSettledRate * Hold) := hBzu_div_eq
        _ ≤ Ctail0 * Real.exp (selectorUSettledRate * W) :=
            mul_le_mul_of_nonneg_left (Real.exp_le_exp.mpr harg_le)
              hCtail0_nonneg
    have hinner :
        Real.exp (-(I j)) * Bzu j ≤
          Ctail0 * Real.exp (selectorUSettledRate * W) := by
      calc
        Real.exp (-(I j)) * Bzu j ≤ 1 * Bzu j :=
          mul_le_mul_of_nonneg_right hIexp_le_one (hBzu0 j)
        _ = Bzu j := by ring
        _ ≤ Ctail0 * Real.exp (selectorUSettledRate * W) := hBzu_le_W
    have hnum_le :
        Real.exp (-L) * Real.exp (-(I j)) * Bzu j ≤
          Real.exp (-L) *
            (Ctail0 * Real.exp (selectorUSettledRate * W)) := by
      calc
        Real.exp (-L) * Real.exp (-(I j)) * Bzu j =
            Real.exp (-L) * (Real.exp (-(I j)) * Bzu j) := by ring
        _ ≤ Real.exp (-L) *
            (Ctail0 * Real.exp (selectorUSettledRate * W)) :=
              mul_le_mul_of_nonneg_left hinner (Real.exp_pos _).le
    have hinv :
        (paper3HoffRate j)⁻¹ ≤ Real.exp ((1 / 8 : ℝ) * W) := by
      simpa [W] using paper3HoffRate_inv_le_exp_writeStart j
    have hmaj_nonneg :
        0 ≤ Real.exp (-L) *
          (Ctail0 * Real.exp (selectorUSettledRate * W)) := by
      positivity
    have hprod :=
      mul_le_mul hnum_le hinv
        (inv_nonneg.mpr (paper3HoffRate_pos j).le) hmaj_nonneg
    calc
      (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Real.exp (-(I j)) * Bzu j) / paper3HoffRate j
          =
        (Real.exp (-L) * Real.exp (-(I j)) * Bzu j) *
          (paper3HoffRate j)⁻¹ := by
            rw [div_eq_mul_inv]
      _ ≤
        (Real.exp (-L) *
            (Ctail0 * Real.exp (selectorUSettledRate * W))) *
          Real.exp ((1 / 8 : ℝ) * W) := hprod
      _ =
        Ctail0 *
          (Real.exp (-L) *
            Real.exp ((selectorUSettledRate + (1 / 8 : ℝ)) * W)) := by
        calc
          (Real.exp (-L) *
              (Ctail0 * Real.exp (selectorUSettledRate * W))) *
              Real.exp ((1 / 8 : ℝ) * W)
              =
            Ctail0 *
              (Real.exp (-L) *
                (Real.exp (selectorUSettledRate * W) *
                  Real.exp ((1 / 8 : ℝ) * W))) := by ring
          _ =
            Ctail0 *
              (Real.exp (-L) *
                Real.exp (selectorUSettledRate * W + (1 / 8 : ℝ) * W)) := by
              rw [← Real.exp_add]
          _ =
            Ctail0 *
              (Real.exp (-L) *
                Real.exp ((selectorUSettledRate + (1 / 8 : ℝ)) * W)) := by
              rw [show
                selectorUSettledRate * W + (1 / 8 : ℝ) * W =
                  (selectorUSettledRate + (1 / 8 : ℝ)) * W by ring]
      _ =
        Ctail0 *
          (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            Real.exp ((selectorUSettledRate + (1 / 8 : ℝ)) *
              selectorMUWriteStartTime (j + 1))) := by
          simp [L, W]

theorem paper3Headline_tailZU_le_const_hoffRate_of_settledSlack
    (Bzu I : ℕ → ℝ)
    (hBzu0 : ∀ j : ℕ, 0 ≤ Bzu j)
    (hδ : ∀ j : ℕ, δuSettled (Bzu j) j ≤ r_LE_U)
    (hI_nonneg : ∀ j : ℕ, 0 ≤ I j) :
    ∃ Ctail : ℝ, 0 ≤ Ctail ∧ ∀ j : ℕ,
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          (Real.exp (-(I j)) * Bzu j) ≤
        Ctail * paper3HoffRate j := by
  let f : ℕ → ℝ := fun j =>
    Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
      (Real.exp (-(I j)) * Bzu j)
  have hf0 : ∀ j : ℕ, 0 ≤ f j := by
    intro j
    dsimp [f]
    exact mul_nonneg (Real.exp_pos _).le
      (mul_nonneg (Real.exp_pos _).le (hBzu0 j))
  have hlim :
      Tendsto (fun j : ℕ => f j / paper3HoffRate j) atTop (𝓝 0) := by
    have htail :=
      paper3Headline_tailZU_div_hoffRate_tendsto_zero_of_settledSlack
        Bzu I hBzu0 hδ hI_nonneg
    refine htail.congr' ?_
    filter_upwards [] with j
    dsimp [f]
    ring
  exact
    paper3Headline_tendsto_div_hoffRate_zero_to_const_hoffRate f hf0 hlim

theorem
    paper3Headline_exp_neg_writeStartEarlyIntLower_mul_nonneg_const_le_const_hoffRate
    (A : ℝ) (hA0 : 0 ≤ A) :
    ∃ C : ℝ, 0 ≤ C ∧ ∀ j : ℕ,
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) * A ≤
        C * paper3HoffRate j := by
  let f : ℕ → ℝ := fun j =>
    Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) * A
  have hf0 : ∀ j : ℕ, 0 ≤ f j := by
    intro j
    dsimp [f]
    exact mul_nonneg (Real.exp_pos _).le hA0
  have hlim :
      Tendsto (fun j : ℕ => f j / paper3HoffRate j) atTop (𝓝 0) := by
    have hmajor_tendsto :
        Tendsto
          (fun j : ℕ =>
            A *
              (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
                Real.exp ((1 / 8 : ℝ) * selectorMUWriteStartTime (j + 1))))
          atTop (𝓝 0) := by
      simpa only [mul_zero] using
        tendsto_const_nhds.mul
          (paper3HeadlineWriteStartEarlyIntLower_absorbs_exp_writeStart
            (1 / 8 : ℝ))
    refine squeeze_zero' ?_ ?_ hmajor_tendsto
    · filter_upwards [] with j
      exact div_nonneg (hf0 j) (paper3HoffRate_pos j).le
    · filter_upwards [] with j
      let L : ℝ := paper3HeadlineWriteStartEarlyIntLower (j + 1)
      let W : ℝ := selectorMUWriteStartTime (j + 1)
      have hinv :
          (paper3HoffRate j)⁻¹ ≤ Real.exp ((1 / 8 : ℝ) * W) := by
        simpa [W] using paper3HoffRate_inv_le_exp_writeStart j
      have hleft_nonneg : 0 ≤ Real.exp (-L) * A := by
        exact mul_nonneg (Real.exp_pos _).le hA0
      have hprod :=
        mul_le_mul_of_nonneg_left hinv hleft_nonneg
      calc
        f j / paper3HoffRate j =
            (Real.exp (-L) * A) * (paper3HoffRate j)⁻¹ := by
              dsimp [f, L]
              rw [div_eq_mul_inv]
        _ ≤ (Real.exp (-L) * A) * Real.exp ((1 / 8 : ℝ) * W) := hprod
        _ = A * (Real.exp (-L) * Real.exp ((1 / 8 : ℝ) * W)) := by ring
        _ = A *
            (Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
              Real.exp ((1 / 8 : ℝ) * selectorMUWriteStartTime (j + 1))) := by
              simp [L, W]
  exact
    paper3Headline_tendsto_div_hoffRate_zero_to_const_hoffRate f hf0 hlim

theorem paper3Headline_activeQSS_Rstart_fixed_part_le_const_hoffRate :
    ∃ Cfixed : ℝ, 0 ≤ Cfixed ∧ ∀ j : ℕ,
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          (r_LE_U + ((D_U : ℝ) - 2)) ≤
        Cfixed * paper3HoffRate j := by
  exact
    paper3Headline_exp_neg_writeStartEarlyIntLower_mul_nonneg_const_le_const_hoffRate
      (r_LE_U + ((D_U : ℝ) - 2))
      (by
        have hDU : (2 : ℝ) ≤ D_U := by
          norm_num [D_U]
        nlinarith [r_LE_U_pos.le])

theorem paper3Headline_rPulse_one_le_quarter_of_sin_ge_half
    {t : ℝ} (hsin : (1 : ℝ) / 2 ≤ Real.sin t) :
    rPulse 1 t ≤ (1 / 4 : ℝ) := by
  unfold rPulse
  simp only [pow_one]
  linarith

/-- The start-to-early z-write mass dominates
`paper3HeadlineWriteStartEarlyIntLower`.  On this prefix we only have
`sin ≥ 1/2`, so the pulse cap is `rPulse ≤ 1/4`; this is exactly the lower
needed for the Duhamel start kernel at every time in the active suffix. -/
theorem paper3Headline_writeStartEarlyIntLower_le_gateZ_integral
    (wg w j : ℕ) :
    paper3HeadlineWriteStartEarlyIntLower j ≤
      ∫ t in selectorMUWriteStartTime j..selectorMUEarlyWriteSubStart j,
        bgpParams38.A * ((paper3HeadlineSolFam wg) w).α t *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ t) t := by
  let solw := (paper3HeadlineSolFam wg) w
  let W : ℝ := selectorMUWriteStartTime j
  let E : ℝ := selectorMUEarlyWriteSubStart j
  let k : ℝ → ℝ := fun t =>
    bgpParams38.A * solw.α t * bGateZ bgpParams38.L (solw.μ t) t
  let lower : ℝ :=
    Real.exp (bgpParams38.cα * W) *
      Real.exp (-((bgpParams38.cμ / 4) * E))
  have hWE : W ≤ E := by
    simpa [W, E] using selectorMUWriteStart_le_earlySubStart j
  have hW0 : 0 ≤ W := by
    simpa [W] using selectorMUWriteStartTime_nonneg j
  have hE0 : 0 ≤ E := le_trans hW0 hWE
  have hk_cont : Continuous k := by
    simpa [k, solw] using selector_replicator_gateZ_integrand_continuous solw
  have hα : ∀ t ∈ Icc W E, solw.α t = Real.exp (bgpParams38.cα * t) := by
    intro t ht
    exact solw.alpha_eq_exp selectorSchedule_domain_of_nonneg_structural
      (le_trans hW0 ht.1)
  have hμ : ∀ t ∈ Icc W E, solw.μ t = bgpParams38.cμ * t := by
    intro t ht
    rw [solw.mu_eq_linear selectorSchedule_domain_of_nonneg_structural
      (le_trans hW0 ht.1), solw.μ_at_zero]
    simp [bgpParams38]
  have hsin : ∀ t ∈ Icc W E, (1 : ℝ) / 2 ≤ Real.sin t := by
    intro t ht
    exact sin_window_ge j
      (by simpa [W, selectorMUWriteStartTime] using ht.1)
      (by
        have hright :
            selectorMUEarlyWriteSubStart j ≤
              2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6 := by
          unfold selectorMUEarlyWriteSubStart
          linarith [Real.pi_pos]
        exact le_trans (by simpa [E] using ht.2) hright)
  have hpoint : ∀ t ∈ Icc W E, lower ≤ k t := by
    intro t ht
    have ht0 : 0 ≤ t := le_trans hW0 ht.1
    have hαle :
        Real.exp (bgpParams38.cα * W) ≤ Real.exp (bgpParams38.cα * t) := by
      exact Real.exp_le_exp.mpr
        (mul_le_mul_of_nonneg_left ht.1
          (by norm_num [bgpParams38] : 0 ≤ bgpParams38.cα))
    have hrp : rPulse 1 t ≤ (1 / 4 : ℝ) :=
      paper3Headline_rPulse_one_le_quarter_of_sin_ge_half (hsin t ht)
    have hrpL : rPulse bgpParams38.L t ≤ (1 / 4 : ℝ) := by
      simpa [bgpParams38] using hrp
    have htr :
        (bgpParams38.cμ * t) * rPulse bgpParams38.L t ≤
          (bgpParams38.cμ / 4) * E := by
      have hcμ_nonneg : 0 ≤ bgpParams38.cμ := by
        norm_num [bgpParams38]
      have hleft :
          bgpParams38.cμ * t ≤ bgpParams38.cμ * E :=
        mul_le_mul_of_nonneg_left ht.2 hcμ_nonneg
      have hright_nonneg :
          0 ≤ rPulse bgpParams38.L t :=
        rPulse_nonneg bgpParams38.L t
      have htop_nonneg : 0 ≤ bgpParams38.cμ * E :=
        mul_nonneg hcμ_nonneg hE0
      have hmul :=
        mul_le_mul hleft hrpL hright_nonneg htop_nonneg
      nlinarith [hmul]
    have hgate :
        Real.exp (-((bgpParams38.cμ / 4) * E)) ≤
          bGateZ bgpParams38.L (solw.μ t) t := by
      rw [hμ t ht]
      calc
        Real.exp (-((bgpParams38.cμ / 4) * E))
            ≤ Real.exp (-((bgpParams38.cμ * t) * rPulse bgpParams38.L t)) := by
              exact Real.exp_le_exp.mpr (by linarith)
        _ = bGateZ bgpParams38.L (bgpParams38.cμ * t) t := by
              unfold bGateZ
              ring
    have hmul :=
      mul_le_mul hαle hgate (Real.exp_pos _).le (Real.exp_pos _).le
    calc
      lower = Real.exp (bgpParams38.cα * W) *
          Real.exp (-((bgpParams38.cμ / 4) * E)) := rfl
      _ ≤ Real.exp (bgpParams38.cα * t) *
          bGateZ bgpParams38.L (solw.μ t) t := hmul
      _ = k t := by
          dsimp [k]
          rw [hα t ht]
          norm_num [bgpParams38]
  have hconst :
      (∫ _t in W..E, lower) =
        lower * (E - W) := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
    ring
  have hlen : E - W = Real.pi / 12 := by
    dsimp [E, W, selectorMUEarlyWriteSubStart, selectorMUWriteStartTime]
    ring
  calc
    paper3HeadlineWriteStartEarlyIntLower j
        = lower * (E - W) := by
            dsimp [paper3HeadlineWriteStartEarlyIntLower, lower, E, W]
            rw [hlen]
    _ = ∫ _t in W..E, lower := hconst.symm
    _ ≤ ∫ t in W..E, k t :=
        intervalIntegral.integral_mono_on hWE _root_.intervalIntegrable_const
          (hk_cont.intervalIntegrable W E) hpoint
    _ = ∫ t in selectorMUWriteStartTime j..selectorMUEarlyWriteSubStart j,
        bgpParams38.A * ((paper3HeadlineSolFam wg) w).α t *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ t) t := by
        simp [k, W, E, solw]

/-- Uniform bound for the Duhamel start kernel on the active suffix, using the
new start-to-early z-write lower. -/
theorem paper3Headline_activeSuffix_startKernel_le_writeStartEarly
    (wg w j : ℕ) {τ : ℝ}
    (hτ : τ ∈ Icc (selectorMUEarlyWriteSubStart (j + 1))
        (selectorMUWriteHoldTime (j + 1))) :
    Real.exp (-(∫ s in selectorMUWriteStartTime (j + 1)..τ,
        bgpParams38.A * ((paper3HeadlineSolFam wg) w).α s *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ s) s)) ≤
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) := by
  let solw := (paper3HeadlineSolFam wg) w
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let k : ℝ → ℝ := fun s =>
    bgpParams38.A * solw.α s * bGateZ bgpParams38.L (solw.μ s) s
  have hWE : W ≤ E := by
    simpa [W, E] using selectorMUWriteStart_le_earlySubStart (j + 1)
  have hEτ : E ≤ τ := by
    simpa [E] using hτ.1
  have hWτ : W ≤ τ := le_trans hWE hEτ
  have hk_cont : Continuous k := by
    simpa [k, solw] using selector_replicator_gateZ_integrand_continuous solw
  have hk0_prefix : 0 ≤ ∫ s in E..τ, k s := by
    apply intervalIntegral.integral_nonneg hEτ
    intro s hs
    have hW0 : 0 ≤ W := by
      simpa [W] using selectorMUWriteStartTime_nonneg (j + 1)
    have hs0 : 0 ≤ s := le_trans (le_trans hW0 hWE) hs.1
    exact selector_replicator_gateZ_integrand_nonneg solw
      selectorSchedule_domain_of_nonneg_structural
      (by norm_num [bgpParams38]) hs0
  have hWE_int : IntervalIntegrable k MeasureTheory.volume W E :=
    hk_cont.intervalIntegrable W E
  have hEτ_int : IntervalIntegrable k MeasureTheory.volume E τ :=
    hk_cont.intervalIntegrable E τ
  have hadd :
      (∫ s in W..E, k s) + (∫ s in E..τ, k s) =
        ∫ s in W..τ, k s :=
    intervalIntegral.integral_add_adjacent_intervals hWE_int hEτ_int
  have hlower :=
    paper3Headline_writeStartEarlyIntLower_le_gateZ_integral wg w (j + 1)
  have hWτ_lower :
      paper3HeadlineWriteStartEarlyIntLower (j + 1) ≤ ∫ s in W..τ, k s := by
    calc
      paper3HeadlineWriteStartEarlyIntLower (j + 1)
          ≤ ∫ s in W..E, k s := by
              simpa [W, E, k, solw] using hlower
      _ ≤ (∫ s in W..E, k s) + ∫ s in E..τ, k s := by
              linarith
      _ = ∫ s in W..τ, k s := hadd
  exact Real.exp_le_exp.mpr (neg_le_neg hWτ_lower)

theorem paper3Headline_activeSuffix_weighted_startKernel_le_writeStartEarly
    (wg w j : ℕ) {Rstart Rmix τ : ℝ}
    (hRstart0 : 0 ≤ Rstart)
    (hτ : τ ∈ Icc (selectorMUEarlyWriteSubStart (j + 1))
        (selectorMUWriteHoldTime (j + 1))) :
    Real.exp (-(∫ s in selectorMUWriteStartTime (j + 1)..τ,
        bgpParams38.A * ((paper3HeadlineSolFam wg) w).α s *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ s) s)) *
          Rstart + Rmix ≤
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Rstart + Rmix := by
  have hk :=
    paper3Headline_activeSuffix_startKernel_le_writeStartEarly
      (wg := wg) (w := w) (j := j) (τ := τ) hτ
  simpa [add_comm, add_left_comm, add_assoc] using
    add_le_add_right (mul_le_mul_of_nonneg_right hk hRstart0) Rmix

theorem paper3Headline_activeSuffix_kernelURhs_le_writeStartEarly
    (wg w j : ℕ) {Rstart Rmix EncB τ : ℝ}
    (hRstart0 : 0 ≤ Rstart)
    (hτ : τ ∈ Icc (selectorMUEarlyWriteSubStart (j + 1))
        (selectorMUWriteHoldTime (j + 1))) :
    (((Real.exp (-(∫ s in selectorMUWriteStartTime (j + 1)..τ,
        bgpParams38.A * ((paper3HeadlineSolFam wg) w).α s *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ s) s)) *
            Rstart + Rmix) + EncB) + r_LE_U) *
        Real.exp (-(selectorUSettledRate *
          selectorMUWriteStartTime (j + 1))) ≤
      (((Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            Rstart + Rmix) + EncB) + r_LE_U) *
        Real.exp (-(selectorUSettledRate *
          selectorMUWriteStartTime (j + 1))) := by
  have hZK :=
    paper3Headline_activeSuffix_weighted_startKernel_le_writeStartEarly
      (wg := wg) (w := w) (j := j) (Rstart := Rstart)
      (Rmix := Rmix) (τ := τ) hRstart0 hτ
  have hsum_base :
      ((Real.exp (-(∫ s in selectorMUWriteStartTime (j + 1)..τ,
          bgpParams38.A * ((paper3HeadlineSolFam wg) w).α s *
            bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ s) s)) *
            Rstart + Rmix) + EncB) + r_LE_U ≤
      ((Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            Rstart + Rmix) + EncB) + r_LE_U :=
    by linarith [hZK]
  exact mul_le_mul_of_nonneg_right hsum_base
    (Real.exp_pos (-(selectorUSettledRate *
      selectorMUWriteStartTime (j + 1)))).le

/-- Kernel major with the start-kernel already collapsed to the uniform
write-start-to-early lower bound. -/
@[irreducible]
def paper3HeadlineActiveQSSKernelMajorEarly
    (wg w j : ℕ) (Rstart Rmix EncB : ℝ)
    (v : UniversalLocalView) (τ : ℝ) : ℝ :=
  let sol := paper3HeadlineSolFam wg
  let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let gap : ℝ :=
    selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
  let CrD : ℝ := (paper3HeadlineM : ℝ) * |(paper3HeadlineKappa : ℝ)|
  let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
  let ZK : ℝ :=
    Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) * Rstart + Rmix
  let URhs : ℝ :=
    ((ZK + EncB) + r_LE_U) *
      Real.exp (-(selectorUSettledRate * W))
  let CgD : ℝ :=
    ((paper3HeadlineM : ℝ) + bgpParams38.cα) *
      (|((paper3WarmGainQ wg : ℚ) : ℝ)| * Real.exp (bgpParams38.cα * τ))
  let Grad : ℝ :=
    selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos c
        (fun k : Fin d_U =>
          r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|) +
      selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
        (fun k : Fin d_U =>
          r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|)
  (1 / card) *
    (CrD / gamma +
      (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (CgD * 1 +
            selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
              (Grad * URhs))) /
        gamma ^ 2)

theorem paper3HeadlineActiveQSSKernelMajor_le_writeStartEarly
    (wg w j : ℕ) {Rstart Rmix EncB τ : ℝ}
    (hRstart0 : 0 ≤ Rstart)
    (hτ : τ ∈ Icc (selectorMUEarlyWriteSubStart (j + 1))
        (selectorMUWriteHoldTime (j + 1)))
    (v : UniversalLocalView) :
    paper3HeadlineActiveQSSKernelMajor wg w j Rstart Rmix EncB v τ ≤
      paper3HeadlineActiveQSSKernelMajorEarly wg w j Rstart Rmix EncB v τ := by
  let sol := paper3HeadlineSolFam wg
  let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let gap : ℝ :=
    selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
  let CrD : ℝ := (paper3HeadlineM : ℝ) * |(paper3HeadlineKappa : ℝ)|
  let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
  let gateZ : ℝ → ℝ := fun t =>
    bgpParams38.A * ((sol w).α t) *
      bGateZ bgpParams38.L ((sol w).μ t) t
  let ZK : ℝ :=
    Real.exp (-(∫ s in W..τ, gateZ s)) * Rstart + Rmix
  let ZKearly : ℝ :=
    Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) * Rstart + Rmix
  let URhs : ℝ :=
    ((ZK + EncB) + r_LE_U) *
      Real.exp (-(selectorUSettledRate * W))
  let URhsEarly : ℝ :=
    ((ZKearly + EncB) + r_LE_U) *
      Real.exp (-(selectorUSettledRate * W))
  let CgD : ℝ :=
    ((paper3HeadlineM : ℝ) + bgpParams38.cα) *
      (|((paper3WarmGainQ wg : ℚ) : ℝ)| * Real.exp (bgpParams38.cα * τ))
  let Grad : ℝ :=
    selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos c
        (fun k : Fin d_U =>
          r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|) +
      selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
        (fun k : Fin d_U =>
          r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|)
  have hURhs : URhs ≤ URhsEarly := by
    simpa [sol, W, E, gateZ, ZK, ZKearly, URhs, URhsEarly] using
      paper3Headline_activeSuffix_kernelURhs_le_writeStartEarly
        (wg := wg) (w := w) (j := j)
        (Rstart := Rstart) (Rmix := Rmix) (EncB := EncB)
        (τ := τ) hRstart0 hτ
  have hcr_nonneg :
      0 ≤ selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ := by
    dsimp [selectorMU_activeCr]
    have hbase0 : 0 ≤ (1 + Real.cos τ) / 2 := by
      nlinarith [Real.neg_one_le_cos τ]
    exact mul_nonneg (pow_nonneg hbase0 paper3HeadlineM)
      (by norm_num [paper3HeadlineKappa])
  have hcg_nonneg :
      0 ≤ selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ := by
    dsimp [selectorMU_activeCg]
    have hbase0 : 0 ≤ (1 + Real.sin τ) / 2 := by
      nlinarith [Real.neg_one_le_sin τ]
    exact mul_nonneg (pow_nonneg hbase0 paper3HeadlineM)
      (mul_nonneg (paper3WarmGainQ_nonneg wg) (Real.exp_pos _).le)
  have hrad0 :
      ∀ k : Fin d_U,
        0 ≤ r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)| := by
    intro k
    exact add_nonneg r_LE_U_pos.le (abs_nonneg _)
  have hGrad_nonneg : 0 ≤ Grad := by
    dsimp [Grad]
    exact add_nonneg
      (selectorMU_pvalGradBoxBound_nonneg
        paper3HeadlineEta paper3HeadlineEta_pos c hrad0)
      (selectorMU_pvalGradBoxBound_nonneg
        paper3HeadlineEta paper3HeadlineEta_pos v hrad0)
  have hinner :
      CgD * 1 +
          selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
            (Grad * URhs) ≤
        CgD * 1 +
          selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
            (Grad * URhsEarly) := by
    have hgrad_mul : Grad * URhs ≤ Grad * URhsEarly :=
      mul_le_mul_of_nonneg_left hURhs hGrad_nonneg
    have hcg_mul :
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
            (Grad * URhs) ≤
          selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
            (Grad * URhsEarly) :=
      mul_le_mul_of_nonneg_left hgrad_mul hcg_nonneg
    linarith
  have hfrac :
      (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (CgD * 1 +
            selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
              (Grad * URhs))) /
          gamma ^ 2 ≤
        (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (CgD * 1 +
            selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
              (Grad * URhsEarly))) /
          gamma ^ 2 := by
    have hmul :=
      mul_le_mul_of_nonneg_left hinner hcr_nonneg
    exact div_le_div_of_nonneg_right hmul (sq_nonneg gamma)
  have hsum :
      CrD / gamma +
        (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
            (CgD * 1 +
              selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
                (Grad * URhs))) /
            gamma ^ 2 ≤
      CrD / gamma +
        (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
            (CgD * 1 +
              selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
                (Grad * URhsEarly))) /
            gamma ^ 2 := by
    simpa [add_comm, add_left_comm, add_assoc] using
      add_le_add_left hfrac (CrD / gamma)
  have hcard_nonneg : 0 ≤ 1 / card := by
    dsimp [card]
    positivity
  have hmain :=
    mul_le_mul_of_nonneg_left hsum hcard_nonneg
  unfold paper3HeadlineActiveQSSKernelMajor
  unfold paper3HeadlineActiveQSSKernelMajorEarly
  dsimp [sol, c, W, E, gap, D, gamma, CrD, card, gateZ, ZK, ZKearly,
    URhs, URhsEarly, CgD, Grad] at hmain ⊢
  simpa [sol, c, W, E, gap, D, gamma, CrD, card, gateZ, ZK, ZKearly,
    URhs, URhsEarly, CgD, Grad] using hmain

theorem paper3Headline_D_U_ge_eight : (8 : ℝ) ≤ D_U := by
  unfold D_U
  exact le_max_left _ _

section HeadlineEncodingBox

open Turing.PartrecToTM2

theorem paper3Headline_one_le_two_D_U : (1 : ℝ) ≤ 2 * D_U := by
  have hD := paper3Headline_D_U_ge_eight
  nlinarith

theorem paper3Headline_confEncU_stack_abs_le_one (c : UConf) (k : K') :
    |(confEncU c (stackCoordU k) : ℝ)| ≤ (1 : ℝ) := by
  have hgap := confEncU_stack_gap_range c k
  have hnonneg : (0 : ℝ) ≤ (confEncU c (stackCoordU k) : ℝ) := by
    exact_mod_cast (le_of_lt hgap.1)
  have hle : (confEncU c (stackCoordU k) : ℝ) ≤ (1 : ℝ) := by
    have hleQ := hgap.2.1
    have hleR :
        (confEncU c (stackCoordU k) : ℝ) ≤
          ((((bot B_U : ℕ) : ℚ) / (B_U : ℚ)) : ℝ) := by
      exact_mod_cast hleQ
    have hbot :
        ((((bot B_U : ℕ) : ℚ) / (B_U : ℚ)) : ℝ) ≤ (1 : ℝ) := by
      norm_num [bot, B_U]
    exact hleR.trans hbot
  rw [abs_of_nonneg hnonneg]
  exact hle

theorem paper3Headline_ctrlVarCodeU_abs_le_two_D_U
    (q : Option (SuppLabel c_f)) (v : Option Γ') :
    |(ctrlVarCodeU q v : ℝ)| ≤ 2 * D_U := by
  let C : ℕ := Fintype.card (Option (SuppLabel c_f) × Option Γ')
  let e := Fintype.equivFin (Option (SuppLabel c_f) × Option Γ')
  have hnonneg : (0 : ℝ) ≤ (ctrlVarCodeU q v : ℝ) := by
    unfold ctrlVarCodeU
    positivity
  have hcode_le : (ctrlVarCodeU q v : ℝ) ≤ 2 * (C : ℝ) := by
    unfold ctrlVarCodeU
    change ((2 * (e (q, v)).val : ℕ) : ℝ) ≤ 2 * (C : ℝ)
    exact_mod_cast (Nat.mul_le_mul_left 2 (Nat.le_of_lt (e (q, v)).isLt))
  have hC_le_D : 2 * (C : ℝ) ≤ D_U := by
    unfold D_U C
    exact le_trans
      (by
        linarith :
          2 * (Fintype.card (Option (SuppLabel c_f) × Option Γ') : ℝ) ≤
            2 * (Fintype.card (Option (SuppLabel c_f) × Option Γ') : ℝ) + 2)
      (le_max_right _ _)
  rw [abs_of_nonneg hnonneg]
  nlinarith [hcode_le, hC_le_D, D_U_nonneg]

theorem paper3Headline_confEncU_halt_abs_le_one (c : UConf) :
    |(confEncU c haltCoordU : ℝ)| ≤ (1 : ℝ) := by
  rw [confEncU_halt]
  unfold haltFlagU
  by_cases h : finHalted c
  · simp [h]
  · simp [h]

/-- Coarse q-free absolute coordinate bound for concrete universal encodings. -/
theorem paper3Headline_confEncU_abs_le_two_D_U
    (c : UConf) (i : Fin d_U) :
    |(confEncU c i : ℝ)| ≤ 2 * D_U := by
  fin_cases i
  · exact (by
      simpa [mainStackCoordU, stackCoordU] using
        (paper3Headline_confEncU_stack_abs_le_one c K'.main).trans
          paper3Headline_one_le_two_D_U)
  · exact (by
      simpa [revStackCoordU, stackCoordU] using
        (paper3Headline_confEncU_stack_abs_le_one c K'.rev).trans
          paper3Headline_one_le_two_D_U)
  · exact (by
      simpa [auxStackCoordU, stackCoordU] using
        (paper3Headline_confEncU_stack_abs_le_one c K'.aux).trans
          paper3Headline_one_le_two_D_U)
  · exact (by
      simpa [dataStackCoordU, stackCoordU] using
        (paper3Headline_confEncU_stack_abs_le_one c K'.stack).trans
          paper3Headline_one_le_two_D_U)
  · exact (by
      simpa [ctrlCoordU] using
          paper3Headline_ctrlVarCodeU_abs_le_two_D_U c.1 c.2.1)
  · exact (by
      simpa [haltCoordU] using
        (paper3Headline_confEncU_halt_abs_le_one c).trans
          paper3Headline_one_le_two_D_U)

end HeadlineEncodingBox

/-- A q-free finite box for selector payoff gradients over all local views. -/
def paper3HeadlineGradBoxConst : ℝ :=
  ∑ v : UniversalLocalView,
    selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
      (fun _ : Fin d_U => r_LE_U + 2 * D_U)

theorem paper3HeadlineGradBoxConst_nonneg :
    0 ≤ paper3HeadlineGradBoxConst := by
  have hr0 : ∀ k : Fin d_U, 0 ≤ r_LE_U + 2 * D_U := by
    intro k
    nlinarith [r_LE_U_pos.le, D_U_nonneg]
  dsimp [paper3HeadlineGradBoxConst]
  exact Finset.sum_nonneg fun v _ =>
    selectorMU_pvalGradBoxBound_nonneg
      paper3HeadlineEta paper3HeadlineEta_pos v hr0

theorem paper3HeadlineGradBoxConst_two_nonneg :
    0 ≤ 2 * paper3HeadlineGradBoxConst := by
  nlinarith [paper3HeadlineGradBoxConst_nonneg]

theorem
    paper3Headline_selectorMU_pvalGradBoxBound_le_radiusConst
    (v : UniversalLocalView) (c : UConf) :
    selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
        (fun k : Fin d_U => r_LE_U + |(confEncU c k : ℝ)|) ≤
      selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
        (fun _ : Fin d_U => r_LE_U + 2 * D_U) := by
  dsimp [selectorMU_pvalGradBoxBound, selectorMU_pvalPderivBoxBound]
  refine Finset.sum_le_sum ?_
  intro i _
  refine EncBoxCore.mvPolynomialBoxBound_mono _ ?_ ?_
  · intro k
    exact add_nonneg r_LE_U_pos.le (abs_nonneg _)
  · intro k
    nlinarith [paper3Headline_confEncU_abs_le_two_D_U c k]

theorem paper3Headline_selectorMU_pvalGradBoxBound_le_const
    (v : UniversalLocalView) (c : UConf) :
    selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
        (fun k : Fin d_U => r_LE_U + |(confEncU c k : ℝ)|) ≤
      paper3HeadlineGradBoxConst := by
  have hmono :=
    paper3Headline_selectorMU_pvalGradBoxBound_le_radiusConst v c
  have hr0 : ∀ k : Fin d_U, 0 ≤ r_LE_U + 2 * D_U := by
    intro k
    nlinarith [r_LE_U_pos.le, D_U_nonneg]
  have hsum :
      selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
          (fun _ : Fin d_U => r_LE_U + 2 * D_U) ≤
        paper3HeadlineGradBoxConst := by
    dsimp [paper3HeadlineGradBoxConst]
    exact Finset.single_le_sum
      (fun u _ =>
        selectorMU_pvalGradBoxBound_nonneg
          paper3HeadlineEta paper3HeadlineEta_pos u hr0)
      (Finset.mem_univ v)
  exact hmono.trans hsum

theorem paper3Headline_activeQSSKernelMajorEarly_Grad_le_const
    (w j : ℕ) (v : UniversalLocalView) :
    (let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
     selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos c
        (fun k : Fin d_U =>
          r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|) +
      selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
        (fun k : Fin d_U =>
          r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|))
      ≤ 2 * paper3HeadlineGradBoxConst := by
  let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
  have hc :
      selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos c
          (fun k : Fin d_U =>
            r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|) ≤
        paper3HeadlineGradBoxConst :=
    paper3Headline_selectorMU_pvalGradBoxBound_le_const c
      (solMUReplStaticCfg w (j + 1))
  have hv :
      selectorMU_pvalGradBoxBound paper3HeadlineEta paper3HeadlineEta_pos v
          (fun k : Fin d_U =>
            r_LE_U + |(confEncU (solMUReplStaticCfg w (j + 1)) k : ℝ)|) ≤
        paper3HeadlineGradBoxConst :=
    paper3Headline_selectorMU_pvalGradBoxBound_le_const v
      (solMUReplStaticCfg w (j + 1))
  dsimp [c]
  nlinarith [hc, hv]

theorem paper3Headline_activeCr_nonneg (τ : ℝ) :
    0 ≤ selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ := by
  dsimp [selectorMU_activeCr]
  have hbase0 : 0 ≤ (1 + Real.cos τ) / 2 := by
    nlinarith [Real.neg_one_le_cos τ]
  exact mul_nonneg (pow_nonneg hbase0 paper3HeadlineM)
    (by norm_num [paper3HeadlineKappa])

theorem paper3Headline_activeCr_le_one (τ : ℝ) :
    selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ ≤ 1 := by
  dsimp [selectorMU_activeCr]
  have hbase0 : 0 ≤ (1 + Real.cos τ) / 2 := by
    nlinarith [Real.neg_one_le_cos τ]
  have hbase1 : (1 + Real.cos τ) / 2 ≤ 1 := by
    nlinarith [Real.cos_le_one τ]
  have hpow : ((1 + Real.cos τ) / 2) ^ paper3HeadlineM ≤ 1 :=
    pow_le_one₀ hbase0 hbase1
  simpa [paper3HeadlineKappa] using hpow

theorem paper3Headline_activeCg_nonneg (wg : ℕ) (τ : ℝ) :
    0 ≤ selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ := by
  dsimp [selectorMU_activeCg]
  have hbase0 : 0 ≤ (1 + Real.sin τ) / 2 := by
    nlinarith [Real.neg_one_le_sin τ]
  exact mul_nonneg (pow_nonneg hbase0 paper3HeadlineM)
    (mul_nonneg (paper3WarmGainQ_nonneg wg) (Real.exp_pos _).le)

theorem paper3Headline_activeCg_le_gain_exp (wg : ℕ) (τ : ℝ) :
    selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ ≤
      ((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (bgpParams38.cα * τ) := by
  dsimp [selectorMU_activeCg]
  have hbase0 : 0 ≤ (1 + Real.sin τ) / 2 := by
    nlinarith [Real.neg_one_le_sin τ]
  have hbase1 : (1 + Real.sin τ) / 2 ≤ 1 := by
    nlinarith [Real.sin_le_one τ]
  have hpow : ((1 + Real.sin τ) / 2) ^ paper3HeadlineM ≤ 1 :=
    pow_le_one₀ hbase0 hbase1
  have hgain_nonneg :
      0 ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (bgpParams38.cα * τ) :=
    mul_nonneg (paper3WarmGainQ_nonneg wg) (Real.exp_pos _).le
  calc
    ((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) *
          Real.exp (bgpParams38.cα * τ))
        ≤ 1 *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * τ)) :=
          mul_le_mul_of_nonneg_right hpow hgain_nonneg
    _ = ((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (bgpParams38.cα * τ) := by ring

theorem paper3Headline_activeKernel_D_pos (wg : ℕ) :
    0 <
      ((3 / 4 : ℝ) ^ paper3HeadlineM) *
        ((paper3WarmGainQ wg : ℚ) : ℝ) := by
  exact mul_pos
    (pow_pos (by norm_num : (0 : ℝ) < 3 / 4) paper3HeadlineM)
    (paper3WarmGainQ_pos wg)

theorem
    paper3Headline_activeQSSKernelMajorEarly_CrD_div_gamma_le_hoffRate
    (wg j : ℕ) :
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let gap : ℝ :=
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
    let CrD : ℝ := (paper3HeadlineM : ℝ) * |(paper3HeadlineKappa : ℝ)|
    CrD / gamma ≤ (CrD / (D * gap)) * paper3HoffRate j := by
  dsimp
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let gap : ℝ :=
    selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
  let CrD : ℝ := (paper3HeadlineM : ℝ) * |(paper3HeadlineKappa : ℝ)|
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hD_pos : 0 < D := by
    simpa [D] using paper3Headline_activeKernel_D_pos wg
  have hCrD_nonneg : 0 ≤ CrD := by
    dsimp [CrD]
    positivity
  have hcoeff_nonneg : 0 ≤ CrD / (D * gap) := by
    exact div_nonneg hCrD_nonneg (mul_pos hD_pos hgap_pos).le
  have hrewrite :
      CrD / gamma =
        (CrD / (D * gap)) * Real.exp (-(bgpParams38.cα * E)) := by
    dsimp [gamma]
    rw [Real.exp_neg]
    field_simp [hD_pos.ne', hgap_pos.ne',
      (Real.exp_ne_zero (bgpParams38.cα * E))]
  calc
    CrD / gamma =
        (CrD / (D * gap)) * Real.exp (-(bgpParams38.cα * E)) := hrewrite
    _ ≤ (CrD / (D * gap)) * paper3HoffRate j :=
        mul_le_mul_of_nonneg_left
          (by
            simpa [E] using
              paper3Headline_exp_neg_cAlpha_early_le_hoffRate j)
          hcoeff_nonneg

theorem
    paper3Headline_activeQSSKernelMajorEarly_activeCr_CgD_div_gamma_sq_le_hoffRate
    (wg j : ℕ) {τ : ℝ}
    (hτ : τ ∈ Set.Icc (selectorMUEarlyWriteSubStart (j + 1))
      (selectorMUWriteHoldTime (j + 1))) :
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let gap : ℝ :=
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) * q
    let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
    let CgD : ℝ := ((paper3HeadlineM : ℝ) + bgpParams38.cα) *
      (|q| * Real.exp (bgpParams38.cα * τ))
    (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
        (CgD * 1)) / gamma ^ 2 ≤
      ((((paper3HeadlineM : ℝ) + bgpParams38.cα) * |q| / ((D * gap) ^ 2)) *
        Real.exp (Real.pi / 48)) * paper3HoffRate j := by
  dsimp
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let gap : ℝ :=
    selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) * q
  let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
  let CgD : ℝ := ((paper3HeadlineM : ℝ) + bgpParams38.cα) *
    (|q| * Real.exp (bgpParams38.cα * τ))
  let coeff : ℝ := ((paper3HeadlineM : ℝ) + bgpParams38.cα) * |q| / ((D * gap) ^ 2)
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hD_pos : 0 < D := by
    simpa [D, q] using paper3Headline_activeKernel_D_pos wg
  have hgamma_pos : 0 < gamma := by
    dsimp [gamma]
    exact mul_pos (mul_pos hD_pos (Real.exp_pos _)) hgap_pos
  have hCgD_nonneg : 0 ≤ CgD := by
    dsimp [CgD]
    have hcoef_nonneg :
        0 ≤ (paper3HeadlineM : ℝ) + bgpParams38.cα := by
      norm_num [paper3HeadlineM, bgpParams38]
    exact mul_nonneg hcoef_nonneg
      (mul_nonneg (abs_nonneg q) (Real.exp_pos _).le)
  have hfrac_nonneg : 0 ≤ CgD / gamma ^ 2 := by
    exact div_nonneg hCgD_nonneg (sq_nonneg gamma)
  have hdrop :
      (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (CgD * 1)) / gamma ^ 2 ≤ CgD / gamma ^ 2 := by
    have hcr := paper3Headline_activeCr_le_one τ
    calc
      (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (CgD * 1)) / gamma ^ 2
          = selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
              (CgD / gamma ^ 2) := by
            ring
      _ ≤ 1 * (CgD / gamma ^ 2) :=
            mul_le_mul_of_nonneg_right hcr hfrac_nonneg
      _ = CgD / gamma ^ 2 := by ring
  have hrewrite :
      CgD / gamma ^ 2 =
        coeff *
          Real.exp (bgpParams38.cα * (τ - 2 * E)) := by
    have hexp :
        Real.exp (bgpParams38.cα * (τ - 2 * E)) =
          Real.exp (bgpParams38.cα * τ) /
            (Real.exp (bgpParams38.cα * E)) ^ 2 := by
      calc
        Real.exp (bgpParams38.cα * (τ - 2 * E))
            = Real.exp (bgpParams38.cα * τ -
                2 * (bgpParams38.cα * E)) := by
                congr 1
                ring
        _ = Real.exp (bgpParams38.cα * τ) /
            Real.exp (2 * (bgpParams38.cα * E)) := by
              rw [Real.exp_sub]
        _ = Real.exp (bgpParams38.cα * τ) /
            (Real.exp (bgpParams38.cα * E)) ^ 2 := by
              congr 1
              rw [show 2 * (bgpParams38.cα * E) =
                  bgpParams38.cα * E + bgpParams38.cα * E by ring,
                Real.exp_add]
              ring
    dsimp [CgD, gamma, coeff]
    rw [hexp]
    field_simp [hD_pos.ne', hgap_pos.ne',
      (Real.exp_ne_zero (bgpParams38.cα * E))]
  have hcoeff_nonneg : 0 ≤ coeff := by
    dsimp [coeff]
    exact div_nonneg
      (mul_nonneg
        (by norm_num [paper3HeadlineM, bgpParams38] :
          0 ≤ (paper3HeadlineM : ℝ) + bgpParams38.cα)
        (abs_nonneg q))
      (sq_nonneg (D * gap))
  have hexp_bound :
      Real.exp (bgpParams38.cα * (τ - 2 * E)) ≤
        Real.exp (Real.pi / 48) * paper3HoffRate j := by
    simpa [E] using
      paper3Headline_exp_activeEarly_le_exp_pi_div_fortyEight_mul_hoffRate
        j hτ
  calc
    (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
        (CgD * 1)) / gamma ^ 2 ≤ CgD / gamma ^ 2 := hdrop
    _ = coeff * Real.exp (bgpParams38.cα * (τ - 2 * E)) := hrewrite
    _ ≤ coeff * (Real.exp (Real.pi / 48) * paper3HoffRate j) :=
        mul_le_mul_of_nonneg_left hexp_bound hcoeff_nonneg
    _ = (coeff * Real.exp (Real.pi / 48)) * paper3HoffRate j := by ring

theorem
    paper3Headline_activeQSSKernelMajorEarly_URhs_sum_factor_le_hoffRate
    (j : ℕ) {τ Rstart Rmix EncB Cstart : ℝ}
    (hτ : τ ∈ Set.Icc (selectorMUEarlyWriteSubStart (j + 1))
      (selectorMUWriteHoldTime (j + 1)))
    (hRstart : 0 ≤ Rstart)
    (hRmix : 0 ≤ Rmix)
    (hEncB : 0 ≤ EncB)
    (hstart :
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Rstart ≤
        Cstart * paper3HoffRate j) :
    Real.exp
        (bgpParams38.cα *
            (τ - 2 * selectorMUEarlyWriteSubStart (j + 1)) -
          selectorUSettledRate * selectorMUWriteStartTime (j + 1)) *
      (((Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            Rstart + Rmix) + EncB) + r_LE_U) ≤
      (Cstart + Rmix + EncB + r_LE_U) * paper3HoffRate j := by
  let start : ℝ :=
    Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) * Rstart
  let K : ℝ := Rmix + EncB + r_LE_U
  let q : ℝ :=
    Real.exp
      (bgpParams38.cα *
          (τ - 2 * selectorMUEarlyWriteSubStart (j + 1)) -
        selectorUSettledRate * selectorMUWriteStartTime (j + 1))
  have hq_le_one : q ≤ 1 := by
    dsimp [q]
    exact paper3Headline_exp_activeEarly_sub_settled_writeStart_le_one
      (j := j) (τ := τ) hτ
  have hq_le_hoff : q ≤ paper3HoffRate j := by
    dsimp [q]
    exact paper3Headline_exp_activeEarly_sub_settled_writeStart_le_hoffRate
      (j := j) (τ := τ) hτ
  have hstart_nonneg : 0 ≤ start := by
    dsimp [start]
    exact mul_nonneg (Real.exp_pos _).le hRstart
  have hstart_le : start ≤ Cstart * paper3HoffRate j := by
    simpa [start] using hstart
  have hK_nonneg : 0 ≤ K := by
    dsimp [K]
    nlinarith [hRmix, hEncB, r_LE_U_pos.le]
  have hstart_piece : q * start ≤ Cstart * paper3HoffRate j := by
    calc
      q * start ≤ 1 * start :=
        mul_le_mul_of_nonneg_right hq_le_one hstart_nonneg
      _ = start := by ring
      _ ≤ Cstart * paper3HoffRate j := hstart_le
  have hK_piece : q * K ≤ K * paper3HoffRate j := by
    calc
      q * K ≤ paper3HoffRate j * K :=
        mul_le_mul_of_nonneg_right hq_le_hoff hK_nonneg
      _ = K * paper3HoffRate j := by ring
  calc
    Real.exp
        (bgpParams38.cα *
            (τ - 2 * selectorMUEarlyWriteSubStart (j + 1)) -
          selectorUSettledRate * selectorMUWriteStartTime (j + 1)) *
      (((Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
            Rstart + Rmix) + EncB) + r_LE_U)
        = q * (start + K) := by
          dsimp [q, start, K]
          ring
    _ = q * start + q * K := by ring
    _ ≤ Cstart * paper3HoffRate j + K * paper3HoffRate j :=
        add_le_add hstart_piece hK_piece
    _ = (Cstart + Rmix + EncB + r_LE_U) * paper3HoffRate j := by
        dsimp [K]
        ring

theorem
    paper3Headline_activeQSSKernelMajorEarly_activeCr_activeCg_Grad_URhs_div_gamma_sq_le_hoffRate
    (wg j : ℕ) {τ Rstart Rmix EncB Cstart Grad : ℝ}
    (hτ : τ ∈ Set.Icc (selectorMUEarlyWriteSubStart (j + 1))
      (selectorMUWriteHoldTime (j + 1)))
    (hRstart : 0 ≤ Rstart)
    (hRmix : 0 ≤ Rmix)
    (hEncB : 0 ≤ EncB)
    (hGrad0 : 0 ≤ Grad)
    (hGrad : Grad ≤ 2 * paper3HeadlineGradBoxConst)
    (hstart :
      Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Rstart ≤
        Cstart * paper3HoffRate j) :
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let W : ℝ := selectorMUWriteStartTime (j + 1)
    let gap : ℝ :=
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) * q
    let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
    let sumUR : ℝ :=
      (((Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Rstart + Rmix) + EncB) + r_LE_U)
    let URhs : ℝ := sumUR *
      Real.exp (-(selectorUSettledRate * W))
    (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
        (selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
          (Grad * URhs))) / gamma ^ 2 ≤
      (((q * (2 * paper3HeadlineGradBoxConst)) / ((D * gap) ^ 2)) *
        (Cstart + Rmix + EncB + r_LE_U)) * paper3HoffRate j := by
  dsimp
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let gap : ℝ :=
    selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) * q
  let gamma : ℝ := D * Real.exp (bgpParams38.cα * E) * gap
  let Gcap : ℝ := 2 * paper3HeadlineGradBoxConst
  let sumUR : ℝ :=
    (((Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
        Rstart + Rmix) + EncB) + r_LE_U)
  let URhs : ℝ := sumUR *
    Real.exp (-(selectorUSettledRate * W))
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hD_pos : 0 < D := by
    simpa [D, q] using paper3Headline_activeKernel_D_pos wg
  have hgamma_pos : 0 < gamma := by
    dsimp [gamma]
    exact mul_pos (mul_pos hD_pos (Real.exp_pos _)) hgap_pos
  have hq_nonneg : 0 ≤ q := by
    simpa [q] using paper3WarmGainQ_nonneg wg
  have hqexp_nonneg :
      0 ≤ q * Real.exp (bgpParams38.cα * τ) :=
    mul_nonneg hq_nonneg (Real.exp_pos _).le
  have hGcap_nonneg : 0 ≤ Gcap := by
    dsimp [Gcap]
    exact paper3HeadlineGradBoxConst_two_nonneg
  have hsum_nonneg : 0 ≤ sumUR := by
    dsimp [sumUR]
    nlinarith [hRstart, hRmix, hEncB, r_LE_U_pos.le,
      (Real.exp_pos (-(paper3HeadlineWriteStartEarlyIntLower (j + 1)))).le]
  have hURhs_nonneg : 0 ≤ URhs := by
    dsimp [URhs]
    exact mul_nonneg hsum_nonneg (Real.exp_pos _).le
  have hcr_le := paper3Headline_activeCr_le_one τ
  have hcg_nonneg := paper3Headline_activeCg_nonneg wg τ
  have hcg_le := paper3Headline_activeCg_le_gain_exp wg τ
  have hgrad_urhs :
      Grad * URhs ≤ Gcap * URhs := by
    exact mul_le_mul_of_nonneg_right (by simpa [Gcap] using hGrad)
      hURhs_nonneg
  have hgrad_urhs_nonneg : 0 ≤ Grad * URhs :=
    mul_nonneg hGrad0 hURhs_nonneg
  have hrest :
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
          (Grad * URhs) ≤
        (q * Real.exp (bgpParams38.cα * τ)) *
          (Gcap * URhs) := by
    exact mul_le_mul (by simpa [q] using hcg_le) hgrad_urhs
      hgrad_urhs_nonneg hqexp_nonneg
  have hrest_nonneg :
      0 ≤ selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
          (Grad * URhs) :=
    mul_nonneg hcg_nonneg hgrad_urhs_nonneg
  have hnum_bound :
      selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
            (Grad * URhs)) ≤
