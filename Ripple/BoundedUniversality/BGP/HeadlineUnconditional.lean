      (fun s _ => paper3NW4cg_nonneg wg s)
  have hfloor : paper3NW4DeltaGFloor wg j ≤
      ((paper3HeadlineSolFamNW wg) w).G (selectorMUWriteHoldTime j) -
        ((paper3HeadlineSolFamNW wg) w).G (selectorMUSelectStartTime j) := by
    rw [h1]
