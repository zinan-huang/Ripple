/-- Closed linear form of the N-family clock coordinate. -/
theorem paper3HeadlineSolFamN_mu (wg w : ℕ) {t : ℝ} (ht : 0 ≤ t) :
    ((paper3HeadlineSolFamN wg) w).μ t = bgpParamsN.cμ * t := by
  rw [((paper3HeadlineSolFamN wg) w).mu_eq_linear
    selectorSchedule_domain_of_nonneg_structural ht,
    ((paper3HeadlineSolFamN wg) w).μ_at_zero, zero_add]

/-- N-parametric prefix-window u-drift envelope (rate `450·bgpScale`). -/
noncomputable def δuWritePrefixN (Bzu : ℝ) (j : ℕ) : ℝ :=
  Bzu * ((Real.pi / 3) *
    Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)))

/-- N-parametric settled-window u-drift envelope. -/
noncomputable def δuSettledN (Bzu : ℝ) (j : ℕ) : ℝ :=
  Bzu * ((Real.pi / 3) *
    Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime j)))

theorem δuWritePrefixN_nonneg {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) (j : ℕ) :
    0 ≤ δuWritePrefixN Bzu j := by
  unfold δuWritePrefixN
  exact mul_nonneg hBzu0
    (mul_nonneg (by positivity) (Real.exp_pos _).le)

theorem δuSettledN_nonneg {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) (j : ℕ) :
    0 ≤ δuSettledN Bzu j := by
  unfold δuSettledN
  exact mul_nonneg hBzu0
    (mul_nonneg (by positivity) (Real.exp_pos _).le)

/-- The N-rate envelope is dominated by the fixed-rate `450` envelope: the
N drift is uniformly SMALLER (`450·bgpScale ≥ 450`), so every fixed-rate
budget transfers to the N family for free. -/
theorem δuWritePrefixN_le_δuWritePrefix {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) (j : ℕ) :
    δuWritePrefixN Bzu j ≤ δuWritePrefix Bzu j := by
  unfold δuWritePrefixN δuWritePrefix
  have hrate : selectorUSettledRate ≤ selectorUSettledRate_N := by
    rw [selectorUSettledRate_N_eq]
    have hs := bgpScaleR_ge_one
    have h38 : selectorUSettledRate = 450 := by
      norm_num [selectorUSettledRate, bgpParams38]
    rw [h38]
    nlinarith
  have hws0 : 0 ≤ selectorMUWriteStartTime j :=
    selectorMUWriteStartTime_nonneg j
  have hexp : Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)) ≤
      Real.exp (-(selectorUSettledRate * selectorMUWriteStartTime j)) := by
    apply Real.exp_le_exp.mpr
    have := mul_le_mul_of_nonneg_right hrate hws0
    linarith
  have hπ : (0 : ℝ) ≤ Real.pi / 3 := by positivity
  have hmul := mul_le_mul_of_nonneg_left hexp hπ
  exact mul_le_mul_of_nonneg_left hmul hBzu0

set_option maxHeartbeats 800000 in
/-- **N-parametric prefix-window u-freeze.**  On the write window
`[ws j, hold j]` the u-gate is qPulse-off at the scaled settled rate
`450·bgpScale`, so a window `|z−u|` envelope `Bzu` releases the u-drift
envelope `δuWritePrefixN Bzu j` — the N sibling of
`u_drift_on_write_prefix_window`. -/
theorem u_drift_on_write_prefix_window_N
    {eta : ℚ} {heta : 0 < eta} {Mcy : ℕ} {κ₀ g₀ : ℚ}
    (sol : SelectorReplicatorDynSol d_U B_U UniversalLocalView bgpParamsN selectorSchedule
      branchU
      (fun t => ((1 + Real.cos t) / 2) ^ Mcy)
      (fun t => ((1 + Real.sin t) / 2) ^ Mcy)
      (fun _ => (κ₀ : ℝ))
      (fun t => (g₀ : ℝ) * Real.exp (bgpParamsN.cα * t))
      (universalPval eta heta))
    (j : ℕ) (i : Fin d_U) {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu)
    (hdom : ∀ t : ℝ, 0 ≤ t → t ∈ selectorSchedule.domain)
    (hzu : ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteHoldTime j),
      |sol.z t i - sol.u t i| ≤ Bzu) :
    ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteHoldTime j),
      |sol.u t i - sol.u (selectorMUWriteStartTime j) i| ≤
        δuWritePrefixN Bzu j := by
  intro t ht
  have ha0 : 0 ≤ selectorMUWriteStartTime j :=
    selectorMUWriteStartTime_nonneg j
  have hat : selectorMUWriteStartTime j ≤ t := ht.1
  have hfield :
      ∀ τ ∈ Icc (selectorMUWriteStartTime j) t,
        |bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ *
          (sol.z τ i - sol.u τ i)|
          ≤ Bzu *
            Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)) := by
    intro τ hτ
    have hτ_full :
        τ ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteHoldTime j) :=
      ⟨hτ.1, le_trans hτ.2 ht.2⟩
    have hτ0 : 0 ≤ τ := le_trans ha0 hτ.1
    have hατ : sol.α τ = Real.exp (bgpParamsN.cα * τ) :=
      sol.alpha_eq_exp hdom hτ0
    have hμτ : sol.μ τ = bgpParamsN.cμ * τ := by
      rw [sol.mu_eq_linear hdom hτ0, sol.μ_at_zero, zero_add]
    have hsin : (1 : ℝ) / 2 ≤ Real.sin τ :=
      sin_window_ge j
        (by simpa [selectorMUWriteStartTime] using hτ_full.1)
        (by
          have hτ_read : τ ≤ selectorMUWriteReadTime j :=
            le_trans hτ_full.2 (selectorMUWriteHold_le_read j)
          simpa [selectorMUWriteReadTime] using hτ_read)
    have hcoef0 :
        0 ≤ bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ := by
      rw [hατ]
      exact mul_nonneg
        (mul_nonneg (by rw [bgpParamsN_A_eq]; norm_num) (Real.exp_pos _).le)
        (bGateU_pos bgpParamsN.L (sol.μ τ) τ).le
    have hcoef_le :
        bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ
          ≤ Real.exp (-(selectorUSettledRate_N * τ)) := by
      have h :=
        gateU_integrand_le_settled_exp_repl
          (sol := sol) (A := (1 : ℝ)) (cμ := bgpParamsN.cμ)
          (cα := bgpParamsN.cα)
          hτ0 (by norm_num) bgpParamsN_cμ_pos.le
          bgpParamsN_A_eq
          hατ hμτ hsin
      simpa [selectorUSettledRate_N] using h
    have hdec :
        Real.exp (-(selectorUSettledRate_N * τ))
          ≤ Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)) := by
      apply Real.exp_le_exp.mpr
      have hmul : selectorUSettledRate_N * selectorMUWriteStartTime j
          ≤ selectorUSettledRate_N * τ :=
        mul_le_mul_of_nonneg_left hτ.1 selectorUSettledRate_N_pos.le
      linarith
    calc
      |bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ *
          (sol.z τ i - sol.u τ i)|
          = (bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ) *
              |sol.z τ i - sol.u τ i| := by
            rw [abs_mul, abs_of_nonneg hcoef0]
      _ ≤ Real.exp (-(selectorUSettledRate_N * τ)) * Bzu :=
            mul_le_mul hcoef_le (hzu τ hτ_full) (abs_nonneg _) (Real.exp_pos _).le
      _ ≤ Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)) * Bzu :=
            mul_le_mul_of_nonneg_right hdec hBzu0
      _ = Bzu * Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)) := by
            ring
  have hhold := hold_bound
    (fun τ => sol.u τ i)
    (fun τ =>
      bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ *
        (sol.z τ i - sol.u τ i))
    (Bzu * Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)))
    (selectorMUWriteStartTime j) t hat
    (fun τ hτ => sol.u_hasDeriv τ
      (hdom τ (le_trans ha0 hτ.1)) i)
    hfield
  have hlen : t - selectorMUWriteStartTime j ≤ Real.pi / 3 := by
    have hhold' :
        selectorMUWriteHoldTime j - selectorMUWriteStartTime j = Real.pi / 3 := by
      unfold selectorMUWriteHoldTime selectorMUWriteStartTime
      ring
    calc
      t - selectorMUWriteStartTime j
          ≤ selectorMUWriteHoldTime j - selectorMUWriteStartTime j :=
            sub_le_sub_right ht.2 _
      _ = Real.pi / 3 := hhold'
  have hη0 :
      0 ≤ Bzu * Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)) :=
    mul_nonneg hBzu0 (Real.exp_pos _).le
  calc
    |sol.u t i - sol.u (selectorMUWriteStartTime j) i|
        ≤ (Bzu * Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j))) *
            (t - selectorMUWriteStartTime j) := hhold
    _ ≤ (Bzu * Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j))) *
          (Real.pi / 3) :=
        mul_le_mul_of_nonneg_left hlen hη0
    _ = δuWritePrefixN Bzu j := by
        dsimp [δuWritePrefixN]
        ring

set_option maxHeartbeats 800000 in
/-- **N-parametric settled-window u-freeze** — the settled sibling of
`u_drift_on_write_prefix_window_N` (rate `450·bgpScale`, envelope
`δuSettledN`). -/
theorem u_drift_on_settled_window_N
    {eta : ℚ} {heta : 0 < eta} {Mcy : ℕ} {κ₀ g₀ : ℚ}
    (sol : SelectorReplicatorDynSol d_U B_U UniversalLocalView bgpParamsN selectorSchedule
      branchU
      (fun t => ((1 + Real.cos t) / 2) ^ Mcy)
      (fun t => ((1 + Real.sin t) / 2) ^ Mcy)
      (fun _ => (κ₀ : ℝ))
      (fun t => (g₀ : ℝ) * Real.exp (bgpParamsN.cα * t))
      (universalPval eta heta))
    (j : ℕ) (i : Fin d_U) {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu)
    (hdom : ∀ t : ℝ, 0 ≤ t → t ∈ selectorSchedule.domain)
    (hzu : ∀ t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUWriteReadTime j),
      |sol.z t i - sol.u t i| ≤ Bzu) :
    ∀ t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUWriteReadTime j),
      |sol.u t i - sol.u (selectorMUWriteHoldTime j) i| ≤ δuSettledN Bzu j := by
  intro t ht
  have ha0 : 0 ≤ selectorMUWriteHoldTime j := by
    unfold selectorMUWriteHoldTime
    positivity
  have hat : selectorMUWriteHoldTime j ≤ t := ht.1
  have hfield :
      ∀ τ ∈ Icc (selectorMUWriteHoldTime j) t,
        |bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ *
          (sol.z τ i - sol.u τ i)|
          ≤ Bzu *
            Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime j)) := by
    intro τ hτ
    have hτ_full :
        τ ∈ Icc (selectorMUWriteHoldTime j) (selectorMUWriteReadTime j) :=
      ⟨hτ.1, le_trans hτ.2 ht.2⟩
    have hτ0 : 0 ≤ τ := le_trans ha0 hτ.1
    have hατ : sol.α τ = Real.exp (bgpParamsN.cα * τ) :=
      sol.alpha_eq_exp hdom hτ0
    have hμτ : sol.μ τ = bgpParamsN.cμ * τ := by
      rw [sol.mu_eq_linear hdom hτ0, sol.μ_at_zero, zero_add]
    have hsin : (1 : ℝ) / 2 ≤ Real.sin τ :=
      sin_window_ge j
        (by
          have hselect_le_hold :
              2 * Real.pi * (j : ℝ) + Real.pi / 6 ≤ selectorMUWriteHoldTime j := by
            unfold selectorMUWriteHoldTime
            linarith [Real.pi_pos]
          exact le_trans hselect_le_hold hτ_full.1)
        (by simpa [selectorMUWriteReadTime] using hτ_full.2)
    have hcoef0 :
        0 ≤ bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ := by
      rw [hατ]
      exact mul_nonneg
        (mul_nonneg (by rw [bgpParamsN_A_eq]; norm_num) (Real.exp_pos _).le)
        (bGateU_pos bgpParamsN.L (sol.μ τ) τ).le
    have hcoef_le :
        bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ
          ≤ Real.exp (-(selectorUSettledRate_N * τ)) := by
      have h :=
        gateU_integrand_le_settled_exp_repl
          (sol := sol) (A := (1 : ℝ)) (cμ := bgpParamsN.cμ)
          (cα := bgpParamsN.cα)
          hτ0 (by norm_num) bgpParamsN_cμ_pos.le
          bgpParamsN_A_eq
          hατ hμτ hsin
      simpa [selectorUSettledRate_N] using h
    have hdec :
        Real.exp (-(selectorUSettledRate_N * τ))
          ≤ Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime j)) := by
      apply Real.exp_le_exp.mpr
      have hmul : selectorUSettledRate_N * selectorMUWriteHoldTime j
          ≤ selectorUSettledRate_N * τ :=
        mul_le_mul_of_nonneg_left hτ.1 selectorUSettledRate_N_pos.le
      linarith
    calc
      |bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ *
          (sol.z τ i - sol.u τ i)|
          = (bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ) *
              |sol.z τ i - sol.u τ i| := by
            rw [abs_mul, abs_of_nonneg hcoef0]
      _ ≤ Real.exp (-(selectorUSettledRate_N * τ)) * Bzu :=
            mul_le_mul hcoef_le (hzu τ hτ_full) (abs_nonneg _) (Real.exp_pos _).le
      _ ≤ Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime j)) * Bzu :=
            mul_le_mul_of_nonneg_right hdec hBzu0
      _ = Bzu * Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime j)) := by
            ring
  have hhold := hold_bound
    (fun τ => sol.u τ i)
    (fun τ =>
      bgpParamsN.A * sol.α τ * bGateU bgpParamsN.L (sol.μ τ) τ *
        (sol.z τ i - sol.u τ i))
    (Bzu * Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime j)))
    (selectorMUWriteHoldTime j) t hat
    (fun τ hτ => sol.u_hasDeriv τ
      (hdom τ (le_trans ha0 hτ.1)) i)
    hfield
  have hlen : t - selectorMUWriteHoldTime j ≤ Real.pi / 3 := by
