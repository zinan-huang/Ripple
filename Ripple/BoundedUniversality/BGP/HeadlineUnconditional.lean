    exact mul_pos (Real.exp_pos _) hg
  have hkk_pos : ∀ τ : ℝ, 0 ≤ τ → 0 < kk τ := fun τ h =>
    add_pos (hkZ_pos τ h) (hkU_pos τ h)
  have hgateZ_cont : Continuous fun τ : ℝ =>
      bGateZ (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ := by
    have hr : Continuous fun τ : ℝ => rPulse (bgpParamsNW w).L τ := by
      simp only [rPulse]
      exact ((continuous_const.sub Real.continuous_sin).div_const 2).pow
