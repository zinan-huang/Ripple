          (Cstart + Rmix + EncB + r_LE_U)
    s.sum (fun v =>
      ∫ τ in E..Htime,
        paper3HeadlineActiveQSSKernelMajorEarly wg w j Rstart Rmix EncB v τ) ≤
      (card * Cmajor) * paper3HoffRate j := by
  classical
  dsimp
  let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let s : Finset UniversalLocalView :=
    Finset.univ.filter (fun v : UniversalLocalView => v ≠ c)
  let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
  let gap : ℝ :=
    selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) * q
  let CrD : ℝ := (paper3HeadlineM : ℝ) * |(paper3HeadlineKappa : ℝ)|
  let Ccr : ℝ := CrD / (D * gap)
  let Ccg : ℝ :=
    (((paper3HeadlineM : ℝ) + bgpParams38.cα) * |q| / ((D * gap) ^ 2)) *
      Real.exp (Real.pi / 48)
  let Cur : ℝ :=
    ((q * (2 * paper3HeadlineGradBoxConst)) / ((D * gap) ^ 2)) *
      (Cstart + Rmix + EncB + r_LE_U)
  let Cmajor : ℝ := Ccr + Ccg + Cur
  have hHoff_nonneg : 0 ≤ paper3HoffRate j :=
    (paper3HoffRate_pos j).le
  have hCstart_nonneg : 0 ≤ Cstart := by
    have hstart_nonneg :
        0 ≤ Real.exp (-(paper3HeadlineWriteStartEarlyIntLower (j + 1))) *
          Rstart :=
      mul_nonneg (Real.exp_pos _).le hRstart
    have hprod : 0 ≤ Cstart * paper3HoffRate j :=
      le_trans hstart_nonneg hstart
    nlinarith [hprod, paper3HoffRate_pos j]
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hD_pos : 0 < D := by
    simpa [D, q] using paper3Headline_activeKernel_D_pos wg
  have hCrD_nonneg : 0 ≤ CrD := by
    dsimp [CrD]
    positivity
  have hq_nonneg : 0 ≤ q := by
    simpa [q] using paper3WarmGainQ_nonneg wg
  have hCcr_nonneg : 0 ≤ Ccr := by
    dsimp [Ccr]
    exact div_nonneg hCrD_nonneg (mul_pos hD_pos hgap_pos).le
  have hCcg_nonneg : 0 ≤ Ccg := by
    dsimp [Ccg]
    exact mul_nonneg
      (div_nonneg
        (mul_nonneg
          (by norm_num [paper3HeadlineM, bgpParams38] :
            0 ≤ (paper3HeadlineM : ℝ) + bgpParams38.cα)
          (abs_nonneg q))
        (sq_nonneg (D * gap)))
      (Real.exp_pos _).le
  have hCur_nonneg : 0 ≤ Cur := by
    dsimp [Cur]
    exact mul_nonneg
      (div_nonneg
        (mul_nonneg hq_nonneg paper3HeadlineGradBoxConst_two_nonneg)
        (sq_nonneg (D * gap)))
      (by nlinarith [hCstart_nonneg, hRmix, hEncB, r_LE_U_pos.le])
  have hCmajor_nonneg : 0 ≤ Cmajor := by
    dsimp [Cmajor]
    nlinarith [hCcr_nonneg, hCcg_nonneg, hCur_nonneg]
  have hconst_nonneg : 0 ≤ Cmajor * paper3HoffRate j :=
    mul_nonneg hCmajor_nonneg hHoff_nonneg
  have hpoint : ∀ v ∈ s,
      (∫ τ in E..Htime,
        paper3HeadlineActiveQSSKernelMajorEarly wg w j Rstart Rmix EncB v τ) ≤
        Cmajor * paper3HoffRate j := by
    intro v _hv
    simpa [E, Htime, gap, q, D, CrD, Cmajor, Ccr, Ccg, Cur] using
      paper3HeadlineActiveQSSKernelMajorEarly_integral_le_hoffRate_scalar
        (wg := wg) (w := w) (j := j) (Rstart := Rstart)
        (Rmix := Rmix) (EncB := EncB) (Cstart := Cstart)
        hRstart hRmix hEncB hstart v
  have hsum_to_card :
      s.sum (fun v =>
        ∫ τ in E..Htime,
          paper3HeadlineActiveQSSKernelMajorEarly wg w j Rstart Rmix EncB v τ) ≤
        s.sum (fun _v => Cmajor * paper3HoffRate j) := by
    exact Finset.sum_le_sum hpoint
  have hsum_const :
      s.sum (fun _v => Cmajor * paper3HoffRate j) =
        (s.card : ℝ) * (Cmajor * paper3HoffRate j) := by
    simp
  have hcard_le : (s.card : ℝ) ≤ card := by
    dsimp [s, card]
    exact_mod_cast Finset.card_le_univ s
  have hcard_bound :
      (s.card : ℝ) * (Cmajor * paper3HoffRate j) ≤
        card * (Cmajor * paper3HoffRate j) :=
    mul_le_mul_of_nonneg_right hcard_le hconst_nonneg
  calc
    s.sum (fun v =>
      ∫ τ in E..Htime,
        paper3HeadlineActiveQSSKernelMajorEarly wg w j Rstart Rmix EncB v τ)
        ≤ s.sum (fun _v => Cmajor * paper3HoffRate j) := hsum_to_card
    _ = (s.card : ℝ) * (Cmajor * paper3HoffRate j) := hsum_const
    _ ≤ card * (Cmajor * paper3HoffRate j) := hcard_bound
    _ = (card * Cmajor) * paper3HoffRate j := by ring

/-- q-free absolute coordinate bound for the next static configuration. -/
theorem paper3Headline_next_confEncU_abs_le_two_D_U
    (w j : ℕ) :
    ∀ i : Fin d_U,
      |(confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)| ≤ 2 * D_U := by
  intro i
  exact paper3Headline_confEncU_abs_le_two_D_U
    (solMUReplStaticCfg w (j + 2)) i

/-- Triangle bridge from an all-coordinate z box to the next-target start tube.

The only dynamic input is the q-free z-coordinate box at write start.  The
encoding side is discharged by `paper3Headline_next_confEncU_abs_le_two_D_U`. -/
theorem paper3Headline_writeStart_z_to_next_of_abs_box
    (wg w j : ℕ) {Zbox : ℝ}
    (hz_abs : ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| ≤ Zbox) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        (confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)| ≤
        Zbox + 2 * D_U := by
  intro i
  have henc := paper3Headline_next_confEncU_abs_le_two_D_U w j i
  calc
    |((paper3HeadlineSolFam wg) w).z
        (selectorMUWriteStartTime (j + 1)) i -
      (confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)|
        =
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i +
        -((confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ))| := by
          ring_nf
    _ ≤
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| +
        |-((confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ))| :=
          abs_add_le _ _
    _ =
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| +
        |(confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)| := by
          simp
    _ ≤ Zbox + 2 * D_U := add_le_add (hz_abs i) henc

theorem paper3Headline_writeStart_z_abs_box_radius_nonneg
    (wg w j : ℕ) {Zbox : ℝ}
    (hz_abs : ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| ≤ Zbox) :
    0 ≤ Zbox + 2 * D_U := by
  have hZ : 0 ≤ Zbox := by
    have h := hz_abs (⟨0, by decide⟩ : Fin d_U)
    exact le_trans (abs_nonneg _) h
  nlinarith [hZ, D_U_nonneg]

theorem paper3Headline_writeStart_z_to_next_of_abs_box_radius
    (wg w j : ℕ) {Zbox Rstart : ℝ}
    (hz_abs : ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| ≤ Zbox)
    (hRstart : Zbox + 2 * D_U ≤ Rstart) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        (confEncU (solMUReplStaticCfg w (j + 2)) i : ℝ)| ≤ Rstart := by
  intro i
  exact le_trans
      (paper3Headline_writeStart_z_to_next_of_abs_box
        (wg := wg) (w := w) (j := j) hz_abs i)
    hRstart

theorem paper3Headline_init_z_abs_le_two_D_U
    (w : ℕ) :
    ∀ i : Fin d_U,
      |(((selectorInitX0 w i : ℚ) : ℝ))| ≤ 2 * D_U := by
  intro i
  rw [selectorInitX0_cast_enc]
  simpa [stackMachineEncodingU_enc_eq] using
    paper3Headline_confEncU_abs_le_two_D_U (selectorInitConfig w) i

/-- Selector z-coordinate trapping from a box on the dynamic mix target.

This is the selector-specific analogue of the contract scalar trapping theorem:
`z' = k(t) * (mix(t) - z(t))` with `k(t) >= 0`.  It does not use finite-prefix
`Bpre` information or active-QSS residuals. -/
theorem paper3Headline_z_abs_le_of_mix_abs_box
    (wg w : ℕ) {T Zbox : ℝ}
    (hT : 0 ≤ T)
    (hinit_abs : ∀ i : Fin d_U,
      |(((selectorInitX0 w i : ℚ) : ℝ))| ≤ Zbox)
    (hmix_abs : ∀ t, t ∈ Icc (0 : ℝ) T -> ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
          ((paper3HeadlineSolFam wg) w).lam t i| ≤ Zbox) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z T i| ≤ Zbox := by
  intro i
  have hz0eq :=
    (paper3HeadlineSolFam_initial_values wg w).1 i
  have hmem :
      ((paper3HeadlineSolFam wg) w).z T i ∈ Icc (-Zbox) Zbox := by
    refine scalar_relaxation_trapping_invariant
      (y := fun τ => ((paper3HeadlineSolFam wg) w).z τ i)
      (g := fun τ =>
        selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
          ((paper3HeadlineSolFam wg) w).lam τ i)
      (k := fun τ =>
        bgpParams38.A * ((paper3HeadlineSolFam wg) w).α τ *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ)
      (lo := -Zbox) (hi := Zbox) (T := T)
      hT
      (selector_replicator_gateZ_integrand_continuous
        ((paper3HeadlineSolFam wg) w))
      (((paper3HeadlineSolFam wg) w).cont_mixTarget i)
      ?_ ?_ ?_ ?_
    · intro τ hτ
      exact ((paper3HeadlineSolFam wg) w).z_hasDeriv τ
        (selectorSchedule_domain_of_nonneg_structural τ hτ.1) i
    · intro τ hτ
      exact selector_replicator_gateZ_integrand_nonneg
        ((paper3HeadlineSolFam wg) w)
        selectorSchedule_domain_of_nonneg_structural
        (by norm_num [bgpParams38]) hτ.1
    · intro τ hτ
      exact abs_le.mp (hmix_abs τ hτ i)
    · change ((paper3HeadlineSolFam wg) w).z 0 i ∈ Icc (-Zbox) Zbox
      rw [hz0eq]
      exact abs_le.mp (hinit_abs i)
  exact abs_le.mpr hmem

theorem paper3Headline_writeStart_z_abs_le_of_mix_abs_box
    (wg w j : ℕ) {Zbox : ℝ}
    (hinit_abs : ∀ i : Fin d_U,
      |(((selectorInitX0 w i : ℚ) : ℝ))| ≤ Zbox)
    (hmix_abs : ∀ t,
      t ∈ Icc (0 : ℝ) (selectorMUWriteStartTime (j + 1)) ->
      ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
            ((paper3HeadlineSolFam wg) w).lam t i| ≤ Zbox) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| ≤ Zbox :=
  paper3Headline_z_abs_le_of_mix_abs_box
    (wg := wg) (w := w) (T := selectorMUWriteStartTime (j + 1))
    (Zbox := Zbox) (selectorMUWriteStartTime_nonneg (j + 1))
    hinit_abs hmix_abs

theorem paper3Headline_abs_sum_weighted_le_of_simplex_and_abs_le
    {V : Type} [Fintype V] (lam : V → ℝ) (a : V → ℝ) {B : ℝ}
    (hlam_nonneg : ∀ v : V, 0 ≤ lam v)
    (hlam_sum : (∑ v : V, lam v) = 1)
    (ha : ∀ v : V, |a v| ≤ B) :
    |∑ v : V, lam v * a v| ≤ B := by
  calc
    |∑ v : V, lam v * a v|
        ≤ ∑ v : V, |lam v * a v| := Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ v : V, lam v * B := by
          refine Finset.sum_le_sum ?_
          intro v _hv
          rw [abs_mul, abs_of_nonneg (hlam_nonneg v)]
          exact mul_le_mul_of_nonneg_left (ha v) (hlam_nonneg v)
    _ = (∑ v : V, lam v) * B := by rw [Finset.sum_mul]
    _ = B := by rw [hlam_sum, one_mul]

theorem paper3Headline_selectorMixTarget_abs_le_of_branch_abs
    (wg w : ℕ) (t : ℝ) {B : ℝ}
    (hlam_nonneg : ∀ v : UniversalLocalView,
      0 ≤ ((paper3HeadlineSolFam wg) w).lam v t)
    (hlam_sum :
      (∑ v : UniversalLocalView, ((paper3HeadlineSolFam wg) w).lam v t) = 1)
    (hbranch_abs : ∀ i : Fin d_U, ∀ v : UniversalLocalView,
      |BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFam wg) w).u t) i| ≤ B) :
    ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
          ((paper3HeadlineSolFam wg) w).lam t i| ≤ B := by
  intro i
  simpa [selectorMixTarget, selectorF] using
    paper3Headline_abs_sum_weighted_le_of_simplex_and_abs_le
      (lam := fun v : UniversalLocalView =>
        ((paper3HeadlineSolFam wg) w).lam v t)
      (a := fun v : UniversalLocalView =>
        BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFam wg) w).u t) i)
      hlam_nonneg hlam_sum (hbranch_abs i)

theorem paper3Headline_selectorMixTarget_abs_le_of_branch_abs_on_prefix
    (wg w j : ℕ) {B : ℝ}
    (hbranch_abs : ∀ t,
      t ∈ Icc (0 : ℝ) (selectorMUWriteStartTime (j + 1)) ->
      ∀ i : Fin d_U, ∀ v : UniversalLocalView,
        |BranchData.evalBranch (branchU v)
            (((paper3HeadlineSolFam wg) w).u t) i| ≤ B) :
    ∀ t,
      t ∈ Icc (0 : ℝ) (selectorMUWriteStartTime (j + 1)) ->
      ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
            ((paper3HeadlineSolFam wg) w).lam t i| ≤ B := by
  intro t ht
  exact
    paper3Headline_selectorMixTarget_abs_le_of_branch_abs
      (wg := wg) (w := w) (t := t)
      (fun v => by
        simpa using paper3Headline_lam_nonneg_forward wg w v t ht.1)
      (by
        simpa using paper3Headline_lam_sum_forward wg w t ht.1)
      (hbranch_abs t ht)

/-- Prefix branch-coordinate boxes are exactly the remaining input needed to
trap `z` at the next write start.

This composes the finite simplex convexity reduction with the real scalar
relaxation trapping theorem for the selector `z` ODE.  The hypothesis is kept
explicit because it is the genuine all-prefix `u`/branch box obligation; the
write-window UTube facts only cover the later write window and are not used
here. -/
theorem paper3Headline_writeStart_z_abs_le_of_branch_abs_on_prefix
    (wg w j : ℕ) {B : ℝ}
    (hinit_le : 2 * D_U ≤ B)
    (hbranch_abs : ∀ t,
      t ∈ Icc (0 : ℝ) (selectorMUWriteStartTime (j + 1)) ->
      ∀ i : Fin d_U, ∀ v : UniversalLocalView,
        |BranchData.evalBranch (branchU v)
            (((paper3HeadlineSolFam wg) w).u t) i| ≤ B) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i| ≤ B := by
  refine
    paper3Headline_writeStart_z_abs_le_of_mix_abs_box
      (wg := wg) (w := w) (j := j) (Zbox := B) ?_ ?_
  · intro i
    exact (paper3Headline_init_z_abs_le_two_D_U w i).trans hinit_le
  · exact
      paper3Headline_selectorMixTarget_abs_le_of_branch_abs_on_prefix
        (wg := wg) (w := w) (j := j) hbranch_abs

/-! #### F1-NW (5/5) infrastructure: the `[0, π/6]` head-started u-freeze

The word-coupled family `paper3HeadlineSolFamNW wg` runs its clock at
`cμ = 1000·bgpScaleW wg`, so on the warm prefix `[0, π/6]` (where
`sin ≥ 0`, hence `qPulse ≥ 1/2` at `L = 1`) the u-kernel
`A·α·bGateU ≤ e^{(300−500)·bgpScaleW·τ} = e^{−200·bgpScaleW·τ}` has total
mass `≤ 1/(200·bgpScaleW wg)` — the head start.  Combined with the
rate-independent hull trapping of `z` (mix target in the `2·D_U` hull under
the maintained `r_LE_U` u-tube), a first-exit bootstrap freezes `u` within
`5·D_U/(200·bgpScaleW wg) ≪ r_LE_U/2` of its exact initial encoding, and
the PROVED budget arithmetic `bgpScaleW_beats_depth_weight` converts this
into the (5/5) quarter bound. -/

/-- Pointwise u-kernel bound on `[0, π]` at the word-coupled rates:
`A·α(τ)·bGateU(μ(τ), τ) ≤ e^{−200·bgpScaleW·τ}` (`qPulse ≥ 1/2` there). -/
theorem paper3NW_uKernel_le_exp (wg w : ℕ) {τ : ℝ}
    (h0 : 0 ≤ τ) (hπ : τ ≤ Real.pi) :
    (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ ≤
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by
  have hα := paper3HeadlineSolFamNW_alpha wg w h0
  have hμ := paper3HeadlineSolFamNW_mu wg w h0
  rw [hα, hμ]
  simp only [bgpParamsNW_A_eq, one_mul, bgpParamsNW_L_eq]
  unfold bGateU qPulse
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  have hsin : 0 ≤ Real.sin τ := Real.sin_nonneg_of_nonneg_of_le_pi h0 hπ
  have hq : (1 : ℝ) / 2 ≤ ((1 + Real.sin τ) / 2) ^ 1 := by
    rw [pow_one]; linarith
  have hsW : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  rw [bgpParamsNW_cα_def, bgpParamsNW_cμ_def]
  nlinarith [mul_le_mul_of_nonneg_left hq
    (mul_nonneg (mul_nonneg (by norm_num : (0 : ℝ) ≤ 1000) hsW.le) h0),
    mul_nonneg hsW.le h0]

/-- Grönwall-style u-freeze on the warm prefix: under a `|z − u|` box on
`[0, t] ⊆ [0, π/6]`, the `u` drift is at most `Bzu/(200·bgpScaleW wg)`
(`paper3NW_exp_mass_le` now lives in the N warm-prefix block, mid-file). -/
theorem paper3NW_u_drift_on_warm_prefix (wg w : ℕ) (i : Fin d_U)
    {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) {t : ℝ}
    (ht : t ∈ Icc (0 : ℝ) (Real.pi / 6))
    (hzu : ∀ τ ∈ Icc (0 : ℝ) t,
      |((paper3HeadlineSolFamNW wg) w).z τ i -
        ((paper3HeadlineSolFamNW wg) w).u τ i| ≤ Bzu) :
    |((paper3HeadlineSolFamNW wg) w).u t i -
        ((paper3HeadlineSolFamNW wg) w).u 0 i| ≤
      Bzu / (200 * (bgpScaleW wg : ℝ)) := by
  have hsW : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hc : (0 : ℝ) < 200 * (bgpScaleW wg : ℝ) := by nlinarith
  have hπ6 : Real.pi / 6 ≤ Real.pi := by linarith [Real.pi_pos]
  have hgate_cont : Continuous fun τ : ℝ =>
      bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
    unfold bGateU
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamNW wg) w).cont_μ.mul
        (qPulse_continuous (bgpParamsNW wg).L)).neg)
  have hgc : Continuous fun τ : ℝ =>
      (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        (((paper3HeadlineSolFamNW wg) w).z τ i -
          ((paper3HeadlineSolFamNW wg) w).u τ i) :=
    ((continuous_const.mul ((paper3HeadlineSolFamNW wg) w).cont_α).mul
        hgate_cont).mul
      ((((paper3HeadlineSolFamNW wg) w).cont_z i).sub
        (((paper3HeadlineSolFamNW wg) w).cont_u i))
  have hy : ∀ τ ∈ Icc (0 : ℝ) t,
      HasDerivAt (fun s => ((paper3HeadlineSolFamNW wg) w).u s i)
        ((bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
            bGateU (bgpParamsNW wg).L
              (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
          (((paper3HeadlineSolFamNW wg) w).z τ i -
            ((paper3HeadlineSolFamNW wg) w).u τ i)) τ :=
    fun τ hτ => ((paper3HeadlineSolFamNW wg) w).u_hasDeriv τ
      (selectorSchedule_domain_of_nonneg_structural τ hτ.1) i
  have hhold := hold_bound_integral
    (fun s => ((paper3HeadlineSolFamNW wg) w).u s i)
    (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
      (((paper3HeadlineSolFamNW wg) w).z τ i -
        ((paper3HeadlineSolFamNW wg) w).u τ i))
    0 t ht.1 hgc hy
  have hpt : ∀ τ ∈ Icc (0 : ℝ) t,
      |(bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        (((paper3HeadlineSolFamNW wg) w).z τ i -
          ((paper3HeadlineSolFamNW wg) w).u τ i)| ≤
      Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := hτ.1
    have hτπ : τ ≤ Real.pi := le_trans (le_trans hτ.2 ht.2) hπ6
    have hker_nonneg : 0 ≤
        (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L
            (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
      have hα := paper3HeadlineSolFamNW_alpha wg w hτ0
      rw [hα]
      simp only [bgpParamsNW_A_eq, one_mul]
      exact mul_nonneg (Real.exp_pos _).le
        (bGateU_pos (bgpParamsNW wg).L _ τ).le
    rw [abs_mul, abs_of_nonneg hker_nonneg]
    calc (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        |((paper3HeadlineSolFamNW wg) w).z τ i -
          ((paper3HeadlineSolFamNW wg) w).u τ i|
        ≤ Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) * Bzu :=
          mul_le_mul (paper3NW_uKernel_le_exp wg w hτ0 hτπ) (hzu τ hτ)
            (abs_nonneg _) (Real.exp_pos _).le
      _ = Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by ring
  have hEnvCont : Continuous fun τ : ℝ =>
      Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) :=
    continuous_const.mul
      (Real.continuous_exp.comp (continuous_const.mul continuous_id).neg)
  have hmono := intervalIntegral.integral_mono_on ht.1
    (hgc.abs.intervalIntegrable (μ := MeasureTheory.volume) 0 t)
    (hEnvCont.intervalIntegrable (μ := MeasureTheory.volume) 0 t) hpt
  have hmass : (∫ τ in (0 : ℝ)..t,
      Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ))) ≤
      Bzu / (200 * (bgpScaleW wg : ℝ)) := by
    rw [intervalIntegral.integral_const_mul]
    calc Bzu * ∫ τ in (0 : ℝ)..t,
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ))
        ≤ Bzu * (1 / (200 * (bgpScaleW wg : ℝ))) :=
          mul_le_mul_of_nonneg_left (paper3NW_exp_mass_le hc ht.1) hBzu0
      _ = Bzu / (200 * (bgpScaleW wg : ℝ)) := by ring
  calc |((paper3HeadlineSolFamNW wg) w).u t i -
        ((paper3HeadlineSolFamNW wg) w).u 0 i|
      ≤ ∫ τ in (0 : ℝ)..t,
          |(bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
              bGateU (bgpParamsNW wg).L
                (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
            (((paper3HeadlineSolFamNW wg) w).z τ i -
              ((paper3HeadlineSolFamNW wg) w).u τ i)| := hhold
    _ ≤ ∫ τ in (0 : ℝ)..t,
          Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := hmono
    _ ≤ Bzu / (200 * (bgpScaleW wg : ℝ)) := hmass

/-- Forward total selector mass at the word-coupled family. -/
theorem paper3NW_lam_sum_forward (wg w : ℕ) :
    ∀ t : ℝ, 0 ≤ t →
      (∑ v : UniversalLocalView,
        ((paper3HeadlineSolFamNW wg) w).lam v t) = 1 := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  have hode : ∀ v : UniversalLocalView, ∀ t : ℝ, 0 ≤ t →
      HasDerivAt (((paper3HeadlineSolFamNW wg) w).lam v)
        ((((1 + Real.cos t) / 2) ^ paper3HeadlineM *
              ((paper3HeadlineKappa : ℚ) : ℝ)) *
            (1 / (Fintype.card UniversalLocalView : ℝ) -
              ((paper3HeadlineSolFamNW wg) w).lam v t)
          + (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQNW wg : ℚ) : ℝ) *
                Real.exp ((bgpParamsNW wg).cα * t))) *
            ((paper3HeadlineSolFamNW wg) w).lam v t *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                  (((paper3HeadlineSolFamNW wg) w).u t)
                - ∑ u : UniversalLocalView,
                    ((paper3HeadlineSolFamNW wg) w).lam u t *
                      universalPval paper3HeadlineEta paper3HeadlineEta_pos u
                        (((paper3HeadlineSolFamNW wg) w).u t))) t := by
    intro v t ht
    simpa using ((paper3HeadlineSolFamNW wg) w).lam_hasDeriv v t
      (selectorSchedule_domain_of_nonneg_structural t ht)
  have hsum0 : (∑ v : UniversalLocalView,
      ((paper3HeadlineSolFamNW wg) w).lam v 0) = 1 := by
    have h0 := (paper3HeadlineSolFamNW_initial_values wg w).2.2.1
    have hcard : (Fintype.card UniversalLocalView : ℝ) ≠ 0 := by
      exact_mod_cast Fintype.card_pos.ne'
    calc (∑ v : UniversalLocalView, ((paper3HeadlineSolFamNW wg) w).lam v 0)
        = ∑ _v : UniversalLocalView,
            (1 : ℝ) / ((Fintype.card UniversalLocalView : ℚ) : ℝ) :=
          Finset.sum_congr rfl (fun v _ => by rw [h0 v])
      _ = (Fintype.card UniversalLocalView : ℝ) *
            ((1 : ℝ) / ((Fintype.card UniversalLocalView : ℚ) : ℝ)) := by
          rw [Finset.sum_const, Finset.card_univ, nsmul_eq_mul]
      _ = 1 := by
          push_cast
          field_simp
  exact replicator_sum_lam_eq_one
    (lam := fun v t => ((paper3HeadlineSolFamNW wg) w).lam v t)
    (P := fun v t =>
      universalPval paper3HeadlineEta paper3HeadlineEta_pos v
        (((paper3HeadlineSolFamNW wg) w).u t))
    (cr := fun t => ((1 + Real.cos t) / 2) ^ paper3HeadlineM *
      ((paper3HeadlineKappa : ℚ) : ℝ))
    (cg := fun t => ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
      (((paper3WarmGainQNW wg : ℚ) : ℝ) *
        Real.exp ((bgpParamsNW wg).cα * t)))
    ((((continuous_const.add Real.continuous_cos).div_const 2).pow _).mul
      continuous_const)
    ((((continuous_const.add Real.continuous_sin).div_const 2).pow _).mul
      (continuous_const.mul
        (Real.continuous_exp.comp (continuous_const.mul continuous_id))))
    (fun v => ((paper3HeadlineSolFamNW wg) w).cont_lam v)
    (fun v => universalPval_continuous_of_cont_u paper3HeadlineEta
      paper3HeadlineEta_pos v ((paper3HeadlineSolFamNW wg) w).cont_u)
    hode hsum0

/-- Forward coordinatewise selector nonnegativity at the word-coupled
family. -/
theorem paper3NW_lam_nonneg_forward (wg w : ℕ) :
    ∀ v : UniversalLocalView, ∀ t : ℝ, 0 ≤ t →
      0 ≤ ((paper3HeadlineSolFamNW wg) w).lam v t := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  have hode : ∀ v : UniversalLocalView, ∀ t : ℝ, 0 ≤ t →
      HasDerivAt (((paper3HeadlineSolFamNW wg) w).lam v)
        ((((1 + Real.cos t) / 2) ^ paper3HeadlineM *
              ((paper3HeadlineKappa : ℚ) : ℝ)) *
            (1 / (Fintype.card UniversalLocalView : ℝ) -
              ((paper3HeadlineSolFamNW wg) w).lam v t)
          + (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQNW wg : ℚ) : ℝ) *
                Real.exp ((bgpParamsNW wg).cα * t))) *
            ((paper3HeadlineSolFamNW wg) w).lam v t *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                  (((paper3HeadlineSolFamNW wg) w).u t)
                - ∑ u : UniversalLocalView,
                    ((paper3HeadlineSolFamNW wg) w).lam u t *
                      universalPval paper3HeadlineEta paper3HeadlineEta_pos u
                        (((paper3HeadlineSolFamNW wg) w).u t))) t := by
    intro v t ht
    simpa using ((paper3HeadlineSolFamNW wg) w).lam_hasDeriv v t
      (selectorSchedule_domain_of_nonneg_structural t ht)
  have hinit : ∀ v : UniversalLocalView,
      0 ≤ ((paper3HeadlineSolFamNW wg) w).lam v 0 := by
    intro v
    rw [(paper3HeadlineSolFamNW_initial_values wg w).2.2.1 v]
    have hcard : (0 : ℚ) < (Fintype.card UniversalLocalView : ℚ) := by
      exact_mod_cast Fintype.card_pos
    positivity
  exact replicator_lam_nonneg
    (lam := fun v t => ((paper3HeadlineSolFamNW wg) w).lam v t)
    (P := fun v t =>
      universalPval paper3HeadlineEta paper3HeadlineEta_pos v
        (((paper3HeadlineSolFamNW wg) w).u t))
    (cr := fun t => ((1 + Real.cos t) / 2) ^ paper3HeadlineM *
      ((paper3HeadlineKappa : ℚ) : ℝ))
    (cg := fun t => ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
      (((paper3WarmGainQNW wg : ℚ) : ℝ) *
        Real.exp ((bgpParamsNW wg).cα * t)))
    ((((continuous_const.add Real.continuous_cos).div_const 2).pow _).mul
      continuous_const)
    ((((continuous_const.add Real.continuous_sin).div_const 2).pow _).mul
      (continuous_const.mul
        (Real.continuous_exp.comp (continuous_const.mul continuous_id))))
    (fun v => ((paper3HeadlineSolFamNW wg) w).cont_lam v)
    (fun v => universalPval_continuous_of_cont_u paper3HeadlineEta
      paper3HeadlineEta_pos v ((paper3HeadlineSolFamNW wg) w).cont_u)
    (fun t => mul_nonneg
      (pow_nonneg (by nlinarith [Real.neg_one_le_cos t]) _)
      (by norm_num [paper3HeadlineKappa]))
    hode hinit

/-- Simplex convexity reduction for the word-coupled mix target. -/
theorem paper3NW_mixTarget_abs_le_of_branch_abs (wg w : ℕ)
    {t : ℝ} (ht : 0 ≤ t) {B : ℝ}
    (hbranch_abs : ∀ i : Fin d_U, ∀ v : UniversalLocalView,
      |BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFamNW wg) w).u t) i| ≤ B) :
    ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam t i| ≤ B := by
  intro i
  simpa [selectorMixTarget, selectorF] using
    paper3Headline_abs_sum_weighted_le_of_simplex_and_abs_le
      (lam := fun v : UniversalLocalView =>
        ((paper3HeadlineSolFamNW wg) w).lam v t)
      (a := fun v : UniversalLocalView =>
        BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFamNW wg) w).u t) i)
      (fun v => paper3NW_lam_nonneg_forward wg w v t ht)
      (paper3NW_lam_sum_forward wg w t ht) (hbranch_abs i)

/-- Scalar relaxation trapping of the word-coupled `z` under a mix box. -/
theorem paper3NW_z_abs_le_of_mix_abs_box (wg w : ℕ)
    {T Zbox : ℝ} (hT : 0 ≤ T)
    (hinit_abs : ∀ i : Fin d_U,
      |(((selectorInitX0 w i : ℚ) : ℝ))| ≤ Zbox)
    (hmix_abs : ∀ t, t ∈ Icc (0 : ℝ) T → ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam t i| ≤ Zbox) :
    ∀ t, t ∈ Icc (0 : ℝ) T → ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).z t i| ≤ Zbox := by
  intro t ht i
  have hz0eq := (paper3HeadlineSolFamNW_initial_values wg w).1 i
  have hmem : ((paper3HeadlineSolFamNW wg) w).z t i ∈ Icc (-Zbox) Zbox := by
    refine scalar_relaxation_trapping_invariant
      (y := fun τ => ((paper3HeadlineSolFamNW wg) w).z τ i)
      (g := fun τ =>
        selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam τ i)
      (k := fun τ =>
        (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateZ (bgpParamsNW wg).L
            (((paper3HeadlineSolFamNW wg) w).μ τ) τ)
      (lo := -Zbox) (hi := Zbox) (T := t)
      ht.1
      (selector_replicator_gateZ_integrand_continuous
        ((paper3HeadlineSolFamNW wg) w))
      (((paper3HeadlineSolFamNW wg) w).cont_mixTarget i)
      ?_ ?_ ?_ ?_
    · intro τ hτ
      exact ((paper3HeadlineSolFamNW wg) w).z_hasDeriv τ
        (selectorSchedule_domain_of_nonneg_structural τ hτ.1) i
    · intro τ hτ
      exact selector_replicator_gateZ_integrand_nonneg
        ((paper3HeadlineSolFamNW wg) w)
        selectorSchedule_domain_of_nonneg_structural
        (by rw [bgpParamsNW_A_eq]; norm_num) hτ.1
    · intro τ hτ
      exact abs_le.mp (hmix_abs τ ⟨hτ.1, le_trans hτ.2 ht.2⟩ i)
    · change ((paper3HeadlineSolFamNW wg) w).z 0 i ∈ Icc (-Zbox) Zbox
      rw [hz0eq]
      exact abs_le.mp (hinit_abs i)
  exact abs_le.mpr hmem

/-- Under the maintained warm-prefix u-tube, the coupled pair stays in a
`5·D_U` box: `z` is trapped in the `2·D_U` mix hull and `u` is tube-pinned
near the (`2·D_U`-bounded) encoding. -/
theorem paper3NW_zu_box_of_utube (wg w : ℕ) {t : ℝ}
    (ht : t ∈ Icc (0 : ℝ) (Real.pi / 6))
    (htube : ∀ s ∈ Icc (0 : ℝ) t, ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).u s i -
        stackMachineEncodingU.enc (selectorInitConfig w) i| ≤ r_LE_U) :
    ∀ s ∈ Icc (0 : ℝ) t, ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).z s i -
        ((paper3HeadlineSolFamNW wg) w).u s i| ≤ 5 * D_U := by
  have hmix : ∀ s, s ∈ Icc (0 : ℝ) t → ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam s i| ≤ 2 * D_U := by
    intro s hs
    exact paper3NW_mixTarget_abs_le_of_branch_abs wg w hs.1
      (fun i v => branchU_evalBranch_abs_le_two_D_U
        (fun j => htube s hs j) v i)
  have hz : ∀ s, s ∈ Icc (0 : ℝ) t → ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).z s i| ≤ 2 * D_U :=
    paper3NW_z_abs_le_of_mix_abs_box wg w ht.1
      (paper3Headline_init_z_abs_le_two_D_U w) hmix
  intro s hs i
  have h1 := hz s hs i
  have h2 := htube s hs i
  have h3 : |stackMachineEncodingU.enc (selectorInitConfig w) i| ≤
      2 * D_U := by
    rw [stackMachineEncodingU_enc_eq]
    exact paper3Headline_confEncU_abs_le_two_D_U (selectorInitConfig w) i
  have hD8 := paper3Headline_D_U_ge_eight
  have hrv : r_LE_U = 1 / 1000 := rfl
  rw [abs_le] at h1 h2 h3 ⊢
  constructor <;> [linarith [h1.1, h2.2, h3.2]; linarith [h1.2, h2.1, h3.1]]

/-- The word-coupled kernel-mass denominator beats the `5·D_U` box with
`r_LE_U/2` to spare. -/
theorem paper3NW_drift_le_half_r (wg : ℕ) :
    5 * D_U / (200 * (bgpScaleW wg : ℝ)) ≤ r_LE_U / 2 := by
  have hD := D_U_le_two_bgpScale
  have hs : (bgpScale : ℝ) * 1296 ≤ (bgpScaleW wg : ℝ) := by
    have hnat : bgpScale * 1296 ≤ bgpScaleW wg := by
      have h64 : (1296 : ℕ) ≤ 6 ^ (MachineInstance.inputLenU 1 wg + 220) := by
        calc (1296 : ℕ) = 6 ^ 4 := by norm_num
          _ ≤ 6 ^ (MachineInstance.inputLenU 1 wg + 220) :=
            Nat.pow_le_pow_right (by norm_num) (by omega)
      exact Nat.mul_le_mul_left _ h64
    exact_mod_cast hnat
  have hs0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hsc0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hrv : r_LE_U = 1 / 1000 := rfl
  rw [div_le_iff₀ (by nlinarith : (0 : ℝ) < 200 * (bgpScaleW wg : ℝ)), hrv]
  nlinarith

/-- **The warm-prefix u-tube bootstrap**: on `[0, π/6]` the word-coupled
`u` stays within `r_LE_U` of its exact initial encoding (first-exit
argument; the conditional drift is `≤ 5·D_U/(200·bgpScaleW) ≤ r_LE_U/2`). -/
theorem paper3NW_warm_prefix_utube (wg w : ℕ) :
    ∀ t ∈ Icc (0 : ℝ) (Real.pi / 6), ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).u t i -
        stackMachineEncodingU.enc (selectorInitConfig w) i| ≤ r_LE_U := by
  classical
  have hr_pos : (0 : ℝ) < r_LE_U := by norm_num [r_LE_U]
  have hu0 : ∀ i : Fin d_U,
      ((paper3HeadlineSolFamNW wg) w).u 0 i =
        stackMachineEncodingU.enc (selectorInitConfig w) i := by
    intro i
    rw [(paper3HeadlineSolFamNW_initial_values wg w).2.1 i]
    exact selectorInitX0_cast_enc w i
  by_contra hcon
  push_neg at hcon
  obtain ⟨tb, htb, i0, hi0⟩ := hcon
  set Bad : Set ℝ := Icc (0 : ℝ) tb ∩
    ⋃ i : Fin d_U, {s : ℝ |
      r_LE_U ≤ |((paper3HeadlineSolFamNW wg) w).u s i -
        stackMachineEncodingU.enc (selectorInitConfig w) i|} with hBadDef
  have hclosed : IsClosed Bad := by
    refine isClosed_Icc.inter (isClosed_iUnion_of_finite fun i => ?_)
    exact isClosed_le continuous_const
      (((((paper3HeadlineSolFamNW wg) w).cont_u i).sub
        continuous_const).abs)
  have htb_mem : tb ∈ Bad :=
    ⟨⟨htb.1, le_refl tb⟩, Set.mem_iUnion.mpr ⟨i0, hi0.le⟩⟩
  have hne : Bad.Nonempty := ⟨tb, htb_mem⟩
  have hbdd : BddBelow Bad := ⟨0, fun s hs => hs.1.1⟩
  have htmem : sInf Bad ∈ Bad := hclosed.csInf_mem hne hbdd
  have ht0 : 0 ≤ sInf Bad := le_csInf hne fun b hb => hb.1.1
  have htle : sInf Bad ≤ tb := csInf_le hbdd htb_mem
  have htπ : sInf Bad ≤ Real.pi / 6 := le_trans htle htb.2
  have htpos : 0 < sInf Bad := by
    rcases lt_or_eq_of_le ht0 with h | h
    · exact h
    · exfalso
      obtain ⟨i, hi⟩ := Set.mem_iUnion.mp htmem.2
      rw [← h] at hi
      simp only [Set.mem_setOf_eq] at hi
      rw [hu0 i, sub_self, abs_zero] at hi
      linarith
  have htube : ∀ s ∈ Icc (0 : ℝ) (sInf Bad), ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).u s i -
        stackMachineEncodingU.enc (selectorInitConfig w) i| ≤ r_LE_U := by
    intro s hs i
    rcases lt_or_eq_of_le hs.2 with hlt | heq
    · by_contra hgt
      push_neg at hgt
      have hmem : s ∈ Bad :=
        ⟨⟨hs.1, le_trans hs.2 htle⟩, Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
      exact absurd (csInf_le hbdd hmem) (not_le.mpr hlt)
    · have hf : Continuous fun τ : ℝ =>
          |((paper3HeadlineSolFamNW wg) w).u τ i -
            stackMachineEncodingU.enc (selectorInitConfig w) i| :=
        ((((paper3HeadlineSolFamNW wg) w).cont_u i).sub
          continuous_const).abs
      have hev : ∀ᶠ τ in nhdsWithin (sInf Bad) (Set.Iio (sInf Bad)),
          |((paper3HeadlineSolFamNW wg) w).u τ i -
            stackMachineEncodingU.enc (selectorInitConfig w) i| ≤
            r_LE_U := by
        filter_upwards [Ioo_mem_nhdsLT htpos] with τ hτ
        by_contra hgt
        push_neg at hgt
        have hmem : τ ∈ Bad :=
          ⟨⟨hτ.1.le, le_trans hτ.2.le htle⟩,
            Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
        exact absurd (csInf_le hbdd hmem) (not_le.mpr hτ.2)
      have hlim := le_of_tendsto
        (hf.continuousWithinAt
          (s := Set.Iio (sInf Bad)) (x := sInf Bad)) hev
      rw [heq]
      exact hlim
  -- the conditional drift beats the exit level: contradiction
  obtain ⟨i, hi⟩ := Set.mem_iUnion.mp htmem.2
  simp only [Set.mem_setOf_eq] at hi
  have hzu := paper3NW_zu_box_of_utube wg w ⟨ht0, htπ⟩ htube
  have hD8 := paper3Headline_D_U_ge_eight
  have hdrift := paper3NW_u_drift_on_warm_prefix wg w i
    (by linarith : (0 : ℝ) ≤ 5 * D_U) ⟨ht0, htπ⟩
    (fun τ hτ => hzu τ hτ i)
  rw [hu0 i] at hdrift
  have hhalf := paper3NW_drift_le_half_r wg
  linarith [hi, hdrift, hhalf]

/-- **F1-NW (5/5) PROVED: the head-started cycle-`0` weighted boundary
budget.**  `u(0) = enc(cfg 0)` exactly; on `[0, π/6]` the word-coupled
u-kernel mass is `≤ 1/(200·bgpScaleW w)` while `|z − u| ≤ 5·D_U` (hull
trapping under the bootstrapped u-tube), so the weighted boundary
`B_U^{dep(0,i)}·|u(π/6) − enc|_i ≤ 6^{inputLenU+30}·(5·D_U)/(200·bgpScaleW w)`
fits in `r_LE_U/4` by `bgpScaleW_beats_depth_weight`. -/
theorem paper3F1_W0_quarter_NW (w : ℕ) :
    ∀ i, paper3F1W0NW w i ≤ r_LE_U / 4 := by
  intro i
  have hπ0 : (0 : ℝ) ≤ Real.pi / 6 := by linarith [Real.pi_pos]
  have hπ6 : (Real.pi / 6) ∈ Icc (0 : ℝ) (Real.pi / 6) :=
    ⟨hπ0, le_refl _⟩
  have htube := paper3NW_warm_prefix_utube w w
  have hzu := paper3NW_zu_box_of_utube w w hπ6
    (fun s hs j => htube s hs j)
  have hD8 := paper3Headline_D_U_ge_eight
  have hdrift := paper3NW_u_drift_on_warm_prefix w w i
    (by linarith : (0 : ℝ) ≤ 5 * D_U) hπ6 (fun τ hτ => hzu τ hτ i)
  -- boundary error at the cycle-0 write start
  have hws : selectorMUWriteStartTime 0 = Real.pi / 6 := by
    unfold selectorMUWriteStartTime
    norm_num
  have hcfg : paper3F1Cfg w 0 = selectorInitConfig w := by
    simp [paper3F1Cfg, solMUReplStaticCfg]
  have hu0 : ((paper3HeadlineSolFamNW w) w).u 0 i =
      stackMachineEncodingU.enc (paper3F1Cfg w 0) i := by
    rw [(paper3HeadlineSolFamNW_initial_values w w).2.1 i, hcfg]
    exact selectorInitX0_cast_enc w i
  have herr : paper3F1BoundaryErrNW w 0 i ≤
      5 * D_U / (200 * (bgpScaleW w : ℝ)) := by
