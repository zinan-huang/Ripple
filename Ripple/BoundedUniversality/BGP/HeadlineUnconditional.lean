/-! ### S2 Glue-1 δs producer (Q4168, self-implemented; codex exhausted) -/

/-- Crude but explicit entry error for the hold-window settled-z contraction. -/
noncomputable def paper3S2SettledEntryD0NW : ℝ :=
  paper3F1CwinDefN + r_LE_U + 4 * D_U

/-- The explicit settled-z entry constant has a very coarse exponential currency.
This is intentionally much weaker than the actual polynomial size. -/
theorem paper3S2_settledEntryD0_le_exp_currency_NW (w : ℕ) :
    paper3S2SettledEntryD0NW ≤
      Real.exp (2 * (bgpScaleW w : ℝ) + 200) := by
  let S : ℝ := (bgpScaleW w : ℝ)
  have hS4 : (4 : ℝ) ≤ S := by
    exact bgpScaleWR_ge_four w
  have hS0 : 0 ≤ S := le_trans (by norm_num) hS4
  have hscale : (bgpScale : ℝ) ≤ S := by
    exact bgpScaleR_le_bgpScaleWR w
  have hD : D_U ≤ 2 * S := by
    exact D_U_le_two_bgpScaleW w
  have hcwin :
      paper3F1CwinDefN ≤ S * (Real.exp (199 : ℝ) + 11) := by
    unfold paper3F1CwinDefN paper3F1CwinDef
    exact mul_le_mul_of_nonneg_right hscale (by positivity)
  have hr : r_LE_U = (1 : ℝ) / 1000 := rfl
  have hraw :
      paper3S2SettledEntryD0NW ≤
        S * (Real.exp (199 : ℝ) + 20) := by
    unfold paper3S2SettledEntryD0NW
    rw [hr]
    nlinarith
  have h199 : Real.exp (199 : ℝ) ≤ Real.exp (200 : ℝ) :=
    Real.exp_le_exp.mpr (by norm_num)
  have h20 : (20 : ℝ) ≤ Real.exp (200 : ℝ) := by
    exact paper3NW4_exp_three_ge.trans
      (Real.exp_le_exp.mpr (by norm_num : (3 : ℝ) ≤ 200))
  have hcoef :
      Real.exp (199 : ℝ) + 20 ≤ 2 * Real.exp (200 : ℝ) := by
    linarith
  have hadd := Real.add_one_le_exp S
  have hSle : S ≤ Real.exp S := by linarith
  have htwo : (2 : ℝ) ≤ Real.exp S := by linarith
  have hmul : 2 * S ≤ Real.exp S * Real.exp S :=
    mul_le_mul htwo hSle hS0 (Real.exp_pos S).le
  have h2S : 2 * S ≤ Real.exp (2 * S) := by
    calc
      2 * S ≤ Real.exp S * Real.exp S := hmul
      _ = Real.exp (2 * S) := by
        rw [← Real.exp_add]
        congr 1
        ring
  calc
    paper3S2SettledEntryD0NW
        ≤ S * (Real.exp (199 : ℝ) + 20) := hraw
    _ ≤ S * (2 * Real.exp (200 : ℝ)) :=
      mul_le_mul_of_nonneg_left hcoef hS0
    _ = (2 * S) * Real.exp (200 : ℝ) := by ring
    _ ≤ Real.exp (2 * S) * Real.exp (200 : ℝ) :=
      mul_le_mul_of_nonneg_right h2S (Real.exp_pos _).le
    _ = Real.exp (2 * S + 200) := by
      rw [← Real.exp_add]

/-- The hold write mass annihilates the explicit hold-entry constant. -/
theorem paper3S2_settledEntry_exp_neg_holdMass_le_twentieth_NW
    (w j : ℕ) :
    Real.exp (-(paper3S2HoldMassLowerNW w j)) *
        paper3S2SettledEntryD0NW ≤ r_LE_U / 20 := by
  let S : ℝ := (bgpScaleW w : ℝ)
  have hS4 : (4 : ℝ) ≤ S := by
    exact bgpScaleWR_ge_four w
  have hS0 : 0 ≤ S := le_trans (by norm_num) hS4
  have hj0 : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
  have htime :
      (3 / 2 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + Real.pi / 2 := by
    nlinarith [Real.pi_gt_three]
  have hcoef0 : 0 ≤ 50 * S := by positivity
  have htime_mul := mul_le_mul_of_nonneg_left htime hcoef0
  have hinner :
      75 * S ≤
        50 * S * (2 * Real.pi * (j : ℝ) + Real.pi / 2) := by
    nlinarith [htime_mul]
  have hexp_inner :
      Real.exp (75 * S) ≤
        Real.exp (50 * S *
          (2 * Real.pi * (j : ℝ) + Real.pi / 2)) :=
    Real.exp_le_exp.mpr hinner
  have hlinexp := Real.add_one_le_exp (75 * S)
  have hlinear : 2 * S + 212 ≤ Real.exp (75 * S) := by
    nlinarith
  have hpi_one : (1 : ℝ) ≤ Real.pi / 3 := by
    nlinarith [Real.pi_gt_three]
  have hmass :
      2 * S + 212 ≤ paper3S2HoldMassLowerNW w j := by
    unfold paper3S2HoldMassLowerNW
    calc
      2 * S + 212 ≤ Real.exp (75 * S) := hlinear
      _ ≤ Real.exp (50 * S *
          (2 * Real.pi * (j : ℝ) + Real.pi / 2)) := hexp_inner
      _ ≤ (Real.pi / 3) *
          Real.exp (50 * S *
            (2 * Real.pi * (j : ℝ) + Real.pi / 2)) :=
        le_mul_of_one_le_left (Real.exp_pos _).le hpi_one
  have hcurrency :
      paper3S2SettledEntryD0NW ≤ Real.exp (2 * S + 200) := by
    exact paper3S2_settledEntryD0_le_exp_currency_NW w
  have hmul :
      Real.exp (-(paper3S2HoldMassLowerNW w j)) *
          paper3S2SettledEntryD0NW ≤
        Real.exp (-(paper3S2HoldMassLowerNW w j)) *
          Real.exp (2 * S + 200) :=
    mul_le_mul_of_nonneg_left hcurrency (Real.exp_pos _).le
  have h12 : (20000 : ℝ) ≤ Real.exp (12 : ℝ) := by
    have h20 := paper3NW4_exp_three_ge
    have e3 := Real.exp_pos (3 : ℝ)
    have hsplit : Real.exp (12 : ℝ) =
        Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 := by
      rw [show (12 : ℝ) = 3 + 3 + 3 + 3 by norm_num,
        Real.exp_add, Real.exp_add, Real.exp_add]
    have h2 : (400 : ℝ) ≤ Real.exp 3 * Real.exp 3 := by nlinarith [h20, e3]
    rw [hsplit]
    nlinarith [mul_le_mul h2 h2 (by norm_num : (0:ℝ) ≤ 400) (by positivity)]
  have hrecip :
      1 / Real.exp (12 : ℝ) ≤ 1 / (20000 : ℝ) :=
    one_div_le_one_div_of_le (by norm_num) h12
  have hr : r_LE_U = (1 : ℝ) / 1000 := rfl
  have hfinal : Real.exp (-(12 : ℝ)) ≤ r_LE_U / 20 := by
    have heneg : Real.exp (-(12 : ℝ)) = 1 / Real.exp (12 : ℝ) := by
      rw [Real.exp_neg]
      ring
    rw [heneg, hr]
    calc
      1 / Real.exp (12 : ℝ) ≤ 1 / (20000 : ℝ) := hrecip
      _ = (1 / 1000 : ℝ) / 20 := by norm_num
  calc
    Real.exp (-(paper3S2HoldMassLowerNW w j)) *
        paper3S2SettledEntryD0NW
        ≤ Real.exp (-(paper3S2HoldMassLowerNW w j)) *
            Real.exp (2 * S + 200) := hmul
    _ = Real.exp
        (2 * S + 200 - paper3S2HoldMassLowerNW w j) := by
      rw [← Real.exp_add]
      congr 1
      ring
    _ ≤ Real.exp (-(12 : ℝ)) :=
      Real.exp_le_exp.mpr (by linarith)
    _ ≤ r_LE_U / 20 := hfinal

/-- The widened M1 radius at the sharp F1 input is at most `3r/20`. -/
theorem paper3S2_M1_sharp_le_three_twentieth_NW (w j : ℕ) :
    paper3S2M1NW w j (r_LE_U / 60) ≤ 3 * r_LE_U / 20 := by
  have hlegs := paper3S2_M1_legs_le_twentieth_NW w j
  unfold paper3S2M1NW
  have hr : r_LE_U = (1 : ℝ) / 1000 := rfl
  rw [hr] at hlegs ⊢
  linarith

/-- **S2 Glue-1 settled-z producer.**  The hold-window z relaxation contracts
an explicit F1/Seg-C entry box below `r/20`, while the moving target contributes
at most `3r/20`. -/
theorem paper3S2_settled_z_at_wr_NW (w j : ℕ) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (selectorMUWriteReadTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
          r_LE_U / 5 := by
  intro i
  let sol := (paper3HeadlineSolFamNW w) w
  let wh : ℝ := selectorMUWriteHoldTime j
  let wr : ℝ := selectorMUWriteReadTime j
  let M : ℝ := stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i
  have hwhwr : wh ≤ wr := by
    simpa [wh, wr] using selectorMUWriteHold_le_read j
  have hwrz : wr ≤ selectorMUZOffStart j := by
    dsimp [wr]
    unfold selectorMUWriteReadTime selectorMUZOffStart
    nlinarith [Real.pi_pos]
  have hwh_mem :
      selectorMUWriteHoldTime j ∈
        Icc (selectorMUWriteStartTime j) (selectorMUWriteReadTime j) :=
    ⟨selectorMUWriteStart_le_hold j, selectorMUWriteHold_le_read j⟩
  have hzu := paper3SegC_envelope_NW w j i
    (selectorMUWriteHoldTime j) hwh_mem
  have hu :
      |sol.u wh i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U := by
    simpa [sol, wh] using
      (paper3SegC_utube_win_NW w j (selectorMUWriteHoldTime j) hwh_mem i)
  have henc_old := paper3NW4_enc_abs (paper3F1Cfg w j) i
  have henc_new := paper3NW4_enc_abs (paper3F1Cfg w (j + 1)) i
  have htri1 :
      |sol.z wh i - M| ≤ |sol.z wh i - sol.u wh i| + |sol.u wh i - M| :=
    abs_sub_le _ _ _
  have htri2 :
      |sol.u wh i - M| ≤
        |sol.u wh i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
        |stackMachineEncodingU.enc (paper3F1Cfg w j) i - M| :=
    abs_sub_le _ _ _
  have htri3 :
      |stackMachineEncodingU.enc (paper3F1Cfg w j) i - M| ≤
        |stackMachineEncodingU.enc (paper3F1Cfg w j) i| + |M| :=
    abs_sub _ _
  have hentry : |sol.z wh i - M| ≤ paper3S2SettledEntryD0NW := by
    dsimp [sol, wh, M] at hzu hu henc_old henc_new htri1 htri2 htri3 ⊢
    unfold paper3S2SettledEntryD0NW
    linarith
  have hstart : ∀ k : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u
          (selectorMUWriteStartTime j) k -
        stackMachineEncodingU.enc (paper3F1Cfg w j) k| ≤
          r_LE_U / 60 :=
    paper3F1_writeStart_sharp_NW w j
  have hmix_all :=
    paper3S2_M1_mix_conc_hold_NW w j hstart
  have hstab : ∀ t ∈ Icc wh wr,
      |selectorMixTarget branchU sol.u sol.lam t i - M| ≤
        paper3S2M1NW w j (r_LE_U / 60) := by
    intro t ht
    have ht' : t ∈ Icc (selectorMUWriteHoldTime j)
        (selectorMUZOffStart j) := by
      exact ⟨by simpa [wh] using ht.1,
        le_trans (by simpa [wr] using ht.2) hwrz⟩
    simpa [sol, M] using hmix_all t ht' i
  have hwh0 : 0 ≤ wh := by
    dsimp [wh]
    exact le_trans (selectorMUWriteStartTime_nonneg j)
      (selectorMUWriteStart_le_hold j)
  have hdom : ∀ t ∈ Icc wh wr, t ∈ selectorSchedule.domain := by
    intro t ht
    exact selectorSchedule_domain_of_nonneg_structural t
      (le_trans hwh0 ht.1)
  have hg0 : ∀ t ∈ Icc wh wr,
      0 ≤ (bgpParamsNW w).A * sol.α t *
        bGateZ (bgpParamsNW w).L (sol.μ t) t := by
    intro t ht
    simpa [sol] using
      paper3NW4_zKernel_nonneg w w (le_trans hwh0 ht.1)
  have hzh : ∀ t ∈ Icc wr wr, |sol.z t i - sol.z wr i| ≤ (0 : ℝ) := by
    intro t ht
    have ht_eq : t = wr := le_antisymm ht.2 ht.1
    subst t
    simp
  have hwrite :=
    z_after_write_bound_repl
      (sol := sol) (s := i)
      (a := wh) (m := wr) (b := wr) (M := M)
      (δw := paper3S2M1NW w j (r_LE_U / 60)) (δzh := 0)
      hwhwr hdom
      (by simpa [sol] using paper3NW4_zKernel_continuous w w)
      hg0 hstab hzh
  have hraw := hwrite wr ⟨le_rfl, le_rfl⟩
  have hraw' :
      |sol.z wr i - M| ≤
        Real.exp (-(∫ τ in wh..wr,
          (bgpParamsNW w).A * sol.α τ *
            bGateZ (bgpParamsNW w).L (sol.μ τ) τ)) *
          |sol.z wh i - M| +
        paper3S2M1NW w j (r_LE_U / 60) := by
    simpa only [sub_self, abs_zero, zero_add] using hraw
  have hmass := paper3S2_holdMassLower_NW w w j
  have hexp :
      Real.exp (-(∫ τ in wh..wr,
        (bgpParamsNW w).A * sol.α τ *
          bGateZ (bgpParamsNW w).L (sol.μ τ) τ)) ≤
        Real.exp (-(paper3S2HoldMassLowerNW w j)) := by
    apply Real.exp_le_exp.mpr
    simpa [sol, wh, wr] using neg_le_neg hmass
  have hcontract0 :
      Real.exp (-(∫ τ in wh..wr,
        (bgpParamsNW w).A * sol.α τ *
          bGateZ (bgpParamsNW w).L (sol.μ τ) τ)) *
          |sol.z wh i - M| ≤
        Real.exp (-(paper3S2HoldMassLowerNW w j)) *
          paper3S2SettledEntryD0NW :=
    mul_le_mul hexp hentry (abs_nonneg _) (Real.exp_pos _).le
  have hcontract :
      Real.exp (-(∫ τ in wh..wr,
        (bgpParamsNW w).A * sol.α τ *
          bGateZ (bgpParamsNW w).L (sol.μ τ) τ)) *
          |sol.z wh i - M| ≤ r_LE_U / 20 :=
    hcontract0.trans
      (paper3S2_settledEntry_exp_neg_holdMass_le_twentieth_NW w j)
  have hM1 := paper3S2_M1_sharp_le_three_twentieth_NW w j
  dsimp [sol, wr, M] at hraw' ⊢
  linarith


/-! ### S2 Glue-1 handoff entry + unconditional S2 core (Q4170; unblocks S4b) -/

theorem paper3S2_handoff_entry_NW (w j : ℕ) :
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
          9 * r_LE_U / 20) ∧
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i| ≤
        paper3S2GuardCu) := by
  let epsIn : ℝ := r_LE_U / 60
  let M1 : ℝ := paper3S2M1NW w j epsIn

  have heps0 : 0 ≤ epsIn := by
    dsimp [epsIn]
    norm_num [r_LE_U]

  have hstart : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u
          (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ epsIn := by
    intro i
    simpa [epsIn] using (paper3F1_writeStart_sharp_NW w j i)

  have hM10 : 0 ≤ M1 := by
    simpa [M1] using
      (paper3S2M1NW_nonneg w j (epsIn := epsIn) heps0)

  /- Exact tightened value: M1 = r/10 + legs ≤ r/10 + r/20 = 3r/20. -/
  have hM1_le_three_twentieth : M1 ≤ 3 * r_LE_U / 20 := by
    have hlegs := paper3S2_M1_legs_le_twentieth_NW w j
    change
      6 * (r_LE_U / 60) +
          (6 * paper3NW4Drift w j +
            4 * D_U * paper3NW4EpsLam w j) ≤
        3 * r_LE_U / 20
    linarith

  have hM1_le : M1 ≤ r_LE_U / 5 := by
    linarith [hM1_le_three_twentieth]

  have hδs0 : 0 ≤ r_LE_U / 5 := by
    norm_num [r_LE_U]

  /- The settled-z producer is already stated at `wr j = 2πj+5π/6`. -/
  have hz_b : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
          r_LE_U / 5 := by
    intro i
    simpa [selectorMUWriteReadTime] using
      (paper3S2_settled_z_at_wr_NW w j i)

  /- Restrict the widened `[wh,zOffStart]` M1 producer to handoff piece 1
     `[wr,zOffStart]`. -/
  have hwh_wr : selectorMUWriteHoldTime j ≤ selectorMUWriteReadTime j := by
    unfold selectorMUWriteHoldTime selectorMUWriteReadTime
    linarith [Real.pi_pos]

  have hmixHold :=
    paper3S2_M1_mix_conc_hold_NW w j (epsIn := epsIn) hstart

  have hmix1 :
      ∀ t ∈ Icc
          (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
          (2 * Real.pi * (j : ℝ) + Real.pi),
        ∀ i : Fin d_U,
          |selectorMixTarget branchU
                ((paper3HeadlineSolFamNW w) w).u
                ((paper3HeadlineSolFamNW w) w).lam t i -
            stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤ M1 := by
    intro t ht i
    have hwr_t : selectorMUWriteReadTime j ≤ t := by
      simpa [selectorMUWriteReadTime] using ht.1
    have ht_zoff : t ≤ selectorMUZOffStart j := by
      simpa [selectorMUZOffStart] using ht.2
    have ht' : t ∈ Icc (selectorMUWriteHoldTime j)
        (selectorMUZOffStart j) :=
      ⟨le_trans hwh_wr hwr_t, ht_zoff⟩
    simpa [M1] using hmixHold t ht' i

  /- The two build-green guard producers.  Named implicit arguments make the
     code insensitive to ordinary binder reordering. -/
  have hz_box :
      ∀ t ∈ Icc
          (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6),
        ∀ i : Fin d_U,
          |((paper3HeadlineSolFamNW w) w).z t i| ≤
            paper3S2HandoffCz := by
    simpa using
      (paper3S2_handoff_z_box_NW
        (w := w) (j := j)
        (δs := r_LE_U / 5) (M1 := M1)
        hδs0 le_rfl hM10 hM1_le hz_b hmix1)

  have hmz2 :
      ∀ t ∈ Icc
          (2 * Real.pi * (j : ℝ) + Real.pi)
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6),
        ∀ i : Fin d_U,
          |selectorMixTarget branchU
                ((paper3HeadlineSolFamNW w) w).u
                ((paper3HeadlineSolFamNW w) w).lam t i -
            ((paper3HeadlineSolFamNW w) w).z t i| ≤
          paper3S2HandoffMixZGuard := by
    simpa using
      (paper3S2_handoff_mz2_NW
        (w := w) (j := j)
        (δs := r_LE_U / 5) (M1 := M1)
        hδs0 le_rfl hM10 hM1_le hz_b hmix1)

  constructor
  · intro i
    have hzraw :=
      paper3NW_S2_handoff_z
        (wg := w) (w := w) (j := j) (i := i)
        (E := stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i)
        (δs := r_LE_U / 5)
        (M1 := M1)
        (Bmz := paper3S2HandoffMixZGuard)
        hδs0 hM10 paper3S2HandoffMixZGuard_nonneg
        (hz_b i)
        (fun t ht => hmix1 t ht i)
        (fun t ht => hmz2 t ht i)

    have hrowF := paper3S2_handoff_rowF_NW w j

    calc
      |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i|
          ≤ r_LE_U / 5 + M1 +
              paper3S2HandoffMixZGuard *
                Real.exp (-(200 * (bgpScaleW w : ℝ) *
                  (2 * Real.pi * (j : ℝ) + Real.pi))) /
                (200 * (bgpScaleW w : ℝ)) := hzraw
      _ ≤ r_LE_U / 5 + r_LE_U / 5 + r_LE_U / 20 := by
          linarith [hM1_le, hrowF]
      _ = 9 * r_LE_U / 20 := by ring

  · intro i

    /- Old-configuration tube at b_j = wr j supplies the u entry box. -/
    have hutube_b :
        |((paper3HeadlineSolFamNW w) w).u
            (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U := by
      have h := paper3SegC_utube_win_NW w j
        (selectorMUWriteReadTime j)
        ⟨selectorMUWriteStart_le_read j, le_rfl⟩ i
      simpa [selectorMUWriteReadTime, paper3F1Cfg] using h

    have henc :
        |stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ 2 * D_U :=
      paper3NW4_enc_abs (paper3F1Cfg w j) i

    have htri :
        |((paper3HeadlineSolFamNW w) w).u
            (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i| ≤
          |((paper3HeadlineSolFamNW w) w).u
              (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
          |stackMachineEncodingU.enc (paper3F1Cfg w j) i| := by
      have h := abs_sub_le
        (((paper3HeadlineSolFamNW w) w).u
          (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i)
        (stackMachineEncodingU.enc (paper3F1Cfg w j) i)
        0
      simpa using h

    have hu_b :
        |((paper3HeadlineSolFamNW w) w).u
            (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i| ≤
          paper3S2HandoffCu := by
      unfold paper3S2HandoffCu
      have hr : r_LE_U = 1 / 1000 := rfl
      rw [hr] at hutube_b
      linarith [htri, hutube_b, henc, D_U_nonneg]

    have hCzCu : paper3S2HandoffCz ≤ paper3S2HandoffCu := by
      unfold paper3S2HandoffCz paper3S2HandoffCu
      linarith

    have hu_full :=
      paper3NW_S2_handoff_u_box
        (wg := w) (w := w) (j := j) (i := i)
        (Cz := paper3S2HandoffCz) (Cu := paper3S2HandoffCu)
        hCzCu hu_b (fun t ht => hz_box t ht i)

    have hbe :
        2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6 ≤
          2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 := by
      linarith [Real.pi_pos]

    have hu_e := hu_full
      (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
      ⟨hbe, le_rfl⟩

    simpa [paper3S2HandoffCu, paper3S2GuardCu] using hu_e
/-- Unconditional S2 NEW-configuration tube. -/
theorem paper3S2_interRead_new_tube_NW' (w j : ℕ) :
    ∀ t ∈ Set.Icc
        (2 * Real.pi * (j : ℝ) + 11 * Real.pi / 6)
        (2 * Real.pi * (j : ℝ) + 2 * Real.pi),
      UTube r_LE_U (solMUReplStaticCfg w (j + 1))
        (((paper3HeadlineSolFamNW w) w).u t) := by
  rcases paper3S2_handoff_entry_NW w j with ⟨hzEntry, huEntry⟩
  exact
    paper3S2_interRead_new_tube_NW
      (w := w) (j := j)
      (δh := 9 * r_LE_U / 20)
      (by norm_num [r_LE_U])
      le_rfl
      hzEntry
      huEntry
theorem paper3S2_zOffEnd_new_tube_NW (w j : ℕ) :
    UTube r_LE_U (solMUReplStaticCfg w (j + 1))
      (((paper3HeadlineSolFamNW w) w).u (selectorMUZOffEnd j)) := by
  have ht : selectorMUZOffEnd j ∈ Set.Icc
      (2 * Real.pi * (j : ℝ) + 11 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + 2 * Real.pi) := by
    unfold selectorMUZOffEnd
    push_cast
    constructor <;> linarith [Real.pi_pos]
  exact paper3S2_interRead_new_tube_NW' w j
    (selectorMUZOffEnd j) ht

