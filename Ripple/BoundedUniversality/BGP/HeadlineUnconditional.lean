/-- **No-slop prewrite `z−u` hold on `[zOffEnd j, ws (j+1)]`.**  The pair
error `φ = z − u` satisfies
`φ' = −(kZ + kU)·φ + kZ·(mix − u) = (kZ + kU)·(target − φ)` with the
relaxation target `kZ·(mix − u)/(kZ + kU)` bounded by the prewrite mix box
`B` (both kernels are positive).  Scalar trapping gives
`|φ(ws (j+1))| ≤ max E B` with NO additive slop: the ctrl-jump pre-write
(the z-gate genuinely reopens on this tail — the reason the retimed source
integral stops at `zOffEnd`) drags `z` toward the mixture, and the mixture
stays within `B` of the frozen `u`. -/
theorem paper3N_prewrite_zu_hold (wg w j : ℕ) {E B : ℝ}
    (hE : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z (selectorMUZOffEnd j) i -
        ((paper3HeadlineSolFamN wg) w).u (selectorMUZOffEnd j) i| ≤ E)
    (hB : ∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1)),
      |selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam τ i -
        ((paper3HeadlineSolFamN wg) w).u τ i| ≤ B) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        ((paper3HeadlineSolFamN wg) w).u
          (selectorMUWriteStartTime (j + 1)) i| ≤ max E B := by
  intro i
  have hπ := Real.pi_pos
  have haT : selectorMUZOffEnd j ≤ selectorMUWriteStartTime (j + 1) := by
    unfold selectorMUZOffEnd selectorMUWriteStartTime
    push_cast
    linarith
  have ha0 : 0 ≤ selectorMUZOffEnd j := by
    unfold selectorMUZOffEnd
    positivity
  let kZ : ℝ → ℝ := fun τ =>
    bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
      bGateZ bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ
  let kUf : ℝ → ℝ := fun τ =>
    bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
      bGateU bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ
  let kk : ℝ → ℝ := fun τ => kZ τ + kUf τ
  let gg : ℝ → ℝ := fun τ =>
    kZ τ * (selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
        ((paper3HeadlineSolFamN wg) w).lam τ i -
      ((paper3HeadlineSolFamN wg) w).u τ i) / kk τ
  let y : ℝ → ℝ := fun τ =>
    ((paper3HeadlineSolFamN wg) w).z τ i -
      ((paper3HeadlineSolFamN wg) w).u τ i
  have hkZ_pos : ∀ τ : ℝ, 0 ≤ τ → 0 < kZ τ := by
    intro τ hτ0
    have hα := paper3HeadlineSolFamN_alpha wg w hτ0
    dsimp only [kZ]
    rw [hα, bgpParamsN_A_eq, one_mul]
    have hg : (0 : ℝ) < bGateZ bgpParamsN.L
        (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
      simp only [bGateZ]
      exact Real.exp_pos _
    exact mul_pos (Real.exp_pos _) hg
  have hkU_pos : ∀ τ : ℝ, 0 ≤ τ → 0 < kUf τ := by
    intro τ hτ0
    have hα := paper3HeadlineSolFamN_alpha wg w hτ0
    dsimp only [kUf]
    rw [hα, bgpParamsN_A_eq, one_mul]
    have hg : (0 : ℝ) < bGateU bgpParamsN.L
        (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
      simp only [bGateU]
      exact Real.exp_pos _
    exact mul_pos (Real.exp_pos _) hg
  have hkk_pos : ∀ τ : ℝ, 0 ≤ τ → 0 < kk τ := fun τ h =>
    add_pos (hkZ_pos τ h) (hkU_pos τ h)
  have hgateZ_cont : Continuous fun τ : ℝ =>
      bGateZ bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
    have hr : Continuous fun τ : ℝ => rPulse bgpParamsN.L τ := by
      simp only [rPulse]
      exact ((continuous_const.sub Real.continuous_sin).div_const 2).pow
