        (fun k => hupre k τ hτ) i1 (hzpre τ hτ i1)
    have hdrift := paper3NW4_z_drift_of_sin_nonpos w w i1
      (a := 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
      (b := sInf Bad)
      paper3S2MixZGuard_nonneg ha0
      (fun τ hτ => sin_nonpos_on_lower_half j
        (by linarith [hτ.1]) (by linarith [hτ.2, ht_b]))
      hmz (sInf Bad) ⟨hta, le_refl _⟩
    have hcap := paper3S2_firstExit_z_drift_cap_NW w j
    have hza := hz_a i1
    have hsplit : |((paper3HeadlineSolFamNW w) w).z (sInf Bad) i1| ≤
        |((paper3HeadlineSolFamNW w) w).z (sInf Bad) i1 -
          ((paper3HeadlineSolFamNW w) w).z
            (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i1| +
        |((paper3HeadlineSolFamNW w) w).z
          (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i1| := by
      have h := abs_sub_le
        (((paper3HeadlineSolFamNW w) w).z (sInf Bad) i1)
        (((paper3HeadlineSolFamNW w) w).z
