      (selectorMUWriteStartTime (j + 1))) := by
    apply ContinuousOn.div ((hkZ_cont.mul hmixu_cont).continuousOn)
      hkk_cont.continuousOn
    intro τ hτ
    exact ne_of_gt (hkk_pos τ (le_trans ha0 hτ.1))
  have hy_ode : ∀ τ ∈ Icc (selectorMUZOffEnd j)
      (selectorMUWriteStartTime (j + 1)),
      HasDerivAt y (kk τ * (gg τ - y τ)) τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans ha0 hτ.1
