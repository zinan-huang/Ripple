  have harg_nonneg :
      0 ≤ bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta) := by
    have hcα : 0 ≤ bgpParams38.cα := by norm_num [bgpParams38]
    have hsum : 0 ≤ Real.pi / 6 + selectorMURecoveryDelta := by
      nlinarith [Real.pi_pos, selectorMURecoveryDelta_pos]
    exact mul_nonneg hcα hsum
  have hexp : (1 : ℝ) ≤ expGain := by
    change (1 : ℝ) ≤
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta))
    rw [← Real.exp_zero]
    exact Real.exp_le_exp.mpr harg_nonneg
  have hexp_nonneg : 0 ≤ expGain :=
    le_trans (by norm_num : (0 : ℝ) ≤ 1) hexp
  have hwidth : (1 / 4 : ℝ) ≤ width := by
    change (1 / 4 : ℝ) ≤ Real.pi / 12 - selectorMURecoveryDelta
    simp [selectorMURecoveryDelta]
    nlinarith [Real.pi_gt_d2]
  have hwidth_nonneg : 0 ≤ width :=
    le_trans (by norm_num : (0 : ℝ) ≤ 1 / 4) hwidth
  have htail : (3 * Real.pi / 4 : ℝ) ≤ tail := by
    change (3 * Real.pi / 4 : ℝ) ≤ 2 * Real.pi * bgpParams38.cα
    have : bgpParams38.cα = 300 := by norm_num [bgpParams38]
    nlinarith [Real.pi_pos]
  have htail_lower_nonneg : 0 ≤ (3 * Real.pi / 4 : ℝ) := by
    nlinarith [Real.pi_pos]
  have hgap_scale :
      (15 / 16 : ℝ) * 2 ≤ gap * scale :=
    mul_le_mul hgap hscale (by norm_num : (0 : ℝ) ≤ 2) hgap_nonneg
  have hgap_scale_exp :
      ((15 / 16 : ℝ) * 2) * 1 ≤ (gap * scale) * expGain :=
    mul_le_mul hgap_scale hexp (by norm_num : (0 : ℝ) ≤ 1)
      (mul_nonneg hgap_nonneg hscale_nonneg)
  have hgap_scale_exp_width :
      (((15 / 16 : ℝ) * 2) * 1) * (1 / 4) ≤
        ((gap * scale) * expGain) * width :=
    mul_le_mul hgap_scale_exp hwidth
      (by norm_num : (0 : ℝ) ≤ 1 / 4)
      (mul_nonneg (mul_nonneg hgap_nonneg hscale_nonneg) hexp_nonneg)
  have hprod :
      ((((15 / 16 : ℝ) * 2) * 1) * (1 / 4)) *
          (3 * Real.pi / 4) ≤
        (((gap * scale) * expGain) * width) * tail :=
    mul_le_mul hgap_scale_exp_width htail htail_lower_nonneg
      (mul_nonneg
        (mul_nonneg (mul_nonneg hgap_nonneg hscale_nonneg) hexp_nonneg)
        hwidth_nonneg)
  calc
    (Real.pi / 4 : ℝ)
        ≤ ((((15 / 16 : ℝ) * 2) * 1) * (1 / 4)) *
            (3 * Real.pi / 4) := by
          nlinarith [Real.pi_pos]
    _ ≤ (((gap * scale) * expGain) * width) * tail := hprod
    _ = gap * (scale * expGain * width * tail) := by ring

theorem paper3Headline_earlyGainSlope_ge_pi
    (wg : ℕ) :
    (1125 * Real.pi : ℝ) ≤
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        (((3 / 4 : ℝ) ^ paper3HeadlineM) *
          (((paper3WarmGainQ wg : ℚ) : ℝ)) *
          Real.exp (bgpParams38.cα *
            (Real.pi / 6 + selectorMURecoveryDelta)) *
          (Real.pi / 12 - selectorMURecoveryDelta) *
          (2 * Real.pi * bgpParams38.cα)) := by
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let scale : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ))
  let expGain : ℝ :=
    Real.exp (bgpParams38.cα *
      (Real.pi / 6 + selectorMURecoveryDelta))
  let width : ℝ := Real.pi / 12 - selectorMURecoveryDelta
  let tail : ℝ := 2 * Real.pi * bgpParams38.cα
  change (1125 * Real.pi : ℝ) ≤
    gap * (scale * expGain * width * tail)
  have hgap : (15 / 16 : ℝ) ≤ gap := by
    simpa [gap, paper3RecoveryGap] using
      paper3RecoveryGap_ge_fifteen_sixteen wg 0
  have hgap_nonneg : 0 ≤ gap :=
    le_trans (by norm_num : (0 : ℝ) ≤ 15 / 16) hgap
  have hscale : (8 : ℝ) ≤ scale := by
    simpa [scale] using paper3HeadlineHScale_eight wg
  have hscale_nonneg : 0 ≤ scale :=
    le_trans (by norm_num : (0 : ℝ) ≤ 8) hscale
  have harg_nonneg :
      0 ≤ bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta) := by
    have hcα : 0 ≤ bgpParams38.cα := by norm_num [bgpParams38]
    have hsum : 0 ≤ Real.pi / 6 + selectorMURecoveryDelta := by
      nlinarith [Real.pi_pos, selectorMURecoveryDelta_pos]
    exact mul_nonneg hcα hsum
  have hexp : (1 : ℝ) ≤ expGain := by
    change (1 : ℝ) ≤
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta))
    rw [← Real.exp_zero]
    exact Real.exp_le_exp.mpr harg_nonneg
  have hexp_nonneg : 0 ≤ expGain :=
    le_trans (by norm_num : (0 : ℝ) ≤ 1) hexp
  have hwidth : (1 / 4 : ℝ) ≤ width := by
    change (1 / 4 : ℝ) ≤ Real.pi / 12 - selectorMURecoveryDelta
    simp [selectorMURecoveryDelta]
    nlinarith [Real.pi_gt_d2]
  have hwidth_nonneg : 0 ≤ width :=
    le_trans (by norm_num : (0 : ℝ) ≤ 1 / 4) hwidth
  have htail : (600 * Real.pi : ℝ) ≤ tail := by
    change (600 * Real.pi : ℝ) ≤ 2 * Real.pi * bgpParams38.cα
    have hcα : bgpParams38.cα = (300 : ℝ) := by norm_num [bgpParams38]
    rw [hcα]
    nlinarith
  have htail_lower_nonneg : 0 ≤ (600 * Real.pi : ℝ) := by
    nlinarith [Real.pi_pos]
  have hgap_scale :
      (15 / 16 : ℝ) * 8 ≤ gap * scale :=
    mul_le_mul hgap hscale (by norm_num : (0 : ℝ) ≤ 8) hgap_nonneg
  have hgap_scale_exp :
      ((15 / 16 : ℝ) * 8) * 1 ≤ (gap * scale) * expGain :=
    mul_le_mul hgap_scale hexp (by norm_num : (0 : ℝ) ≤ 1)
      (mul_nonneg hgap_nonneg hscale_nonneg)
  have hgap_scale_exp_width :
      (((15 / 16 : ℝ) * 8) * 1) * (1 / 4) ≤
        ((gap * scale) * expGain) * width :=
    mul_le_mul hgap_scale_exp hwidth
      (by norm_num : (0 : ℝ) ≤ 1 / 4)
      (mul_nonneg (mul_nonneg hgap_nonneg hscale_nonneg) hexp_nonneg)
  have hprod :
      ((((15 / 16 : ℝ) * 8) * 1) * (1 / 4)) *
          (600 * Real.pi) ≤
        (((gap * scale) * expGain) * width) * tail :=
    mul_le_mul hgap_scale_exp_width htail htail_lower_nonneg
      (mul_nonneg
        (mul_nonneg (mul_nonneg hgap_nonneg hscale_nonneg) hexp_nonneg)
        hwidth_nonneg)
  calc
    (1125 * Real.pi : ℝ)
        ≤ ((((15 / 16 : ℝ) * 8) * 1) * (1 / 4)) *
            (600 * Real.pi) := by
          nlinarith [Real.pi_pos]
    _ ≤ (((gap * scale) * expGain) * width) * tail := hprod
    _ = gap * (scale * expGain * width * tail) := by ring

/-- The early select-to-substart linear gain decay is already below the
headline Hoff rate at the preceding cycle. -/
theorem paper3Headline_earlyLinearGainDecay_succ_le_hoffRate
    (wg j : ℕ) :
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let c : ℝ :=
      ((3 / 4 : ℝ) ^ paper3HeadlineM) *
        (((paper3WarmGainQ wg : ℚ) : ℝ)) *
        Real.exp (bgpParams38.cα *
          (Real.pi / 6 + selectorMURecoveryDelta)) *
        (Real.pi / 12 - selectorMURecoveryDelta) *
        (2 * Real.pi * bgpParams38.cα)
    Real.exp (-(gap * c) * ((j + 1 : ℕ) : ℝ)) ≤ paper3HoffRate j := by
  dsimp
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let c : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ)) *
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta)) *
      (Real.pi / 12 - selectorMURecoveryDelta) *
      (2 * Real.pi * bgpParams38.cα)
  have hslope : (Real.pi / 4 : ℝ) ≤ gap * c := by
    simpa [gap, c] using paper3Headline_earlyGainSlope_ge_hoffSlope wg
  have hj1_nonneg : 0 ≤ ((j + 1 : ℕ) : ℝ) := by
    exact_mod_cast Nat.zero_le (j + 1)
  have hslope_j :
      (Real.pi / 4) * ((j + 1 : ℕ) : ℝ) ≤
        (gap * c) * ((j + 1 : ℕ) : ℝ) :=
    mul_le_mul_of_nonneg_right hslope hj1_nonneg
  have hhoff_le :
      paper3HoffExponent j ≤
        (Real.pi / 4) * ((j + 1 : ℕ) : ℝ) := by
    have hj_nonneg : 0 ≤ (j : ℝ) := by
      exact_mod_cast Nat.zero_le j
    rw [paper3HoffExponent]
    push_cast
    ring_nf
    nlinarith [Real.pi_pos, hj_nonneg]
  have htotal :
      paper3HoffExponent j ≤
        (gap * c) * ((j + 1 : ℕ) : ℝ) :=
    le_trans hhoff_le hslope_j
  rw [paper3HoffRate]
  refine Real.exp_le_exp.mpr ?_
  have hneg :
      -((gap * c) * ((j + 1 : ℕ) : ℝ)) ≤ -paper3HoffExponent j :=
    neg_le_neg htotal
  simpa [gap, c, mul_assoc] using hneg

/-- The homogeneous Duhamel decay from select start, restricted to the active
suffix, has a q-free square integral.  The early select-to-substart gain gives
the Hoff factor; the active suffix integral is discharged by the square
backward-decay cancellation. -/
theorem paper3Headline_activeTransportedDecay_cg_square_le_hoffRate
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let S : ℝ := selectorMUSelectStartTime (j + 1)
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
    let Csq : ℝ := 1 / (2 * gap)
    (∫ τ in E..Htime,
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
        (Real.exp (-(gap * ((sol w).G τ - (sol w).G S)))) ^ 2) ≤
      Csq * paper3HoffRate j := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let S : ℝ := selectorMUSelectStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let cg : ℝ → ℝ := fun τ =>
    selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  let D : ℝ := Real.exp (-(gap * ((sol w).G E - (sol w).G S)))
  let Hrate : ℝ := paper3HoffRate j
  let Csq : ℝ := 1 / (2 * gap)
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hEH : E ≤ Htime := by
    simpa [E, Htime] using selectorMUEarlySubStart_le_writeHold (j + 1)
  have hE_nonneg : 0 ≤ E := by
    exact le_trans (selectorMUWriteStartTime_nonneg (j + 1))
      (by simpa [E] using selectorMUWriteStart_le_earlySubStart (j + 1))
  have hG_cont : Continuous fun τ : ℝ => (sol w).G τ := (sol w).cont_G
  have hGder : ∀ τ ∈ Icc E Htime, HasDerivAt (sol w).G (cg τ) τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans hE_nonneg hτ.1
    simpa [cg, sol] using
      (sol w).G_hasDeriv τ (solMURepl_static_hdom_nonneg τ hτ0)
  have hcg_cont : Continuous cg := by
    simpa [cg] using
      selectorMU_activeCg_continuous paper3HeadlineM (paper3WarmGainQ wg)
  have hcg_nonneg : ∀ τ ∈ Icc E Htime, 0 ≤ cg τ := by
    intro τ _hτ
    dsimp [cg, selectorMU_activeCg]
    have hsin_base_nonneg : 0 ≤ (1 + Real.sin τ) / 2 := by
      nlinarith [Real.neg_one_le_sin τ]
    exact mul_nonneg (pow_nonneg hsin_base_nonneg paper3HeadlineM)
      (mul_nonneg (paper3WarmGainQ_pos wg).le (Real.exp_pos _).le)
  have hdecay_square_raw :=
    forward_weight_decay_square_integral_le
      (a := E) (b := Htime) (gap := gap) (C := 1) (D := D)
      (G := (sol w).G) (cg := cg) (weight := cg)
      hEH hgap_pos (by norm_num) hG_cont hGder hcg_cont hcg_cont
      hcg_nonneg
      (by
        intro τ _hτ
        have hself : cg τ ≤ cg τ := le_rfl
        simpa using hself)
  have htarget_eq :
      (∫ τ in E..Htime,
        cg τ *
          (Real.exp (-(gap * ((sol w).G τ - (sol w).G S)))) ^ 2)
        =
      ∫ τ in E..Htime,
        cg τ *
          (D * Real.exp (-(gap * ((sol w).G τ - (sol w).G E)))) ^ 2 := by
    refine intervalIntegral.integral_congr ?_
    intro τ _hτ
    have hdecay :
        Real.exp (-(gap * ((sol w).G τ - (sol w).G S))) =
          D * Real.exp (-(gap * ((sol w).G τ - (sol w).G E))) := by
      dsimp [D]
      rw [← Real.exp_add]
      congr 1
      ring
    simpa [hdecay]
  let c : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ)) *
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta)) *
      (Real.pi / 12 - selectorMURecoveryDelta) *
      (2 * Real.pi * bgpParams38.cα)
  have hD_linear :
      D ≤ Real.exp (-(gap * c * ((j + 1 : ℕ) : ℝ))) := by
    have hlin :=
      shifted_early_deltaG_exp_decay_le_linear
        (paper3HeadlineSolFam wg) w (paper3WarmGainQ_pos wg) hgap_pos
    simpa [D, gap, S, E, c, sol] using hlin (j + 1)
  have hlinear_hoff :
      Real.exp (-(gap * c * ((j + 1 : ℕ) : ℝ))) ≤ Hrate := by
    simpa [Hrate, gap, c, mul_assoc] using
      paper3Headline_earlyLinearGainDecay_succ_le_hoffRate wg j
  have hD_le_H : D ≤ Hrate := hD_linear.trans hlinear_hoff
  have hD_nonneg : 0 ≤ D := by
    dsimp [D]
    exact (Real.exp_pos _).le
  have hH_nonneg : 0 ≤ Hrate := by
    dsimp [Hrate, paper3HoffRate]
    positivity
  have hD_sq_le_H_sq : D ^ 2 ≤ Hrate ^ 2 := by
    have hmul := mul_le_mul hD_le_H hD_le_H hD_nonneg hH_nonneg
    simpa [sq] using hmul
  have hH_sq_le_H : Hrate ^ 2 ≤ Hrate := by
    have hH_le_one : Hrate ≤ 1 := by
      simpa [Hrate] using paper3HoffRate_le_one j
    nlinarith [hH_nonneg, hH_le_one]
  have hD_sq_le_H : D ^ 2 ≤ Hrate := hD_sq_le_H_sq.trans hH_sq_le_H
  have hcoeff_nonneg : 0 ≤ 1 / (2 * gap) := by
    positivity
  calc
    (∫ τ in E..Htime,
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
        (Real.exp (-(gap * ((sol w).G τ - (sol w).G S)))) ^ 2)
        =
      ∫ τ in E..Htime,
        cg τ *
          (D * Real.exp (-(gap * ((sol w).G τ - (sol w).G E)))) ^ 2 := by
          simpa [cg] using htarget_eq
    _ ≤ D ^ 2 * (1 / (2 * gap)) := by
          simpa [cg, D] using hdecay_square_raw.2
    _ ≤ Hrate * (1 / (2 * gap)) :=
          mul_le_mul_of_nonneg_right hD_sq_le_H hcoeff_nonneg
    _ = Csq * Hrate := by
          dsimp [Csq]
          ring

/-- The shifted select-to-hold gain-decay term is pointwise below the Hoff
rate, up to the fixed factor `exp (π/8)`. -/
theorem paper3Headline_gainDecay_le_hoffRate_with_const
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    Real.exp (-(gap *
      ((sol w).G (selectorMUWriteHoldTime j) -
        (sol w).G (selectorMUSelectStartTime j)))) ≤
      Real.exp (Real.pi / 8) * paper3HoffRate j := by
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let c : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ)) *
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta)) *
      (Real.pi / 3 - selectorMURecoveryDelta) *
      (2 * Real.pi * bgpParams38.cα)
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hlinear :=
    shifted_deltaG_exp_decay_le_linear
      (sol := sol) (w := w) (gap := gap)
      (paper3WarmGainQ_pos wg) hgap_pos
  dsimp [sol, gap, c] at hlinear
  have hslope : (Real.pi / 4 : ℝ) ≤ gap * c := by
    simpa [gap, c] using paper3Headline_gainSlope_ge_hoffSlope wg
  have hj_nonneg : 0 ≤ (j : ℝ) := by
    exact_mod_cast Nat.zero_le j
  have hslope_j :
      (Real.pi / 4) * (j : ℝ) ≤ (gap * c) * (j : ℝ) :=
    mul_le_mul_of_nonneg_right hslope hj_nonneg
  have hexp_compare :
      Real.exp (-(gap * c * (j : ℝ))) ≤
        Real.exp (Real.pi / 8) * paper3HoffRate j := by
    rw [paper3HoffRate, ← Real.exp_add]
    refine Real.exp_le_exp.mpr ?_
    rw [paper3HoffExponent]
    nlinarith [hslope_j]
  exact (hlinear j).trans hexp_compare

/-- Concrete pointwise early-full shifted endpoint bound at the next cycle,
reduced to the headline Hoff rate. -/
theorem paper3Headline_epsLamShiftedEarlyFullAt_le_hoffRate_with_const
    (wg w j : ℕ) :
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
    epsLamShiftedEarlyFullAt (paper3HeadlineSolFam wg) w gap card (j + 1) ≤
      ((card - 1) * card +
        2 * (card - 1) * (Real.exp (Real.pi / 16) / gap)) *
        paper3HoffRate j := by
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
  let c : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ)) *
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta)) *
      (Real.pi / 12 - selectorMURecoveryDelta) *
      (2 * Real.pi * bgpParams38.cα)
  let gainDecay : ℝ := Real.exp (-(gap * c) * ((j + 1 : ℕ) : ℝ))
  let resetTail : ℝ :=
    Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime (j + 1))) / gap
  let H : ℝ := paper3HoffRate j
  let K : ℝ := Real.exp (Real.pi / 16) / gap
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hbase :
      epsLamShiftedEarlyFullAt sol w gap card (j + 1) ≤
        (card - 1) * (card * gainDecay + resetTail) +
          (card - 1) * resetTail := by
    have h :=
      epsLamShiftedEarlyFullAt_le_linear_decay_bound
        (sol := sol) (w := w) (gap := gap) (R0 := card)
        (paper3WarmGainQ_pos wg) hgap_pos
        (by dsimp [card]; positivity)
        (by norm_num [paper3HeadlineKappa])
        (paper3HeadlineHScale wg)
    simpa [sol, gap, card, c, gainDecay, resetTail] using h (j + 1)
  have hgain : gainDecay ≤ H := by
    dsimp [gainDecay, H, gap, c]
    exact paper3Headline_earlyLinearGainDecay_succ_le_hoffRate wg j
  have hreset_succ :
      resetTail ≤ K * paper3HoffRate (j + 1) := by
    dsimp [resetTail, K, gap]
    simpa [gap] using paper3Headline_resetTail_div_gap_decay_le_hoffRate (j + 1)
  have hK_nonneg : 0 ≤ K := by
    dsimp [K]
    exact div_nonneg (Real.exp_pos _).le hgap_pos.le
  have hreset : resetTail ≤ K * H := by
    exact le_trans hreset_succ
      (mul_le_mul_of_nonneg_left (paper3HoffRate_succ_le j) hK_nonneg)
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  have hcard_nonneg : 0 ≤ card := by
    dsimp [card]
    positivity
  have hcard_sub_nonneg : 0 ≤ card - 1 := by
    dsimp [card]
    have hcard_pos_nat :
        0 < Fintype.card UniversalLocalView :=
      Fintype.card_pos_iff.mpr inferInstance
    have hcard_one : (1 : ℝ) ≤ Fintype.card UniversalLocalView := by
      exact_mod_cast hcard_pos_nat
    linarith
  have hgain_scaled :
      (card - 1) * (card * gainDecay) ≤
        (card - 1) * (card * H) := by
    have hcard_gain : card * gainDecay ≤ card * H :=
      mul_le_mul_of_nonneg_left hgain hcard_nonneg
    exact mul_le_mul_of_nonneg_left hcard_gain hcard_sub_nonneg
  have hreset_scaled :
      (card - 1) * resetTail ≤ (card - 1) * (K * H) :=
    mul_le_mul_of_nonneg_left hreset hcard_sub_nonneg
  calc
    epsLamShiftedEarlyFullAt sol w gap card (j + 1)
        ≤ (card - 1) * (card * gainDecay + resetTail) +
            (card - 1) * resetTail := hbase
    _ = (card - 1) * (card * gainDecay) +
          (card - 1) * resetTail + (card - 1) * resetTail := by ring
    _ ≤ (card - 1) * (card * H) +
          (card - 1) * (K * H) + (card - 1) * (K * H) := by
      linarith [hgain_scaled, hreset_scaled]
    _ = ((card - 1) * card + 2 * (card - 1) * K) * H := by ring

theorem paper3_abs_div_le_exp_neg_of_sink_bounds
    {num sink cg gap D E : ℝ}
    (hnum_nonneg : 0 ≤ num) (hnum_le_one : num ≤ 1)
    (hden_pos : 0 < cg * gap) (hsink_ge : cg * gap ≤ sink)
    (hD_pos : 0 < D) (hcg_ge : D * Real.exp E ≤ cg)
    (hgap_pos : 0 < gap) :
    |num / sink| ≤ (1 / (gap * D)) * Real.exp (-E) := by
  have hsink_pos : 0 < sink := lt_of_lt_of_le hden_pos hsink_ge
  have hquot_nonneg : 0 ≤ num / sink := div_nonneg hnum_nonneg hsink_pos.le
  rw [abs_of_nonneg hquot_nonneg]
  have hinv1 : 1 / sink ≤ 1 / (cg * gap) := by
    apply one_div_le_one_div_of_le
    · exact hden_pos
    · exact hsink_ge
  have hq1 : num / sink ≤ 1 / (cg * gap) := by
    calc
      num / sink = num * (1 / sink) := by ring
      _ ≤ 1 * (1 / sink) := by
        exact mul_le_mul_of_nonneg_right hnum_le_one
          (one_div_nonneg.mpr hsink_pos.le)
      _ ≤ 1 * (1 / (cg * gap)) := by
        exact mul_le_mul_of_nonneg_left hinv1 zero_le_one
      _ = 1 / (cg * gap) := by ring
  have hDexp_pos : 0 < D * Real.exp E := mul_pos hD_pos (Real.exp_pos E)
  have hden2_pos : 0 < gap * (D * Real.exp E) :=
    mul_pos hgap_pos hDexp_pos
  have hden2_le : gap * (D * Real.exp E) ≤ gap * cg :=
    mul_le_mul_of_nonneg_left hcg_ge hgap_pos.le
  have hinv2 : 1 / (cg * gap) ≤ 1 / ((gap * D) * Real.exp E) := by
    have hden_le : (gap * D) * Real.exp E ≤ cg * gap := by
      calc
        (gap * D) * Real.exp E = gap * (D * Real.exp E) := by ring
        _ ≤ gap * cg := hden2_le
        _ = cg * gap := by ring
    apply one_div_le_one_div_of_le
    · simpa [mul_assoc] using hden2_pos
    · exact hden_le
  calc
    num / sink ≤ 1 / (cg * gap) := hq1
    _ ≤ 1 / ((gap * D) * Real.exp E) := hinv2
    _ = (1 / (gap * D)) * Real.exp (-E) := by
      rw [Real.exp_neg]
      field_simp [hgap_pos.ne', hD_pos.ne', (Real.exp_pos E).ne']

/-- The active-suffix start carries at least the write-start Hoff decay, up to
the fixed endpoint slack already used by the reset-tail estimate. -/
theorem paper3Headline_exp_neg_calpha_earlySubStart_succ_le_hoffRate
    (j : ℕ) :
    Real.exp (-(bgpParams38.cα *
        selectorMUEarlyWriteSubStart (j + 1))) ≤
      Real.exp (Real.pi / 16) * paper3HoffRate j := by
  have hα_nonneg : 0 ≤ bgpParams38.cα := by
    norm_num [bgpParams38]
  have hstart :
      selectorMUWriteStartTime (j + 1) ≤
        selectorMUEarlyWriteSubStart (j + 1) :=
    selectorMUWriteStart_le_earlySubStart (j + 1)
  have hprod :
      bgpParams38.cα * selectorMUWriteStartTime (j + 1) ≤
        bgpParams38.cα * selectorMUEarlyWriteSubStart (j + 1) :=
    mul_le_mul_of_nonneg_left hstart hα_nonneg
  have hdecay :
      Real.exp (-(bgpParams38.cα *
          selectorMUEarlyWriteSubStart (j + 1))) ≤
        Real.exp (-(bgpParams38.cα *
          selectorMUWriteStartTime (j + 1))) :=
    Real.exp_le_exp.mpr (neg_le_neg hprod)
  have hreset :=
    paper3Headline_resetTail_decay_le_hoffRate (j + 1)
  have hfactor_nonneg : 0 ≤ Real.exp (Real.pi / 16) := (Real.exp_pos _).le
  have hsucc :
      Real.exp (Real.pi / 16) * paper3HoffRate (j + 1) ≤
        Real.exp (Real.pi / 16) * paper3HoffRate j :=
    mul_le_mul_of_nonneg_left (paper3HoffRate_succ_le j) hfactor_nonneg
  exact le_trans hdecay (le_trans hreset hsucc)

/-- Scalar aggregation for the Hoff edge outlet.  Once each edge term has been
bounded by a constant multiple of the canonical Hoff rate, this lemma checks
that the constants fit inside the edge budget left after the middle cap. -/
theorem paper3HeadlineHoff_edges_terms_le_edgeBudget
    (j : ℕ)
    {readBudget leftBad recoveryGate postSelectNewLoser rightLate
      Cread Cleft C0 Cpre Crecovery Cpost Clate : ℝ}
    (hread : readBudget ≤ Cread * paper3HoffRate j)
    (hleft : leftBad ≤ Cleft * paper3HoffRate j)
    (hrec : recoveryGate ≤ Crecovery * paper3HoffRate j)
    (hpost : postSelectNewLoser ≤ Cpost * paper3HoffRate j)
    (hlate : rightLate ≤ Clate * paper3HoffRate j)
    (hconst :
      3 * Cread + 4 * Cleft + 8 + 2 * (C0 + Cpre) +
          2 * (Crecovery + Cpost + Clate) ≤ selectorMUHoffEdgeBudgetCoeff) :
    3 * readBudget + 4 * leftBad + selectorMUHoffMiddleEnvelopeFullCap j +
        2 * (C0 * paper3HoffRate j + Cpre * paper3HoffRate j) +
        2 * (recoveryGate + postSelectNewLoser + rightLate) ≤
      selectorMUHoffEdgeBudgetCoeff * paper3HoffRate j := by
  have hrate_nonneg : 0 ≤ paper3HoffRate j := (Real.exp_pos _).le
  have hmid :
      selectorMUHoffMiddleEnvelopeFullCap j ≤
        (8 : ℝ) * paper3HoffRate j := by
    exact paper3Headline_middleEnvelopeFullCap_le_eight_hoffRate j
  have hconst_scaled :
      (3 * Cread + 4 * Cleft + 8 + 2 * (C0 + Cpre) +
          2 * (Crecovery + Cpost + Clate)) * paper3HoffRate j ≤
        selectorMUHoffEdgeBudgetCoeff * paper3HoffRate j :=
    mul_le_mul_of_nonneg_right hconst hrate_nonneg
  nlinarith [hread, hleft, hrec, hpost, hlate, hmid, hconst_scaled]

/-! ### Hoff edge budget: decomposed analytic cores

The two half-budget obligations below (`endpoints` and `mixTargetVariation`)
are assembled from five sharply-scoped analytic cores plus fully proved glue
(halt-exactness bridge, z-transport through the off-phase middle window, and
scalar budget arithmetic).  Cores S1 and S3 are DISCHARGED by the
`paper3S13_*` singleton-safe machinery below (trivial/main `card⁴` case
split against the budget's `4000 + card⁴` coefficient); S2 is REDUCED to
the single post-copy new-tube core `paper3S2_interRead_new_tube` (see the
S2 block: at `zOffEnd` the mass sits on the NEW view — the u-channel copies
`z ≈ enc(cfg (j+1))` around `2πj + 3π/2` — so the bridge goes through
`1 − λ_new`, not `1 − λ_old`); S4a/S4b remain.

Quantitative frame (numerically verified; `j = 0` is always the binding
case): the budget is
`selectorMUHoffEdgeBudget3992 j = (4000 + card⁴ − 1/200) · exp(−200·(2πj+π))`.

* The QSS (quasi-steady-state) old/new-loser mass at time `t` on the edge
  windows is `≈ cr(t)·κ₀ / (card · cg(t) · gain(t) · gap)` with
  `gain = g₀·exp(300·t)`, hence decays at rate `exp(−300·t)`.  Anchors for
  the Duhamel window must be late enough that
  `300·anchor(j) > 200·(2πj + π)` already at `j = 0`: `2πj + 3π/4` works on
  the read side (`225π > 200π`), and any anchor in the last quarter of the
  middle window works at `zOffEnd` (`≥ 525π ≫ 200π`); note `cg·gain`
  vanishes at `2πj + 3π/2`, so the Duhamel window must not cross that dead
  zone.
* ROUTE CORRECTION (vs ChatGPT Q4071): bounds frozen at
  `writeStart j = 2πj + π/6` — the `epsLam` of
  `paper3HeadlineShiftedConcentrationAt` and hence `Bz_read` — are NOT
  sufficient: `300·(π/6) = 50π < 200π`, so they lose to the budget at
  `j = 0` by `≈ e^{470}`.  The read-time cores below must be produced by
  `selectorMU_old_new_badMass_duhamel_bound_of_initial_source_on_Icc` on a
  late window, not by the shifted concentration bundle.
* ROUTE CORRECTION (vs ChatGPT Q4071): the edge TV integrands are NOT
  term-wise loser-mass small — the reset inflow `cr·κ₀/card` alone
  integrates to a `j`-independent constant (`≈ 10⁻²⁵` on the left window,
  `≈ 10⁻¹` on the right window), far above the decaying budget.  The TV
  bound must use the net reset/gain cancellation (slaving): for each bad
  view `v`, `λ̇_v = R − D_v·λ_v` with `R = cr·κ₀/card` and
  `D_v = cr·κ₀ + cg·gain·(P̄ − P_v)`, so `|λ̇_v| = D_v·|λ_v − E_v|` with
  `E_v := R/D_v`, and the generic tracking engine
  `stack_write_tracking_total_variation_le` (applied with `y := λ_v`,
  `k := D_v`, `m := E_v`) yields
  `∫|λ̇_v| ≤ |λ_v(a) − E_v(a)| + ∫|E_v'|`, each term of which decays at
  rate `exp(−300·a)`.  The halt-centered form
  (`selectorMU_mixTargetDerivRHS_halt_eq_centered_lam_of_boxInputs` with
  `c := localViewU (cfg j)` plus `henc`) kills the old- and new-winner
  terms, leaving `|RHS| ≤ Σ_{bad v} |λ̇_v|` via
  `branchU_haltCoord_spread_le_one`.
-/

/-- The scalar Hoff edge budget is nonnegative. -/
theorem paper3HeadlineHoff_edgeBudget3992_nonneg (j : ℕ) :
    0 ≤ selectorMUHoffEdgeBudget3992 j := by
  unfold selectorMUHoffEdgeBudget3992 selectorMUHoffEdgeBudget
  exact mul_nonneg selectorMUHoffEdgeBudgetCoeff_nonneg (Real.exp_pos _).le

/-- The canonical middle cap consumes at most `1/32` of the scalar Hoff edge
budget (it is `≤ (1/200)·exp(−200·(2πj+π))` while the budget coefficient is
`≥ 4000 − 1/200`). -/
theorem paper3HeadlineHoff_middleFullCap_le_edgeBudget_div_32 (j : ℕ) :
    selectorMUHoffMiddleEnvelopeFullCap j ≤
      selectorMUHoffEdgeBudget3992 j / 32 := by
  have hcap := selectorMUHoffMiddleEnvelopeFullCap_le_one_div_200 j
  have hE : (0 : ℝ) ≤
      Real.exp (-((bgpParams38.cμ * (1 / 2 : ℝ) ^ bgpParams38.L - bgpParams38.cα) *
        (2 * Real.pi * (j : ℝ) + Real.pi))) := (Real.exp_pos _).le
  have hcoeff : (32 : ℝ) * (1 / 200) ≤ selectorMUHoffEdgeBudgetCoeff := by
    unfold selectorMUHoffEdgeBudgetCoeff
    linarith [selectorReplicatorHoldEnvelopeCoeff_ge_4000]
  have hscaled := mul_le_mul_of_nonneg_right hcoeff hE
  unfold selectorMUHoffEdgeBudget3992 selectorMUHoffEdgeBudget
  linarith

/-- Middle-envelope residual instance whose cap is the canonical full-interval
scalar cap `selectorMUHoffMiddleEnvelopeFullCap`. -/
def paper3HeadlineHoffMiddleFullCapResidual :
    SelectorMUHoffMiddleEnvelopeResidual where
  capMid := fun _ j => selectorMUHoffMiddleEnvelopeFullCap j
  henvInt := by
    intro w j t ht
    have henv_cont : Continuous selectorMUHoffMiddleEnvelope := by
      unfold selectorMUHoffMiddleEnvelope
      fun_prop
    have hI : ∀ x y : ℝ,
        IntervalIntegrable selectorMUHoffMiddleEnvelope MeasureTheory.volume x y :=
      fun x y => henv_cont.intervalIntegrable x y
    have htail :
        0 ≤ ∫ τ in t..(selectorMUZOffEnd j), selectorMUHoffMiddleEnvelope τ := by
      apply intervalIntegral.integral_nonneg ht.2
      intro τ _hτ
      unfold selectorMUHoffMiddleEnvelope
      have hA : (0 : ℝ) ≤ bgpParams38.A := by norm_num [bgpParams38]
      exact mul_nonneg hA (Real.exp_pos _).le
    have hadd := intervalIntegral.integral_add_adjacent_intervals
      (hI (selectorMUZOffStart j) t) (hI t (selectorMUZOffEnd j))
    unfold selectorMUHoffMiddleEnvelopeFullCap
    linarith

/-- Transport of the halt `z`-coordinate from the inter-read left endpoint to
the z-off end: the total drift is paid by the left edge field cap plus the
canonical off-phase middle cap (on the middle window `sin ≤ 0`, so the raw
z-gate is exponentially suppressed and `|mix − z| ≤ 1` suffices). -/
theorem paper3HeadlineHoff_edge_z_drift_read_to_zOffEnd
    (wg w j : ℕ) :
    |((paper3HeadlineSolFam wg) w).z (selectorMUZOffEnd j) haltCoordU -
        ((paper3HeadlineSolFam wg) w).z (selectorMUInterReadStart j) haltCoordU| ≤
      selectorMUHoffCapLeftField (paper3HeadlineSolFam wg) w j +
        selectorMUHoffMiddleEnvelopeFullCap j := by
  classical
  let sol := paper3HeadlineSolFam wg
  let a : ℝ := selectorMUInterReadStart j
  let b : ℝ := selectorMUZOffStart j
  let c : ℝ := selectorMUZOffEnd j
  let y : ℝ → ℝ := fun τ => (sol w).z τ haltCoordU
  let m : ℝ → ℝ := fun τ =>
    selectorMixTarget branchU (sol w).u (sol w).lam τ haltCoordU
  let k : ℝ → ℝ := fun τ => selectorMUHoffGateCoeff sol w τ
  have hab : a ≤ b := selectorMUInterReadStart_le_zOffStart j
  have hbc : b ≤ c := selectorMUZOffStart_le_zOffEnd j
  have hac : a ≤ c := le_trans hab hbc
  have ha0 : 0 ≤ a := by
    simp [a, selectorMUInterReadStart, selectorMUWriteReadTime]
    positivity
  have hk_cont : Continuous k := by
    simpa [k, selectorMUHoffGateCoeff] using
      selector_replicator_gateZ_integrand_continuous (sol w)
  have hm_cont : Continuous m := by
    simpa [m] using (sol w).cont_mixTarget haltCoordU
  have hy_cont : Continuous y := by
    simpa [y] using (sol w).cont_z haltCoordU
  have hy_ode : ∀ τ ∈ Set.uIcc a c,
      HasDerivAt y (k τ * (m τ - y τ)) τ := by
    intro τ hτ
    rw [Set.uIcc_of_le hac] at hτ
    have hτ0 : 0 ≤ τ := le_trans ha0 hτ.1
    simpa [y, m, k, selectorMUHoffGateCoeff] using
      (sol w).z_hasDeriv τ
        (selectorSchedule_domain_of_nonneg_structural τ hτ0) haltCoordU
  have hftc : (∫ τ in a..c, k τ * (m τ - y τ)) = y c - y a :=
    intervalIntegral.integral_eq_sub_of_hasDerivAt hy_ode
      ((hk_cont.mul (hm_cont.sub hy_cont)).intervalIntegrable a c)
  have hInt : ∀ x x' : ℝ, IntervalIntegrable
      (fun τ => selectorMUHoffIntegrand sol w τ) MeasureTheory.volume x x' :=
    fun x x' =>
      (selectorMUHoffIntegrand_continuous (sol := sol) w).intervalIntegrable x x'
  have habs_eq : ∀ τ : ℝ,
      |k τ * (m τ - y τ)| = selectorMUHoffIntegrand sol w τ := by
    intro τ
    simp [selectorMUHoffIntegrand, selectorMUHoffGateCoeff, k, m, y, mul_assoc]
  have habs : |y c - y a| ≤ ∫ τ in a..c, selectorMUHoffIntegrand sol w τ := by
    rw [← hftc]
    refine le_trans (intervalIntegral.abs_integral_le_integral_abs hac) ?_
    exact le_of_eq (intervalIntegral.integral_congr (fun τ _hτ => habs_eq τ))
  have hsplit :
      (∫ τ in a..c, selectorMUHoffIntegrand sol w τ) =
        (∫ τ in a..b, selectorMUHoffIntegrand sol w τ) +
          ∫ τ in b..c, selectorMUHoffIntegrand sol w τ :=
    (intervalIntegral.integral_add_adjacent_intervals (hInt a b) (hInt b c)).symm
  have hmid :
      (∫ τ in b..c, selectorMUHoffIntegrand sol w τ) ≤
        selectorMUHoffMiddleEnvelopeFullCap j := by
    have h := selectorMUHoff_middle_offphase_of_envelope
      (sol := sol) (paper3HeadlineBoxInputs wg)
      paper3HeadlineHoffMiddleFullCapResidual w j (selectorMUZOffEnd j)
      ⟨selectorMUZOffStart_le_zOffEnd j, le_rfl⟩
    simpa [b, c, paper3HeadlineHoffMiddleFullCapResidual] using h
  have hleft :
      (∫ τ in a..b, selectorMUHoffIntegrand sol w τ) =
        selectorMUHoffCapLeftField sol w j := rfl
  calc
    |((paper3HeadlineSolFam wg) w).z (selectorMUZOffEnd j) haltCoordU -
        ((paper3HeadlineSolFam wg) w).z (selectorMUInterReadStart j) haltCoordU|
        = |y c - y a| := rfl
    _ ≤ ∫ τ in a..c, selectorMUHoffIntegrand sol w τ := habs
    _ = (∫ τ in a..b, selectorMUHoffIntegrand sol w τ) +
          ∫ τ in b..c, selectorMUHoffIntegrand sol w τ := hsplit
    _ ≤ selectorMUHoffCapLeftField sol w j +
          selectorMUHoffMiddleEnvelopeFullCap j :=
        add_le_add (le_of_eq hleft) hmid
    _ = selectorMUHoffCapLeftField (paper3HeadlineSolFam wg) w j +
          selectorMUHoffMiddleEnvelopeFullCap j := rfl

/-! #### S1/S3 late-window loser-mass machinery.

Every estimate is against the Hoff rate `exp(-(200π(2j+1)))`, whose budget
coefficient is `4000 + card⁴` (`selectorReplicatorHoldEnvelopeCoeff`).  All
proofs split on `card⁴ ≤ 96·exp(200π(2j+1))`:

* in the *trivial* regime the coarse simplex/flag boxes (`≤ 1`) already fit,
  because the budget's `card⁴` prefactor alone pays three full rates;
* in the *main* regime `card ≤ 96^{1/4}·exp(50π(2j+1))`, so every
  `1/card`-degraded decay exponent still wins doubly-exponentially — NO
  absolute cardinality bound is ever needed (none is provable in this
  development: `Fintype.card UniversalLocalView` has no numeric upper bound).

The loser-mass engine is SINGLETON-safe (safe set `{oldView}`): the pair-safe
`hpair` against the NEW view is false mid-write-window (the new view is not
yet matched by the `u`-state), while the single-tube gap
`paper3Headline_pairwiseGap_of_single_tube` holds throughout
`[selectStart j, writeRead j]` from the write-window u-tube
(`paper3HeadlineFullUTubeResidual`, closed at the right endpoint by the
`hutube_tail` field).  Two Duhamel passes: pass 1 on
`[selectStart j, writeRead j]` at floor `1/card` brings the loser mass to
`1/4` from `2πj + 3π/4` on; pass 2 restarts at `2πj + 3π/4` with the improved
(card-free!) floor `3/4` and wins the budget from `2πj + 19π/24` on. -/

/-- Midpoint of the S1/S3 late window: `2πj + 19π/24`. -/
def paper3S13Mid (j : ℕ) : ℝ :=
  2 * Real.pi * (j : ℝ) + 19 * Real.pi / 24

/-- The gain-clock integrand of the headline family. -/
def paper3S13cgF (wg : ℕ) (t : ℝ) : ℝ :=
  ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
    (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * t))

/-- The reset integrand of the headline family. -/
def paper3S13crF (t : ℝ) : ℝ :=
  ((1 + Real.cos t) / 2) ^ paper3HeadlineM * ((paper3HeadlineKappa : ℚ) : ℝ)

theorem paper3S13cgF_continuous (wg : ℕ) :
    Continuous (paper3S13cgF wg) := by
  unfold paper3S13cgF
  fun_prop

theorem paper3S13crF_continuous : Continuous paper3S13crF := by
  unfold paper3S13crF
  fun_prop

theorem paper3S13cgF_nonneg (wg : ℕ) (t : ℝ) : 0 ≤ paper3S13cgF wg t := by
  unfold paper3S13cgF
  exact mul_nonneg
    (pow_nonneg (by nlinarith [Real.neg_one_le_sin t]) _)
    (mul_nonneg (paper3WarmGainQ_pos wg).le (Real.exp_pos _).le)

theorem paper3S13crF_nonneg (t : ℝ) : 0 ≤ paper3S13crF t := by
  unfold paper3S13crF
  exact mul_nonneg
    (pow_nonneg (by nlinarith [Real.neg_one_le_cos t]) _)
    (by norm_num [paper3HeadlineKappa])

theorem paper3S13crF_le_one (t : ℝ) : paper3S13crF t ≤ 1 := by
  unfold paper3S13crF
  have hbase0 : (0 : ℝ) ≤ (1 + Real.cos t) / 2 := by
    nlinarith [Real.neg_one_le_cos t]
  have hbase1 : (1 + Real.cos t) / 2 ≤ 1 := by
    nlinarith [Real.cos_le_one t]
  have hpow : ((1 + Real.cos t) / 2) ^ paper3HeadlineM ≤ 1 :=
    pow_le_one₀ hbase0 hbase1
  have hκ : ((paper3HeadlineKappa : ℚ) : ℝ) = 1 := by
    norm_num [paper3HeadlineKappa]
  rw [hκ, mul_one]
  exact hpow

