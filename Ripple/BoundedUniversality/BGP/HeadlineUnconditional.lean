stays within `B` of the frozen `u`. -/
theorem paper3NW_prewrite_zu_hold (w j : ℕ) {E B : ℝ}
    (hE : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z (selectorMUZOffEnd j) i -
        ((paper3HeadlineSolFamNW w) w).u (selectorMUZOffEnd j) i| ≤ E)
    (hB : ∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1)),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
          ((paper3HeadlineSolFamNW w) w).lam τ i -
        ((paper3HeadlineSolFamNW w) w).u τ i| ≤ B) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        ((paper3HeadlineSolFamNW w) w).u
          (selectorMUWriteStartTime (j + 1)) i| ≤ max E B := by
  intro i
  have hπ := Real.pi_pos
