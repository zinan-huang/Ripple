  have hr : (1 : ℝ) / 4 ≤ ((1 - Real.sin τ) / 2) ^ 1 := by
    rw [pow_one]
    linarith
  have hsW : (0 : ℝ) < (bgpScaleW w : ℝ) := bgpScaleWR_pos w
