/-- **Ledger row G closes**: the copy-entry radius through the landed
`233·S` copy-mass contraction fits in a quarter of the readout tube
(`D0 = Cu + 2·D_U = 4·D_U + 2` with the repo encoding hull). -/
theorem paper3S2_copy_D0_exp_neg_mass_le_quarter_NW (w j : ℕ) :
    (4 * D_U + 2) * Real.exp (-paper3S2CopyMassLowerNW w j) ≤
      r_LE_U / 4 := by
  have hπ3 := Real.pi_gt_three
  have hS := paper3NW4_S_ge w
  have hSpos : (0 : ℝ) < (bgpScaleW w : ℝ) := bgpScaleWR_pos w
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) := by
    have hπ := Real.pi_pos
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith
  have hD := paper3NW4_DU_le_exp w
  have hD0 := D_U_nonneg
  have hE1 : (1 : ℝ) ≤ Real.exp (bgpScaleW w : ℝ) := by
    have := Real.add_one_le_exp (bgpScaleW w : ℝ)
    linarith
  have h6 : (6 : ℝ) ≤ Real.exp (bgpScaleW w : ℝ) := by
    have hq := paper3NW4_sq_quarter_le_exp
      (by linarith : (0 : ℝ) ≤ (bgpScaleW w : ℝ))
    nlinarith [sq_nonneg ((bgpScaleW w : ℝ) - 5184)]
  -- D0 ≤ e^{2S}
  have hD0le : (4 * D_U + 2 : ℝ) ≤ Real.exp (2 * (bgpScaleW w : ℝ)) := by
    have h2 : Real.exp (2 * (bgpScaleW w : ℝ)) =
        Real.exp (bgpScaleW w : ℝ) * Real.exp (bgpScaleW w : ℝ) := by
      rw [← Real.exp_add]
      ring_nf
    rw [h2]
    nlinarith [hD, hE1, hD0, h6]
  -- copy mass ≥ 932·S + 1 ≥ 2·S + 200
  have hmass : 2 * (bgpScaleW w : ℝ) + 200 ≤ paper3S2CopyMassLowerNW w j := by
    unfold paper3S2CopyMassLowerNW
    have ha4 : (4 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3 := by
      nlinarith
    have hexp_arg : 932 * (bgpScaleW w : ℝ) ≤
        233 * (bgpScaleW w : ℝ) *
          (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3) := by
      nlinarith [mul_le_mul_of_nonneg_left ha4
        (by linarith : (0 : ℝ) ≤ 233 * (bgpScaleW w : ℝ))]
    have hexp_ge : 932 * (bgpScaleW w : ℝ) + 1 ≤
        Real.exp (233 * (bgpScaleW w : ℝ) *
          (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)) := by
      have h := Real.add_one_le_exp (233 * (bgpScaleW w : ℝ) *
        (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3))
      linarith
    have hπ1 : (1 : ℝ) ≤ Real.pi / 3 := by linarith
    have hexp_pos : (0 : ℝ) ≤ Real.exp (233 * (bgpScaleW w : ℝ) *
        (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)) := (Real.exp_pos _).le
    nlinarith [mul_le_mul_of_nonneg_right hπ1 hexp_pos]
  -- assemble: D0·e^{−M} ≤ e^{2S}·e^{−(2S+200)} = e^{−200} ≤ r/4
  have hexp_mass : Real.exp (-paper3S2CopyMassLowerNW w j) ≤
      Real.exp (-(2 * (bgpScaleW w : ℝ) + 200)) := by
    apply Real.exp_le_exp.mpr
    linarith
  have hprod : (4 * D_U + 2) * Real.exp (-paper3S2CopyMassLowerNW w j) ≤
      Real.exp (2 * (bgpScaleW w : ℝ)) *
        Real.exp (-(2 * (bgpScaleW w : ℝ) + 200)) := by
    apply mul_le_mul hD0le hexp_mass (Real.exp_pos _).le (Real.exp_pos _).le
  have hsum : Real.exp (2 * (bgpScaleW w : ℝ)) *
      Real.exp (-(2 * (bgpScaleW w : ℝ) + 200)) = Real.exp (-(200 : ℝ)) := by
    rw [← Real.exp_add]
    ring_nf
  have hfinal : Real.exp (-(200 : ℝ)) ≤ r_LE_U / 4 := by
    have hq := paper3NW4_sq_quarter_le_exp (by norm_num : (0 : ℝ) ≤ (200 : ℝ))
    have h10000 : (10000 : ℝ) ≤ Real.exp (200 : ℝ) := by nlinarith
    have hinv : Real.exp (-(200 : ℝ)) * Real.exp (200 : ℝ) = 1 := by
      rw [← Real.exp_add]
      norm_num
    have hx0 : (0 : ℝ) ≤ Real.exp (-(200 : ℝ)) := (Real.exp_pos _).le
    have hr : r_LE_U = 1 / 1000 := rfl
