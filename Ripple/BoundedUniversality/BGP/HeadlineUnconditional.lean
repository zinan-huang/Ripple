/-- Leg 6: the prewrite-tail slop. -/
theorem paper3NW4_leg_tail (wg : ℕ) (j : ℕ) :
    (4 * D_U + 3) *
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffEnd j)) /
      (200 * (bgpScaleW wg : ℝ)) ≤
