      ring
    have h4 : D_U * Real.exp (-((bgpScaleW wg : ℝ) + 3)) ≤
        Real.exp (-(3 : ℝ)) := by
      rw [← hcombine]
      exact hmul
    have hE_le : Real.exp (-((bgpScaleW wg : ℝ) + 3)) ≤
        Real.exp (-(3 : ℝ)) := by
