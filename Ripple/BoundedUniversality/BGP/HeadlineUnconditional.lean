theorem paper3S13_oldLoser_duhamel (wg w j : ℕ)
    {a b Lsafe Csrc : ℝ}
    (hab : a ≤ b) (ha0 : 0 ≤ a) (hLsafe0 : 0 < Lsafe) (hCsrc0 : 0 ≤ Csrc)
    (htube : ∀ t ∈ Icc a b,
      UTube r_LE_U (solMUReplStaticCfg w j)
        (((paper3HeadlineSolFam wg) w).u t))
    (hfloor : ∀ t ∈ Icc a b,
      Lsafe ≤ ((paper3HeadlineSolFam wg) w).lam
        (localViewU (solMUReplStaticCfg w j)) t)
    (hCsrc_ratio : ∀ s ∈ Icc a b, (1 : ℝ) ≤ Csrc * paper3S13cgF wg s) :
    ∀ t ∈ Icc a b,
      1 - ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w j)) t ≤
        (1 - ((paper3HeadlineSolFam wg) w).lam
            (localViewU (solMUReplStaticCfg w j)) a) *
            Real.exp
              (-((selectorReplicatorGapVal paper3HeadlineEta
                    paper3HeadlineEta_pos * Lsafe) *
                (((paper3HeadlineSolFam wg) w).G t -
                  ((paper3HeadlineSolFam wg) w).G a))) +
          Csrc / (selectorReplicatorGapVal paper3HeadlineEta
              paper3HeadlineEta_pos * Lsafe) := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  have hgap0 := paper3S13_gapVal_pos
  have hgapL0 : 0 < selectorReplicatorGapVal paper3HeadlineEta
      paper3HeadlineEta_pos * Lsafe := mul_pos hgap0 hLsafe0
  have hGder : ∀ t ∈ Ico a b,
      HasDerivWithinAt ((paper3HeadlineSolFam wg) w).G
        (paper3S13cgF wg t) (Ici t) t := by
    intro s hs
    have hs0 : 0 ≤ s := le_trans ha0 hs.1
    have h := ((paper3HeadlineSolFam wg) w).G_hasDeriv s
      (selectorSchedule_domain_of_nonneg_structural s hs0)
    exact (by simpa [paper3S13cgF] using h :
      HasDerivAt ((paper3HeadlineSolFam wg) w).G (paper3S13cgF wg s) s).hasDerivWithinAt
  have hBder : ∀ s ∈ Ico a b, ∃ dB : ℝ,
      HasDerivWithinAt
        (fun τ => 1 - ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w j)) τ) dB (Ici s) s ∧
        dB ≤ -(selectorReplicatorGapVal paper3HeadlineEta
            paper3HeadlineEta_pos * Lsafe) * paper3S13cgF wg s *
            (1 - ((paper3HeadlineSolFam wg) w).lam
              (localViewU (solMUReplStaticCfg w j)) s) +
          paper3S13crF s * 1 := by
    intro s hs
    have hs0 : 0 ≤ s := le_trans ha0 hs.1
    have hsIcc : s ∈ Icc a b := Ico_subset_Icc_self hs
    have hsum := paper3Headline_lam_sum_forward wg w s hs0
    have hnonneg := fun v => paper3Headline_lam_nonneg_forward wg w v s hs0
    have hode :
        HasDerivAt (((paper3HeadlineSolFam wg) w).lam
            (localViewU (solMUReplStaticCfg w j)))
          ((((1 + Real.cos s) / 2) ^ paper3HeadlineM *
              ((paper3HeadlineKappa : ℚ) : ℝ)) *
            (1 / (Fintype.card UniversalLocalView : ℝ) -
              ((paper3HeadlineSolFam wg) w).lam
                (localViewU (solMUReplStaticCfg w j)) s)
          + (((1 + Real.sin s) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQ wg : ℚ) : ℝ) *
                Real.exp (bgpParams38.cα * s))) *
            ((paper3HeadlineSolFam wg) w).lam
              (localViewU (solMUReplStaticCfg w j)) s *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos
                (localViewU (solMUReplStaticCfg w j))
                (((paper3HeadlineSolFam wg) w).u s)
                - ∑ u : UniversalLocalView,
                    ((paper3HeadlineSolFam wg) w).lam u s *
                      universalPval paper3HeadlineEta paper3HeadlineEta_pos u
                        (((paper3HeadlineSolFam wg) w).u s))) s := by
      simpa [selectorSchedule] using
        ((paper3HeadlineSolFam wg) w).lam_hasDeriv
          (localViewU (solMUReplStaticCfg w j)) s
          (by simpa [selectorSchedule] using hs0)
    refine ⟨_, ((hode).const_sub 1).hasDerivWithinAt, ?_⟩
    have havg := selector_replicator_havg_gap_of_utube
      (eta := paper3HeadlineEta) (heta := paper3HeadlineEta_pos)
      (lam := fun v => ((paper3HeadlineSolFam wg) w).lam v s)
      (u := ((paper3HeadlineSolFam wg) w).u s)
      (c := solMUReplStaticCfg w j)
      (gap := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
      paper3HeadlineHerr (htube s hsIcc) le_rfl hsum hnonneg
    have hlam1 := paper3S13_lam_le_one wg w j hs0
    have hlamL := hfloor s hsIcc
    have hcr0 := paper3S13crF_nonneg s
    have hcg0 := paper3S13cgF_nonneg wg s
    have hinv0 : (0 : ℝ) ≤ 1 / (Fintype.card UniversalLocalView : ℝ) := by
      positivity
    have hB0 : 0 ≤ 1 - ((paper3HeadlineSolFam wg) w).lam
        (localViewU (solMUReplStaticCfg w j)) s := by linarith
    have hgapB0 : 0 ≤ selectorReplicatorGapVal paper3HeadlineEta
        paper3HeadlineEta_pos *
        (1 - ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w j)) s) :=
      mul_nonneg hgap0.le hB0
    have hkey : Lsafe * (selectorReplicatorGapVal paper3HeadlineEta
        paper3HeadlineEta_pos *
        (1 - ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w j)) s)) ≤
        ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w j)) s *
        (universalPval paper3HeadlineEta paper3HeadlineEta_pos
            (localViewU (solMUReplStaticCfg w j))
            (((paper3HeadlineSolFam wg) w).u s)
          - ∑ u : UniversalLocalView,
              ((paper3HeadlineSolFam wg) w).lam u s *
                universalPval paper3HeadlineEta paper3HeadlineEta_pos u
                  (((paper3HeadlineSolFam wg) w).u s)) :=
      mul_le_mul hlamL havg hgapB0 (le_trans hLsafe0.le hlamL)
    have hkey' := mul_le_mul_of_nonneg_left hkey hcg0
    have hcrlam : (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        ((paper3HeadlineKappa : ℚ) : ℝ)) *
        ((paper3HeadlineSolFam wg) w).lam
          (localViewU (solMUReplStaticCfg w j)) s ≤ paper3S13crF s := by
      have := mul_le_mul_of_nonneg_left hlam1
        (paper3S13crF_nonneg s)
      simpa [paper3S13crF] using this
    have hcrinv : 0 ≤ (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        ((paper3HeadlineKappa : ℚ) : ℝ)) *
        (1 / (Fintype.card UniversalLocalView : ℝ)) := by
      have : 0 ≤ (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
          ((paper3HeadlineKappa : ℚ) : ℝ)) := by
        simpa [paper3S13crF] using paper3S13crF_nonneg s
