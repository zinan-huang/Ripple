      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1EtaN wg w) j i) := by
  obtain ⟨Csrc, _, _, _, hsrc_all, _, _⟩ :=
    paper3F1_src_geo_and_budget_N wg w hsrcgeo hW0q hmixbox
