        constructor
        · have h := le_trans (selectorMUWriteStart_le_selectStart j) hs.1
          simpa [selectorMUWriteStartTime] using h
        · simpa [selectorMUWriteHoldTime] using hs.2
      have hsin : (1 : ℝ) / 2 ≤ Real.sin s :=
        sin_ge_half_of_gate_window j hgate
      have hpow : (3 / 4 : ℝ) ^ paper3HeadlineM ≤
          ((1 + Real.sin s) / 2) ^ paper3HeadlineM := by
        apply pow_le_pow_left₀ (by norm_num)
        linarith
      have hcα : 0 ≤ (bgpParamsNW wg).cα := by
        rw [bgpParamsNW_cα_def]
        have := bgpScaleWR_pos wg
        nlinarith
      have hexp : Real.exp ((bgpParamsNW wg).cα *
          selectorMUSelectStartTime j) ≤
          Real.exp ((bgpParamsNW wg).cα * s) := by
        apply Real.exp_le_exp.mpr
        exact mul_le_mul_of_nonneg_left hs.1 hcα
      have hw0 := paper3WarmGainQNW_nonneg_real wg
      unfold paper3NW4cg
      have hE0 := (Real.exp_pos ((bgpParamsNW wg).cα *
        selectorMUSelectStartTime j)).le
      have hP0 : (0 : ℝ) ≤ (3 / 4 : ℝ) ^ paper3HeadlineM := by positivity
      calc (3 / 4 : ℝ) ^ paper3HeadlineM *
            (((paper3WarmGainQNW wg : ℚ) : ℝ) *
              Real.exp ((bgpParamsNW wg).cα * selectorMUSelectStartTime j))
          ≤ (3 / 4 : ℝ) ^ paper3HeadlineM *
            (((paper3WarmGainQNW wg : ℚ) : ℝ) *
