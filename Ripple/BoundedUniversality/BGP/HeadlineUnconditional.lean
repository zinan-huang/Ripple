      Real.exp (-(2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
        ((bgpScaleW wg : ℝ) + 3))) := by
    apply Real.exp_le_exp.mpr
    linarith
  have hsplit : Real.exp (-(2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
      ((bgpScaleW wg : ℝ) + 3))) =
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
      Real.exp (-((bgpScaleW wg : ℝ) + 3)) := by
    rw [← Real.exp_add, ← Real.exp_add]
    congr 1
    ring
  have hconst : (4 * D_U + 3) * Real.exp (-((bgpScaleW wg : ℝ) + 3)) ≤ 1 := by
    have hmul : D_U * Real.exp (-((bgpScaleW wg : ℝ) + 3)) ≤
        Real.exp (bgpScaleW wg : ℝ) *
          Real.exp (-((bgpScaleW wg : ℝ) + 3)) :=
