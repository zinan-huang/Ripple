        selectorMUWriteReadTime j - selectorMUWriteHoldTime j = Real.pi / 3 := by
      unfold selectorMUWriteReadTime selectorMUWriteHoldTime
      ring
    calc
      t - selectorMUWriteHoldTime j
          ≤ selectorMUWriteReadTime j - selectorMUWriteHoldTime j :=
