      _ ≤ (B_U : ℝ) ^
            ((((MachineInstance.inputLenU 1 w + 30 : ℕ) : ℤ)) : ℝ) :=
          Real.rpow_le_rpow_of_exponent_le (by norm_num [B_U])
            (by exact_mod_cast hd)
      _ = (6 : ℝ) ^ (MachineInstance.inputLenU 1 w + 30) := by
          rw [show ((((MachineInstance.inputLenU 1 w + 30 : ℕ) : ℤ)) : ℝ) =
              ((MachineInstance.inputLenU 1 w + 30 : ℕ) : ℝ) by push_cast; ring,
