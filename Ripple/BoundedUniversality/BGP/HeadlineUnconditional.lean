  have h6 : (400 : ℝ) ≤ Real.exp 3 * Real.exp 3 := by nlinarith
  have h9 : (8000 : ℝ) ≤ Real.exp 3 * Real.exp 3 * Real.exp 3 := by nlinarith
  have h12 : (160000 : ℝ) ≤
      Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 := by nlinarith
  have h15 : (3200000 : ℝ) ≤
      Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 := by
    nlinarith
  have hsplit : Real.exp (15 : ℝ) =
      Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 := by
    rw [show (15 : ℝ) = 3 + 3 + 3 + 3 + 3 by norm_num,
      Real.exp_add, Real.exp_add, Real.exp_add, Real.exp_add]
  have hpow : (2 : ℝ) ^ (paper3HeadlineM + 1) = 2097152 := by
    norm_num [paper3HeadlineM]
  rw [hpow, hsplit]
  linarith

