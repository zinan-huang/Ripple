  selectorReplicatorSphereInitQ_presented_of_x0_presented_warm
    (d := d_U) (x₀ := selectorInitX0) (warmGainQ := paper3WarmGainQ)
    UniversalLocalView selectorInitX0_presented paper3WarmGainQ_presented

