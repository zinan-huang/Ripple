/-! ## The F1-NW (4/5) campaign toolbox (one-cycle Leg B+C at NW rates)

Everything below is new material for `paper3F1_src_geo_quantitative_NW`
(the statement and design docstring live at the F1-N layer, mid-file).
Search "F1-NW (4/5) PROVED" for the final theorem. -/

/-! ## NEW: (4/5)-NW toolbox, part A — kernels, masses, drift, trapping -/

/-! ### Abbreviations

Throughout this layer `S w := (bgpScaleW w : ℝ)` and the two channel
kernels of the word-coupled family are

`kU τ = A·α(τ)·bGateU(L, μ(τ), τ) = e^{S·τ·(−200 − 500·sin τ)}`,
`kZ τ = A·α(τ)·bGateZ(L, μ(τ), τ) = e^{S·τ·(500·sin τ − 200)}`

(for `τ ≥ 0`, using the closed forms of `α`/`μ` and `L = 1`). -/

/-- Closed exponential form of the word-coupled u-kernel. -/
theorem paper3NW4_uKernel_eq (wg w : ℕ) {τ : ℝ} (h0 : 0 ≤ τ) :
    (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ =
      Real.exp ((bgpScaleW wg : ℝ) * τ * (-200 - 500 * Real.sin τ)) := by
  have hα := paper3HeadlineSolFamNW_alpha wg w h0
  have hμ := paper3HeadlineSolFamNW_mu wg w h0
  rw [hα, hμ]
  simp only [bgpParamsNW_A_eq, one_mul, bgpParamsNW_L_eq]
  unfold bGateU qPulse
  rw [← Real.exp_add]
  congr 1
  rw [bgpParamsNW_cα_def, bgpParamsNW_cμ_def]
  ring

/-- Closed exponential form of the word-coupled z-kernel. -/
theorem paper3NW4_zKernel_eq (wg w : ℕ) {τ : ℝ} (h0 : 0 ≤ τ) :
    (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ =
      Real.exp ((bgpScaleW wg : ℝ) * τ * (500 * Real.sin τ - 200)) := by
  have hα := paper3HeadlineSolFamNW_alpha wg w h0
  have hμ := paper3HeadlineSolFamNW_mu wg w h0
  rw [hα, hμ]
  simp only [bgpParamsNW_A_eq, one_mul, bgpParamsNW_L_eq]
  unfold bGateZ rPulse
  rw [← Real.exp_add]
  congr 1
  rw [bgpParamsNW_cα_def, bgpParamsNW_cμ_def]
  ring

/-- u-kernel upper bound wherever `sin ≥ 0`: `kU ≤ e^{−200·S·τ}`. -/
theorem paper3NW4_uKernel_le_of_sin_nonneg (wg w : ℕ) {τ : ℝ}
    (h0 : 0 ≤ τ) (hsin : 0 ≤ Real.sin τ) :
    (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ ≤
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by
  rw [paper3NW4_uKernel_eq wg w h0]
  apply Real.exp_le_exp.mpr
  have hS := bgpScaleWR_pos wg
  nlinarith [mul_nonneg (mul_nonneg hS.le h0) hsin]

/-- z-kernel upper bound wherever `sin ≤ 0`: `kZ ≤ e^{−200·S·τ}`. -/
theorem paper3NW4_zKernel_le_of_sin_nonpos (wg w : ℕ) {τ : ℝ}
    (h0 : 0 ≤ τ) (hsin : Real.sin τ ≤ 0) :
    (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ ≤
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by
  rw [paper3NW4_zKernel_eq wg w h0]
  apply Real.exp_le_exp.mpr
  have hS := bgpScaleWR_pos wg
  nlinarith [mul_nonneg (mul_nonneg hS.le h0) (neg_nonneg.mpr hsin)]

/-- z-kernel lower bound wherever `sin ≥ 1/2`: `e^{50·S·τ} ≤ kZ`. -/
theorem paper3NW4_zKernel_ge_of_sin_ge_half (wg w : ℕ) {τ : ℝ}
    (h0 : 0 ≤ τ) (hsin : (1 : ℝ) / 2 ≤ Real.sin τ) :
    Real.exp (50 * (bgpScaleW wg : ℝ) * τ) ≤
      (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
  rw [paper3NW4_zKernel_eq wg w h0]
  apply Real.exp_le_exp.mpr
  have hS := bgpScaleWR_pos wg
  nlinarith [mul_nonneg (mul_nonneg hS.le h0) (by linarith : (0 : ℝ) ≤ Real.sin τ - 1/2)]

/-- u-kernel lower bound wherever `sin ≤ −1/2`: `e^{50·S·τ} ≤ kU`. -/
theorem paper3NW4_uKernel_ge_of_sin_le_neg_half (wg w : ℕ) {τ : ℝ}
    (h0 : 0 ≤ τ) (hsin : Real.sin τ ≤ -(1 / 2 : ℝ)) :
    Real.exp (50 * (bgpScaleW wg : ℝ) * τ) ≤
      (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
  rw [paper3NW4_uKernel_eq wg w h0]
  apply Real.exp_le_exp.mpr
  have hS := bgpScaleWR_pos wg
  nlinarith [mul_nonneg (mul_nonneg hS.le h0) (by linarith : (0 : ℝ) ≤ -(1/2 : ℝ) - Real.sin τ)]

/-- Nonnegativity of the u-kernel (any `τ ≥ 0`). -/
theorem paper3NW4_uKernel_nonneg (wg w : ℕ) {τ : ℝ} (h0 : 0 ≤ τ) :
    0 ≤ (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
  rw [paper3NW4_uKernel_eq wg w h0]
  exact (Real.exp_pos _).le

/-- Nonnegativity of the z-kernel (any `τ ≥ 0`). -/
theorem paper3NW4_zKernel_nonneg (wg w : ℕ) {τ : ℝ} (h0 : 0 ≤ τ) :
    0 ≤ (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
  rw [paper3NW4_zKernel_eq wg w h0]
  exact (Real.exp_pos _).le

/-- Continuity of the u-kernel. -/
theorem paper3NW4_uKernel_continuous (wg w : ℕ) :
    Continuous fun τ : ℝ =>
      (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
  have hgate : Continuous fun τ : ℝ =>
      bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
    unfold bGateU
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamNW wg) w).cont_μ.mul
        (qPulse_continuous (bgpParamsNW wg).L)).neg)
  simpa [mul_assoc] using
    (continuous_const.mul ((paper3HeadlineSolFamNW wg) w).cont_α).mul hgate

/-- Continuity of the z-kernel. -/
theorem paper3NW4_zKernel_continuous (wg w : ℕ) :
    Continuous fun τ : ℝ =>
      (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ :=
  selector_replicator_gateZ_integrand_continuous ((paper3HeadlineSolFamNW wg) w)

/-- Shifted decaying-exponential mass bound:
`∫_a^b e^{−c·τ} dτ ≤ e^{−c·a}/c` for `0 < c`, `a ≤ b`. -/
theorem paper3NW4_exp_mass_le {c a b : ℝ} (hc : 0 < c) (hab : a ≤ b) :
    (∫ τ in a..b, Real.exp (-(c * τ))) ≤ Real.exp (-(c * a)) / c := by
  have hderiv : ∀ τ ∈ Set.uIcc a b,
      HasDerivAt (fun τ => -Real.exp (-(c * τ)) / c) (Real.exp (-(c * τ))) τ := by
    intro τ _
    have h1 : HasDerivAt (fun τ : ℝ => -(c * τ)) (-c) τ := by
      simpa using ((hasDerivAt_id τ).const_mul c).neg
    have h2 := (Real.hasDerivAt_exp (-(c * τ))).comp τ h1
    have h3 := h2.neg.div_const c
    convert h3 using 1
    field_simp
  have hint : (∫ τ in a..b, Real.exp (-(c * τ))) =
      (-Real.exp (-(c * b)) / c) - (-Real.exp (-(c * a)) / c) := by
    apply intervalIntegral.integral_eq_sub_of_hasDerivAt hderiv
    exact (Real.continuous_exp.comp
      (continuous_const.mul continuous_id).neg).intervalIntegrable a b
  rw [hint]
  have hb : 0 < Real.exp (-(c * b)) := Real.exp_pos _
  have h3 : -Real.exp (-(c * b)) / c ≤ 0 :=
    div_nonpos_of_nonpos_of_nonneg (by linarith) hc.le
  have h4 : -(-Real.exp (-(c * a)) / c) = Real.exp (-(c * a)) / c := by ring
  linarith

/-- One-sided u-freeze (Grönwall form): on `[a, b]` with `sin ≥ 0`
throughout and a `|z − u|` box `Bzu`, the `u` drift from `a` is at most
`Bzu·e^{−200·S·a}/(200·S)`. -/
theorem paper3NW4_u_drift_of_sin_nonneg (wg w : ℕ) (i : Fin d_U)
    {a b : ℝ} {Bzu : ℝ} (hBzu0 : 0 ≤ Bzu) (ha : 0 ≤ a)
    (hsin : ∀ τ ∈ Icc a b, 0 ≤ Real.sin τ)
    (hzu : ∀ τ ∈ Icc a b, ∀ i' : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).z τ i' -
        ((paper3HeadlineSolFamNW wg) w).u τ i'| ≤ Bzu) :
    ∀ t ∈ Icc a b,
      |((paper3HeadlineSolFamNW wg) w).u t i -
        ((paper3HeadlineSolFamNW wg) w).u a i| ≤
      Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
        (200 * (bgpScaleW wg : ℝ)) := by
  intro t ht
  have hS : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hc : (0 : ℝ) < 200 * (bgpScaleW wg : ℝ) := by nlinarith
  have hat : a ≤ t := ht.1
  have hgc : Continuous fun τ : ℝ =>
      (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        (((paper3HeadlineSolFamNW wg) w).z τ i -
          ((paper3HeadlineSolFamNW wg) w).u τ i) :=
    (paper3NW4_uKernel_continuous wg w).mul
      ((((paper3HeadlineSolFamNW wg) w).cont_z i).sub
        (((paper3HeadlineSolFamNW wg) w).cont_u i))
  have hy : ∀ τ ∈ Icc a t,
      HasDerivAt (fun s => ((paper3HeadlineSolFamNW wg) w).u s i)
        ((bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
            bGateU (bgpParamsNW wg).L
              (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
          (((paper3HeadlineSolFamNW wg) w).z τ i -
            ((paper3HeadlineSolFamNW wg) w).u τ i)) τ :=
    fun τ hτ => ((paper3HeadlineSolFamNW wg) w).u_hasDeriv τ
      (selectorSchedule_domain_of_nonneg_structural τ (le_trans ha hτ.1)) i
  have hhold := hold_bound_integral
    (fun s => ((paper3HeadlineSolFamNW wg) w).u s i)
    (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
      (((paper3HeadlineSolFamNW wg) w).z τ i -
        ((paper3HeadlineSolFamNW wg) w).u τ i))
    a t hat hgc hy
  have hpt : ∀ τ ∈ Icc a t,
      |(bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        (((paper3HeadlineSolFamNW wg) w).z τ i -
          ((paper3HeadlineSolFamNW wg) w).u τ i)| ≤
      Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans ha hτ.1
    have hτIcc : τ ∈ Icc a b := ⟨hτ.1, le_trans hτ.2 ht.2⟩
    have hker_nonneg := paper3NW4_uKernel_nonneg wg w hτ0
    rw [abs_mul, abs_of_nonneg hker_nonneg]
    calc (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        |((paper3HeadlineSolFamNW wg) w).z τ i -
          ((paper3HeadlineSolFamNW wg) w).u τ i|
        ≤ Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) * Bzu :=
          mul_le_mul
            (paper3NW4_uKernel_le_of_sin_nonneg wg w hτ0 (hsin τ hτIcc))
            (hzu τ hτIcc i) (abs_nonneg _) (Real.exp_pos _).le
      _ = Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by ring
  have hEnvCont : Continuous fun τ : ℝ =>
      Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) :=
    continuous_const.mul
      (Real.continuous_exp.comp (continuous_const.mul continuous_id).neg)
  have hmono := intervalIntegral.integral_mono_on hat
    (hgc.abs.intervalIntegrable (μ := MeasureTheory.volume) a t)
    (hEnvCont.intervalIntegrable (μ := MeasureTheory.volume) a t) hpt
  have hmass : (∫ τ in a..t,
      Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ))) ≤
      Bzu * (Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
        (200 * (bgpScaleW wg : ℝ))) := by
    rw [intervalIntegral.integral_const_mul]
    exact mul_le_mul_of_nonneg_left (paper3NW4_exp_mass_le hc hat) hBzu0
  calc |((paper3HeadlineSolFamNW wg) w).u t i -
        ((paper3HeadlineSolFamNW wg) w).u a i|
      ≤ ∫ τ in a..t,
          |(bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
              bGateU (bgpParamsNW wg).L
                (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
            (((paper3HeadlineSolFamNW wg) w).z τ i -
              ((paper3HeadlineSolFamNW wg) w).u τ i)| := hhold
    _ ≤ ∫ τ in a..t,
          Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := hmono
    _ ≤ Bzu * Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
        (200 * (bgpScaleW wg : ℝ)) := by
        rw [mul_div_assoc]
        exact hmass

/-- z-freeze twin: on `[a, b]` with `sin ≤ 0` throughout and a
`|mix − z|` box `Bmz`, the `z` drift from `a` is at most
`Bmz·e^{−200·S·a}/(200·S)`. -/
theorem paper3NW4_z_drift_of_sin_nonpos (wg w : ℕ) (i : Fin d_U)
    {a b : ℝ} {Bmz : ℝ} (hBmz0 : 0 ≤ Bmz) (ha : 0 ≤ a)
    (hsin : ∀ τ ∈ Icc a b, Real.sin τ ≤ 0)
    (hmz : ∀ τ ∈ Icc a b,
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam τ i -
        ((paper3HeadlineSolFamNW wg) w).z τ i| ≤ Bmz) :
    ∀ t ∈ Icc a b,
      |((paper3HeadlineSolFamNW wg) w).z t i -
        ((paper3HeadlineSolFamNW wg) w).z a i| ≤
      Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
        (200 * (bgpScaleW wg : ℝ)) := by
  intro t ht
  have hS : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hc : (0 : ℝ) < 200 * (bgpScaleW wg : ℝ) := by nlinarith
  have hat : a ≤ t := ht.1
  have hgc : Continuous fun τ : ℝ =>
      (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        (selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
            ((paper3HeadlineSolFamNW wg) w).lam τ i -
          ((paper3HeadlineSolFamNW wg) w).z τ i) :=
    (paper3NW4_zKernel_continuous wg w).mul
      ((((paper3HeadlineSolFamNW wg) w).cont_mixTarget i).sub
        (((paper3HeadlineSolFamNW wg) w).cont_z i))
  have hy : ∀ τ ∈ Icc a t,
      HasDerivAt (fun s => ((paper3HeadlineSolFamNW wg) w).z s i)
        ((bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
            bGateZ (bgpParamsNW wg).L
              (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
          (selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
              ((paper3HeadlineSolFamNW wg) w).lam τ i -
            ((paper3HeadlineSolFamNW wg) w).z τ i)) τ :=
    fun τ hτ => ((paper3HeadlineSolFamNW wg) w).z_hasDeriv τ
      (selectorSchedule_domain_of_nonneg_structural τ (le_trans ha hτ.1)) i
  have hhold := hold_bound_integral
    (fun s => ((paper3HeadlineSolFamNW wg) w).z s i)
    (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
      (selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam τ i -
        ((paper3HeadlineSolFamNW wg) w).z τ i))
    a t hat hgc hy
  have hpt : ∀ τ ∈ Icc a t,
      |(bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        (selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
            ((paper3HeadlineSolFamNW wg) w).lam τ i -
          ((paper3HeadlineSolFamNW wg) w).z τ i)| ≤
      Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans ha hτ.1
    have hτIcc : τ ∈ Icc a b := ⟨hτ.1, le_trans hτ.2 ht.2⟩
    have hker_nonneg := paper3NW4_zKernel_nonneg wg w hτ0
    rw [abs_mul, abs_of_nonneg hker_nonneg]
    calc (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
        |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
            ((paper3HeadlineSolFamNW wg) w).lam τ i -
          ((paper3HeadlineSolFamNW wg) w).z τ i|
        ≤ Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) * Bmz :=
          mul_le_mul
            (paper3NW4_zKernel_le_of_sin_nonpos wg w hτ0 (hsin τ hτIcc))
            (hmz τ hτIcc) (abs_nonneg _) (Real.exp_pos _).le
      _ = Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := by ring
  have hEnvCont : Continuous fun τ : ℝ =>
      Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) :=
    continuous_const.mul
      (Real.continuous_exp.comp (continuous_const.mul continuous_id).neg)
  have hmono := intervalIntegral.integral_mono_on hat
    (hgc.abs.intervalIntegrable (μ := MeasureTheory.volume) a t)
    (hEnvCont.intervalIntegrable (μ := MeasureTheory.volume) a t) hpt
  have hmass : (∫ τ in a..t,
      Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ))) ≤
      Bmz * (Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
        (200 * (bgpScaleW wg : ℝ))) := by
    rw [intervalIntegral.integral_const_mul]
    exact mul_le_mul_of_nonneg_left (paper3NW4_exp_mass_le hc hat) hBmz0
  calc |((paper3HeadlineSolFamNW wg) w).z t i -
        ((paper3HeadlineSolFamNW wg) w).z a i|
      ≤ ∫ τ in a..t,
          |(bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
              bGateZ (bgpParamsNW wg).L
                (((paper3HeadlineSolFamNW wg) w).μ τ) τ *
            (selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
                ((paper3HeadlineSolFamNW wg) w).lam τ i -
              ((paper3HeadlineSolFamNW wg) w).z τ i)| := hhold
    _ ≤ ∫ τ in a..t,
          Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) * τ)) := hmono
    _ ≤ Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
        (200 * (bgpScaleW wg : ℝ)) := by
        rw [mul_div_assoc]
        exact hmass


/-- S2-NW handoff, z side (v1: mix concentration on piece 1 and the crude
`|mix − z|` box on piece 2 are hypotheses).  Piece 1 `[2πj+5π/6, 2πj+π]`:
`sin ≥ 0` keeps the mix target `M₁`-close to `E`, so `z` is trapped in the
`δs + M₁` tube (rate-independent trapping — no z-mass lower bound needed).
Piece 2 `[2πj+π, 2πj+7π/6]`: `sin ≤ 0` freezes the z-gate; total variation
at most `Bmz·e^{−200·S·(2πj+π)}/(200·S)`. -/
theorem paper3NW_S2_handoff_z (wg w j : ℕ) (i : Fin d_U)
    {E δs M1 Bmz : ℝ}
    (hδs0 : 0 ≤ δs) (hM10 : 0 ≤ M1) (hBmz0 : 0 ≤ Bmz)
    (hz_b : |((paper3HeadlineSolFamNW wg) w).z
        (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i - E| ≤ δs)
    (hmix1 : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
        (2 * Real.pi * (j : ℝ) + Real.pi),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam t i - E| ≤ M1)
    (hmz2 : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + Real.pi)
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam t i -
        ((paper3HeadlineSolFamNW wg) w).z t i| ≤ Bmz) :
    |((paper3HeadlineSolFamNW wg) w).z
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i - E| ≤
      δs + M1 + Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) *
          (2 * Real.pi * (j : ℝ) + Real.pi))) / (200 * (bgpScaleW wg : ℝ)) := by
  have hπ := Real.pi_pos
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) := by positivity
  have hb0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6 := by linarith
  have hT0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + Real.pi := by linarith
  have hbT : 2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6 ≤
      2 * Real.pi * (j : ℝ) + Real.pi := by linarith
  have hTa : 2 * Real.pi * (j : ℝ) + Real.pi ≤
      2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 := by linarith
  have hpiece1 : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
      (2 * Real.pi * (j : ℝ) + Real.pi),
      |((paper3HeadlineSolFamNW wg) w).z t i - E| ≤ δs + M1 := by
    apply relax_abs_trap
      (fun τ => ((paper3HeadlineSolFamNW wg) w).z τ i)
      (fun τ => selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
        ((paper3HeadlineSolFamNW wg) w).lam τ i)
      (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ)
      hbT
      (paper3NW4_zKernel_continuous wg w)
      (((paper3HeadlineSolFamNW wg) w).cont_mixTarget i)
      (fun t ht => ((paper3HeadlineSolFamNW wg) w).z_hasDeriv t
        (selectorSchedule_domain_of_nonneg_structural t (le_trans hb0 ht.1)) i)
      (fun t ht => paper3NW4_zKernel_nonneg wg w (le_trans hb0 ht.1))
      (le_trans hz_b (by linarith))
      (fun t ht => le_trans (hmix1 t ht) (by linarith))
  have hpiece2 := paper3NW4_z_drift_of_sin_nonpos wg w i
    (a := 2 * Real.pi * (j : ℝ) + Real.pi)
    (b := 2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
    hBmz0 hT0
    (fun τ hτ => sin_nonpos_on_handoff_piece2 j hτ.1 hτ.2)
    hmz2
    (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) ⟨hTa, le_refl _⟩
  have hzT := hpiece1 (2 * Real.pi * (j : ℝ) + Real.pi) ⟨hbT, le_refl _⟩
  calc |((paper3HeadlineSolFamNW wg) w).z
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i - E|
      ≤ |((paper3HeadlineSolFamNW wg) w).z
            (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6) i -
          ((paper3HeadlineSolFamNW wg) w).z
            (2 * Real.pi * (j : ℝ) + Real.pi) i| +
        |((paper3HeadlineSolFamNW wg) w).z
            (2 * Real.pi * (j : ℝ) + Real.pi) i - E| := abs_sub_le _ _ _
    _ ≤ Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) *
          (2 * Real.pi * (j : ℝ) + Real.pi))) / (200 * (bgpScaleW wg : ℝ)) +
        (δs + M1) := add_le_add hpiece2 hzT
    _ = δs + M1 + Bmz * Real.exp (-(200 * (bgpScaleW wg : ℝ) *
          (2 * Real.pi * (j : ℝ) + Real.pi))) / (200 * (bgpScaleW wg : ℝ)) := by
        ring

/-- S2-NW handoff, u side: the guard box survives the whole handoff window
`[2πj+5π/6, 2πj+7π/6]` by forward invariance — the u-gate opening near the
right endpoint is harmless because its target `z` stays in the (smaller)
box.  Never bound `∫ kU` on this window. -/
theorem paper3NW_S2_handoff_u_box (wg w j : ℕ) (i : Fin d_U)
    {Cz Cu : ℝ} (hCzCu : Cz ≤ Cu)
    (hu_b : |((paper3HeadlineSolFamNW wg) w).u
        (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i| ≤ Cu)
    (hz_box : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6),
      |((paper3HeadlineSolFamNW wg) w).z t i| ≤ Cz) :
    ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6)
        (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6),
      |((paper3HeadlineSolFamNW wg) w).u t i| ≤ Cu := by
  have hπ := Real.pi_pos
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) := by positivity
  have hb0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6 := by linarith
  have hba : 2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6 ≤
      2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 := by linarith
  have hbox := relaxation_box_invariant
    (fun τ => ((paper3HeadlineSolFamNW wg) w).u τ i)
    (fun τ => ((paper3HeadlineSolFamNW wg) w).z τ i)
    (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
      bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ)
    (lo := -Cu) (hi := Cu) hba
    (paper3NW4_uKernel_continuous wg w)
    (((paper3HeadlineSolFamNW wg) w).cont_z i)
    (fun t ht => ((paper3HeadlineSolFamNW wg) w).u_hasDeriv t
      (selectorSchedule_domain_of_nonneg_structural t (le_trans hb0 ht.1)) i)
    (fun t ht => paper3NW4_uKernel_nonneg wg w (le_trans hb0 ht.1))
    (fun t ht => by
      have hz := hz_box t ht
      rw [abs_le] at hz
      exact ⟨by linarith [hz.1], by linarith [hz.2]⟩)
    (by
      rw [abs_le] at hu_b
      exact ⟨by linarith [hu_b.1], by linarith [hu_b.2]⟩)
  intro t ht
  have hu := hbox t ht
  rw [abs_le]
  exact ⟨by linarith [hu.1], by linarith [hu.2]⟩

/-- S4 edge tube by entry slack + suppressed drift (`sin ≥ 0` on the edge):
the u-state enters `drift`-inside the tube and drifts at most `drift`, so it
stays in the radius-`r_LE_U` tube.  The drift budget is the exact suppressed
u-gate mass `Cwin·e^{−200·S·a}/(200·S)`. -/
theorem paper3S4_edge_utubeNW (wg w : ℕ) (c : UConf)
    {a b Cwin : ℝ} (_hab : a ≤ b) (ha0 : 0 ≤ a) (hCwin0 : 0 ≤ Cwin)
    (hsin : ∀ τ ∈ Icc a b, 0 ≤ Real.sin τ)
    (hzu : ∀ τ ∈ Icc a b, ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).z τ i -
        ((paper3HeadlineSolFamNW wg) w).u τ i| ≤ Cwin)
    (hstart : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).u a i - (confEncU c i : ℝ)| ≤
        r_LE_U - Cwin * Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
          (200 * (bgpScaleW wg : ℝ))) :
    ∀ τ ∈ Icc a b, UTube r_LE_U c (((paper3HeadlineSolFamNW wg) w).u τ) := by
  intro τ hτ i
  have hdrift := paper3NW4_u_drift_of_sin_nonneg wg w i hCwin0 ha0 hsin hzu τ hτ
  calc |((paper3HeadlineSolFamNW wg) w).u τ i - (confEncU c i : ℝ)|
      ≤ |((paper3HeadlineSolFamNW wg) w).u τ i -
          ((paper3HeadlineSolFamNW wg) w).u a i| +
        |((paper3HeadlineSolFamNW wg) w).u a i - (confEncU c i : ℝ)| :=
        abs_sub_le _ _ _
    _ ≤ Cwin * Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
          (200 * (bgpScaleW wg : ℝ)) +
        (r_LE_U - Cwin * Real.exp (-(200 * (bgpScaleW wg : ℝ) * a)) /
          (200 * (bgpScaleW wg : ℝ))) := add_le_add hdrift (hstart i)
    _ = r_LE_U := by ring

/-- Named lower bound for the settled z-write mass at NW: the open z-gate
accumulates at least `(2π/3)·e^{50·S·(2πj+π/6)}` over the write window
(`sin ≥ 1/2` there, so `kZ ≥ e^{50·S·τ} ≥ e^{50·S·writeStart}`). -/
noncomputable def paper3S2WriteMassLowerNW (wg j : ℕ) : ℝ :=
  (2 * Real.pi / 3) *
    Real.exp (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ) + Real.pi / 6))

theorem paper3S2_writeMassLower_NW (wg w j : ℕ) :
    paper3S2WriteMassLowerNW wg j ≤
      ∫ τ in (selectorMUWriteStartTime j)..(selectorMUWriteReadTime j),
        (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
  have hπ := Real.pi_pos
  have hS : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) :=
    mul_nonneg (mul_nonneg (by norm_num) hπ.le) (Nat.cast_nonneg _)
  have hws0 : (0 : ℝ) ≤ selectorMUWriteStartTime j := by
    unfold selectorMUWriteStartTime; linarith
  have hab : selectorMUWriteStartTime j ≤ selectorMUWriteReadTime j := by
    unfold selectorMUWriteStartTime selectorMUWriteReadTime; linarith
  have hpoint : ∀ τ ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteReadTime j),
      Real.exp (50 * (bgpScaleW wg : ℝ) *
          (2 * Real.pi * (j : ℝ) + Real.pi / 6)) ≤
        (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans hws0 hτ.1
    have hsin : (1 : ℝ) / 2 ≤ Real.sin τ := by
      apply sin_ge_half_of_write_window j
      constructor
      · have := hτ.1; unfold selectorMUWriteStartTime at this; linarith
      · have := hτ.2; unfold selectorMUWriteReadTime at this; linarith
    calc Real.exp (50 * (bgpScaleW wg : ℝ) *
          (2 * Real.pi * (j : ℝ) + Real.pi / 6))
        ≤ Real.exp (50 * (bgpScaleW wg : ℝ) * τ) := by
          apply Real.exp_le_exp.mpr
          have := hτ.1; unfold selectorMUWriteStartTime at this
          nlinarith
      _ ≤ _ := paper3NW4_zKernel_ge_of_sin_ge_half wg w hτ0 hsin
  have hconst_int : IntervalIntegrable
      (fun _ : ℝ => Real.exp (50 * (bgpScaleW wg : ℝ) *
        (2 * Real.pi * (j : ℝ) + Real.pi / 6)))
      MeasureTheory.volume (selectorMUWriteStartTime j) (selectorMUWriteReadTime j) :=
    intervalIntegrable_const
  have hker_int : IntervalIntegrable
      (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ)
      MeasureTheory.volume (selectorMUWriteStartTime j) (selectorMUWriteReadTime j) :=
    (paper3NW4_zKernel_continuous wg w).intervalIntegrable _ _
  have hmono := intervalIntegral.integral_mono_on hab hconst_int hker_int hpoint
  have hwidth : (∫ _ in (selectorMUWriteStartTime j)..(selectorMUWriteReadTime j),
      Real.exp (50 * (bgpScaleW wg : ℝ) *
        (2 * Real.pi * (j : ℝ) + Real.pi / 6))) =
      paper3S2WriteMassLowerNW wg j := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
    unfold paper3S2WriteMassLowerNW selectorMUWriteStartTime selectorMUWriteReadTime
    ring
  calc paper3S2WriteMassLowerNW wg j = _ := hwidth.symm
    _ ≤ _ := hmono

/-- Sharp NW copy-mass lower bound: on `[2πj+4π/3, 2πj+5π/3]` the sine stays
below `−√3/2`, so the u-kernel rate `−200 − 500·sin τ` is at least
`−200 + 250·√3 ≥ 233` and the accumulated copy mass is at least
`(π/3)·e^{233·S·(2πj+4π/3)}`. -/
noncomputable def paper3S2CopyMassLowerNW (wg j : ℕ) : ℝ :=
  (Real.pi / 3) * Real.exp (233 * (bgpScaleW wg : ℝ) *
    (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3))

theorem paper3S2_copyMassLowerNW_le_integral (wg w j : ℕ) :
    paper3S2CopyMassLowerNW wg j ≤
      ∫ τ in (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)..(2 *
          Real.pi * (j : ℝ) + 5 * Real.pi / 3),
        (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
  have hπ := Real.pi_pos
  have hS : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) :=
    mul_nonneg (mul_nonneg (by norm_num) hπ.le) (Nat.cast_nonneg _)
  have ha0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3 := by linarith
  have hab : 2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3 ≤
      2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3 := by linarith
  have hsqrt : (1.732 : ℝ) ≤ Real.sqrt 3 := by
    rw [show (1.732 : ℝ) = Real.sqrt (1.732 ^ 2) from
      (Real.sqrt_sq (by norm_num)).symm]
    exact Real.sqrt_le_sqrt (by norm_num)
  have hpoint : ∀ τ ∈ Icc (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)
      (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3),
      Real.exp (233 * (bgpScaleW wg : ℝ) *
          (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)) ≤
        (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
          bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans ha0 hτ.1
    have hsin := sin_le_neg_sqrt3_div_two_on_copy_window j hτ.1 hτ.2
    rw [paper3NW4_uKernel_eq wg w hτ0]
    apply Real.exp_le_exp.mpr
    have hrate : (233 : ℝ) ≤ -200 - 500 * Real.sin τ := by linarith
    have hSτ : 0 ≤ (bgpScaleW wg : ℝ) * τ := mul_nonneg hS.le hτ0
    nlinarith [mul_le_mul_of_nonneg_left hτ.1
        (mul_nonneg (by norm_num) hS.le : (0 : ℝ) ≤ 233 * (bgpScaleW wg : ℝ)),
      mul_le_mul_of_nonneg_left hrate hSτ]
  have hconst_int : IntervalIntegrable
      (fun _ : ℝ => Real.exp (233 * (bgpScaleW wg : ℝ) *
        (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)))
      MeasureTheory.volume (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)
      (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3) := intervalIntegrable_const
  have hker_int : IntervalIntegrable
      (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
        bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ)
      MeasureTheory.volume (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)
      (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3) :=
    (paper3NW4_uKernel_continuous wg w).intervalIntegrable _ _
  have hmono := intervalIntegral.integral_mono_on hab hconst_int hker_int hpoint
  have hwidth : (∫ _ in (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)..(2 *
      Real.pi * (j : ℝ) + 5 * Real.pi / 3),
      Real.exp (233 * (bgpScaleW wg : ℝ) *
        (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3))) =
      paper3S2CopyMassLowerNW wg j := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
    unfold paper3S2CopyMassLowerNW
    ring
  calc paper3S2CopyMassLowerNW wg j = _ := hwidth.symm
    _ ≤ _ := hmono

/-- S2 copy-phase contraction at NW: from a coarse entry `D₀` at
`2πj + 4π/3` and a `δz` tube for the target `z`, the copy mass drives `u`
to `e^{−CopyMass}·D₀ + δz` at `2πj + 5π/3`. -/
theorem paper3S2_u_copy_contract_NW (wg w j : ℕ) (i : Fin d_U)
    {E D0 δz : ℝ} (hδz0 : 0 ≤ δz)
    (hentry : |((paper3HeadlineSolFamNW wg) w).u
        (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3) i - E| ≤ D0)
    (hz : ∀ t ∈ Icc (2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3)
        (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3),
      |((paper3HeadlineSolFamNW wg) w).z t i - E| ≤ δz) :
    |((paper3HeadlineSolFamNW wg) w).u
        (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3) i - E| ≤
      Real.exp (-paper3S2CopyMassLowerNW wg j) * D0 + δz := by
  have hπ := Real.pi_pos
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) :=
    mul_nonneg (mul_nonneg (by norm_num) hπ.le) (Nat.cast_nonneg _)
  have ha0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3 := by linarith
  have hab : 2 * Real.pi * (j : ℝ) + 4 * Real.pi / 3 ≤
      2 * Real.pi * (j : ℝ) + 5 * Real.pi / 3 := by linarith
  exact relax_endpoint_contract_of_mass_lower
    (fun τ => ((paper3HeadlineSolFamNW wg) w).u τ i)
    (fun τ => ((paper3HeadlineSolFamNW wg) w).z τ i)
    (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
      bGateU (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ)
    hab
    (paper3NW4_uKernel_continuous wg w)
    (fun t ht => paper3NW4_uKernel_nonneg wg w (le_trans ha0 ht.1))
    (((paper3HeadlineSolFamNW wg) w).cont_z i)
    (fun t ht => ((paper3HeadlineSolFamNW wg) w).u_hasDeriv t
      (selectorSchedule_domain_of_nonneg_structural t (le_trans ha0 ht.1)) i)
    hentry hz hδz0
    (paper3S2_copyMassLowerNW_le_integral wg w j)

/-- Settled z at the write-read endpoint (NW): from a coarse entry `D₀` at
`writeStart j` and an `εmix` mix tube around `E` on the write window, the
open z-gate mass drives `z` to `e^{−WriteMass}·D₀ + εmix` at `writeRead j`
(= the handoff entry `b_j`). -/
theorem paper3S2_settled_z_at_b_NW (wg w j : ℕ) (i : Fin d_U)
    {E D0 εmix : ℝ} (hεmix0 : 0 ≤ εmix)
    (hentry : |((paper3HeadlineSolFamNW wg) w).z
        (selectorMUWriteStartTime j) i - E| ≤ D0)
    (hmix : ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteReadTime j),
      |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
          ((paper3HeadlineSolFamNW wg) w).lam t i - E| ≤ εmix) :
    |((paper3HeadlineSolFamNW wg) w).z (selectorMUWriteReadTime j) i - E| ≤
      Real.exp (-paper3S2WriteMassLowerNW wg j) * D0 + εmix := by
  have hπ := Real.pi_pos
  have hj0 : (0 : ℝ) ≤ 2 * Real.pi * (j : ℝ) :=
    mul_nonneg (mul_nonneg (by norm_num) hπ.le) (Nat.cast_nonneg _)
  have hws0 : (0 : ℝ) ≤ selectorMUWriteStartTime j := by
    unfold selectorMUWriteStartTime; linarith
  have hab : selectorMUWriteStartTime j ≤ selectorMUWriteReadTime j := by
    unfold selectorMUWriteStartTime selectorMUWriteReadTime; linarith
  exact relax_endpoint_contract_of_mass_lower
    (fun τ => ((paper3HeadlineSolFamNW wg) w).z τ i)
    (fun τ => selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
      ((paper3HeadlineSolFamNW wg) w).lam τ i)
    (fun τ => (bgpParamsNW wg).A * ((paper3HeadlineSolFamNW wg) w).α τ *
      bGateZ (bgpParamsNW wg).L (((paper3HeadlineSolFamNW wg) w).μ τ) τ)
    hab
    (paper3NW4_zKernel_continuous wg w)
    (fun t ht => paper3NW4_zKernel_nonneg wg w (le_trans hws0 ht.1))
    (((paper3HeadlineSolFamNW wg) w).cont_mixTarget i)
    (fun t ht => ((paper3HeadlineSolFamNW wg) w).z_hasDeriv t
      (selectorSchedule_domain_of_nonneg_structural t (le_trans hws0 ht.1)) i)
    hentry hmix hεmix0
    (paper3S2_writeMassLower_NW wg w j)

/-! ### Schedule trig windows (shifted sine facts) -/

theorem paper3NW4_sin_nonneg_writeToZOff (j : ℕ) {t : ℝ}
    (h1 : selectorMUWriteStartTime j ≤ t) (h2 : t ≤ selectorMUZOffStart j) :
    0 ≤ Real.sin t := by
  have hπ := Real.pi_pos
  refine sin_window_nonneg j ?_ ?_
  · unfold selectorMUWriteStartTime at h1
    linarith
  · unfold selectorMUZOffStart at h2
    linarith

theorem paper3NW4_sin_ge_half_write (j : ℕ) {t : ℝ}
    (h1 : selectorMUWriteStartTime j ≤ t) (h2 : t ≤ selectorMUWriteReadTime j) :
    (1 : ℝ) / 2 ≤ Real.sin t := by
  refine sin_window_ge j ?_ ?_
  · unfold selectorMUWriteStartTime at h1
    linarith
  · unfold selectorMUWriteReadTime at h2
    linarith

theorem paper3NW4_sin_nonpos_zOff (j : ℕ) {t : ℝ}
    (h1 : selectorMUZOffStart j ≤ t) (h2 : t ≤ selectorMUZOffEnd j) :
    Real.sin t ≤ 0 := by
  have hπ := Real.pi_pos
  refine sin_window_nonpos j ?_ ?_
  · unfold selectorMUZOffStart at h1
    linarith
  · unfold selectorMUZOffEnd at h2
    linarith

theorem paper3NW4_sin_le_neg_half_uActive (j : ℕ) {t : ℝ}
    (h1 : selectorMUUActiveStart j ≤ t) (h2 : t ≤ selectorMUUActiveEnd j) :
    Real.sin t ≤ -(1 / 2 : ℝ) := by
  have hπ := Real.pi_pos
  unfold selectorMUUActiveStart at h1
  unfold selectorMUUActiveEnd at h2
  have hshift : Real.sin t = -Real.sin (t - Real.pi) := by
    have := Real.sin_sub_pi t
    linarith
  have hge : (1 : ℝ) / 2 ≤ Real.sin (t - Real.pi) := by
    refine sin_window_ge j ?_ ?_ <;> linarith
  linarith [hshift.le, hshift.symm.le]

theorem paper3NW4_sin_nonneg_prewriteTail (j : ℕ) {t : ℝ}
    (h1 : selectorMUZOffEnd j ≤ t) (h2 : t ≤ selectorMUWriteStartTime (j + 1)) :
    0 ≤ Real.sin t := by
  have hπ := Real.pi_pos
  refine sin_window_nonneg (j + 1) ?_ ?_
  · unfold selectorMUZOffEnd at h1
    push_cast
    linarith
  · unfold selectorMUWriteStartTime at h2
    push_cast at h2 ⊢
    linarith

/-! ## NEW part B: per-cycle tube maintenance on `[ws j, zOffStart j]` -/

/-- Division monotonicity helper (name-stable). -/
theorem paper3NW4_div_mono {x y c : ℝ} (hc : 0 < c) (h : x ≤ y) :
    x / c ≤ y / c := by
  rw [div_le_div_iff₀ hc hc]
  nlinarith

/-- `|a − b| ≤ |a| + |b|` (name-stable). -/
theorem paper3NW4_abs_sub_le_add {a b : ℝ} :
    |a - b| ≤ |a| + |b| := by
  have h := abs_add_le a (-b)
  simpa [sub_eq_add_neg, abs_neg] using h

/-- Uniform sharp NW drift envelope for the cycle-`j` write-to-z-off
window (both the write-window and the extension legs fit under it). -/
def paper3NW4Drift (wg : ℕ) (j : ℕ) : ℝ :=
  3 * paper3F1CwinDefN *
    Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUWriteStartTime j)) /
      (200 * (bgpScaleW wg : ℝ))

theorem paper3NW4Drift_nonneg (wg j : ℕ) : 0 ≤ paper3NW4Drift wg j := by
  unfold paper3NW4Drift
  have h1 : 0 ≤ paper3F1CwinDefN := by
    unfold paper3F1CwinDefN paper3F1CwinDef
    positivity
  have h2 := bgpScaleWR_pos wg
  positivity

theorem paper3F1CwinDefN_pos : 0 < paper3F1CwinDefN := by
  unfold paper3F1CwinDefN paper3F1CwinDef
  have := bgpScaleR_pos
  positivity

/-- `1296·bgpScale ≤ bgpScaleW w` (the head start is at least `6⁴`). -/
theorem paper3NW4_scale_gap (wg : ℕ) :
    (bgpScale : ℝ) * 1296 ≤ (bgpScaleW wg : ℝ) := by
  have hnat : bgpScale * 1296 ≤ bgpScaleW wg := by
    have h64 : (1296 : ℕ) ≤ 6 ^ (MachineInstance.inputLenU 1 wg + 220) := by
      calc (1296 : ℕ) = 6 ^ 4 := by norm_num
        _ ≤ 6 ^ (MachineInstance.inputLenU 1 wg + 220) :=
          Nat.pow_le_pow_right (by norm_num) (by omega)
    exact Nat.mul_le_mul_left _ h64
  exact_mod_cast hnat

/-- The sharp NW drift fits under the N write-prefix reserve alone (leaving
the settled reserve `δuSettledN > 0` as strict first-exit headroom). -/
theorem paper3NW4Drift_le_reserveWP (wg : ℕ) (j : ℕ) :
    paper3NW4Drift wg j ≤ δuWritePrefixN paper3F1CwinDefN 0 := by
  have hS4 := bgpScaleWR_ge_four wg
  have hS0 := bgpScaleWR_pos wg
  have hs0 := bgpScaleR_pos
  have hgap := paper3NW4_scale_gap wg
  have hC0 := paper3F1CwinDefN_pos
  have hπ3 := Real.pi_gt_three
  have hπ4 := Real.pi_le_four
  have hws : Real.pi / 6 ≤ selectorMUWriteStartTime j := by
    unfold selectorMUWriteStartTime
    have hπ := Real.pi_pos
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith
  have hws0 : selectorMUWriteStartTime 0 = Real.pi / 6 := by
    unfold selectorMUWriteStartTime
    norm_num
  have hrate : selectorUSettledRate_N = 450 * (bgpScale : ℝ) :=
    selectorUSettledRate_N_eq
  -- the mass factor `3·e^{−200·S·ws j}/(200·S)` is below `(π/3)·e^{−75π·s}`
  have hkey : 3 * Real.exp (-(200 * (bgpScaleW wg : ℝ) *
      selectorMUWriteStartTime j)) / (200 * (bgpScaleW wg : ℝ)) ≤
      (Real.pi / 3) *
        Real.exp (-(450 * (bgpScale : ℝ) * (Real.pi / 6))) := by
    have hc : (0 : ℝ) < 200 * (bgpScaleW wg : ℝ) := by nlinarith
    rw [div_le_iff₀ hc]
    have hexp_cmp : Real.exp (-(200 * (bgpScaleW wg : ℝ) *
        selectorMUWriteStartTime j)) ≤
        Real.exp (-(450 * (bgpScale : ℝ) * (Real.pi / 6))) := by
      apply Real.exp_le_exp.mpr
      have h1 : 450 * (bgpScale : ℝ) * (Real.pi / 6) ≤
          100 * (bgpScaleW wg : ℝ) := by nlinarith
      have h2 : 100 * (bgpScaleW wg : ℝ) ≤
          200 * (bgpScaleW wg : ℝ) * selectorMUWriteStartTime j := by
        nlinarith
      linarith
    have hbig : (3 : ℝ) ≤ (Real.pi / 3) * (200 * (bgpScaleW wg : ℝ)) := by
      nlinarith
    calc 3 * Real.exp (-(200 * (bgpScaleW wg : ℝ) *
          selectorMUWriteStartTime j))
        ≤ 3 * Real.exp (-(450 * (bgpScale : ℝ) * (Real.pi / 6))) :=
          mul_le_mul_of_nonneg_left hexp_cmp (by norm_num)
      _ ≤ ((Real.pi / 3) * (200 * (bgpScaleW wg : ℝ))) *
          Real.exp (-(450 * (bgpScale : ℝ) * (Real.pi / 6))) :=
          mul_le_mul_of_nonneg_right hbig (Real.exp_pos _).le
      _ = Real.pi / 3 *
          Real.exp (-(450 * (bgpScale : ℝ) * (Real.pi / 6))) *
          (200 * (bgpScaleW wg : ℝ)) := by ring
  unfold paper3NW4Drift δuWritePrefixN
  rw [hws0, hrate]
  calc 3 * paper3F1CwinDefN *
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUWriteStartTime j)) /
        (200 * (bgpScaleW wg : ℝ))
      = paper3F1CwinDefN *
        (3 * Real.exp (-(200 * (bgpScaleW wg : ℝ) *
          selectorMUWriteStartTime j)) / (200 * (bgpScaleW wg : ℝ))) := by
        ring
    _ ≤ paper3F1CwinDefN * ((Real.pi / 3) *
        Real.exp (-(450 * (bgpScale : ℝ) * (Real.pi / 6)))) :=
        mul_le_mul_of_nonneg_left hkey hC0.le

/-- Encoding coordinates are `2·D_U`-bounded. -/
theorem paper3NW4_enc_abs (c : UConf) (i : Fin d_U) :
    |stackMachineEncodingU.enc c i| ≤ 2 * D_U := by
  rw [stackMachineEncodingU_enc_eq]
  exact paper3Headline_confEncU_abs_le_two_D_U c i

/-- Crude extension box: `Cwin + 2r + 6D_U ≤ 2·CwinDefN`. -/
theorem paper3NW4_extBox_le :
    paper3F1CwinDefN + 2 * r_LE_U + 6 * D_U ≤ 2 * paper3F1CwinDefN := by
  have hD := D_U_le_two_bgpScale
  have hD8 := paper3Headline_D_U_ge_eight
  have hs4 := bgpScaleR_ge_four
  have hexp : (200 : ℝ) ≤ Real.exp (199 : ℝ) := by
    have := Real.add_one_le_exp (199 : ℝ)
    linarith
  have hr : r_LE_U = 1 / 1000 := rfl
  unfold paper3F1CwinDefN paper3F1CwinDef
  nlinarith

/-- Schedule ordering: `ws j ≤ wr j`. -/
theorem paper3NW4_ws_le_wr (j : ℕ) :
    selectorMUWriteStartTime j ≤ selectorMUWriteReadTime j := by
  unfold selectorMUWriteStartTime selectorMUWriteReadTime
  have := Real.pi_pos
  linarith

/-- Schedule ordering: `wr j ≤ zOffStart j`. -/
theorem paper3NW4_wr_le_zOffStart (j : ℕ) :
    selectorMUWriteReadTime j ≤ selectorMUZOffStart j := by
  unfold selectorMUWriteReadTime selectorMUZOffStart
  have := Real.pi_pos
  linarith

/-- **Per-cycle tube maintenance.**  Under the cycle-`j` write-start
boundary tube (radius `paper3F1TubeRadiusN paper3F1CwinDefN`) and the
cycle-`j` window envelope, the `u` trajectory stays inside the `r_LE_U`
readout tube of `enc (cfg j)` on the whole `[ws j, zOffStart j]`, with
total drift below the sharp NW envelope `paper3NW4Drift`. -/
theorem paper3NW4_tube_maintenance (wg w j : ℕ)
    (htube0 : ∀ i,
      |((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN)
    (hwin : ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW wg) w).z t i -
        ((paper3HeadlineSolFamNW wg) w).u t i| ≤ paper3F1CwinDefN) :
    (∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW wg) w).u t i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U) ∧
    (∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW wg) w).u t i -
          ((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i| ≤
          paper3NW4Drift wg j) := by
  classical
  set sol := (paper3HeadlineSolFamNW wg) w with hsol
  set A := selectorMUWriteStartTime j with hA
  set W := selectorMUWriteReadTime j with hW
  set Z := selectorMUZOffStart j with hZ
  have hAW : A ≤ W := paper3NW4_ws_le_wr j
  have hWZ : W ≤ Z := paper3NW4_wr_le_zOffStart j
  have hA0 : 0 ≤ A := selectorMUWriteStartTime_nonneg j
  have hS0 := bgpScaleWR_pos wg
  have hc : (0 : ℝ) < 200 * (bgpScaleW wg : ℝ) := by nlinarith
  have hC0 := paper3F1CwinDefN_pos
  have hD8 := paper3Headline_D_U_ge_eight
  have hδsN_pos : 0 < δuSettledN paper3F1CwinDefN 0 := by
    unfold δuSettledN
    have := Real.exp_pos
      (-(selectorUSettledRate_N * selectorMUWriteHoldTime 0))
    have hπ := Real.pi_pos
    positivity
  -- write-window drift
  have hdrift1 : ∀ t ∈ Icc A W, ∀ i : Fin d_U,
      |sol.u t i - sol.u A i| ≤
        paper3F1CwinDefN *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
          (200 * (bgpScaleW wg : ℝ)) := by
    intro t ht i
    exact paper3NW4_u_drift_of_sin_nonneg wg w i hC0.le hA0
      (fun τ hτ => paper3NW4_sin_nonneg_writeToZOff j hτ.1
        (le_trans hτ.2 hWZ))
      (fun τ hτ i' => hwin i' τ hτ) t ht
  -- tube at the write-read endpoint
  have htubeW : ∀ i : Fin d_U,
      |sol.u W i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN +
          paper3F1CwinDefN *
            Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
            (200 * (bgpScaleW wg : ℝ)) := by
    intro i
    calc |sol.u W i - stackMachineEncodingU.enc (paper3F1Cfg w j) i|
        ≤ |sol.u W i - sol.u A i| +
          |sol.u A i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| :=
          abs_sub_le _ _ _
      _ ≤ paper3F1CwinDefN *
            Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
            (200 * (bgpScaleW wg : ℝ)) +
          paper3F1TubeRadiusN paper3F1CwinDefN :=
          add_le_add (hdrift1 W ⟨hAW, le_refl W⟩ i) (htube0 i)
      _ = paper3F1TubeRadiusN paper3F1CwinDefN +
          paper3F1CwinDefN *
            Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
            (200 * (bgpScaleW wg : ℝ)) := by ring
  -- drift-part numerics: the two legs fit under the reserve envelope
  have hd1_le : paper3F1CwinDefN *
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
      (200 * (bgpScaleW wg : ℝ)) +
      2 * paper3F1CwinDefN *
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * W)) /
        (200 * (bgpScaleW wg : ℝ)) ≤ paper3NW4Drift wg j := by
    unfold paper3NW4Drift
    rw [← hA]
    have hexp_le : Real.exp (-(200 * (bgpScaleW wg : ℝ) * W)) ≤
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) := by
      apply Real.exp_le_exp.mpr
      nlinarith
    have h2 : 2 * paper3F1CwinDefN *
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * W)) ≤
        2 * paper3F1CwinDefN *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) := by
      nlinarith
    have hcomb : paper3F1CwinDefN *
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
        (200 * (bgpScaleW wg : ℝ)) +
        2 * paper3F1CwinDefN *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * W)) /
          (200 * (bgpScaleW wg : ℝ)) =
        (paper3F1CwinDefN *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) +
          2 * paper3F1CwinDefN *
            Real.exp (-(200 * (bgpScaleW wg : ℝ) * W))) /
          (200 * (bgpScaleW wg : ℝ)) := by
      ring
    rw [hcomb]
    apply paper3NW4_div_mono hc
    linarith
  -- the extension bootstrap on [W, Z]
  have hext : ∀ t ∈ Icc W Z, ∀ i : Fin d_U,
      |sol.u t i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U ∧
      |sol.u t i - sol.u W i| ≤
        2 * paper3F1CwinDefN *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * W)) /
          (200 * (bgpScaleW wg : ℝ)) := by
    -- first-exit argument at level r_LE_U
    have hW0 : 0 ≤ W := le_trans hA0 hAW
    -- conditional pair box on any not-yet-exited prefix
    have hpair : ∀ b ∈ Icc W Z,
        (∀ s ∈ Icc W b, ∀ i : Fin d_U,
          |sol.u s i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
            r_LE_U) →
        ∀ s ∈ Icc W b, ∀ i : Fin d_U,
          |sol.z s i - sol.u s i| ≤ 2 * paper3F1CwinDefN := by
      intro b hb htube_pre s hs i
      -- z is trapped in the hull of z(W) and the ±2D_U mix range
      have hmix_box : ∀ σ ∈ Icc W s, ∀ i' : Fin d_U,
          |selectorMixTarget branchU sol.u sol.lam σ i'| ≤ 2 * D_U := by
        intro σ hσ i'
        have hσ0 : 0 ≤ σ := le_trans hW0 hσ.1
        refine paper3NW_mixTarget_abs_le_of_branch_abs wg w hσ0 ?_ i'
        intro i'' v
        exact branchU_evalBranch_abs_le_two_D_U
          (fun i''' => htube_pre σ ⟨hσ.1, le_trans hσ.2 hs.2⟩ i''') v i''
      have hzW_abs : |sol.z W i| ≤
          paper3F1CwinDefN + r_LE_U + 2 * D_U := by
        have h1 := hwin i W ⟨hAW, le_refl W⟩
        have h2 := htube_pre W ⟨le_refl W, le_trans hs.1 hs.2⟩ i
        have h3 := paper3NW4_enc_abs (paper3F1Cfg w j) i
        have := abs_sub_abs_le_abs_sub (sol.z W i) (sol.u W i)
        have h4 : |sol.u W i| ≤ r_LE_U + 2 * D_U := by
          have := abs_sub_abs_le_abs_sub (sol.u W i)
            (stackMachineEncodingU.enc (paper3F1Cfg w j) i)
          linarith
        linarith
      have htrap : sol.z s i ∈ Icc
          (min (sol.z W i) (-(2 * D_U))) (max (sol.z W i) (2 * D_U)) := by
        refine paper3N_trapping_on_Icc
          (fun τ => sol.z τ i)
          (fun τ => selectorMixTarget branchU sol.u sol.lam τ i)
          (fun τ => (bgpParamsNW wg).A * sol.α τ *
            bGateZ (bgpParamsNW wg).L (sol.μ τ) τ)
          hs.1
          (paper3NW4_zKernel_continuous wg w)
          (sol.cont_mixTarget i)
          (fun τ hτ => sol.z_hasDeriv τ
            (selectorSchedule_domain_of_nonneg_structural τ
              (le_trans hW0 hτ.1)) i)
          (fun τ hτ => paper3NW4_zKernel_nonneg wg w (le_trans hW0 hτ.1))
          (fun τ hτ => ?_) ?_
        · have hm := hmix_box τ hτ i
          rw [abs_le] at hm
          constructor
          · exact le_trans (min_le_right _ _) hm.1
          · exact le_trans hm.2 (le_max_right _ _)
        · constructor
          · exact min_le_left _ _
          · exact le_max_left _ _
      have hz_abs : |sol.z s i| ≤
          paper3F1CwinDefN + r_LE_U + 4 * D_U := by
        have h1 := htrap.1
        have h2 := htrap.2
        rw [abs_le]
        constructor
        · have := min_le_left (sol.z W i) (-(2 * D_U))
          have habs := abs_le.mp hzW_abs
          have hmin : -(paper3F1CwinDefN + r_LE_U + 4 * D_U) ≤
              min (sol.z W i) (-(2 * D_U)) := by
            rcases min_cases (sol.z W i) (-(2 * D_U)) with h | h
            · rw [h.1]; linarith [habs.1]
            · rw [h.1]; linarith
          linarith
        · have habs := abs_le.mp hzW_abs
          have hmax : max (sol.z W i) (2 * D_U) ≤
              paper3F1CwinDefN + r_LE_U + 4 * D_U := by
            rcases max_cases (sol.z W i) (2 * D_U) with h | h
            · rw [h.1]; linarith [habs.2]
            · rw [h.1]; linarith
          linarith
      have hu_abs : |sol.u s i| ≤ r_LE_U + 2 * D_U := by
        have h2 := htube_pre s hs i
        have h3 := paper3NW4_enc_abs (paper3F1Cfg w j) i
        have := abs_sub_abs_le_abs_sub (sol.u s i)
          (stackMachineEncodingU.enc (paper3F1Cfg w j) i)
        linarith
      have hEB := paper3NW4_extBox_le
      calc |sol.z s i - sol.u s i| ≤ |sol.z s i| + |sol.u s i| :=
            paper3NW4_abs_sub_le_add
        _ ≤ (paper3F1CwinDefN + r_LE_U + 4 * D_U) + (r_LE_U + 2 * D_U) := by
            linarith
        _ ≤ 2 * paper3F1CwinDefN := by
            have : paper3F1CwinDefN + 2 * r_LE_U + 6 * D_U ≤
                2 * paper3F1CwinDefN := hEB
            linarith
    -- radius slack: entry + both drift legs sit strictly below r_LE_U
    have hslack : paper3F1TubeRadiusN paper3F1CwinDefN +
        paper3NW4Drift wg j ≤ r_LE_U - δuSettledN paper3F1CwinDefN 0 := by
      have h1 := paper3NW4Drift_le_reserveWP wg j
      unfold paper3F1TubeRadiusN
      linarith
    -- the first-exit tube
    have hext_tube : ∀ t ∈ Icc W Z, ∀ i : Fin d_U,
        |sol.u t i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
          r_LE_U := by
      by_contra hcon
      push_neg at hcon
      obtain ⟨tb, htb, i0, hi0⟩ := hcon
      set Bad : Set ℝ := Icc W tb ∩
        ⋃ i : Fin d_U, {s : ℝ |
          r_LE_U ≤ |sol.u s i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i|} with hBadDef
      have hclosed : IsClosed Bad := by
        refine isClosed_Icc.inter (isClosed_iUnion_of_finite fun i => ?_)
        exact isClosed_le continuous_const
          (((sol.cont_u i).sub continuous_const).abs)
      have htb_mem : tb ∈ Bad :=
        ⟨⟨htb.1, le_refl tb⟩, Set.mem_iUnion.mpr ⟨i0, hi0.le⟩⟩
      have hne : Bad.Nonempty := ⟨tb, htb_mem⟩
      have hbdd : BddBelow Bad := ⟨W, fun s hs => hs.1.1⟩
      have hmem_inf : sInf Bad ∈ Bad := hclosed.csInf_mem hne hbdd
      have hWinf : W ≤ sInf Bad := le_csInf hne fun b hb => hb.1.1
      have hinf_tb : sInf Bad ≤ tb := csInf_le hbdd htb_mem
      have hinfZ : sInf Bad ≤ Z := le_trans hinf_tb htb.2
      -- entry bound: strictly inside at W
      have hentryW : ∀ i : Fin d_U,
          |sol.u W i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| <
            r_LE_U := by
        intro i
        have h1 := htubeW i
        have h2 : paper3F1CwinDefN *
            Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
            (200 * (bgpScaleW wg : ℝ)) ≤ paper3NW4Drift wg j := by
          unfold paper3NW4Drift
          rw [← hA]
          apply paper3NW4_div_mono hc
          nlinarith [(Real.exp_pos
            (-(200 * (bgpScaleW wg : ℝ) * A))).le]
        have := hslack
        calc |sol.u W i - stackMachineEncodingU.enc (paper3F1Cfg w j) i|
            ≤ paper3F1TubeRadiusN paper3F1CwinDefN +
              paper3F1CwinDefN *
                Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
                (200 * (bgpScaleW wg : ℝ)) := h1
          _ ≤ paper3F1TubeRadiusN paper3F1CwinDefN +
              paper3NW4Drift wg j := by linarith
          _ ≤ r_LE_U - δuSettledN paper3F1CwinDefN 0 := hslack
          _ < r_LE_U := by linarith
      have hWlt : W < sInf Bad := by
        rcases lt_or_eq_of_le hWinf with h | h
        · exact h
        · exfalso
          obtain ⟨i, hi⟩ := Set.mem_iUnion.mp hmem_inf.2
          rw [← h] at hi
          simp only [Set.mem_setOf_eq] at hi
          exact absurd hi (not_le.mpr (hentryW i))
      -- the maintained tube up to the exit time
      have htube_pre : ∀ s ∈ Icc W (sInf Bad), ∀ i : Fin d_U,
          |sol.u s i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
            r_LE_U := by
        intro s hs i
        rcases lt_or_eq_of_le hs.2 with hlt | heq
        · by_contra hgt
          push_neg at hgt
          have hmem : s ∈ Bad :=
            ⟨⟨hs.1, le_trans hs.2 hinf_tb⟩,
              Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
          exact absurd (csInf_le hbdd hmem) (not_le.mpr hlt)
        · have hf : Continuous fun τ : ℝ =>
              |sol.u τ i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| :=
            ((sol.cont_u i).sub continuous_const).abs
          have hev : ∀ᶠ τ in nhdsWithin (sInf Bad) (Set.Iio (sInf Bad)),
              |sol.u τ i -
                stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U := by
            filter_upwards [Ioo_mem_nhdsLT hWlt] with τ hτ
            by_contra hgt
            push_neg at hgt
            have hmem : τ ∈ Bad :=
              ⟨⟨hτ.1.le, le_trans hτ.2.le hinf_tb⟩,
                Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
            exact absurd (csInf_le hbdd hmem) (not_le.mpr hτ.2)
          have hlim := le_of_tendsto
            (hf.continuousWithinAt
              (s := Set.Iio (sInf Bad)) (x := sInf Bad)) hev
          rw [heq]
          exact hlim
      -- drift on [W, sInf Bad] beats the exit level: contradiction
      obtain ⟨i, hi⟩ := Set.mem_iUnion.mp hmem_inf.2
      simp only [Set.mem_setOf_eq] at hi
      have hbox := hpair (sInf Bad) ⟨hWinf, hinfZ⟩ htube_pre
      have hdrift2 := paper3NW4_u_drift_of_sin_nonneg wg w i
        (by nlinarith : (0 : ℝ) ≤ 2 * paper3F1CwinDefN) hW0
        (fun τ hτ => paper3NW4_sin_nonneg_writeToZOff j
          (le_trans hAW hτ.1) (le_trans hτ.2 hinfZ))
        (fun τ hτ i' => hbox τ hτ i')
        (sInf Bad) ⟨hWinf, le_refl _⟩
      have hend : |sol.u (sInf Bad) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| <
          r_LE_U := by
        have h1 := htubeW i
        have hsum : paper3F1CwinDefN *
            Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
            (200 * (bgpScaleW wg : ℝ)) +
            2 * paper3F1CwinDefN *
              Real.exp (-(200 * (bgpScaleW wg : ℝ) * W)) /
              (200 * (bgpScaleW wg : ℝ)) ≤ paper3NW4Drift wg j := hd1_le
        calc |sol.u (sInf Bad) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i|
            ≤ |sol.u (sInf Bad) i - sol.u W i| +
              |sol.u W i -
                stackMachineEncodingU.enc (paper3F1Cfg w j) i| :=
              abs_sub_le _ _ _
          _ ≤ 2 * paper3F1CwinDefN *
                Real.exp (-(200 * (bgpScaleW wg : ℝ) * W)) /
                (200 * (bgpScaleW wg : ℝ)) +
              (paper3F1TubeRadiusN paper3F1CwinDefN +
                paper3F1CwinDefN *
                  Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
                  (200 * (bgpScaleW wg : ℝ))) :=
              add_le_add hdrift2 h1
          _ ≤ paper3F1TubeRadiusN paper3F1CwinDefN +
              paper3NW4Drift wg j := by linarith
          _ ≤ r_LE_U - δuSettledN paper3F1CwinDefN 0 := hslack
          _ < r_LE_U := by linarith
      exact absurd hi (not_le.mpr hend)
    -- with the tube established, the extension drift is unconditional
    intro t ht i
    refine ⟨hext_tube t ht i, ?_⟩
    exact paper3NW4_u_drift_of_sin_nonneg wg w i
      (by nlinarith : (0 : ℝ) ≤ 2 * paper3F1CwinDefN) hW0
      (fun τ hτ => paper3NW4_sin_nonneg_writeToZOff j
        (le_trans hAW hτ.1) hτ.2)
      (fun τ hτ i' => hpair Z ⟨hWZ, le_refl Z⟩ hext_tube τ hτ i')
      t ht
  -- assemble the two outputs over the split at W
  constructor
  · intro t ht i
    rcases le_total t W with htW | htW
    · have h1 := hdrift1 t ⟨ht.1, htW⟩ i
      have h2 := htube0 i
      have h3 : paper3F1CwinDefN *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
          (200 * (bgpScaleW wg : ℝ)) ≤ paper3NW4Drift wg j := by
        unfold paper3NW4Drift
        rw [← hA]
        apply paper3NW4_div_mono hc
        nlinarith [(Real.exp_pos
          (-(200 * (bgpScaleW wg : ℝ) * A))).le]
      have hslack : paper3F1TubeRadiusN paper3F1CwinDefN +
          paper3NW4Drift wg j ≤ r_LE_U - δuSettledN paper3F1CwinDefN 0 := by
        have := paper3NW4Drift_le_reserveWP wg j
        unfold paper3F1TubeRadiusN
        linarith
      calc |sol.u t i - stackMachineEncodingU.enc (paper3F1Cfg w j) i|
          ≤ |sol.u t i - sol.u A i| +
            |sol.u A i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| :=
            abs_sub_le _ _ _
        _ ≤ paper3NW4Drift wg j + paper3F1TubeRadiusN paper3F1CwinDefN := by
            linarith
        _ ≤ r_LE_U := by linarith
    · exact (hext t ⟨htW, ht.2⟩ i).1
  · intro t ht i
    rcases le_total t W with htW | htW
    · have h1 := hdrift1 t ⟨ht.1, htW⟩ i
      have h3 : paper3F1CwinDefN *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
          (200 * (bgpScaleW wg : ℝ)) ≤ paper3NW4Drift wg j := by
        unfold paper3NW4Drift
        rw [← hA]
        apply paper3NW4_div_mono hc
        nlinarith [(Real.exp_pos
          (-(200 * (bgpScaleW wg : ℝ) * A))).le]
      linarith
    · have h1 := (hext t ⟨htW, ht.2⟩ i).2
      have h2 := hdrift1 W ⟨hAW, le_refl W⟩ i
      calc |sol.u t i - sol.u A i|
          ≤ |sol.u t i - sol.u W i| + |sol.u W i - sol.u A i| :=
            abs_sub_le _ _ _
        _ ≤ 2 * paper3F1CwinDefN *
              Real.exp (-(200 * (bgpScaleW wg : ℝ) * W)) /
              (200 * (bgpScaleW wg : ℝ)) +
            paper3F1CwinDefN *
              Real.exp (-(200 * (bgpScaleW wg : ℝ) * A)) /
              (200 * (bgpScaleW wg : ℝ)) := add_le_add h1 h2
        _ ≤ paper3NW4Drift wg j := by
            have := hd1_le
            linarith

