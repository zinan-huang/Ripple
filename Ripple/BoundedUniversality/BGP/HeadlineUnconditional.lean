/-- The N-scaled u-active mass dominates the same linear function of the
cycle index as the fixed mass: for `j ≥ 5` the closed-form exponent
`100π·j − 325π/3` is positive, so scaling it by `bgpScale ≥ 1` only helps;
for `j ≤ 4` the bound is trivial from nonnegativity. -/
theorem selectorInterReadUActiveMassLowerNW_ge_linear (sW : ℕ) (j : ℕ) :
    2 * (j : ℝ) - 8 ≤ selectorInterReadUActiveMassLowerNW sW j := by
  have hK0 := selectorInterReadUActiveMassLowerNW_nonneg sW j
  by_cases hj : (j : ℝ) ≤ 4
  · linarith
  · push_neg at hj
    have hrw38 : selectorInterReadUActiveMassLower j =
        (2 * Real.pi / 3) *
          Real.exp (100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3) := by
      unfold selectorInterReadUActiveMassLower selectorMUUActiveStart
        selectorMUUActiveEnd
      rw [← Real.exp_add]
      ring_nf
    have hrwN : selectorInterReadUActiveMassLowerNW sW j =
        (2 * Real.pi / 3) *
          Real.exp ((bgpScaleW sW : ℝ) *
            (100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3)) := by
      unfold selectorInterReadUActiveMassLowerNW selectorMUUActiveStart
        selectorMUUActiveEnd
      rw [← Real.exp_add]
      ring_nf
    have hlin : (0 : ℝ) ≤ 100 * (j : ℝ) - 325 / 3 := by linarith
    have hE0 : 0 ≤ 100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3 := by
      nlinarith [mul_nonneg Real.pi_pos.le hlin]
    have hsE : 100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3 ≤
        (bgpScaleW sW : ℝ) * (100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3) := by
      nlinarith [bgpScaleWR_ge_one sW, hE0]
    have hdom : selectorInterReadUActiveMassLower j ≤
        selectorInterReadUActiveMassLowerNW sW j := by
      rw [hrw38, hrwN]
      exact mul_le_mul_of_nonneg_left (Real.exp_le_exp.mpr hsE)
        (by positivity)
    have h38 := selectorInterReadUActiveMassLower_ge_linear j
    linarith

/-- Geometric contraction of the N-scaled inter-read u-kernel (rate `2`,
uniform prefactor `e⁸`). -/
theorem exp_neg_selectorInterReadUActiveMassLowerNW_le_geometric (sW : ℕ) (j : ℕ) :
    Real.exp (-(selectorInterReadUActiveMassLowerNW sW j)) ≤
      Real.exp (8 : ℝ) * Real.exp (-(2 : ℝ) * (j : ℝ)) := by
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  have h := selectorInterReadUActiveMassLowerNW_ge_linear sW j
  linarith

/-- N-parametric offphase z-gate envelope: on `sin ≤ 0` subwindows the
z-integrand decays at the scaled leak rate `200·bgpScale` (the
`(bgpParamsNW_chi_leak_eq sW)` margin). -/
theorem gateZ_integrand_le_offphase_exp_NW (sW : ℕ)
    {eta : ℚ} {heta : 0 < eta} {Mcy : ℕ} {κ₀ g₀ : ℚ}
    (sol : SelectorReplicatorDynSol d_U B_U UniversalLocalView (bgpParamsNW sW) selectorSchedule
      branchU
      (fun t => ((1 + Real.cos t) / 2) ^ Mcy)
      (fun t => ((1 + Real.sin t) / 2) ^ Mcy)
      (fun _ => (κ₀ : ℝ))
      (fun t => (g₀ : ℝ) * Real.exp ((bgpParamsNW sW).cα * t))
      (universalPval eta heta))
    {t : ℝ} (ht0 : 0 ≤ t) (hsin : Real.sin t ≤ 0) :
    (bgpParamsNW sW).A * sol.α t * bGateZ (bgpParamsNW sW).L (sol.μ t) t ≤
      Real.exp (-(200 * (bgpScaleW sW : ℝ) * t)) := by
  have hα : sol.α t = Real.exp ((bgpParamsNW sW).cα * t) :=
    sol.alpha_eq_exp selectorSchedule_domain_of_nonneg_structural ht0
  have hμ : sol.μ t = (bgpParamsNW sW).cμ * t := by
    rw [sol.mu_eq_linear selectorSchedule_domain_of_nonneg_structural ht0,
      sol.μ_at_zero, zero_add]
  have h :=
    gateZ_integrand_le_offphase_exp_repl
      (sol := sol) (A := (1 : ℝ)) (cμ := (bgpParamsNW sW).cμ)
      (cα := (bgpParamsNW sW).cα)
      ht0 (by norm_num) (bgpParamsNW_cμ_pos sW).le
      (bgpParamsNW_A_eq sW)
      hα hμ hsin
  calc
    (bgpParamsNW sW).A * sol.α t * bGateZ (bgpParamsNW sW).L (sol.μ t) t
        ≤ (1 : ℝ) *
            Real.exp (-(((bgpParamsNW sW).cμ * (1 / 2 : ℝ) ^ (bgpParamsNW sW).L -
              (bgpParamsNW sW).cα) * t)) := h
    _ = Real.exp (-(200 * (bgpScaleW sW : ℝ) * t)) := by
      rw [one_mul, (bgpParamsNW_chi_leak_eq sW)]

