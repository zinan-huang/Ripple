                    ((sol w).u τ))) *
            (sol w).lam v τ|
    (Finset.univ.filter (fun v : UniversalLocalView => v ≠ c)).sum
        forcingInt ≤
      Delta * Csq * paper3HoffRate j := by
  classical
  dsimp at hDelta_upper hdelta_nonneg hcg_square
  dsimp
  let sol := paper3HeadlineSolFam wg
  let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let S : Finset UniversalLocalView :=
    Finset.univ.filter (fun v : UniversalLocalView => v ≠ c)
  let P : UniversalLocalView → ℝ → ℝ := fun v τ =>
    universalPval paper3HeadlineEta paper3HeadlineEta_pos v ((sol w).u τ)
  let cg : ℝ → ℝ := fun τ =>
    selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  let meanGap : ℝ → ℝ := fun τ =>
    ∑ x : UniversalLocalView, (sol w).lam x τ * (P c τ - P x τ)
  let loserMass : ℝ → ℝ := fun τ =>
    S.sum (fun v => (sol w).lam v τ)
  let forcingFun : UniversalLocalView → ℝ → ℝ := fun v τ =>
    |cg τ * meanGap τ * (sol w).lam v τ|
  let squareFun : ℝ → ℝ := fun τ => cg τ * (loserMass τ) ^ 2
  have hEH : E ≤ Htime := by
    simpa [E, Htime] using selectorMUEarlySubStart_le_writeHold (j + 1)
  have hE0 : 0 ≤ E := by
    exact le_trans (selectorMUWriteStartTime_nonneg (j + 1))
      (by simpa [E] using selectorMUWriteStart_le_earlySubStart (j + 1))
  have hP : ∀ v : UniversalLocalView, Continuous (P v) := by
    intro v
    simpa [P, sol] using
      paper3UniversalPval_continuous_of_cont_u v (fun i => (sol w).cont_u i)
  have hlam : ∀ v : UniversalLocalView,
      Continuous fun τ : ℝ => (sol w).lam v τ := by
    intro v
    exact (sol w).cont_lam v
  have hcg_cont : Continuous cg := by
    simpa [cg] using
      selectorMU_activeCg_continuous paper3HeadlineM (paper3WarmGainQ wg)
  have hmean_cont : Continuous meanGap := by
    dsimp [meanGap]
    refine continuous_finsetSum Finset.univ ?_
    intro x _hx
    exact (hlam x).mul ((hP c).sub (hP x))
  have hloser_cont : Continuous loserMass := by
    dsimp [loserMass]
    exact continuous_finsetSum S (fun v _hv => hlam v)
  have hforce_cont : ∀ v : UniversalLocalView, Continuous (forcingFun v) := by
    intro v
    dsimp [forcingFun]
    exact ((hcg_cont.mul hmean_cont).mul (hlam v)).abs
  have hsquare_cont : Continuous squareFun := by
    dsimp [squareFun]
    exact hcg_cont.mul (hloser_cont.pow 2)
  have hforce_sum_cont : Continuous fun τ : ℝ => S.sum (fun v => forcingFun v τ) := by
    exact continuous_finsetSum S (fun v _hv => hforce_cont v)
  have hright_cont : Continuous fun τ : ℝ => Delta * squareFun τ :=
    continuous_const.mul hsquare_cont
  have hforce_split :
      (∫ τ in E..Htime, S.sum (fun v => forcingFun v τ)) =
        S.sum (fun v => ∫ τ in E..Htime, forcingFun v τ) := by
    rw [intervalIntegral.integral_finsetSum]
    intro v _hv
    exact (hforce_cont v).intervalIntegrable E Htime
  have hpoint : ∀ τ ∈ Set.Icc E Htime,
      S.sum (fun v => forcingFun v τ) ≤ Delta * squareFun τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans hE0 hτ.1
    have hlam_nonneg : ∀ v : UniversalLocalView, 0 ≤ (sol w).lam v τ := by
      intro v
      exact paper3Headline_lam_nonneg_forward wg w v τ hτ0
    have hcg_nonneg : 0 ≤ cg τ := by
      dsimp [cg, selectorMU_activeCg]
      have hsin_base_nonneg : 0 ≤ (1 + Real.sin τ) / 2 := by
        nlinarith [Real.neg_one_le_sin τ]
      exact mul_nonneg (pow_nonneg hsin_base_nonneg paper3HeadlineM)
        (mul_nonneg (paper3WarmGainQ_pos wg).le (Real.exp_pos _).le)
    have hdelta_self : P c τ - P c τ = 0 := by ring
    have hraw :=
      paper3_filtered_forcing_pointwise_le_delta_loser_square
        (V := UniversalLocalView) c
        (lam := fun v : UniversalLocalView => (sol w).lam v τ)
        (gap := fun v : UniversalLocalView => P c τ - P v τ)
        (cg := cg τ) (Delta := Delta)
        hlam_nonneg hcg_nonneg
        (hdelta_nonneg τ (by simpa [E, Htime] using hτ))
        hdelta_self
        (fun v hv =>
          have hvS :
              v ∈ Finset.univ.filter
                (fun y : UniversalLocalView => y ≠ c) := by
            exact Finset.mem_filter.mpr ⟨Finset.mem_univ v, hv⟩
          hDelta_upper τ (by simpa [E, Htime] using hτ) v hvS)
    simpa [forcingFun, squareFun, meanGap, loserMass, S, P] using hraw
  have hmono :
      (∫ τ in E..Htime, S.sum (fun v => forcingFun v τ)) ≤
        ∫ τ in E..Htime, Delta * squareFun τ := by
    exact intervalIntegral.integral_mono_on hEH
      (hforce_sum_cont.intervalIntegrable E Htime)
      (hright_cont.intervalIntegrable E Htime)
      hpoint
  have hconst :
      (∫ τ in E..Htime, Delta * squareFun τ) =
        Delta * ∫ τ in E..Htime, squareFun τ := by
    rw [intervalIntegral.integral_const_mul]
  have hsquare :
      (∫ τ in E..Htime, squareFun τ) ≤ Csq * paper3HoffRate j := by
    simpa [squareFun, loserMass, cg, S, sol, c, E, Htime] using hcg_square
  calc
    S.sum (fun v => ∫ τ in E..Htime, forcingFun v τ)
        = ∫ τ in E..Htime, S.sum (fun v => forcingFun v τ) := hforce_split.symm
    _ ≤ ∫ τ in E..Htime, Delta * squareFun τ := hmono
    _ = Delta * ∫ τ in E..Htime, squareFun τ := hconst
    _ ≤ Delta * (Csq * paper3HoffRate j) :=
        mul_le_mul_of_nonneg_left hsquare hDelta_nonneg
    _ = Delta * Csq * paper3HoffRate j := by ring

/-- A crude but explicit active-gain integral upper bound: on the active
subwindow, the pulse is at most one and the exponential gain is bounded by its
right endpoint. -/
theorem paper3Headline_activeCg_integral_le_hold_exp
    (wg j : ℕ) :
    let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
    let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
    (∫ τ in E..Htime,
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ) ≤
      ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
        Real.exp (bgpParams38.cα * Htime) := by
  classical
  dsimp
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
  let rhs : ℝ := q * Real.exp (bgpParams38.cα * Htime)
  have hEH : E ≤ Htime := by
    simpa [E, Htime] using selectorMUEarlySubStart_le_writeHold (j + 1)
  have hcg_cont : Continuous fun τ : ℝ =>
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ :=
    selectorMU_activeCg_continuous paper3HeadlineM (paper3WarmGainQ wg)
  have hrhs_cont : Continuous fun _τ : ℝ => rhs := continuous_const
  have hpoint : ∀ τ ∈ Set.Icc E Htime,
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ ≤ rhs := by
    intro τ hτ
    have hpulse_le : ((1 + Real.sin τ) / 2) ^ paper3HeadlineM ≤ 1 := by
      simpa [qPulse] using qPulse_le_one paper3HeadlineM τ
    have hpulse_nonneg : 0 ≤ ((1 + Real.sin τ) / 2) ^ paper3HeadlineM := by
      simpa [qPulse] using qPulse_nonneg paper3HeadlineM τ
    have hq_nonneg : 0 ≤ q := by
      simpa [q] using paper3WarmGainQ_nonneg wg
    have hα_nonneg : 0 ≤ bgpParams38.cα := by
      norm_num [bgpParams38]
    have harg_le : bgpParams38.cα * τ ≤ bgpParams38.cα * Htime :=
      mul_le_mul_of_nonneg_left hτ.2 hα_nonneg
    have hexp_le :
        Real.exp (bgpParams38.cα * τ) ≤
          Real.exp (bgpParams38.cα * Htime) :=
      Real.exp_le_exp.mpr harg_le
    have hgain_le :
        q * Real.exp (bgpParams38.cα * τ) ≤
          q * Real.exp (bgpParams38.cα * Htime) :=
      mul_le_mul_of_nonneg_left hexp_le hq_nonneg
    have hgain_nonneg :
        0 ≤ q * Real.exp (bgpParams38.cα * τ) :=
      mul_nonneg hq_nonneg (Real.exp_pos _).le
    calc
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
          =
              ((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
                (q * Real.exp (bgpParams38.cα * τ)) := by
            dsimp [selectorMU_activeCg, q]
      _ ≤ 1 * (q * Real.exp (bgpParams38.cα * Htime)) :=
            mul_le_mul hpulse_le hgain_le hgain_nonneg
              (by norm_num : (0 : ℝ) ≤ 1)
      _ = rhs := by
            dsimp [rhs]
            ring
  have hmono :
      (∫ τ in E..Htime,
          selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ) ≤
        ∫ _τ in E..Htime, rhs := by
    exact intervalIntegral.integral_mono_on hEH
      (hcg_cont.intervalIntegrable E Htime)
      (hrhs_cont.intervalIntegrable E Htime)
      hpoint
  have hconst :
      (∫ _τ in E..Htime, rhs) = (Real.pi / 4) * rhs := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
    have hlen : Htime - E = Real.pi / 4 := by
      dsimp [E, Htime, selectorMUEarlyWriteSubStart, selectorMUWriteHoldTime]
      ring
    rw [hlen]
  calc
    (∫ τ in E..Htime,
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ)
        ≤ ∫ _τ in E..Htime, rhs := hmono
    _ = (Real.pi / 4) * rhs := hconst
    _ = q * (Real.pi / 4) * Real.exp (bgpParams38.cα * Htime) := by
      ring

/-- The active gain integral absorbs one early linear gain-decay factor.  The
remaining bound is uniform in the cycle index because the strong headline gain
slope dominates the `3/8` active-gain growth. -/
theorem paper3Headline_activeCgInt_mul_earlyLinearGainDecay_succ_le_const
    (wg j : ℕ) :
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let c : ℝ :=
      ((3 / 4 : ℝ) ^ paper3HeadlineM) *
        (((paper3WarmGainQ wg : ℚ) : ℝ)) *
        Real.exp (bgpParams38.cα *
          (Real.pi / 6 + selectorMURecoveryDelta)) *
        (Real.pi / 12 - selectorMURecoveryDelta) *
        (2 * Real.pi * bgpParams38.cα)
    let gainDecay : ℝ := Real.exp (-(gap * c) * ((j + 1 : ℕ) : ℝ))
    (∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
        (selectorMUWriteHoldTime (j + 1)),
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ) *
        gainDecay ≤
      ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
        Real.exp (3 * Real.pi / 16) := by
  classical
  dsimp
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let c : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ)) *
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta)) *
      (Real.pi / 12 - selectorMURecoveryDelta) *
      (2 * Real.pi * bgpParams38.cα)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let Icg : ℝ :=
    ∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..Htime,
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
  let gainDecay : ℝ := Real.exp (-(gap * c) * ((j + 1 : ℕ) : ℝ))
  let upper : ℝ := q * (Real.pi / 4) * Real.exp (bgpParams38.cα * Htime)
  let K : ℝ := q * (Real.pi / 4)
  have hI : Icg ≤ upper := by
    simpa [Icg, Htime, q, upper] using
      paper3Headline_activeCg_integral_le_hold_exp wg j
  have hgain_nonneg : 0 ≤ gainDecay := by
    dsimp [gainDecay]
    exact (Real.exp_pos _).le
  have hI_mul : Icg * gainDecay ≤ upper * gainDecay :=
    mul_le_mul_of_nonneg_right hI hgain_nonneg
  have hslope : (1125 * Real.pi : ℝ) ≤ gap * c := by
    simpa [gap, c] using paper3Headline_earlyGainSlope_ge_pi wg
  have hn_nonneg : 0 ≤ ((j + 1 : ℕ) : ℝ) := by
    exact_mod_cast Nat.zero_le (j + 1)
  have hslope_n :
      (1125 * Real.pi) * ((j + 1 : ℕ) : ℝ) ≤
        (gap * c) * ((j + 1 : ℕ) : ℝ) :=
    mul_le_mul_of_nonneg_right hslope hn_nonneg
  have hexp_arg :
      bgpParams38.cα * Htime - (gap * c) * ((j + 1 : ℕ) : ℝ) ≤
        3 * Real.pi / 16 := by
    dsimp [Htime, selectorMUWriteHoldTime]
    norm_num [bgpParams38]
    ring_nf
    nlinarith [hslope_n, hn_nonneg, Real.pi_pos]
  have hexp_mul :
      Real.exp (bgpParams38.cα * Htime) * gainDecay =
        Real.exp (bgpParams38.cα * Htime -
          (gap * c) * ((j + 1 : ℕ) : ℝ)) := by
    dsimp [gainDecay]
    rw [← Real.exp_add]
    congr 1
    ring
  have hexp_le :
      Real.exp (bgpParams38.cα * Htime) * gainDecay ≤
        Real.exp (3 * Real.pi / 16) := by
    rw [hexp_mul]
    exact Real.exp_le_exp.mpr hexp_arg
  have hK_nonneg : 0 ≤ K := by
    dsimp [K, q]
    exact mul_nonneg (paper3WarmGainQ_nonneg wg)
      (by nlinarith [Real.pi_pos] : 0 ≤ Real.pi / 4)
  have hupper_mul :
      upper * gainDecay ≤ K * Real.exp (3 * Real.pi / 16) := by
    calc
      upper * gainDecay
          = K * (Real.exp (bgpParams38.cα * Htime) * gainDecay) := by
              dsimp [upper, K]
              ring
      _ ≤ K * Real.exp (3 * Real.pi / 16) :=
          mul_le_mul_of_nonneg_left hexp_le hK_nonneg
  calc
    Icg * gainDecay ≤ upper * gainDecay := hI_mul
    _ ≤ K * Real.exp (3 * Real.pi / 16) := hupper_mul
    _ = q * (Real.pi / 4) * Real.exp (3 * Real.pi / 16) := by
      dsimp [K]

/-- The active gain integral also absorbs one reset-tail factor.  Here the
active exponential at write-hold cancels against the reset tail based at
write-start, leaving only the fixed schedule offset. -/
theorem paper3Headline_activeCgInt_mul_resetTail_div_gap_decay_succ_le_const
    (wg j : ℕ) :
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let resetTail : ℝ :=
      Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime (j + 1))) / gap
    (∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
        (selectorMUWriteHoldTime (j + 1)),
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ) *
        resetTail ≤
      ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
        Real.exp (100 * Real.pi) / gap := by
  classical
  dsimp
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let Icg : ℝ :=
    ∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..Htime,
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  let q : ℝ := ((paper3WarmGainQ wg : ℚ) : ℝ)
  let resetTail : ℝ := Real.exp (-(bgpParams38.cα * W)) / gap
  let upper : ℝ := q * (Real.pi / 4) * Real.exp (bgpParams38.cα * Htime)
  let K : ℝ := q * (Real.pi / 4)
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hI : Icg ≤ upper := by
    simpa [Icg, Htime, q, upper] using
      paper3Headline_activeCg_integral_le_hold_exp wg j
  have hreset_nonneg : 0 ≤ resetTail := by
    dsimp [resetTail]
    exact div_nonneg (Real.exp_pos _).le hgap_pos.le
  have hI_mul : Icg * resetTail ≤ upper * resetTail :=
    mul_le_mul_of_nonneg_right hI hreset_nonneg
  have hexp_arg :
      bgpParams38.cα * Htime - bgpParams38.cα * W = 100 * Real.pi := by
    dsimp [Htime, W, selectorMUWriteHoldTime, selectorMUWriteStartTime]
    norm_num [bgpParams38]
    ring
  have hexp_mul :
      Real.exp (bgpParams38.cα * Htime) *
        Real.exp (-(bgpParams38.cα * W)) =
      Real.exp (bgpParams38.cα * Htime - bgpParams38.cα * W) := by
    rw [← Real.exp_add]
    congr 1
  have hexp_le :
      Real.exp (bgpParams38.cα * Htime) *
        Real.exp (-(bgpParams38.cα * W)) ≤
      Real.exp (100 * Real.pi) := by
    rw [hexp_mul, hexp_arg]
  have hK_nonneg : 0 ≤ K := by
    dsimp [K, q]
    exact mul_nonneg (paper3WarmGainQ_nonneg wg)
      (by nlinarith [Real.pi_pos] : 0 ≤ Real.pi / 4)
  have hinv_gap_nonneg : 0 ≤ gap⁻¹ := inv_nonneg.mpr hgap_pos.le
  have hupper_mul :
      upper * resetTail ≤ K * Real.exp (100 * Real.pi) / gap := by
    have hmain :
        K *
            (Real.exp (bgpParams38.cα * Htime) *
              Real.exp (-(bgpParams38.cα * W))) * gap⁻¹ ≤
          K * Real.exp (100 * Real.pi) * gap⁻¹ :=
      mul_le_mul_of_nonneg_right
        (mul_le_mul_of_nonneg_left hexp_le hK_nonneg)
        hinv_gap_nonneg
    calc
      upper * resetTail
          = K *
              (Real.exp (bgpParams38.cα * Htime) *
                Real.exp (-(bgpParams38.cα * W))) * gap⁻¹ := by
            dsimp [upper, resetTail, K]
            rw [div_eq_mul_inv]
            ring
      _ ≤ K * Real.exp (100 * Real.pi) * gap⁻¹ := hmain
      _ = K * Real.exp (100 * Real.pi) / gap := by
            rw [div_eq_mul_inv]
  calc
    Icg * resetTail ≤ upper * resetTail := hI_mul
    _ ≤ K * Real.exp (100 * Real.pi) / gap := hupper_mul
    _ = q * (Real.pi / 4) * Real.exp (100 * Real.pi) / gap := rfl

/-- Square version of the early gain component estimate: one factor is absorbed
by the active gain integral, and the other factor supplies the Hoff rate. -/
theorem paper3Headline_activeCgInt_mul_earlyLinearGainDecay_sq_succ_le_hoffRate
    (wg j : ℕ) :
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let c : ℝ :=
      ((3 / 4 : ℝ) ^ paper3HeadlineM) *
        (((paper3WarmGainQ wg : ℚ) : ℝ)) *
        Real.exp (bgpParams38.cα *
          (Real.pi / 6 + selectorMURecoveryDelta)) *
        (Real.pi / 12 - selectorMURecoveryDelta) *
        (2 * Real.pi * bgpParams38.cα)
    let gainDecay : ℝ := Real.exp (-(gap * c) * ((j + 1 : ℕ) : ℝ))
    let CgainAbs : ℝ :=
      ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
        Real.exp (3 * Real.pi / 16)
    (∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
        (selectorMUWriteHoldTime (j + 1)),
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ) *
        gainDecay ^ 2 ≤
      CgainAbs * paper3HoffRate j := by
  classical
  dsimp
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let c : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ)) *
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta)) *
      (Real.pi / 12 - selectorMURecoveryDelta) *
      (2 * Real.pi * bgpParams38.cα)
  let gainDecay : ℝ := Real.exp (-(gap * c) * ((j + 1 : ℕ) : ℝ))
  let CgainAbs : ℝ :=
    ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
      Real.exp (3 * Real.pi / 16)
  let Icg : ℝ :=
    ∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
      (selectorMUWriteHoldTime (j + 1)),
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  have hAbs : Icg * gainDecay ≤ CgainAbs := by
    simpa [Icg, gap, c, gainDecay, CgainAbs] using
      paper3Headline_activeCgInt_mul_earlyLinearGainDecay_succ_le_const wg j
  have hhoff : gainDecay ≤ paper3HoffRate j := by
    dsimp [gainDecay, gap, c]
    exact paper3Headline_earlyLinearGainDecay_succ_le_hoffRate wg j
  have hgain_nonneg : 0 ≤ gainDecay := by
    dsimp [gainDecay]
    exact (Real.exp_pos _).le
  have hCgain_nonneg : 0 ≤ CgainAbs := by
    dsimp [CgainAbs]
    exact mul_nonneg
      (mul_nonneg (paper3WarmGainQ_nonneg wg)
        (by nlinarith [Real.pi_pos] : 0 ≤ Real.pi / 4))
      (Real.exp_pos _).le
  calc
    Icg * gainDecay ^ 2
        = (Icg * gainDecay) * gainDecay := by ring
    _ ≤ CgainAbs * gainDecay :=
        mul_le_mul_of_nonneg_right hAbs hgain_nonneg
    _ ≤ CgainAbs * paper3HoffRate j :=
        mul_le_mul_of_nonneg_left hhoff hCgain_nonneg

/-- Square version of the reset-tail component estimate: one reset-tail factor
is absorbed by the active gain integral and the other supplies the Hoff rate. -/
theorem paper3Headline_activeCgInt_mul_resetTail_sq_succ_le_hoffRate
    (wg j : ℕ) :
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let resetTail : ℝ :=
      Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime (j + 1))) / gap
    let CresetAbs : ℝ :=
      ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
        Real.exp (100 * Real.pi) / gap
    let Kreset : ℝ := Real.exp (Real.pi / 16) / gap
    (∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
        (selectorMUWriteHoldTime (j + 1)),
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ) *
        resetTail ^ 2 ≤
      (CresetAbs * Kreset) * paper3HoffRate j := by
  classical
  dsimp
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let resetTail : ℝ :=
    Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime (j + 1))) / gap
  let CresetAbs : ℝ :=
    ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
      Real.exp (100 * Real.pi) / gap
  let Kreset : ℝ := Real.exp (Real.pi / 16) / gap
  let Icg : ℝ :=
    ∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
      (selectorMUWriteHoldTime (j + 1)),
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hAbs : Icg * resetTail ≤ CresetAbs := by
    simpa [Icg, gap, resetTail, CresetAbs] using
      paper3Headline_activeCgInt_mul_resetTail_div_gap_decay_succ_le_const wg j
  have hreset_succ :
      resetTail ≤ Kreset * paper3HoffRate (j + 1) := by
    dsimp [resetTail, Kreset, gap]
    simpa [gap] using paper3Headline_resetTail_div_gap_decay_le_hoffRate (j + 1)
  have hKreset_nonneg : 0 ≤ Kreset := by
    dsimp [Kreset]
    exact div_nonneg (Real.exp_pos _).le hgap_pos.le
  have hreset : resetTail ≤ Kreset * paper3HoffRate j :=
    le_trans hreset_succ
      (mul_le_mul_of_nonneg_left (paper3HoffRate_succ_le j) hKreset_nonneg)
  have hreset_nonneg : 0 ≤ resetTail := by
    dsimp [resetTail]
    exact div_nonneg (Real.exp_pos _).le hgap_pos.le
  have hCreset_nonneg : 0 ≤ CresetAbs := by
    dsimp [CresetAbs]
    exact div_nonneg
      (mul_nonneg
        (mul_nonneg (paper3WarmGainQ_nonneg wg)
          (by nlinarith [Real.pi_pos] : 0 ≤ Real.pi / 4))
        (Real.exp_pos _).le)
      hgap_pos.le
  calc
    Icg * resetTail ^ 2
        = (Icg * resetTail) * resetTail := by ring
    _ ≤ CresetAbs * resetTail :=
        mul_le_mul_of_nonneg_right hAbs hreset_nonneg
    _ ≤ CresetAbs * (Kreset * paper3HoffRate j) :=
        mul_le_mul_of_nonneg_left hreset hCreset_nonneg
    _ = (CresetAbs * Kreset) * paper3HoffRate j := by ring

theorem paper3_mul_sq_le_of_le_two_components
    (I Efull A B rate CA CB C : ℝ)
    (hI_nonneg : 0 ≤ I)
    (hEfull_nonneg : 0 ≤ Efull)
    (hA_nonneg : 0 ≤ A) (hB_nonneg : 0 ≤ B)
    (hrate_nonneg : 0 ≤ rate)
    (hEfull_le : Efull ≤ A + B)
    (hA2 : I * A ^ 2 ≤ CA * rate)
    (hB2 : I * B ^ 2 ≤ CB * rate)
    (hC : 2 * CA + 2 * CB ≤ C) :
    I * Efull ^ 2 ≤ C * rate := by
  have hAB_nonneg : 0 ≤ A + B := add_nonneg hA_nonneg hB_nonneg
  have hE_sq : Efull ^ 2 ≤ (A + B) ^ 2 := by
    have hmul := mul_le_mul hEfull_le hEfull_le hEfull_nonneg hAB_nonneg
    simpa [sq] using hmul
  have hAB_sq : (A + B) ^ 2 ≤ 2 * A ^ 2 + 2 * B ^ 2 := by
    nlinarith [sq_nonneg (A - B)]
  have hmain : I * Efull ^ 2 ≤ I * (2 * A ^ 2 + 2 * B ^ 2) := by
    exact mul_le_mul_of_nonneg_left (hE_sq.trans hAB_sq) hI_nonneg
  have hparts : I * (2 * A ^ 2 + 2 * B ^ 2) ≤ (2 * CA + 2 * CB) * rate := by
    nlinarith [hA2, hB2]
  have hconst : (2 * CA + 2 * CB) * rate ≤ C * rate :=
    mul_le_mul_of_nonneg_right hC hrate_nonneg
  exact hmain.trans (hparts.trans hconst)

/-- Correct scalar square producer for the active forcing route.  This keeps the
concrete shifted early-full bound through the square, splits it into gain and
reset components, and only then collapses one factor of each component to the
Hoff envelope. -/
theorem paper3Headline_activeCgInt_mul_shiftedEarlyFull_sq_le_hoffRate
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
    let Efull : ℝ := epsLamShiftedEarlyFullAt sol w gap card (j + 1)
    let CgainAbs : ℝ :=
      ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
        Real.exp (3 * Real.pi / 16)
    let CresetAbs : ℝ :=
      ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
        Real.exp (100 * Real.pi) / gap
    let Kreset : ℝ := Real.exp (Real.pi / 16) / gap
    let CA : ℝ := ((card - 1) * card) ^ 2 * CgainAbs
    let CB : ℝ := (2 * (card - 1)) ^ 2 * (CresetAbs * Kreset)
    let Csq : ℝ := 2 * CA + 2 * CB
    (∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
        (selectorMUWriteHoldTime (j + 1)),
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ) *
        Efull ^ 2 ≤
      Csq * paper3HoffRate j := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let card : ℝ := (Fintype.card UniversalLocalView : ℝ)
  let c : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ)) *
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta)) *
      (Real.pi / 12 - selectorMURecoveryDelta) *
      (2 * Real.pi * bgpParams38.cα)
  let gainDecay : ℝ := Real.exp (-(gap * c) * ((j + 1 : ℕ) : ℝ))
  let resetTail : ℝ :=
    Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime (j + 1))) / gap
  let Efull : ℝ := epsLamShiftedEarlyFullAt sol w gap card (j + 1)
  let Icg : ℝ :=
    ∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
      (selectorMUWriteHoldTime (j + 1)),
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ
  let A : ℝ := (card - 1) * card * gainDecay
  let B : ℝ := 2 * (card - 1) * resetTail
  let CgainAbs : ℝ :=
    ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
      Real.exp (3 * Real.pi / 16)
  let CresetAbs : ℝ :=
    ((paper3WarmGainQ wg : ℚ) : ℝ) * (Real.pi / 4) *
      Real.exp (100 * Real.pi) / gap
  let Kreset : ℝ := Real.exp (Real.pi / 16) / gap
  let CA : ℝ := ((card - 1) * card) ^ 2 * CgainAbs
  let CB : ℝ := (2 * (card - 1)) ^ 2 * (CresetAbs * Kreset)
  let Csq : ℝ := 2 * CA + 2 * CB
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hcard_nonneg : 0 ≤ card := by
    dsimp [card]
    positivity
  have hcard_sub_nonneg : 0 ≤ card - 1 := by
    dsimp [card]
    have hcard_pos_nat :
        0 < Fintype.card UniversalLocalView :=
      Fintype.card_pos_iff.mpr ⟨defaultLocalViewU⟩
    have hcard_one : (1 : ℝ) ≤ Fintype.card UniversalLocalView := by
      exact_mod_cast hcard_pos_nat
    linarith
  have hgain_nonneg : 0 ≤ gainDecay := by
    dsimp [gainDecay]
    exact (Real.exp_pos _).le
  have hreset_nonneg : 0 ≤ resetTail := by
    dsimp [resetTail]
    exact div_nonneg (Real.exp_pos _).le hgap_pos.le
  have hA_nonneg : 0 ≤ A := by
    dsimp [A]
    exact mul_nonneg (mul_nonneg hcard_sub_nonneg hcard_nonneg) hgain_nonneg
  have hB_nonneg : 0 ≤ B := by
    dsimp [B]
    exact mul_nonneg (mul_nonneg (by norm_num : (0 : ℝ) ≤ 2) hcard_sub_nonneg)
      hreset_nonneg
  have hEfull_nonneg : 0 ≤ Efull := by
    dsimp [Efull, sol, gap, card]
    exact epsLamShiftedEarlyFullAt_nonneg (paper3HeadlineSolFam wg) w
      (by simpa [gap] using hgap_pos)
      (by positivity)
      (by norm_num [paper3HeadlineKappa]) (j + 1)
  have hI_nonneg : 0 ≤ Icg := by
    dsimp [Icg]
    apply intervalIntegral.integral_nonneg
      (by simpa using selectorMUEarlySubStart_le_writeHold (j + 1))
    intro τ _hτ
    dsimp [selectorMU_activeCg]
    have hsin_base_nonneg : 0 ≤ (1 + Real.sin τ) / 2 := by
      nlinarith [Real.neg_one_le_sin τ]
    exact mul_nonneg (pow_nonneg hsin_base_nonneg paper3HeadlineM)
      (mul_nonneg (paper3WarmGainQ_pos wg).le (Real.exp_pos _).le)
  have hEfull_base :
      Efull ≤ (card - 1) * (card * gainDecay + resetTail) +
        (card - 1) * resetTail := by
    have h :=
      epsLamShiftedEarlyFullAt_le_linear_decay_bound
        (sol := sol) (w := w) (gap := gap) (R0 := card)
        (paper3WarmGainQ_pos wg) hgap_pos
        (by dsimp [card]; positivity)
        (by norm_num [paper3HeadlineKappa])
        (paper3HeadlineHScale wg)
    simpa [sol, gap, card, c, gainDecay, resetTail, Efull] using h (j + 1)
  have hEfull_le : Efull ≤ A + B := by
    calc
      Efull ≤ (card - 1) * (card * gainDecay + resetTail) +
          (card - 1) * resetTail := hEfull_base
      _ = A + B := by
          dsimp [A, B]
          ring
  have hgain_sq :
      Icg * gainDecay ^ 2 ≤ CgainAbs * paper3HoffRate j := by
    simpa [Icg, gap, c, gainDecay, CgainAbs] using
      paper3Headline_activeCgInt_mul_earlyLinearGainDecay_sq_succ_le_hoffRate wg j
  have hreset_sq :
      Icg * resetTail ^ 2 ≤ (CresetAbs * Kreset) * paper3HoffRate j := by
    simpa [Icg, gap, resetTail, CresetAbs, Kreset] using
      paper3Headline_activeCgInt_mul_resetTail_sq_succ_le_hoffRate wg j
  have hA2 : Icg * A ^ 2 ≤ CA * paper3HoffRate j := by
    have hcoef_nonneg : 0 ≤ ((card - 1) * card) ^ 2 := sq_nonneg _
    calc
      Icg * A ^ 2
          = ((card - 1) * card) ^ 2 * (Icg * gainDecay ^ 2) := by
              dsimp [A]
              ring
      _ ≤ ((card - 1) * card) ^ 2 * (CgainAbs * paper3HoffRate j) :=
          mul_le_mul_of_nonneg_left hgain_sq hcoef_nonneg
      _ = CA * paper3HoffRate j := by
          dsimp [CA]
          ring
  have hB2 : Icg * B ^ 2 ≤ CB * paper3HoffRate j := by
    have hcoef_nonneg : 0 ≤ (2 * (card - 1)) ^ 2 := sq_nonneg _
    calc
      Icg * B ^ 2
          = (2 * (card - 1)) ^ 2 * (Icg * resetTail ^ 2) := by
              dsimp [B]
              ring
      _ ≤ (2 * (card - 1)) ^ 2 *
            ((CresetAbs * Kreset) * paper3HoffRate j) :=
          mul_le_mul_of_nonneg_left hreset_sq hcoef_nonneg
      _ = CB * paper3HoffRate j := by
          dsimp [CB]
          ring
  exact
    paper3_mul_sq_le_of_le_two_components
      (I := Icg) (Efull := Efull) (A := A) (B := B)
      (rate := paper3HoffRate j) (CA := CA) (CB := CB) (C := Csq)
      hI_nonneg hEfull_nonneg hA_nonneg hB_nonneg
      (by dsimp [paper3HoffRate]; exact (Real.exp_pos _).le)
      hEfull_le hA2 hB2
      (by dsimp [Csq]; exact le_rfl)

/--
Cycle-invariant frontier for the concrete shifted warm-gain headline.

This applies `selectorMU_cycle_late_start_of_all` on each diagonal input after
discharging the static selector, box, and scale side conditions.  The remaining
arguments are precisely the current proof-producing analytic data: all-cycle
invariants, the off-field integral cap, shifted next-write convergence, and the
recovery-rate lower bounds.
-/
theorem paper3_headline_unconditional_of_cycle_late_start_step
    (eps δzH : ℕ → ℕ → ℝ)
    (hall : ∀ wg j,
      SelectorMUCycleInvariant (paper3HeadlineSolFam wg) wg r_LE_U
        (eps wg) (δzH wg) j)
    (hoffStep : ∀ wg,
      SelectorMUCycleHoffFieldIntegralStep (paper3HeadlineSolFam wg) wg r_LE_U
        (eps wg) (δzH wg))
    (crMin crMax cgMin recoveryGap recoveryB : ℕ → ℕ → ℝ)
    (recoveryK : ℕ → ℕ → ℕ)
    (hcrMin_pos : ∀ wg j, 0 < crMin wg j)
    (hcrMin_le_crMax : ∀ wg j, crMin wg j ≤ crMax wg j)
    (hcgMin_nonneg : ∀ wg j, 0 ≤ cgMin wg j)
    (hrecoveryGap_nonneg : ∀ wg j, 0 ≤ recoveryGap wg j)
    (hrecoveryGap_le_gapVal : ∀ wg j,
      recoveryGap wg j ≤
        selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
    (hrecoveryB_eq : ∀ wg j,
      recoveryB wg j = cgMin wg j * recoveryGap wg j / 2 - crMax wg j)
    (hrecoveryB_pos : ∀ wg j, 0 < recoveryB wg j)
    (hrecoveryBDelta : ∀ wg j,
      (recoveryK wg j : ℝ) ≤ recoveryB wg j * selectorMURecoveryDelta)
    (hpow : ∀ wg j,
      1 + recoveryB wg j / crMin wg j ≤ (2 : ℝ) ^ recoveryK wg j)
    (hcr_bounds : ∀ wg j,
      ∀ u ∈ Icc (selectorMUWriteStartTime j) (selectorMUSelectStartTime j),
        crMin wg j ≤ ((1 + Real.cos u) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ) ∧
          ((1 + Real.cos u) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ) ≤ crMax wg j)
    (hcg_min : ∀ wg j,
      ∀ u ∈ Icc (selectorMUWriteStartTime j) (selectorMUSelectStartTime j),
        cgMin wg j ≤
          ((1 + Real.sin u) / 2) ^ paper3HeadlineM *
            (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * u)))
    (δnext : ℕ → ℕ → ℝ)
    (hδnext : ∀ wg, Tendsto (δnext wg) atTop (𝓝 0))
    (hδnext_nonneg : ∀ wg j, 0 ≤ δnext wg j)
    (hnextWrite : ∀ wg j, ∀ t ∈ Icc (selectorMUNextWriteStart j)
        (selectorMUNextRead j),
      |((paper3HeadlineSolFam wg) wg).z t haltCoordU -
        stackMachineEncodingU.enc (solMUReplStaticCfg wg (j + 2)) haltCoordU| ≤
          δnext wg j) :
    ∃ P : Ripple.BoundedUniversality.GPAC.PIVP ℚ,
      Nonempty (EventualThresholdSimulation P undecidableMachine) := by
  refine paper3_headline_unconditional_of_late_start_only ?_
  intro wg
  exact
    selectorMU_cycle_late_start_of_all_step
      (hall := hall wg) (hoffStep := hoffStep wg)
      (boxInputs := paper3HeadlineBoxInputs wg)
      paper3HeadlineHerr
      (by norm_num [paper3HeadlineKappa])
      (paper3WarmGainQ_pos wg)
      (paper3HeadlineHScale wg)
      (crMin wg) (crMax wg) (cgMin wg) (recoveryGap wg)
      (recoveryB wg) (recoveryK wg)
      paper3HeadlineHCardTwo
      (hcrMin_pos wg) (hcrMin_le_crMax wg) (hcgMin_nonneg wg)
      (hrecoveryGap_nonneg wg) (hrecoveryGap_le_gapVal wg)
      (hrecoveryB_eq wg) (hrecoveryB_pos wg)
      (hrecoveryBDelta wg) (hpow wg) (hcr_bounds wg) (hcg_min wg)
      (Bz := fun _ => (1 : ℝ)) (Bzmax := (1 : ℝ))
      (δnext := δnext wg) (holdPrefix := fun _ => (1 : ℝ))
      (by intro j; norm_num)
      (by intro j; norm_num)
      (Filter.Eventually.of_forall fun j => le_rfl)
      (hδnext wg)
      (hδnext_nonneg wg)
      (hnextWrite wg)
      (by intro j; norm_num)
      (by intro j; norm_num)

