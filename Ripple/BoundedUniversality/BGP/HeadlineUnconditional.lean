      apply intervalIntegral.integral_nonneg hU1b
      intro s' hs'
      exact hkU_nonneg s' (le_trans hU10 hs'.1)
    have hadd1 : (∫ s' in τ..m, kU s') +
        (∫ s' in m..(selectorMUUActiveEnd j), kU s') =
        ∫ s' in τ..(selectorMUUActiveEnd j), kU s' :=
      intervalIntegral.integral_add_adjacent_intervals (hkU_int τ m)
        (hkU_int m (selectorMUUActiveEnd j))
    have hadd2 : (∫ s' in τ..(selectorMUUActiveEnd j), kU s') +
        (∫ s' in (selectorMUUActiveEnd j)..b, kU s') =
        ∫ s' in τ..b, kU s' :=
      intervalIntegral.integral_add_adjacent_intervals
        (hkU_int τ (selectorMUUActiveEnd j)) (hkU_int (selectorMUUActiveEnd j) b)
    linarith [hmid]
  have hAαgZ_nonneg : ∀ τ : ℝ, 0 ≤ τ →
      0 ≤ bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
        bGateZ bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
    intro τ hτ0'
    have hα := paper3HeadlineSolFamN_alpha wg w hτ0'
    rw [hα, bgpParamsN_A_eq, one_mul]
    have hg : (0 : ℝ) ≤ bGateZ bgpParamsN.L
        (((paper3HeadlineSolFamN wg) w).μ τ) τ := by
      simp only [bGateZ]
      exact (Real.exp_pos _).le
    exact mul_nonneg (Real.exp_pos _).le hg
  have hsrc_early : ∀ τ ∈ Icc a m, |src τ| ≤
      Real.exp (50 * (bgpScale : ℝ) * m) * (5 * D_U) := by
    intro τ hτ
    have hτ0' : 0 ≤ τ := le_trans ha0 hτ.1
    have hsin : Real.sin τ ≤ 1 / 2 :=
      paper3N_sin_le_half_interRead j hτ.1 hτ.2
    have hgate := paper3N_gateZ_integrand_le_halfphase wg w hτ0' hsin
    have hmz := hbox i τ ⟨hτ.1, le_trans hτ.2 hmb⟩
    have hexp_mono : Real.exp (50 * (bgpScale : ℝ) * τ) ≤
        Real.exp (50 * (bgpScale : ℝ) * m) := by
      apply Real.exp_le_exp.mpr
      nlinarith [hτ.2, hs0.le]
    dsimp only [src]
    rw [abs_mul, abs_of_nonneg (hAαgZ_nonneg τ hτ0')]
    calc bgpParamsN.A * ((paper3HeadlineSolFamN wg) w).α τ *
          bGateZ bgpParamsN.L (((paper3HeadlineSolFamN wg) w).μ τ) τ *
          |selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
              ((paper3HeadlineSolFamN wg) w).lam τ i -
            ((paper3HeadlineSolFamN wg) w).z τ i|
        ≤ Real.exp (50 * (bgpScale : ℝ) * τ) * (5 * D_U) :=
          mul_le_mul hgate hmz (abs_nonneg _) (Real.exp_pos _).le
      _ ≤ Real.exp (50 * (bgpScale : ℝ) * m) * (5 * D_U) :=
          mul_le_mul_of_nonneg_right hexp_mono hB0
  have hearly : (∫ τ in a..m, F τ) ≤ 1 / 2 := by
    have hpoint : ∀ τ ∈ Icc a m, F τ ≤
        Real.exp (-(2 * Real.pi / 3 *
            Real.exp (50 * (bgpScale : ℝ) * m))) *
          (Real.exp (50 * (bgpScale : ℝ) * m) * (5 * D_U)) := by
      intro τ hτ
      exact mul_le_mul (hweight_early τ hτ) (hsrc_early τ hτ)
        (abs_nonneg _) (Real.exp_pos _).le
    have hmono := intervalIntegral.integral_mono_on ham
      (hF_cont.intervalIntegrable (μ := MeasureTheory.volume) a m)
      _root_.intervalIntegrable_const hpoint
    have hlen : m - a = Real.pi / 3 := by
      dsimp only [a, m]
      unfold selectorMUWriteReadTime selectorMUUActiveStart
      ring
    have hconst : (∫ _τ in a..m,
        (Real.exp (-(2 * Real.pi / 3 *
            Real.exp (50 * (bgpScale : ℝ) * m))) *
          (Real.exp (50 * (bgpScale : ℝ) * m) * (5 * D_U)))) =
        Real.exp (-(2 * Real.pi / 3 *
            Real.exp (50 * (bgpScale : ℝ) * m))) *
          (Real.exp (50 * (bgpScale : ℝ) * m) * (5 * D_U)) *
          (Real.pi / 3) := by
      rw [intervalIntegral.integral_const, smul_eq_mul, hlen]
      ring
    have hBle : (5 : ℝ) * D_U ≤ 10 * (bgpScale : ℝ) := by linarith
    have harith := paper3N_earlyPiece_arith hs1 hB0 hBle hX175
    calc (∫ τ in a..m, F τ)
        ≤ ∫ _τ in a..m,
            (Real.exp (-(2 * Real.pi / 3 *
                Real.exp (50 * (bgpScale : ℝ) * m))) *
              (Real.exp (50 * (bgpScale : ℝ) * m) * (5 * D_U))) := hmono
      _ = Real.exp (-(2 * Real.pi / 3 *
            Real.exp (50 * (bgpScale : ℝ) * m))) *
          (Real.exp (50 * (bgpScale : ℝ) * m) * (5 * D_U)) *
          (Real.pi / 3) := hconst
      _ ≤ 1 / 2 := harith
  have hlate : (∫ τ in m..b, F τ) ≤ 1 / 20 := by
    have hpoint : ∀ τ ∈ Icc m b, F τ ≤
        Real.exp (-(200 * (bgpScale : ℝ) * τ)) * (5 * D_U) := by
      intro τ hτ
      have hτ0' : 0 ≤ τ := le_trans hm0 hτ.1
      have hWle1 : Real.exp (-(∫ s' in τ..b, kU s')) ≤ 1 := by
        rw [show (1 : ℝ) = Real.exp 0 from Real.exp_zero.symm]
        apply Real.exp_le_exp.mpr
        have hI : 0 ≤ ∫ s' in τ..b, kU s' := by
          apply intervalIntegral.integral_nonneg hτ.2
          intro s' hs'
          exact hkU_nonneg s' (le_trans hτ0' hs'.1)
        linarith
      have hτlow : 2 * Real.pi * j + Real.pi ≤ τ := by
        have h1 : selectorMUUActiveStart j ≤ τ := hτ.1
        unfold selectorMUUActiveStart at h1
        linarith
      have hτhigh : τ ≤ 2 * Real.pi * j + 2 * Real.pi := by
        have h2 : τ ≤ selectorMUZOffEnd j := hτ.2
        unfold selectorMUZOffEnd at h2
        push_cast at h2
        linarith
      have hsin : Real.sin τ ≤ 0 := sin_window_nonpos j hτlow hτhigh
      have hgate := gateZ_integrand_le_offphase_exp_N
        ((paper3HeadlineSolFamN wg) w) hτ0' hsin
      have hmz := hbox i τ ⟨le_trans ham hτ.1, hτ.2⟩
      have habs : |src τ| ≤
          Real.exp (-(200 * (bgpScale : ℝ) * τ)) * (5 * D_U) := by
        dsimp only [src]
        rw [abs_mul, abs_of_nonneg (hAαgZ_nonneg τ hτ0')]
        exact mul_le_mul hgate hmz (abs_nonneg _) (Real.exp_pos _).le
      calc F τ ≤ 1 * |src τ| :=
            mul_le_mul_of_nonneg_right hWle1 (abs_nonneg _)
        _ = |src τ| := one_mul _
        _ ≤ Real.exp (-(200 * (bgpScale : ℝ) * τ)) * (5 * D_U) := habs
    have hg_cont : Continuous fun τ : ℝ =>
        Real.exp (-(200 * (bgpScale : ℝ) * τ)) * (5 * D_U) := by
      have hexp_cont : Continuous fun τ : ℝ =>
          Real.exp (-(200 * (bgpScale : ℝ) * τ)) :=
        Real.continuous_exp.comp
          ((continuous_const.mul continuous_id).neg)
      exact hexp_cont.mul continuous_const
    have hmono := intervalIntegral.integral_mono_on hmb
      (hF_cont.intervalIntegrable (μ := MeasureTheory.volume) m b)
      (hg_cont.intervalIntegrable (μ := MeasureTheory.volume) m b) hpoint
    have hmass : (∫ τ in m..b, Real.exp (-(200 * (bgpScale : ℝ) * τ))) ≤
        Real.exp (-(200 * (bgpScale : ℝ) * m)) / (200 * (bgpScale : ℝ)) :=
      paper3N_exp_mass_from_le (by positivity) hmb
    have hsplit_mul : (∫ τ in m..b,
        Real.exp (-(200 * (bgpScale : ℝ) * τ)) * (5 * D_U)) =
        (∫ τ in m..b, Real.exp (-(200 * (bgpScale : ℝ) * τ))) *
          (5 * D_U) := by
      rw [intervalIntegral.integral_mul_const]
    have hEle1 : Real.exp (-(200 * (bgpScale : ℝ) * m)) ≤ 1 := by
      rw [show (1 : ℝ) = Real.exp 0 from Real.exp_zero.symm]
      apply Real.exp_le_exp.mpr
      nlinarith [hm0, hs0.le]
    have hfin : (∫ τ in m..b, Real.exp (-(200 * (bgpScale : ℝ) * τ))) *
        (5 * D_U) ≤ 1 / 20 := by
      have hInn : 0 ≤ ∫ τ in m..b, Real.exp (-(200 * (bgpScale : ℝ) * τ)) := by
        apply intervalIntegral.integral_nonneg hmb
        intro τ _
        exact (Real.exp_pos _).le
      have h1 : (∫ τ in m..b, Real.exp (-(200 * (bgpScale : ℝ) * τ))) *
          (5 * D_U) ≤
          (Real.exp (-(200 * (bgpScale : ℝ) * m)) /
            (200 * (bgpScale : ℝ))) * (5 * D_U) :=
        mul_le_mul_of_nonneg_right hmass hB0
      have h2 : (Real.exp (-(200 * (bgpScale : ℝ) * m)) /
          (200 * (bgpScale : ℝ))) * (5 * D_U) ≤ 1 / 20 := by
        rw [div_mul_eq_mul_div, div_le_iff₀ (by positivity :
          (0 : ℝ) < 200 * (bgpScale : ℝ))]
        have h3 : Real.exp (-(200 * (bgpScale : ℝ) * m)) * (5 * D_U) ≤
            1 * (5 * D_U) := mul_le_mul_of_nonneg_right hEle1 hB0
        nlinarith [h3, hDle, hs0.le]
      linarith
    calc (∫ τ in m..b, F τ)
        ≤ ∫ τ in m..b, Real.exp (-(200 * (bgpScale : ℝ) * τ)) * (5 * D_U) :=
          hmono
      _ = (∫ τ in m..b, Real.exp (-(200 * (bgpScale : ℝ) * τ))) *
            (5 * D_U) := hsplit_mul
      _ ≤ 1 / 20 := hfin
  have hgoal : (∫ τ in a..b, F τ) ≤ 1 := by
    rw [hsplit]
    linarith
  exact hgoal

/-- **THE INTER-READ MIXTURE BOX, AS A NAMED HYPOTHESIS (F1-N input 6).**
TRUE at the actual N solutions, but NOT derivable from the crude
boundary-tube + window-envelope data (which admit an
`O(bgpScale·e^{200})`-displaced `z` at read time whose u-copy the branch
evaluations then amplify by `B_U` per cycle).  The discharge is the
one-cycle settled machinery (Leg B: write-window λ-concentration
⟹ `z` settled `≈ enc(cfg (j+1))` at `wr j`; then the copy keeps all stack
coordinates inside the `[−1, 1]` hull where
`branchU_evalBranch_abs_le_two_D_U`-type bounds give `|mix| ≤ 2·D_U`, and
interval trapping keeps `|z|, |u| ≤ 3·D_U` through the inter-read).

Field 1: `|mix − z| ≤ 5·D_U` on `[wr j, zOffEnd j]` (feeds the retimed
source cap).  Field 2: `|mix − u| ≤ 5·D_U` on `[zOffEnd j, ws (j+1)]`
(feeds the no-slop prewrite trapping `paper3N_prewrite_zu_hold`). -/
def Paper3F1InterReadMixBoxN (wg w : ℕ) : Prop :=
  ∀ j : ℕ,
    (∀ i, paper3F1BoundaryErrN wg w j i ≤
      paper3F1TubeRadiusN paper3F1CwinDefN) →
    (∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamN wg) w).z t i -
        ((paper3HeadlineSolFamN wg) w).u t i| ≤ paper3F1CwinDefN) →
    (∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUWriteReadTime j)
        (selectorMUZOffEnd j),
      |selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam τ i -
        ((paper3HeadlineSolFamN wg) w).z τ i| ≤ 5 * D_U) ∧
    (∀ i : Fin d_U, ∀ τ ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1)),
      |selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
          ((paper3HeadlineSolFamN wg) w).lam τ i -
        ((paper3HeadlineSolFamN wg) w).u τ i| ≤ 5 * D_U)

/-- **F1-N ANALYTIC INPUT (4/5) AS A NAMED HYPOTHESIS — NOT YET SOUNDLY
STATABLE AS A PROOF OBLIGATION.**  The tube-conditional source decay with the
diagonal-quantitative coefficient.  ⚠️ As a plain clone this is STILL FALSE:
`paper3F1GeomCap w Csrc ≤ r_LE_U/4` forces `Csrc ≲ 6^{-(|w|+1)}·10⁻⁴`, but
`paper3F1SrcCoreN wg w 0 i` contains the `w`-INDEPENDENT cycle-0 u-drift legs
(`δuWritePrefixN`/`δuSettledN ≈ e^{-225·bgpScale}`) at the input-stack
coordinate — see the layer header.  Consumed as a hypothesis at the plain N
family; the word-coupled carrier `paper3HeadlineSolFamNW` (on which the
statement is TRUE) is `paper3F1_src_geo_quantitative_NW` below. -/
def Paper3F1SrcGeoQuantitativeN (wg w : ℕ) : Prop :=
  ∃ Csrc : ℝ, 0 ≤ Csrc ∧
    paper3F1GeomCap w Csrc ≤ r_LE_U / 4 ∧
    ∀ j : ℕ,
      (∀ i, paper3F1BoundaryErrN wg w j i ≤
        paper3F1TubeRadiusN paper3F1CwinDefN) →
      (∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamN wg) w).z t i -
          ((paper3HeadlineSolFamN wg) w).u t i| ≤ paper3F1CwinDefN) →
      ∀ i, paper3F1SrcCoreN wg w j i ≤
        Csrc * Real.exp (-(2 : ℝ) * (j : ℝ))

/-- **F1-N ANALYTIC INPUT (5/5) AS A NAMED HYPOTHESIS — NOT YET SOUNDLY
STATABLE AS A PROOF OBLIGATION.**  The diagonal warm-gain cycle-`0` weighted
boundary budget.  ⚠️ As a plain clone this is STILL FALSE at the input-stack
coordinate: `W0N i = 6^{|w|+1}·|u(π/6) i - enc i|` with the cycle-0 u-gate
leak `|u(π/6) - enc|_i ≈ Ω(1)/(250·bgpScale)²` `w`-independent (the warm gain
`g₀` enters only the λ-replicator, never the u-gate), so the bound fails from
`|w| ≈ 4` on — see the layer header for the fix options (clock head start
`μ(0) ≈ 4·(|w|+1)` or a `wg`-linear factor in `cμ`).  Consumed as a
hypothesis at the plain N family; the word-coupled carrier
`paper3HeadlineSolFamNW` (on which the statement is TRUE) is
`paper3F1_W0_quarter_NW` below. -/
def Paper3F1W0QuarterN (wg w : ℕ) : Prop :=
  ∀ i, paper3F1W0N wg w i ≤ r_LE_U / 4

/-- **THE JOINT F1-N CORE, ASSEMBLED** from the PROVED N inputs (1/5)–(3/5)
(the (3/5) source cap in its retimed-at-`zOffEnd` form) and the three named
hypotheses: (4/5)–(5/5) plus the inter-read mixture box
(`Paper3F1InterReadMixBoxN`).  The endpoint recurrence `hnext_of` now runs
in two legs: the retimed transport
`selector_replicator_zOffEnd_zu_of_read_zu_and_interRead_source_N` with the
kernel-mass comparison `selectorInterRead_kernel_le_uActiveMass_N_zOff`
(read box contracts, source `≤ 1`), then the no-slop prewrite trapping
`paper3N_prewrite_zu_hold` across `[zOffEnd j, ws (j+1)]` (the ctrl-jump
pre-write is absorbed by the `5·D_U ≤ 10·bgpScale` mix box, the second
branch of the `max` in `paper3F1EzuDefN`). -/
theorem paper3F1_joint_step_core_N (wg w : ℕ)
    (hsrcgeo : Paper3F1SrcGeoQuantitativeN wg w)
    (hW0q : Paper3F1W0QuarterN wg w)
    (hmixbox : Paper3F1InterReadMixBoxN wg w)
    (hdiag : wg = w := by first | rfl | assumption) :
    Nonempty (Paper3F1JointStepCoreN wg w) := by
  obtain ⟨Csrc, hCsrc0, hcap, hsrc⟩ := hsrcgeo
  have hb := paper3F1_window_relaxation_bootstrap_N wg w
  have hE0 := paper3F1_cycle0_endpoint_N wg w
  have hsrcCap := paper3F1_interRead_source_cap_N wg w
  have hs1 : (1 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_one
  -- the cycle-`j` window envelope released by the bootstrap at the
  -- recurrence endpoint
  have hwin_all : ∀ j : ℕ,
      (∀ i, paper3F1BoundaryErrN wg w j i ≤
        paper3F1TubeRadiusN paper3F1CwinDefN) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i| ≤
          paper3F1EzuDefN j) →
      ∀ i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamN wg) w).z t i -
          ((paper3HeadlineSolFamN wg) w).u t i| ≤
          max (paper3F1EzuDefN j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
            (bgpScale : ℝ) :=
    fun j htube hend =>
      hb j (paper3F1EzuDefN j) (paper3F1EzuDefN_nonneg j)
        (paper3F1EzuDefN_le_ten j)
        (fun i => le_trans (htube i) paper3F1TubeRadiusN_CwinDefN_le) hend
  refine ⟨{ Cwin := paper3F1CwinDefN
            Csrc := Csrc
            Ezu := paper3F1EzuDefN
            hCwin0 := paper3F1CwinDefN_nonneg
            hCwin_le := paper3F1CwinDefN_le_scale_exp200
            hCsrc0 := hCsrc0
            hE0 := ?_
            hwin_of := ?_
            hnext_of := ?_
            hsrc_geo_of := ?_
            hbudget_half := ?_ }⟩
  · -- hE0
    intro i
    rw [paper3F1EzuDefN_zero]
    exact hE0 i
  · -- hwin_of
    intro j htube hend i t ht
    exact le_trans (hwin_all j htube hend i t ht)
      (paper3F1EzuDefN_window_le j)
  · -- hnext_of
    intro j htube hend i
    have hwin := hwin_all j htube hend
    have hread : ∀ i' : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteReadTime j) i' -
          ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteReadTime j) i'| ≤
          max (paper3F1EzuDefN j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
            (bgpScale : ℝ) :=
      fun i' => hwin i' (selectorMUWriteReadTime j)
        ⟨selectorMUWriteStart_le_read j, le_refl _⟩
    have hwinC : ∀ i' : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamN wg) w).z t i' -
          ((paper3HeadlineSolFamN wg) w).u t i'| ≤ paper3F1CwinDefN :=
      fun i' t ht => le_trans (hwin i' t ht) (paper3F1EzuDefN_window_le j)
    obtain ⟨hboxZ, hboxU⟩ := hmixbox j htube hwinC
    have hsource := hsrcCap j hboxZ
    have htrans :=
      selector_replicator_zOffEnd_zu_of_read_zu_and_interRead_source_N
        (paper3HeadlineSolFamN wg) w j hread hsource
    have hτmem : selectorMUWriteReadTime j ∈
        Icc (selectorMUWriteReadTime j) (selectorMUUActiveStart j) := by
      constructor
      · exact le_refl _
      · unfold selectorMUWriteReadTime selectorMUUActiveStart
        linarith [Real.pi_pos]
    have hker := selectorInterRead_kernel_le_uActiveMass_N_zOff
      ((paper3HeadlineSolFamN wg) w) j hτmem
    have hBread0 : 0 ≤ max (paper3F1EzuDefN j)
        ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ) := by
      have h1 := le_max_right (paper3F1EzuDefN j)
        ((bgpScale : ℝ) * Real.exp (198 : ℝ))
      have h2 : (0 : ℝ) ≤ (bgpScale : ℝ) * Real.exp (198 : ℝ) := by
        positivity
      have h3 : (0 : ℝ) ≤ (bgpScale : ℝ) := by positivity
      linarith
    have hmul := mul_le_mul_of_nonneg_right hker hBread0
    -- endpoint at `zOffEnd j`: contraction on the read box + retimed cap
    have hzOff : ∀ i' : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).z (selectorMUZOffEnd j) i' -
          ((paper3HeadlineSolFamN wg) w).u (selectorMUZOffEnd j) i'| ≤
          Real.exp (-(selectorInterReadUActiveMassLowerN j)) *
            (max (paper3F1EzuDefN j)
              ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ)) + 1 := by
      intro i'
      have h := htrans i'
      linarith [h, hmul]
    -- prewrite hold across `[zOffEnd j, ws (j+1)]` (no-slop trapping)
    have hhold := paper3N_prewrite_zu_hold wg w j hzOff hboxU i
    have hDle : (D_U : ℝ) ≤ 2 * (bgpScale : ℝ) := D_U_le_two_bgpScale
    have hmax_le : max (Real.exp (-(selectorInterReadUActiveMassLowerN j)) *
          (max (paper3F1EzuDefN j)
            ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ)) + 1)
        ((5 : ℝ) * D_U) ≤ paper3F1EzuDefN (j + 1) := by
      rw [paper3F1EzuDefN_succ]
      exact max_le_max (le_refl _) (by linarith)
    exact le_trans hhold hmax_le
  · -- hsrc_geo_of
    intro j htube hend i
    have hwinC : ∀ i' : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFamN wg) w).z t i' -
          ((paper3HeadlineSolFamN wg) w).u t i'| ≤ paper3F1CwinDefN :=
      fun i' t ht => le_trans (hwin_all j htube hend i' t ht)
        (paper3F1EzuDefN_window_le j)
    exact hsrc j htube hwinC i
  · -- hbudget_half
    intro i
    have h1 := hW0q i
    linarith [hcap]

/-- **The N invariant-threaded tube induction**: the write-start boundary
tube AND the write-start `z-u` endpoint hold at every cycle of the N family,
given a joint core.  Mirrors `paper3F1_joint_tube_and_endpoint`; the generic
engine `paper3F1_tube_and_invariant_of_conditional_step_normalized` is reused
(it is family-agnostic in the coordinate function `u`). -/
theorem paper3F1_joint_tube_and_endpoint_N (wg w : ℕ)
    (core : Paper3F1JointStepCoreN wg w) :
    ∀ j, (∀ i, paper3F1BoundaryErrN wg w j i ≤
        paper3F1TubeRadiusN core.Cwin) ∧
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFamN wg) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j) := by
  have hreserve_half :
      δuWritePrefixN core.Cwin 0 + δuSettledN core.Cwin 0 ≤ r_LE_U / 2 :=
    paper3F1_delta_reserveN_of_envelope_le core.hCwin_le
