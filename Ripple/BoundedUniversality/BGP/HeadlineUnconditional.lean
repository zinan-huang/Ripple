    simp only [bGateU]
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamNW w) w).cont_μ.mul hq).neg)
  have hkZ_cont : Continuous kZ :=
    (continuous_const.mul ((paper3HeadlineSolFamNW w) w).cont_α).mul
