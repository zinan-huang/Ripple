    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUZOffEnd j
    let b : ℝ := selectorMUWriteStartTime (j + 1)
    let Creset : ℝ :=
      ((Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
        (Fintype.card UniversalLocalView : ℝ)
    (∫ τ in a..b,
      selectorMUHoffGateCoeff sol w τ *
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => (sol w).lam v τ))
      ≤
    (∫ τ in a..b,
      selectorMUHoffGateCoeff sol w τ *
        (B0 * Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a))) +
          (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
            (gap * Lsafe))) := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let a : ℝ := selectorMUZOffEnd j
  let b : ℝ := selectorMUWriteStartTime (j + 1)
  let Creset : ℝ :=
    ((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)
  let resetBd : ℝ :=
    (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
      (gap * Lsafe)
  let k : ℝ → ℝ := fun τ => selectorMUHoffGateCoeff sol w τ
  let bad : ℝ → ℝ := fun τ =>
    (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
      (fun v => (sol w).lam v τ)
  let major : ℝ → ℝ := fun τ =>
    B0 * Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a))) +
      resetBd
  have hab : a ≤ b := by
    simpa [a, b] using selectorMUZOffEnd_le_writeStart_succ j
  have ha_nonneg : 0 ≤ a := by
    dsimp [a]
    unfold selectorMUZOffEnd
    positivity
  have hk_cont : Continuous k := by
    dsimp [k, selectorMUHoffGateCoeff]
    exact selector_replicator_gateZ_integrand_continuous (sol w)
  have hbad_cont : Continuous bad := by
    dsimp [bad, sol]
    simpa using
      (continuous_finsetSum
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1))))
        (fun v _hv => ((paper3HeadlineSolFam wg) w).cont_lam v))
  have hmajor_cont : Continuous major := by
    have hG_cont : Continuous fun τ : ℝ => (sol w).G τ := (sol w).cont_G
    have hsub_cont :
        Continuous fun τ : ℝ => (sol w).G τ - (sol w).G a :=
      hG_cont.sub continuous_const
    have hscaled_cont :
        Continuous fun τ : ℝ =>
          -((gap * Lsafe) * ((sol w).G τ - (sol w).G a)) :=
      (continuous_const.mul hsub_cont).neg
    have hdecay_cont :
        Continuous fun τ : ℝ =>
          Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a))) :=
      Real.continuous_exp.comp hscaled_cont
    dsimp [major, resetBd]
    exact (continuous_const.mul hdecay_cont).add continuous_const
  have hleft_int : IntervalIntegrable (fun τ => k τ * bad τ)
      MeasureTheory.volume a b :=
    (hk_cont.mul hbad_cont).intervalIntegrable a b
  have hright_int : IntervalIntegrable (fun τ => k τ * major τ)
      MeasureTheory.volume a b :=
    (hk_cont.mul hmajor_cont).intervalIntegrable a b
  have hpoint : ∀ τ ∈ Icc a b, k τ * bad τ ≤ k τ * major τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans ha_nonneg hτ.1
    have hk_nonneg : 0 ≤ k τ := by
      dsimp [k, selectorMUHoffGateCoeff, sol]
      exact selector_replicator_gateZ_integrand_nonneg
        ((paper3HeadlineSolFam wg) w)
        selectorSchedule_domain_of_nonneg_structural
        (by norm_num [bgpParams38])
        hτ0
    have hbad :=
      paper3HeadlinePrewriteOldNewBadMassDuhamelSharp
        (wg := wg) (w := w) (j := j)
        (B0 := B0) (Lsafe := Lsafe)
        hgapL_pos hsafe_floor hpair hBa τ
        (by simpa [a, b] using hτ)
    exact mul_le_mul_of_nonneg_left
      (by
        simpa [bad, major, resetBd, sol, gap, a, Creset,
          mul_assoc, mul_left_comm, mul_comm] using hbad)
      hk_nonneg
  have hmono :=
    intervalIntegral.integral_mono_on hab hleft_int hright_int hpoint
  simpa [k, bad, major, resetBd, sol, gap, a, b, Creset,
    mul_assoc, mul_left_comm, mul_comm] using hmono

/-- Linearized Hoff-weighted prewrite Duhamel bound.  This separates the
transported initial bad mass from the reset-source constant times the same
Hoff gate integral. -/
theorem paper3HeadlinePrewriteOldNewBadMassHoffIntegralDuhamelSplit
    (wg w j : ℕ) {B0 Lsafe : ℝ}
    (hgapL_pos :
      0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        Lsafe)
    (hsafe_floor : ∀ t ∈
      Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      Lsafe ≤
        (insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView)).sum
          (fun u => ((paper3HeadlineSolFam wg) w).lam u t))
    (hpair : ∀ t ∈
      Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      ∀ v : UniversalLocalView,
        v ∉ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
    (hBa :
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => ((paper3HeadlineSolFam wg) w).lam v
            (selectorMUZOffEnd j)) ≤ B0) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUZOffEnd j
    let b : ℝ := selectorMUWriteStartTime (j + 1)
    let Creset : ℝ :=
      ((Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
        (Fintype.card UniversalLocalView : ℝ)
    let resetBd : ℝ :=
      (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
        (gap * Lsafe)
    (∫ τ in a..b,
      selectorMUHoffGateCoeff sol w τ *
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => (sol w).lam v τ))
      ≤
    B0 *
      (∫ τ in a..b,
        selectorMUHoffGateCoeff sol w τ *
          Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a)))) +
      resetBd *
        (∫ τ in a..b, selectorMUHoffGateCoeff sol w τ) := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let a : ℝ := selectorMUZOffEnd j
  let b : ℝ := selectorMUWriteStartTime (j + 1)
  let Creset : ℝ :=
    ((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)
  let resetBd : ℝ :=
    (Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) * Creset) /
      (gap * Lsafe)
  let k : ℝ → ℝ := fun τ => selectorMUHoffGateCoeff sol w τ
  let decay : ℝ → ℝ := fun τ =>
    Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a)))
  have hraw :=
    paper3HeadlinePrewriteOldNewBadMassHoffIntegralDuhamelRaw
      (wg := wg) (w := w) (j := j)
      (B0 := B0) (Lsafe := Lsafe)
      hgapL_pos hsafe_floor hpair hBa
  have hk_cont : Continuous k := by
    dsimp [k, selectorMUHoffGateCoeff, sol]
    exact selector_replicator_gateZ_integrand_continuous
      ((paper3HeadlineSolFam wg) w)
  have hG_cont : Continuous fun τ : ℝ => (sol w).G τ := (sol w).cont_G
  have hsub_cont :
      Continuous fun τ : ℝ => (sol w).G τ - (sol w).G a :=
    hG_cont.sub continuous_const
  have hscaled_cont :
      Continuous fun τ : ℝ =>
        -((gap * Lsafe) * ((sol w).G τ - (sol w).G a)) :=
    (continuous_const.mul hsub_cont).neg
  have hdecay_cont : Continuous decay := by
    dsimp [decay]
    exact Real.continuous_exp.comp hscaled_cont
  have hterm1_int : IntervalIntegrable (fun τ => B0 * (k τ * decay τ))
      MeasureTheory.volume a b :=
    (continuous_const.mul (hk_cont.mul hdecay_cont)).intervalIntegrable a b
  have hterm2_int : IntervalIntegrable (fun τ => resetBd * k τ)
      MeasureTheory.volume a b :=
    (continuous_const.mul hk_cont).intervalIntegrable a b
  have hlin :
      (∫ τ in a..b,
        k τ * (B0 * decay τ + resetBd)) =
      B0 * (∫ τ in a..b, k τ * decay τ) +
        resetBd * (∫ τ in a..b, k τ) := by
    calc
      (∫ τ in a..b,
        k τ * (B0 * decay τ + resetBd))
          =
        (∫ τ in a..b,
          B0 * (k τ * decay τ) + resetBd * k τ) := by
            congr
            ext τ
            ring
      _ =
        (∫ τ in a..b, B0 * (k τ * decay τ)) +
          (∫ τ in a..b, resetBd * k τ) := by
            rw [intervalIntegral.integral_add hterm1_int hterm2_int]
      _ =
        B0 * (∫ τ in a..b, k τ * decay τ) +
          resetBd * (∫ τ in a..b, k τ) := by
            rw [intervalIntegral.integral_const_mul,
              intervalIntegral.integral_const_mul]
  calc
    (∫ τ in a..b,
      k τ *
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => (sol w).lam v τ))
        ≤
      ∫ τ in a..b, k τ * (B0 * decay τ + resetBd) := by
        simpa [sol, gap, a, b, Creset, resetBd, k, decay,
          mul_assoc, mul_left_comm, mul_comm] using hraw
    _ =
      B0 * (∫ τ in a..b, k τ * decay τ) +
        resetBd * (∫ τ in a..b, k τ) := hlin
    _ =
      B0 *
        (∫ τ in a..b,
          selectorMUHoffGateCoeff sol w τ *
            Real.exp (-((gap * Lsafe) * ((sol w).G τ - (sol w).G a)))) +
        resetBd *
          (∫ τ in a..b, selectorMUHoffGateCoeff sol w τ) := by
          simp [k, decay]

theorem paper3HeadlineSolFam_initial_values (wg w : ℕ) :
      (∀ i : Fin d_U,
        ((paper3HeadlineSolFam wg) w).z 0 i =
          ((selectorInitX0 w i : ℚ) : ℝ)) ∧
      (∀ i : Fin d_U,
        ((paper3HeadlineSolFam wg) w).u 0 i =
          ((selectorInitX0 w i : ℚ) : ℝ)) ∧
      (∀ v : UniversalLocalView,
        ((paper3HeadlineSolFam wg) w).lam v 0 =
          ((1 / (Fintype.card UniversalLocalView : ℚ)) : ℝ)) ∧
      ((paper3HeadlineSolFam wg) w).G 0 = 0 := by
  classical
  let ex :=
    selector_replicator_sol_exists_MU paper3HeadlineEta paper3HeadlineEta_pos
      paper3HeadlineM paper3HeadlineKappa (paper3WarmGainQ wg)
      paper3HeadlineHP paper3HeadlineKq paper3HeadlineR selectorInitX0 w
      (paper3HeadlineHFin wg w)
      (paper3HeadlineHGateZ wg w)
      (paper3HeadlineHGateU wg w)
      (paper3HeadlineHChiReset wg w)
      (paper3HeadlineHChiGate wg w)
      (paper3HeadlineHKappa wg w)
      (paper3HeadlineHGain wg w)
      (paper3HeadlineHPval wg w)
  have hspec := ex.choose_spec
  have hsol : (paper3HeadlineSolFam wg) w = ex.choose := by
    dsimp [ex]
    unfold paper3HeadlineSolFam solMUReplWarm
    rw [solMURepl_def]
  refine ⟨?_, ?_, ?_, ?_⟩
  · intro i
    rw [hsol]
    exact hspec.2.2.1 i
  · intro i
    rw [hsol]
    simpa [selectorReplicatorEuclInitQ, selU, selOfContract, contractU, contractTailU]
      using hspec.2.2.2.1 i
  · intro v
    rw [hsol]
    exact hspec.2.2.2.2.1 v
  · rw [hsol]
    exact hspec.2.2.2.2.2.1

