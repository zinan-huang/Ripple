def paper3HeadlineEta : ℚ :=
  1 / (144 * Fintype.card UniversalLocalView)

theorem paper3HeadlineEta_pos : 0 < paper3HeadlineEta := by
  have hN : (0 : ℚ) < Fintype.card UniversalLocalView := by
    exact_mod_cast (Fintype.card_pos_iff.mpr ⟨defaultLocalViewU⟩ :
      0 < Fintype.card UniversalLocalView)
  unfold paper3HeadlineEta
  exact div_pos zero_lt_one (mul_pos (by norm_num) hN)

/-- The five universal gate atoms carry total error `9 * eta`. -/
theorem paper3UniversalGateAtoms_errSel (eta : ℚ) (heta : 0 < eta) :
    (gateSelectorAtomsCoordN (universalGateAtoms eta heta)).errSel =
      9 * (eta : ℝ) := by
  rw [GateSelectorAtomsN.errSel, Fin.sum_univ_five]
  simp [gateSelectorAtomsCoordN, CoordAtomData.toAtomicSelectorData,
    universalGateAtoms, controlAtom, mainPairAtom, stackTopAtom, CoordAtomData.relabel,
    IntervalAtomSpec.toCoordAtomData, SlabAtomicSelectorData.toCoordAtomData,
    controlAtomSlab, finiteCoordinateAtoms, stackTopAtomSpec, mainPairAtomSpec]
  ring

theorem paper3HeadlineHerr :
    (gateSelectorAtomsCoordN
        (universalGateAtoms paper3HeadlineEta paper3HeadlineEta_pos)).errSel < 1 / 2 := by
  rw [paper3UniversalGateAtoms_errSel]
  have hN_nat : 0 < Fintype.card UniversalLocalView :=
    Fintype.card_pos_iff.mpr ⟨defaultLocalViewU⟩
  have hN : (0 : ℝ) < Fintype.card UniversalLocalView := by
    exact_mod_cast hN_nat
  have hN_one : (1 : ℝ) ≤ Fintype.card UniversalLocalView := by
    exact_mod_cast (Nat.succ_le_of_lt hN_nat)
  unfold paper3HeadlineEta
  push_cast
  field_simp [ne_of_gt hN]
  nlinarith [hN_one]

/-- On a universal configuration tube, every selector payoff lies in `[-1/2,1/2]`;
therefore any pairwise payoff difference is at most `1`. -/
theorem paper3Headline_universalPval_sub_le_one_of_utube
    {eta : ℚ} {heta : 0 < eta} {c : UConf} {x : Fin d_U → ℝ}
    (hutube : UTube r_LE_U c x) (v u : UniversalLocalView) :
    universalPval eta heta v x - universalPval eta heta u x ≤ 1 := by
  let atoms := gateSelectorAtomsCoordN (universalGateAtoms eta heta)
  have hwork : atoms.inWorkingDomain x := by
    simpa [atoms] using universalGateAtoms_inWorkingDomain eta heta hutube
  have hLv_le_one :
      LambdaN universalViewSpecN atoms x v ≤ 1 := by
    rw [LambdaN_factor]
    exact Finset.prod_le_one
      (fun k _hk =>
        ((atoms.atom k).range (universalViewSpecN.comp k v) x (hwork k)).1)
      (fun k _hk =>
        ((atoms.atom k).range (universalViewSpecN.comp k v) x (hwork k)).2)
  have hLu_nonneg :
      0 ≤ LambdaN universalViewSpecN atoms x u := by
    rw [LambdaN_factor]
    exact Finset.prod_nonneg (fun k _hk =>
      ((atoms.atom k).range (universalViewSpecN.comp k u) x (hwork k)).1)
  dsimp [universalPval, atoms] at hLv_le_one hLu_nonneg ⊢
  linarith

