set_option maxHeartbeats 1600000 in
/-- N-parametric lower bound of the actual u-gate mass on the u-active
inter-read subwindow. -/
theorem selectorInterReadUActiveMassLowerNW_le_integral (sW : ℕ)
    {eta : ℚ} {heta : 0 < eta} {Mcy : ℕ} {κ₀ g₀ : ℚ}
    (sol : SelectorReplicatorDynSol d_U B_U UniversalLocalView (bgpParamsNW sW) selectorSchedule
      branchU
      (fun t => ((1 + Real.cos t) / 2) ^ Mcy)
      (fun t => ((1 + Real.sin t) / 2) ^ Mcy)
      (fun _ => (κ₀ : ℝ))
      (fun t => (g₀ : ℝ) * Real.exp ((bgpParamsNW sW).cα * t))
      (universalPval eta heta))
    (j : ℕ) :
    selectorInterReadUActiveMassLowerNW sW j ≤
      ∫ s in (selectorMUUActiveStart j)..(selectorMUUActiveEnd j),
        (bgpParamsNW sW).A * sol.α s * bGateU (bgpParamsNW sW).L (sol.μ s) s := by
  let a : ℝ := selectorMUUActiveStart j
  let b : ℝ := selectorMUUActiveEnd j
  let c : ℝ := Real.exp (300 * (bgpScaleW sW : ℝ) * a) *
    Real.exp (-(1000 * (bgpScaleW sW : ℝ) * b * (1 / 4 : ℝ)))
  have hab : a ≤ b := by
    dsimp [a, b, selectorMUUActiveStart, selectorMUUActiveEnd]
    linarith [Real.pi_pos]
  have ha0 : 0 ≤ a := by
    dsimp [a, selectorMUUActiveStart]
    nlinarith [Real.pi_pos, (Nat.cast_nonneg j : (0 : ℝ) ≤ (j : ℝ))]
  have hg_cont : Continuous fun s : ℝ =>
      (bgpParamsNW sW).A * sol.α s * bGateU (bgpParamsNW sW).L (sol.μ s) s := by
    have hq : Continuous fun s : ℝ => qPulse (bgpParamsNW sW).L s := by
      simp only [qPulse]
      exact ((continuous_const.add Real.continuous_sin).div_const 2).pow
        (bgpParamsNW sW).L
    have hgateU : Continuous fun s : ℝ =>
        bGateU (bgpParamsNW sW).L (sol.μ s) s := by
      simp only [bGateU]
      exact Real.continuous_exp.comp (((sol.cont_μ).mul hq).neg)
    simpa [mul_assoc] using
      ((continuous_const.mul sol.cont_α).mul hgateU)
  have hpoint : ∀ s ∈ Icc a b, c ≤
      (bgpParamsNW sW).A * sol.α s * bGateU (bgpParamsNW sW).L (sol.μ s) s := by
    intro s hs
    have hs0 : 0 ≤ s := le_trans ha0 hs.1
    have hαs : sol.α s = Real.exp ((bgpParamsNW sW).cα * s) :=
      sol.alpha_eq_exp selectorSchedule_domain_of_nonneg_structural hs0
    have hμs : sol.μ s = (bgpParamsNW sW).cμ * s := by
      rw [sol.mu_eq_linear selectorSchedule_domain_of_nonneg_structural hs0,
        sol.μ_at_zero, zero_add]
    have hsin : Real.sin s ≤ -(1 / 2 : ℝ) := by
      apply sin_window_le_neg_half j
      · simpa [a, selectorMUUActiveStart] using hs.1
      · simpa [b, selectorMUUActiveEnd] using hs.2
    have hαle : Real.exp (300 * (bgpScaleW sW : ℝ) * a) ≤
        Real.exp (300 * (bgpScaleW sW : ℝ) * s) := by
      refine Real.exp_le_exp.mpr
        (mul_le_mul_of_nonneg_left hs.1 ?_)
      nlinarith [bgpScaleWR_pos sW]
    have hgate_active :
        Real.exp (-(sol.μ s * (1 / 4 : ℝ) ^ (bgpParamsNW sW).L)) ≤
          bGateU (bgpParamsNW sW).L (sol.μ s) s :=
      bGateU_ge_active (bgpParamsNW sW).L
        (by rw [hμs]; exact mul_nonneg (bgpParamsNW_cμ_pos sW).le hs0)
        hsin
    have hgate_floor :
        Real.exp (-(1000 * (bgpScaleW sW : ℝ) * b * (1 / 4 : ℝ))) ≤
          bGateU (bgpParamsNW sW).L (sol.μ s) s := by
      have hfloor :
          Real.exp (-(1000 * (bgpScaleW sW : ℝ) * b * (1 / 4 : ℝ))) ≤
            Real.exp (-(sol.μ s * (1 / 4 : ℝ) ^ (bgpParamsNW sW).L)) := by
        apply Real.exp_le_exp.mpr
        rw [hμs, (bgpParamsNW_cμ_def sW)]
        have hL : (bgpParamsNW sW).L = 1 := rfl
        rw [hL, pow_one]
        have h1000s : (0 : ℝ) ≤ 1000 * (bgpScaleW sW : ℝ) := by
          nlinarith [bgpScaleWR_pos sW]
        nlinarith [mul_le_mul_of_nonneg_left hs.2 h1000s]
      exact le_trans hfloor hgate_active
    have hmul := mul_le_mul hαle hgate_floor (Real.exp_pos _).le (Real.exp_pos _).le
    calc
      c ≤ Real.exp (300 * (bgpScaleW sW : ℝ) * s) *
          bGateU (bgpParamsNW sW).L (sol.μ s) s := hmul
      _ = (bgpParamsNW sW).A * sol.α s * bGateU (bgpParamsNW sW).L (sol.μ s) s := by
        have hcα : (bgpParamsNW sW).cα * s = 300 * (bgpScaleW sW : ℝ) * s := by
          rw [(bgpParamsNW_cα_def sW)]
        rw [hαs, hcα, (bgpParamsNW_A_eq sW), one_mul]
  have hmono :
      (∫ _s in a..b, c) ≤
        ∫ s in a..b,
          (bgpParamsNW sW).A * sol.α s * bGateU (bgpParamsNW sW).L (sol.μ s) s :=
    intervalIntegral.integral_mono_on hab _root_.intervalIntegrable_const
      (hg_cont.intervalIntegrable a b) hpoint
  have hconst :
      (∫ _s in a..b, c) = c * (b - a) := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
    ring
  have hmass :
      selectorInterReadUActiveMassLowerNW sW j = c * (b - a) := by
    show Real.exp (300 * (bgpScaleW sW : ℝ) * selectorMUUActiveStart j) *
      Real.exp (-(1000 * (bgpScaleW sW : ℝ) * selectorMUUActiveEnd j * (1 / 4 : ℝ))) *
        ((2 : ℝ) * Real.pi / 3) = c * (b - a)
    have hba : b - a = 2 * Real.pi / 3 := by
      dsimp [a, b, selectorMUUActiveStart, selectorMUUActiveEnd]
      ring
    rw [hba]
  calc
    selectorInterReadUActiveMassLowerNW sW j = c * (b - a) := hmass
    _ = ∫ _s in a..b, c := hconst.symm
    _ ≤ ∫ s in a..b,
          (bgpParamsNW sW).A * sol.α s * bGateU (bgpParamsNW sW).L (sol.μ s) s := hmono


