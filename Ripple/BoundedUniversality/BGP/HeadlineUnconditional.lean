        rw [div_mul_eq_mul_div, le_div_iff₀ hgpos]
        have hgoal_eq : 2 ^ paper3HeadlineM *
            Real.exp (-((bgpParamsNW wg).cα * a)) *
            ((1 / 2 : ℝ) ^ paper3HeadlineM *
              (((paper3WarmGainQNW wg : ℚ) : ℝ) *
                Real.exp ((bgpParamsNW wg).cα * a))) =
            ((2 : ℝ) ^ paper3HeadlineM * (1 / 2 : ℝ) ^ paper3HeadlineM) *
              (Real.exp (-((bgpParamsNW wg).cα * a)) *
                Real.exp ((bgpParamsNW wg).cα * a)) *
              ((paper3WarmGainQNW wg : ℚ) : ℝ) := by
          ring
        rw [hgoal_eq, hpow_cancel, hexp_cancel]
        linarith
      calc ((1 + Real.cos s) / 2) ^ paper3HeadlineM *
