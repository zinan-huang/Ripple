          paper3N_one_le_two_D_U)
  · exact (by
      simpa [revStackCoordU, stackCoordU] using
        (paper3N_confEncU_stack_abs_le_one c K'.rev).trans
          paper3N_one_le_two_D_U)
  · exact (by
      simpa [auxStackCoordU, stackCoordU] using
        (paper3N_confEncU_stack_abs_le_one c K'.aux).trans
          paper3N_one_le_two_D_U)
  · exact (by
      simpa [dataStackCoordU, stackCoordU] using
        (paper3N_confEncU_stack_abs_le_one c K'.stack).trans
          paper3N_one_le_two_D_U)
  · exact (by
      simpa [ctrlCoordU] using
          paper3N_ctrlVarCodeU_abs_le_two_D_U c.1 c.2.1)
  · exact (by
      simpa [haltCoordU] using
