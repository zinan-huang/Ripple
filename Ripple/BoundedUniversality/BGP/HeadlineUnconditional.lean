theorem paper3WarmGainQ_nonneg (w : ℕ) :
    0 ≤ ((paper3WarmGainQ w : ℚ) : ℝ) := by
  have hpow : 0 ≤ ((6 : ℚ) ^ w : ℚ) := pow_nonneg (by norm_num) w
  have hmul : 0 ≤ (paper3WarmGainQ w : ℚ) := by
    unfold paper3WarmGainQ paper3WarmGainC
    exact mul_nonneg (by norm_num) hpow
  exact_mod_cast hmul

