/-!  ### Canonical z-u witnesses as LEAST envelopes

The canonical prefix/tail `|z-u|` witnesses used by the weighted F1 surface
were previously `Classical.choose` of bare existence statements.  That made
the weighted-input obligations `hBpre_le` (an upper bound on the chosen
prefix witness) and `hnorm_tsum` (which subtracts `δuSettled` of the chosen
tail witness) *formally unprovable*: the choose specs are upward-closed
envelope properties, satisfied by arbitrarily large functions, so no upper
bound on the opaque witness is derivable.

Instead we define the witnesses as the `sInf` of the set of valid envelopes.
The spec statements are unchanged (the set is nonempty via the finite-horizon
bound, bounded below by `0`, and the infimum is itself a valid envelope by
`le_csInf`), and the witnesses acquire the crucial *minimality* property:
they are `≤` every valid envelope (`csInf_le`).  This is what lets a genuine
uniform analytic bound transfer to the canonical witnesses. -/

/-- Valid all-coordinate `|z-u|` envelopes on the settled tail window of
cycle `j`. -/
def paper3F1TailZuSet (wg w j : ℕ) : Set ℝ :=
  {B : ℝ | 0 ≤ B ∧
    ∀ i, ∀ t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFam wg) w).z t i -
        ((paper3HeadlineSolFam wg) w).u t i| ≤ B}

theorem paper3F1TailZuSet_nonempty (wg w j : ℕ) :
    (paper3F1TailZuSet wg w j).Nonempty := by
  obtain ⟨B, hB0, hB⟩ := paper3HeadlineF1_tail_zu_bound wg w
  exact ⟨B j, hB0 j, fun i t ht => hB j i t ht⟩

theorem paper3F1TailZuSet_bddBelow (wg w j : ℕ) :
    BddBelow (paper3F1TailZuSet wg w j) :=
  ⟨0, fun _B hB => hB.1⟩

noncomputable def paper3F1CanonicalBzu (wg w : ℕ) : ℕ → ℝ :=
  fun j => sInf (paper3F1TailZuSet wg w j)

/-- Minimality of the canonical tail witness: it is bounded by every valid
tail envelope.  This is the property the old `Classical.choose` witness could
never provide. -/
theorem paper3F1CanonicalBzu_le (wg w j : ℕ) {B : ℝ}
    (hB : B ∈ paper3F1TailZuSet wg w j) :
    paper3F1CanonicalBzu wg w j ≤ B :=
  csInf_le (paper3F1TailZuSet_bddBelow wg w j) hB

theorem paper3F1CanonicalBzu_spec (wg w : ℕ) :
    (∀ j, 0 ≤ paper3F1CanonicalBzu wg w j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteHoldTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤
            paper3F1CanonicalBzu wg w j) := by
  constructor
  · intro j
    exact le_csInf (paper3F1TailZuSet_nonempty wg w j) (fun _B hB => hB.1)
  · intro j i t ht
    exact le_csInf (paper3F1TailZuSet_nonempty wg w j)
      (fun _B hB => hB.2 i t ht)

/-- Valid all-coordinate `|z-u|` envelopes on the write-prefix window of
cycle `j`. -/
def paper3F1PrefixZuSet (wg w j : ℕ) : Set ℝ :=
  {B : ℝ | 0 ≤ B ∧
    ∀ i, ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUWriteHoldTime j),
      |((paper3HeadlineSolFam wg) w).z t i -
        ((paper3HeadlineSolFam wg) w).u t i| ≤ B}

theorem paper3F1PrefixZuSet_nonempty (wg w j : ℕ) :
    (paper3F1PrefixZuSet wg w j).Nonempty := by
  obtain ⟨B, hB0, hB⟩ := paper3HeadlineF1_prefix_zu_bound wg w
  exact ⟨B j, hB0 j, fun i t ht => hB j i t ht⟩

theorem paper3F1PrefixZuSet_bddBelow (wg w j : ℕ) :
    BddBelow (paper3F1PrefixZuSet wg w j) :=
  ⟨0, fun _B hB => hB.1⟩

noncomputable def paper3F1CanonicalBpre (wg w : ℕ) : ℕ → ℝ :=
  fun j => sInf (paper3F1PrefixZuSet wg w j)

/-- Minimality of the canonical prefix witness: it is bounded by every valid
prefix envelope. -/
theorem paper3F1CanonicalBpre_le (wg w j : ℕ) {B : ℝ}
    (hB : B ∈ paper3F1PrefixZuSet wg w j) :
    paper3F1CanonicalBpre wg w j ≤ B :=
  csInf_le (paper3F1PrefixZuSet_bddBelow wg w j) hB

theorem paper3F1CanonicalBpre_spec (wg w : ℕ) :
    (∀ j, 0 ≤ paper3F1CanonicalBpre wg w j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteHoldTime j),
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤
            paper3F1CanonicalBpre wg w j) ∧
      (∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteHoldTime j),
        |((paper3HeadlineSolFam wg) w).u t i -
          ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤
            δuWritePrefix (paper3F1CanonicalBpre wg w j) j) := by
  have h0 : ∀ j, 0 ≤ paper3F1CanonicalBpre wg w j := fun j =>
    le_csInf (paper3F1PrefixZuSet_nonempty wg w j) (fun _B hB => hB.1)
  have hzu : ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteHoldTime j),
      |((paper3HeadlineSolFam wg) w).z t i -
        ((paper3HeadlineSolFam wg) w).u t i| ≤
          paper3F1CanonicalBpre wg w j := by
    intro j i t ht
    exact le_csInf (paper3F1PrefixZuSet_nonempty wg w j)
      (fun _B hB => hB.2 i t ht)
  refine ⟨h0, hzu, ?_⟩
  intro j i t ht
  exact
    u_drift_on_write_prefix_window
      ((paper3HeadlineSolFam wg) w) j i (h0 j)
      selectorSchedule_domain_of_nonneg_structural
      (hzu j i) t ht

/-- Direct non-geometric F1 input surface.

This is the live replacement for the old endpoint-geometric scaffold.  It asks
only for the facts consumed by the canonical residual: a uniform prefix `z-u`
envelope for the chosen prefix witness, summability of the weighted defects, and
the normalized coupled tail reserve for the chosen tail witness. -/
structure Paper3HeadlineF1CanonicalWordWeightedInputs (wg w : ℕ) where
  Cpre : ℝ
  hCpre0 : 0 ≤ Cpre
  hBpre_le : ∀ j, paper3F1CanonicalBpre wg w j ≤ Cpre
  hTsum : ∀ i,
    Summable (fun m =>
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1Eta wg w) m i)
  hnorm_tsum : ∀ j i,
    (paper3F1W0 wg w i +
          ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
            (paper3F1Eta wg w) m i) /
        (B_U : ℝ) ^ paper3F1Depth w j i ≤
      r_LE_U - δuWritePrefix Cpre 0 -
        δuSettled (paper3F1CanonicalBzu wg w j) j

/-! ### Discharge of the multiplier-step inputs: reduction to the
tube-conditional analytic core

`paper3F1_multiplier_step_inputs` is proved here by reducing it to a single
tube-conditional producer surface (`Paper3F1ConditionalStepCore`): the raw
one-cycle multiplier step and its geometric source bound are only required
*given the cycle-`j` write-start boundary tube* — the shape the
settled-window loser-mass machinery actually produces, since the payoff gap
(`selector_replicator_hgap_of_utube`) needs the cycle-`j` readout tube.  The
circularity — the tube is exactly what the induction proves — is broken once
and for all by the **normalized** tube-conditional weighted induction below:
the weighted budget `W(j)` releases the cycle-`j` boundary tube through the
depth-normalized cap `W(j) ≤ r·B_U^{dep(j,i)}` (NOT the lossy unweighted cap
`W(j) ≤ r` of
`DirectTrackingInduction.trackingErr_le_tube_of_conditional_step_geometric`,
which a `B_U^{|w|}`-sized weighted budget could never satisfy).  The
normalized reserve is the quantitative F1 budget itself, so the `hbudget`
field of the multiplier-step surface and the tube unlock of the induction
consume the *same* core estimate `hbudget_geom`. -/

/-- The F1 boundary error is the write-start `trackingErr` of
`DirectTrackingInduction` on the static configuration orbit. -/
theorem paper3F1BoundaryErr_eq_trackingErr
    (wg w j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErr wg w j i =
      trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i := rfl

/-- Pointwise form of the `branchU` stack-operation contract: the branch
diagonal multiplier is bounded by `B_U ^ coordDelta` (pop `= B_U^1`,
push `= B_U^{-1}`, stay/replace `= B_U^0`); reset coordinates have
multiplier `0 ≤ 1 = B_U^0`.  This is the pointwise strengthening of
`selectorMU_coordMultiplier_error_le_BUpow_coordDelta`. -/
theorem paper3F1_coordMultiplier_le_BUpow_coarseDelta
    (w j : ℕ) (i : Fin d_U) :
    stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i ≤
      (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i := by
  unfold selectorMUCoarseDelta
  unfold StackMachineEncoding.coordMultiplier StackMachineEncoding.coordDelta
    StackMachineEncoding.stackMultiplier
  cases h : stackMachineEncodingU.coordStackIndex i with
  | none => simp
  | some s => exact le_rfl

/-- **Normalized tube-conditional weighted cycle induction.**  The
`HeadlineUnconditional` instance of
`DirectTrackingInduction.le_weightedMajorant_of_conditional_weighted_step`:
the one-cycle step and the geometric excess bound are required only *given
the cycle-`j` tube of radius `r`*, and the tube is recovered at each cycle
from the weighted bound through the depth-normalized reserve
`W0 + e^{L·log k}·Cη/(1 - e^{log k - lam}) ≤ r·k^{dep(j,i)}` — the weighted
budget is compared against `r·k^{dep}`, never against the bare radius, so
the `k^{L}`-sized initial weight does not have to fit inside the tube. -/
theorem paper3F1_trackingErr_le_tube_of_conditional_step_normalized
    (u : ℝ → Fin d_U → ℝ) (cfg : ℕ → UConf) (mark : ℕ → ℝ)
    {k r : ℝ} (hk : 1 < k)
    (dep delta : ℕ → Fin d_U → ℤ) (ηc : ℕ → Fin d_U → ℝ)
    {W0 L Cη lam : ℝ}
    (hCη : 0 ≤ Cη) (hrate : Real.log k < lam)
    (hdepth : ∀ j (i : Fin d_U), dep (j + 1) i = dep j i - delta j i)
    (hgrow : ∀ j (i : Fin d_U), ((dep (j + 1) i : ℤ) : ℝ) ≤ L + (j : ℝ))
    (hbase : ∀ i : Fin d_U, k ^ dep 0 i * trackingErr u cfg mark 0 i ≤ W0)
    (hstep : ∀ j, (∀ i, trackingErr u cfg mark j i ≤ r) →
      ∀ i, trackingErr u cfg mark (j + 1) i ≤
        k ^ delta j i * trackingErr u cfg mark j i + ηc j i)
    (hηc_nonneg : ∀ j (i : Fin d_U), 0 ≤ ηc j i)
    (hη_dom : ∀ j, (∀ i, trackingErr u cfg mark j i ≤ r) →
      ∀ i, ηc j i ≤ Cη * Real.exp (-lam * (j : ℝ)))
    (hreserve : ∀ j (i : Fin d_U),
      W0 + Real.exp (Real.log k * L) * Cη *
          (1 / (1 - Real.exp (Real.log k - lam))) ≤ r * k ^ dep j i) :
    ∀ j i, trackingErr u cfg mark j i ≤ r := by
  have hcapW : ∀ j, weightedMajorant W0
      (fun m => Real.exp (Real.log k * L) * Real.exp (Real.log k * (m : ℝ)))
      (fun m => Cη * Real.exp (-lam * (m : ℝ))) j ≤
      W0 + Real.exp (Real.log k * L) * Cη *
        (1 / (1 - Real.exp (Real.log k - lam))) :=
    weightedMajorant_le_geomCap
      (Cg := Real.exp (Real.log k * L)) (Cη := Cη)
      (β := Real.log k) (lam := lam)
      (Real.exp_pos _).le hCη hrate
      (fun m => mul_nonneg hCη (Real.exp_pos _).le)
      (fun m => le_rfl) (fun m => le_rfl)
  have hunlock : ∀ j,
      (∀ i, k ^ dep j i * trackingErr u cfg mark j i ≤
        weightedMajorant W0
          (fun m => Real.exp (Real.log k * L) *
            Real.exp (Real.log k * (m : ℝ)))
          (fun m => Cη * Real.exp (-lam * (m : ℝ))) j) →
      ∀ i, trackingErr u cfg mark j i ≤ r := by
    intro j hw i
    have hpow_pos : (0 : ℝ) < k ^ dep j i :=
      zpow_pos (lt_trans zero_lt_one hk) _
    have hchain : k ^ dep j i * trackingErr u cfg mark j i ≤
        r * k ^ dep j i :=
      le_trans (hw i) (le_trans (hcapW j) (hreserve j i))
    rw [mul_comm (k ^ dep j i) (trackingErr u cfg mark j i)] at hchain
    exact le_of_mul_le_mul_right hchain hpow_pos
  have hweighted :=
    le_weightedMajorant_of_conditional_weighted_step
      (trackingErr u cfg mark) hk dep delta ηc
      (W0 := W0)
      (g := fun m => Real.exp (Real.log k * L) *
        Real.exp (Real.log k * (m : ℝ)))
      (η := fun m => Cη * Real.exp (-lam * (m : ℝ)))
      hdepth
      (fun j hw => hstep j (hunlock j hw))
      hbase
      (zpow_dep_le_exp_linear hk hgrow)
      hηc_nonneg
      (fun j hw => hη_dom j (hunlock j hw))
  intro j i
  exact hunlock j (fun i' => hweighted j i') i

/-- The F1 boundary-tube radius released by the window `z-u` envelope: what
remains of the readout tube `r_LE_U` after paying the cycle-`0` prefix and
settled `u`-drift reserves (both are monotone in the cycle index, so the
cycle-`0` values dominate all cycles). -/
def paper3F1TubeRadius (Cwin : ℝ) : ℝ :=
  r_LE_U - δuWritePrefix Cwin 0 - δuSettled Cwin 0

/-- Closed geometric cap of the weighted-defect tail with source constant
`Csrc` at rate `lam = 2`:
`e^{log B_U·(|w|+1)}·Csrc/(1 - e^{log B_U - 2})`. -/
def paper3F1GeomCap (w : ℕ) (Csrc : ℝ) : ℝ :=
  Real.exp (Real.log (B_U : ℝ) *
      (MachineInstance.inputLenU 1 w : ℝ)) * Csrc *
    (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2)))

/-- **The remaining tube-conditional analytic core (F1).**  Everything the
multiplier-step surface needs, in the exact conditional shapes the
settled-window machinery produces.  `hstep`/`hsrc_geo` may assume the
cycle-`j` write-start boundary tube of radius `paper3F1TubeRadius Cwin`
(which, through `hzu_win` and the `u`-drift envelopes
`δuWritePrefix`/`δuSettled`, releases the full write-window readout tube
`UTube r_LE_U` that the loser-mass payoff gap
`selector_replicator_hgap_of_utube` consumes); the assembly below turns them
into unconditional bounds via the normalized tube-conditional weighted
induction, whose reserve is the quantitative budget `hbudget_geom`.

Discharge route (all rates far above `log B_U`):

* `hstep` chains one cycle `ws j → hold j → read j → ws (j+1)`:
  settled write contraction toward the mixture (`z_write_settled_endpoint`
  with `selector_settled_writeIntegral_lower_lbd_repl`); mixture near the
  winner target with radius
  `Rspread·epsLam(j) + mult(j,i)·(BErr(j,i) + δu(j))`
  (`mixTarget_near_next_on_settled_window` shape — the `mult·BErr` term is
  the comparison term of the raw step, everything else goes into `src`);
  `z-u` endpoint transport at `ws (j+1)`
  (`selector_replicator_writeStart_zu_of_read_zu_and_interRead_source` with
  the inter-read u-active kernel mass,
  `selectorInterReadUActiveMassLower_ge_linear`).  The read-time `|z-u|`
  box is `paper3HeadlineF1_tail_zu_bound`; the window drifts come from
  `hzu_win` through
  `u_drift_on_settled_window`/`u_drift_on_write_prefix_window`.
* `hsrc_geo`: `epsLam` decays through the gain gap `ΔG(j) → ∞` under the
  cycle-`j` tube (concentration); the write-window contraction residuals
  decay through `selectorSettledWriteIntLower`/`selectorEarlyWriteIntLower`
  (both doubly exponential —
  `WriteHoldRecurrence.holdSource_le_geometric` shows even an
  `exp(50·ws(j+1))`-growing inter-read cap is annihilated with an `e^{-2j}`
  margin to spare); the `u`-drift/`z-u` legs decay at the qPulse off-phase
  rate `selectorUSettledRate = 450` per unit time.
* `hzu_win`: all-cycle window `z-u` envelope — geometric `z-u` write-start
  endpoints plus per-window increment control
  (`CoupledEndpointDecay.exists_bound_of_tendsto_zero_nonneg` shape).  Note
  the window `|z-u|` need not (and does not) tend to `0`; only boundedness
  is asserted.
* `hbudget_geom`: the irreducible quantitative F1 budget — the cycle-`0`
  weighted boundary error plus the closed geometric cap fit inside the tube
  radius.  This single field powers BOTH the tube unlock of the normalized
  induction (through `B_U^{dep} ≥ 1`) and the final `hbudget` of the
  multiplier-step surface (through the tsum comparison against the
  geometric series).

CIRCULARITY GUARD: none of these may be routed through the downstream
full-`u`-tube / concentration machinery
(`paper3HeadlineFullUTubeCoupledTailInputsAll`,
`paper3HeadlineFullUTubeResidual`, `paper3HeadlineShiftedConcentrationAt`,
...) — that machinery consumes the residual assembled from
`paper3F1_multiplier_step_inputs` itself.  The cycle-`j` tube is available
*for free* as the conditional hypothesis of `hstep`/`hsrc_geo`. -/
structure Paper3F1ConditionalStepCore (wg w : ℕ) where
  src : ℕ → Fin d_U → ℝ
  Csrc : ℝ
  Cwin : ℝ
  hCsrc0 : 0 ≤ Csrc
  hCwin0 : 0 ≤ Cwin
  hsrc_nonneg : ∀ j i, 0 ≤ src j i
  hzu_win : ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
    |((paper3HeadlineSolFam wg) w).z t i -
      ((paper3HeadlineSolFam wg) w).u t i| ≤ Cwin
  hstep : ∀ j,
    (∀ i, paper3F1BoundaryErr wg w j i ≤ paper3F1TubeRadius Cwin) →
    ∀ i, paper3F1BoundaryErr wg w (j + 1) i ≤
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErr wg w j i + src j i
  hsrc_geo : ∀ j,
    (∀ i, paper3F1BoundaryErr wg w j i ≤ paper3F1TubeRadius Cwin) →
    ∀ i, src j i ≤ Csrc * Real.exp (-(2 : ℝ) * (j : ℝ))
  hbudget_geom : ∀ i,
    paper3F1W0 wg w i + paper3F1GeomCap w Csrc ≤ paper3F1TubeRadius Cwin

/-- Canonical positive-part one-cycle source for the conditional core: the
excess of the next boundary error over the *exact* per-coordinate multiplier
comparison term (`coordMultiplier`, not its `B_U^delta` majorant — so this
source is the smallest one for which the raw multiplier step holds).  With
this choice the `hstep` field of `Paper3F1ConditionalStepCore` is *algebraic*
(`le_max_right`), `hsrc_nonneg` is free, and the entire analytic weight of
the core is concentrated in `paper3F1_core_constants` below: the geometric
decay of this excess under the cycle-`j` tube, the all-cycle window `z-u`
envelope, and the quantitative budget. -/
def paper3F1SrcCore (wg w : ℕ) : ℕ → Fin d_U → ℝ :=
  fun j i =>
    max (0 : ℝ)
      (paper3F1BoundaryErr wg w (j + 1) i -
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          paper3F1BoundaryErr wg w j i)

theorem paper3F1SrcCore_nonneg (wg w : ℕ) :
    ∀ j i, 0 ≤ paper3F1SrcCore wg w j i := by
  intro j i
  unfold paper3F1SrcCore
  exact le_max_left _ _

/-- The raw one-cycle multiplier step is algebraic for the canonical
positive-part source — unconditionally, hence a fortiori under the
cycle-`j` tube. -/
theorem paper3F1_boundaryErr_succ_le_mult_add_srcCore
    (wg w j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErr wg w (j + 1) i ≤
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErr wg w j i + paper3F1SrcCore wg w j i := by
  have h : paper3F1BoundaryErr wg w (j + 1) i -
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErr wg w j i ≤ paper3F1SrcCore wg w j i := by
    unfold paper3F1SrcCore
    exact le_max_right _ _
  linarith

/-- **The Leg-A reserve inequality is astronomically slack**: any envelope
constant below `e^{200}` pays the cycle-`0` prefix and settled `u`-drift
reserves out of half the readout tube.  Indeed
`δuWritePrefix Cwin 0 = Cwin·(π/3)·e^{-450·π/6}` and
`δuSettled Cwin 0 = Cwin·(π/3)·e^{-450·π/2}` with `450·π/6 = 75π > 225`,
so the sum is at most `2·(π/3)·e^{200-225} ≤ (8/3)·e^{-25} < 1/2000 =
r_LE_U/2`.  The eventual envelope discharge therefore only has to avoid a
doubly-exponentially-large constant, nothing more. -/
theorem paper3F1_delta_reserve_of_envelope_le
    {Cwin : ℝ} (hCwin_le : Cwin ≤ Real.exp (200 : ℝ)) :
    δuWritePrefix Cwin 0 + δuSettled Cwin 0 ≤ r_LE_U / 2 := by
  have hrate : selectorUSettledRate = 450 := by
    norm_num [selectorUSettledRate, bgpParams38]
  have hws0 : selectorMUWriteStartTime 0 = Real.pi / 6 := by
    norm_num [selectorMUWriteStartTime]
  have hwh0 : selectorMUWriteHoldTime 0 = Real.pi / 2 := by
    norm_num [selectorMUWriteHoldTime]
  -- both cycle-`0` exponents are at most `-225`
  have hexp_pre :
      Real.exp (-(selectorUSettledRate * selectorMUWriteStartTime 0)) ≤
        Real.exp (-(225 : ℝ)) := by
    rw [hrate, hws0]
    exact Real.exp_le_exp.mpr (by nlinarith [Real.pi_gt_three])
  have hexp_set :
      Real.exp (-(selectorUSettledRate * selectorMUWriteHoldTime 0)) ≤
        Real.exp (-(225 : ℝ)) := by
    rw [hrate, hwh0]
    exact Real.exp_le_exp.mpr (by nlinarith [Real.pi_gt_three])
  -- `e^{25} ≥ 2^{25} ≥ 6000`
  have h2e : (2 : ℝ) ≤ Real.exp 1 := by
    have := Real.add_one_le_exp (1 : ℝ)
    linarith
  have hexp25 : (6000 : ℝ) ≤ Real.exp (25 : ℝ) := by
    have hpow : Real.exp 1 ^ (25 : ℕ) = Real.exp (25 : ℝ) := by
      rw [← Real.exp_nat_mul]
      norm_num
    calc (6000 : ℝ) ≤ (2 : ℝ) ^ (25 : ℕ) := by norm_num
      _ ≤ Real.exp 1 ^ (25 : ℕ) := pow_le_pow_left₀ (by norm_num) h2e 25
      _ = Real.exp (25 : ℝ) := hpow
  have hexp_neg25 : Real.exp (-(25 : ℝ)) ≤ 1 / 6000 := by
    rw [Real.exp_neg, inv_eq_one_div]
    exact one_div_le_one_div_of_le (by norm_num) hexp25
  -- one reserve leg caps at `(π/3)·e^{-25} ≤ 1/4500`
  have hcap :
      Real.exp (200 : ℝ) * (Real.pi / 3 * Real.exp (-(225 : ℝ))) ≤
        1 / 4500 := by
    have hprod :
        Real.exp (200 : ℝ) * Real.exp (-(225 : ℝ)) =
          Real.exp (-(25 : ℝ)) := by
      rw [← Real.exp_add]
      norm_num
    have heq :
        Real.exp (200 : ℝ) * (Real.pi / 3 * Real.exp (-(225 : ℝ))) =
          Real.pi / 3 * (Real.exp (200 : ℝ) * Real.exp (-(225 : ℝ))) := by
      ring
    rw [heq, hprod]
    have hπ43 : Real.pi / 3 ≤ 4 / 3 := by linarith [Real.pi_le_four]
    calc Real.pi / 3 * Real.exp (-(25 : ℝ))
        ≤ (4 / 3 : ℝ) * (1 / 6000) :=
          mul_le_mul hπ43 hexp_neg25 (Real.exp_pos _).le (by norm_num)
      _ ≤ 1 / 4500 := by norm_num
  have hfrac_pre_nonneg :
      0 ≤ Real.pi / 3 *
        Real.exp (-(selectorUSettledRate * selectorMUWriteStartTime 0)) := by
    positivity
  have hfrac_set_nonneg :
      0 ≤ Real.pi / 3 *
        Real.exp (-(selectorUSettledRate * selectorMUWriteHoldTime 0)) := by
    positivity
  have h1 :
      Cwin * (Real.pi / 3 *
          Real.exp (-(selectorUSettledRate * selectorMUWriteStartTime 0))) ≤
        Real.exp (200 : ℝ) * (Real.pi / 3 * Real.exp (-(225 : ℝ))) :=
    mul_le_mul hCwin_le
      (mul_le_mul_of_nonneg_left hexp_pre (by positivity))
      hfrac_pre_nonneg (Real.exp_pos _).le
  have h2 :
      Cwin * (Real.pi / 3 *
          Real.exp (-(selectorUSettledRate * selectorMUWriteHoldTime 0))) ≤
        Real.exp (200 : ℝ) * (Real.pi / 3 * Real.exp (-(225 : ℝ))) :=
    mul_le_mul hCwin_le
      (mul_le_mul_of_nonneg_left hexp_set (by positivity))
      hfrac_set_nonneg (Real.exp_pos _).le
  have hr : r_LE_U / 2 = 1 / 2000 := by
    norm_num [r_LE_U]
  dsimp [δuWritePrefix, δuSettled]
  rw [hr]
  linarith

/-! ### The joint per-cycle core: no unconditional all-time fact remains

The Leg-A envelope is all-time boundedness of `z-u`, which (the mix expands
by `B_U = 6` per relaxation, so no a-priori invariant box exists) is
*equivalent* to the all-cycle tracking tube — it cannot be produced ahead of
the tube induction.  The escape is the same as for the loser-mass circle:
a weaker consumer.  The normalized weighted induction below is extended to
carry an arbitrary per-cycle invariant `P` (instantiated with the write-start
`|z(ws j) - u(ws j)| ≤ Ezu j` endpoint bound), and every remaining analytic
demand is *per-cycle conditional* on the cycle-`j` tube together with `P j`:

* `hwin_of` — tube + endpoint at `ws j` release the window-`j` envelope
  (`u` is qPulse-frozen at rate `450`, `z` is trapped in the hull of its
  start value and the `λ`-mixture range, which the tube keeps `O(1)`);
* `hnext_of` — the endpoint is transported to `ws (j+1)`
  (`selector_replicator_writeStart_zu_of_read_zu_and_interRead_source`
  with the read-time box supplied by `hwin_of` at the SAME cycle, and the
  inter-read u-active kernel mass
  `selectorInterReadUActiveMassLower_ge_linear`); the sequence `Ezu` is a
  free field, so the producer may take the actual recurrence solution
  `Ezu (j+1) = e^{-mass_j}·Cwin + Bsrc j` (bounded: `e^{-mass_j} ≤
  min(1, e^{8-2j})`, so it accumulates additively for `j ≤ 4` and then
  contracts);
* `hsrc_geo_of` — the Leg-B source decay, now with the endpoint available
  as well (strictly weaker than the previous `henv`-global form).

The induction then yields the tube AND the endpoint at every cycle, hence
the unconditional envelope, hence both legs.  The two quantitative demands
(`hCwin_le : Cwin ≤ e^{200}` for the reserve; `hbudget_half` against
`r_LE_U/2`) are exactly the ones the previous split already carried. -/

/-- **Invariant-threaded normalized tube induction.**  The
`paper3F1_trackingErr_le_tube_of_conditional_step_normalized` engine with an
extra per-cycle invariant `P` carried through the induction: the source
domination may consume BOTH the cycle-`j` tube and `P j`, and `P` advances
one cycle at a time using the tube just established (`hPstep`).  The
one-cycle step itself is required unconditionally — the canonical
positive-part source makes it algebraic
(`paper3F1_boundaryErr_succ_le_mult_add_srcCore`). -/
theorem paper3F1_tube_and_invariant_of_conditional_step_normalized
    (P : ℕ → Prop)
    (u : ℝ → Fin d_U → ℝ) (cfg : ℕ → UConf) (mark : ℕ → ℝ)
    {k r : ℝ} (hk : 1 < k)
    (dep delta : ℕ → Fin d_U → ℤ) (ηc : ℕ → Fin d_U → ℝ)
    {W0 L Cη lam : ℝ}
    (hCη : 0 ≤ Cη) (hrate : Real.log k < lam)
    (hdepth : ∀ j (i : Fin d_U), dep (j + 1) i = dep j i - delta j i)
    (hgrow : ∀ j (i : Fin d_U), ((dep (j + 1) i : ℤ) : ℝ) ≤ L + (j : ℝ))
    (hbase : ∀ i : Fin d_U, k ^ dep 0 i * trackingErr u cfg mark 0 i ≤ W0)
    (hP0 : P 0)
    (hPstep : ∀ j, (∀ i, trackingErr u cfg mark j i ≤ r) → P j → P (j + 1))
    (hstep : ∀ j i, trackingErr u cfg mark (j + 1) i ≤
        k ^ delta j i * trackingErr u cfg mark j i + ηc j i)
    (hηc_nonneg : ∀ j (i : Fin d_U), 0 ≤ ηc j i)
    (hη_dom : ∀ j, (∀ i, trackingErr u cfg mark j i ≤ r) → P j →
      ∀ i, ηc j i ≤ Cη * Real.exp (-lam * (j : ℝ)))
    (hreserve : ∀ j (i : Fin d_U),
      W0 + Real.exp (Real.log k * L) * Cη *
          (1 / (1 - Real.exp (Real.log k - lam))) ≤ r * k ^ dep j i) :
    ∀ j, (∀ i, trackingErr u cfg mark j i ≤ r) ∧ P j := by
  have hcapW : ∀ j, weightedMajorant W0
      (fun m => Real.exp (Real.log k * L) * Real.exp (Real.log k * (m : ℝ)))
      (fun m => Cη * Real.exp (-lam * (m : ℝ))) j ≤
      W0 + Real.exp (Real.log k * L) * Cη *
        (1 / (1 - Real.exp (Real.log k - lam))) :=
    weightedMajorant_le_geomCap
      (Cg := Real.exp (Real.log k * L)) (Cη := Cη)
      (β := Real.log k) (lam := lam)
      (Real.exp_pos _).le hCη hrate
      (fun m => mul_nonneg hCη (Real.exp_pos _).le)
      (fun m => le_rfl) (fun m => le_rfl)
  have hunlock : ∀ j,
      (∀ i, k ^ dep j i * trackingErr u cfg mark j i ≤
        weightedMajorant W0
          (fun m => Real.exp (Real.log k * L) *
            Real.exp (Real.log k * (m : ℝ)))
          (fun m => Cη * Real.exp (-lam * (m : ℝ))) j) →
      ∀ i, trackingErr u cfg mark j i ≤ r := by
    intro j hw i
    have hpow_pos : (0 : ℝ) < k ^ dep j i :=
      zpow_pos (lt_trans zero_lt_one hk) _
    have hchain : k ^ dep j i * trackingErr u cfg mark j i ≤
        r * k ^ dep j i :=
      le_trans (hw i) (le_trans (hcapW j) (hreserve j i))
    rw [mul_comm (k ^ dep j i) (trackingErr u cfg mark j i)] at hchain
    exact le_of_mul_le_mul_right hchain hpow_pos
  have hg_dom := zpow_dep_le_exp_linear hk hgrow
  have hmain : ∀ j,
      (∀ i, k ^ dep j i * trackingErr u cfg mark j i ≤
        weightedMajorant W0
          (fun m => Real.exp (Real.log k * L) *
            Real.exp (Real.log k * (m : ℝ)))
          (fun m => Cη * Real.exp (-lam * (m : ℝ))) j) ∧ P j := by
    intro j
    induction j with
    | zero =>
        refine ⟨fun i => ?_, hP0⟩
        rw [weightedMajorant_zero]
        exact hbase i
    | succ j ih =>
        obtain ⟨hw, hp⟩ := ih
        have htube := hunlock j hw
        have hηj := hη_dom j htube hp
        refine ⟨fun i => ?_, hPstep j htube hp⟩
        have hk0 : (0 : ℝ) ≤ k := (zero_lt_one.trans hk).le
        have hk_ne : k ≠ 0 := (zero_lt_one.trans hk).ne'
        have hpow_nonneg : 0 ≤ k ^ dep (j + 1) i := zpow_nonneg hk0 _
        have hone : k ^ dep (j + 1) i * trackingErr u cfg mark (j + 1) i ≤
            k ^ dep j i * trackingErr u cfg mark j i +
              k ^ dep (j + 1) i * ηc j i := by
          calc k ^ dep (j + 1) i * trackingErr u cfg mark (j + 1) i
              ≤ k ^ dep (j + 1) i *
                  (k ^ delta j i * trackingErr u cfg mark j i + ηc j i) :=
                mul_le_mul_of_nonneg_left (hstep j i) hpow_nonneg
            _ = k ^ (dep (j + 1) i + delta j i) *
                  trackingErr u cfg mark j i +
                  k ^ dep (j + 1) i * ηc j i := by
                rw [mul_add, ← mul_assoc, ← zpow_add₀ hk_ne]
            _ = k ^ dep j i * trackingErr u cfg mark j i +
                  k ^ dep (j + 1) i * ηc j i := by
                have hd : dep (j + 1) i + delta j i = dep j i := by
                  rw [hdepth j i]
                  abel
                rw [hd]
        have hdefect : k ^ dep (j + 1) i * ηc j i ≤
            (Real.exp (Real.log k * L) *
              Real.exp (Real.log k * (j : ℝ))) *
              (Cη * Real.exp (-lam * (j : ℝ))) := by
          have hg_nonneg : 0 ≤ Real.exp (Real.log k * L) *
              Real.exp (Real.log k * (j : ℝ)) :=
            le_trans hpow_nonneg (hg_dom j i)
          exact mul_le_mul (hg_dom j i) (hηj i) (hηc_nonneg j i) hg_nonneg
        calc k ^ dep (j + 1) i * trackingErr u cfg mark (j + 1) i
            ≤ k ^ dep j i * trackingErr u cfg mark j i +
                k ^ dep (j + 1) i * ηc j i := hone
          _ ≤ weightedMajorant W0
                (fun m => Real.exp (Real.log k * L) *
                  Real.exp (Real.log k * (m : ℝ)))
                (fun m => Cη * Real.exp (-lam * (m : ℝ))) j +
              (Real.exp (Real.log k * L) *
                Real.exp (Real.log k * (j : ℝ))) *
                (Cη * Real.exp (-lam * (j : ℝ))) :=
              add_le_add (hw i) hdefect
          _ = weightedMajorant W0
                (fun m => Real.exp (Real.log k * L) *
                  Real.exp (Real.log k * (m : ℝ)))
                (fun m => Cη * Real.exp (-lam * (m : ℝ))) (j + 1) :=
              (weightedMajorant_succ W0 _ _ j).symm
  intro j
  obtain ⟨hw, hp⟩ := hmain j
  exact ⟨hunlock j hw, hp⟩

/-- **THE JOINT PER-CYCLE F1 CORE.**  Every field is per-cycle conditional
on the cycle-`j` write-start boundary tube (radius
`paper3F1TubeRadius Cwin`) together with the cycle-`j` write-start
`|z - u|` endpoint bound `Ezu j` — the "cash as you go" shape the
settled-window producers actually deliver.  No unconditional all-time
statement is demanded anywhere.

Discharge routes (verified against the available producers):

* `hwin_of` (window envelope from tube + endpoint): the tube keeps
  `u(ws j)` within `r_LE_U` of `enc(cfg j) ∈ [0,1]` per coordinate; on
  `[ws j, wr j]` the `u`-gate is qPulse-off (`u_drift_on_write_prefix_window`
  / `u_drift_on_settled_window`, rate `selectorUSettledRate = 450`), so `u`
  is quasi-frozen and every branch eval of `u` is `O(1)` (`|evalBranch| ≤
  B_U·|u| + O(1)`); the `λ`-simplex invariants
  (`replicator_lam_coord_nonneg`, `replicator_lam_sum_eq_one_on_Ico`) keep
  the mixture in the convex hull, and the `z`-relaxation trapping
  (`scalar_relaxation_trapping_invariant` shape) confines `z` to the hull of
  `z(ws j)` (within `Ezu j` of the bounded `u(ws j)`) and the mixture range.
  A first-exit bootstrap closes the `u`-drift/envelope self-reference.  The
  resulting `Cwin` is an absolute `O(1)` constant — astronomically below
  `e^{200}`.
* `hnext_of` (endpoint transport):
  `selector_replicator_writeStart_zu_of_read_zu_and_interRead_source` with
  the kernel mass `selectorInterRead_kernel_le_uActiveMass` and
  `selectorInterReadUActiveMassLower_ge_linear`; the read-time `|z-u|` box
  is `hwin_of` at the SAME cycle (available from the two hypotheses).  `Ezu`
  is a free field: take the recurrence solution
  `Ezu (j+1) := e^{-mass_j}·Cwin + Bsrc j`, bounded since
  `e^{-mass_j} ≤ min(1, e^{8-2j})`
  (`exp_neg_selectorInterReadUActiveMassLower_le_geometric`).
* `hsrc_geo_of`: as in Leg B+C (see the
  `paper3F1_src_geo_and_budget_of_envelope` docstring for the full route:
  `mixTarget_near_next_on_settled_window`, `z_write_settled_endpoint`,
  `loser_mass_small_on_settled_window` via
  `selector_replicator_hgap_of_utube` — the tube hypothesis releases the
  gap; `selectorSettledWriteIntLower`/`selectorEarlyWriteIntLower`
  annihilate the growth-controlled inter-read cap with an `e^{-2j}` margin),
  now with the write-start endpoint additionally available.  Any
  `1/card`-degraded exponent must be beaten card-free (the
  `paper3S13_oldLoser_le_quarter` → `..._late_le_two_rate` two-pass floor
  pattern; the budget here has NO `card⁴` prefactor).
* `hbudget_half`: the irreducible warm-gain quantitative budget against
  `r_LE_U/2` — `CW0`-shape cycle-`0` weighted boundary (the `[0, π/6]`
  u-freeze at warm gain `g₀ = paper3WarmGainQ wg`, whose gate factor
  `e^{-c·g₀}` dominates `B_U^{|w|+1}` on the diagonal `wg = w`) plus the
  geometric cap.  See the Leg B+C docstring's quantitative discussion.
* `hE0`: single finite-horizon fact (`paper3F1TailM` at cycle `0`, or the
  exact `u(0) = enc(cfg 0)` initial values plus the `[0, π/6]` prefix
  drift).

CIRCULARITY GUARD (unchanged): nothing may be routed through the downstream
full-`u`-tube / concentration machinery
(`paper3HeadlineFullUTubeCoupledTailInputsAll`,
`paper3HeadlineFullUTubeResidual`, `paper3HeadlineShiftedConcentrationAt`,
...).  The cycle-`j` tube and endpoint are available for free as the
conditional hypotheses. -/
structure Paper3F1JointStepCore (wg w : ℕ) where
  Cwin : ℝ
  Csrc : ℝ
  Ezu : ℕ → ℝ
  hCwin0 : 0 ≤ Cwin
  hCwin_le : Cwin ≤ Real.exp (200 : ℝ)
  hCsrc0 : 0 ≤ Csrc
  hE0 : ∀ i : Fin d_U,
    |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime 0) i -
      ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime 0) i| ≤
      Ezu 0
  hwin_of : ∀ j,
    (∀ i, paper3F1BoundaryErr wg w j i ≤ paper3F1TubeRadius Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFam wg) w).z t i -
        ((paper3HeadlineSolFam wg) w).u t i| ≤ Cwin
  hnext_of : ∀ j,
    (∀ i, paper3F1BoundaryErr wg w j i ≤ paper3F1TubeRadius Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        ((paper3HeadlineSolFam wg) w).u
          (selectorMUWriteStartTime (j + 1)) i| ≤ Ezu (j + 1)
  hsrc_geo_of : ∀ j,
    (∀ i, paper3F1BoundaryErr wg w j i ≤ paper3F1TubeRadius Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i, paper3F1SrcCore wg w j i ≤
      Csrc * Real.exp (-(2 : ℝ) * (j : ℝ))
  hbudget_half : ∀ i,
    paper3F1W0 wg w i + paper3F1GeomCap w Csrc ≤ r_LE_U / 2

/-! #### Joint-core constants: the explicit window envelope and the
endpoint recurrence

The joint core's data fields are pinned to EXPLICIT values so that the five
remaining analytic producers below are fully decoupled from one another:

* `Cwin := e^{199} + 11` — astronomically above the actual `O(1)` window
  envelope, but below the `e^{200}` δu-reserve ceiling `hCwin_le` demands;
* `Ezu` — the exact recurrence solution of the endpoint transport:
  `Ezu 0 = e^{199}` (crude cycle-`0` bound) and
  `Ezu (j+1) = e^{-mass_j}·(max (Ezu j) e^{198} + 1) + 1`, where
  `max (Ezu j) e^{198} + 1` is the window envelope the bootstrap releases
  from an endpoint `≤ Ezu j` and `mass_j = selectorInterReadUActiveMassLower
  j` is the inter-read u-kernel mass.  Since `e^{-mass_j} ≤ min 1 (e^{8-2j})`
  (`selectorInterReadUActiveMassLower_ge_linear`), the recurrence grows by at
  most `+2` per cycle for `j ≤ 4` and contracts by `e^{-2}` afterwards, so
  `Ezu j ≤ e^{199} + 2·min j 5 ≤ e^{199} + 10` and every window envelope
  `max (Ezu j) e^{198} + 1` fits below `Cwin`. -/

/-- The explicit F1 joint-core window-envelope constant `e^{199} + 11`. -/
def paper3F1CwinDef : ℝ := Real.exp (199 : ℝ) + 11

theorem paper3F1CwinDef_nonneg : 0 ≤ paper3F1CwinDef := by
  unfold paper3F1CwinDef
  positivity

theorem paper3F1CwinDef_le_exp200 :
    paper3F1CwinDef ≤ Real.exp (200 : ℝ) := by
  unfold paper3F1CwinDef
  have hsplit : Real.exp (200 : ℝ) = Real.exp (199 : ℝ) * Real.exp 1 := by
    rw [← Real.exp_add]; norm_num
  have h2 : (2 : ℝ) ≤ Real.exp 1 := by
    have := Real.exp_one_gt_d9
    linarith
  have h11 : (11 : ℝ) ≤ Real.exp (199 : ℝ) := by
    have := Real.add_one_le_exp (199 : ℝ)
    linarith
  have hmul := mul_le_mul_of_nonneg_left h2 (Real.exp_pos (199 : ℝ)).le
  rw [hsplit]
  linarith

/-- The explicit endpoint recurrence of the joint core (see the section
header): `Ezu 0 = e^{199}`, `Ezu (j+1) = e^{-mass_j}·(W j) + 1` with
`W j := max (Ezu j) e^{198} + 1` the cycle-`j` window envelope. -/
def paper3F1EzuDef : ℕ → ℝ
  | 0 => Real.exp (199 : ℝ)
  | j + 1 =>
      Real.exp (-(selectorInterReadUActiveMassLower j)) *
        (max (paper3F1EzuDef j) (Real.exp (198 : ℝ)) + 1) + 1

theorem paper3F1EzuDef_zero :
    paper3F1EzuDef 0 = Real.exp (199 : ℝ) := rfl

theorem paper3F1EzuDef_succ (j : ℕ) :
    paper3F1EzuDef (j + 1) =
      Real.exp (-(selectorInterReadUActiveMassLower j)) *
        (max (paper3F1EzuDef j) (Real.exp (198 : ℝ)) + 1) + 1 := rfl

theorem paper3F1EzuDef_nonneg (j : ℕ) : 0 ≤ paper3F1EzuDef j := by
  cases j with
  | zero =>
      rw [paper3F1EzuDef_zero]
      positivity
  | succ j =>
      rw [paper3F1EzuDef_succ]
      have h1 := le_max_right (paper3F1EzuDef j) (Real.exp (198 : ℝ))
      have h2 := (Real.exp_pos (198 : ℝ)).le
      have h3 := (Real.exp_pos (-(selectorInterReadUActiveMassLower j))).le
      have hW : 0 ≤ max (paper3F1EzuDef j) (Real.exp (198 : ℝ)) + 1 := by
        linarith
      have := mul_nonneg h3 hW
      linarith

/-- Staged bound on the endpoint recurrence: `+2` growth for the first five
cycles (where the u-kernel mass bound is vacuous), then contraction. -/
theorem paper3F1EzuDef_le_staged (j : ℕ) :
    paper3F1EzuDef j ≤ Real.exp (199 : ℝ) + 2 * ((min j 5 : ℕ) : ℝ) := by
  induction j with
  | zero =>
      rw [paper3F1EzuDef_zero]
      norm_num
  | succ j ih =>
      have hW0 : 0 ≤ max (paper3F1EzuDef j) (Real.exp (198 : ℝ)) + 1 := by
        have h1 := le_max_right (paper3F1EzuDef j) (Real.exp (198 : ℝ))
        have h2 := (Real.exp_pos (198 : ℝ)).le
        linarith
      have hexp198 : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) :=
        Real.exp_le_exp.mpr (by norm_num)
      have hmin_nn : (0 : ℝ) ≤ 2 * ((min j 5 : ℕ) : ℝ) := by positivity
      by_cases hj : j < 5
      · -- growth regime: `e^{-mass_j} ≤ 1`, `+2` per cycle
        have hq1 : Real.exp (-(selectorInterReadUActiveMassLower j)) ≤ 1 := by
          have h0 := selectorInterReadUActiveMassLower_nonneg j
          calc Real.exp (-(selectorInterReadUActiveMassLower j))
              ≤ Real.exp 0 := Real.exp_le_exp.mpr (by linarith)
            _ = 1 := Real.exp_zero
        have hmin_succ : ((min (j + 1) 5 : ℕ) : ℝ) =
            ((min j 5 : ℕ) : ℝ) + 1 := by
          have h : min (j + 1) 5 = min j 5 + 1 := by omega
          rw [h]; push_cast; ring
        have hWle : max (paper3F1EzuDef j) (Real.exp (198 : ℝ)) ≤
            Real.exp (199 : ℝ) + 2 * ((min j 5 : ℕ) : ℝ) :=
          max_le ih (by linarith)
        rw [paper3F1EzuDef_succ, hmin_succ]
        have hmul := mul_le_mul_of_nonneg_right hq1 hW0
        rw [one_mul] at hmul
        linarith
      · -- contraction regime: `e^{-mass_j} ≤ e^{-2} ≤ 1/7`
        push_neg at hj
        have hjR : (5 : ℝ) ≤ (j : ℝ) := by exact_mod_cast hj
        have hq : Real.exp (-(selectorInterReadUActiveMassLower j)) ≤
            Real.exp (-2 : ℝ) := by
          apply Real.exp_le_exp.mpr
          have h := selectorInterReadUActiveMassLower_ge_linear j
          linarith
        have hq7 : Real.exp (-2 : ℝ) * 7 ≤ 1 := by
          have h7 : (7 : ℝ) ≤ Real.exp 2 := by
            have h1 : (2.7182818283 : ℝ) < Real.exp 1 := Real.exp_one_gt_d9
            have h2 : Real.exp (2 : ℝ) = Real.exp 1 * Real.exp 1 := by
              rw [← Real.exp_add]; norm_num
            nlinarith [Real.exp_pos 1]
          have hE : Real.exp (-2 : ℝ) * Real.exp (2 : ℝ) = 1 := by
            rw [← Real.exp_add]; norm_num
          have hmono :=
            mul_le_mul_of_nonneg_left h7 (Real.exp_pos (-2 : ℝ)).le
          rw [hE] at hmono
          exact hmono
        have hmin5 : ((min j 5 : ℕ) : ℝ) = 5 := by
          have h : min j 5 = 5 := by omega
          rw [h]; norm_num
        have hminS : ((min (j + 1) 5 : ℕ) : ℝ) = 5 := by
          have h : min (j + 1) 5 = 5 := by omega
          rw [h]; norm_num
        have hEj : paper3F1EzuDef j ≤ Real.exp (199 : ℝ) + 10 := by
          rw [hmin5] at ih
          linarith
        have hbig : (1 : ℝ) ≤ Real.exp (199 : ℝ) := by
          have := Real.add_one_le_exp (199 : ℝ)
          linarith
        have hWle : max (paper3F1EzuDef j) (Real.exp (198 : ℝ)) + 1 ≤
            Real.exp (199 : ℝ) + 11 :=
          by
            have := max_le hEj (by linarith :
              Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) + 10)
            linarith
        have hqW : Real.exp (-(selectorInterReadUActiveMassLower j)) *
            (max (paper3F1EzuDef j) (Real.exp (198 : ℝ)) + 1) ≤
            Real.exp (-2 : ℝ) * (Real.exp (199 : ℝ) + 11) :=
          mul_le_mul hq hWle hW0 (Real.exp_pos (-2 : ℝ)).le
        have hA11 : (0 : ℝ) ≤ Real.exp (199 : ℝ) + 11 := by linarith
        have hcap := mul_le_mul_of_nonneg_right hq7 hA11
        rw [one_mul] at hcap
        rw [paper3F1EzuDef_succ, hminS]
        nlinarith [hqW, hcap, hbig]

theorem paper3F1EzuDef_le_ten (j : ℕ) :
    paper3F1EzuDef j ≤ Real.exp (199 : ℝ) + 10 := by
  have h := paper3F1EzuDef_le_staged j
  have hm : ((min j 5 : ℕ) : ℝ) ≤ 5 := by
    exact_mod_cast min_le_right j 5
  linarith

/-- Every per-cycle window envelope released by the bootstrap at the
recurrence endpoint fits below the explicit `Cwin`. -/
theorem paper3F1EzuDef_window_le (j : ℕ) :
    max (paper3F1EzuDef j) (Real.exp (198 : ℝ)) + 1 ≤ paper3F1CwinDef := by
  have h1 := paper3F1EzuDef_le_ten j
  have h2 : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) + 10 := by
    have := Real.exp_le_exp.mpr (by norm_num : (198 : ℝ) ≤ 199)
    linarith
  have h := max_le h1 h2
  unfold paper3F1CwinDef
  linarith

/-- The boundary-tube radius at the explicit `Cwin` sits inside the readout
tube (the δu reserves are nonnegative). -/
theorem paper3F1TubeRadius_CwinDef_le :
    paper3F1TubeRadius paper3F1CwinDef ≤ r_LE_U := by
  have h1 : 0 ≤ δuWritePrefix paper3F1CwinDef 0 := by
    unfold δuWritePrefix
    exact mul_nonneg paper3F1CwinDef_nonneg (by positivity)
  have h2 : 0 ≤ δuSettled paper3F1CwinDef 0 := by
    unfold δuSettled
    exact mul_nonneg paper3F1CwinDef_nonneg (by positivity)
  unfold paper3F1TubeRadius
  linarith


/-- Running the invariant-threaded induction on the joint core: the
write-start boundary tube AND the write-start `z-u` endpoint bound hold at
every cycle.  The one-cycle step is the algebraic canonical positive-part
step; the source domination and the invariant advance are the core's
conditional fields; the reserve is `hbudget_half` plus the (proved)
`e^{200}` δu-reserve. -/
theorem paper3F1_joint_tube_and_endpoint (wg w : ℕ)
    (core : Paper3F1JointStepCore wg w) :
    ∀ j, (∀ i, paper3F1BoundaryErr wg w j i ≤
        paper3F1TubeRadius core.Cwin) ∧
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFam wg) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j) := by
  have hreserve_half :
      δuWritePrefix core.Cwin 0 + δuSettled core.Cwin 0 ≤ r_LE_U / 2 :=
    paper3F1_delta_reserve_of_envelope_le core.hCwin_le
  have hbudget_geom : ∀ i,
      paper3F1W0 wg w i + paper3F1GeomCap w core.Csrc ≤
        paper3F1TubeRadius core.Cwin := by
    intro i
    have h := core.hbudget_half i
    unfold paper3F1TubeRadius
    linarith
  have hq1 : Real.exp (Real.log (B_U : ℝ) - 2) < 1 := by
    rw [Real.exp_lt_one_iff]
    linarith [log_B_U_lt_two]
  have hcap_nonneg : 0 ≤ paper3F1GeomCap w core.Csrc := by
    unfold paper3F1GeomCap
    have hden : 0 < 1 - Real.exp (Real.log (B_U : ℝ) - 2) := by linarith
    have hfrac : 0 ≤ 1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2)) := by
      positivity
    exact mul_nonneg (mul_nonneg (Real.exp_pos _).le core.hCsrc0) hfrac
  have hW0nn : 0 ≤ paper3F1W0 wg w haltCoordU := by
    unfold paper3F1W0
    exact mul_nonneg
      (zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _)
      (abs_nonneg _)
  have hrtube_nonneg : 0 ≤ paper3F1TubeRadius core.Cwin :=
    le_trans (add_nonneg hW0nn hcap_nonneg) (hbudget_geom haltCoordU)
  have hW0_le : ∀ i : Fin d_U, paper3F1W0 wg w i ≤
      paper3F1TubeRadius core.Cwin - paper3F1GeomCap w core.Csrc := by
    intro i
    linarith [hbudget_geom i]
  have hdepth : ∀ j (i : Fin d_U),
      paper3F1Depth w (j + 1) i =
        paper3F1Depth w j i - selectorMUCoarseDelta (paper3F1Cfg w) j i :=
    selectorMUCurrentDepthStep_concrete
      (cfg := paper3F1Cfg w) (fun j => solMUReplStaticCfg_step w j)
  have hbase : ∀ i : Fin d_U,
      (B_U : ℝ) ^ paper3F1Depth w 0 i *
        trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
          selectorMUWriteStartTime 0 i ≤
        paper3F1TubeRadius core.Cwin - paper3F1GeomCap w core.Csrc := by
    intro i
    have h := hW0_le i
    unfold paper3F1W0 at h
    rw [paper3F1BoundaryErr_eq_trackingErr] at h
    exact h
  have hstep' : ∀ j (i : Fin d_U),
      trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
          selectorMUWriteStartTime (j + 1) i ≤
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
            selectorMUWriteStartTime j i + paper3F1SrcCore wg w j i := by
    intro j i
    have hraw : trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime (j + 1) i ≤
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
            selectorMUWriteStartTime j i + paper3F1SrcCore wg w j i := by
      have h := paper3F1_boundaryErr_succ_le_mult_add_srcCore wg w j i
      simpa only [paper3F1BoundaryErr_eq_trackingErr] using h
    exact trackingErr_succ_le_of_multiplier_step
      ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
      selectorMUWriteStartTime
      (m := fun j i => stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i)
      (s := paper3F1SrcCore wg w)
      (delta := selectorMUCoarseDelta (paper3F1Cfg w)) j i
      (paper3F1_coordMultiplier_le_BUpow_coarseDelta w j i) hraw
  have hη_dom' : ∀ j,
      (∀ i, trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i ≤ paper3F1TubeRadius core.Cwin) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFam wg) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j) →
      ∀ i, paper3F1SrcCore wg w j i ≤
        core.Csrc * Real.exp (-(2 : ℝ) * (j : ℝ)) := by
    intro j htube hend i
    have hb : ∀ i', paper3F1BoundaryErr wg w j i' ≤
        paper3F1TubeRadius core.Cwin := by
      intro i'
      rw [paper3F1BoundaryErr_eq_trackingErr]
      exact htube i'
    exact core.hsrc_geo_of j hb hend i
  have hPstep : ∀ j,
      (∀ i, trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i ≤ paper3F1TubeRadius core.Cwin) →
      (∀ i : Fin d_U,
        |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFam wg) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j) →
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFam wg) w).z
            (selectorMUWriteStartTime (j + 1)) i -
          ((paper3HeadlineSolFam wg) w).u
            (selectorMUWriteStartTime (j + 1)) i| ≤ core.Ezu (j + 1) := by
    intro j htube hend
    have hb : ∀ i', paper3F1BoundaryErr wg w j i' ≤
        paper3F1TubeRadius core.Cwin := by
      intro i'
      rw [paper3F1BoundaryErr_eq_trackingErr]
      exact htube i'
    exact core.hnext_of j hb hend
  have hreserve : ∀ j (i : Fin d_U),
      (paper3F1TubeRadius core.Cwin - paper3F1GeomCap w core.Csrc) +
        Real.exp (Real.log (B_U : ℝ) *
            (MachineInstance.inputLenU 1 w : ℝ)) * core.Csrc *
          (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) ≤
        paper3F1TubeRadius core.Cwin * (B_U : ℝ) ^ paper3F1Depth w j i := by
    intro j i
    have hdep_nonneg : 0 ≤ paper3F1Depth w j i :=
      selectorMU_depthU_nonneg (paper3F1Cfg w) j i
    have hpow_ge_one : (1 : ℝ) ≤ (B_U : ℝ) ^ paper3F1Depth w j i :=
      (one_le_zpow_iff_right₀
        (by norm_num [B_U] : (1 : ℝ) < (B_U : ℝ))).mpr hdep_nonneg
    have hcancel : (paper3F1TubeRadius core.Cwin -
          paper3F1GeomCap w core.Csrc) +
        Real.exp (Real.log (B_U : ℝ) *
            (MachineInstance.inputLenU 1 w : ℝ)) * core.Csrc *
          (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) =
        paper3F1TubeRadius core.Cwin := by
      unfold paper3F1GeomCap
      ring
    rw [hcancel]
    calc paper3F1TubeRadius core.Cwin
        = paper3F1TubeRadius core.Cwin * 1 := (mul_one _).symm
      _ ≤ paper3F1TubeRadius core.Cwin *
            (B_U : ℝ) ^ paper3F1Depth w j i :=
          mul_le_mul_of_nonneg_left hpow_ge_one hrtube_nonneg
  have hjoint :=
    paper3F1_tube_and_invariant_of_conditional_step_normalized
      (P := fun j => ∀ i : Fin d_U,
        |((paper3HeadlineSolFam wg) w).z (selectorMUWriteStartTime j) i -
          ((paper3HeadlineSolFam wg) w).u
            (selectorMUWriteStartTime j) i| ≤ core.Ezu j)
      ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
      selectorMUWriteStartTime
      (k := (B_U : ℝ)) (r := paper3F1TubeRadius core.Cwin)
      selectorMU_B_U_real_gt_one
      (paper3F1Depth w) (selectorMUCoarseDelta (paper3F1Cfg w))
      (paper3F1SrcCore wg w)
      (W0 := paper3F1TubeRadius core.Cwin - paper3F1GeomCap w core.Csrc)
      (L := (MachineInstance.inputLenU 1 w : ℝ))
      (Cη := core.Csrc) (lam := 2)
      core.hCsrc0 log_B_U_lt_two
      hdepth (fun j i => paper3F1Depth_succ_le_inputLenU w i j)
      hbase core.hE0 hPstep hstep'
      (paper3F1SrcCore_nonneg wg w) hη_dom' hreserve
  intro j
  obtain ⟨htube, hend⟩ := hjoint j
  refine ⟨fun i => ?_, hend⟩
  rw [paper3F1BoundaryErr_eq_trackingErr]
  exact htube i

/-- All-cycle write-start boundary tube from the conditional core: the
normalized tube-conditional weighted induction, with the reserve supplied by
the quantitative budget `hbudget_geom` through `B_U^{dep} ≥ 1`. -/
theorem paper3F1_boundaryErr_le_tube_of_core
    (wg w : ℕ) (core : Paper3F1ConditionalStepCore wg w) :
    ∀ j i, paper3F1BoundaryErr wg w j i ≤ paper3F1TubeRadius core.Cwin := by
  have hq1 : Real.exp (Real.log (B_U : ℝ) - 2) < 1 := by
    rw [Real.exp_lt_one_iff]
    linarith [log_B_U_lt_two]
  have hcap_nonneg : 0 ≤ paper3F1GeomCap w core.Csrc := by
    unfold paper3F1GeomCap
    have hden : 0 < 1 - Real.exp (Real.log (B_U : ℝ) - 2) := by linarith
    have hfrac : 0 ≤ 1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2)) := by
      positivity
    exact mul_nonneg (mul_nonneg (Real.exp_pos _).le core.hCsrc0) hfrac
  have hW0nn : 0 ≤ paper3F1W0 wg w haltCoordU := by
    unfold paper3F1W0
    exact mul_nonneg
      (zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _)
      (abs_nonneg _)
  have hrtube_nonneg : 0 ≤ paper3F1TubeRadius core.Cwin :=
    le_trans (add_nonneg hW0nn hcap_nonneg) (core.hbudget_geom haltCoordU)
  have hW0_le : ∀ i : Fin d_U, paper3F1W0 wg w i ≤
      paper3F1TubeRadius core.Cwin - paper3F1GeomCap w core.Csrc := by
    intro i
    linarith [core.hbudget_geom i]
  have hdepth : ∀ j (i : Fin d_U),
      paper3F1Depth w (j + 1) i =
        paper3F1Depth w j i - selectorMUCoarseDelta (paper3F1Cfg w) j i :=
    selectorMUCurrentDepthStep_concrete
      (cfg := paper3F1Cfg w) (fun j => solMUReplStaticCfg_step w j)
  have hbase : ∀ i : Fin d_U,
      (B_U : ℝ) ^ paper3F1Depth w 0 i *
        trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
          selectorMUWriteStartTime 0 i ≤
        paper3F1TubeRadius core.Cwin - paper3F1GeomCap w core.Csrc := by
    intro i
    have h := hW0_le i
    unfold paper3F1W0 at h
    rw [paper3F1BoundaryErr_eq_trackingErr] at h
    exact h
  have hstep' : ∀ j,
      (∀ i, trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i ≤ paper3F1TubeRadius core.Cwin) →
      ∀ i, trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
          selectorMUWriteStartTime (j + 1) i ≤
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
            selectorMUWriteStartTime j i + core.src j i := by
    intro j htube i
    have hb : ∀ i', paper3F1BoundaryErr wg w j i' ≤
        paper3F1TubeRadius core.Cwin := by
      intro i'
      rw [paper3F1BoundaryErr_eq_trackingErr]
      exact htube i'
    have hraw : trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime (j + 1) i ≤
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
            selectorMUWriteStartTime j i + core.src j i := by
      have h := core.hstep j hb i
      simpa only [paper3F1BoundaryErr_eq_trackingErr] using h
    exact trackingErr_succ_le_of_multiplier_step
      ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
      selectorMUWriteStartTime
      (m := fun j i => stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i)
      (s := core.src)
      (delta := selectorMUCoarseDelta (paper3F1Cfg w)) j i
      (paper3F1_coordMultiplier_le_BUpow_coarseDelta w j i) hraw
  have hη_dom' : ∀ j,
      (∀ i, trackingErr ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i ≤ paper3F1TubeRadius core.Cwin) →
      ∀ i, core.src j i ≤ core.Csrc * Real.exp (-(2 : ℝ) * (j : ℝ)) := by
    intro j htube i
    have hb : ∀ i', paper3F1BoundaryErr wg w j i' ≤
        paper3F1TubeRadius core.Cwin := by
      intro i'
      rw [paper3F1BoundaryErr_eq_trackingErr]
      exact htube i'
    exact core.hsrc_geo j hb i
  have hreserve : ∀ j (i : Fin d_U),
      (paper3F1TubeRadius core.Cwin - paper3F1GeomCap w core.Csrc) +
        Real.exp (Real.log (B_U : ℝ) *
            (MachineInstance.inputLenU 1 w : ℝ)) * core.Csrc *
          (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) ≤
        paper3F1TubeRadius core.Cwin * (B_U : ℝ) ^ paper3F1Depth w j i := by
    intro j i
    have hdep_nonneg : 0 ≤ paper3F1Depth w j i :=
      selectorMU_depthU_nonneg (paper3F1Cfg w) j i
    have hpow_ge_one : (1 : ℝ) ≤ (B_U : ℝ) ^ paper3F1Depth w j i :=
      (one_le_zpow_iff_right₀
        (by norm_num [B_U] : (1 : ℝ) < (B_U : ℝ))).mpr hdep_nonneg
    have hcancel : (paper3F1TubeRadius core.Cwin -
          paper3F1GeomCap w core.Csrc) +
        Real.exp (Real.log (B_U : ℝ) *
            (MachineInstance.inputLenU 1 w : ℝ)) * core.Csrc *
          (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) =
        paper3F1TubeRadius core.Cwin := by
      unfold paper3F1GeomCap
      ring
    rw [hcancel]
    calc paper3F1TubeRadius core.Cwin
        = paper3F1TubeRadius core.Cwin * 1 := (mul_one _).symm
      _ ≤ paper3F1TubeRadius core.Cwin *
            (B_U : ℝ) ^ paper3F1Depth w j i :=
          mul_le_mul_of_nonneg_left hpow_ge_one hrtube_nonneg
  have htube :=
    paper3F1_trackingErr_le_tube_of_conditional_step_normalized
      ((paper3HeadlineSolFam wg) w).u (paper3F1Cfg w)
      selectorMUWriteStartTime
      (k := (B_U : ℝ)) (r := paper3F1TubeRadius core.Cwin)
      selectorMU_B_U_real_gt_one
      (paper3F1Depth w) (selectorMUCoarseDelta (paper3F1Cfg w)) core.src
      (W0 := paper3F1TubeRadius core.Cwin - paper3F1GeomCap w core.Csrc)
      (L := (MachineInstance.inputLenU 1 w : ℝ))
      (Cη := core.Csrc) (lam := 2)
      core.hCsrc0 log_B_U_lt_two
      hdepth (fun j i => paper3F1Depth_succ_le_inputLenU w i j)
      hbase hstep' core.hsrc_nonneg hη_dom' hreserve
  intro j i
  rw [paper3F1BoundaryErr_eq_trackingErr]
  exact htube j i

/-- **GENUINE F1 ANALYTIC INPUT (2/2): uniform write-window `z-u` envelope
and the normalized budget reserve it leaves.**

A single constant `Czu` bounding `|z-u|` on every write-prefix and settled-tail
window (this is the global tracking bound — the finite-horizon
`paper3F1TailM` witness grows with `j` and does not give it), together with
the quantitative headline reserve: the total weighted budget
`W0 + Σ' weightedDefect` stays below
`(r_LE_U - δuWritePrefix Czu 0 - δuSettled Czu j) · B_U^{dep(j,i)}`.

Note the reserve terms are numerically tiny:
`δuWritePrefix Czu 0 = Czu·(π/3)·e^{-450·π/6}` and
`δuSettled Czu j = Czu·(π/3)·e^{-450·(2πj+π/2)}`, so for `dep ≥ 0` this is
essentially `W0 i + Σ' weightedDefect ≤ r_LE_U - o(1)` — the irreducible
quantitative F1 estimate of the paper. -/
structure Paper3F1GlobalZUEnvelope (wg w : ℕ) where
  Czu : ℝ
  hCzu0 : 0 ≤ Czu
  hpre : ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteHoldTime j),
    |((paper3HeadlineSolFam wg) w).z t i -
      ((paper3HeadlineSolFam wg) w).u t i| ≤ Czu
  htail : ∀ j i, ∀ t ∈ Icc (selectorMUWriteHoldTime j)
      (selectorMUWriteReadTime j),
    |((paper3HeadlineSolFam wg) w).z t i -
      ((paper3HeadlineSolFam wg) w).u t i| ≤ Czu
  /- Cycle-`0` budget reserve of THIS envelope constant.  The reserve must be
  carried by the structure and cannot be an unconditional theorem about every
  envelope: the envelope fields above are pure upper bounds, so any valid
  `Czu` can be inflated at will, and for `Czu` large enough
  (`≳ r_LE_U·(3/π)·e^{450·π/6}`) the right-hand side
  `r_LE_U - δuWritePrefix Czu 0 - δuSettled Czu 0` turns negative while the
  weighted budget on the left is nonnegative.  The reserve is a property of
  the *constructed* (minimal) envelope, i.e. of the producer. -/
  hreserve : ∀ i,
    paper3F1W0 wg w i +
        ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
          (paper3F1Eta wg w) m i ≤
      r_LE_U - δuWritePrefix Czu 0 - δuSettled Czu 0

theorem paper3F1_uniform_budget_reserve_of_global_zu
    (wg w : ℕ) (H : Paper3F1GlobalZUEnvelope wg w) :
    ∀ j i,
      (paper3F1W0 wg w i +
            ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
              (paper3F1Eta wg w) m i) /
          (B_U : ℝ) ^ paper3F1Depth w j i ≤
        r_LE_U - δuWritePrefix H.Czu 0 - δuSettled H.Czu j := by
  /- Scalar arithmetic from the envelope's cycle-`0` reserve `H.hreserve`:
  the numerator is nonnegative, `dep ≥ 0` gives `B_U^{dep} ≥ 1` so the
  normalization only shrinks the left side, and the settled reserve
  `δuSettled Czu j` is largest at `j = 0` (the hold marks increase and the
  qPulse off-phase envelope decays), so the cycle-`0` reserve implies the
  cycle-`j` reserve. -/
  intro j i
  -- numerator nonnegativity
  have hW0 : 0 ≤ paper3F1W0 wg w i := by
    unfold paper3F1W0 paper3F1BoundaryErr
    exact mul_nonneg
      (zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _)
      (abs_nonneg _)
  have htsum0 : 0 ≤ ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
      (paper3F1Eta wg w) m i :=
    tsum_nonneg (fun m => paper3F1_weightedDefect_nonneg wg w i m)
  -- normalization by `B_U^{dep} ≥ 1` only shrinks the left side
  have hdep_nonneg : 0 ≤ paper3F1Depth w j i := by
    simpa [paper3F1Depth] using
      selectorMU_depthU_nonneg (paper3F1Cfg w) j i
  have hpow_ge_one : (1 : ℝ) ≤ (B_U : ℝ) ^ paper3F1Depth w j i :=
    (one_le_zpow_iff_right₀
      (by norm_num [B_U] : (1 : ℝ) < (B_U : ℝ))).mpr hdep_nonneg
  have hdiv :
      (paper3F1W0 wg w i +
            ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
              (paper3F1Eta wg w) m i) /
          (B_U : ℝ) ^ paper3F1Depth w j i ≤
        paper3F1W0 wg w i +
          ∑' m, weightedDefect (B_U : ℝ) (paper3F1Depth w)
            (paper3F1Eta wg w) m i :=
    div_le_self (by linarith) hpow_ge_one
  -- the settled reserve is largest at cycle `0`
  have hhold_mono : selectorMUWriteHoldTime 0 ≤ selectorMUWriteHoldTime j := by
    unfold selectorMUWriteHoldTime
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith [Real.pi_pos, hj]
  have hscaled :
      selectorUSettledRate * selectorMUWriteHoldTime 0 ≤
        selectorUSettledRate * selectorMUWriteHoldTime j :=
    mul_le_mul_of_nonneg_left hhold_mono selectorUSettledRate_pos.le
  have hexp :
      Real.exp (-(selectorUSettledRate * selectorMUWriteHoldTime j)) ≤
        Real.exp (-(selectorUSettledRate * selectorMUWriteHoldTime 0)) :=
    Real.exp_le_exp.mpr (by linarith)
  have hsettled_mono : δuSettled H.Czu j ≤ δuSettled H.Czu 0 := by
    dsimp [δuSettled]
    have hcoef : 0 ≤ H.Czu * (Real.pi / 3) :=
      mul_nonneg H.hCzu0 (by positivity)
    nlinarith [mul_le_mul_of_nonneg_left hexp hcoef]
  have hres := H.hreserve i
  linarith

/-! ### F1-N layer: the `bgpParamsN` clone of the F1 private chain

The `bgpParams38` F1 chain above is quantitatively dead (STOP-SHIP,
