theorem paper3F1EtaN_le_srcCoreN (wg w : ℕ) :
    ∀ j i, paper3F1EtaN wg w j i ≤ paper3F1SrcCoreN wg w j i := by
  intro j i
  have herr_nonneg : 0 ≤ paper3F1BoundaryErrN wg w j i := abs_nonneg _
  have hcmp :
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErrN wg w j i ≤
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          paper3F1BoundaryErrN wg w j i :=
    mul_le_mul_of_nonneg_right
      (paper3F1_coordMultiplier_le_BUpow_coarseDelta w j i) herr_nonneg
  unfold paper3F1EtaN
  refine max_le (paper3F1SrcCoreN_nonneg wg w j i) ?_
  have hsrc : paper3F1BoundaryErrN wg w (j + 1) i -
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErrN wg w j i ≤ paper3F1SrcCoreN wg w j i := by
    unfold paper3F1SrcCoreN
    exact le_max_right _ _
  linarith

