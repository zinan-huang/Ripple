  have hsW : (0 : ℝ) < 200 * (bgpScaleW w : ℝ) := by
    nlinarith [bgpScaleWR_pos w]
  have h5D : 5 * D_U ≤ (bgpScale : ℝ) * Real.exp (200 : ℝ) := by
    have hD := D_U_le_two_bgpScale
    have hexp : (10 : ℝ) ≤ Real.exp (200 : ℝ) := by
