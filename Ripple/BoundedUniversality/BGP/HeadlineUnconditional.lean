    -- the exit coordinate and its displacement bound
    obtain ⟨i1, hi1⟩ := Set.mem_iUnion.mp htmem.2
    simp only [Set.mem_setOf_eq] at hi1
    have hmz : ∀ τ ∈ Icc (2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6)
