  set C1 : ℝ := 2 ^ paper3HeadlineM *
    Real.exp (-((bgpParamsNW wg).cα * a)) /
      ((paper3WarmGainQNW wg : ℚ) : ℝ) with hC1_def
  have hC1_nonneg : 0 ≤ C1 := by
    rw [hC1_def]
    have := (Real.exp_pos (-((bgpParamsNW wg).cα * a))).le
    positivity
  -- pointwise: reset integrand ≤ C1 · gain integrand (both gain-weighted)
