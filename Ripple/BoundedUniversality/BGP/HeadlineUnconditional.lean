noncomputable def selectorInterReadUActiveMassLowerNW (sW : ℕ) (j : ℕ) : ℝ :=
  Real.exp (300 * (bgpScaleW sW : ℝ) * selectorMUUActiveStart j) *
    Real.exp (-(1000 * (bgpScaleW sW : ℝ) * selectorMUUActiveEnd j * (1 / 4 : ℝ))) *
      ((2 : ℝ) * Real.pi / 3)

theorem selectorInterReadUActiveMassLowerNW_nonneg (sW : ℕ) (j : ℕ) :
    0 ≤ selectorInterReadUActiveMassLowerNW sW j := by
  dsimp [selectorInterReadUActiveMassLowerNW]
