/-- Exponential kills the cycle index: `e^{−c·S·2πj} ≤ e^{−2j}` for `c ≥ 1`. -/
theorem paper3NW4_j_decay (wg : ℕ) (j : ℕ) {c : ℝ} (hc : 1 ≤ c) :
