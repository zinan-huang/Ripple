    unfold selectorMU_activeCr
    exact mul_nonneg
      (pow_nonneg (by nlinarith [Real.neg_one_le_cos τ]) _)
      (by norm_num [paper3HeadlineKappa])
  have hbase : (1 / 2 : ℝ) ≤ (1 + Real.sin τ) / 2 := by linarith
  have hpow : (1 / 2 : ℝ) ^ paper3HeadlineM ≤
      ((1 + Real.sin τ) / 2) ^ paper3HeadlineM :=
    pow_le_pow_left₀ (by norm_num) hbase _
  have hgain_pos :
      0 < ((paper3WarmGainQNW w : ℚ) : ℝ) *
        Real.exp ((bgpParamsNW w).cα * τ) :=
    mul_pos (paper3WarmGainQNW_pos_real w) (Real.exp_pos _)
  have hcg_ge : (1 / 2 : ℝ) ^ paper3HeadlineM *
      (((paper3WarmGainQNW w : ℚ) : ℝ) *
        Real.exp ((bgpParamsNW w).cα * τ)) ≤
      selectorMU_activeCgP (p := bgpParamsNW w) paper3HeadlineM
        (paper3WarmGainQNW w) τ := by
    unfold selectorMU_activeCgP
    exact mul_le_mul_of_nonneg_right hpow hgain_pos.le
  have hcg_nonneg :
      0 ≤ selectorMU_activeCgP (p := bgpParamsNW w) paper3HeadlineM
        (paper3WarmGainQNW w) τ := by
    refine le_trans ?_ hcg_ge
    have h1 : (0 : ℝ) ≤ (1 / 2 : ℝ) ^ paper3HeadlineM :=
      pow_nonneg (by norm_num) _
    exact mul_nonneg h1 hgain_pos.le
  have hprod : (1 / 2 : ℝ) ^ paper3HeadlineM *
      (((paper3WarmGainQNW w : ℚ) : ℝ) *
        Real.exp ((bgpParamsNW w).cα * τ)) * (1 / 2) ≤
      selectorMU_activeCgP (p := bgpParamsNW w) paper3HeadlineM
        (paper3WarmGainQNW w) τ *
        (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
            (((paper3HeadlineSolFamNW w) w).u τ) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFamNW w) w).u τ)) :=
    mul_le_mul hcg_ge hgap (by norm_num) hcg_nonneg
  unfold selectorMU_activeSinkP
  linarith

/-- Crude all-coordinate `|z−u|` bound on the S4a edge window: branch hull
+ window-envelope entry + u-tube level. -/
noncomputable def paper3S4EdgeZUBoundNW : ℝ :=
