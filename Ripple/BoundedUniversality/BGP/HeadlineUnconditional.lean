/-- The concrete shifted select-to-hold gain slope dominates the Hoff
exponential slope. -/
theorem paper3Headline_gainSlope_ge_hoffSlope
    (wg : ℕ) :
    (Real.pi / 4 : ℝ) ≤
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        (((3 / 4 : ℝ) ^ paper3HeadlineM) *
          (((paper3WarmGainQ wg : ℚ) : ℝ)) *
          Real.exp (bgpParams38.cα *
            (Real.pi / 6 + selectorMURecoveryDelta)) *
          (Real.pi / 3 - selectorMURecoveryDelta) *
          (2 * Real.pi * bgpParams38.cα)) := by
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let scale : ℝ :=
    ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      (((paper3WarmGainQ wg : ℚ) : ℝ))
  let expGain : ℝ :=
    Real.exp (bgpParams38.cα *
      (Real.pi / 6 + selectorMURecoveryDelta))
  let width : ℝ := Real.pi / 3 - selectorMURecoveryDelta
  let tail : ℝ := 2 * Real.pi * bgpParams38.cα
  change (Real.pi / 4 : ℝ) ≤
    gap * (scale * expGain * width * tail)
  have hgap : (15 / 16 : ℝ) ≤ gap := by
    simpa [gap, paper3RecoveryGap] using
      paper3RecoveryGap_ge_fifteen_sixteen wg 0
  have hgap_nonneg : 0 ≤ gap :=
    le_trans (by norm_num : (0 : ℝ) ≤ 15 / 16) hgap
  have hscale : (1 : ℝ) ≤ scale := by
    simpa [scale, paper3HeadlineKappa] using paper3HeadlineHScale wg
  have hscale_nonneg : 0 ≤ scale :=
    le_trans (by norm_num : (0 : ℝ) ≤ 1) hscale
  have harg_nonneg :
      0 ≤ bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta) := by
    have hcα : 0 ≤ bgpParams38.cα := by norm_num [bgpParams38]
    have hsum : 0 ≤ Real.pi / 6 + selectorMURecoveryDelta := by
      nlinarith [Real.pi_pos, selectorMURecoveryDelta_pos]
    exact mul_nonneg hcα hsum
  have hexp : (1 : ℝ) ≤ expGain := by
    change (1 : ℝ) ≤
      Real.exp (bgpParams38.cα *
        (Real.pi / 6 + selectorMURecoveryDelta))
    rw [← Real.exp_zero]
    exact Real.exp_le_exp.mpr harg_nonneg
  have hexp_nonneg : 0 ≤ expGain :=
    le_trans (by norm_num : (0 : ℝ) ≤ 1) hexp
  have hwidth : (1 / 2 : ℝ) ≤ width := by
    change (1 / 2 : ℝ) ≤ Real.pi / 3 - selectorMURecoveryDelta
    simp [selectorMURecoveryDelta]
    nlinarith [Real.pi_gt_three]
  have hwidth_nonneg : 0 ≤ width :=
    le_trans (by norm_num : (0 : ℝ) ≤ 1 / 2) hwidth
  have htail : (3 * Real.pi / 4 : ℝ) ≤ tail := by
    change (3 * Real.pi / 4 : ℝ) ≤ 2 * Real.pi * bgpParams38.cα
    have : bgpParams38.cα = 300 := by norm_num [bgpParams38]
    nlinarith [Real.pi_pos]
  have htail_lower_nonneg : 0 ≤ (3 * Real.pi / 4 : ℝ) := by
    nlinarith [Real.pi_pos]
  have hgap_scale :
      (15 / 16 : ℝ) * 1 ≤ gap * scale :=
    mul_le_mul hgap hscale (by norm_num : (0 : ℝ) ≤ 1) hgap_nonneg
  have hgap_scale_exp :
      ((15 / 16 : ℝ) * 1) * 1 ≤ (gap * scale) * expGain :=
    mul_le_mul hgap_scale hexp (by norm_num : (0 : ℝ) ≤ 1)
      (mul_nonneg hgap_nonneg hscale_nonneg)
  have hgap_scale_exp_width :
      (((15 / 16 : ℝ) * 1) * 1) * (1 / 2) ≤
        ((gap * scale) * expGain) * width :=
    mul_le_mul hgap_scale_exp hwidth
      (by norm_num : (0 : ℝ) ≤ 1 / 2)
      (mul_nonneg (mul_nonneg hgap_nonneg hscale_nonneg) hexp_nonneg)
  have hprod :
      ((((15 / 16 : ℝ) * 1) * 1) * (1 / 2)) *
          (3 * Real.pi / 4) ≤
        (((gap * scale) * expGain) * width) * tail :=
    mul_le_mul hgap_scale_exp_width htail htail_lower_nonneg
      (mul_nonneg
        (mul_nonneg (mul_nonneg hgap_nonneg hscale_nonneg) hexp_nonneg)
        hwidth_nonneg)
  calc
    (Real.pi / 4 : ℝ)
        ≤ ((((15 / 16 : ℝ) * 1) * 1) * (1 / 2)) *
            (3 * Real.pi / 4) := by
          nlinarith [Real.pi_pos]
    _ ≤ (((gap * scale) * expGain) * width) * tail := hprod
    _ = gap * (scale * expGain * width * tail) := by ring

