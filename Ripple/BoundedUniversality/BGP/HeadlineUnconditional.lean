      C1 * (Real.exp (gap * (sol.G s - sol.G a)) * paper3NW4cg wg s) := by
    intro s hs
    have hs0 : 0 ≤ s := le_trans ha0 hs.1
    have hsin : 0 ≤ Real.sin s := by
      apply paper3NW4_sin_nonneg_writeToZOff j
        (le_trans (selectorMUWriteStart_le_selectStart j) hs.1)
        (le_trans hs.2 htZ)
    have hcr_le : ((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        ((paper3HeadlineKappa : ℚ) : ℝ) ≤ 1 := by
      have hbase : (1 + Real.cos s) / 2 ≤ 1 := by
        have := Real.cos_le_one s
        linarith
      have hbase0 : 0 ≤ (1 + Real.cos s) / 2 := by
        have := Real.neg_one_le_cos s
        linarith
      have hκ : ((paper3HeadlineKappa : ℚ) : ℝ) = 1 := by
        norm_num [paper3HeadlineKappa]
      rw [hκ, mul_one]
      exact pow_le_one₀ hbase0 hbase
    have hcg_ge : (1 / 2 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQNW wg : ℚ) : ℝ) *
          Real.exp ((bgpParamsNW wg).cα * a)) ≤ paper3NW4cg wg s := by
      unfold paper3NW4cg
      have hpow : (1 / 2 : ℝ) ^ paper3HeadlineM ≤
          ((1 + Real.sin s) / 2) ^ paper3HeadlineM := by
        apply pow_le_pow_left₀ (by norm_num)
        linarith
      have hexp : Real.exp ((bgpParamsNW wg).cα * a) ≤
          Real.exp ((bgpParamsNW wg).cα * s) := by
        apply Real.exp_le_exp.mpr
        exact mul_le_mul_of_nonneg_left hs.1 hcα
      have hw0 := paper3WarmGainQNW_nonneg_real wg
      calc (1 / 2 : ℝ) ^ paper3HeadlineM *
            (((paper3WarmGainQNW wg : ℚ) : ℝ) *
