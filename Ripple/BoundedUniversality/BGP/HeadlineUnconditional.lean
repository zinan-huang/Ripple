/-- Leg 1: the drift leg. -/
theorem paper3NW4_leg_drift (wg : ℕ) (j : ℕ) :
    6 * paper3NW4Drift wg j ≤
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
  have hS := paper3NW4_S_ge wg
  have hS0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hπ := Real.pi_gt_three
  unfold paper3NW4Drift
  have hsplit : Real.exp (-(200 * (bgpScaleW wg : ℝ) *
      selectorMUWriteStartTime j)) =
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ)))) *
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * (Real.pi / 6))) := by
    rw [← Real.exp_add]
    congr 1
    unfold selectorMUWriteStartTime
    ring
  rw [hsplit]
  have h1 : Real.exp (-(200 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ)))) ≤
      Real.exp (-(2 * (j : ℝ))) := by
    have := paper3NW4_j_decay wg j (c := 200) (by norm_num)
    linarith [this]
  -- constant part: `18·CwinN·e^{−100S}/(200S) ≤ e^{−20S}`
  have hc2 : Real.exp (-(200 * (bgpScaleW wg : ℝ) * (Real.pi / 6))) ≤
      Real.exp (-(100 * (bgpScaleW wg : ℝ))) := by
    apply Real.exp_le_exp.mpr
    nlinarith
  have hCwin := paper3NW4_CwinN_le_exp wg
  have hC0 : (0 : ℝ) < paper3F1CwinDefN := paper3F1CwinDefN_pos
  have hkey : 18 * paper3F1CwinDefN *
      Real.exp (-(100 * (bgpScaleW wg : ℝ))) ≤
      (200 * (bgpScaleW wg : ℝ)) *
        Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
    have hcomb : Real.exp ((bgpScaleW wg : ℝ) + 200) *
        Real.exp (-(100 * (bgpScaleW wg : ℝ))) =
        Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
          Real.exp (-(79 * (bgpScaleW wg : ℝ)) + 200) := by
      rw [← Real.exp_add, ← Real.exp_add]
      congr 1
      ring
    have hsmall : Real.exp (-(79 * (bgpScaleW wg : ℝ)) + 200) ≤ 1 := by
      rw [Real.exp_le_one_iff]
      nlinarith
    have hE20 : (0 : ℝ) < Real.exp (-(20 * (bgpScaleW wg : ℝ))) :=
      Real.exp_pos _
    calc 18 * paper3F1CwinDefN * Real.exp (-(100 * (bgpScaleW wg : ℝ)))
        ≤ 18 * Real.exp ((bgpScaleW wg : ℝ) + 200) *
          Real.exp (-(100 * (bgpScaleW wg : ℝ))) := by
          have hE := (Real.exp_pos (-(100 * (bgpScaleW wg : ℝ)))).le
          nlinarith
      _ = 18 * (Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
          Real.exp (-(79 * (bgpScaleW wg : ℝ)) + 200)) := by
          rw [← hcomb]
          ring
      _ ≤ 18 * Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
          nlinarith
      _ ≤ (200 * (bgpScaleW wg : ℝ)) *
          Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
          nlinarith
  -- assemble
  have hc200 : (0 : ℝ) < 200 * (bgpScaleW wg : ℝ) := by nlinarith
  have hb1 : (18 * paper3F1CwinDefN *
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * (Real.pi / 6)))) /
      (200 * (bgpScaleW wg : ℝ)) ≤
      Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
    rw [div_le_iff₀ hc200]
    calc 18 * paper3F1CwinDefN *
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * (Real.pi / 6)))
        ≤ 18 * paper3F1CwinDefN *
          Real.exp (-(100 * (bgpScaleW wg : ℝ))) := by
          nlinarith [hc2, hC0]
      _ ≤ 200 * (bgpScaleW wg : ℝ) *
          Real.exp (-(20 * (bgpScaleW wg : ℝ))) := hkey
      _ = Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
          (200 * (bgpScaleW wg : ℝ)) := by ring
  calc 6 * (3 * paper3F1CwinDefN *
      (Real.exp (-(200 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ)))) *
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * (Real.pi / 6)))) /
      (200 * (bgpScaleW wg : ℝ)))
      = (18 * paper3F1CwinDefN *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * (Real.pi / 6)))) /
          (200 * (bgpScaleW wg : ℝ)) *
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ)))) := by
        ring
    _ ≤ Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
        Real.exp (-(2 * (j : ℝ))) := by
        have hE1 : (0 : ℝ) ≤
            Real.exp (-(200 * (bgpScaleW wg : ℝ) *
              (2 * Real.pi * (j : ℝ)))) := (Real.exp_pos _).le
        exact mul_le_mul hb1 h1 hE1 (Real.exp_pos _).le
    _ = Real.exp (-(2 * (j : ℝ))) *
        Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by ring

/-- `20 ≤ e³`. -/
theorem paper3NW4_exp_three_ge : (20 : ℝ) ≤ Real.exp 3 := by
  have he := Real.exp_one_gt_d9.le
  have h3 : Real.exp 3 = Real.exp 1 * Real.exp 1 * Real.exp 1 := by
    rw [show (3 : ℝ) = 1 + 1 + 1 by norm_num, Real.exp_add, Real.exp_add]
  rw [h3]
  nlinarith [Real.exp_pos (1 : ℝ)]

/-- Generic double-exponential kill: the per-cycle write/copy masses
`len·e^{50·S·(2πj + phase)}` dominate any `O(S²)` target plus `2j`. -/
theorem paper3NW4_grow_kill (wg : ℕ) (j : ℕ) {len phase D : ℝ}
    (hlen : 1 ≤ len) (hphase : (3 : ℝ) / 2 ≤ phase) (hD : 0 ≤ D)
    (hDle : D ≤ 1000 * (bgpScaleW wg : ℝ) ^ 2) :
    D + 2 * (j : ℝ) ≤
      len * Real.exp (50 * (bgpScaleW wg : ℝ) *
        (2 * Real.pi * (j : ℝ) + phase)) := by
  have hS := paper3NW4_S_ge wg
  have hS0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hπ := Real.pi_gt_three
  have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
  have hsplit : Real.exp (50 * (bgpScaleW wg : ℝ) *
      (2 * Real.pi * (j : ℝ) + phase)) =
      Real.exp (50 * (bgpScaleW wg : ℝ) * phase) *
      Real.exp (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ))) := by
    rw [← Real.exp_add]
    congr 1
    ring
  have hphase_exp : Real.exp (75 * (bgpScaleW wg : ℝ)) ≤
      Real.exp (50 * (bgpScaleW wg : ℝ) * phase) := by
    apply Real.exp_le_exp.mpr
    nlinarith
  have hquad : (75 * (bgpScaleW wg : ℝ)) ^ 2 / 4 ≤
      Real.exp (75 * (bgpScaleW wg : ℝ)) :=
    paper3NW4_sq_quarter_le_exp (by nlinarith)
  have hA : D + 1 ≤ Real.exp (50 * (bgpScaleW wg : ℝ) * phase) := by
    have hSsq : (5184 : ℝ) * 5184 ≤ (bgpScaleW wg : ℝ) * (bgpScaleW wg : ℝ) :=
      mul_le_mul hS hS (by norm_num) hS0.le
    have h1 : D + 1 ≤ (75 * (bgpScaleW wg : ℝ)) ^ 2 / 4 := by
      nlinarith [hSsq]
    linarith
  have hB : 1 + 2 * (j : ℝ) ≤
      Real.exp (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ))) := by
    have h1 := Real.add_one_le_exp
      (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ)))
    have h2 : 2 * (j : ℝ) ≤
        50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ)) := by
      have hfac : (2 : ℝ) ≤ 50 * (bgpScaleW wg : ℝ) * (2 * Real.pi) := by
        nlinarith
      have hkey := mul_le_mul_of_nonneg_right hfac hj
      nlinarith [hkey]
    linarith
  have hApos : (0 : ℝ) < Real.exp (50 * (bgpScaleW wg : ℝ) * phase) :=
    Real.exp_pos _
  have hBpos : (0 : ℝ) <
      Real.exp (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ))) :=
    Real.exp_pos _
  have hprod : (D + 1) * (1 + 2 * (j : ℝ)) ≤
      Real.exp (50 * (bgpScaleW wg : ℝ) * phase) *
      Real.exp (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ))) := by
    exact mul_le_mul hA hB (by linarith) hApos.le
  rw [hsplit]
  have hlast : D + 2 * (j : ℝ) ≤ (D + 1) * (1 + 2 * (j : ℝ)) := by
    nlinarith
  have hfin : Real.exp (50 * (bgpScaleW wg : ℝ) * phase) *
      Real.exp (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ))) ≤
      len * (Real.exp (50 * (bgpScaleW wg : ℝ) * phase) *
        Real.exp (50 * (bgpScaleW wg : ℝ) * (2 * Real.pi * (j : ℝ)))) := by
    nlinarith [mul_pos hApos hBpos]
  linarith

/-- Package the target currency: `e^{−X} ≤ e^{−2j}·e^{−20·S}` whenever
`2j + 20·S ≤ X`. -/
theorem paper3NW4_currency {wg : ℕ} {j : ℕ} {X : ℝ}
    (h : 2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) ≤ X) :
    Real.exp (-X) ≤
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  linarith

/-- Leg 3: the settled z-write contraction residual. -/
theorem paper3NW4_leg_zc (wg : ℕ) (j : ℕ) :
    2 * paper3F1CwinDefN *
      Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
        selectorMUWriteHoldTime j))) ≤
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
  have hS := paper3NW4_S_ge wg
  have hS0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hπ := Real.pi_gt_three
  have hCwin := paper3NW4_CwinN_le_exp wg
  have hC0 : (0 : ℝ) < paper3F1CwinDefN := paper3F1CwinDefN_pos
  have hhold : selectorMUWriteHoldTime j =
      2 * Real.pi * (j : ℝ) + Real.pi / 2 := rfl
  have hkill := paper3NW4_grow_kill wg j (len := Real.pi / 3)
    (phase := Real.pi / 2)
    (D := 21 * (bgpScaleW wg : ℝ) + 203)
    (by linarith) (by linarith)
    (by nlinarith) (by nlinarith)
  have hXge : 2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
      ((bgpScaleW wg : ℝ) + 203) ≤
      Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
        selectorMUWriteHoldTime j) := by
    rw [hhold]
    linarith
  have h1 : Real.exp (-(Real.pi / 3 *
      Real.exp (50 * (bgpScaleW wg : ℝ) * selectorMUWriteHoldTime j))) ≤
      Real.exp (-(2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
        ((bgpScaleW wg : ℝ) + 203))) := by
    apply Real.exp_le_exp.mpr
    linarith
  have hsplit : Real.exp (-(2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
      ((bgpScaleW wg : ℝ) + 203))) =
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
      Real.exp (-((bgpScaleW wg : ℝ) + 203)) := by
    rw [← Real.exp_add, ← Real.exp_add]
    congr 1
    ring
  have hconst : 2 * paper3F1CwinDefN *
      Real.exp (-((bgpScaleW wg : ℝ) + 203)) ≤ 1 := by
    have hmul : paper3F1CwinDefN * Real.exp (-((bgpScaleW wg : ℝ) + 203)) ≤
        Real.exp ((bgpScaleW wg : ℝ) + 200) *
          Real.exp (-((bgpScaleW wg : ℝ) + 203)) := by
      exact mul_le_mul_of_nonneg_right hCwin (Real.exp_pos _).le
    have hcombine : Real.exp ((bgpScaleW wg : ℝ) + 200) *
        Real.exp (-((bgpScaleW wg : ℝ) + 203)) = Real.exp (-(3 : ℝ)) := by
      rw [← Real.exp_add]
      congr 1
      ring
    have hsm : Real.exp (-(3 : ℝ)) ≤ 1 / 2 := by
      rw [Real.exp_neg]
      have h3 : (2 : ℝ) ≤ Real.exp 3 := by
        have := Real.add_one_le_exp (3 : ℝ)
        linarith
      rw [inv_le_comm₀ (by positivity) (by norm_num)]
      linarith
    nlinarith [hmul, hcombine.le, hcombine.ge]
  calc 2 * paper3F1CwinDefN *
      Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
        selectorMUWriteHoldTime j)))
      ≤ 2 * paper3F1CwinDefN *
        (Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
          Real.exp (-((bgpScaleW wg : ℝ) + 203))) := by
        rw [← hsplit]
        exact mul_le_mul_of_nonneg_left h1 (by nlinarith)
    _ = (2 * paper3F1CwinDefN * Real.exp (-((bgpScaleW wg : ℝ) + 203))) *
        (Real.exp (-(2 * (j : ℝ))) *
          Real.exp (-(20 * (bgpScaleW wg : ℝ)))) := by ring
    _ ≤ 1 * (Real.exp (-(2 * (j : ℝ))) *
        Real.exp (-(20 * (bgpScaleW wg : ℝ)))) := by
        have hE := mul_nonneg (Real.exp_pos (-(2 * (j : ℝ)))).le
          (Real.exp_pos (-(20 * (bgpScaleW wg : ℝ)))).le
        exact mul_le_mul_of_nonneg_right hconst hE
    _ = Real.exp (-(2 * (j : ℝ))) *
        Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by ring

/-- Leg 5: the u-copy contraction residual. -/
theorem paper3NW4_leg_copy (wg : ℕ) (j : ℕ) :
    5 * D_U *
      Real.exp (-(2 * Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
        selectorMUUActiveStart j))) ≤
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
  have hS := paper3NW4_S_ge wg
  have hS0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hπ := Real.pi_gt_three
  have hDU := paper3NW4_DU_le_exp wg
  have hD8 := paper3Headline_D_U_ge_eight
  have hU0 : selectorMUUActiveStart j =
      2 * Real.pi * (j : ℝ) + 7 * Real.pi / 6 := rfl
  have hkill := paper3NW4_grow_kill wg j (len := 2 * Real.pi / 3)
    (phase := 7 * Real.pi / 6)
    (D := 21 * (bgpScaleW wg : ℝ) + 3)
    (by linarith) (by nlinarith)
    (by nlinarith) (by nlinarith)
  have h1 : Real.exp (-(2 * Real.pi / 3 *
      Real.exp (50 * (bgpScaleW wg : ℝ) * selectorMUUActiveStart j))) ≤
      Real.exp (-(2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
        ((bgpScaleW wg : ℝ) + 3))) := by
    apply Real.exp_le_exp.mpr
    rw [hU0]
    linarith
  have hsplit : Real.exp (-(2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
      ((bgpScaleW wg : ℝ) + 3))) =
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
      Real.exp (-((bgpScaleW wg : ℝ) + 3)) := by
    rw [← Real.exp_add, ← Real.exp_add]
    congr 1
    ring
  have hconst : 5 * D_U * Real.exp (-((bgpScaleW wg : ℝ) + 3)) ≤ 1 := by
    have hmul : D_U * Real.exp (-((bgpScaleW wg : ℝ) + 3)) ≤
        Real.exp (bgpScaleW wg : ℝ) *
          Real.exp (-((bgpScaleW wg : ℝ) + 3)) :=
      mul_le_mul_of_nonneg_right hDU (Real.exp_pos _).le
    have hcombine : Real.exp (bgpScaleW wg : ℝ) *
        Real.exp (-((bgpScaleW wg : ℝ) + 3)) = Real.exp (-(3 : ℝ)) := by
      rw [← Real.exp_add]
      congr 1
      ring
    have hsm : Real.exp (-(3 : ℝ)) ≤ 1 / 20 := by
      rw [Real.exp_neg]
      have h3 := paper3NW4_exp_three_ge
      rw [inv_le_comm₀ (by positivity) (by norm_num)]
      linarith
    have h4 : D_U * Real.exp (-((bgpScaleW wg : ℝ) + 3)) ≤
        Real.exp (-(3 : ℝ)) := by
      rw [← hcombine]
      exact hmul
    linarith [h4, hsm]
  calc 5 * D_U *
      Real.exp (-(2 * Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
        selectorMUUActiveStart j)))
      ≤ 5 * D_U *
        (Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
          Real.exp (-((bgpScaleW wg : ℝ) + 3))) := by
        rw [← hsplit]
        exact mul_le_mul_of_nonneg_left h1 (by nlinarith)
    _ = (5 * D_U * Real.exp (-((bgpScaleW wg : ℝ) + 3))) *
        (Real.exp (-(2 * (j : ℝ))) *
          Real.exp (-(20 * (bgpScaleW wg : ℝ)))) := by ring
    _ ≤ 1 * (Real.exp (-(2 * (j : ℝ))) *
        Real.exp (-(20 * (bgpScaleW wg : ℝ)))) := by
        have hE := mul_nonneg (Real.exp_pos (-(2 * (j : ℝ)))).le
          (Real.exp_pos (-(20 * (bgpScaleW wg : ℝ)))).le
        exact mul_le_mul_of_nonneg_right hconst hE
    _ = Real.exp (-(2 * (j : ℝ))) *
        Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by ring

/-- The freeze/eval box constant. -/
def paper3NW4C0 : ℝ := 20000 * D_U ^ 2 + 9000 * D_U

theorem paper3NW4C0_nonneg : 0 ≤ paper3NW4C0 := by
  unfold paper3NW4C0
  have := D_U_nonneg
  positivity

theorem paper3NW4C0_le_exp (wg : ℕ) :
    paper3NW4C0 ≤ Real.exp (2 * (bgpScaleW wg : ℝ) + 11) := by
  have hDU := paper3NW4_DU_le_exp wg
  have hD0 := D_U_nonneg
  have hE0 : (0 : ℝ) < Real.exp (bgpScaleW wg : ℝ) := Real.exp_pos _
  have hsq : D_U ^ 2 ≤ Real.exp (bgpScaleW wg : ℝ) ^ 2 := by
    nlinarith
  have hexp2 : Real.exp (bgpScaleW wg : ℝ) ^ 2 =
      Real.exp (2 * (bgpScaleW wg : ℝ)) := by
    rw [show (2 : ℝ) * (bgpScaleW wg : ℝ) =
      (bgpScaleW wg : ℝ) + (bgpScaleW wg : ℝ) by ring, Real.exp_add]
    ring
  have h11 : (29000 : ℝ) ≤ Real.exp (11 : ℝ) := by
    have h1 : (11 : ℝ) = 8 * (11 / 8) := by norm_num
    have hq := paper3NW4_sq_quarter_le_exp (by norm_num : (0 : ℝ) ≤ 22)
    -- e^{22} ≥ 22²/4 = 121; too weak — use (e^{11} ≥ (11)²/4·... no.
    -- direct: e^{11} = (e^{11/4})⁴ ≥ ((11/4)²/4)⁴? messy; use exp_one bounds
    have he : (2.7182818283 : ℝ) ≤ Real.exp 1 := Real.exp_one_gt_d9.le
    have h2 : (2.7182818283 : ℝ) ^ (11 : ℕ) ≤ Real.exp 1 ^ (11 : ℕ) :=
      pow_le_pow_left₀ (by norm_num) he 11
    have h3 : Real.exp 1 ^ (11 : ℕ) = Real.exp (11 : ℝ) := by
      rw [← Real.exp_nat_mul]
      norm_num
    have h4 : (29000 : ℝ) ≤ (2.7182818283 : ℝ) ^ (11 : ℕ) := by
      norm_num
    linarith
  have hD1 : 1 ≤ D_U := by
    have := paper3Headline_D_U_ge_eight
    linarith
  unfold paper3NW4C0
  have hcomb : Real.exp (2 * (bgpScaleW wg : ℝ) + 11) =
      Real.exp (2 * (bgpScaleW wg : ℝ)) * Real.exp (11 : ℝ) := by
    rw [← Real.exp_add]
  have hDsq : (1 : ℝ) ≤ Real.exp (2 * (bgpScaleW wg : ℝ)) := by
    rw [Real.one_le_exp_iff]
    have := bgpScaleWR_pos wg
    nlinarith
  nlinarith [hsq, hexp2.le, hexp2.ge]

/-- Leg 4: the z-freeze slop. -/
theorem paper3NW4_leg_freeze (wg : ℕ) (j : ℕ) :
    paper3NW4C0 *
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) /
      (200 * (bgpScaleW wg : ℝ)) ≤
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by
  have hS := paper3NW4_S_ge wg
  have hS0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hπ := Real.pi_gt_three
  have hC0 := paper3NW4C0_nonneg
  have hC0e := paper3NW4C0_le_exp wg
  have hc200 : (0 : ℝ) < 200 * (bgpScaleW wg : ℝ) := by nlinarith
  have hz : selectorMUZOffStart j = 2 * Real.pi * (j : ℝ) + Real.pi := rfl
  have hXge : 2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
      (2 * (bgpScaleW wg : ℝ) + 11) ≤
      200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j := by
    rw [hz]
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    have hf1 : (2 : ℝ) ≤ 200 * (bgpScaleW wg : ℝ) * (2 * Real.pi) := by
      nlinarith
    have hf2 := mul_le_mul_of_nonneg_right hf1 hj
    have hf3 : 22 * (bgpScaleW wg : ℝ) + 11 ≤
        200 * (bgpScaleW wg : ℝ) * Real.pi := by
      nlinarith
    nlinarith [hf2, hf3]
  have h1 : Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) ≤
      Real.exp (-(2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
        (2 * (bgpScaleW wg : ℝ) + 11))) := by
    apply Real.exp_le_exp.mpr
    linarith
  have hsplit : Real.exp (-(2 * (j : ℝ) + 20 * (bgpScaleW wg : ℝ) +
      (2 * (bgpScaleW wg : ℝ) + 11))) =
      Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
      Real.exp (-(2 * (bgpScaleW wg : ℝ) + 11)) := by
    rw [← Real.exp_add, ← Real.exp_add]
    congr 1
    ring
  have hconst : paper3NW4C0 * Real.exp (-(2 * (bgpScaleW wg : ℝ) + 11)) ≤ 1 := by
    have hmul := mul_le_mul_of_nonneg_right hC0e
      (Real.exp_pos (-(2 * (bgpScaleW wg : ℝ) + 11))).le
    have hcombine : Real.exp (2 * (bgpScaleW wg : ℝ) + 11) *
        Real.exp (-(2 * (bgpScaleW wg : ℝ) + 11)) = 1 := by
      rw [← Real.exp_add, add_neg_cancel, Real.exp_zero]
    linarith
  have hEE : (0 : ℝ) ≤ Real.exp (-(2 * (j : ℝ))) *
      Real.exp (-(20 * (bgpScaleW wg : ℝ))) :=
    mul_nonneg (Real.exp_pos _).le (Real.exp_pos _).le
  calc paper3NW4C0 *
      Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) /
      (200 * (bgpScaleW wg : ℝ))
      ≤ paper3NW4C0 *
        Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) := by
        rw [div_le_iff₀ hc200]
        have hbase : (0 : ℝ) ≤ paper3NW4C0 *
            Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) :=
          mul_nonneg hC0 (Real.exp_pos _).le
        nlinarith
    _ ≤ paper3NW4C0 *
        (Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) *
          Real.exp (-(2 * (bgpScaleW wg : ℝ) + 11))) := by
        rw [← hsplit]
        exact mul_le_mul_of_nonneg_left h1 hC0
    _ = (paper3NW4C0 * Real.exp (-(2 * (bgpScaleW wg : ℝ) + 11))) *
        (Real.exp (-(2 * (j : ℝ))) *
          Real.exp (-(20 * (bgpScaleW wg : ℝ)))) := by ring
    _ ≤ 1 * (Real.exp (-(2 * (j : ℝ))) *
        Real.exp (-(20 * (bgpScaleW wg : ℝ)))) :=
        mul_le_mul_of_nonneg_right hconst hEE
