              Real.exp ((bgpParamsNW wg).cα * a))) := by
        rw [hC1_def]
        have hgpos : (0 : ℝ) < ((paper3WarmGainQNW wg : ℚ) : ℝ) := by
          linarith
        have hexp_cancel : Real.exp (-((bgpParamsNW wg).cα * a)) *
