/-! Elementary numeric facts. -/

theorem paper3S13_exp_pow_ge {n : ℕ} {x : ℝ} (hx : (n : ℝ) ≤ x) :
    (2 : ℝ) ^ n ≤ Real.exp x := by
  have h2e : (2 : ℝ) ≤ Real.exp 1 := by
    linarith [Real.add_one_le_exp (1 : ℝ)]
  calc (2 : ℝ) ^ n
      ≤ Real.exp 1 ^ n := pow_le_pow_left₀ (by norm_num) h2e n
    _ = Real.exp ((n : ℝ) * 1) := (Real.exp_nat_mul 1 n).symm
    _ = Real.exp (n : ℝ) := by rw [mul_one]
    _ ≤ Real.exp x := Real.exp_le_exp.mpr hx

theorem paper3S13_exp_neg_three_le : Real.exp (-(3 : ℝ)) ≤ 1 / 8 := by
  have h8 : (8 : ℝ) ≤ Real.exp 3 := by
    have := paper3S13_exp_pow_ge (n := 3) (x := 3) (by norm_num)
    norm_num at this
    linarith
  calc Real.exp (-(3 : ℝ)) = 1 / Real.exp 3 := by
        rw [Real.exp_neg, one_div]
    _ ≤ 1 / 8 := one_div_le_one_div_of_le (by norm_num) h8

theorem paper3S13_gapVal_ge_half :
    (1 / 2 : ℝ) ≤
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := by
