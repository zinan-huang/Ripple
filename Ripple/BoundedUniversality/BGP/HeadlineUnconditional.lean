      exact paper3Headline_lam_ratio_card_bound_at
        (lam := fun v' : UniversalLocalView => sol.lam v' a)
        (vstar := localViewU (paper3F1Cfg w j))
        (paper3NW_lam_sum_forward w w a ha0)
        (fun v' => paper3NW_lam_nonneg_forward w w v' a ha0)
        hfloor_a v hv)
    (fun t' ht' => by
      have heq : t' = t := le_antisymm ht'.2 ht'.1
      rw [heq, hKt_def])
    (fun t' ht' => by
      have heq : t' = t := le_antisymm ht'.2 ht'.1
      rw [heq])
  have h := hraw t ⟨le_rfl, le_rfl⟩
  simpa [sol, a, gap, Kt, hgap_def, hKt_def, hsol, ha_def] using h

noncomputable def paper3S4aLoserCoeffNW (w j : ℕ) : ℝ :=
  ((Fintype.card UniversalLocalView : ℝ) - 1) *
    ((Fintype.card UniversalLocalView : ℝ) *
      paper3S4aInitialCoeffNW w j + paper3S4ResetCoeffNW w)

theorem paper3S4aLoserCoeffNW_nonneg (w j : ℕ) :
    0 ≤ paper3S4aLoserCoeffNW w j := by
  have hcard : (1 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) := by
    exact_mod_cast Fintype.card_pos_iff.mpr
      (⟨defaultLocalViewU⟩ : Nonempty UniversalLocalView)
  unfold paper3S4aLoserCoeffNW
  exact mul_nonneg (sub_nonneg.mpr hcard)
    (add_nonneg
      (mul_nonneg (by positivity) (paper3S4aInitialCoeffNW_nonneg w j))
      (paper3S4ResetCoeffNW_nonneg w))

/-- The S4a loser mass itself, not merely a frozen per-cycle radius, decays
at the running physical-time rate `cα`. -/
theorem paper3S4a_loser_mass_timelocal_NW (w j : ℕ) :
    ∀ t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUZOffStart j),
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j))).sum
          (fun v => ((paper3HeadlineSolFamNW w) w).lam v t) ≤
      paper3S4aLoserCoeffNW w j *
        Real.exp (-((bgpParamsNW w).cα * t)) := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  intro t ht
  let sol := (paper3HeadlineSolFamNW w) w
  let a := selectorMUSelectStartTime j
  let gap := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let Kt := ∫ s in a..t,
    Real.exp (gap * (sol.G s - sol.G a)) *
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        ((paper3HeadlineKappa : ℚ) : ℝ))
  let X := Real.exp (-(gap * (sol.G t - sol.G a)))
  have hgap : (15 : ℝ) / 16 ≤ gap := by
    simpa [gap, paper3RecoveryGap] using
      paper3RecoveryGap_ge_fifteen_sixteen w j
  have hraw := paper3S4a_loser_mass_exact_NW w j t ht
  rw [epsLamSettled_card_inv] at hraw
  have hX : X ≤ paper3S4aInitialCoeffNW w j *
      Real.exp (-((bgpParamsNW w).cα * t)) := by
    simpa [X, sol, a, gap] using
      paper3S4a_homogeneous_timelocal_NW w j hgap ht
  have hKX : Kt * X ≤ paper3S4ResetCoeffNW w *
      Real.exp (-((bgpParamsNW w).cα * t)) := by
    simpa [Kt, X, sol, a, gap, neg_mul] using
      paper3S4a_reset_duhamel_timelocal_NW w j hgap ht
  have hcard0 : 0 ≤ (Fintype.card UniversalLocalView : ℝ) := by positivity
  have hcardm1 : 0 ≤ (Fintype.card UniversalLocalView : ℝ) - 1 := by
    have hcard : (1 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) := by
      exact_mod_cast Fintype.card_pos_iff.mpr
        (⟨defaultLocalViewU⟩ : Nonempty UniversalLocalView)
    linarith
  calc
    (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j))).sum
        (fun v => sol.lam v t)
        ≤ ((Fintype.card UniversalLocalView : ℝ) - 1) *
          (((Fintype.card UniversalLocalView : ℝ) + Kt) * X) := by
            simpa [sol, a, gap, Kt, X] using hraw
    _ = ((Fintype.card UniversalLocalView : ℝ) - 1) *
          ((Fintype.card UniversalLocalView : ℝ) * X + Kt * X) := by ring
    _ ≤ ((Fintype.card UniversalLocalView : ℝ) - 1) *
          ((Fintype.card UniversalLocalView : ℝ) *
              (paper3S4aInitialCoeffNW w j *
                Real.exp (-((bgpParamsNW w).cα * t))) +
            paper3S4ResetCoeffNW w *
              Real.exp (-((bgpParamsNW w).cα * t))) := by
      apply mul_le_mul_of_nonneg_left _ hcardm1
      exact add_le_add (mul_le_mul_of_nonneg_left hX hcard0) hKX
    _ = paper3S4aLoserCoeffNW w j *
          Real.exp (-((bgpParamsNW w).cα * t)) := by
      unfold paper3S4aLoserCoeffNW
      ring

/-! ### Q4158/S2 Glue 1 input: the M₁ mix-concentration producer

Anchored at WRITE START (not at the read time): the landed
`paper3NW4_mix_radius` already pins the mixture target to the NEXT encoding
on `[wh j, zOffStart j]` with radius
`coordMult·|u(ws) − enc(cfg j)| + (6·Drift + 4·D_U·EpsLam)`, and the two
numeric legs `paper3NW4_leg_drift` / `paper3NW4_leg_eps` are landed.  So the
M₁ producer is pure assembly; the ONLY analytic premise is the sharp
write-start read error `epsIn`, which the S2 cycle induction supplies
(cf. Q4151 §4: S2 must export its exact radius for the next cycle).  This
obsoletes the Q4158 `drift1`-at-`wr` route (would duplicate the landed
`paper3NW4Drift` legs). -/

/-- The S2 piece-1 M₁ radius, anchored at write start. -/
noncomputable def paper3S2M1NW (wg j : ℕ) (epsIn : ℝ) : ℝ :=
  6 * epsIn + (6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j)

theorem paper3S2M1NW_nonneg (wg j : ℕ) {epsIn : ℝ}
    (h0 : 0 ≤ epsIn) : 0 ≤ paper3S2M1NW wg j epsIn := by
  unfold paper3S2M1NW
  have h1 := paper3NW4Drift_nonneg wg j
  have h2 : 0 ≤ 4 * D_U * paper3NW4EpsLam wg j := by
    have := paper3NW4EpsLam_nonneg wg j
    nlinarith [D_U_nonneg]
  linarith

/-- **The M₁ producer** (Q4142 handoff row, Q4158 corrected): on the whole
`[wr j, zOffStart j]` piece the mixture target is `M₁`-close to the NEXT
encoding, conditional only on the sharp write-start read error. -/
theorem paper3S2_M1_mix_conc_NW (w j : ℕ) {epsIn : ℝ}
    (hstart : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ epsIn) :
    ∀ t ∈ Icc (selectorMUWriteReadTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
            ((paper3HeadlineSolFamNW w) w).lam t i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
        paper3S2M1NW w j epsIn := by
  classical
  intro t ht i
  rcases paper3F1_joint_step_core_NW w with ⟨core, hCwinEq⟩
  have hje := paper3F1_joint_tube_and_endpoint_NW w core
  have htube0 : ∀ i' : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i' -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i'| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN := by
    intro i'
    have h := (hje j).1 i'
    rw [hCwinEq] at h
    exact h
  have hwin : ∀ i' : Fin d_U, ∀ τ ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z τ i' -
        ((paper3HeadlineSolFamNW w) w).u τ i'| ≤ paper3F1CwinDefN := by
    intro i' τ hτ
    have h := core.hwin_of j (hje j).1 (hje j).2 i' τ hτ
    rwa [hCwinEq] at h
  obtain ⟨hT, hD⟩ := paper3NW4_tube_maintenance w w j htube0 hwin
  have hmixR := paper3NW4_mix_radius w w j hT hD
  have hwh_wr : selectorMUWriteHoldTime j ≤ selectorMUWriteReadTime j := by
    unfold selectorMUWriteHoldTime selectorMUWriteReadTime
    have := Real.pi_pos
    linarith
  have ht' : t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUZOffStart j) :=
    ⟨le_trans hwh_wr ht.1, ht.2⟩
  have h := hmixR t ht' i
  have hmult := coordMultiplierU_le_six (paper3F1Cfg w j) i
  have hmult0 := coordMultiplierU_nonneg (paper3F1Cfg w j) i
  have habs0 : 0 ≤
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| := abs_nonneg _
  have hWc : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ 6 * epsIn := by
    have hstep : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        6 * |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| :=
      mul_le_mul_of_nonneg_right hmult habs0
    have := hstart i
    linarith
  unfold paper3S2M1NW
  linarith [h, hWc]

/-- Ledger rows D+E: the anchored M₁ legs sit below `r/10`. -/
theorem paper3S2_M1_legs_le_tenth_NW (wg j : ℕ) :
    6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j ≤
      r_LE_U / 10 := by
  have h1 := paper3NW4_leg_drift wg j
  have h2 := paper3NW4_leg_eps wg j
  have hS : (4 : ℝ) ≤ (bgpScaleW wg : ℝ) := by
    exact_mod_cast bgpScaleW_ge_four wg
  have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
  have hej : Real.exp (-(2 * (j : ℝ))) ≤ 1 := by
    rw [Real.exp_le_one_iff]
    linarith
  have heS : Real.exp (-(20 * (bgpScaleW wg : ℝ))) ≤ Real.exp (-(80 : ℝ)) :=
    Real.exp_le_exp.mpr (by linarith)
  have h80 : (20000 : ℝ) ≤ Real.exp (80 : ℝ) := by
    have h10 : (11 : ℝ) ≤ Real.exp (10 : ℝ) := by
      have := Real.add_one_le_exp (10 : ℝ)
      linarith
    have hpow : (11 : ℝ) ^ (8 : ℕ) ≤ (Real.exp (10 : ℝ)) ^ (8 : ℕ) :=
      pow_le_pow_left₀ (by norm_num) h10 8
    have hexp8 : Real.exp (80 : ℝ) = (Real.exp (10 : ℝ)) ^ (8 : ℕ) := by
      rw [← Real.exp_nat_mul]
      norm_num
    rw [hexp8]
    nlinarith [hpow]
  have he80 : Real.exp (-(80 : ℝ)) ≤ 1 / 20000 := by
    rw [Real.exp_neg]
    have hpos : (0 : ℝ) < Real.exp (80 : ℝ) := Real.exp_pos _
    rw [inv_le_comm₀ hpos (by norm_num)]
    linarith
  have hcombo : Real.exp (-(2 * (j : ℝ))) *
      Real.exp (-(20 * (bgpScaleW wg : ℝ))) ≤ 1 / 20000 := by
    have h0 : 0 ≤ Real.exp (-(20 * (bgpScaleW wg : ℝ))) := (Real.exp_pos _).le
    calc Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ)))
        ≤ 1 * Real.exp (-(20 * (bgpScaleW wg : ℝ))) :=
          mul_le_mul_of_nonneg_right hej h0
      _ = Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by ring
      _ ≤ Real.exp (-(80 : ℝ)) := heS
      _ ≤ 1 / 20000 := he80
  have hr : r_LE_U / 10 = 1 / 10000 := by norm_num [r_LE_U]
  rw [hr]
  linarith

/-- M₁ closes its Q4142 ledger share `r/5` from the sharp-entry row. -/
theorem paper3S2_M1_le_fifth_NW (wg j : ℕ) {epsIn : ℝ}
    (hentry : 6 * epsIn ≤ r_LE_U / 10) :
    paper3S2M1NW wg j epsIn ≤ r_LE_U / 5 := by
  unfold paper3S2M1NW
  have := paper3S2_M1_legs_le_tenth_NW wg j
  linarith

/-- **Widened M₁ producer**: the mixture-target concentration holds on the
WHOLE hold-through-copy window `[wh j, zOffStart j]`, not merely
`[wr j, zOffStart j]`.  The landed `paper3NW4_mix_radius` already covers
`[wh, zOffStart]`; `paper3S2_M1_mix_conc_NW` only exposed the `[wr, zOffStart]`
sub-window.  Verbatim clone with the lower window bound widened `wr → wh`;
supplies the hold-window `hmix1` premise of the δs producer. -/
theorem paper3S2_M1_mix_conc_hold_NW (w j : ℕ) {epsIn : ℝ}
    (hstart : ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ epsIn) :
    ∀ t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
            ((paper3HeadlineSolFamNW w) w).lam t i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
        paper3S2M1NW w j epsIn := by
  classical
  intro t ht i
  rcases paper3F1_joint_step_core_NW w with ⟨core, hCwinEq⟩
  have hje := paper3F1_joint_tube_and_endpoint_NW w core
  have htube0 : ∀ i' : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i' -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i'| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN := by
    intro i'
    have h := (hje j).1 i'
    rw [hCwinEq] at h
    exact h
  have hwin : ∀ i' : Fin d_U, ∀ τ ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW w) w).z τ i' -
        ((paper3HeadlineSolFamNW w) w).u τ i'| ≤ paper3F1CwinDefN := by
    intro i' τ hτ
    have h := core.hwin_of j (hje j).1 (hje j).2 i' τ hτ
    rwa [hCwinEq] at h
  obtain ⟨hT, hD⟩ := paper3NW4_tube_maintenance w w j htube0 hwin
  have hmixR := paper3NW4_mix_radius w w j hT hD
  have h := hmixR t ht i
  have hmult := coordMultiplierU_le_six (paper3F1Cfg w j) i
  have hmult0 := coordMultiplierU_nonneg (paper3F1Cfg w j) i
  have habs0 : 0 ≤
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| := abs_nonneg _
  have hWc : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
      |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ 6 * epsIn := by
    have hstep : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        6 * |((paper3HeadlineSolFamNW w) w).u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| :=
      mul_le_mul_of_nonneg_right hmult habs0
    have := hstart i
    linarith
  unfold paper3S2M1NW
  linarith [h, hWc]

/-- **Sharper M₁ legs bound**: the two anchored M₁ legs
`6·Drift + 4·D_U·EpsLam` sit below `r/20` (not merely `r/10`), leaving room
for the settling residual in the δs producer.  Same `e^{−80}`-scale legs,
`40000 ≤ e^{80}` in place of `20000 ≤ e^{80}`. -/
theorem paper3S2_M1_legs_le_twentieth_NW (wg j : ℕ) :
    6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j ≤
      r_LE_U / 20 := by
  have h1 := paper3NW4_leg_drift wg j
  have h2 := paper3NW4_leg_eps wg j
  have hS : (4 : ℝ) ≤ (bgpScaleW wg : ℝ) := by
    exact_mod_cast bgpScaleW_ge_four wg
  have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
  have hej : Real.exp (-(2 * (j : ℝ))) ≤ 1 := by
    rw [Real.exp_le_one_iff]
    linarith
  have heS : Real.exp (-(20 * (bgpScaleW wg : ℝ))) ≤ Real.exp (-(80 : ℝ)) :=
    Real.exp_le_exp.mpr (by linarith)
  have h80 : (40000 : ℝ) ≤ Real.exp (80 : ℝ) := by
    have h10 : (11 : ℝ) ≤ Real.exp (10 : ℝ) := by
      have := Real.add_one_le_exp (10 : ℝ)
      linarith
    have hpow : (11 : ℝ) ^ (8 : ℕ) ≤ (Real.exp (10 : ℝ)) ^ (8 : ℕ) :=
      pow_le_pow_left₀ (by norm_num) h10 8
    have hexp8 : Real.exp (80 : ℝ) = (Real.exp (10 : ℝ)) ^ (8 : ℕ) := by
      rw [← Real.exp_nat_mul]
      norm_num
    rw [hexp8]
    nlinarith [hpow]
  set P : ℝ := Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ)))
    with hP
  have hPcap : P ≤ Real.exp (-(80 : ℝ)) := by
    rw [hP]
    calc Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ)))
        ≤ 1 * Real.exp (-(20 * (bgpScaleW wg : ℝ))) :=
          mul_le_mul_of_nonneg_right hej (Real.exp_pos _).le
      _ = Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by ring
      _ ≤ Real.exp (-(80 : ℝ)) := heS
  have hr : r_LE_U = 1 / 1000 := rfl
  have h2cap : 2 * Real.exp (-(80 : ℝ)) ≤ r_LE_U / 20 := by
    have heneg : Real.exp (-(80 : ℝ)) = 1 / Real.exp (80 : ℝ) := by
      rw [Real.exp_neg]; ring
    have hrecip : 1 / Real.exp 80 ≤ 1 / 40000 :=
      one_div_le_one_div_of_le (by norm_num) h80
    rw [heneg, hr]
    calc 2 * (1 / Real.exp 80) ≤ 2 * (1 / 40000) :=
          mul_le_mul_of_nonneg_left hrecip (by norm_num)
      _ = 1 / 1000 / 20 := by norm_num
  have hlegs : 6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j ≤ 2 * P := by
    have hh1 : 6 * paper3NW4Drift wg j ≤ P := h1
    have hh2 : 4 * D_U * paper3NW4EpsLam wg j ≤ P := h2
    linarith
  have h2P : 2 * P ≤ 2 * Real.exp (-(80 : ℝ)) := by linarith [hPcap]
  linarith [hlegs, h2P, h2cap]

/-! ### S2-NW handoff-window guard producers (Q4151 Glue 1) -/

noncomputable def paper3S2HandoffCz : ℝ := 2 * D_U + 1

noncomputable def paper3S2HandoffCu : ℝ := 2 * D_U + 2

noncomputable def paper3S2HandoffBranchGuard : ℝ :=
  2 * D_U + 4000 * D_U * (5 * D_U + 2)

noncomputable def paper3S2HandoffMixZGuard : ℝ :=
  paper3S2HandoffBranchGuard + paper3S2HandoffCz

theorem paper3S2HandoffMixZGuard_nonneg :
    0 ≤ paper3S2HandoffMixZGuard := by
  unfold paper3S2HandoffMixZGuard paper3S2HandoffBranchGuard paper3S2HandoffCz
  nlinarith [D_U_nonneg]

theorem paper3S2_handoff_branch_abs_le_guard (w j : ℕ) {t : ℝ}
    (hu : ∀ k : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u t k| ≤ paper3S2HandoffCu) :
    ∀ (i : Fin d_U) (v : UniversalLocalView),
      |BranchData.evalBranch (branchU v)
          (((paper3HeadlineSolFamNW w) w).u t) i| ≤
        paper3S2HandoffBranchGuard := by
  intro i v
  have henc := paper3NW4_enc_abs (paper3F1Cfg w (j + 1)) i
  have hui := hu i
  have hx : |((paper3HeadlineSolFamNW w) w).u t i -
      stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
      5 * D_U + 2 := by
    have htri := abs_sub (((paper3HeadlineSolFamNW w) w).u t i)
      (stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i)
    unfold paper3S2HandoffCu at hui
    nlinarith [D_U_nonneg, htri, henc, hui]
  have h := paper3NW4_eval_abs_of_coord_bound v i
    (paper3F1Cfg w (j + 1)) hx
  unfold paper3S2HandoffBranchGuard
  exact h

theorem paper3S2_handoff_mixz_abs_le_guard (w j : ℕ) {t : ℝ}
    (ht0 : 0 ≤ t)
    (hu : ∀ k : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u t k| ≤ paper3S2HandoffCu)
    (i : Fin d_U)
    (hz : |((paper3HeadlineSolFamNW w) w).z t i| ≤ paper3S2HandoffCz) :
    |selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
        ((paper3HeadlineSolFamNW w) w).lam t i -
      ((paper3HeadlineSolFamNW w) w).z t i| ≤
        paper3S2HandoffMixZGuard := by
  have hmix := paper3NW_mixTarget_abs_le_of_branch_abs w w ht0
    (fun i' v => paper3S2_handoff_branch_abs_le_guard w j hu i' v) i
  have htri := abs_sub
    (selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
      ((paper3HeadlineSolFamNW w) w).lam t i)
    (((paper3HeadlineSolFamNW w) w).z t i)
  unfold paper3S2HandoffMixZGuard
  nlinarith [htri, hmix, hz]

theorem paper3S2_handoff_u_b_abs_NW (w j : ℕ) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW w) w).u
          (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) i| ≤
        paper3S2HandoffCu := by
  intro i
  have hb_edge :
      (2 * Real.pi * (j : ℝ) + 5 * Real.pi / 6) ∈
        Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j) := by
    change selectorMUWriteReadTime j ∈
      Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j)
    exact ⟨selectorMUWriteStart_le_read j, paper3NW4_wr_le_zOffStart j⟩
