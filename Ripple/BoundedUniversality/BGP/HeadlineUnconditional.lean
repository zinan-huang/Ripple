/-- The Hoff exponent is beaten by the late-subwindow gate scale, at every
cycle including `j = 0`. -/
theorem paper3S13_hoffExp_le_gate (j : ℕ) :
    200 * Real.pi * (2 * (j : ℝ) + 1) ≤
      Real.pi / 24 * Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) := by
  have hπ3 : (3 : ℝ) < Real.pi := Real.pi_gt_three
  have hπ0 : (0 : ℝ) < Real.pi := Real.pi_pos
  have hj0 : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
  have hE : (8192 : ℝ) ≤ Real.exp (175 * Real.pi / 6) := by
    have h13 : ((13 : ℕ) : ℝ) ≤ 175 * Real.pi / 6 := by
      push_cast
      nlinarith
    have := paper3S13_exp_pow_ge h13
    norm_num at this
    linarith
  have hlin : 1 + 100 * Real.pi * (j : ℝ) ≤
      Real.exp (100 * Real.pi * (j : ℝ)) := by
    linarith [Real.add_one_le_exp (100 * Real.pi * (j : ℝ))]
  have hsplit : Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) =
      Real.exp (175 * Real.pi / 6) * Real.exp (100 * Real.pi * (j : ℝ)) := by
    rw [← Real.exp_add]
    ring_nf
  have hprod : (8192 : ℝ) * (1 + 100 * Real.pi * (j : ℝ)) ≤
      Real.exp (175 * Real.pi / 6) * Real.exp (100 * Real.pi * (j : ℝ)) := by
    have h1x : (0 : ℝ) ≤ 1 + 100 * Real.pi * (j : ℝ) := by positivity
    exact mul_le_mul hE hlin h1x (le_trans (by norm_num) hE)
  have hmain : Real.pi / 24 * (8192 * (1 + 100 * Real.pi * (j : ℝ))) ≤
      Real.pi / 24 * Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) := by
    rw [hsplit]
    exact mul_le_mul_of_nonneg_left hprod (by positivity)
  have hπj : 0 ≤ Real.pi * (j : ℝ) := by positivity
  nlinarith [hmain, hπj, hπ0.le,
    mul_nonneg (by linarith : (0 : ℝ) ≤ Real.pi - 3) hπj]

