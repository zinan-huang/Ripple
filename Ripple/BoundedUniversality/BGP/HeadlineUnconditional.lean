    (universalPval eta heta)

/-- Realized N-parametric solution family: only the finite-horizon bound is
consumed; every structural realization is discharged by the `_N` lemmas
above. -/
noncomputable def solMUReplRealizedN
    (eta : ℚ) (heta : 0 < eta) (M : ℕ) (κ₀ g₀ : ℚ)
    (HP : MvPolynomial (Fin d_U) ℚ) (Kq : ℚ) (R : ℕ)
