      gg τ ∈ Icc (-(max E B)) (max E B) := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans ha0 hτ.1
    have hkkp := hkk_pos τ hτ0
    have hkZnn := (hkZ_pos τ hτ0).le
    have hkUnn := (hkU_pos τ hτ0).le
    have hmu := hB i τ hτ
