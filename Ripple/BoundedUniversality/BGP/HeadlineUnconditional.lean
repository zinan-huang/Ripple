    simp only [bGateZ]
    exact Real.continuous_exp.comp
      ((((paper3HeadlineSolFamNW w) w).cont_μ.mul hr).neg)
  have hgateU_cont : Continuous fun τ : ℝ =>
      bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ := by
    have hq : Continuous fun τ : ℝ => qPulse (bgpParamsNW w).L τ := by
      simp only [qPulse]
      exact ((continuous_const.add Real.continuous_sin).div_const 2).pow
