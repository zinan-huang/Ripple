def paper3WarmGainC : ℚ := 1734736490

def paper3WarmGainQ (w : ℕ) : ℚ :=
  paper3WarmGainC * (6 : ℚ) ^ w

def paper3Pow6Nat : ℕ → ℕ :=
  Nat.rec 1 (fun _ ih => 6 * ih)

theorem computable_paper3Pow6Nat : Computable paper3Pow6Nat := by
  have hstep : Primrec₂ (fun _ ih : ℕ => 6 * ih) :=
    Primrec.nat_mul.comp₂ (Primrec₂.const 6) Primrec₂.right
  exact (Primrec.nat_rec₁ 1 hstep).to_comp

theorem paper3Pow6Nat_eq (w : ℕ) : paper3Pow6Nat w = 6 ^ w := by
  induction w with
  | zero => rfl
  | succ w ih =>
      calc
        paper3Pow6Nat (w + 1) = 6 * paper3Pow6Nat w := rfl
        _ = 6 * 6 ^ w := by rw [ih]
        _ = 6 ^ (w + 1) := by
          rw [pow_succ]
          exact Nat.mul_comm 6 (6 ^ w)

def paper3WarmGainQPresenter (w : ℕ) : ℤ × ℕ :=
  (Int.ofNat (1734736490 * paper3Pow6Nat w), 1)

theorem computable_paper3WarmGainQPresenter :
    Computable paper3WarmGainQPresenter := by
  have hnumNat : Computable fun w => 1734736490 * paper3Pow6Nat w :=
    Primrec.nat_mul.to_comp.comp (Computable.const 1734736490)
      computable_paper3Pow6Nat
  have hnumInt : Computable fun w => Int.ofNat (1734736490 * paper3Pow6Nat w) :=
    computable_int_ofNat.comp hnumNat
  exact (Computable.pair hnumInt (Computable.const 1)).of_eq fun w => by
    simp [paper3WarmGainQPresenter]

theorem paper3WarmGainQ_presented :
    ∃ g : ℕ → ℤ × ℕ, Computable g ∧
      ∀ w, (g w).2 ≠ 0 ∧
        paper3WarmGainQ w = (g w).1 / ((g w).2 : ℚ) := by
  refine ⟨paper3WarmGainQPresenter, computable_paper3WarmGainQPresenter, ?_⟩
  intro w
  refine ⟨by simp [paper3WarmGainQPresenter], ?_⟩
  simp [paper3WarmGainQPresenter, paper3WarmGainQ, paper3WarmGainC,
    paper3Pow6Nat_eq]

/-! ### N-parametric warm gain (parallel `bgpParamsN` surface)

`paper3WarmGainCN = 1734736490 · bgpScale⁶` (BGPParamsN.lean) replaces the
fixed `paper3WarmGainC` on the N-parametric migration path.  The constant is
an opaque-but-fixed natural (it depends on
`Fintype.card (Option (SuppLabel c_f) × Option Γ')` through `bgpScale`), so the
presenter below is still computable: `Computable.const` does not require the
value to be a closed numeral.  The fixed-gain definitions above are left
untouched until every consumer has migrated. -/

def paper3WarmGainQNPresenter (w : ℕ) : ℤ × ℕ :=
  (Int.ofNat ((1734736490 * bgpScale ^ 6) * paper3Pow6Nat w), 1)

theorem computable_paper3WarmGainQNPresenter :
    Computable paper3WarmGainQNPresenter := by
  have hnumNat :
      Computable fun w => (1734736490 * bgpScale ^ 6) * paper3Pow6Nat w :=
    Primrec.nat_mul.to_comp.comp
      (Computable.const (1734736490 * bgpScale ^ 6))
      computable_paper3Pow6Nat
  have hnumInt :
      Computable fun w =>
        Int.ofNat ((1734736490 * bgpScale ^ 6) * paper3Pow6Nat w) :=
    computable_int_ofNat.comp hnumNat
  exact (Computable.pair hnumInt (Computable.const 1)).of_eq fun w => rfl

theorem paper3WarmGainQN_presented :
    ∃ g : ℕ → ℤ × ℕ, Computable g ∧
      ∀ w, (g w).2 ≠ 0 ∧
        paper3WarmGainQN w = (g w).1 / ((g w).2 : ℚ) := by
  refine ⟨paper3WarmGainQNPresenter, computable_paper3WarmGainQNPresenter, ?_⟩
  intro w
  refine ⟨one_ne_zero, ?_⟩
  have hval : paper3WarmGainQN w =
      ((1734736490 * bgpScale ^ 6 * paper3Pow6Nat w : ℕ) : ℚ) := by
    unfold paper3WarmGainQN paper3WarmGainCN
    simp only [paper3Pow6Nat_eq]
    push_cast
    ring
  rw [hval]
  show ((1734736490 * bgpScale ^ 6 * paper3Pow6Nat w : ℕ) : ℚ) =
    ((Int.ofNat (1734736490 * bgpScale ^ 6 * paper3Pow6Nat w) : ℤ) : ℚ) /
      ((1 : ℕ) : ℚ)
  rw [Int.ofNat_eq_natCast, Int.cast_natCast, Nat.cast_one, div_one]

/-- Bridge: the fixed warm gain is dominated by the N-parametric one, so every
lower-bound-shaped consumer of `paper3WarmGainC` migrates by transitivity. -/
theorem paper3WarmGainC_le_warmGainCN :
    paper3WarmGainC ≤ paper3WarmGainCN := by
  have h := paper3WarmGainCN_ge_base
  unfold paper3WarmGainC
  exact h

