/-- Master budget arithmetic: `144000·6^L ≤ e^{20·S w}`. -/
theorem paper3NW4_budget_master (w : ℕ) :
    144000 * (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) ≤
      Real.exp (20 * (bgpScaleW w : ℝ)) := by
  set L : ℕ := MachineInstance.inputLenU 1 w with hL_def
  have he2 : (6 : ℝ) ≤ Real.exp 2 := by
    have he := Real.exp_one_gt_d9.le
    have hsplit : Real.exp (2 : ℝ) = Real.exp 1 * Real.exp 1 := by
      rw [← Real.exp_add]
      norm_num
    nlinarith [Real.exp_pos (1 : ℝ)]
  have h12 : (160000 : ℝ) ≤ Real.exp 12 := by
    have h20 := paper3NW4_exp_three_ge
    have hE3 := Real.exp_pos (3 : ℝ)
    have h6 : (400 : ℝ) ≤ Real.exp 3 * Real.exp 3 := by nlinarith
    have h9 : (8000 : ℝ) ≤ Real.exp 3 * Real.exp 3 * Real.exp 3 := by
      nlinarith
    have hsplit : Real.exp (12 : ℝ) =
        Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 := by
      rw [show (12 : ℝ) = 3 + 3 + 3 + 3 by norm_num,
        Real.exp_add, Real.exp_add, Real.exp_add]
    rw [hsplit]
    nlinarith
  have hpowL : (6 : ℝ) ^ L ≤ Real.exp (2 * (L : ℝ)) := by
    have h1 : (6 : ℝ) ^ L ≤ Real.exp 2 ^ L :=
      pow_le_pow_left₀ (by norm_num) he2 L
    have h2 : Real.exp 2 ^ L = Real.exp ((L : ℝ) * 2) :=
      (Real.exp_nat_mul 2 L).symm
    rw [show (2 : ℝ) * (L : ℝ) = (L : ℝ) * 2 by ring]
    linarith [h1, h2.le, h2.ge]
  have hSL : 2 * (L : ℝ) + 12 ≤ 20 * (bgpScaleW w : ℝ) := by
    have hnat : 4 * (L + 1) ≤ bgpScaleW w := by
      have h1 : L + 1 ≤ 6 ^ L := Nat.lt_pow_self (by norm_num)
      have h2 : 6 ^ L ≤ 6 ^ (L + 220) :=
        Nat.pow_le_pow_right (by norm_num) (by omega)
      have h3 : 4 ≤ bgpScale := bgpScale_ge_four
      calc 4 * (L + 1) ≤ 4 * 6 ^ (L + 220) :=
            Nat.mul_le_mul_left 4 (le_trans h1 h2)
        _ ≤ bgpScale * 6 ^ (L + 220) :=
            Nat.mul_le_mul_right _ h3
        _ = bgpScaleW w := by
            unfold bgpScaleW bgpHeadStartN
            rw [hL_def]
    have hcast : 4 * ((L : ℝ) + 1) ≤ (bgpScaleW w : ℝ) := by
      exact_mod_cast hnat
    linarith
  have hsplit20 : Real.exp (20 * (bgpScaleW w : ℝ)) =
      Real.exp (20 * (bgpScaleW w : ℝ) - (2 * (L : ℝ) + 12)) *
      (Real.exp (2 * (L : ℝ)) * Real.exp (12 : ℝ)) := by
    rw [← Real.exp_add, ← Real.exp_add]
    congr 1
    ring
  have hone : (1 : ℝ) ≤
      Real.exp (20 * (bgpScaleW w : ℝ) - (2 * (L : ℝ) + 12)) := by
    rw [Real.one_le_exp_iff]
    linarith
  have hE2L := (Real.exp_pos (2 * (L : ℝ))).le
  have hE12 := (Real.exp_pos (12 : ℝ)).le
  have hP6 : (0 : ℝ) ≤ (6 : ℝ) ^ L := by positivity
  calc 144000 * (6 : ℝ) ^ L
      ≤ 160000 * (6 : ℝ) ^ L := by nlinarith
    _ ≤ Real.exp (12 : ℝ) * Real.exp (2 * (L : ℝ)) := by
        have := mul_le_mul h12 hpowL hP6 (by positivity)
        linarith [this]
    _ ≤ Real.exp (20 * (bgpScaleW w : ℝ) - (2 * (L : ℝ) + 12)) *
        (Real.exp (2 * (L : ℝ)) * Real.exp (12 : ℝ)) := by
        nlinarith [mul_nonneg hE2L hE12,
          mul_le_mul_of_nonneg_right hone (mul_nonneg hE2L hE12)]
    _ = Real.exp (20 * (bgpScaleW w : ℝ)) := hsplit20.symm

/-- Sharp master budget arithmetic: `4320000·6^L ≤ e^{20·S w}` (30× sibling
of `paper3NW4_budget_master`, per Q4163 §2.1: `160000 ≤ e^{12}` becomes
`5000000 ≤ e^{18}` and `2L+12 ≤ 20S` becomes `2L+18 ≤ 20S`, both loose
against `4(L+1) ≤ S`). -/
theorem paper3NW4_budget_master_sharp (w : ℕ) :
    4320000 * (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) ≤
      Real.exp (20 * (bgpScaleW w : ℝ)) := by
  set L : ℕ := MachineInstance.inputLenU 1 w with hL_def
  have he2 : (6 : ℝ) ≤ Real.exp 2 := by
    have he := Real.exp_one_gt_d9.le
    have hsplit : Real.exp (2 : ℝ) = Real.exp 1 * Real.exp 1 := by
      rw [← Real.exp_add]
      norm_num
    nlinarith [Real.exp_pos (1 : ℝ)]
  have h18 : (5000000 : ℝ) ≤ Real.exp 18 := by
    have h20 := paper3NW4_exp_three_ge
    have hE3 := Real.exp_pos (3 : ℝ)
    have h6 : (400 : ℝ) ≤ Real.exp 3 * Real.exp 3 := by nlinarith
    have h9 : (8000 : ℝ) ≤ Real.exp 3 * Real.exp 3 * Real.exp 3 := by
      nlinarith
    have h12 : (160000 : ℝ) ≤
        Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 := by
      nlinarith
    have h15 : (3200000 : ℝ) ≤
        Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 := by
      nlinarith
    have hsplit : Real.exp (18 : ℝ) =
        Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 * Real.exp 3 *
          Real.exp 3 := by
      rw [show (18 : ℝ) = 3 + 3 + 3 + 3 + 3 + 3 by norm_num,
        Real.exp_add, Real.exp_add, Real.exp_add, Real.exp_add, Real.exp_add]
    rw [hsplit]
    nlinarith
  have hpowL : (6 : ℝ) ^ L ≤ Real.exp (2 * (L : ℝ)) := by
    have h1 : (6 : ℝ) ^ L ≤ Real.exp 2 ^ L :=
      pow_le_pow_left₀ (by norm_num) he2 L
    have h2 : Real.exp 2 ^ L = Real.exp ((L : ℝ) * 2) :=
      (Real.exp_nat_mul 2 L).symm
    rw [show (2 : ℝ) * (L : ℝ) = (L : ℝ) * 2 by ring]
    linarith [h1, h2.le, h2.ge]
  have hSL : 2 * (L : ℝ) + 18 ≤ 20 * (bgpScaleW w : ℝ) := by
    have hnat : 4 * (L + 1) ≤ bgpScaleW w := by
      have h1 : L + 1 ≤ 6 ^ L := Nat.lt_pow_self (by norm_num)
      have h2 : 6 ^ L ≤ 6 ^ (L + 220) :=
        Nat.pow_le_pow_right (by norm_num) (by omega)
      have h3 : 4 ≤ bgpScale := bgpScale_ge_four
      calc 4 * (L + 1) ≤ 4 * 6 ^ (L + 220) :=
            Nat.mul_le_mul_left 4 (le_trans h1 h2)
        _ ≤ bgpScale * 6 ^ (L + 220) :=
            Nat.mul_le_mul_right _ h3
        _ = bgpScaleW w := by
            unfold bgpScaleW bgpHeadStartN
            rw [hL_def]
    have hcast : 4 * ((L : ℝ) + 1) ≤ (bgpScaleW w : ℝ) := by
      exact_mod_cast hnat
    linarith
  have hsplit20 : Real.exp (20 * (bgpScaleW w : ℝ)) =
      Real.exp (20 * (bgpScaleW w : ℝ) - (2 * (L : ℝ) + 18)) *
      (Real.exp (2 * (L : ℝ)) * Real.exp (18 : ℝ)) := by
    rw [← Real.exp_add, ← Real.exp_add]
    congr 1
    ring
  have hone : (1 : ℝ) ≤
      Real.exp (20 * (bgpScaleW w : ℝ) - (2 * (L : ℝ) + 18)) := by
    rw [Real.one_le_exp_iff]
    linarith
  have hE2L := (Real.exp_pos (2 * (L : ℝ))).le
  have hE18 := (Real.exp_pos (18 : ℝ)).le
  have hP6 : (0 : ℝ) ≤ (6 : ℝ) ^ L := by positivity
  calc 4320000 * (6 : ℝ) ^ L
      ≤ 5000000 * (6 : ℝ) ^ L := by nlinarith
    _ ≤ Real.exp (18 : ℝ) * Real.exp (2 * (L : ℝ)) := by
        have := mul_le_mul h18 hpowL hP6 (by positivity)
        linarith [this]
    _ ≤ Real.exp (20 * (bgpScaleW w : ℝ) - (2 * (L : ℝ) + 18)) *
        (Real.exp (2 * (L : ℝ)) * Real.exp (18 : ℝ)) := by
        nlinarith [mul_nonneg hE2L hE18,
          mul_le_mul_of_nonneg_right hone (mul_nonneg hE2L hE18)]
    _ = Real.exp (20 * (bgpScaleW w : ℝ)) := hsplit20.symm

/-- The geometric-sum coefficient of the F1 cap is at most `6`. -/
theorem paper3NW4_geo_coeff_le :
    1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2)) ≤ 6 := by
  have h6 : ((B_U : ℕ) : ℝ) = 6 := by norm_num [B_U]
  have hlog : Real.exp (Real.log (B_U : ℝ) - 2) =
      6 * Real.exp (-(2 : ℝ)) := by
    rw [Real.exp_sub, Real.exp_log (by rw [h6]; norm_num : (0 : ℝ) < (B_U : ℝ))]
    rw [h6, Real.exp_neg]
    ring
  have he2 : (7.38 : ℝ) ≤ Real.exp 2 := by
    have he := Real.exp_one_gt_d9.le
    have hsplit : Real.exp (2 : ℝ) = Real.exp 1 * Real.exp 1 := by
      rw [← Real.exp_add]
      norm_num
    nlinarith [Real.exp_pos (1 : ℝ)]
  have hval : Real.exp (Real.log (B_U : ℝ) - 2) ≤ 0.82 := by
    rw [hlog, Real.exp_neg]
    have hinv : (Real.exp 2)⁻¹ ≤ (7.38 : ℝ)⁻¹ := by
      rw [inv_eq_one_div, inv_eq_one_div]
      exact one_div_le_one_div_of_le (by norm_num) he2
    calc 6 * (Real.exp 2)⁻¹ ≤ 6 * (7.38 : ℝ)⁻¹ := by nlinarith
      _ ≤ 0.82 := by norm_num
  have hpos : (0.18 : ℝ) ≤ 1 - Real.exp (Real.log (B_U : ℝ) - 2) := by
    linarith
  rw [div_le_iff₀ (by linarith)]
  nlinarith

/-- **F1-NW (4/5) PROVED: tube-conditional source decay with the
diagonal-quantitative coefficient.**  The coefficient is the uniform
six-leg source constant `6·e^{−20·bgpScaleW w}`; the budget
`paper3F1GeomCap w Csrc ≤ r_LE_U/4` is the master arithmetic
`144000·6^L ≤ e^{20·bgpScaleW w}` (`paper3NW4_budget_master`). -/
theorem paper3F1_src_geo_quantitative_NW (w : ℕ) :
    ∃ Csrc : ℝ, 0 ≤ Csrc ∧
      paper3F1GeomCap w Csrc ≤ r_LE_U / 4 ∧
      ∀ j : ℕ,
        (∀ i, paper3F1BoundaryErrNW w j i ≤
          paper3F1TubeRadiusN paper3F1CwinDefN) →
        (∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
            (selectorMUWriteReadTime j),
          |((paper3HeadlineSolFamNW w) w).z t i -
            ((paper3HeadlineSolFamNW w) w).u t i| ≤ paper3F1CwinDefN) →
        ∀ i, paper3F1SrcCoreNW w j i ≤
          Csrc * Real.exp (-(2 : ℝ) * (j : ℝ)) := by
  refine ⟨6 * Real.exp (-(20 * (bgpScaleW w : ℝ))),
    by positivity, ?_, ?_⟩
  · -- budget: `GeomCap w (6·e^{−20·S}) ≤ r_LE_U/4`
    unfold paper3F1GeomCap
    have hL6 : Real.exp (Real.log (B_U : ℝ) *
        (MachineInstance.inputLenU 1 w : ℝ)) =
        (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) := by
      have h6 : ((B_U : ℕ) : ℝ) = 6 := by norm_num [B_U]
      rw [show Real.log (B_U : ℝ) * (MachineInstance.inputLenU 1 w : ℝ) =
        (MachineInstance.inputLenU 1 w : ℝ) * Real.log (B_U : ℝ) by ring]
      rw [Real.exp_nat_mul, Real.exp_log (by rw [h6]; norm_num :
        (0 : ℝ) < (B_U : ℝ)), h6]
    have hgeo := paper3NW4_geo_coeff_le
    have hgeo0 : (0 : ℝ) ≤ 1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2)) := by
      have h6 : ((B_U : ℕ) : ℝ) = 6 := by norm_num [B_U]
      have hlog : Real.exp (Real.log (B_U : ℝ) - 2) =
          6 * Real.exp (-(2 : ℝ)) := by
        rw [Real.exp_sub, Real.exp_log (by rw [h6]; norm_num :
          (0 : ℝ) < (B_U : ℝ))]
        rw [h6, Real.exp_neg]
        ring
      have he2 : (7.38 : ℝ) ≤ Real.exp 2 := by
        have he := Real.exp_one_gt_d9.le
        have hsplit : Real.exp (2 : ℝ) = Real.exp 1 * Real.exp 1 := by
          rw [← Real.exp_add]
          norm_num
        nlinarith [Real.exp_pos (1 : ℝ)]
      have hval : Real.exp (Real.log (B_U : ℝ) - 2) ≤ 0.82 := by
        rw [hlog, Real.exp_neg]
        have hinv : (Real.exp 2)⁻¹ ≤ (7.38 : ℝ)⁻¹ := by
          rw [inv_eq_one_div, inv_eq_one_div]
          exact one_div_le_one_div_of_le (by norm_num) he2
        calc 6 * (Real.exp 2)⁻¹ ≤ 6 * (7.38 : ℝ)⁻¹ := by nlinarith
          _ ≤ 0.82 := by norm_num
      exact div_nonneg zero_le_one (by linarith)
    have hmaster := paper3NW4_budget_master w
    have hE20 := (Real.exp_pos (-(20 * (bgpScaleW w : ℝ)))).le
    have hP6 : (0 : ℝ) ≤ (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) := by
      positivity
    have hr : r_LE_U = 1 / 1000 := rfl
    rw [hL6]
    -- goal: 6^L·(6e^{−20S})·geo ≤ 1/4000
    have hkey : (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) *
        (6 * Real.exp (-(20 * (bgpScaleW w : ℝ)))) * 6 ≤ 1 / 4000 := by
      have hcancel : Real.exp (20 * (bgpScaleW w : ℝ)) *
          Real.exp (-(20 * (bgpScaleW w : ℝ))) = 1 := by
        rw [← Real.exp_add, add_neg_cancel, Real.exp_zero]
      have h1 : (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) * 36 * 4000 ≤
          Real.exp (20 * (bgpScaleW w : ℝ)) := by
        nlinarith [hmaster, hP6]
      have h2 := mul_le_mul_of_nonneg_right h1 hE20
      rw [hcancel] at h2
      nlinarith [h2, hE20]
    have hcoef : (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) *
        (6 * Real.exp (-(20 * (bgpScaleW w : ℝ)))) *
        (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2))) ≤
        (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) *
        (6 * Real.exp (-(20 * (bgpScaleW w : ℝ)))) * 6 := by
      apply mul_le_mul_of_nonneg_left hgeo
      positivity
    rw [hr]
    calc (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) *
        (6 * Real.exp (-(20 * (bgpScaleW w : ℝ)))) *
        (1 / (1 - Real.exp (Real.log (B_U : ℝ) - 2)))
        ≤ (6 : ℝ) ^ (MachineInstance.inputLenU 1 w) *
          (6 * Real.exp (-(20 * (bgpScaleW w : ℝ)))) * 6 := hcoef
      _ ≤ 1 / 4000 := hkey
      _ = 1 / 1000 / 4 := by norm_num
  · -- the per-cycle conditional source bound
    intro j htube hwin i
    have h1 := paper3NW4_one_cycle w w j htube hwin i
    have h2 := paper3NW4Src_le w j
    have hexp_eq : Real.exp (-(2 : ℝ) * (j : ℝ)) =
        Real.exp (-(2 * (j : ℝ))) := by
      congr 1
      ring
    have hgoal0 : 0 ≤ 6 * Real.exp (-(20 * (bgpScaleW w : ℝ))) *
        Real.exp (-(2 : ℝ) * (j : ℝ)) := by
      positivity
    unfold paper3F1SrcCoreNW
    apply max_le hgoal0
    have h3 : paper3F1BoundaryErrNW w (j + 1) i -
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          paper3F1BoundaryErrNW w j i ≤ paper3NW4Src w j := by
      have h1' : paper3F1BoundaryErrNW w (j + 1) i ≤
          stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
            paper3F1BoundaryErrNW w j i + paper3NW4Src w j := h1
      linarith
    calc paper3F1BoundaryErrNW w (j + 1) i -
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          paper3F1BoundaryErrNW w j i
        ≤ paper3NW4Src w j := h3
      _ ≤ 6 * Real.exp (-(20 * (bgpScaleW w : ℝ))) *
          Real.exp (-(2 * (j : ℝ))) := h2
      _ = 6 * Real.exp (-(20 * (bgpScaleW w : ℝ))) *
          Real.exp (-(2 : ℝ) * (j : ℝ)) := by rw [hexp_eq]




