theorem paper3S13_coeff_ge_card4 :
    ((Fintype.card UniversalLocalView : ℝ)) ^ 4 ≤
      selectorMUHoffEdgeBudgetCoeff := by
  unfold selectorMUHoffEdgeBudgetCoeff selectorReplicatorHoldEnvelopeCoeff
  linarith

/-- Trivial-regime discharge: any quantity `≤ 1` fits in `1/32` of the Hoff
budget once `96·exp(200π(2j+1)) < card⁴`. -/
theorem paper3S13_trivial_le_budget_div_32 (j : ℕ) {q : ℝ}
    (hq : q ≤ 1)
    (htriv : 96 * Real.exp (200 * Real.pi * (2 * (j : ℝ) + 1)) <
      ((Fintype.card UniversalLocalView : ℝ)) ^ 4) :
    q ≤ selectorMUHoffEdgeBudget3992 j / 32 := by
  have hrate_pos : (0 : ℝ) <
      Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) := Real.exp_pos _
  have hcancel : Real.exp (200 * Real.pi * (2 * (j : ℝ) + 1)) *
      Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) = 1 := by
    rw [← Real.exp_add]
    simp
  have h3 : (3 : ℝ) ≤ selectorMUHoffEdgeBudget3992 j / 32 := by
    rw [paper3S13_budget_eq j]
    have hcoeff := paper3S13_coeff_ge_card4
    have h96 : 96 * Real.exp (200 * Real.pi * (2 * (j : ℝ) + 1)) ≤
        selectorMUHoffEdgeBudgetCoeff := le_of_lt (lt_of_lt_of_le htriv hcoeff)
    have := mul_le_mul_of_nonneg_right h96 hrate_pos.le
    rw [mul_assoc, hcancel, mul_one] at this
    linarith
  linarith

/-- Main-regime discharge: any quantity `≤ 3·rate` fits in `1/32` of the Hoff
budget. -/
theorem paper3S13_three_rate_le_budget_div_32 (j : ℕ) {q : ℝ}
    (hq : q ≤ 3 * Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1)))) :
    q ≤ selectorMUHoffEdgeBudget3992 j / 32 := by
  have hrate_pos : (0 : ℝ) <
      Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) := Real.exp_pos _
  rw [paper3S13_budget_eq j]
  have hcoeff := paper3S13_coeff_ge_3999
  nlinarith [hq, hrate_pos, hcoeff]

/-! Analytic core S2 (Hoff edge): the old/new-loser selector mass at the z-off
end `2π(j+1)` fits in `1/32` of the Hoff edge budget.

ROUTE CORRECTION (supersedes the earlier "old-view transport" plan, which was
based on a FALSE premise): the earlier comment claimed the OLD-config UTube
extends across the inter-read via u-drift suppression
"`bGateU ≤ exp(−500·(2πj+5π/6))` on the entire interval".  That bound is
wrong: `bGateU = exp(−μ·qPulse)` with `qPulse = ((1+sin t)/2)^L`, which
equals `1` at `t = 2πj + 3π/2` — the u-channel is wide OPEN in the middle of
the inter-read (that is the designed u-active window
`[2πj+7π/6, 2πj+11π/6]`, cf. `selectorMUUActiveStart/End`, with
`α·bGateU ≥ e^{50t}` there).  During that window the u-state COPIES
`z ≈ enc(cfg (j+1))` (z is written to the next configuration by `readStart`
and is FROZEN on the u-active window since `rPulse = ((1−sin)/2)^L ≥ 3/4`
makes the z-rate `≤ e^{−450t}`).  Hence at `zOffEnd` the view carrying the
mass is the NEW one, `1 − λ_old(zOffEnd) ≈ 1`, and the old statement
`1 − λ_old(zOffEnd) ≤ 2·rate` is unprovable (false).  The correct singleton
core is `1 − λ_NEW(zOffEnd) ≤ 2·rate`, and the pair bridge goes through
`selectorMU_old_new_loser_mass_le_new_loser` instead.

VERIFIED ROUTE (all discharged below except the single tube core):
* `paper3S2_interRead_new_tube` (the remaining SORRY): post-copy NEW tube on
  `[2πj+11π/6, 2π(j+1)]`;
* reset recovery on `[11π/6, 23π/12]` regenerates the NEW-winner floor
  `1/card` (there `cos ≥ √3/2`, so `cr ≥ 1/8`, while
  `cg·gain ≥ e^{600πj+525π}` since `sin ≥ −1/2`);
* barrier propagation keeps the floor to `2π(j+1)`;
* one singleton Duhamel pass (`paper3S13_oldLoser_duhamel` at index `j+1`)
  on `[2πj+23π/12, 2π(j+1)]` at floor `1/card`: the coarse initial mass
  `≤ 1` decays through `ΔG ≥ (π/12)·4^{−20}·g₀·e^{600πj+575π}` and the QSS
  drip fits under one rate, both after the main-regime
  `card ≤ 4·e^{50π(2j+1)}` fourth-power degrade.  Concentration exponent
  `600πj+575π` vs budget `400πj+200π`: margin `200πj+375π` (≈ `e^{1178}`
  to spare at `j = 0`). -/

/-- Start of the S2 post-copy window: `2πj + 11π/6` (the u-active end). -/
def paper3S2RecStart (j : ℕ) : ℝ :=
  2 * Real.pi * (j : ℝ) + 11 * Real.pi / 6

/-- S2 Duhamel anchor: `2πj + 23π/12` (recovery ends, Duhamel starts). -/
def paper3S2Mid (j : ℕ) : ℝ :=
  2 * Real.pi * (j : ℝ) + 23 * Real.pi / 12

theorem paper3S2_recStart_nonneg (j : ℕ) : 0 ≤ paper3S2RecStart j := by
  unfold paper3S2RecStart
  positivity

theorem paper3S2_mid_nonneg (j : ℕ) : 0 ≤ paper3S2Mid j := by
  unfold paper3S2Mid
  positivity

theorem paper3S2_recStart_le_mid (j : ℕ) :
    paper3S2RecStart j ≤ paper3S2Mid j := by
  unfold paper3S2RecStart paper3S2Mid
  nlinarith [Real.pi_pos]

theorem paper3S2_mid_le_zOffEnd (j : ℕ) :
    paper3S2Mid j ≤ selectorMUZOffEnd j := by
  unfold paper3S2Mid selectorMUZOffEnd
  nlinarith [Real.pi_pos]

/-- `sin ≥ -1/2` on the whole S2 window `[2πj + 11π/6, 2π(j+1)]`. -/
theorem paper3S2_sin_ge_neg_half (j : ℕ) {t : ℝ}
    (h1 : paper3S2RecStart j ≤ t) (h2 : t ≤ selectorMUZOffEnd j) :
    -(1 / 2 : ℝ) ≤ Real.sin t := by
  have hπ := Real.pi_pos
  have hteq : t = (t - 2 * Real.pi * ((j : ℝ) + 1)) +
      ((j + 1 : ℕ) : ℝ) * (2 * Real.pi) := by
    push_cast
    ring
  have hsin_eq : Real.sin t = Real.sin (t - 2 * Real.pi * ((j : ℝ) + 1)) := by
    conv_lhs => rw [hteq]
    rw [Real.sin_add_nat_mul_two_pi]
  rw [hsin_eq]
  set x := t - 2 * Real.pi * ((j : ℝ) + 1) with hx
  have hx1 : -(Real.pi / 6) ≤ x := by
    simp only [hx]
    unfold paper3S2RecStart at h1
    linarith
  have hx2 : x ≤ 0 := by
    simp only [hx]
    unfold selectorMUZOffEnd at h2
    linarith
  have hcos_le : Real.cos (x + Real.pi / 2) ≤ 1 / 2 := by
    calc Real.cos (x + Real.pi / 2)
        ≤ Real.cos (Real.pi / 3) :=
          Real.cos_le_cos_of_nonneg_of_le_pi (by linarith) (by linarith)
            (by linarith)
      _ = 1 / 2 := Real.cos_pi_div_three
  have hsx : Real.sin x = -Real.cos (x + Real.pi / 2) := by
    rw [Real.cos_add_pi_div_two]
    ring
  rw [hsx]
  linarith

/-- The reset clock is at least `1/8` on the S2 window: there
`cos ≥ cos(π/6) = √3/2 ≥ 17/20`, so `(1+cos)/2 ≥ 37/40` and
`(37/40)^20 ≥ 1/8`. -/
theorem paper3S2_crF_ge_eighth (j : ℕ) {t : ℝ}
    (h1 : paper3S2RecStart j ≤ t) (h2 : t ≤ selectorMUZOffEnd j) :
    (1 / 8 : ℝ) ≤ paper3S13crF t := by
  have hπ := Real.pi_pos
  have hteq : t = (t - 2 * Real.pi * ((j : ℝ) + 1)) +
      ((j + 1 : ℕ) : ℝ) * (2 * Real.pi) := by
    push_cast
    ring
  have hcos_eq : Real.cos t = Real.cos (t - 2 * Real.pi * ((j : ℝ) + 1)) := by
    conv_lhs => rw [hteq]
    rw [Real.cos_add_nat_mul_two_pi]
  have hx1 : -(Real.pi / 6) ≤ t - 2 * Real.pi * ((j : ℝ) + 1) := by
    unfold paper3S2RecStart at h1
    linarith
  have hx2 : t - 2 * Real.pi * ((j : ℝ) + 1) ≤ 0 := by
    unfold selectorMUZOffEnd at h2
    linarith
  have habs : |t - 2 * Real.pi * ((j : ℝ) + 1)| ≤ Real.pi / 6 :=
    abs_le.mpr ⟨by linarith, by linarith⟩
  have hcos_ge : Real.sqrt 3 / 2 ≤ Real.cos t := by
    rw [hcos_eq]
    calc Real.sqrt 3 / 2 = Real.cos (Real.pi / 6) := (Real.cos_pi_div_six).symm
      _ ≤ Real.cos |t - 2 * Real.pi * ((j : ℝ) + 1)| :=
          Real.cos_le_cos_of_nonneg_of_le_pi (abs_nonneg _) (by linarith) habs
      _ = Real.cos (t - 2 * Real.pi * ((j : ℝ) + 1)) :=
          Real.cos_abs _
  have hs3 : (17 / 10 : ℝ) ≤ Real.sqrt 3 := by
    nlinarith [Real.sq_sqrt (show (0 : ℝ) ≤ 3 by norm_num), Real.sqrt_nonneg 3]
  have hbase : (37 / 40 : ℝ) ≤ (1 + Real.cos t) / 2 := by linarith
  unfold paper3S13crF
  have hκ : ((paper3HeadlineKappa : ℚ) : ℝ) = 1 := by
    norm_num [paper3HeadlineKappa]
  rw [hκ, mul_one]
  calc (1 / 8 : ℝ) ≤ (37 / 40 : ℝ) ^ paper3HeadlineM := by
        norm_num [paper3HeadlineM]
    _ ≤ ((1 + Real.cos t) / 2) ^ paper3HeadlineM :=
        pow_le_pow_left₀ (by norm_num) hbase _

/-- `exp x ≤ 4^n` once `x ≤ n` (elementary: `exp(-1/2) ≥ 1/2` gives
`exp 1 ≤ 4`). -/
theorem paper3S2_exp_le_four_pow {n : ℕ} {x : ℝ} (hx : x ≤ (n : ℝ)) :
    Real.exp x ≤ (4 : ℝ) ^ n := by
  have h1 : (1 / 2 : ℝ) ≤ Real.exp (-(1 / 2 : ℝ)) := by
    have := Real.add_one_le_exp (-(1 / 2 : ℝ))
    linarith
  have hmul : Real.exp (1 / 2 : ℝ) * Real.exp (-(1 / 2 : ℝ)) = 1 := by
    rw [← Real.exp_add]
    norm_num
  have h2 : Real.exp (1 / 2 : ℝ) ≤ 2 := by
    nlinarith [Real.exp_pos (1 / 2 : ℝ), Real.exp_pos (-(1 / 2 : ℝ))]
  have hE1 : Real.exp 1 ≤ 4 := by
    have hsq : Real.exp 1 = Real.exp (1 / 2) * Real.exp (1 / 2) := by
      rw [← Real.exp_add]
      norm_num
    nlinarith [Real.exp_pos (1 / 2 : ℝ)]
  calc Real.exp x ≤ Real.exp (n : ℝ) := Real.exp_le_exp.mpr hx
    _ = Real.exp 1 ^ n := by
        rw [← Real.exp_nat_mul, mul_one]
    _ ≤ (4 : ℝ) ^ n := pow_le_pow_left₀ (Real.exp_pos 1).le hE1 n

/-- Gain-clock increment at the quarter base: on any forward window where
`sin ≥ -1/2`, the clock gains at least `(b-a)·(1/4)^20·g₀·exp(300a)`. -/
theorem paper3S2_G_increment_ge (wg w : ℕ) {a b : ℝ}
    (hab : a ≤ b) (ha0 : 0 ≤ a)
    (hsin : ∀ s ∈ Icc a b, -(1 / 2 : ℝ) ≤ Real.sin s) :
    (b - a) *
        ((1 / 4 : ℝ) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a))) ≤
      ((paper3HeadlineSolFam wg) w).G b - ((paper3HeadlineSolFam wg) w).G a := by
  rw [← paper3S13_G_eq wg w hab ha0]
  have hconst :
      (b - a) * ((1 / 4 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a))) =
      ∫ _s in a..b, ((1 / 4 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a))) := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
  rw [hconst]
  refine intervalIntegral.integral_mono_on hab intervalIntegrable_const
    ((paper3S13cgF_continuous wg).intervalIntegrable a b) ?_
  intro s hs
  unfold paper3S13cgF
  have hsin_s := hsin s hs
  have hpow : (1 / 4 : ℝ) ^ paper3HeadlineM ≤
      ((1 + Real.sin s) / 2) ^ paper3HeadlineM :=
    pow_le_pow_left₀ (by norm_num) (by linarith) _
  have hexp : Real.exp (bgpParams38.cα * a) ≤ Real.exp (bgpParams38.cα * s) := by
    apply Real.exp_le_exp.mpr
    have hcα : (0 : ℝ) ≤ bgpParams38.cα := by norm_num [bgpParams38]
    nlinarith [hs.1]
  have hg0 : (0 : ℝ) ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) := paper3WarmGainQ_nonneg wg
  calc (1 / 4 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * a))
      ≤ (1 / 4 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * s)) := by
        exact mul_le_mul_of_nonneg_left
          (mul_le_mul_of_nonneg_left hexp hg0) (by positivity)
    _ ≤ ((1 + Real.sin s) / 2) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * s)) :=
        mul_le_mul_of_nonneg_right hpow
          (mul_nonneg hg0 (Real.exp_pos _).le)


/-- Main-regime exponent comparison for the S2 exp leg: even after the
`card ≤ 4·e^{100πj+50π}` degrade and the `gap ≥ 1/2` loss (the factor `2`
folded into the `400`), the Hoff exponent is beaten by the S2 anchor clock
`(π/12)·(1/4)^20·g₀·e^{600πj+575π}`. -/
theorem paper3S2_hoffExp_card_le_gate (wg j : ℕ) :
    400 * Real.pi * (2 * (j : ℝ) + 1) *
        (4 * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)) ≤
      Real.pi / 12 * ((1 / 4 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) *
          Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi))) := by
  have hπ : (0 : ℝ) < Real.pi := Real.pi_pos
  have hπ3 : (3 : ℝ) < Real.pi := Real.pi_gt_three
  have hj0 : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
  have hg0 := paper3S13_g0_ge wg
  have hg1 : (1 : ℝ) ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) := by linarith
  have h2j : 2 * (j : ℝ) + 1 ≤ Real.exp (500 * Real.pi * (j : ℝ)) := by
    have h := Real.add_one_le_exp (500 * Real.pi * (j : ℝ))
    nlinarith [mul_nonneg hj0 (by linarith : (0 : ℝ) ≤ 500 * Real.pi - 2)]
  have hAe : (19200 : ℝ) * (4 : ℝ) ^ paper3HeadlineM ≤
      Real.exp (525 * Real.pi) := by
    have h55 : ((55 : ℕ) : ℝ) ≤ 525 * Real.pi := by
      push_cast
      nlinarith
    have hp := paper3S13_exp_pow_ge h55
    have hnum : (19200 : ℝ) * (4 : ℝ) ^ paper3HeadlineM ≤ (2 : ℝ) ^ (55 : ℕ) := by
      norm_num [paper3HeadlineM]
    linarith
  have hcore : (19200 : ℝ) * (4 : ℝ) ^ paper3HeadlineM * (2 * (j : ℝ) + 1) ≤
      ((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (500 * Real.pi * (j : ℝ) + 525 * Real.pi) := by
    have hprod : (19200 : ℝ) * (4 : ℝ) ^ paper3HeadlineM * (2 * (j : ℝ) + 1) ≤
        Real.exp (525 * Real.pi) * Real.exp (500 * Real.pi * (j : ℝ)) := by
      have h := mul_le_mul hAe h2j (by positivity) (Real.exp_pos _).le
      calc (19200 : ℝ) * (4 : ℝ) ^ paper3HeadlineM * (2 * (j : ℝ) + 1)
          = (19200 : ℝ) * (4 : ℝ) ^ paper3HeadlineM * (2 * (j : ℝ) + 1) := rfl
        _ ≤ Real.exp (525 * Real.pi) * Real.exp (500 * Real.pi * (j : ℝ)) := h
    have hcomb : Real.exp (525 * Real.pi) * Real.exp (500 * Real.pi * (j : ℝ)) =
        Real.exp (500 * Real.pi * (j : ℝ) + 525 * Real.pi) := by
      rw [← Real.exp_add]
      ring_nf
    rw [hcomb] at hprod
    have hE_pos := Real.exp_pos (500 * Real.pi * (j : ℝ) + 525 * Real.pi)
    nlinarith [hprod, hg1, hE_pos]
  have h4M_pos : (0 : ℝ) < (4 : ℝ) ^ paper3HeadlineM := by positivity
  have h4M_ne : ((4 : ℝ) ^ paper3HeadlineM) ≠ 0 := ne_of_gt h4M_pos
  have hEsplit : Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi) =
      Real.exp (500 * Real.pi * (j : ℝ) + 525 * Real.pi) *
        Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi) := by
    rw [← Real.exp_add]
    ring_nf
  have hq : ((1 : ℝ) / 4) ^ paper3HeadlineM = ((4 : ℝ) ^ paper3HeadlineM)⁻¹ := by
    rw [one_div, inv_pow]
  rw [hEsplit, hq]
  have hc_nonneg : (0 : ℝ) ≤ Real.pi *
      Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi) /
      (12 * (4 : ℝ) ^ paper3HeadlineM) := by positivity
  have hlift := mul_le_mul_of_nonneg_right hcore hc_nonneg
  have hLHS_eq : (19200 : ℝ) * (4 : ℝ) ^ paper3HeadlineM * (2 * (j : ℝ) + 1) *
      (Real.pi * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi) /
        (12 * (4 : ℝ) ^ paper3HeadlineM)) =
      400 * Real.pi * (2 * (j : ℝ) + 1) *
        (4 * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)) := by
    field_simp
    ring
  have hRHS_eq : ((paper3WarmGainQ wg : ℚ) : ℝ) *
      Real.exp (500 * Real.pi * (j : ℝ) + 525 * Real.pi) *
      (Real.pi * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi) /
        (12 * (4 : ℝ) ^ paper3HeadlineM)) =
      Real.pi / 12 * (((4 : ℝ) ^ paper3HeadlineM)⁻¹ *
        (((paper3WarmGainQ wg : ℚ) : ℝ) *
          (Real.exp (500 * Real.pi * (j : ℝ) + 525 * Real.pi) *
            Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)))) := by
    field_simp
  rw [hLHS_eq, hRHS_eq] at hlift
  exact hlift

/-- Main-regime source-leg comparison for S2: the QSS drip at the anchor
`2πj + 23π/12`, degraded by `card ≤ 4·e^{100πj+50π}` and `gap ≥ 1/2` (the
factor `2`), still fits under one Hoff rate. -/
theorem paper3S2_src_card_le_rate (wg j : ℕ) :
    2 * ((4 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) *
          Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi))⁻¹) *
      (4 * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)) ≤
    Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) := by
  have hπ3 : (3 : ℝ) < Real.pi := Real.pi_gt_three
  have hj0 : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
  have hg0 := paper3S13_g0_ge wg
  have hg1 : (1 : ℝ) ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) := by linarith
  have hg_pos : (0 : ℝ) < ((paper3WarmGainQ wg : ℚ) : ℝ) := by linarith
  have hgE_pos : (0 : ℝ) < ((paper3WarmGainQ wg : ℚ) : ℝ) *
      Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi) :=
    mul_pos hg_pos (Real.exp_pos _)
  have h1 : (8 : ℝ) * (4 : ℝ) ^ paper3HeadlineM ≤
      Real.exp (100 * Real.pi * (j : ℝ) + 325 * Real.pi) := by
    have h43 : ((43 : ℕ) : ℝ) ≤ 100 * Real.pi * (j : ℝ) + 325 * Real.pi := by
      push_cast
      nlinarith [mul_nonneg (Real.pi_pos.le) hj0]
    have hp := paper3S13_exp_pow_ge h43
    have hnum : (8 : ℝ) * (4 : ℝ) ^ paper3HeadlineM ≤ (2 : ℝ) ^ (43 : ℕ) := by
      norm_num [paper3HeadlineM]
    linarith
  have hclear : 2 * (4 : ℝ) ^ paper3HeadlineM *
      (4 * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)) ≤
      Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) *
        (((paper3WarmGainQ wg : ℚ) : ℝ) *
          Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi)) := by
    have hRE : Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) *
        Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi) =
        Real.exp (200 * Real.pi * (j : ℝ) + 375 * Real.pi) := by
      rw [← Real.exp_add]
      congr 1
      ring
    have hE2eq : Real.exp (100 * Real.pi * (j : ℝ) + 325 * Real.pi) *
        Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi) =
        Real.exp (200 * Real.pi * (j : ℝ) + 375 * Real.pi) := by
      rw [← Real.exp_add]
      congr 1
      ring
    have hstep : 2 * (4 : ℝ) ^ paper3HeadlineM *
        (4 * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)) =
        (8 * (4 : ℝ) ^ paper3HeadlineM) *
          Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi) := by
      ring
    rw [hstep]
    calc (8 * (4 : ℝ) ^ paper3HeadlineM) *
          Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)
        ≤ Real.exp (100 * Real.pi * (j : ℝ) + 325 * Real.pi) *
            Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi) :=
          mul_le_mul_of_nonneg_right h1 (Real.exp_pos _).le
      _ = Real.exp (200 * Real.pi * (j : ℝ) + 375 * Real.pi) := hE2eq
      _ ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) *
          Real.exp (200 * Real.pi * (j : ℝ) + 375 * Real.pi) :=
          le_mul_of_one_le_left (Real.exp_pos _).le hg1
      _ = Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi)) := by
          rw [mul_left_comm, hRE]
  have hfinal := mul_le_mul_of_nonneg_right hclear
    (inv_nonneg.mpr hgE_pos.le)
  have hL : 2 * (4 : ℝ) ^ paper3HeadlineM *
      (4 * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)) *
      (((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi))⁻¹ =
      2 * ((4 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) *
          Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi))⁻¹) *
      (4 * Real.exp (100 * Real.pi * (j : ℝ) + 50 * Real.pi)) := by
    ring
  have hR : Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) *
      (((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi)) *
      (((paper3WarmGainQ wg : ℚ) : ℝ) *
        Real.exp (600 * Real.pi * (j : ℝ) + 575 * Real.pi))⁻¹ =
      Real.exp (-(200 * Real.pi * (2 * (j : ℝ) + 1))) := by
    rw [mul_assoc, mul_inv_cancel₀ (ne_of_gt hgE_pos), mul_one]
  rw [hL, hR] at hfinal
  exact hfinal

/-- The old/new-pair loser mass is dominated by the singleton NEW-view loser
mass `1 - λ_new` (the correct bridge at `zOffEnd`, where the mass sits on the
new view). -/
theorem paper3S2_pairLoser_le_one_sub_new (wg w j : ℕ) {t : ℝ}
    (ht0 : 0 ≤ t) :
    (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
        (fun v => ((paper3HeadlineSolFam wg) w).lam v t) ≤
      1 - ((paper3HeadlineSolFam wg) w).lam
        (localViewU (solMUReplStaticCfg w (j + 1))) t := by
  classical
  have hnonneg := fun v => paper3Headline_lam_nonneg_forward wg w v t ht0
  have hsum := paper3Headline_lam_sum_forward wg w t ht0
  have h1 := selectorMU_old_new_loser_mass_le_new_loser
    (sol := paper3HeadlineSolFam wg) w j t hnonneg
  have h2 : (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
      (fun v => ((paper3HeadlineSolFam wg) w).lam v t) =
      1 - ((paper3HeadlineSolFam wg) w).lam
        (localViewU (solMUReplStaticCfg w (j + 1))) t := by
    have herase := Finset.add_sum_erase Finset.univ
      (fun v => ((paper3HeadlineSolFam wg) w).lam v t)
      (Finset.mem_univ (localViewU (solMUReplStaticCfg w (j + 1))))
    rw [Finset.filter_ne']
    linarith [herase, hsum]
  linarith

/-- The z-gate mass on `[2πj + 19π/24, 2πj + 5π/6]` is at least
`(π/24)·exp(100πj + 175π/6)`: on this window `sin ≥ 1/2`, so
`rPulse 1 ≤ 1/4` and the pointwise gate is `≥ exp(300·t − 250·t)`-scale. -/
theorem paper3S13_zGateMass_ge (wg w j : ℕ) :
    Real.pi / 24 * Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) ≤
      ∫ τ in (paper3S13Mid j)..(selectorMUWriteReadTime j),
        bgpParams38.A * ((paper3HeadlineSolFam wg) w).α τ *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ := by
  have hab := paper3S13_mid_le_read j
  have ha0 := paper3S13_mid_nonneg j
  have hpoint : ∀ τ ∈ Icc (paper3S13Mid j) (selectorMUWriteReadTime j),
      Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) ≤
        bgpParams38.A * ((paper3HeadlineSolFam wg) w).α τ *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ := by
    intro τ hτ
    have hτ0 : 0 ≤ τ := le_trans ha0 hτ.1
    have hα := ((paper3HeadlineSolFam wg) w).alpha_eq_exp
      selectorSchedule_domain_of_nonneg_structural hτ0
    have hμ := ((paper3HeadlineSolFam wg) w).mu_eq_linear
      selectorSchedule_domain_of_nonneg_structural hτ0
    have hμ0 := ((paper3HeadlineSolFam wg) w).μ_at_zero
    have hA : bgpParams38.A = 1 := by norm_num [bgpParams38]
    have hcα : bgpParams38.cα = 300 := by norm_num [bgpParams38]
    have hcμ : bgpParams38.cμ = 1000 := by norm_num [bgpParams38]
    have hL : bgpParams38.L = 1 := by norm_num [bgpParams38]
    have hsin : (1 / 2 : ℝ) ≤ Real.sin τ :=
      paper3S13_sin_ge_half j
        (le_trans (le_trans (paper3S13_selectStart_le_subEnd j)
          (paper3S13_subEnd_le_mid j)) hτ.1) hτ.2
    have hr : rPulse 1 τ ≤ 1 / 4 := by
      unfold rPulse
      rw [pow_one]
      linarith
    have hr0 : 0 ≤ rPulse 1 τ := by
      unfold rPulse
      rw [pow_one]
      nlinarith [Real.sin_le_one τ]
    have hμτ : ((paper3HeadlineSolFam wg) w).μ τ = 1000 * τ := by
      rw [hμ, hμ0, hcμ]
      ring
    have hgate : Real.exp (-(250 * selectorMUWriteReadTime j)) ≤
        bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ := by
      unfold bGateZ
      apply Real.exp_le_exp.mpr
      rw [hL, hμτ]
      have hτread : τ ≤ selectorMUWriteReadTime j := hτ.2
      nlinarith [hr, hr0, hτ0, hτread, paper3S13_read_nonneg j]
    have hα_ge : Real.exp (300 * paper3S13Mid j) ≤
        ((paper3HeadlineSolFam wg) w).α τ := by
      rw [hα, hcα]
      exact Real.exp_le_exp.mpr (by nlinarith [hτ.1])
    have hprod : Real.exp (300 * paper3S13Mid j) *
        Real.exp (-(250 * selectorMUWriteReadTime j)) ≤
        ((paper3HeadlineSolFam wg) w).α τ *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ :=
      mul_le_mul hα_ge hgate (Real.exp_pos _).le
        (le_trans (Real.exp_pos _).le hα_ge)
    have hexp_eq : Real.exp (300 * paper3S13Mid j) *
        Real.exp (-(250 * selectorMUWriteReadTime j)) =
        Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) := by
      rw [← Real.exp_add]
      congr 1
      unfold paper3S13Mid selectorMUWriteReadTime
      ring
    rw [hA, one_mul, ← hexp_eq]
    exact hprod
  have hcont := selector_replicator_gateZ_integrand_continuous
    ((paper3HeadlineSolFam wg) w)
  have hmono := intervalIntegral.integral_mono_on hab
    (continuous_const.intervalIntegrable (μ := MeasureTheory.volume) _ _)
    (hcont.intervalIntegrable (μ := MeasureTheory.volume) _ _)
    (fun τ hτ => hpoint τ hτ)
  have hconst : (∫ _τ in (paper3S13Mid j)..(selectorMUWriteReadTime j),
      Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6)) =
      (selectorMUWriteReadTime j - paper3S13Mid j) *
        Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
  have hlen : selectorMUWriteReadTime j - paper3S13Mid j = Real.pi / 24 := by
    unfold selectorMUWriteReadTime paper3S13Mid
    ring
  calc Real.pi / 24 * Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6)
      = (selectorMUWriteReadTime j - paper3S13Mid j) *
          Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) := by
        rw [hlen]
    _ = ∫ _τ in (paper3S13Mid j)..(selectorMUWriteReadTime j),
          Real.exp (100 * Real.pi * (j : ℝ) + 175 * Real.pi / 6) := hconst.symm
    _ ≤ _ := hmono

/-! #### S4a/S4b: per-view TV slaving layer

The edge TV obligations reduce, through the halt-centered form
(`selectorMU_mixTargetDerivRHS_halt_eq_centered_lam_of_boxInputs`) and the
`henc` winner-handoff halt equality, to per-view total variations of the
bad selector masses; each bad mass is slaved to its quasi-steady-state
target `selectorMU_activeQSS` by the linear-defect tracking engine
`stack_write_linear_defect_integral_le_initial_tracking_add_target_deriv_add_forcing_on`.
The proved layer below is window-generic; the remaining analytic inputs
(payoff-gap floors from tube persistence, QSS-derivative mass, mean-gap
forcing mass) are isolated in the `paper3S4a_*`/`paper3S4b_*` lemmas. -/

/-- `sin ≥ 0` on the left Hoff edge window `[2πj + 5π/6, 2πj + π]`. -/
theorem paper3S4a_sin_nonneg (j : ℕ) {τ : ℝ}
    (h1 : selectorMUInterReadStart j ≤ τ) (h2 : τ ≤ selectorMUZOffStart j) :
    0 ≤ Real.sin τ := by
  set x : ℝ := τ - 2 * Real.pi * (j : ℝ) with hx
  have hsin : Real.sin τ = Real.sin x := by
    have hrewrite : τ = x + (j : ℕ) * (2 * Real.pi) := by
      rw [hx]
      ring
    conv_lhs => rw [hrewrite]
    rw [Real.sin_add_nat_mul_two_pi]
  have hx_left : 5 * Real.pi / 6 ≤ x := by
    rw [hx]
    unfold selectorMUInterReadStart selectorMUWriteReadTime at h1
    linarith
  have hx_right : x ≤ Real.pi := by
    rw [hx]
    unfold selectorMUZOffStart at h2
    linarith
  rw [hsin]
  exact Real.sin_nonneg_of_nonneg_of_le_pi (by linarith [Real.pi_pos]) hx_right

/-- `sin ≥ 0` on the right Hoff edge window `[2π(j+1), 2π(j+1) + π/2]`. -/
theorem paper3S4b_sin_nonneg (j : ℕ) {τ : ℝ}
    (h1 : selectorMUZOffEnd j ≤ τ) (h2 : τ ≤ selectorMUNextWriteStart j) :
    0 ≤ Real.sin τ := by
  set x : ℝ := τ - 2 * Real.pi * ((j : ℝ) + 1) with hx
  have hsin : Real.sin τ = Real.sin x := by
    have hrewrite : τ = x + ((j + 1 : ℕ)) * (2 * Real.pi) := by
      rw [hx]
      push_cast
      ring
    conv_lhs => rw [hrewrite]
    rw [Real.sin_add_nat_mul_two_pi]
  have hx_left : 0 ≤ x := by
    rw [hx]
    unfold selectorMUZOffEnd at h1
    linarith
  have hx_right : x ≤ Real.pi := by
    rw [hx]
    unfold selectorMUNextWriteStart selectorMUWriteHoldTime at h2
    push_cast at h2
    linarith [Real.pi_pos]
  rw [hsin]
  exact Real.sin_nonneg_of_nonneg_of_le_pi hx_left hx_right

/-- Explicit gain floor for the active sink at any point with `sin ≥ 0` and
payoff gap `≥ 1/2`. -/
theorem paper3S4_sink_ge_of_gap_half
    (wg w : ℕ) (c v : UniversalLocalView) {τ : ℝ}
    (hsin : 0 ≤ Real.sin τ)
    (hgap : (1 / 2 : ℝ) ≤
      universalPval paper3HeadlineEta paper3HeadlineEta_pos c
          (((paper3HeadlineSolFam wg) w).u τ) -
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
          (((paper3HeadlineSolFam wg) w).u τ)) :
    (1 / 2 : ℝ) ^ paper3HeadlineM *
        (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * τ)) *
        (1 / 2) ≤
      selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v τ := by
  have hcr_nonneg :
      0 ≤ selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ := by
    unfold selectorMU_activeCr
    exact mul_nonneg
      (pow_nonneg (by nlinarith [Real.neg_one_le_cos τ]) _)
      (by norm_num [paper3HeadlineKappa])
  have hbase : (1 / 2 : ℝ) ≤ (1 + Real.sin τ) / 2 := by linarith
  have hpow : (1 / 2 : ℝ) ^ paper3HeadlineM ≤
      ((1 + Real.sin τ) / 2) ^ paper3HeadlineM :=
    pow_le_pow_left₀ (by norm_num) hbase _
  have hgain_pos :
      0 < ((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * τ) :=
    mul_pos (paper3WarmGainQ_pos wg) (Real.exp_pos _)
  have hcg_ge : (1 / 2 : ℝ) ^ paper3HeadlineM *
      (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * τ)) ≤
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ := by
    unfold selectorMU_activeCg
    exact mul_le_mul_of_nonneg_right hpow hgain_pos.le
  have hcg_nonneg :
      0 ≤ selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ :=
    le_trans (by positivity) hcg_ge
  have hprod : (1 / 2 : ℝ) ^ paper3HeadlineM *
      (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * τ)) *
      (1 / 2) ≤
      selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
        (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
            (((paper3HeadlineSolFam wg) w).u τ) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u τ)) :=
    mul_le_mul hcg_ge hgap (by norm_num) hcg_nonneg
  unfold selectorMU_activeSink
  linarith

/-- Strict sink positivity at any point with `sin ≥ 0` and payoff gap `≥ 1/2`. -/
theorem paper3S4_sink_pos_of_gap_half
    (wg w : ℕ) (c v : UniversalLocalView) {τ : ℝ}
    (hsin : 0 ≤ Real.sin τ)
    (hgap : (1 / 2 : ℝ) ≤
      universalPval paper3HeadlineEta paper3HeadlineEta_pos c
          (((paper3HeadlineSolFam wg) w).u τ) -
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
          (((paper3HeadlineSolFam wg) w).u τ)) :
    0 < selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
      (paper3HeadlineSolFam wg) w c v τ := by
  have h := paper3S4_sink_ge_of_gap_half wg w c v hsin hgap
  have h1 : (0 : ℝ) < (1 / 2 : ℝ) ^ paper3HeadlineM := by positivity
  have h2 : (0 : ℝ) <
      ((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * τ) :=
    mul_pos (paper3WarmGainQ_pos wg) (Real.exp_pos _)
  nlinarith

/-- Window generalization of
`selectorMU_activeQSS_hasDerivAt_of_sol_u_hasDerivAt`: the active QSS target
is differentiable at any forward time where the active sink is nonzero, with
the concrete quotient-rule RHS. -/
theorem paper3S4_activeQSS_hasDerivAt
    (wg w : ℕ) (c v : UniversalLocalView) {τ : ℝ} (hτ0 : 0 ≤ τ)
    (hsink_pos : 0 < selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
      (paper3HeadlineSolFam wg) w c v τ) :
    HasDerivAt
      (fun s => selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v s)
      (selectorMU_activeQSSDerivRHS paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v τ) τ := by
  classical
  have hdom : τ ∈ selectorSchedule.domain :=
    selectorSchedule_domain_of_nonneg_structural τ hτ0
  have hcr_diff : DifferentiableAt ℝ
      (fun s : ℝ => selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s) τ := by
    dsimp [selectorMU_activeCr]
    fun_prop
  have hcg_diff : DifferentiableAt ℝ
      (fun s : ℝ => selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) s) τ := by
    dsimp [selectorMU_activeCg]
    fun_prop
  have hcr : HasDerivAt
      (fun s : ℝ => selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s)
      (selectorMU_activeCrDeriv paper3HeadlineM paper3HeadlineKappa τ) τ := by
    simpa [selectorMU_activeCrDeriv] using hcr_diff.hasDerivAt
  have hcg : HasDerivAt
      (fun s : ℝ => selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) s)
      (selectorMU_activeCgDeriv paper3HeadlineM (paper3WarmGainQ wg) τ) τ := by
    simpa [selectorMU_activeCgDeriv] using hcg_diff.hasDerivAt
  have hdelta : HasDerivAt
      (fun s =>
        universalPval paper3HeadlineEta paper3HeadlineEta_pos c
            (((paper3HeadlineSolFam wg) w).u s) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u s))
      (selectorMU_universalPvalDerivRHS paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c τ -
        selectorMU_universalPvalDerivRHS paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w v τ) τ :=
    selectorMU_universalPval_gap_hasDerivAt_of_sol_u_hasDerivAt
      (sol := paper3HeadlineSolFam wg) w c v hdom
  have hk : HasDerivAt
      (fun s => selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v s)
      (selectorMU_activeSinkDerivRHS paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v τ) τ := by
    convert hcr.add (hcg.mul hdelta) using 1
    simp [selectorMU_activeSinkDerivRHS]
    ring
  have hr : HasDerivAt
      (fun s => selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa s *
        (Fintype.card UniversalLocalView : ℝ)⁻¹)
      (selectorMU_activeCrDeriv paper3HeadlineM paper3HeadlineKappa τ *
        (Fintype.card UniversalLocalView : ℝ)⁻¹) τ :=
    hcr.mul_const _
  have hq := hr.div hk (ne_of_gt hsink_pos)
  simpa [selectorMU_activeQSS, selectorMU_activeQSSDerivRHS, pow_two] using hq

/-- Window generalization of
`selectorMU_activeQSSDerivRHS_continuousOn_of_gap_nonneg`. -/
theorem paper3S4_activeQSSDerivRHS_continuousOn
    (wg w : ℕ) (c v : UniversalLocalView) {a b : ℝ}
    (hsink_pos : ∀ τ ∈ Icc a b,
      0 < selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v τ) :
    ContinuousOn
      (fun τ : ℝ => selectorMU_activeQSSDerivRHS paper3HeadlineEta
        paper3HeadlineEta_pos (paper3HeadlineSolFam wg) w c v τ)
      (Icc a b) := by
  have hcr := selectorMU_activeCr_continuous paper3HeadlineM paper3HeadlineKappa
  have hcrD := selectorMU_activeCrDeriv_continuous paper3HeadlineM paper3HeadlineKappa
  have hk := selectorMU_activeSink_continuous paper3HeadlineEta paper3HeadlineEta_pos
    (paper3HeadlineSolFam wg) w c v
  have hkD := selectorMU_activeSinkDerivRHS_continuous paper3HeadlineEta
    paper3HeadlineEta_pos (paper3HeadlineSolFam wg) w c v
  have hden_ne : ∀ τ ∈ Icc a b,
      selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v τ ^ 2 ≠ 0 :=
    fun τ hτ => pow_ne_zero 2 (ne_of_gt (hsink_pos τ hτ))
  have hnum : Continuous fun τ : ℝ =>
      (selectorMU_activeCrDeriv paper3HeadlineM paper3HeadlineKappa τ *
          (Fintype.card UniversalLocalView : ℝ)⁻¹) *
        selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c v τ -
      (selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (Fintype.card UniversalLocalView : ℝ)⁻¹) *
        selectorMU_activeSinkDerivRHS paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c v τ :=
    ((hcrD.mul continuous_const).mul hk).sub
      ((hcr.mul continuous_const).mul hkD)
  have hden : Continuous fun τ : ℝ =>
      selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v τ ^ 2 := hk.pow 2
  simpa [selectorMU_activeQSSDerivRHS] using
    hnum.continuousOn.div hden.continuousOn hden_ne

/-- Per-view Hoff edge slaving: on any forward window where the active payoff
sink stays strictly positive, the total variation of the per-view selector ODE
right-hand side is paid by the initial QSS tracking error, the QSS-derivative
mass, and twice the mean-gap forcing mass. -/
theorem paper3S4_perView_TV_le_initial_add_qssDeriv_add_two_forcing
    (wg w : ℕ) (c v : UniversalLocalView) {a b : ℝ}
    (hab : a ≤ b) (ha0 : 0 ≤ a)
    (hsink_pos : ∀ τ ∈ Icc a b,
      0 < selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
        (paper3HeadlineSolFam wg) w c v τ) :
    (∫ τ in a..b,
      |selectorMU_activeCr paper3HeadlineM paper3HeadlineKappa τ *
          (Fintype.card UniversalLocalView : ℝ)⁻¹ -
        selectorMU_activeSink paper3HeadlineEta paper3HeadlineEta_pos
            (paper3HeadlineSolFam wg) w c v τ *
          ((paper3HeadlineSolFam wg) w).lam v τ +
        selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
          (∑ x : UniversalLocalView,
            ((paper3HeadlineSolFam wg) w).lam x τ *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
                  (((paper3HeadlineSolFam wg) w).u τ) -
                universalPval paper3HeadlineEta paper3HeadlineEta_pos x
                  (((paper3HeadlineSolFam wg) w).u τ))) *
          ((paper3HeadlineSolFam wg) w).lam v τ|) ≤
      |selectorMU_activeQSS paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c v a -
        ((paper3HeadlineSolFam wg) w).lam v a| +
      (∫ τ in a..b,
        |selectorMU_activeQSSDerivRHS paper3HeadlineEta paper3HeadlineEta_pos
          (paper3HeadlineSolFam wg) w c v τ|) +
      2 * (∫ τ in a..b,
        |selectorMU_activeCg paper3HeadlineM (paper3WarmGainQ wg) τ *
          (∑ x : UniversalLocalView,
            ((paper3HeadlineSolFam wg) w).lam x τ *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
                  (((paper3HeadlineSolFam wg) w).u τ) -
                universalPval paper3HeadlineEta paper3HeadlineEta_pos x
