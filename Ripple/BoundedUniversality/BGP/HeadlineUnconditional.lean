    unfold selectorMUZOffEnd selectorMUWriteStartTime
    push_cast
    linarith
  have ha0 : 0 ≤ selectorMUZOffEnd j := by
    unfold selectorMUZOffEnd
    positivity
  let kZ : ℝ → ℝ := fun τ =>
    (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
      bGateZ (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ
  let kUf : ℝ → ℝ := fun τ =>
    (bgpParamsNW w).A * ((paper3HeadlineSolFamNW w) w).α τ *
      bGateU (bgpParamsNW w).L (((paper3HeadlineSolFamNW w) w).μ τ) τ
  let kk : ℝ → ℝ := fun τ => kZ τ + kUf τ
  let gg : ℝ → ℝ := fun τ =>
    kZ τ * (selectorMixTarget branchU ((paper3HeadlineSolFamNW w) w).u
        ((paper3HeadlineSolFamNW w) w).lam τ i -
      ((paper3HeadlineSolFamNW w) w).u τ i) / kk τ
  let y : ℝ → ℝ := fun τ =>
    ((paper3HeadlineSolFamNW w) w).z τ i -
      ((paper3HeadlineSolFamNW w) w).u τ i
  have hkZ_pos : ∀ τ : ℝ, 0 ≤ τ → 0 < kZ τ := by
    intro τ hτ0
    have hα := paper3HeadlineSolFamNW_alpha w w hτ0
    dsimp only [kZ]
    rw [hα, (bgpParamsNW_A_eq w), one_mul]
    have hg : (0 : ℝ) < bGateZ (bgpParamsNW w).L
        (((paper3HeadlineSolFamNW w) w).μ τ) τ := by
