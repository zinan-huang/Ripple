    linarith
  have h2 : (bgpScale : ℝ) ^ 6 ≤ Real.exp (bgpScaleW wg : ℝ) ^ 6 := by
    have hb : (bgpScale : ℝ) ≤ Real.exp (bgpScaleW wg : ℝ) :=
