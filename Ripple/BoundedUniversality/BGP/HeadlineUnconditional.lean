/-- Recovery reset source as a multiple of the common gain, with the
exponential factor measured at write start. -/
theorem paper3HeadlineRecoveryResetRatio
    (wg _w j : ℕ) {Creset t : ℝ}
    (hCreset_nonneg : 0 ≤ Creset)
    (hCreset_le_one : Creset ≤ 1)
    (ht : t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUSelectStartTime j)) :
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    (((1 + Real.cos t) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ)) * Creset ≤
      (Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime j)) / D) *
        (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t))) := by
  dsimp
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 3 / 4) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hreset_upper :
      ((1 + Real.cos t) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ) ≤ 1 := by
    exact (paper3RecoveryCrBounds wg j t ht).2
  have hresetC_le_one :
      (((1 + Real.cos t) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ)) * Creset ≤ 1 := by
    have hreset_nonneg :
        0 ≤ ((1 + Real.cos t) / 2) ^ paper3HeadlineM *
          (paper3HeadlineKappa : ℝ) := by
      exact mul_nonneg
        (pow_nonneg (by nlinarith [Real.neg_one_le_cos t]) paper3HeadlineM)
        (by norm_num [paper3HeadlineKappa])
    nlinarith [mul_le_mul hreset_upper hCreset_le_one hCreset_nonneg
      (by norm_num : (0 : ℝ) ≤ 1)]
  have hsin : (1 : ℝ) / 2 ≤ Real.sin t :=
    paper3HeadlineRecovery_sin_ge_half j ht
  have hsin_base : (3 / 4 : ℝ) ≤ (1 + Real.sin t) / 2 := by
    linarith
  have hsin_pow :
      ((3 / 4 : ℝ) ^ paper3HeadlineM) ≤
        ((1 + Real.sin t) / 2) ^ paper3HeadlineM := by
    exact pow_le_pow_left₀ (by norm_num) hsin_base paper3HeadlineM
  have hD_le :
      D ≤ ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          ((paper3WarmGainQ wg : ℚ) : ℝ) := by
    dsimp [D]
    exact mul_le_mul_of_nonneg_right hsin_pow (paper3WarmGainQ_nonneg wg)
  have htime :
      Real.exp (bgpParams38.cα * selectorMUWriteStartTime j) ≤
        Real.exp (bgpParams38.cα * t) := by
    refine Real.exp_le_exp.mpr ?_
    have hcα_nonneg : 0 ≤ bgpParams38.cα := by norm_num [bgpParams38]
    exact mul_le_mul_of_nonneg_left ht.1 hcα_nonneg
  have hgain_lower :
      D * Real.exp (bgpParams38.cα * selectorMUWriteStartTime j) ≤
        ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t)) := by
    calc
      D * Real.exp (bgpParams38.cα * selectorMUWriteStartTime j)
          ≤ D * Real.exp (bgpParams38.cα * t) :=
            mul_le_mul_of_nonneg_left htime hD_pos.le
      _ ≤ (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
              ((paper3WarmGainQ wg : ℚ) : ℝ)) *
            Real.exp (bgpParams38.cα * t) :=
            mul_le_mul_of_nonneg_right hD_le (Real.exp_pos _).le
      _ = ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t)) := by ring
  have hcoeff_pos :
      0 < Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime j)) / D :=
    div_pos (Real.exp_pos _) hD_pos
  have hunit :
      (1 : ℝ) ≤
        (Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime j)) / D) *
          (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
            (((paper3WarmGainQ wg : ℚ) : ℝ) *
              Real.exp (bgpParams38.cα * t))) := by
    have hmul := mul_le_mul_of_nonneg_left hgain_lower hcoeff_pos.le
    have hcancel :
        (Real.exp (-(bgpParams38.cα * selectorMUWriteStartTime j)) / D) *
            (D * Real.exp (bgpParams38.cα * selectorMUWriteStartTime j)) =
          1 := by
      field_simp [hD_pos.ne']
      rw [← Real.exp_add]
      ring_nf
      rw [Real.exp_zero]
    simpa [hcancel, mul_assoc] using hmul
  exact le_trans hresetC_le_one hunit

/-- The recovery weight/gain ratio has the headline Hoff decay rate. -/
theorem paper3HeadlineRecoveryWeightRatio_le_hoffRate
    (wg j : ℕ) :
    let rmin : ℝ := (1 - Real.sqrt 2 / 2) / 2
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    Real.exp (-(rmin * selectorMUWriteStartTime (j + 1))) / D ≤
      (1 / D) * paper3HoffRate j := by
  dsimp
  let rmin : ℝ := (1 - Real.sqrt 2 / 2) / 2
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 3 / 4) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hrmin_ge : (1 / 8 : ℝ) ≤ rmin := by
    dsimp [rmin]
    have hsqrt_le : Real.sqrt 2 ≤ (3 / 2 : ℝ) := by
      rw [Real.sqrt_le_iff]
      constructor <;> norm_num
    nlinarith
  have hW_nonneg : 0 ≤ selectorMUWriteStartTime (j + 1) :=
    selectorMUWriteStartTime_nonneg (j + 1)
  have hbase_nonneg : 0 ≤ 2 * Real.pi * (j : ℝ) + Real.pi := by
    have hj : 0 ≤ (j : ℝ) := by exact_mod_cast Nat.zero_le j
    have hpi : 0 ≤ Real.pi := Real.pi_pos.le
    nlinarith
  have hW_ge :
      2 * Real.pi * (j : ℝ) + Real.pi ≤
        selectorMUWriteStartTime (j + 1) := by
    have hpi : 0 ≤ Real.pi := Real.pi_pos.le
    norm_num [selectorMUWriteStartTime]
    nlinarith
  have hprod :
      paper3HoffExponent j ≤
        rmin * selectorMUWriteStartTime (j + 1) := by
    have h1 :
        (1 / 8 : ℝ) * selectorMUWriteStartTime (j + 1) ≤
          rmin * selectorMUWriteStartTime (j + 1) :=
      mul_le_mul_of_nonneg_right hrmin_ge hW_nonneg
    have h2 :
        (1 / 8 : ℝ) * (2 * Real.pi * (j : ℝ) + Real.pi) ≤
          (1 / 8 : ℝ) * selectorMUWriteStartTime (j + 1) :=
      mul_le_mul_of_nonneg_left hW_ge (by norm_num : (0 : ℝ) ≤ 1 / 8)
    simpa [paper3HoffExponent] using le_trans h2 h1
  have hexp :
      Real.exp (-(rmin * selectorMUWriteStartTime (j + 1))) ≤
        paper3HoffRate j := by
    simpa [paper3HoffRate] using
      Real.exp_le_exp.mpr (by linarith)
  have hmul :=
    mul_le_mul_of_nonneg_right hexp (inv_nonneg.mpr hD_pos.le)
  simpa [D, rmin, div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using hmul

/-- Weighted integral form of a Duhamel bad-mass envelope.

This is the scalar combiner used by the recovery producer: the prefix reset
convolution stays inside the weighted integral, so the gain derivative cancels
it through `forward_weight_prefix_reset_decay_integral_le`. -/
theorem paper3WeightedBadMassDuhamelIntegral_le
    {a b gap C B0 : ℝ} {G cg weight reset bad : ℝ → ℝ}
    (hab : a ≤ b) (hgap : 0 < gap) (hC_nonneg : 0 ≤ C)
    (hB0_nonneg : 0 ≤ B0)
    (hG_cont : Continuous G)
    (hGder : ∀ t ∈ Icc a b, HasDerivAt G (cg t) t)
    (hcg_cont : Continuous cg)
    (hweight_cont : Continuous weight)
    (hreset_cont : Continuous reset)
    (hbad_cont : Continuous bad)
    (hcg_nonneg : ∀ t ∈ Icc a b, 0 ≤ cg t)
    (hreset_nonneg : ∀ t ∈ Icc a b, 0 ≤ reset t)
    (hweight_nonneg : ∀ t ∈ Icc a b, 0 ≤ weight t)
    (hweight_bound : ∀ t ∈ Icc a b, weight t ≤ C * cg t)
    (hbad_bound : ∀ t ∈ Icc a b,
      bad t ≤
        B0 * Real.exp (-(gap * (G t - G a))) +
          (∫ s in a..t, Real.exp (gap * (G s - G a)) * reset s) *
            Real.exp (-(gap * (G t - G a)))) :
    (∫ t in a..b, weight t * bad t) ≤
      B0 * (C / gap) + (C / gap) * ∫ s in a..b, reset s := by
  let decay := fun t : ℝ => Real.exp (-(gap * (G t - G a)))
  let K := fun t : ℝ =>
    (∫ s in a..t, Real.exp (gap * (G s - G a)) * reset s)
  let pref := fun t : ℝ => K t * decay t
  have hdecay_cont : Continuous decay := by
    dsimp [decay]
    exact Real.continuous_exp.comp
      ((continuous_const.mul (hG_cont.sub continuous_const)).neg)
  have hresetExp_cont : Continuous fun s : ℝ =>
      Real.exp (gap * (G s - G a)) * reset s := by
    exact (Real.continuous_exp.comp
      (continuous_const.mul (hG_cont.sub continuous_const))).mul hreset_cont
  have hK_cont : Continuous K := by
    dsimp [K]
    exact continuous_iff_continuousAt.mpr fun t =>
      (intervalIntegral.integral_hasDerivAt_right
        (hresetExp_cont.intervalIntegrable a t)
        (hresetExp_cont.stronglyMeasurableAtFilter _ _)
        hresetExp_cont.continuousAt).continuousAt
  have hprefix_cont : Continuous pref := by
    dsimp [pref]
    exact hK_cont.mul hdecay_cont
  have hmajor_cont :
      Continuous fun t : ℝ => B0 * decay t + pref t :=
    (continuous_const.mul hdecay_cont).add hprefix_cont
  have hleft_int : IntervalIntegrable (fun t => weight t * bad t)
      MeasureTheory.volume a b :=
    (hweight_cont.mul hbad_cont).intervalIntegrable a b
  have hright_int :
      IntervalIntegrable (fun t => weight t * (B0 * decay t + pref t))
        MeasureTheory.volume a b :=
    (hweight_cont.mul hmajor_cont).intervalIntegrable a b
  have hpoint :
      ∀ t ∈ Icc a b,
        weight t * bad t ≤ weight t * (B0 * decay t + pref t) := by
    intro t ht
    exact mul_le_mul_of_nonneg_left
      (by simpa [decay, K, pref] using hbad_bound t ht)
      (hweight_nonneg t ht)
  have hmono :
      (∫ t in a..b, weight t * bad t) ≤
        ∫ t in a..b, weight t * (B0 * decay t + pref t) :=
    intervalIntegral.integral_mono_on hab hleft_int hright_int hpoint
  have hterm1_int :
      IntervalIntegrable (fun t => B0 * (weight t * decay t))
        MeasureTheory.volume a b :=
    (continuous_const.mul (hweight_cont.mul hdecay_cont)).intervalIntegrable a b
  have hterm2_int :
      IntervalIntegrable (fun t => weight t * pref t)
        MeasureTheory.volume a b :=
    (hweight_cont.mul hprefix_cont).intervalIntegrable a b
  have hsplit :
      (∫ t in a..b, weight t * (B0 * decay t + pref t)) =
        B0 * (∫ t in a..b, weight t * decay t) +
          ∫ t in a..b, weight t * pref t := by
    calc
      (∫ t in a..b, weight t * (B0 * decay t + pref t))
          =
        ∫ t in a..b, B0 * (weight t * decay t) + weight t * pref t := by
          refine intervalIntegral.integral_congr ?_
          intro t _ht
          ring
      _ =
        (∫ t in a..b, B0 * (weight t * decay t)) +
          ∫ t in a..b, weight t * pref t := by
          rw [intervalIntegral.integral_add hterm1_int hterm2_int]
      _ =
        B0 * (∫ t in a..b, weight t * decay t) +
          ∫ t in a..b, weight t * pref t := by
          rw [intervalIntegral.integral_const_mul]
  have hdecay_bound :=
    forward_weight_decay_integral_le
      (a := a) (b := b) (gap := gap) (C := C)
      (G := G) (cg := cg) (weight := weight)
      hab hgap hC_nonneg hG_cont hGder hcg_cont hweight_cont
      hweight_nonneg hweight_bound
  have hprefix_bound :=
    forward_weight_prefix_reset_decay_integral_le
      (a := a) (b := b) (gap := gap) (C := C)
      (G := G) (cg := cg) (weight := weight) (reset := reset)
      hab hgap hC_nonneg hG_cont hGder hcg_cont hweight_cont
      hreset_cont hcg_nonneg hreset_nonneg hweight_nonneg hweight_bound
  have hdecay_le :
      (∫ t in a..b, weight t * decay t) ≤ C / gap := by
    simpa [decay] using hdecay_bound.2
  have hprefix_le :
      (∫ t in a..b, weight t * pref t) ≤
        (C / gap) * ∫ s in a..b, reset s := by
    simpa [pref, K, decay, mul_assoc] using hprefix_bound.2
  calc
    (∫ t in a..b, weight t * bad t)
        ≤ ∫ t in a..b, weight t * (B0 * decay t + pref t) := hmono
    _ = B0 * (∫ t in a..b, weight t * decay t) +
          ∫ t in a..b, weight t * pref t := hsplit
    _ ≤ B0 * (C / gap) + (C / gap) * ∫ s in a..b, reset s :=
          add_le_add (mul_le_mul_of_nonneg_left hdecay_le hB0_nonneg)
            hprefix_le

set_option maxHeartbeats 2000000

/-- Recovery-prefix weighted old/new bad-mass Duhamel bound.

The result keeps the reset contribution as the actual unweighted reset integral.
That integral is harmless because the Hoff/gain ratio already has the canonical
Hoff decay. -/
theorem paper3HeadlineRecoveryOldNewBadMassHoffIntegralDuhamel
    (wg w j : ℕ) {B0 Lsafe : ℝ}
    (hgapL_pos :
      0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        Lsafe)
    (hB0_nonneg : 0 ≤ B0)
    (hsafe_floor : ∀ t ∈
      Icc (selectorMUWriteStartTime (j + 1))
        (selectorMUSelectStartTime (j + 1)),
      Lsafe ≤
        (insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView)).sum
          (fun u => ((paper3HeadlineSolFam wg) w).lam u t))
    (hpair : ∀ t ∈
      Icc (selectorMUWriteStartTime (j + 1))
        (selectorMUSelectStartTime (j + 1)),
      ∀ v : UniversalLocalView,
        v ∉ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
    (hBa :
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => ((paper3HeadlineSolFam wg) w).lam v
            (selectorMUWriteStartTime (j + 1))) ≤ B0) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUWriteStartTime (j + 1)
    let b : ℝ := selectorMUSelectStartTime (j + 1)
    let rmin : ℝ := (1 - Real.sqrt 2 / 2) / 2
    let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    let Cw : ℝ := Real.exp (-(rmin * a)) / D
    let Creset : ℝ :=
      ((Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (solMUReplStaticCfg w j) ∧
          v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
        (Fintype.card UniversalLocalView : ℝ)
    let reset : ℝ → ℝ := fun t =>
      (((1 + Real.cos t) / 2) ^ paper3HeadlineM *
        (paper3HeadlineKappa : ℝ)) * Creset
    (∫ t in a..b,
      selectorMUHoffGateCoeff sol w t *
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
          (fun v => (sol w).lam v t)) ≤
      B0 * (Cw / (gap * Lsafe)) +
        (Cw / (gap * Lsafe)) * ∫ s in a..b, reset s := by
  classical
  dsimp
  let sol := paper3HeadlineSolFam wg
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  let a : ℝ := selectorMUWriteStartTime (j + 1)
  let b : ℝ := selectorMUSelectStartTime (j + 1)
  let rmin : ℝ := (1 - Real.sqrt 2 / 2) / 2
  let D : ℝ := ((3 / 4 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  let Cw : ℝ := Real.exp (-(rmin * a)) / D
  let Creset : ℝ :=
    ((Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).card : ℝ) /
      (Fintype.card UniversalLocalView : ℝ)
  let cg : ℝ → ℝ := fun t =>
    ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
      (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * t))
  let weight : ℝ → ℝ := fun t => selectorMUHoffGateCoeff sol w t
  let reset : ℝ → ℝ := fun t =>
    (((1 + Real.cos t) / 2) ^ paper3HeadlineM *
      (paper3HeadlineKappa : ℝ)) * Creset
  let bad : ℝ → ℝ := fun t =>
    (Finset.univ.filter (fun v : UniversalLocalView =>
      v ≠ localViewU (solMUReplStaticCfg w j) ∧
        v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
      (fun v => (sol w).lam v t)
  have hab : a ≤ b := by
    simpa [a, b] using selectorMUWriteStart_le_selectStart (j + 1)
  have ha_nonneg : 0 ≤ a := by
    simpa [a] using selectorMUWriteStartTime_nonneg (j + 1)
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have hgap_nonneg : 0 ≤ gap := hgap_pos.le
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 3 / 4) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hCw_nonneg : 0 ≤ Cw := by
    dsimp [Cw]
    exact div_nonneg (Real.exp_pos _).le hD_pos.le
  have hcard_pos : (0 : ℝ) < Fintype.card UniversalLocalView := by
    exact_mod_cast
      (Fintype.card_pos_iff.mpr ⟨defaultLocalViewU⟩ :
        0 < Fintype.card UniversalLocalView)
  have hCreset_nonneg : 0 ≤ Creset := by
    dsimp [Creset]
    exact div_nonneg (Nat.cast_nonneg _) hcard_pos.le
  have hI_nonneg : ∀ t ∈ Icc a b, 0 ≤ t := by
    intro t ht
    exact le_trans ha_nonneg ht.1
  have hGder : ∀ t ∈ Icc a b, HasDerivAt (sol w).G (cg t) t := by
    intro t ht
    have ht0 : 0 ≤ t := hI_nonneg t ht
    simpa [sol, cg] using
      (sol w).G_hasDeriv t (selectorSchedule_domain_of_nonneg_structural t ht0)
  have hcg_cont : Continuous cg := by
    dsimp [cg]
    fun_prop
  have hweight_cont : Continuous weight := by
    dsimp [weight, selectorMUHoffGateCoeff, sol]
    exact selector_replicator_gateZ_integrand_continuous
      ((paper3HeadlineSolFam wg) w)
  have hreset_cont : Continuous reset := by
    dsimp [reset]
    fun_prop
  have hbad_cont : Continuous bad := by
    dsimp [bad, sol]
    simpa using
      (continuous_finsetSum
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1))))
        (fun v _hv => ((paper3HeadlineSolFam wg) w).cont_lam v))
  have hcg_nonneg : ∀ t ∈ Icc a b, 0 ≤ cg t := by
    intro t _ht
    dsimp [cg]
    exact mul_nonneg
      (pow_nonneg (by nlinarith [Real.neg_one_le_sin t]) paper3HeadlineM)
      (mul_nonneg (paper3WarmGainQ_nonneg wg) (Real.exp_pos _).le)
  have hreset_nonneg : ∀ t ∈ Icc a b, 0 ≤ reset t := by
    intro t _ht
    dsimp [reset]
    exact mul_nonneg
      (mul_nonneg
        (pow_nonneg (by nlinarith [Real.neg_one_le_cos t]) paper3HeadlineM)
        (by norm_num [paper3HeadlineKappa]))
      hCreset_nonneg
  have hweight_nonneg : ∀ t ∈ Icc a b, 0 ≤ weight t := by
    intro t ht
    dsimp [weight, selectorMUHoffGateCoeff, sol]
    exact selector_replicator_gateZ_integrand_nonneg
      ((paper3HeadlineSolFam wg) w)
      selectorSchedule_domain_of_nonneg_structural
      (by norm_num [bgpParams38])
      (hI_nonneg t ht)
  have hweight_bound : ∀ t ∈ Icc a b, weight t ≤ Cw * cg t := by
    intro t ht
    simpa [weight, Cw, cg, a, b, rmin, D, sol] using
      paper3HeadlineHoffGateCoeff_recovery_le_gain_ratio
        (wg := wg) (w := w) (j := j + 1) (t := t)
        (by simpa [a, b] using ht)
  have hbad_bound :
      ∀ t ∈ Icc a b,
        bad t ≤
          B0 * Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) +
            (∫ s in a..t,
              Real.exp ((gap * Lsafe) * ((sol w).G s - (sol w).G a)) *
                reset s) *
              Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) := by
    intro t ht
    have hduh :=
      selectorMU_old_new_badMass_duhamel_bound_on_Icc
        (sol := paper3HeadlineSolFam wg)
        (paper3HeadlineBoxInputs wg)
        (paper3WarmGainQ_nonneg wg)
        w j
        (a := a) (b := b) (gap := gap) (Lsafe := Lsafe)
        hab hI_nonneg hgap_nonneg hgapL_pos
        (by simpa [a, b, sol] using hsafe_floor)
        (by simpa [a, b, sol, gap] using hpair)
        t ht
    have hdecay_nonneg :
        0 ≤ Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) :=
      (Real.exp_pos _).le
    have hinit :
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => ((paper3HeadlineSolFam wg) w).lam v a) *
          Real.exp (-((gap * Lsafe) *
            (((paper3HeadlineSolFam wg) w).G t -
              ((paper3HeadlineSolFam wg) w).G a))) ≤
        B0 * Real.exp (-((gap * Lsafe) * ((sol w).G t - (sol w).G a))) := by
      exact mul_le_mul_of_nonneg_right
        (by simpa [a, sol] using hBa)
        hdecay_nonneg
    have hduh' :
        bad t ≤
          (Finset.univ.filter (fun v : UniversalLocalView =>
            v ≠ localViewU (solMUReplStaticCfg w j) ∧
              v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
              (fun v => ((paper3HeadlineSolFam wg) w).lam v a) *
            Real.exp (-((gap * Lsafe) *
              (((paper3HeadlineSolFam wg) w).G t -
                ((paper3HeadlineSolFam wg) w).G a))) +
          (∫ s in a..t,
            Real.exp ((gap * Lsafe) *
                (((paper3HeadlineSolFam wg) w).G s -
                  ((paper3HeadlineSolFam wg) w).G a)) *
              (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
                (paper3HeadlineKappa : ℝ)) *
              Creset) *
            Real.exp (-((gap * Lsafe) *
              (((paper3HeadlineSolFam wg) w).G t -
                ((paper3HeadlineSolFam wg) w).G a))) := by
      simpa [bad, reset, sol, gap, a, Creset, mul_assoc] using hduh
    simpa [reset, sol, gap, a, Creset, mul_assoc] using
      (le_trans hduh' (add_le_add hinit le_rfl))
  have hmain :=
    paper3WeightedBadMassDuhamelIntegral_le
      (a := a) (b := b) (gap := gap * Lsafe) (C := Cw) (B0 := B0)
      (G := (sol w).G) (cg := cg) (weight := weight) (reset := reset)
      (bad := bad)
      hab hgapL_pos hCw_nonneg hB0_nonneg (sol w).cont_G hGder
      hcg_cont hweight_cont hreset_cont hbad_cont hcg_nonneg
      hreset_nonneg hweight_nonneg hweight_bound hbad_bound
  simpa [sol, gap, a, b, rmin, D, Cw, Creset, weight, reset, bad,
    mul_assoc, mul_left_comm, mul_comm] using hmain

