/-- Direct canonical F1 residual constructor.  It bypasses the old endpoint
geometric package: `η → 0` comes from summable weighted defects, and the cap is
the coupled-tail prefix-budget algebra. -/
noncomputable def paper3HeadlineF1CanonicalWordAnalyticResidual_direct
    (wg w : ℕ)
    (inputs : Paper3HeadlineF1CanonicalWordWeightedInputs wg w) :
    Paper3HeadlineF1CanonicalWordAnalyticResidual wg w := by
  classical
  let εhold : ℝ := δuWritePrefix inputs.Cpre 0
  let Bzu : ℕ → ℝ := paper3F1CanonicalBzu wg w
  have hBzu0 : ∀ j, 0 ≤ Bzu j := by
    intro j
    simpa [Bzu] using (paper3F1CanonicalBzu_spec wg w).1 j
  have hzu_tail :
      ∀ j i, ∀ t ∈ Icc (selectorMUWriteHoldTime j)
          (selectorMUWriteReadTime j),
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤ Bzu j := by
    intro j i t ht
    simpa [Bzu] using (paper3F1CanonicalBzu_spec wg w).2 j i t ht
  have hzu_pre :
      ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteHoldTime j),
        |((paper3HeadlineSolFam wg) w).z t i -
          ((paper3HeadlineSolFam wg) w).u t i| ≤
            paper3F1CanonicalBpre wg w j :=
    (paper3F1CanonicalBpre_spec wg w).2.1
  have hhold :
      ∀ j i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
          (selectorMUWriteHoldTime j),
        |((paper3HeadlineSolFam wg) w).u t i -
          ((paper3HeadlineSolFam wg) w).u (selectorMUWriteStartTime j) i| ≤
            εhold := by
    simpa [εhold] using
      paper3F1_hhold_of_bounded_prefix_zu
        (wg := wg) (w := w) (paper3F1CanonicalBpre wg w)
        inputs.hCpre0 inputs.hBpre_le hzu_pre
  have hcap_tail :
      ∀ j i,
        selectorMUWboundPrefix (paper3F1W0 wg w) (paper3F1Depth w)
            (paper3F1Eta wg w) j i ≤
          (r_LE_U - εhold - δuSettled (Bzu j) j) *
            (B_U : ℝ) ^ paper3F1Depth w j i := by
    refine
      selectorMUWboundPrefix_coupled_tail_cap_of_tsum_normalized
        (paper3F1W0 wg w) (paper3F1Depth w) (paper3F1Eta wg w)
        εhold Bzu ?_ inputs.hTsum ?_
    · intro m i
      exact paper3F1_weightedDefect_nonneg wg w i m
    · intro j i
      simpa [εhold, Bzu] using inputs.hnorm_tsum j i
  exact
    { εhold := εhold
