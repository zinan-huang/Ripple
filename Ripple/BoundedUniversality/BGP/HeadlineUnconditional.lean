          ≤ 1 := hcr_le
        _ ≤ C1 * ((1 / 2 : ℝ) ^ paper3HeadlineM *
            (((paper3WarmGainQNW wg : ℚ) : ℝ) *
              Real.exp ((bgpParamsNW wg).cα * a))) := hkey
        _ ≤ C1 * paper3NW4cg wg s :=
            mul_le_mul_of_nonneg_left hcg_ge hC1_nonneg
    have hE0 := (Real.exp_pos (gap * (sol.G s - sol.G a))).le
    calc Real.exp (gap * (sol.G s - sol.G a)) *
          (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
            ((paper3HeadlineKappa : ℚ) : ℝ))
        ≤ Real.exp (gap * (sol.G s - sol.G a)) * (C1 * paper3NW4cg wg s) :=
          mul_le_mul_of_nonneg_left hcr_le_cg hE0
      _ = C1 * (Real.exp (gap * (sol.G s - sol.G a)) *
          paper3NW4cg wg s) := by ring
  -- FTC: the gain-weighted gain integral has the closed antiderivative
  have hFder : ∀ s ∈ Set.uIcc a t,
      HasDerivAt (fun s' => Real.exp (gap * (sol.G s' - sol.G a)) / gap)
        (Real.exp (gap * (sol.G s - sol.G a)) * paper3NW4cg wg s) s := by
    intro s hs
    rw [Set.uIcc_of_le hat] at hs
    have hs0 : 0 ≤ s := le_trans ha0 hs.1
    have hG := paper3NW4_G_hasDeriv wg w hs0
    have hinner : HasDerivAt (fun s' => gap * (sol.G s' - sol.G a))
        (gap * paper3NW4cg wg s) s := by
      simpa using ((hG.sub_const (sol.G a)).const_mul gap)
    have hexp := (Real.hasDerivAt_exp
      (gap * (sol.G s - sol.G a))).comp s hinner
    have hdiv := hexp.div_const gap
    convert hdiv using 1
    field_simp
  have hcont_int : Continuous fun s =>
      Real.exp (gap * (sol.G s - sol.G a)) * paper3NW4cg wg s := by
    exact (Real.continuous_exp.comp
      ((continuous_const.mul (sol.cont_G.sub continuous_const)))).mul
      (paper3NW4cg_cont wg)
  have hint : (∫ s in a..t,
      Real.exp (gap * (sol.G s - sol.G a)) * paper3NW4cg wg s) =
      Real.exp (gap * (sol.G t - sol.G a)) / gap -
        Real.exp (gap * (sol.G a - sol.G a)) / gap := by
    apply intervalIntegral.integral_eq_sub_of_hasDerivAt hFder
    exact hcont_int.intervalIntegrable a t
  have hcr_cont : Continuous fun s : ℝ =>
      Real.exp (gap * (sol.G s - sol.G a)) *
        (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
          ((paper3HeadlineKappa : ℚ) : ℝ)) := by
    exact (Real.continuous_exp.comp
      ((continuous_const.mul (sol.cont_G.sub continuous_const)))).mul
      ((((continuous_const.add Real.continuous_cos).div_const 2).pow _).mul
        continuous_const)
  have hmono := intervalIntegral.integral_mono_on hat
    (hcr_cont.intervalIntegrable (μ := MeasureTheory.volume) a t)
    ((hcont_int.const_mul C1).intervalIntegrable
      (μ := MeasureTheory.volume) a t)
    hpt
  have hpull : (∫ s in a..t,
      C1 * (Real.exp (gap * (sol.G s - sol.G a)) * paper3NW4cg wg s)) =
      C1 * ∫ s in a..t,
        Real.exp (gap * (sol.G s - sol.G a)) * paper3NW4cg wg s :=
    intervalIntegral.integral_const_mul _ _
  rw [hpull, hint] at hmono
  -- assemble: multiply through by the concentration weight
  have hX0 : (0 : ℝ) < Real.exp (-gap * (sol.G t - sol.G a)) :=
    Real.exp_pos _
  have hcancel : Real.exp (gap * (sol.G t - sol.G a)) *
      Real.exp (-gap * (sol.G t - sol.G a)) = 1 := by
    rw [← Real.exp_add]
    simp
  have hE1 : Real.exp (gap * (sol.G a - sol.G a)) = 1 := by
    simp
  have hstep : (∫ s in a..t,
      Real.exp (gap * (sol.G s - sol.G a)) *
        (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
          ((paper3HeadlineKappa : ℚ) : ℝ))) *
      Real.exp (-gap * (sol.G t - sol.G a)) ≤ C1 / gap := by
    have h1 := mul_le_mul_of_nonneg_right hmono hX0.le
    calc (∫ s in a..t,
        Real.exp (gap * (sol.G s - sol.G a)) *
          (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
            ((paper3HeadlineKappa : ℚ) : ℝ))) *
        Real.exp (-gap * (sol.G t - sol.G a))
        ≤ C1 * (Real.exp (gap * (sol.G t - sol.G a)) / gap -
            Real.exp (gap * (sol.G a - sol.G a)) / gap) *
          Real.exp (-gap * (sol.G t - sol.G a)) := h1
      _ ≤ C1 / gap := by
          rw [hE1]
          have hE2 := (Real.exp_pos (gap * (sol.G t - sol.G a))).le
          have hexpand : C1 * (Real.exp (gap * (sol.G t - sol.G a)) / gap -
              1 / gap) * Real.exp (-gap * (sol.G t - sol.G a)) =
              C1 / gap * (Real.exp (gap * (sol.G t - sol.G a)) *
                Real.exp (-gap * (sol.G t - sol.G a))) -
              C1 / gap * Real.exp (-gap * (sol.G t - sol.G a)) := by
            ring
          rw [hexpand, hcancel]
          have hlast : 0 ≤ C1 / gap * Real.exp (-gap * (sol.G t - sol.G a)) := by
            have := hX0.le
            positivity
          linarith
  -- final numeric absorption: `C1/gap ≤ 2^{M+1}·e^{−cα·a}`
  refine le_trans hstep ?_
  rw [hC1_def]
  have hE := (Real.exp_pos (-((bgpParamsNW wg).cα * a))).le
  have hgpos : (0 : ℝ) < ((paper3WarmGainQNW wg : ℚ) : ℝ) := by linarith
  have hP0 : (0 : ℝ) < (2 : ℝ) ^ paper3HeadlineM := by positivity
  rw [div_div, div_le_iff₀ (by nlinarith : (0 : ℝ) <
    ((paper3WarmGainQNW wg : ℚ) : ℝ) * gap)]
  have hpow2 : (2 : ℝ) ^ (paper3HeadlineM + 1) =
      2 * 2 ^ paper3HeadlineM := by
    rw [pow_succ]
    ring
  rw [hpow2]
  have hkey : (1 : ℝ) ≤ 2 * (((paper3WarmGainQNW wg : ℚ) : ℝ) * gap) := by
    nlinarith
  have hfin := mul_le_mul_of_nonneg_left hkey
    (mul_pos hP0 (Real.exp_pos (-((bgpParamsNW wg).cα * a)))).le
  nlinarith [hfin]

/-- **Per-cycle loser-mass bound at NW rates** on `[hold j, zOffStart j]`,
conditional only on the maintained cycle-`j` readout tube. -/
theorem paper3NW4_loser_mass (wg w j : ℕ)
    (hutube : ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW wg) w).u t i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U) :
    ∀ t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUZOffStart j),
      (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (paper3F1Cfg w j))).sum
          (fun v => ((paper3HeadlineSolFamNW wg) w).lam v t) ≤
      paper3NW4EpsLam wg j := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  set sol := (paper3HeadlineSolFamNW wg) w with hsol
  set a := selectorMUSelectStartTime j with ha_def
  set gap := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    with hgap_def
  intro t ht
  have hsel_hold : a ≤ selectorMUWriteHoldTime j :=
    (selectorMUSelectStart_lt_hold j).le
  have hat : a ≤ t := le_trans hsel_hold ht.1
  have ha0 : 0 ≤ a :=
    le_trans (selectorMUWriteStartTime_nonneg j)
      (selectorMUWriteStart_le_selectStart j)
  have hgap0 : 0 < gap :=
    solMURepl_static_hgap0 paper3HeadlineEta paper3HeadlineEta_pos
      paper3HeadlineHerr
  have hgap1516 : (15 : ℝ) / 16 ≤ gap := by
    have h := paper3RecoveryGap_ge_fifteen_sixteen wg j
    simpa [paper3RecoveryGap, hgap_def] using h
  have hcard_pos : (0 : ℝ) < (Fintype.card UniversalLocalView : ℝ) := by
    exact_mod_cast Fintype.card_pos_iff.mpr
      (⟨defaultLocalViewU⟩ : Nonempty UniversalLocalView)
  set Kt := ∫ s in a..t,
    Real.exp (gap * (sol.G s - sol.G a)) *
      (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
        ((paper3HeadlineKappa : ℚ) : ℝ)) with hKt_def
  have hKt0 : 0 ≤ Kt := by
    rw [hKt_def]
    apply intervalIntegral.integral_nonneg hat
    intro s _
    have hb := Real.neg_one_le_cos s
    exact mul_nonneg (Real.exp_pos _).le
      (mul_nonneg (pow_nonneg (by linarith) _)
        (by norm_num [paper3HeadlineKappa]))
  have hfloor := paper3NW4_floor_on_selToZOff wg w j hutube
  have hsub_aZ : ∀ s, s ∈ Icc a t → s ∈ Icc a (selectorMUZOffStart j) :=
    fun s hs => ⟨hs.1, le_trans hs.2 ht.2⟩
  have hsub_wsZ : ∀ s, s ∈ Icc a t →
      s ∈ Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j) :=
    fun s hs => ⟨le_trans (selectorMUWriteStart_le_selectStart j) hs.1,
      le_trans hs.2 ht.2⟩
  have h1 := loser_mass_small_on_settled_window sol
    (localViewU (paper3F1Cfg w j))
    (selectStart := a) (writeStart := t) (readStart := t)
    (Lmin := 1 / (Fintype.card UniversalLocalView : ℝ))
    (gap := gap) (R0 := (Fintype.card UniversalLocalView : ℝ))
    (Kreset := Kt)
    hat (le_refl t)
    (by positivity)
    hgap0.le
    hcard_pos.le
    hKt0
    (fun s hs => selectorSchedule_domain_of_nonneg_structural s
      (le_trans ha0 hs.1))
    ((((continuous_const.add Real.continuous_cos).div_const 2).pow _).mul
      continuous_const)
    (fun s hs => hfloor s (hsub_aZ s hs))
    (fun v s hs => paper3NW_lam_nonneg_forward wg w v s
      (le_trans ha0 hs.1))
    (fun s hs => paper3NW_lam_sum_forward wg w s (le_trans ha0 hs.1))
    (fun s hs => by
      have hb := Real.neg_one_le_cos s
      exact mul_nonneg (pow_nonneg (by linarith) _)
        (by norm_num [paper3HeadlineKappa]))
    (fun s hs => by
      have hb := Real.neg_one_le_sin s
      exact mul_nonneg (pow_nonneg (by linarith) _)
        (mul_nonneg (paper3WarmGainQNW_nonneg_real wg) (Real.exp_pos _).le))
    (fun v hv s hs => by
      have h := paper3NW4_gap_of_tube wg w j hutube v hv s
        (hsub_wsZ s ⟨hs.1, hs.2.le⟩)
      simpa [hgap_def] using h)
    (fun v hv => by
      have hfloor_a : 1 / (Fintype.card UniversalLocalView : ℝ) ≤
          sol.lam (localViewU (paper3F1Cfg w j)) a :=
        hfloor a ⟨le_refl a, paper3NW4_sel_le_zOffStart j⟩
      exact paper3Headline_lam_ratio_card_bound_at
        (lam := fun v' : UniversalLocalView => sol.lam v' a)
        (vstar := localViewU (paper3F1Cfg w j))
        (paper3NW_lam_sum_forward wg w a ha0)
        (fun v' => paper3NW_lam_nonneg_forward wg w v' a ha0)
        hfloor_a v hv)
    (fun t' ht' => by
      have heq : t' = t := le_antisymm ht'.2 ht'.1
      rw [heq])
    (fun t' ht' => by
      have heq : t' = t := le_antisymm ht'.2 ht'.1
      rw [heq])
  have h2 := h1 t ⟨le_refl t, le_refl t⟩
  rw [epsLamSettled_card_inv] at h2
  have hcard1 : (0 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) - 1 := by
    have h := paper3HeadlineHCardTwo
    have h2' : (2 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) := by
      exact_mod_cast h
    linarith
  have hΔG := paper3NW4_deltaG_lower wg w j (t := t) ht.1
  have hΔGf0 := paper3NW4DeltaGFloor_nonneg wg j
  have hXle : Real.exp (-(gap * (sol.G t - sol.G a))) ≤
      Real.exp (-(15 / 16) * paper3NW4DeltaGFloor wg j) := by
    apply Real.exp_le_exp.mpr
    have hΔG0 : 0 ≤ sol.G t - sol.G a := le_trans hΔGf0 hΔG
    nlinarith
  have hKtX : Kt * Real.exp (-(gap * (sol.G t - sol.G a))) ≤
      2 ^ (paper3HeadlineM + 1) *
        Real.exp (-((bgpParamsNW wg).cα * a)) := by
    have hkill := paper3NW4_reset_kill wg w j (t := t) (gap := gap)
      hat ht.2 hgap1516
    have hXeq : Real.exp (-gap * (sol.G t - sol.G a)) =
        Real.exp (-(gap * (sol.G t - sol.G a))) := by
      congr 1
      ring
    rw [hXeq] at hkill
    rw [hKt_def]
    exact hkill
  calc (Finset.univ.filter (fun v : UniversalLocalView =>
        v ≠ localViewU (paper3F1Cfg w j))).sum
          (fun v => sol.lam v t)
      ≤ ((Fintype.card UniversalLocalView : ℝ) - 1) *
        (((Fintype.card UniversalLocalView : ℝ) + Kt) *
          Real.exp (-(gap * (sol.G t - sol.G a)))) := h2
    _ = ((Fintype.card UniversalLocalView : ℝ) - 1) *
        ((Fintype.card UniversalLocalView : ℝ) *
          Real.exp (-(gap * (sol.G t - sol.G a))) +
         Kt * Real.exp (-(gap * (sol.G t - sol.G a)))) := by
        ring
    _ ≤ ((Fintype.card UniversalLocalView : ℝ) - 1) *
        ((Fintype.card UniversalLocalView : ℝ) *
          Real.exp (-(15 / 16) * paper3NW4DeltaGFloor wg j) +
         2 ^ (paper3HeadlineM + 1) *
          Real.exp (-((bgpParamsNW wg).cα * a))) := by
        apply mul_le_mul_of_nonneg_left ?_ hcard1
        have h3 := mul_le_mul_of_nonneg_left hXle hcard_pos.le
        linarith
    _ = paper3NW4EpsLam wg j := by
        rw [paper3NW4EpsLam, ha_def]

/-! ## NEW part D: elementary growth helpers and the six source legs

Uniform currency: every source leg is bounded by `e^{−2j}·e^{−20·S wg}`. -/

/-- `x²/4 ≤ e^x` for `x ≥ 0`. -/
theorem paper3NW4_sq_quarter_le_exp {x : ℝ} (hx : 0 ≤ x) :
    x ^ 2 / 4 ≤ Real.exp x := by
  have h1 : 1 + x / 2 ≤ Real.exp (x / 2) := by
    have := Real.add_one_le_exp (x / 2)
    linarith
  have h2 : (1 + x / 2) ^ 2 ≤ Real.exp (x / 2) ^ 2 := by
    have h0 : 0 ≤ 1 + x / 2 := by linarith
    nlinarith
  have h3 : Real.exp (x / 2) ^ 2 = Real.exp x := by
    rw [← Real.exp_nat_mul]
    congr 1
    push_cast
    ring
  nlinarith [h2, h3]

/-- `2x ≤ e^x` for `x ≥ 8`. -/
theorem paper3NW4_two_mul_le_exp {x : ℝ} (hx : 8 ≤ x) :
    2 * x ≤ Real.exp x := by
  have h := paper3NW4_sq_quarter_le_exp (by linarith : (0 : ℝ) ≤ x)
  nlinarith

/-- The word-coupled scale dominates `8` (indeed `4·6⁴`). -/
theorem paper3NW4_S_ge (wg : ℕ) : (5184 : ℝ) ≤ (bgpScaleW wg : ℝ) := by
  have h := paper3NW4_scale_gap wg
  have h4 := bgpScaleR_ge_four
  nlinarith

/-- Crude hull constant: `CwinDefN ≤ e^{S + 200}`. -/
theorem paper3NW4_CwinN_le_exp (wg : ℕ) :
    paper3F1CwinDefN ≤ Real.exp ((bgpScaleW wg : ℝ) + 200) := by
  have hS := paper3NW4_S_ge wg
  have hsS : (bgpScale : ℝ) ≤ (bgpScaleW wg : ℝ) := bgpScaleR_le_bgpScaleWR wg
  have h1 : (bgpScale : ℝ) ≤ Real.exp (bgpScaleW wg : ℝ) := by
    have h2 := paper3NW4_two_mul_le_exp (by linarith : (8 : ℝ) ≤ (bgpScaleW wg : ℝ))
    have h4 := bgpScaleR_ge_four
    nlinarith
  have h3 : paper3F1CwinDef ≤ Real.exp (200 : ℝ) := by
    unfold paper3F1CwinDef
    have h5 : Real.exp (199 : ℝ) * (Real.exp 1 - 1) ≥ 11 := by
      have he1 : (2 : ℝ) ≤ Real.exp 1 := by
        have := Real.add_one_le_exp (1 : ℝ)
        linarith
      have he199 : (200 : ℝ) ≤ Real.exp (199 : ℝ) := by
        have := Real.add_one_le_exp (199 : ℝ)
        linarith
      nlinarith
    have h6 : Real.exp (200 : ℝ) = Real.exp (199 : ℝ) * Real.exp 1 := by
      rw [← Real.exp_add]
      norm_num
    nlinarith [Real.exp_pos (199 : ℝ)]
  unfold paper3F1CwinDefN
  rw [Real.exp_add]
  have hC0 : (0 : ℝ) ≤ paper3F1CwinDef := by
    unfold paper3F1CwinDef
    positivity
  have hE0 : (0 : ℝ) < Real.exp (bgpScaleW wg : ℝ) := Real.exp_pos _
  nlinarith [Real.exp_pos (200 : ℝ)]

/-- `D_U ≤ e^S`. -/
