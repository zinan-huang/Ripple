/-- N boundary error: distance of the N-family `u` from the static-orbit
encoding at the cycle-`j` write start. -/
def paper3F1BoundaryErrN (wg w : ℕ) (j : ℕ) (i : Fin d_U) : ℝ :=
  |((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i -
    stackMachineEncodingU.enc (paper3F1Cfg w j) i|

/-- The N boundary error is the write-start `trackingErr` of the N family. -/
theorem paper3F1BoundaryErrN_eq_trackingErr
    (wg w j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErrN wg w j i =
      trackingErr ((paper3HeadlineSolFamN wg) w).u (paper3F1Cfg w)
        selectorMUWriteStartTime j i := rfl

theorem paper3F1BoundaryErrN_le_writeStart_zu_add_zerr
    (wg w : ℕ) (j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErrN wg w j i ≤
      |((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i| +
      |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| := by
  have h := abs_sub_le
    (((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i)
    (((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i)
    (stackMachineEncodingU.enc (paper3F1Cfg w j) i)
  simpa [paper3F1BoundaryErrN] using h

/-- Exact initial weighted boundary for the F1-N prefix budget. -/
def paper3F1W0N (wg w : ℕ) : Fin d_U → ℝ :=
  fun i => (B_U : ℝ) ^ paper3F1Depth w 0 i * paper3F1BoundaryErrN wg w 0 i

/-- Positive part of the exact one-step excess at the N family. -/
def paper3F1EtaN (wg w : ℕ) : ℕ → Fin d_U → ℝ :=
  fun j i =>
    max (0 : ℝ)
      (paper3F1BoundaryErrN wg w (j + 1) i -
        (B_U : ℝ) ^ selectorMUCoarseDelta (paper3F1Cfg w) j i *
          paper3F1BoundaryErrN wg w j i)

theorem paper3F1EtaN_nonneg (wg w : ℕ) :
    ∀ j i, 0 ≤ paper3F1EtaN wg w j i := by
  intro j i
  unfold paper3F1EtaN
  exact le_max_left _ _

theorem paper3F1N_weightedDefect_summable_of_eta_geometric
    (wg w : ℕ) (i : Fin d_U) {Cη lamη : ℝ}
    (hβlt : Real.log (B_U : ℝ) < lamη)
    (hηgeo : ∀ j, paper3F1EtaN wg w j i ≤
      Cη * Real.exp (-lamη * (j : ℝ))) :
    Summable (fun j =>
      weightedDefect (B_U : ℝ) (paper3F1Depth w)
        (paper3F1EtaN wg w) j i) := by
  refine weightedDefect_summable_of_parts (B_U : ℝ) (paper3F1Depth w)
    (paper3F1EtaN wg w) i
    (Cdep := Real.exp (Real.log (B_U : ℝ) *
      (MachineInstance.inputLenU 1 w : ℝ)))
    (Cη := Cη) (β := Real.log (B_U : ℝ)) (lamη := lamη)
    ?_ hβlt ?_ ?_ ?_ hηgeo
  · exact (Real.exp_pos _).le
  · intro j
    exact zpow_nonneg (by norm_num [B_U] : (0 : ℝ) ≤ (B_U : ℝ)) _
  · exact paper3F1Depth_zpow_succ_le_exp w i
  · intro j
    exact paper3F1EtaN_nonneg wg w j i

/-- Canonical positive-part one-cycle source for the N conditional core
(the `paper3F1SrcCore` sibling: exact `coordMultiplier` comparison term). -/
def paper3F1SrcCoreN (wg w : ℕ) : ℕ → Fin d_U → ℝ :=
  fun j i =>
    max (0 : ℝ)
      (paper3F1BoundaryErrN wg w (j + 1) i -
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          paper3F1BoundaryErrN wg w j i)

theorem paper3F1SrcCoreN_nonneg (wg w : ℕ) :
    ∀ j i, 0 ≤ paper3F1SrcCoreN wg w j i := by
  intro j i
  unfold paper3F1SrcCoreN
  exact le_max_left _ _

/-- The raw one-cycle multiplier step is algebraic for the N canonical
positive-part source. -/
theorem paper3F1_boundaryErrN_succ_le_mult_add_srcCoreN
    (wg w j : ℕ) (i : Fin d_U) :
    paper3F1BoundaryErrN wg w (j + 1) i ≤
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErrN wg w j i + paper3F1SrcCoreN wg w j i := by
  have h : paper3F1BoundaryErrN wg w (j + 1) i -
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3F1BoundaryErrN wg w j i ≤ paper3F1SrcCoreN wg w j i := by
    unfold paper3F1SrcCoreN
    exact le_max_right _ _
  linarith

/-- The F1-N boundary-tube radius: what remains of the readout tube after
paying the cycle-`0` N-rate (`450·bgpScale`) prefix and settled u-drift
reserves. -/
noncomputable def paper3F1TubeRadiusN (Cwin : ℝ) : ℝ :=
  r_LE_U - δuWritePrefixN Cwin 0 - δuSettledN Cwin 0

/-- **The Leg-A reserve inequality at N rates is even slacker than at `38`**:
any envelope constant below `bgpScale·e^{200}` pays the cycle-`0` reserves out
of half the readout tube, because the reserve exponent `-450·bgpScale·π/6 ≤
-225·bgpScale` beats the linear `bgpScale` prefactor
(`bgpScale ≤ e^{bgpScale}`). -/
theorem paper3F1_delta_reserveN_of_envelope_le
    {Cwin : ℝ} (hCwin_le : Cwin ≤ (bgpScale : ℝ) * Real.exp (200 : ℝ)) :
    δuWritePrefixN Cwin 0 + δuSettledN Cwin 0 ≤ r_LE_U / 2 := by
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hs4 : (4 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_four
  have hrate : selectorUSettledRate_N = 450 * (bgpScale : ℝ) :=
    selectorUSettledRate_N_eq
  have hws0 : selectorMUWriteStartTime 0 = Real.pi / 6 := by
    norm_num [selectorMUWriteStartTime]
  have hwh0 : selectorMUWriteHoldTime 0 = Real.pi / 2 := by
    norm_num [selectorMUWriteHoldTime]
  -- both cycle-`0` exponents are at most `-225·bgpScale`
  have hexp_pre :
      Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime 0)) ≤
        Real.exp (-(225 * (bgpScale : ℝ))) := by
    rw [hrate, hws0]
    apply Real.exp_le_exp.mpr
    nlinarith [Real.pi_gt_three, hs0]
  have hexp_set :
      Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime 0)) ≤
        Real.exp (-(225 * (bgpScale : ℝ))) := by
    rw [hrate, hwh0]
    apply Real.exp_le_exp.mpr
    nlinarith [Real.pi_gt_three, hs0]
  -- the linear prefactor is absorbed: `s·e^{-225s} ≤ e^{-224s}`
  have hs_exp : (bgpScale : ℝ) * Real.exp (-(225 * (bgpScale : ℝ))) ≤
      Real.exp (-(224 * (bgpScale : ℝ))) := by
    have hse : (bgpScale : ℝ) ≤ Real.exp (bgpScale : ℝ) := by
      have := Real.add_one_le_exp ((bgpScale : ℝ))
      linarith
    have hmul := mul_le_mul_of_nonneg_right hse
      (Real.exp_pos (-(225 * (bgpScale : ℝ)))).le
    calc (bgpScale : ℝ) * Real.exp (-(225 * (bgpScale : ℝ)))
        ≤ Real.exp ((bgpScale : ℝ)) * Real.exp (-(225 * (bgpScale : ℝ))) :=
          hmul
      _ = Real.exp ((bgpScale : ℝ) - 225 * (bgpScale : ℝ)) := by
          rw [← Real.exp_add]; ring_nf
      _ ≤ Real.exp (-(224 * (bgpScale : ℝ))) := by
          apply Real.exp_le_exp.mpr
          linarith
  -- `e^{200}·e^{-224s} ≤ e^{-25}` (using `s ≥ 4` hence `224s ≥ 896 ≥ 225`)
  have hprod : Real.exp (200 : ℝ) * Real.exp (-(224 * (bgpScale : ℝ))) ≤
      Real.exp (-(25 : ℝ)) := by
    rw [← Real.exp_add]
    apply Real.exp_le_exp.mpr
    nlinarith [hs4]
  -- `e^{-25} ≤ 1/6000`
  have h2e : (2 : ℝ) ≤ Real.exp 1 := by
    have := Real.add_one_le_exp (1 : ℝ)
    linarith
  have hexp25 : (6000 : ℝ) ≤ Real.exp (25 : ℝ) := by
    have hpow : Real.exp 1 ^ (25 : ℕ) = Real.exp (25 : ℝ) := by
      rw [← Real.exp_nat_mul]
      norm_num
    calc (6000 : ℝ) ≤ (2 : ℝ) ^ (25 : ℕ) := by norm_num
      _ ≤ Real.exp 1 ^ (25 : ℕ) := pow_le_pow_left₀ (by norm_num) h2e 25
      _ = Real.exp (25 : ℝ) := hpow
  have hexp_neg25 : Real.exp (-(25 : ℝ)) ≤ 1 / 6000 := by
    rw [Real.exp_neg, inv_eq_one_div]
    exact one_div_le_one_div_of_le (by norm_num) hexp25
  -- one reserve leg caps at `(π/3)·(s·e^{200})·e^{-225s} ≤ (4/3)/6000`
  have hcap :
      (bgpScale : ℝ) * Real.exp (200 : ℝ) *
        (Real.pi / 3 * Real.exp (-(225 * (bgpScale : ℝ)))) ≤ 1 / 4500 := by
    have hπ43 : Real.pi / 3 ≤ 4 / 3 := by linarith [Real.pi_le_four]
    have hπ0 : (0 : ℝ) ≤ Real.pi / 3 := by positivity
    have hchain : (bgpScale : ℝ) * Real.exp (200 : ℝ) *
        Real.exp (-(225 * (bgpScale : ℝ))) ≤ 1 / 6000 := by
      have h1 : (bgpScale : ℝ) * Real.exp (200 : ℝ) *
          Real.exp (-(225 * (bgpScale : ℝ))) =
          Real.exp (200 : ℝ) *
            ((bgpScale : ℝ) * Real.exp (-(225 * (bgpScale : ℝ)))) := by
        ring
      rw [h1]
      calc Real.exp (200 : ℝ) *
            ((bgpScale : ℝ) * Real.exp (-(225 * (bgpScale : ℝ))))
          ≤ Real.exp (200 : ℝ) * Real.exp (-(224 * (bgpScale : ℝ))) :=
            mul_le_mul_of_nonneg_left hs_exp (Real.exp_pos _).le
        _ ≤ Real.exp (-(25 : ℝ)) := hprod
        _ ≤ 1 / 6000 := hexp_neg25
    have hnn : (0 : ℝ) ≤ (bgpScale : ℝ) * Real.exp (200 : ℝ) *
        Real.exp (-(225 * (bgpScale : ℝ))) := by positivity
    calc (bgpScale : ℝ) * Real.exp (200 : ℝ) *
          (Real.pi / 3 * Real.exp (-(225 * (bgpScale : ℝ))))
        = Real.pi / 3 * ((bgpScale : ℝ) * Real.exp (200 : ℝ) *
            Real.exp (-(225 * (bgpScale : ℝ)))) := by ring
      _ ≤ (4 / 3 : ℝ) * (1 / 6000) := by
          exact mul_le_mul hπ43 hchain hnn (by norm_num)
      _ ≤ 1 / 4500 := by norm_num
  have hfrac_pre_nonneg :
      0 ≤ Real.pi / 3 *
        Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime 0)) := by
    positivity
  have hfrac_set_nonneg :
      0 ≤ Real.pi / 3 *
        Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime 0)) := by
    positivity
  have h1 :
      Cwin * (Real.pi / 3 *
          Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime 0))) ≤
        (bgpScale : ℝ) * Real.exp (200 : ℝ) *
          (Real.pi / 3 * Real.exp (-(225 * (bgpScale : ℝ)))) :=
    mul_le_mul hCwin_le
      (mul_le_mul_of_nonneg_left hexp_pre (by positivity))
      hfrac_pre_nonneg (by positivity)
  have h2 :
      Cwin * (Real.pi / 3 *
          Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime 0))) ≤
        (bgpScale : ℝ) * Real.exp (200 : ℝ) *
          (Real.pi / 3 * Real.exp (-(225 * (bgpScale : ℝ)))) :=
    mul_le_mul hCwin_le
      (mul_le_mul_of_nonneg_left hexp_set (by positivity))
      hfrac_set_nonneg (by positivity)
  have hr : r_LE_U / 2 = 1 / 2000 := by
    norm_num [r_LE_U]
  dsimp [δuWritePrefixN, δuSettledN]
  rw [hr]
  linarith

/-- **The N joint per-cycle core** — the `Paper3F1JointStepCore` sibling at
the N family, N tube radius, and `bgpScale`-scaled envelope ceiling. -/
structure Paper3F1JointStepCoreN (wg w : ℕ) where
  Cwin : ℝ
  Csrc : ℝ
  Ezu : ℕ → ℝ
  hCwin0 : 0 ≤ Cwin
  hCwin_le : Cwin ≤ (bgpScale : ℝ) * Real.exp (200 : ℝ)
  hCsrc0 : 0 ≤ Csrc
  hE0 : ∀ i : Fin d_U,
    |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime 0) i -
      ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime 0) i| ≤
      Ezu 0
  hwin_of : ∀ j,
    (∀ i, paper3F1BoundaryErrN wg w j i ≤ paper3F1TubeRadiusN Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamN wg) w).z t i -
        ((paper3HeadlineSolFamN wg) w).u t i| ≤ Cwin
  hnext_of : ∀ j,
    (∀ i, paper3F1BoundaryErrN wg w j i ≤ paper3F1TubeRadiusN Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z
          (selectorMUWriteStartTime (j + 1)) i -
        ((paper3HeadlineSolFamN wg) w).u
          (selectorMUWriteStartTime (j + 1)) i| ≤ Ezu (j + 1)
  hsrc_geo_of : ∀ j,
    (∀ i, paper3F1BoundaryErrN wg w j i ≤ paper3F1TubeRadiusN Cwin) →
    (∀ i : Fin d_U,
      |((paper3HeadlineSolFamN wg) w).z (selectorMUWriteStartTime j) i -
        ((paper3HeadlineSolFamN wg) w).u (selectorMUWriteStartTime j) i| ≤
        Ezu j) →
    ∀ i, paper3F1SrcCoreN wg w j i ≤
      Csrc * Real.exp (-(2 : ℝ) * (j : ℝ))
  hbudget_half : ∀ i,
    paper3F1W0N wg w i + paper3F1GeomCap w Csrc ≤ r_LE_U / 2

/-- The explicit F1-N joint-core window-envelope constant
`bgpScale·(e^{199} + 11)` — the `bgpScale`-scaled hull (the fixed `e^{199}`
hull is N-unsound: coordinate boxes are `O(D_U) = O(bgpScale)`). -/
noncomputable def paper3F1CwinDefN : ℝ :=
  (bgpScale : ℝ) * paper3F1CwinDef

theorem paper3F1CwinDefN_nonneg : 0 ≤ paper3F1CwinDefN := by
  unfold paper3F1CwinDefN
  exact mul_nonneg (by positivity) paper3F1CwinDef_nonneg

theorem paper3F1CwinDefN_le_scale_exp200 :
    paper3F1CwinDefN ≤ (bgpScale : ℝ) * Real.exp (200 : ℝ) := by
  unfold paper3F1CwinDefN
  exact mul_le_mul_of_nonneg_left paper3F1CwinDef_le_exp200 (by positivity)

/-- The explicit N endpoint recurrence (RETIMED, 2026-07-10):
`Ezu 0 = bgpScale·e^{199}`,
`Ezu (j+1) = max (e^{-massN_j}·(max (Ezu j) (bgpScale·e^{198}) + bgpScale)
+ 1) (10·bgpScale)`, where `massN_j = selectorInterReadUActiveMassLowerN j`
is the N-scaled inter-read u-kernel mass.  The first branch is the
`wr j → zOffEnd j` transport (contraction on the read box, retimed source
cap `≤ 1`); the second is the `5·D_U ≤ 10·bgpScale` prewrite mix box
threaded through the no-slop trapping `paper3N_prewrite_zu_hold` on
`[zOffEnd j, ws (j+1)]`. -/
noncomputable def paper3F1EzuDefN : ℕ → ℝ
  | 0 => (bgpScale : ℝ) * Real.exp (199 : ℝ)
  | j + 1 =>
      max (Real.exp (-(selectorInterReadUActiveMassLowerN j)) *
          (max (paper3F1EzuDefN j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
            (bgpScale : ℝ)) + 1)
        (10 * (bgpScale : ℝ))

theorem paper3F1EzuDefN_zero :
    paper3F1EzuDefN 0 = (bgpScale : ℝ) * Real.exp (199 : ℝ) := rfl

theorem paper3F1EzuDefN_succ (j : ℕ) :
    paper3F1EzuDefN (j + 1) =
      max (Real.exp (-(selectorInterReadUActiveMassLowerN j)) *
          (max (paper3F1EzuDefN j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
            (bgpScale : ℝ)) + 1)
        (10 * (bgpScale : ℝ)) := rfl

theorem paper3F1EzuDefN_nonneg (j : ℕ) : 0 ≤ paper3F1EzuDefN j := by
  cases j with
  | zero =>
      rw [paper3F1EzuDefN_zero]
      positivity
  | succ j =>
      rw [paper3F1EzuDefN_succ]
      have hs0 : (0 : ℝ) ≤ 10 * (bgpScale : ℝ) := by positivity
      exact le_trans hs0 (le_max_right _ _)

/-- Staged bound on the N endpoint recurrence: `+2·bgpScale` growth for the
first five cycles, then contraction (the N mass linear bound
`selectorInterReadUActiveMassLowerN_ge_linear` has the same `2j - 8` shape
as the fixed one). -/
theorem paper3F1EzuDefN_le_staged (j : ℕ) :
    paper3F1EzuDefN j ≤
      (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 2 * ((min j 5 : ℕ) : ℝ)) := by
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hs1 : (1 : ℝ) ≤ (bgpScale : ℝ) := bgpScaleR_ge_one
  induction j with
  | zero =>
      rw [paper3F1EzuDefN_zero]
      norm_num
  | succ j ih =>
      have hW0 : 0 ≤ max (paper3F1EzuDefN j)
          ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ) := by
        have h1 := le_max_right (paper3F1EzuDefN j)
          ((bgpScale : ℝ) * Real.exp (198 : ℝ))
        have h2 : (0 : ℝ) ≤ (bgpScale : ℝ) * Real.exp (198 : ℝ) := by
          positivity
        linarith
      have hexp198 : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) :=
        Real.exp_le_exp.mpr (by norm_num)
      have hmin_nn : (0 : ℝ) ≤ 2 * ((min j 5 : ℕ) : ℝ) := by positivity
      by_cases hj : j < 5
      · -- growth regime: `e^{-massN_j} ≤ 1`, `+2·bgpScale` per cycle
        have hq1 : Real.exp (-(selectorInterReadUActiveMassLowerN j)) ≤ 1 := by
          have h0 := selectorInterReadUActiveMassLowerN_nonneg j
          calc Real.exp (-(selectorInterReadUActiveMassLowerN j))
              ≤ Real.exp 0 := Real.exp_le_exp.mpr (by linarith)
            _ = 1 := Real.exp_zero
        have hmin_succ : ((min (j + 1) 5 : ℕ) : ℝ) =
            ((min j 5 : ℕ) : ℝ) + 1 := by
          have h : min (j + 1) 5 = min j 5 + 1 := by omega
          rw [h]; push_cast; ring
        have hWle : max (paper3F1EzuDefN j)
            ((bgpScale : ℝ) * Real.exp (198 : ℝ)) ≤
            (bgpScale : ℝ) *
              (Real.exp (199 : ℝ) + 2 * ((min j 5 : ℕ) : ℝ)) := by
          refine max_le ih ?_
          have : Real.exp (198 : ℝ) ≤
              Real.exp (199 : ℝ) + 2 * ((min j 5 : ℕ) : ℝ) := by linarith
          exact mul_le_mul_of_nonneg_left this hs0.le
        have h200 : (200 : ℝ) ≤ Real.exp (199 : ℝ) := by
          have := Real.add_one_le_exp (199 : ℝ)
          linarith
        rw [paper3F1EzuDefN_succ, hmin_succ]
        have hmul := mul_le_mul_of_nonneg_right hq1 hW0
        rw [one_mul] at hmul
        apply max_le
        · nlinarith [hmul, hWle]
        · nlinarith [h200, hs0.le, hmin_nn]
      · -- contraction regime: `e^{-massN_j} ≤ e^{-2}`
        push_neg at hj
        have hjR : (5 : ℝ) ≤ (j : ℝ) := by exact_mod_cast hj
        have hq : Real.exp (-(selectorInterReadUActiveMassLowerN j)) ≤
            Real.exp (-2 : ℝ) := by
          apply Real.exp_le_exp.mpr
          have h := selectorInterReadUActiveMassLowerN_ge_linear j
          linarith
        have hq7 : Real.exp (-2 : ℝ) * 7 ≤ 1 := by
          have h7 : (7 : ℝ) ≤ Real.exp 2 := by
            have h1 : (2.7182818283 : ℝ) < Real.exp 1 := Real.exp_one_gt_d9
            have h2 : Real.exp (2 : ℝ) = Real.exp 1 * Real.exp 1 := by
              rw [← Real.exp_add]; norm_num
            nlinarith [Real.exp_pos 1]
          have hE : Real.exp (-2 : ℝ) * Real.exp (2 : ℝ) = 1 := by
            rw [← Real.exp_add]; norm_num
          have hmono :=
            mul_le_mul_of_nonneg_left h7 (Real.exp_pos (-2 : ℝ)).le
          rw [hE] at hmono
          exact hmono
        have hmin5 : ((min j 5 : ℕ) : ℝ) = 5 := by
          have h : min j 5 = 5 := by omega
          rw [h]; norm_num
        have hminS : ((min (j + 1) 5 : ℕ) : ℝ) = 5 := by
          have h : min (j + 1) 5 = 5 := by omega
          rw [h]; norm_num
        have hEj : paper3F1EzuDefN j ≤
            (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by
          rw [hmin5] at ih
          linarith
        have hbig : (1 : ℝ) ≤ Real.exp (199 : ℝ) := by
          have := Real.add_one_le_exp (199 : ℝ)
          linarith
        have hWle : max (paper3F1EzuDefN j)
            ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ) ≤
            (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 11) := by
          have h198 : (bgpScale : ℝ) * Real.exp (198 : ℝ) ≤
              (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by
            have : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) + 10 := by
              linarith
            exact mul_le_mul_of_nonneg_left this hs0.le
          have hmax := max_le hEj h198
          nlinarith [hmax]
        -- the closed numeric core: `e^{-2}·(E+11) + 1 ≤ E + 10` at `E = e^{199}`
        have hXE : Real.exp (-2 : ℝ) * Real.exp (199 : ℝ) * 7 ≤
            Real.exp (199 : ℝ) := by
          nlinarith [hq7, (Real.exp_pos (199 : ℝ)).le]
        have hcore : Real.exp (-2 : ℝ) * (Real.exp (199 : ℝ) + 11) + 1 ≤
            Real.exp (199 : ℝ) + 10 := by
          nlinarith [hXE, hq7, hbig]
        have hqW : Real.exp (-(selectorInterReadUActiveMassLowerN j)) *
            (max (paper3F1EzuDefN j)
              ((bgpScale : ℝ) * Real.exp (198 : ℝ)) + (bgpScale : ℝ)) ≤
            Real.exp (-2 : ℝ) *
              ((bgpScale : ℝ) * (Real.exp (199 : ℝ) + 11)) :=
          mul_le_mul hq hWle hW0 (Real.exp_pos (-2 : ℝ)).le
        have hscaled := mul_le_mul_of_nonneg_left hcore hs0.le
        rw [paper3F1EzuDefN_succ, hminS]
        apply max_le
        · nlinarith [hqW, hscaled, hs1]
        · nlinarith [hbig, hs0.le]

theorem paper3F1EzuDefN_le_ten (j : ℕ) :
    paper3F1EzuDefN j ≤ (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by
  have h := paper3F1EzuDefN_le_staged j
  have hm : ((min j 5 : ℕ) : ℝ) ≤ 5 := by
    exact_mod_cast min_le_right j 5
  have hs0 : (0 : ℝ) ≤ (bgpScale : ℝ) := by positivity
  nlinarith [h, hm, hs0]

/-- Every per-cycle N window envelope fits below the explicit `CwinN`. -/
theorem paper3F1EzuDefN_window_le (j : ℕ) :
    max (paper3F1EzuDefN j) ((bgpScale : ℝ) * Real.exp (198 : ℝ)) +
      (bgpScale : ℝ) ≤ paper3F1CwinDefN := by
  have hs0 : (0 : ℝ) ≤ (bgpScale : ℝ) := by positivity
  have h1 := paper3F1EzuDefN_le_ten j
  have h2 : (bgpScale : ℝ) * Real.exp (198 : ℝ) ≤
      (bgpScale : ℝ) * (Real.exp (199 : ℝ) + 10) := by
    have : Real.exp (198 : ℝ) ≤ Real.exp (199 : ℝ) + 10 := by
      have := Real.exp_le_exp.mpr (by norm_num : (198 : ℝ) ≤ 199)
      linarith
    exact mul_le_mul_of_nonneg_left this hs0
  have h := max_le h1 h2
  unfold paper3F1CwinDefN paper3F1CwinDef
  nlinarith [h]

/-- The N boundary-tube radius at the explicit `CwinN` sits inside the
readout tube. -/
theorem paper3F1TubeRadiusN_CwinDefN_le :
    paper3F1TubeRadiusN paper3F1CwinDefN ≤ r_LE_U := by
  have h1 : 0 ≤ δuWritePrefixN paper3F1CwinDefN 0 :=
    δuWritePrefixN_nonneg paper3F1CwinDefN_nonneg 0
  have h2 : 0 ≤ δuSettledN paper3F1CwinDefN 0 :=
    δuSettledN_nonneg paper3F1CwinDefN_nonneg 0
  unfold paper3F1TubeRadiusN
  linarith

/-! #### N warm-prefix infrastructure (for the (2/5)_N endpoint)

The same `[0, π/6]` head-start freeze skeleton as the F1-NW (5/5) block
(mid-file), instantiated at the plain N rates: `sin ≥ 0` gives the u-kernel
`A·α·bGateU ≤ e^{−200·bgpScale·τ}` with mass `≤ 1/(200·bgpScale) ≤ 1/800`,
which maintains a LOOSE `1/3`-radius u-tube (NOT the `r_LE_U` tube — that
one is exactly what fails at w-independent rates); the `1/3` tube still
releases the `2·D_U` branch hull
(`branchU_evalBranch_abs_le_two_D_U_of_third_tube`), so the coupled pair
stays in a `5·D_U` box and the cycle-0 endpoint lands below
`bgpScale·e^{199}` with astronomical slack. -/

/-- Mass of a decaying exponential kernel: `∫₀ᵗ e^{−c·τ} dτ ≤ 1/c`. -/
theorem paper3NW_exp_mass_le {c : ℝ} (hc : 0 < c) {t : ℝ}
    (ht : 0 ≤ t) :
    (∫ τ in (0 : ℝ)..t, Real.exp (-(c * τ))) ≤ 1 / c := by
  have hcont : Continuous fun τ : ℝ => Real.exp (-(c * τ)) :=
    Real.continuous_exp.comp (continuous_const.mul continuous_id).neg
  have hderiv : ∀ τ ∈ Set.uIcc (0 : ℝ) t,
      HasDerivAt (fun s : ℝ => -(Real.exp (-(c * s)) / c))
        (Real.exp (-(c * τ))) τ := by
    intro τ _
    have h1 : HasDerivAt (fun s : ℝ => -(c * s)) (-c) τ := by
      simpa using ((hasDerivAt_id τ).const_mul c).neg
    have h2 : HasDerivAt (fun s : ℝ => Real.exp (-(c * s)))
        (Real.exp (-(c * τ)) * -c) τ := h1.exp
    have h3 := (h2.div_const c).neg
    have hsimp : -(Real.exp (-(c * τ)) * -c / c) = Real.exp (-(c * τ)) := by
      field_simp
    rw [← hsimp]
    exact h3
  have heq := intervalIntegral.integral_eq_sub_of_hasDerivAt hderiv
    (hcont.intervalIntegrable 0 t)
  rw [heq]
  have h1 : 0 < Real.exp (-(c * t)) := Real.exp_pos _
  have h2 : Real.exp (-(c * (0 : ℝ))) = 1 := by norm_num
  rw [h2]
  have h3 : 0 < Real.exp (-(c * t)) / c := div_pos h1 hc
  have h4 : 0 < 1 / c := by positivity
  linarith

