    exact Set.mem_Icc.mpr (abs_le.mp hle)
  have hy0 : y (selectorMUZOffEnd j) ∈ Icc (-(max E B)) (max E B) := by
    have hle : |y (selectorMUZOffEnd j)| ≤ max E B :=
      le_trans (hE i) (le_max_left E B)
    exact Set.mem_Icc.mpr (abs_le.mp hle)
  have hfin := paper3N_trapping_on_Icc_cOn y gg kk haT
    hkk_cont.continuousOn hgg_cOn hy_ode hknn hgg_range hy0
  have habs_fin : |y (selectorMUWriteStartTime (j + 1))| ≤ max E B :=
    abs_le.mpr (Set.mem_Icc.mp hfin)
