    have hz := ((paper3HeadlineSolFamN wg) w).z_hasDeriv τ hdom i
    have hu := ((paper3HeadlineSolFamN wg) w).u_hasDeriv τ hdom i
    have hkkne : kk τ ≠ 0 := ne_of_gt (hkk_pos τ hτ0)
    have hsub := hz.sub hu
    convert hsub using 1
    have hkkgg : kk τ * gg τ =
        kZ τ * (selectorMixTarget branchU ((paper3HeadlineSolFamN wg) w).u
            ((paper3HeadlineSolFamN wg) w).lam τ i -
          ((paper3HeadlineSolFamN wg) w).u τ i) := by
      dsimp only [gg]
      rw [mul_comm]
      exact div_mul_cancel₀ _ hkkne
    rw [mul_sub, hkkgg]
    dsimp only [y, kk, kZ, kUf]
    ring
  have hknn : ∀ τ ∈ Icc (selectorMUZOffEnd j)
      (selectorMUWriteStartTime (j + 1)), 0 ≤ kk τ :=
    fun τ hτ => (hkk_pos τ (le_trans ha0 hτ.1)).le
  have hBnn : 0 ≤ B :=
    le_trans (abs_nonneg _) (hB i _ ⟨le_refl _, haT⟩)
