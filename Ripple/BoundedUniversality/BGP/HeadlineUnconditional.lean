  let sol := paper3HeadlineSolFam wg
  let c : UniversalLocalView := localViewU (solMUReplStaticCfg w (j + 1))
  ∫ τ in (selectorMUEarlyWriteSubStart (j + 1))..
      (selectorMUWriteHoldTime (j + 1)),
    (∑ v : UniversalLocalView,
      (BranchData.evalBranch (branchU v) ((sol w).u τ) haltCoordU -
        BranchData.evalBranch (branchU c) ((sol w).u τ) haltCoordU) *
        |(((1 + Real.cos τ) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ)) *
            (Fintype.card UniversalLocalView : ℝ)⁻¹ -
          ((((1 + Real.cos τ) / 2) ^ paper3HeadlineM *
              (paper3HeadlineKappa : ℝ)) +
            (((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQ wg : ℚ) : ℝ) *
                Real.exp (bgpParams38.cα * τ))) *
              (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
                  ((sol w).u τ) -
                universalPval paper3HeadlineEta paper3HeadlineEta_pos v
                  ((sol w).u τ))) *
            (sol w).lam v τ|) +
    (((1 + Real.sin τ) / 2) ^ paper3HeadlineM *
      (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * τ))) *
      (∑ v : UniversalLocalView,
        (sol w).lam v τ *
          (universalPval paper3HeadlineEta paper3HeadlineEta_pos c
