/-- The homogeneous part has already paid the double-exponential selection
mass by `hold`; from `hold` onward it retains the running physical-time
decay. -/
theorem paper3S4a_homogeneous_timelocal_NW
    (w j : ℕ) {gap t : ℝ}
    (hgap : (15 : ℝ) / 16 ≤ gap)
    (ht : t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUZOffStart j)) :
    Real.exp (-gap *
        (((paper3HeadlineSolFamNW w) w).G t -
          ((paper3HeadlineSolFamNW w) w).G (selectorMUSelectStartTime j))) ≤
      paper3S4aInitialCoeffNW w j *
        Real.exp (-((bgpParamsNW w).cα * t)) := by
  let sol := (paper3HeadlineSolFamNW w) w
  let a := selectorMUSelectStartTime j
  let h := selectorMUWriteHoldTime j
  let c := (bgpParamsNW w).cα
  let cg : ℝ → ℝ := paper3NW4cg w
  have hgap0 : 0 < gap := by linarith
  have ha0 : 0 ≤ a :=
    le_trans (selectorMUWriteStartTime_nonneg j)
      (selectorMUWriteStart_le_selectStart j)
  have hah : a ≤ h := by
    exact (selectorMUSelectStart_lt_hold j).le
  have hh0 : 0 ≤ h := le_trans ha0 hah
  have hht : h ≤ t := ht.1
  have hΔ := paper3NW4_deltaG_lower w w j
    (t := selectorMUWriteHoldTime j) le_rfl
  have hΔ0 := paper3NW4DeltaGFloor_nonneg w j
  have hfirst :
      Real.exp (-gap * (sol.G h - sol.G a)) ≤
        Real.exp (-(15 / 16 : ℝ) * paper3NW4DeltaGFloor w j) := by
    apply Real.exp_le_exp.mpr
    have hG0 : 0 ≤ sol.G h - sol.G a := by
      exact le_trans hΔ0 (by simpa [sol, h, a] using hΔ)
    have hΔh : paper3NW4DeltaGFloor w j ≤ sol.G h - sol.G a := by
      simpa [sol, h, a] using hΔ
    nlinarith
  have hpost :
      Real.exp (-gap * (sol.G t - sol.G h)) ≤
        Real.exp (c * h) * Real.exp (-(c * t)) := by
    have hpost' := exp_neg_G_sub_le_exp_mul_exp_neg_of_rate_le
      (a := h) (t := t) (gap := gap) (c := c)
      (G := sol.G) (cg := cg) hht
      (fun s hs => by
        have hs0 : 0 ≤ s := le_trans hh0 hs.1
        simpa [sol, cg] using paper3NW4_G_hasDeriv w w hs0)
      (paper3NW4cg_cont w)
      (fun s hs => by
        have hswin : s ∈ Icc (selectorMUSelectStartTime j)
            (selectorMUZOffStart j) :=
          ⟨le_trans hah hs.1, le_trans hs.2 ht.2⟩
        simpa [c, cg] using
          paper3S4a_gap_mul_cg_ge_calpha_NW w j hgap hswin)
    simpa only [neg_mul] using hpost'
  calc
    Real.exp (-gap * (sol.G t - sol.G a)) =
        Real.exp (-gap * (sol.G h - sol.G a)) *
          Real.exp (-gap * (sol.G t - sol.G h)) := by
      rw [← Real.exp_add]
      congr 1
      ring
    _ ≤ Real.exp (-(15 / 16 : ℝ) * paper3NW4DeltaGFloor w j) *
          (Real.exp (c * h) * Real.exp (-(c * t))) :=
      mul_le_mul hfirst hpost (Real.exp_pos _).le
        (Real.exp_pos _).le
    _ = paper3S4aInitialCoeffNW w j * Real.exp (-(c * t)) := by
      unfold paper3S4aInitialCoeffNW
      rw [Real.exp_add]
      ring
    _ = paper3S4aInitialCoeffNW w j *
          Real.exp (-((bgpParamsNW w).cα * t)) := by rfl

/-- Unfrozen Duhamel form of the old-winner loser mass.  In particular, the
reset integral and terminal integrating factor still share the same endpoint
