prefix/tail package. -/
theorem hutube_win
    {wg : ℕ} (R : SelectorMUWriteFullUTubeCoupledTailInputsDiag wg) :
    ∀ j, ∀ t ∈ Ico (selectorMUWriteStartTime j) (selectorMUWriteReadTime j),
      UTube r_LE_U (solMUReplStaticCfg wg j) (((paper3HeadlineSolFam wg) wg).u t) := by
  intro j t ht
  by_cases hlt : t < selectorMUWriteHoldTime j
  · let budget :=
      R.wordInput.toSelectorMUCoarseUTubeBudgetInputs.toBudget
        (solMUReplStaticCfg_step wg)
    exact budget.coarse_utube_all j t ⟨ht.1, hlt⟩
  · exact
      selectorMU_hutube_tail_of_hold_slack (((paper3HeadlineSolFam wg) wg))
        (fun j : ℕ => solMUReplStaticCfg wg j) j
        (R.wordInput.Bzu j) (R.wordInput.hBzu0 j)
        (fun t ht => selectorSchedule_domain_of_nonneg_structural t ht)
        (R.wordInput.hzu_tail j)
        (R.wordInput.writeHold_slack (solMUReplStaticCfg_step wg) j)
        t ⟨le_of_not_gt hlt, le_of_lt ht.2⟩

end SelectorMUWriteFullUTubeCoupledTailInputsDiag

/-- Headline-level projection from a local inter-read all-coordinate amplitude
bound to the weighted z-source integral used by the true write-start reducer. -/
theorem paper3Headline_interRead_source_integral_le_of_mixZBound
    (wg w j : ℕ) {Bamp : ℝ}
    (hBamp0 : 0 ≤ Bamp)
    (hamp : ∀ τ ∈ Icc (selectorMUWriteReadTime j)
        (selectorMUWriteStartTime (j + 1)), ∀ i : Fin d_U,
      |selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
          ((paper3HeadlineSolFam wg) w).lam τ i -
        ((paper3HeadlineSolFam wg) w).z τ i| ≤ Bamp) :
    ∀ i : Fin d_U,
      (∫ τ in (selectorMUWriteReadTime j)..(selectorMUWriteStartTime (j + 1)),
        Real.exp (-(∫ s in τ..(selectorMUWriteStartTime (j + 1)),
          bgpParams38.A * ((paper3HeadlineSolFam wg) w).α s *
            bGateU bgpParams38.L (((paper3HeadlineSolFam wg) w).μ s) s)) *
        |bgpParams38.A * ((paper3HeadlineSolFam wg) w).α τ *
          bGateZ bgpParams38.L (((paper3HeadlineSolFam wg) w).μ τ) τ *
          (selectorMixTarget branchU ((paper3HeadlineSolFam wg) w).u
            ((paper3HeadlineSolFam wg) w).lam τ i -
            ((paper3HeadlineSolFam wg) w).z τ i)|) ≤
      selectorInterReadSourceCap Bamp j := by
  exact selector_replicator_interRead_source_integral_le_envelope
    (((paper3HeadlineSolFam wg) w)) j hBamp0 hamp

theorem paper3_finset_sum_abs_sub_le_sum_abs_add_sum_of_nonneg
    {α : Type} [DecidableEq α] (s : Finset α) (a b : α → ℝ)
    (hb : ∀ x ∈ s, 0 ≤ b x) :
    s.sum (fun x => |a x - b x|) ≤
      s.sum (fun x => |a x|) + s.sum b := by
  calc
    s.sum (fun x => |a x - b x|) ≤
        s.sum (fun x => |a x| + b x) := by
      refine Finset.sum_le_sum ?_
      intro x hx
      have htri : |a x - b x| ≤ |a x| + |b x| := by
        have h := abs_sub_le (a x) 0 (b x)
        simpa using h
      simpa [abs_of_nonneg (hb x hx)] using htri
    _ = s.sum (fun x => |a x|) + s.sum b := by
      rw [Finset.sum_add_distrib]

abbrev paper3HoffExponent (j : ℕ) : ℝ :=
  (1 / 8 : ℝ) * (2 * Real.pi * (j : ℝ) + Real.pi)

abbrev paper3HoffRate (j : ℕ) : ℝ :=
  Real.exp (-paper3HoffExponent j)

theorem paper3HoffRate_pos (j : ℕ) :
    0 < paper3HoffRate j := by
  dsimp [paper3HoffRate]
  positivity

theorem paper3HoffRate_succ_le (j : ℕ) :
    paper3HoffRate (j + 1) ≤ paper3HoffRate j := by
  rw [paper3HoffRate, paper3HoffRate]
  refine Real.exp_le_exp.mpr ?_
  rw [paper3HoffExponent, paper3HoffExponent]
  push_cast
  nlinarith [Real.pi_pos]

theorem paper3HoffRate_le_one (j : ℕ) :
    paper3HoffRate j ≤ 1 := by
  rw [paper3HoffRate]
  rw [← Real.exp_zero]
  refine Real.exp_le_exp.mpr ?_
  rw [paper3HoffExponent]
  have hj : 0 ≤ (j : ℝ) := by
    exact_mod_cast (Nat.zero_le j : 0 ≤ j)
  nlinarith [Real.pi_pos, hj]

theorem paper3HoffRate_inv_le_exp_writeStart (j : ℕ) :
    (paper3HoffRate j)⁻¹ ≤
      Real.exp ((1 / 8 : ℝ) * selectorMUWriteStartTime (j + 1)) := by
  rw [paper3HoffRate]
  calc
    (Real.exp (-paper3HoffExponent j))⁻¹ = Real.exp (paper3HoffExponent j) := by
      rw [← Real.exp_neg]
      ring_nf
    _ ≤ Real.exp ((1 / 8 : ℝ) * selectorMUWriteStartTime (j + 1)) := by
      refine Real.exp_le_exp.mpr ?_
      rw [paper3HoffExponent, selectorMUWriteStartTime]
      push_cast
      nlinarith [Real.pi_pos]

theorem paper3Headline_t_mul_rmin_le_cmu_mul_rPulse
    {rmin t : ℝ}
    (ht : 0 ≤ t)
    (hr : rmin ≤ rPulse bgpParams38.L t) :
    t * rmin ≤ (bgpParams38.cμ * t) * rPulse bgpParams38.L t := by
  have hbase : t * rmin ≤ t * rPulse bgpParams38.L t :=
    mul_le_mul_of_nonneg_left hr ht
  have hcmu : (1 : ℝ) ≤ bgpParams38.cμ := by
    norm_num [bgpParams38]
  have hpulse_nonneg : 0 ≤ rPulse bgpParams38.L t :=
    rPulse_nonneg bgpParams38.L t
  have hscale :
      t * rPulse bgpParams38.L t ≤
        (bgpParams38.cμ * t) * rPulse bgpParams38.L t := by
    have hprod_nonneg : 0 ≤ t * rPulse bgpParams38.L t :=
      mul_nonneg ht hpulse_nonneg
    calc
      t * rPulse bgpParams38.L t =
          (1 : ℝ) * (t * rPulse bgpParams38.L t) := by ring
      _ ≤ bgpParams38.cμ * (t * rPulse bgpParams38.L t) :=
          mul_le_mul_of_nonneg_right hcmu hprod_nonneg
      _ = (bgpParams38.cμ * t) * rPulse bgpParams38.L t := by ring
  exact le_trans hbase hscale

theorem paper3Headline_middleEnvelopeFullCap_le_eight_hoffRate (j : ℕ) :
    selectorMUHoffMiddleEnvelopeFullCap j ≤ (8 : ℝ) * paper3HoffRate j := by
  let T : ℝ := 2 * Real.pi * (j : ℝ) + Real.pi
  have hbase := selectorMUHoffMiddleEnvelopeFullCap_le_eight j
  have hT_nonneg : 0 ≤ T := by
    dsimp [T]
    have hj : 0 ≤ (j : ℝ) := by
      exact_mod_cast Nat.zero_le j
    nlinarith [Real.pi_pos]
  have hrate :
      (1 / 8 : ℝ) ≤
        bgpParams38.cμ * (2 ^ bgpParams38.L : ℝ)⁻¹ - bgpParams38.cα := by
    norm_num [bgpParams38]
  have hfast_le :
      Real.exp
          (-((bgpParams38.cμ * (2 ^ bgpParams38.L : ℝ)⁻¹ -
              bgpParams38.cα) * T)) ≤
        paper3HoffRate j := by
    dsimp [paper3HoffRate, paper3HoffExponent, T]
    apply Real.exp_le_exp.mpr
    apply neg_le_neg
    exact mul_le_mul_of_nonneg_right hrate hT_nonneg
  have hscaled := mul_le_mul_of_nonneg_left hfast_le
    (by norm_num : (0 : ℝ) ≤ 8)
  exact le_trans (by simpa [T] using hbase) hscaled

theorem paper3Headline_cAlpha_le_selectorUSettledRate :
    bgpParams38.cα ≤ selectorUSettledRate := by
  norm_num [selectorUSettledRate, bgpParams38]

theorem paper3Headline_active_E_eq_writeStart_add_pi_div_twelve
    (j : ℕ) :
    selectorMUEarlyWriteSubStart (j + 1) =
      selectorMUWriteStartTime (j + 1) + Real.pi / 12 := by
  dsimp [selectorMUEarlyWriteSubStart, selectorMUWriteStartTime]
  ring

theorem paper3Headline_active_hold_eq_writeStart_add_pi_div_three
    (j : ℕ) :
    selectorMUWriteHoldTime (j + 1) =
      selectorMUWriteStartTime (j + 1) + Real.pi / 3 := by
  dsimp [selectorMUWriteHoldTime, selectorMUWriteStartTime]
  ring

theorem paper3Headline_active_len_eq_pi_div_four
    (j : ℕ) :
    selectorMUWriteHoldTime (j + 1) -
      selectorMUEarlyWriteSubStart (j + 1) = Real.pi / 4 := by
  dsimp [selectorMUWriteHoldTime, selectorMUEarlyWriteSubStart]
  ring

theorem paper3Headline_active_len_le_one (j : ℕ) :
    selectorMUWriteHoldTime (j + 1) -
      selectorMUEarlyWriteSubStart (j + 1) ≤ 1 := by
  rw [paper3Headline_active_len_eq_pi_div_four]
  nlinarith [Real.pi_lt_four]

theorem paper3Headline_exp_neg_cAlpha_early_le_hoffRate
    (j : ℕ) :
    Real.exp (-(bgpParams38.cα *
        selectorMUEarlyWriteSubStart (j + 1))) ≤
      paper3HoffRate j := by
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  have hratio :
      Real.exp (-(bgpParams38.cα * E)) / paper3HoffRate j ≤ 1 := by
    have hinv := paper3HoffRate_inv_le_exp_writeStart j
    have hmul :
        Real.exp (-(bgpParams38.cα * E)) * (paper3HoffRate j)⁻¹ ≤
          Real.exp (-(bgpParams38.cα * E)) *
            Real.exp ((1 / 8 : ℝ) * W) := by
      exact mul_le_mul_of_nonneg_left (by simpa [W] using hinv)
        (Real.exp_pos _).le
    have harg :
        -(bgpParams38.cα * E) + (1 / 8 : ℝ) * W ≤ 0 := by
      have hn : 0 ≤ ((j + 1 : ℕ) : ℝ) := by
        exact_mod_cast (Nat.zero_le (j + 1) : 0 ≤ j + 1)
      dsimp [E, W, selectorMUEarlyWriteSubStart, selectorMUWriteStartTime]
      norm_num [bgpParams38]
      nlinarith [hn, Real.pi_pos]
    calc
      Real.exp (-(bgpParams38.cα * E)) / paper3HoffRate j
          =
        Real.exp (-(bgpParams38.cα * E)) * (paper3HoffRate j)⁻¹ := by
          rw [div_eq_mul_inv]
      _ ≤
        Real.exp (-(bgpParams38.cα * E)) *
          Real.exp ((1 / 8 : ℝ) * W) := hmul
      _ =
        Real.exp (-(bgpParams38.cα * E) + (1 / 8 : ℝ) * W) := by
          rw [← Real.exp_add]
      _ ≤ 1 := by
          simpa using
            (Real.exp_le_exp.mpr harg :
              Real.exp (-(bgpParams38.cα * E) + (1 / 8 : ℝ) * W) ≤
                Real.exp 0)
  have h :=
    (div_le_iff₀ (paper3HoffRate_pos j)).mp hratio
  simpa [E, one_mul] using h

theorem
    paper3Headline_exp_activeEarly_le_exp_pi_div_fortyEight_mul_hoffRate
    (j : ℕ) {τ : ℝ}
    (hτ : τ ∈ Set.Icc (selectorMUEarlyWriteSubStart (j + 1))
      (selectorMUWriteHoldTime (j + 1))) :
    Real.exp (bgpParams38.cα *
        (τ - 2 * selectorMUEarlyWriteSubStart (j + 1))) ≤
      Real.exp (Real.pi / 48) * paper3HoffRate j := by
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  have hratio :
      Real.exp (bgpParams38.cα * (τ - 2 * E)) / paper3HoffRate j ≤
        Real.exp (Real.pi / 48) := by
    have hinv := paper3HoffRate_inv_le_exp_writeStart j
    have hmul :
        Real.exp (bgpParams38.cα * (τ - 2 * E)) *
            (paper3HoffRate j)⁻¹ ≤
          Real.exp (bgpParams38.cα * (τ - 2 * E)) *
            Real.exp ((1 / 8 : ℝ) * W) := by
      exact mul_le_mul_of_nonneg_left (by simpa [W] using hinv)
        (Real.exp_pos _).le
    have harg :
        bgpParams38.cα * (τ - 2 * E) + (1 / 8 : ℝ) * W ≤
          Real.pi / 48 := by
      have hτH : τ ≤ Htime := by
        simpa [Htime] using hτ.2
      have hn : 0 ≤ ((j + 1 : ℕ) : ℝ) := by
        exact_mod_cast (Nat.zero_le (j + 1) : 0 ≤ j + 1)
      dsimp [E, Htime, W, selectorMUEarlyWriteSubStart,
        selectorMUWriteHoldTime, selectorMUWriteStartTime] at hτH ⊢
      norm_num [bgpParams38] at *
      nlinarith [hτH, hn, Real.pi_pos]
    calc
      Real.exp (bgpParams38.cα * (τ - 2 * E)) / paper3HoffRate j
          =
        Real.exp (bgpParams38.cα * (τ - 2 * E)) *
          (paper3HoffRate j)⁻¹ := by
          rw [div_eq_mul_inv]
      _ ≤
        Real.exp (bgpParams38.cα * (τ - 2 * E)) *
          Real.exp ((1 / 8 : ℝ) * W) := hmul
      _ =
        Real.exp (bgpParams38.cα * (τ - 2 * E) +
          (1 / 8 : ℝ) * W) := by
          rw [← Real.exp_add]
      _ ≤ Real.exp (Real.pi / 48) :=
          Real.exp_le_exp.mpr harg
  have h :=
    (div_le_iff₀ (paper3HoffRate_pos j)).mp hratio
  simpa [E] using h

theorem
    paper3Headline_exp_activeEarly_sub_settled_writeStart_le_one
    (j : ℕ) {τ : ℝ}
    (hτ : τ ∈ Set.Icc (selectorMUEarlyWriteSubStart (j + 1))
      (selectorMUWriteHoldTime (j + 1))) :
    Real.exp (bgpParams38.cα *
        (τ - 2 * selectorMUEarlyWriteSubStart (j + 1)) -
          selectorUSettledRate * selectorMUWriteStartTime (j + 1)) ≤
      1 := by
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  have hτH : τ ≤ Htime := by
    simpa [Htime] using hτ.2
  have hn : 0 ≤ ((j + 1 : ℕ) : ℝ) := by
    exact_mod_cast (Nat.zero_le (j + 1) : 0 ≤ j + 1)
  have hτ_bound : τ ≤ 2 * E + W := by
    have hH_le : Htime ≤ 2 * E + W := by
      dsimp [E, Htime, W, selectorMUEarlyWriteSubStart,
        selectorMUWriteHoldTime, selectorMUWriteStartTime]
      nlinarith [hn, Real.pi_pos]
    exact le_trans hτH hH_le
  have harg :
      bgpParams38.cα * (τ - 2 * E) - selectorUSettledRate * W ≤ 0 := by
    have hsub : τ - 2 * E ≤ W := by
      linarith [hτ_bound]
    have hcα : 0 ≤ bgpParams38.cα := by
      norm_num [bgpParams38]
    have hW_nonneg : 0 ≤ W := selectorMUWriteStartTime_nonneg (j + 1)
    have hrate_le : bgpParams38.cα * W ≤ selectorUSettledRate * W :=
      mul_le_mul_of_nonneg_right paper3Headline_cAlpha_le_selectorUSettledRate hW_nonneg
    have hmul := mul_le_mul_of_nonneg_left hsub hcα
    nlinarith
  simpa [E, W] using
    (Real.exp_le_exp.mpr harg :
      Real.exp (bgpParams38.cα * (τ - 2 * E) -
        selectorUSettledRate * W) ≤ Real.exp 0)

theorem
    paper3Headline_exp_activeEarly_sub_settled_writeStart_le_hoffRate
    (j : ℕ) {τ : ℝ}
    (hτ : τ ∈ Set.Icc (selectorMUEarlyWriteSubStart (j + 1))
      (selectorMUWriteHoldTime (j + 1))) :
    Real.exp (bgpParams38.cα *
        (τ - 2 * selectorMUEarlyWriteSubStart (j + 1)) -
          selectorUSettledRate * selectorMUWriteStartTime (j + 1)) ≤
      paper3HoffRate j := by
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let E : ℝ := selectorMUEarlyWriteSubStart (j + 1)
  let Htime : ℝ := selectorMUWriteHoldTime (j + 1)
  have hratio :
      Real.exp (bgpParams38.cα * (τ - 2 * E) -
          selectorUSettledRate * W) / paper3HoffRate j ≤ 1 := by
    have hinv := paper3HoffRate_inv_le_exp_writeStart j
    have hmul :
        Real.exp (bgpParams38.cα * (τ - 2 * E) -
            selectorUSettledRate * W) * (paper3HoffRate j)⁻¹ ≤
          Real.exp (bgpParams38.cα * (τ - 2 * E) -
              selectorUSettledRate * W) *
            Real.exp ((1 / 8 : ℝ) * W) := by
      exact mul_le_mul_of_nonneg_left (by simpa [W] using hinv)
        (Real.exp_pos _).le
    have harg :
        bgpParams38.cα * (τ - 2 * E) -
            selectorUSettledRate * W + (1 / 8 : ℝ) * W ≤ 0 := by
      have hτH : τ ≤ Htime := by
        simpa [Htime] using hτ.2
      have hn : 0 ≤ ((j + 1 : ℕ) : ℝ) := by
        exact_mod_cast (Nat.zero_le (j + 1) : 0 ≤ j + 1)
      dsimp [E, Htime, W, selectorMUEarlyWriteSubStart,
        selectorMUWriteHoldTime, selectorMUWriteStartTime] at hτH ⊢
      norm_num [selectorUSettledRate, bgpParams38] at *
      nlinarith [hτH, hn, Real.pi_pos]
    calc
      Real.exp (bgpParams38.cα * (τ - 2 * E) -
          selectorUSettledRate * W) / paper3HoffRate j
          =
        Real.exp (bgpParams38.cα * (τ - 2 * E) -
          selectorUSettledRate * W) * (paper3HoffRate j)⁻¹ := by
          rw [div_eq_mul_inv]
      _ ≤
        Real.exp (bgpParams38.cα * (τ - 2 * E) -
            selectorUSettledRate * W) *
          Real.exp ((1 / 8 : ℝ) * W) := hmul
      _ =
        Real.exp (bgpParams38.cα * (τ - 2 * E) -
            selectorUSettledRate * W + (1 / 8 : ℝ) * W) := by
          rw [← Real.exp_add]
      _ ≤ 1 := by
          simpa using
            (Real.exp_le_exp.mpr harg :
              Real.exp (bgpParams38.cα * (τ - 2 * E) -
                  selectorUSettledRate * W + (1 / 8 : ℝ) * W) ≤
                Real.exp 0)
  have h :=
    (div_le_iff₀ (paper3HoffRate_pos j)).mp hratio
  simpa [E, W, one_mul] using h

/-- Concrete positivity of the prewrite Duhamel coefficient for the natural
half-mass safe floor. -/
theorem paper3Headline_gap_mul_half_pos :
    0 <
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos *
        (1 / 2 : ℝ) := by
  have hgap :
      0 < selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos :=
    selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
      paper3HeadlineHerr
  positivity

/-- The prewrite prefix is still in the first small positive sine arc, so the
z-pulse is not offphase but its sine is at most one half. -/
theorem paper3HeadlinePrewrite_sin_le_half
    (j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1))) :
    Real.sin t ≤ (1 : ℝ) / 2 := by
  obtain ⟨hl, hr⟩ := ht
  have hpi := Real.pi_pos
  set s := t - 2 * Real.pi * ((j : ℝ) + 1) with hs
  have hsin : Real.sin t = Real.sin s := by
    have ht_eq : t = s + (j + 1 : ℕ) * (2 * Real.pi) := by
      rw [hs]
      push_cast
      ring_nf
    rw [ht_eq, Real.sin_add_nat_mul_two_pi]
  rw [hsin]
  have hs0 : 0 ≤ s := by
    rw [hs]
    unfold selectorMUZOffEnd at hl
    linarith
  have hs1 : s ≤ Real.pi / 6 := by
    rw [hs]
    unfold selectorMUWriteStartTime at hr
    push_cast at hr
    linarith
  have hmem_s : s ∈ Set.Icc (-(Real.pi / 2)) (Real.pi / 2) := by
    constructor <;> linarith
  have hmem_end : Real.pi / 6 ∈ Set.Icc (-(Real.pi / 2)) (Real.pi / 2) := by
    constructor <;> linarith
  have hmono := Real.strictMonoOn_sin.monotoneOn hmem_s hmem_end hs1
  rwa [Real.sin_pi_div_six] at hmono

/-- On the prewrite prefix, the z-gate pulse is bounded below by one quarter. -/
theorem paper3HeadlinePrewrite_rPulse_ge_quarter
    (j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUZOffEnd j)
        (selectorMUWriteStartTime (j + 1))) :
    (1 / 4 : ℝ) ≤ rPulse bgpParams38.L t := by
  have hsin := paper3HeadlinePrewrite_sin_le_half j ht
  have hbase : (1 / 4 : ℝ) ≤ (1 - Real.sin t) / 2 := by
    linarith
  simpa [rPulse, bgpParams38] using hbase

/-- On the left Hoff edge, the sine phase remains in the nonnegative
half-period. -/
theorem paper3HeadlineLeft_sin_nonneg
    (j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUInterReadStart j)
        (selectorMUZOffStart j)) :
    0 ≤ Real.sin t := by
  have hstart : (2 : ℝ) * Real.pi * (j : ℝ) ≤ t := by
    have hread :
        (2 : ℝ) * Real.pi * (j : ℝ) ≤ selectorMUInterReadStart j := by
      unfold selectorMUInterReadStart selectorMUWriteReadTime
      linarith [Real.pi_pos]
    exact le_trans hread ht.1
  have hend : t ≤ (2 : ℝ) * Real.pi * (j : ℝ) + Real.pi := by
    simpa [selectorMUZOffStart] using ht.2
  exact sin_window_nonneg j hstart hend

/-- On the left Hoff edge, the sine phase has already passed the half-height
point, so it is at most one half. -/
theorem paper3HeadlineLeft_sin_le_half
    (j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUInterReadStart j)
        (selectorMUZOffStart j)) :
    Real.sin t ≤ (1 : ℝ) / 2 := by
  obtain ⟨hl, hr⟩ := ht
  set s := t - 2 * Real.pi * (j : ℝ) with hs
  have hsin_t : Real.sin t = Real.sin s := by
    have ht_eq : t = s + (j : ℕ) * (2 * Real.pi) := by
      rw [hs]
      ring
    rw [ht_eq, Real.sin_add_nat_mul_two_pi]
  rw [hsin_t]
  have hs_lo : (5 : ℝ) * Real.pi / 6 ≤ s := by
    rw [hs]
    unfold selectorMUInterReadStart selectorMUWriteReadTime at hl
    linarith
  have hs_hi : s ≤ Real.pi := by
    rw [hs]
    unfold selectorMUZOffStart at hr
    linarith
  let y : ℝ := Real.pi - s
  have hy_nonneg : 0 ≤ y := by
    dsimp [y]
    linarith
  have hy_le : y ≤ Real.pi / 6 := by
    dsimp [y]
    linarith
  have hsin_y : Real.sin s = Real.sin y := by
    have hs_eq : s = Real.pi - y := by
      dsimp [y]
      ring
    rw [hs_eq, Real.sin_pi_sub]
  rw [hsin_y]
  have hmem_y : y ∈ Set.Icc (-(Real.pi / 2)) (Real.pi / 2) := by
    constructor <;> linarith [Real.pi_pos, hy_nonneg, hy_le]
