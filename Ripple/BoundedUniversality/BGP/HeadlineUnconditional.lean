/-- Prewrite reset-source convolution bound for the headline parameters.

This is the scalar source condition needed by the old/new bad-mass Duhamel
route on `[ZOffEnd j, WriteStart (j+1)]`; it uses the concrete prewrite
reset/gain ratio rather than a pure gate estimate. -/
theorem paper3HeadlinePrewriteSourceDecay
    (wg w j : ℕ) :
    let sol := paper3HeadlineSolFam wg
    let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
    let a : ℝ := selectorMUZOffEnd j
    let b : ℝ := selectorMUWriteStartTime (j + 1)
    ∀ t ∈ Icc a b,
      (∫ s in a..t,
        Real.exp (gap * ((sol w).G s - (sol w).G a)) *
          (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ))) *
        Real.exp (-(gap * ((sol w).G t - (sol w).G a))) ≤
          Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) / gap := by
  classical
  dsimp
  intro t ht
  let gap : ℝ := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos
  have hgap_pos : 0 < gap := by
    simpa [gap] using
      selectorReplicatorGapVal_pos paper3HeadlineEta paper3HeadlineEta_pos
        paper3HeadlineHerr
  have ha_nonneg : 0 ≤ selectorMUZOffEnd j := by
    unfold selectorMUZOffEnd
    positivity
  have hreset :
      ∀ s ∈ Icc (selectorMUZOffEnd j) t,
        (((1 + Real.cos s) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ)) * (1 : ℝ) ≤
          Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)) *
            (((1 + Real.sin s) / 2) ^ paper3HeadlineM *
              (((paper3WarmGainQ wg : ℚ) : ℝ) *
                Real.exp (bgpParams38.cα * s))) := by
    intro s hs
    have hs_pre :
        s ∈ Icc (selectorMUZOffEnd j)
            (selectorMUWriteStartTime (j + 1)) :=
      ⟨hs.1, le_trans hs.2 ht.2⟩
    simpa [one_mul] using
      paper3HeadlinePrewriteResetRatio wg 0 j s hs_pre
  have hsrc :=
    selectorMU_old_new_source_decay_le_of_reset_ratio
      (paper3HeadlineSolFam wg) w
      (a := selectorMUZOffEnd j)
      (t := t)
      (gapEff := gap)
      (Creset := (1 : ℝ))
      (Csrc := Real.exp (-(bgpParams38.cα * selectorMUZOffEnd j)))
      ht.1
      hgap_pos
      (Real.exp_pos _).le
      (by norm_num [paper3HeadlineKappa])
      (by norm_num)
      ha_nonneg
      hreset
  simpa [gap, one_mul, mul_assoc] using hsrc

