    (HP : MvPolynomial (Fin d_U) ℚ) (Kq : ℚ) (R : ℕ)
    (x₀ : ℕ → Fin d_U → ℚ) (w : ℕ)
    (hfin :
      Ripple.FiniteHorizonBound (selectorMUReplicatorFieldN eta heta M κ₀ g₀ HP Kq R)
        (selectorMUReplicatorInit x₀ w g₀)) :
    ∃ sol : SelectorReplicatorDynSol d_U B_U UniversalLocalView bgpParamsN selectorSchedule
        branchU
        (fun t => ((1 + Real.cos t) / 2) ^ M)
        (fun t => ((1 + Real.sin t) / 2) ^ M)
        (fun _ => (κ₀ : ℝ))
        (fun t => (g₀ : ℝ) * Real.exp (bgpParamsN.cα * t))
        (universalPval eta heta),
      sol.z 0 = sol.init_z ∧ sol.u 0 = sol.init_u ∧
        (∀ i : Fin d_U,
          sol.z 0 i =
            ((x₀ w i : ℚ) : ℝ)) ∧
        (∀ i,
          sol.u 0 i =
            ((selectorReplicatorEuclInitQ d_U UniversalLocalView x₀ w g₀
              (selU UniversalLocalView i) : ℚ) : ℝ)) ∧
        (∀ v : UniversalLocalView,
          sol.lam v 0 =
            ((1 / (Fintype.card UniversalLocalView : ℚ)) : ℝ)) ∧
        sol.G 0 = 0 ∧
        sol.ZUFiniteCoordBound :=
  selector_replicator_sol_exists_MU_NS bgpScale eta heta M κ₀ g₀ HP Kq R x₀ w hfin

/-- N-parametric per-input warm-gain solution family type (the `bgpParamsN`
sibling of `MUReplicatorSolFamily`). -/
abbrev MUReplicatorSolFamilyN (eta : ℚ) (heta : 0 < eta) (M : ℕ)
    (κ₀ g₀ : ℚ) :=
  ℕ → SelectorReplicatorDynSol d_U B_U UniversalLocalView bgpParamsN selectorSchedule
    branchU
    (fun t => ((1 + Real.cos t) / 2) ^ M)
    (fun t => ((1 + Real.sin t) / 2) ^ M)
    (fun _ => (κ₀ : ℝ))
