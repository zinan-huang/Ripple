/-- N-parametric explicit lower bound for the u-active mass on the inter-read
u-active subwindow `[7π/6, 11π/6]` (per cycle), with the scaled exponents
`300·bgpScale` and `1000·bgpScale`. -/
noncomputable def selectorInterReadUActiveMassLowerN (j : ℕ) : ℝ :=
  Real.exp (300 * (bgpScale : ℝ) * selectorMUUActiveStart j) *
    Real.exp (-(1000 * (bgpScale : ℝ) * selectorMUUActiveEnd j * (1 / 4 : ℝ))) *
      ((2 : ℝ) * Real.pi / 3)

theorem selectorInterReadUActiveMassLowerN_nonneg (j : ℕ) :
    0 ≤ selectorInterReadUActiveMassLowerN j := by
  dsimp [selectorInterReadUActiveMassLowerN]
  positivity

set_option maxHeartbeats 800000 in
/-- N-parametric lower bound of the actual u-gate mass on the u-active
inter-read subwindow. -/
theorem selectorInterReadUActiveMassLowerN_le_integral
    {eta : ℚ} {heta : 0 < eta} {Mcy : ℕ} {κ₀ g₀ : ℚ}
    (sol : SelectorReplicatorDynSol d_U B_U UniversalLocalView bgpParamsN selectorSchedule
      branchU
      (fun t => ((1 + Real.cos t) / 2) ^ Mcy)
      (fun t => ((1 + Real.sin t) / 2) ^ Mcy)
      (fun _ => (κ₀ : ℝ))
      (fun t => (g₀ : ℝ) * Real.exp (bgpParamsN.cα * t))
      (universalPval eta heta))
    (j : ℕ) :
    selectorInterReadUActiveMassLowerN j ≤
      ∫ s in (selectorMUUActiveStart j)..(selectorMUUActiveEnd j),
        bgpParamsN.A * sol.α s * bGateU bgpParamsN.L (sol.μ s) s := by
  let a : ℝ := selectorMUUActiveStart j
  let b : ℝ := selectorMUUActiveEnd j
  let c : ℝ := Real.exp (300 * (bgpScale : ℝ) * a) *
    Real.exp (-(1000 * (bgpScale : ℝ) * b * (1 / 4 : ℝ)))
  have hab : a ≤ b := by
    dsimp [a, b, selectorMUUActiveStart, selectorMUUActiveEnd]
    linarith [Real.pi_pos]
  have ha0 : 0 ≤ a := by
    dsimp [a, selectorMUUActiveStart]
    positivity
  have hg_cont : Continuous fun s : ℝ =>
      bgpParamsN.A * sol.α s * bGateU bgpParamsN.L (sol.μ s) s := by
    have hq : Continuous fun s : ℝ => qPulse bgpParamsN.L s := by
      simp only [qPulse]
      exact ((continuous_const.add Real.continuous_sin).div_const 2).pow
        bgpParamsN.L
    have hgateU : Continuous fun s : ℝ =>
        bGateU bgpParamsN.L (sol.μ s) s := by
      simp only [bGateU]
      exact Real.continuous_exp.comp (((sol.cont_μ).mul hq).neg)
    simpa [mul_assoc] using
      ((continuous_const.mul sol.cont_α).mul hgateU)
  have hpoint : ∀ s ∈ Icc a b, c ≤
      bgpParamsN.A * sol.α s * bGateU bgpParamsN.L (sol.μ s) s := by
    intro s hs
    have hs0 : 0 ≤ s := le_trans ha0 hs.1
    have hαs : sol.α s = Real.exp (bgpParamsN.cα * s) :=
      sol.alpha_eq_exp selectorSchedule_domain_of_nonneg_structural hs0
    have hμs : sol.μ s = bgpParamsN.cμ * s := by
      rw [sol.mu_eq_linear selectorSchedule_domain_of_nonneg_structural hs0,
        sol.μ_at_zero, zero_add]
    have hsin : Real.sin s ≤ -(1 / 2 : ℝ) := by
      apply sin_window_le_neg_half j
      · simpa [a, selectorMUUActiveStart] using hs.1
      · simpa [b, selectorMUUActiveEnd] using hs.2
    have hαle : Real.exp (300 * (bgpScale : ℝ) * a) ≤
        Real.exp (300 * (bgpScale : ℝ) * s) := by
      exact Real.exp_le_exp.mpr
        (mul_le_mul_of_nonneg_left hs.1 (by positivity))
    have hgate_active :
        Real.exp (-(sol.μ s * (1 / 4 : ℝ) ^ bgpParamsN.L)) ≤
          bGateU bgpParamsN.L (sol.μ s) s :=
      bGateU_ge_active bgpParamsN.L
        (by rw [hμs]; exact mul_nonneg bgpParamsN_cμ_pos.le hs0)
        hsin
    have hgate_floor :
        Real.exp (-(1000 * (bgpScale : ℝ) * b * (1 / 4 : ℝ))) ≤
          bGateU bgpParamsN.L (sol.μ s) s := by
      have hfloor :
          Real.exp (-(1000 * (bgpScale : ℝ) * b * (1 / 4 : ℝ))) ≤
            Real.exp (-(sol.μ s * (1 / 4 : ℝ) ^ bgpParamsN.L)) := by
        apply Real.exp_le_exp.mpr
        rw [hμs, bgpParamsN_cμ_def]
        have hL : bgpParamsN.L = 1 := rfl
        rw [hL, pow_one]
        have h1000s : (0 : ℝ) ≤ 1000 * (bgpScale : ℝ) := by positivity
        nlinarith [mul_le_mul_of_nonneg_left hs.2 h1000s]
      exact le_trans hfloor hgate_active
    have hmul := mul_le_mul hαle hgate_floor (Real.exp_pos _).le (Real.exp_pos _).le
    calc
      c ≤ Real.exp (300 * (bgpScale : ℝ) * s) *
          bGateU bgpParamsN.L (sol.μ s) s := by
        simpa [c] using hmul
      _ = bgpParamsN.A * sol.α s * bGateU bgpParamsN.L (sol.μ s) s := by
        rw [hαs]
        simp only [bgpParamsN_A_eq, bgpParamsN_cα_def]
        ring
  have hmono :
      (∫ _s in a..b, c) ≤
        ∫ s in a..b,
          bgpParamsN.A * sol.α s * bGateU bgpParamsN.L (sol.μ s) s :=
    intervalIntegral.integral_mono_on hab _root_.intervalIntegrable_const
      (hg_cont.intervalIntegrable a b) hpoint
  have hconst :
      (∫ _s in a..b, c) = c * (b - a) := by
    rw [intervalIntegral.integral_const, smul_eq_mul]
    ring
  have hmass :
      selectorInterReadUActiveMassLowerN j = c * (b - a) := by
    dsimp [selectorInterReadUActiveMassLowerN, selectorMUUActiveStart,
      selectorMUUActiveEnd, a, b, c]
    ring
  calc
    selectorInterReadUActiveMassLowerN j = c * (b - a) := hmass
    _ = ∫ _s in a..b, c := hconst.symm
    _ ≤ ∫ s in a..b,
          bgpParamsN.A * sol.α s * bGateU bgpParamsN.L (sol.μ s) s := hmono

set_option maxHeartbeats 800000 in
/-- N-parametric inter-read kernel domination: if `τ` is before the u-active
subwindow, the future u-kernel to the next write start includes the whole
N-scaled u-active mass. -/
theorem selectorInterRead_kernel_le_uActiveMass_N
    {eta : ℚ} {heta : 0 < eta} {Mcy : ℕ} {κ₀ g₀ : ℚ}
    (sol : SelectorReplicatorDynSol d_U B_U UniversalLocalView bgpParamsN selectorSchedule
      branchU
      (fun t => ((1 + Real.cos t) / 2) ^ Mcy)
      (fun t => ((1 + Real.sin t) / 2) ^ Mcy)
      (fun _ => (κ₀ : ℝ))
      (fun t => (g₀ : ℝ) * Real.exp (bgpParamsN.cα * t))
      (universalPval eta heta))
    (j : ℕ) {τ : ℝ}
    (hτ : τ ∈ Icc (selectorMUWriteReadTime j) (selectorMUUActiveStart j)) :
    Real.exp (-(∫ s in τ..(selectorMUWriteStartTime (j + 1)),
      bgpParamsN.A * sol.α s * bGateU bgpParamsN.L (sol.μ s) s)) ≤
    Real.exp (-(selectorInterReadUActiveMassLowerN j)) := by
  let U0 : ℝ := selectorMUUActiveStart j
  let U1 : ℝ := selectorMUUActiveEnd j
  let W : ℝ := selectorMUWriteStartTime (j + 1)
  let kU : ℝ → ℝ := fun s =>
    bgpParamsN.A * sol.α s * bGateU bgpParamsN.L (sol.μ s) s
  have hτU0 : τ ≤ U0 := by simpa [U0] using hτ.2
  have hU0U1 : U0 ≤ U1 := by
    dsimp [U0, U1, selectorMUUActiveStart, selectorMUUActiveEnd]
    linarith [Real.pi_pos]
  have hU1W : U1 ≤ W := by
    dsimp [U1, W, selectorMUUActiveEnd, selectorMUWriteStartTime]
    push_cast
    linarith [Real.pi_pos]
  have hread0 : 0 ≤ selectorMUWriteReadTime j := by
    unfold selectorMUWriteReadTime
    positivity
  have hτ0 : 0 ≤ τ := le_trans hread0 hτ.1
  have hk_cont : Continuous kU := by
    have hq : Continuous fun s : ℝ => qPulse bgpParamsN.L s := by
      simp only [qPulse]
      exact ((continuous_const.add Real.continuous_sin).div_const 2).pow
        bgpParamsN.L
    have hgateU : Continuous fun s : ℝ =>
        bGateU bgpParamsN.L (sol.μ s) s := by
      simp only [bGateU]
      exact Real.continuous_exp.comp (((sol.cont_μ).mul hq).neg)
    simpa [kU, mul_assoc] using
      ((continuous_const.mul sol.cont_α).mul hgateU)
  have hk_nonneg : ∀ s : ℝ, 0 ≤ s → 0 ≤ kU s := by
    intro s hs0
    have hαs : sol.α s = Real.exp (bgpParamsN.cα * s) :=
      sol.alpha_eq_exp selectorSchedule_domain_of_nonneg_structural hs0
    dsimp [kU]
    rw [hαs]
    exact mul_nonneg
      (mul_nonneg (by rw [bgpParamsN_A_eq]; norm_num) (Real.exp_pos _).le)
      (bGateU_pos bgpParamsN.L (sol.μ s) s).le
  have hI_left_nonneg : 0 ≤ ∫ s in τ..U0, kU s := by
    apply intervalIntegral.integral_nonneg hτU0
    intro s hs
    exact hk_nonneg s (le_trans hτ0 hs.1)
  have hI_right_nonneg : 0 ≤ ∫ s in U1..W, kU s := by
    apply intervalIntegral.integral_nonneg hU1W
    intro s hs
    have hU10 : 0 ≤ U1 := by
      dsimp [U1, selectorMUUActiveEnd]
      positivity
    exact hk_nonneg s (le_trans hU10 hs.1)
  have hmass_mid :
      selectorInterReadUActiveMassLowerN j ≤ ∫ s in U0..U1, kU s := by
    simpa [U0, U1, kU] using
      selectorInterReadUActiveMassLowerN_le_integral sol j
  have hI : selectorInterReadUActiveMassLowerN j ≤ ∫ s in τ..W, kU s := by
    have hII : ∀ x y : ℝ, IntervalIntegrable kU MeasureTheory.volume x y :=
      fun x y => hk_cont.intervalIntegrable x y
    have hadd1 :
        (∫ s in τ..U0, kU s) + (∫ s in U0..U1, kU s)
          = ∫ s in τ..U1, kU s :=
      intervalIntegral.integral_add_adjacent_intervals (hII τ U0) (hII U0 U1)
    have hadd2 :
        (∫ s in τ..U1, kU s) + (∫ s in U1..W, kU s)
          = ∫ s in τ..W, kU s :=
      intervalIntegral.integral_add_adjacent_intervals (hII τ U1) (hII U1 W)
    calc
      selectorInterReadUActiveMassLowerN j
          ≤ ∫ s in U0..U1, kU s := hmass_mid
      _ ≤ (∫ s in τ..U0, kU s) + (∫ s in U0..U1, kU s) := by
        linarith
      _ = ∫ s in τ..U1, kU s := hadd1
      _ ≤ (∫ s in τ..U1, kU s) + (∫ s in U1..W, kU s) := by
        linarith
      _ = ∫ s in τ..W, kU s := hadd2
  exact Real.exp_le_exp.mpr (by linarith)

/-- The N-scaled u-active mass dominates the same linear function of the
cycle index as the fixed mass: for `j ≥ 5` the closed-form exponent
`100π·j − 325π/3` is positive, so scaling it by `bgpScale ≥ 1` only helps;
for `j ≤ 4` the bound is trivial from nonnegativity. -/
theorem selectorInterReadUActiveMassLowerN_ge_linear (j : ℕ) :
    2 * (j : ℝ) - 8 ≤ selectorInterReadUActiveMassLowerN j := by
  have hK0 := selectorInterReadUActiveMassLowerN_nonneg j
  by_cases hj : (j : ℝ) ≤ 4
  · linarith
  · push_neg at hj
    have hrw38 : selectorInterReadUActiveMassLower j =
        (2 * Real.pi / 3) *
          Real.exp (100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3) := by
      unfold selectorInterReadUActiveMassLower selectorMUUActiveStart
        selectorMUUActiveEnd
      rw [← Real.exp_add]
      ring_nf
    have hrwN : selectorInterReadUActiveMassLowerN j =
        (2 * Real.pi / 3) *
          Real.exp ((bgpScale : ℝ) *
            (100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3)) := by
      unfold selectorInterReadUActiveMassLowerN selectorMUUActiveStart
        selectorMUUActiveEnd
      rw [← Real.exp_add]
      ring_nf
    have hlin : (0 : ℝ) ≤ 100 * (j : ℝ) - 325 / 3 := by linarith
    have hE0 : 0 ≤ 100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3 := by
      nlinarith [mul_nonneg Real.pi_pos.le hlin]
    have hsE : 100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3 ≤
        (bgpScale : ℝ) * (100 * Real.pi * (j : ℝ) - 325 * Real.pi / 3) := by
      nlinarith [bgpScaleR_ge_one, hE0]
    have hdom : selectorInterReadUActiveMassLower j ≤
        selectorInterReadUActiveMassLowerN j := by
      rw [hrw38, hrwN]
      exact mul_le_mul_of_nonneg_left (Real.exp_le_exp.mpr hsE)
        (by positivity)
    have h38 := selectorInterReadUActiveMassLower_ge_linear j
    linarith

/-- Geometric contraction of the N-scaled inter-read u-kernel (rate `2`,
uniform prefactor `e⁸`). -/
theorem exp_neg_selectorInterReadUActiveMassLowerN_le_geometric (j : ℕ) :
    Real.exp (-(selectorInterReadUActiveMassLowerN j)) ≤
      Real.exp (8 : ℝ) * Real.exp (-(2 : ℝ) * (j : ℝ)) := by
  rw [← Real.exp_add]
  apply Real.exp_le_exp.mpr
  have h := selectorInterReadUActiveMassLowerN_ge_linear j
  linarith

/-- N-parametric offphase z-gate envelope: on `sin ≤ 0` subwindows the
z-integrand decays at the scaled leak rate `200·bgpScale` (the
`bgpParamsN_chi_leak_eq` margin). -/
theorem gateZ_integrand_le_offphase_exp_N
    {eta : ℚ} {heta : 0 < eta} {Mcy : ℕ} {κ₀ g₀ : ℚ}
    (sol : SelectorReplicatorDynSol d_U B_U UniversalLocalView bgpParamsN selectorSchedule
      branchU
      (fun t => ((1 + Real.cos t) / 2) ^ Mcy)
      (fun t => ((1 + Real.sin t) / 2) ^ Mcy)
      (fun _ => (κ₀ : ℝ))
      (fun t => (g₀ : ℝ) * Real.exp (bgpParamsN.cα * t))
      (universalPval eta heta))
    {t : ℝ} (ht0 : 0 ≤ t) (hsin : Real.sin t ≤ 0) :
    bgpParamsN.A * sol.α t * bGateZ bgpParamsN.L (sol.μ t) t ≤
      Real.exp (-(200 * (bgpScale : ℝ) * t)) := by
  have hα : sol.α t = Real.exp (bgpParamsN.cα * t) :=
    sol.alpha_eq_exp selectorSchedule_domain_of_nonneg_structural ht0
  have hμ : sol.μ t = bgpParamsN.cμ * t := by
    rw [sol.mu_eq_linear selectorSchedule_domain_of_nonneg_structural ht0,
      sol.μ_at_zero, zero_add]
  have h :=
    gateZ_integrand_le_offphase_exp_repl
      (sol := sol) (A := (1 : ℝ)) (cμ := bgpParamsN.cμ)
      (cα := bgpParamsN.cα)
      ht0 (by norm_num) bgpParamsN_cμ_pos.le
      bgpParamsN_A_eq
      hα hμ hsin
  calc
    bgpParamsN.A * sol.α t * bGateZ bgpParamsN.L (sol.μ t) t
        ≤ (1 : ℝ) *
            Real.exp (-((bgpParamsN.cμ * (1 / 2 : ℝ) ^ bgpParamsN.L -
              bgpParamsN.cα) * t)) := h
    _ = Real.exp (-(200 * (bgpScale : ℝ) * t)) := by
      rw [one_mul, bgpParamsN_chi_leak_eq]

