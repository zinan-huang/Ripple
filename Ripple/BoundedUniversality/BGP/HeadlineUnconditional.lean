lemma paper3_sum_univ_filter_not_mem_add_sum
    {V : Type} [Fintype V] [DecidableEq V]
    (safe : Finset V) (f : V → ℝ) :
    (∑ v : V, f v) =
      (Finset.univ.filter (fun v : V => v ∉ safe)).sum f + safe.sum f := by
  classical
  let bad : Finset V := Finset.univ.filter (fun v : V => v ∉ safe)
  have hdisj : Disjoint bad safe := by
    rw [Finset.disjoint_left]
    intro v hv hsafe
    have hvnot : v ∉ safe := by
      simpa [bad] using hv
    exact hvnot hsafe
  have hcover : bad ∪ safe = (Finset.univ : Finset V) := by
    ext v
    by_cases hv : v ∈ safe
    · simp [bad, hv]
    · simp [bad, hv]
  calc
    (∑ v : V, f v) = (bad ∪ safe).sum f := by rw [hcover]
    _ = bad.sum f + safe.sum f := by rw [Finset.sum_union hdisj]

/-- Finite-set algebra bridge for the prewrite Duhamel floor: a bound on the
old/new bad mass yields the corresponding mass floor on the two safe views. -/
theorem paper3HeadlinePrewriteSafeMass_floor_of_badMass_le
    (wg w j : ℕ) {Lsafe : ℝ}
    (hbad :
      ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
        (Finset.univ.filter (fun v : UniversalLocalView =>
          v ≠ localViewU (solMUReplStaticCfg w j) ∧
            v ≠ localViewU (solMUReplStaticCfg w (j + 1)))).sum
            (fun v => ((paper3HeadlineSolFam wg) w).lam v t) ≤ 1 - Lsafe) :
    ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      Lsafe ≤
        (insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView)).sum
          (fun u => ((paper3HeadlineSolFam wg) w).lam u t) := by
  classical
  intro t ht
  let safe : Finset UniversalLocalView :=
    insert (localViewU (solMUReplStaticCfg w j))
      ({localViewU (solMUReplStaticCfg w (j + 1))} :
        Finset UniversalLocalView)
  let bad : Finset UniversalLocalView :=
    Finset.univ.filter (fun v : UniversalLocalView => v ∉ safe)
  let f : UniversalLocalView → ℝ := fun v => ((paper3HeadlineSolFam wg) w).lam v t
  have ha_nonneg : 0 ≤ selectorMUZOffEnd j := by
    unfold selectorMUZOffEnd
    positivity
  have ht_nonneg : 0 ≤ t := le_trans ha_nonneg ht.1
  have hsum : (∑ v : UniversalLocalView, f v) = 1 := by
    simpa [f] using paper3Headline_lam_sum_forward wg w t ht_nonneg
  have hpartition :
      (∑ v : UniversalLocalView, f v) = bad.sum f + safe.sum f := by
    simpa [bad, f] using
      paper3_sum_univ_filter_not_mem_add_sum
        (V := UniversalLocalView) safe f
  have hbad_t :
      bad.sum f ≤ 1 - Lsafe := by
    simpa [bad, safe, f, not_or] using hbad t ht
  have htotal : bad.sum f + safe.sum f = 1 := by
    rw [← hpartition, hsum]
  linarith

/-- Pairwise payoff-gap bridge for the prewrite Duhamel hypothesis: once the
state is known to lie in both old and new `UTube`s, every bad view is worse than
each safe view by the concrete selector gap. -/
theorem paper3HeadlinePrewrite_pairwiseGap_of_old_new_tubes
    (wg w j : ℕ)
    (htubes :
      ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
        UTube r_LE_U (solMUReplStaticCfg w j)
          (((paper3HeadlineSolFam wg) w).u t) ∧
        UTube r_LE_U (solMUReplStaticCfg w (j + 1))
          (((paper3HeadlineSolFam wg) w).u t)) :
    ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      ∀ v : UniversalLocalView,
        v ∉ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
      ∀ u : UniversalLocalView,
        u ∈ insert (localViewU (solMUReplStaticCfg w j))
          ({localViewU (solMUReplStaticCfg w (j + 1))} :
            Finset UniversalLocalView) →
        universalPval paper3HeadlineEta paper3HeadlineEta_pos v
            (((paper3HeadlineSolFam wg) w).u t) -
          universalPval paper3HeadlineEta paper3HeadlineEta_pos u
            (((paper3HeadlineSolFam wg) w).u t) ≤
          -selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := by
  classical
  intro t ht v hv u hu
  have hUold := (htubes t ht).1
  have hUnew := (htubes t ht).2
  have hgap_le :
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos ≤
        selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := le_rfl
  have h :=
    universalPval_pairwise_gap_bad_to_old_new_of_tubes
      (eta := paper3HeadlineEta) (heta := paper3HeadlineEta_pos)
      (cold := solMUReplStaticCfg w j)
      (cnew := solMUReplStaticCfg w (j + 1))
      (Z := ((paper3HeadlineSolFam wg) w).u t)
      (gap := selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos)
      paper3HeadlineHerr hgap_le hUold hUnew v
      (by simpa using hv) u (by simpa using hu)
  simpa using h

