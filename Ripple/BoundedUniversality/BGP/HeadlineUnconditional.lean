/-- Pointwise left-edge Hoff-gate coefficient as a multiple of the replicator
common gain.  This is the left-edge counterpart of the recovery/post-select
weight ratios, with the weaker but valid `((1/2)^M)` active-gain floor. -/
theorem paper3HeadlineHoffGateCoeff_left_le_gain_ratio
    (wg w j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUInterReadStart j)
        (selectorMUZOffStart j)) :
    let rmin : ℝ := (1 / 4 : ℝ)
    let D : ℝ := ((1 / 2 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t ≤
      (Real.exp (-(rmin * selectorMUInterReadStart j)) / D) *
        (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t))) := by
  dsimp
  let sol := paper3HeadlineSolFam wg
  let rmin : ℝ := (1 / 4 : ℝ)
  let D : ℝ := ((1 / 2 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 1 / 2) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hrmin_nonneg : 0 ≤ rmin := by
    dsimp [rmin]
    norm_num
  have hleft_nonneg : 0 ≤ selectorMUInterReadStart j := by
    unfold selectorMUInterReadStart selectorMUWriteReadTime
    positivity
  have ht_nonneg : 0 ≤ t := le_trans hleft_nonneg ht.1
  have hα : (sol w).α t = Real.exp (bgpParams38.cα * t) :=
    (sol w).alpha_eq_exp selectorSchedule_domain_of_nonneg_structural ht_nonneg
  have hμlin : (sol w).μ t = (sol w).μ 0 + bgpParams38.cμ * t :=
    (sol w).mu_eq_linear selectorSchedule_domain_of_nonneg_structural ht_nonneg
  have hμ : (sol w).μ t = bgpParams38.cμ * t := by
    rw [hμlin, (sol w).μ_at_zero]
    simp [bgpParams38]
  have hr : rmin ≤ rPulse bgpParams38.L t := by
    simpa [rmin] using paper3HeadlineLeft_rPulse_ge_quarter j ht
  have htr : t * rmin ≤ (sol w).μ t * rPulse bgpParams38.L t := by
    rw [hμ]
    exact paper3Headline_t_mul_rmin_le_cmu_mul_rPulse ht_nonneg hr
  have hbGate :
      bGateZ bgpParams38.L ((sol w).μ t) t ≤ Real.exp (-(t * rmin)) := by
    unfold bGateZ
    exact Real.exp_le_exp.mpr (neg_le_neg htr)
  have hsin_base : (1 / 2 : ℝ) ≤ (1 + Real.sin t) / 2 :=
    paper3HeadlineLeft_qBase_ge_half j ht
  have hsin_pow :
      ((1 / 2 : ℝ) ^ paper3HeadlineM) ≤
        ((1 + Real.sin t) / 2) ^ paper3HeadlineM := by
    exact pow_le_pow_left₀ (by norm_num) hsin_base paper3HeadlineM
  have hD_le :
      D ≤ ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          ((paper3WarmGainQ wg : ℚ) : ℝ) := by
    dsimp [D]
    exact mul_le_mul_of_nonneg_right hsin_pow (paper3WarmGainQ_nonneg wg)
  have hDexp_le :
      D * Real.exp (bgpParams38.cα * t) ≤
        ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t)) := by
    calc
      D * Real.exp (bgpParams38.cα * t) ≤
          (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
            ((paper3WarmGainQ wg : ℚ) : ℝ)) *
              Real.exp (bgpParams38.cα * t) :=
            mul_le_mul_of_nonneg_right hD_le (Real.exp_pos _).le
      _ = ((1 + Real.sin t) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) *
            Real.exp (bgpParams38.cα * t)) := by ring
  have hdecay :
      Real.exp (-(t * rmin)) ≤
        Real.exp (-(rmin * selectorMUInterReadStart j)) := by
    refine Real.exp_le_exp.mpr ?_
    have hmul := mul_le_mul_of_nonneg_left ht.1 hrmin_nonneg
    nlinarith [hmul]
  have hcoeff_nonneg :
      0 ≤ Real.exp (-(rmin * selectorMUInterReadStart j)) / D :=
    div_nonneg (Real.exp_pos _).le hD_pos.le
  calc
    selectorMUHoffGateCoeff (paper3HeadlineSolFam wg) w t
        = Real.exp (bgpParams38.cα * t) *
            bGateZ bgpParams38.L ((sol w).μ t) t := by
          simp [selectorMUHoffGateCoeff, sol, hα, bgpParams38]
    _ ≤ Real.exp (bgpParams38.cα * t) * Real.exp (-(t * rmin)) := by
          exact mul_le_mul_of_nonneg_left hbGate (Real.exp_pos _).le
    _ ≤ Real.exp (bgpParams38.cα * t) *
          Real.exp (-(rmin * selectorMUInterReadStart j)) := by
          exact mul_le_mul_of_nonneg_left hdecay (Real.exp_pos _).le
    _ = (Real.exp (-(rmin * selectorMUInterReadStart j)) / D) *
          (D * Real.exp (bgpParams38.cα * t)) := by
          field_simp [hD_pos.ne']
    _ ≤ (Real.exp (-(rmin * selectorMUInterReadStart j)) / D) *
          (((1 + Real.sin t) / 2) ^ paper3HeadlineM *
            (((paper3WarmGainQ wg : ℚ) : ℝ) *
              Real.exp (bgpParams38.cα * t))) := by
          exact mul_le_mul_of_nonneg_left hDexp_le hcoeff_nonneg

/-- The left-edge Hoff/gain ratio is already below the canonical Hoff decay. -/
theorem paper3HeadlineLeftWeightRatio_le_hoffRate
    (wg j : ℕ) :
    let rmin : ℝ := (1 / 4 : ℝ)
    let D : ℝ := ((1 / 2 : ℝ) ^ paper3HeadlineM) *
      ((paper3WarmGainQ wg : ℚ) : ℝ)
    Real.exp (-(rmin * selectorMUInterReadStart j)) / D ≤
      (1 / D) * paper3HoffRate j := by
  dsimp
  let rmin : ℝ := (1 / 4 : ℝ)
  let D : ℝ := ((1 / 2 : ℝ) ^ paper3HeadlineM) *
    ((paper3WarmGainQ wg : ℚ) : ℝ)
  have hD_pos : 0 < D := by
    dsimp [D]
    exact mul_pos (pow_pos (by norm_num : (0 : ℝ) < 1 / 2) paper3HeadlineM)
      (paper3WarmGainQ_pos wg)
  have hleft_nonneg : 0 ≤ selectorMUInterReadStart j := by
    unfold selectorMUInterReadStart selectorMUWriteReadTime
    positivity
  have hprod :
      paper3HoffExponent j ≤ rmin * selectorMUInterReadStart j := by
    dsimp [paper3HoffExponent, rmin]
    unfold selectorMUInterReadStart selectorMUWriteReadTime
    have hj : 0 ≤ (j : ℝ) := by exact_mod_cast Nat.zero_le j
    nlinarith [Real.pi_pos, hj]
  have hexp :
      Real.exp (-(rmin * selectorMUInterReadStart j)) ≤ paper3HoffRate j := by
    simpa [paper3HoffRate] using Real.exp_le_exp.mpr (by linarith)
  have hmul :=
    mul_le_mul_of_nonneg_right hexp (inv_nonneg.mpr hD_pos.le)
  simpa [D, rmin, div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using hmul

/-- On the shifted post-select prefix, the sine phase has not passed `π/4`. -/
theorem paper3HeadlinePostSelect_sin_le_sqrt2
    (j : ℕ) {t : ℝ}
    (ht : t ∈ Icc (selectorMUSelectStartTime j)
        (selectorMUEarlyWriteSubStart j)) :
    Real.sin t ≤ Real.sqrt 2 / 2 := by
  obtain ⟨hl, hr⟩ := ht
  have hpi := Real.pi_pos
  set s := t - 2 * Real.pi * (j : ℝ) with hs
  have hsin : Real.sin t = Real.sin s := by
    have ht_eq : t = s + (j : ℕ) * (2 * Real.pi) := by
      rw [hs]
      ring
    rw [ht_eq, Real.sin_add_nat_mul_two_pi]
  rw [hsin]
  have hs0 : 0 ≤ s := by
    rw [hs]
    unfold selectorMUSelectStartTime selectorMUWriteStartTime selectorMURecoveryDelta at hl
    linarith
  have hs1 : s ≤ Real.pi / 4 := by
    rw [hs]
    unfold selectorMUEarlyWriteSubStart at hr
    linarith
  have hmem_s : s ∈ Set.Icc (-(Real.pi / 2)) (Real.pi / 2) := by
    constructor <;> linarith
  have hmem_end : Real.pi / 4 ∈ Set.Icc (-(Real.pi / 2)) (Real.pi / 2) := by
    constructor <;> linarith
  have hmono := Real.strictMonoOn_sin.monotoneOn hmem_s hmem_end hs1
  rwa [Real.sin_pi_div_four] at hmono

