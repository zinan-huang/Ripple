      hη_tendsto_zero :=
        paper3F1Eta_tendsto_zero_of_weightedDefect_summable
          wg w inputs.hTsum
      hhold := hhold
      hBzu0 := hBzu0
      hzu_tail := hzu_tail
      hcap_tail := hcap_tail }

