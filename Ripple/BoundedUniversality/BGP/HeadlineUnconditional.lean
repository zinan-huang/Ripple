          (mul_le_mul_of_nonneg_left hsm1 hEE)
          (mul_le_mul_of_nonneg_left hsm2 hEE)
    _ = Real.exp (-(2 * (j : ℝ))) *
        Real.exp (-(20 * (bgpScaleW wg : ℝ))) := by ring

/-! ## NEW part E: coordinatewise eval boxes and the one-cycle chain -/

/-- Public two-tube-point extraction of the branch scale:
`|scale_{v,i}| ≤ 4000·D_U`. -/
theorem paper3NW4_branchU_scale_abs (v : UniversalLocalView)
    (i : Fin d_U) :
    |(((branchU v).action i).scale : ℝ)| ≤ 4000 * D_U := by
  classical
  set c : UConf := solMUReplStaticCfg 0 0 with hc_def
  set x : Fin d_U → ℝ := fun i' => stackMachineEncodingU.enc c i' with hx_def
  set y : Fin d_U → ℝ := fun i' =>
    if i' = i then stackMachineEncodingU.enc c i' + r_LE_U
    else stackMachineEncodingU.enc c i' with hy_def
  have hr : r_LE_U = 1 / 1000 := rfl
  have htx : EncodingTube stackMachineEncodingU r_LE_U c x := by
    intro i'
    rw [hx_def]
    simp only [sub_self, abs_zero]
    norm_num [hr]
  have hty : EncodingTube stackMachineEncodingU r_LE_U c y := by
    intro i'
    rw [hy_def]
    by_cases h : i' = i
    · simp only [h, if_pos]
      rw [show stackMachineEncodingU.enc c i + r_LE_U -
        stackMachineEncodingU.enc c i = r_LE_U by ring]
      rw [abs_of_nonneg (by norm_num [hr])]
    · simp only [if_neg h, sub_self, abs_zero]
      norm_num [hr]
  have hex := branchU_evalBranch_abs_le_two_D_U htx v i
  have hey := branchU_evalBranch_abs_le_two_D_U hty v i
  have hdiff : |BranchData.evalBranch (branchU v) y i -
      BranchData.evalBranch (branchU v) x i| =
      |(((branchU v).action i).scale : ℝ)| * |y i - x i| := by
    show |BranchAction.evalReal B_U ((branchU v).action i) (y i) -
      BranchAction.evalReal B_U ((branchU v).action i) (x i)| = _
    exact BranchAction.affine_lipschitz B_U _ _ _
  have hyx : y i - x i = r_LE_U := by
    rw [hy_def, hx_def]
    simp
  have hbound : |(((branchU v).action i).scale : ℝ)| * r_LE_U ≤ 4 * D_U := by
    have h1 : |BranchData.evalBranch (branchU v) y i -
        BranchData.evalBranch (branchU v) x i| ≤ 4 * D_U := by
      have := paper3NW4_abs_sub_le_add
        (a := BranchData.evalBranch (branchU v) y i)
        (b := BranchData.evalBranch (branchU v) x i)
      linarith
    rw [hdiff, hyx] at h1
    rwa [abs_of_nonneg (by norm_num [hr] : (0:ℝ) ≤ r_LE_U)] at h1
  rw [hr] at hbound
  linarith

/-- Coordinatewise affine eval box: near any encoding coordinate the branch
evaluations are polynomially bounded. -/
theorem paper3NW4_eval_abs_of_coord_bound (v : UniversalLocalView)
    (i : Fin d_U) (c : UConf) {x : Fin d_U → ℝ}
    (hx : |x i - stackMachineEncodingU.enc c i| ≤ 5 * D_U + 2) :
    |BranchData.evalBranch (branchU v) x i| ≤
      2 * D_U + 4000 * D_U * (5 * D_U + 2) := by
  classical
  set xe : Fin d_U → ℝ := fun i' => stackMachineEncodingU.enc c i'
    with hxe_def
  have hr : r_LE_U = 1 / 1000 := rfl
  have hte : EncodingTube stackMachineEncodingU r_LE_U c xe := by
    intro i'
    rw [hxe_def]
    simp only [sub_self, abs_zero]
    norm_num [hr]
  have hee := branchU_evalBranch_abs_le_two_D_U hte v i
  have hdiff : |BranchData.evalBranch (branchU v) x i -
      BranchData.evalBranch (branchU v) xe i| =
      |(((branchU v).action i).scale : ℝ)| * |x i - xe i| := by
    show |BranchAction.evalReal B_U ((branchU v).action i) (x i) -
      BranchAction.evalReal B_U ((branchU v).action i) (xe i)| = _
    exact BranchAction.affine_lipschitz B_U _ _ _
  have hscale := paper3NW4_branchU_scale_abs v i
  have hD0 := D_U_nonneg
  have hxen : |x i - xe i| ≤ 5 * D_U + 2 := by
    rw [hxe_def]
    exact hx
  have h1 : |BranchData.evalBranch (branchU v) x i -
      BranchData.evalBranch (branchU v) xe i| ≤
      4000 * D_U * (5 * D_U + 2) := by
    rw [hdiff]
    have habs0 : (0 : ℝ) ≤ |(((branchU v).action i).scale : ℝ)| :=
      abs_nonneg _
    calc |(((branchU v).action i).scale : ℝ)| * |x i - xe i|
        ≤ (4000 * D_U) * (5 * D_U + 2) :=
          mul_le_mul hscale hxen (abs_nonneg _) (by nlinarith)
      _ = 4000 * D_U * (5 * D_U + 2) := by ring
  calc |BranchData.evalBranch (branchU v) x i|
      ≤ |BranchData.evalBranch (branchU v) x i -
          BranchData.evalBranch (branchU v) xe i| +
        |BranchData.evalBranch (branchU v) xe i| := by
        have := abs_sub_le (BranchData.evalBranch (branchU v) x i)
          (BranchData.evalBranch (branchU v) xe i) 0
        simpa using this
    _ ≤ 4000 * D_U * (5 * D_U + 2) + 2 * D_U := add_le_add h1 hee
    _ = 2 * D_U + 4000 * D_U * (5 * D_U + 2) := by ring

/-- Small-currency absorption: `e^{−2j}·e^{−20·S} ≤ 1/1000`. -/
theorem paper3NW4_currency_small (wg : ℕ) (j : ℕ) :
    Real.exp (-(2 * (j : ℝ))) * Real.exp (-(20 * (bgpScaleW wg : ℝ))) ≤
      1 / 1000 := by
  have hS := paper3NW4_S_ge wg
  have h1 : Real.exp (-(2 * (j : ℝ))) ≤ 1 := by
    rw [Real.exp_le_one_iff]
    have : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    linarith
  have h2 : Real.exp (-(20 * (bgpScaleW wg : ℝ))) ≤ Real.exp (-(7 : ℝ)) := by
    apply Real.exp_le_exp.mpr
    nlinarith
  have h3 : Real.exp (-(7 : ℝ)) ≤ 1 / 1000 := by
    rw [Real.exp_neg]
    have h20 := paper3NW4_exp_three_ge
    have he := Real.exp_one_gt_d9.le
    have hE3 := Real.exp_pos (3 : ℝ)
    have hE1 := Real.exp_pos (1 : ℝ)
    have hsplit : Real.exp (7 : ℝ) =
        Real.exp 3 * Real.exp 3 * Real.exp 1 := by
      rw [show (7 : ℝ) = 3 + 3 + 1 by norm_num, Real.exp_add, Real.exp_add]
    have h1000 : (1000 : ℝ) ≤ Real.exp 7 := by
      rw [hsplit]
      nlinarith
    rw [inv_le_comm₀ (by positivity) (by norm_num)]
    linarith
  have hE2 := (Real.exp_pos (-(20 * (bgpScaleW wg : ℝ)))).le
  nlinarith [h1, h2, h3, (Real.exp_pos (-(2 * (j : ℝ)))).le]

/-- The tube radius sits inside the readout tube. -/
theorem paper3NW4_TubeRadiusN_le_r :
    paper3F1TubeRadiusN paper3F1CwinDefN ≤ r_LE_U := by
  unfold paper3F1TubeRadiusN
  have h1 := δuWritePrefixN_nonneg paper3F1CwinDefN_pos.le (0 : ℕ)
  have h2 := δuSettledN_nonneg paper3F1CwinDefN_pos.le (0 : ℕ)
  linarith

/-- **The one-cycle mix radius**: on the settled-to-z-off window the mixture
target is pinned near the NEXT encoding, with the pointwise multiplier
comparison term plus a uniform decaying source. -/
theorem paper3NW4_mix_radius (wg w j : ℕ)
    (hT : ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW wg) w).u t i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U)
    (hD : ∀ t ∈ Icc (selectorMUWriteStartTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW wg) w).u t i -
          ((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i| ≤
          paper3NW4Drift wg j) :
    ∀ t ∈ Icc (selectorMUWriteHoldTime j) (selectorMUZOffStart j),
      ∀ i : Fin d_U,
        |selectorMixTarget branchU ((paper3HeadlineSolFamNW wg) w).u
            ((paper3HeadlineSolFamNW wg) w).lam t i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          |((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
          (6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j) := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  set sol := (paper3HeadlineSolFamNW wg) w with hsol
  intro t ht i
  have hws_hold : selectorMUWriteStartTime j ≤ selectorMUWriteHoldTime j := by
    unfold selectorMUWriteStartTime selectorMUWriteHoldTime
    have := Real.pi_pos
    linarith
  have htfull : t ∈ Icc (selectorMUWriteStartTime j)
      (selectorMUZOffStart j) := ⟨le_trans hws_hold ht.1, ht.2⟩
  have ht0 : 0 ≤ t :=
    le_trans (le_trans (selectorMUWriteStartTime_nonneg j) hws_hold) ht.1
  have hloser := paper3NW4_loser_mass wg w j hT t ht
  -- the concentration part: mix near the winner's branch value
  have hmix_raw := replicator_mix_error_of_loser_mass
    (vstar := localViewU (paper3F1Cfg w j))
    (lam := fun v : UniversalLocalView => sol.lam v t)
    (A := fun v : UniversalLocalView =>
      BranchData.evalBranch (branchU v) (sol.u t) i)
    (Rspread := 4 * D_U) (loserBound := paper3NW4EpsLam wg j)
    (by nlinarith [D_U_nonneg])
    (paper3NW_lam_sum_forward wg w t ht0)
    (fun v => paper3NW_lam_nonneg_forward wg w v t ht0)
    (fun v _hv => by
      have hev := branchU_evalBranch_abs_le_two_D_U
        (fun i' => hT t htfull i') v i
      have hevstar := branchU_evalBranch_abs_le_two_D_U
        (fun i' => hT t htfull i') (localViewU (paper3F1Cfg w j)) i
      have := paper3NW4_abs_sub_le_add
        (a := BranchData.evalBranch (branchU v) (sol.u t) i)
        (b := BranchData.evalBranch (branchU (localViewU (paper3F1Cfg w j)))
          (sol.u t) i)
      linarith)
    hloser
  have hmix1 : |selectorMixTarget branchU sol.u sol.lam t i -
      BranchData.evalBranch (branchU (localViewU (paper3F1Cfg w j)))
        (sol.u t) i| ≤ 4 * D_U * paper3NW4EpsLam wg j := by
    simpa [selectorMixTarget, selectorF] using hmix_raw
  -- the diagonal part: the winner's branch value near the NEXT encoding
  have hdiag := (branchU_contract_clause (paper3F1Cfg w j)).diagonal
    (sol.u t) i
  have hstep_cfg : M_U.step (paper3F1Cfg w j) = paper3F1Cfg w (j + 1) :=
    solMUReplStaticCfg_step w j
  rw [hstep_cfg] at hdiag
  -- the u-coordinate deviation
  have hu_dev : |sol.u t i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
      |sol.u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
        paper3NW4Drift wg j := by
    have h1 := hD t htfull i
    have := abs_sub_le (sol.u t i) (sol.u (selectorMUWriteStartTime j) i)
      (stackMachineEncodingU.enc (paper3F1Cfg w j) i)
    linarith
  have hmult_le := coordMultiplierU_le_six (paper3F1Cfg w j) i
  have hmult0 := coordMultiplierU_nonneg (paper3F1Cfg w j) i
  have hdrift0 := paper3NW4Drift_nonneg wg j
  have hdiag2 : |BranchData.evalBranch
      (branchU (localViewU (paper3F1Cfg w j))) (sol.u t) i -
      stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |sol.u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
        6 * paper3NW4Drift wg j := by
    have h1 : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |sol.u t i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          (|sol.u (selectorMUWriteStartTime j) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
            paper3NW4Drift wg j) :=
      mul_le_mul_of_nonneg_left hu_dev hmult0
    have h2 : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        paper3NW4Drift wg j ≤ 6 * paper3NW4Drift wg j :=
      mul_le_mul_of_nonneg_right hmult_le hdrift0
    rw [mul_add] at h1
    have hstep_a : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |sol.u t i - stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          |sol.u (selectorMUWriteStartTime j) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
          6 * paper3NW4Drift wg j := by
      linarith [h1, h2]
    exact le_trans hdiag hstep_a
  calc |selectorMixTarget branchU sol.u sol.lam t i -
      stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i|
      ≤ |selectorMixTarget branchU sol.u sol.lam t i -
          BranchData.evalBranch (branchU (localViewU (paper3F1Cfg w j)))
            (sol.u t) i| +
        |BranchData.evalBranch (branchU (localViewU (paper3F1Cfg w j)))
            (sol.u t) i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| :=
        abs_sub_le _ _ _
    _ ≤ 4 * D_U * paper3NW4EpsLam wg j +
        (stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          |sol.u (selectorMUWriteStartTime j) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
          6 * paper3NW4Drift wg j) := add_le_add hmix1 hdiag2
    _ = stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |sol.u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
        (6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j) := by
        ring

/-- Ordering: `hold j ≤ wr j`, `ws j ≤ hold j`. -/
theorem paper3NW4_ws_le_hold (j : ℕ) :
    selectorMUWriteStartTime j ≤ selectorMUWriteHoldTime j := by
  unfold selectorMUWriteStartTime selectorMUWriteHoldTime
  have := Real.pi_pos
  linarith

theorem paper3NW4_zOffStart_le_zOffEnd (j : ℕ) :
    selectorMUZOffStart j ≤ selectorMUZOffEnd j := by
  unfold selectorMUZOffStart selectorMUZOffEnd
  have := Real.pi_pos
  push_cast
  linarith

/-- **The z-side box on the off window.**  Under the cycle-`j` tube and
window hypotheses, the `z` trajectory is pinned near the NEXT encoding on
the whole `[zOffStart j, zOffEnd j]`. -/
theorem paper3NW4_z_off_box (wg w j : ℕ)
    (htube0 : ∀ i,
      |((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN)
    (hwin : ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW wg) w).z t i -
        ((paper3HeadlineSolFamNW wg) w).u t i| ≤ paper3F1CwinDefN) :
    ∀ t ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW wg) w).z t i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
        (stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          |((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
          (6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j)) +
        2 * paper3F1CwinDefN *
          Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
            selectorMUWriteHoldTime j))) +
        paper3NW4C0 *
          Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) /
          (200 * (bgpScaleW wg : ℝ)) := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  set sol := (paper3HeadlineSolFamNW wg) w with hsol
  obtain ⟨hT, hD⟩ := paper3NW4_tube_maintenance wg w j htube0 hwin
  have hmixR := paper3NW4_mix_radius wg w j hT hD
  -- shorthand for the per-coordinate mix radius
  set Wc : Fin d_U → ℝ := fun i =>
    stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
      |sol.u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
      (6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j) with hWc_def
  set zcLeg : ℝ := 2 * paper3F1CwinDefN *
    Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
      selectorMUWriteHoldTime j))) with hzc_def
  set fzLeg : ℝ := paper3NW4C0 *
    Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) /
    (200 * (bgpScaleW wg : ℝ)) with hfz_def
  have hS0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hD8 := paper3Headline_D_U_ge_eight
  have hCwin0 := paper3F1CwinDefN_pos
  have hzc0 : 0 ≤ zcLeg := by
    rw [hzc_def]
    positivity
  have hfz0 : 0 ≤ fzLeg := by
    rw [hfz_def]
    have := paper3NW4C0_nonneg
    positivity
  have hEps0 : 0 ≤ 4 * D_U * paper3NW4EpsLam wg j := by
    have h2 : (0 : ℝ) ≤ 4 * D_U := by nlinarith [D_U_nonneg]
    have hc1 : (0 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) - 1 := by
      have h := paper3HeadlineHCardTwo
      have h2' : (2 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) := by
        exact_mod_cast h
      linarith
    have hc2 : (0 : ℝ) ≤ (Fintype.card UniversalLocalView : ℝ) := by
      linarith [hc1]
    have hE1 := (Real.exp_pos
      (-(15 / 16) * paper3NW4DeltaGFloor wg j)).le
    have hE2 := (Real.exp_pos
      (-((bgpParamsNW wg).cα * selectorMUSelectStartTime j))).le
    have h2p : (0 : ℝ) ≤ (2 : ℝ) ^ (paper3HeadlineM + 1) := by positivity
    have hL0 : 0 ≤ paper3NW4EpsLam wg j := by
      unfold paper3NW4EpsLam
      exact mul_nonneg hc1
        (add_nonneg (mul_nonneg hc2 hE1) (mul_nonneg h2p hE2))
    exact mul_nonneg h2 hL0
  have hWc0 : ∀ i, 0 ≤ Wc i := by
    intro i
    rw [hWc_def]
    have h1 := coordMultiplierU_nonneg (paper3F1Cfg w j) i
    have h2 := paper3NW4Drift_nonneg wg j
    have h3 := abs_nonneg (sol.u (selectorMUWriteStartTime j) i -
      stackMachineEncodingU.enc (paper3F1Cfg w j) i)
    nlinarith [hEps0]
  -- smallness: `Wc i + zcLeg ≤ 1/100`
  have hWc_small : ∀ i, Wc i + zcLeg ≤ 1 / 100 := by
    intro i
    have hd := paper3NW4_leg_drift wg j
    have he := paper3NW4_leg_eps wg j
    have hz := paper3NW4_leg_zc wg j
    have hsm := paper3NW4_currency_small wg j
    have hmult := coordMultiplierU_le_six (paper3F1Cfg w j) i
    have hmult0 := coordMultiplierU_nonneg (paper3F1Cfg w j) i
    have hBE : |sol.u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U :=
      le_trans (htube0 i) paper3NW4_TubeRadiusN_le_r
    have hBE0 := abs_nonneg (sol.u (selectorMUWriteStartTime j) i -
      stackMachineEncodingU.enc (paper3F1Cfg w j) i)
    have hr : r_LE_U = 1 / 1000 := rfl
    have hm : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |sol.u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ 6 / 1000 := by
      calc stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          |sol.u (selectorMUWriteStartTime j) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i|
          ≤ 6 * r_LE_U :=
            mul_le_mul hmult hBE hBE0 (by norm_num)
        _ = 6 / 1000 := by rw [hr]; ring
    have hdrift6 : 6 * paper3NW4Drift wg j ≤ 1 / 1000 :=
      le_trans hd hsm
    have heps4 : 4 * D_U * paper3NW4EpsLam wg j ≤ 1 / 1000 :=
      le_trans he hsm
    have hzc1 : zcLeg ≤ 1 / 1000 := by
      rw [hzc_def]
      exact le_trans hz hsm
    rw [hWc_def]
    linarith
  -- ordering
  have hhold_wr : selectorMUWriteHoldTime j ≤ selectorMUWriteReadTime j :=
    selectorMUWriteHold_le_read j
  have hws_hold := paper3NW4_ws_le_hold j
  have hwr_z := paper3NW4_wr_le_zOffStart j
  have hz_ze := paper3NW4_zOffStart_le_zOffEnd j
  have hhold0 : 0 ≤ selectorMUWriteHoldTime j :=
    le_trans (selectorMUWriteStartTime_nonneg j) hws_hold
  have hz0 : 0 ≤ selectorMUZOffStart j :=
    le_trans hhold0 (le_trans hhold_wr hwr_z)
  -- z endpoint at the write-read time
  have hBz : ∀ i, |sol.z (selectorMUWriteHoldTime j) i -
      stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
      2 * paper3F1CwinDefN := by
    intro i
    have h1 := hwin i (selectorMUWriteHoldTime j) ⟨hws_hold, hhold_wr⟩
    have h2 := hT (selectorMUWriteHoldTime j)
      ⟨hws_hold, le_trans hhold_wr hwr_z⟩ i
    have h3 := paper3NW4_enc_abs (paper3F1Cfg w j) i
    have h4 := paper3NW4_enc_abs (paper3F1Cfg w (j + 1)) i
    have hEB := paper3NW4_extBox_le
    have hr : r_LE_U = 1 / 1000 := rfl
    have habs1 := abs_le.mp h1
    have habs2 := abs_le.mp h2
    have habs3 := abs_le.mp h3
    have habs4 := abs_le.mp h4
    rw [abs_le]
    constructor <;> [skip; skip] <;>
      [nlinarith [habs1.1, habs2.1, habs3.1, habs4.2, hD8];
       nlinarith [habs1.2, habs2.2, habs3.2, habs4.1, hD8]]
  have hMz : Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
      selectorMUWriteHoldTime j) ≤
      ∫ τ in (selectorMUWriteHoldTime j)..(selectorMUWriteReadTime j),
        (bgpParamsNW wg).A * sol.α τ *
          bGateZ (bgpParamsNW wg).L (sol.μ τ) τ := by
    have hpt : ∀ τ ∈ Icc (selectorMUWriteHoldTime j)
        (selectorMUWriteReadTime j),
        Real.exp (50 * (bgpScaleW wg : ℝ) * selectorMUWriteHoldTime j) ≤
        (bgpParamsNW wg).A * sol.α τ *
          bGateZ (bgpParamsNW wg).L (sol.μ τ) τ := by
      intro τ hτ
      have hτ0 : 0 ≤ τ := le_trans hhold0 hτ.1
      have hsin := paper3NW4_sin_ge_half_write j
        (le_trans hws_hold hτ.1) hτ.2
      have h1 := paper3NW4_zKernel_ge_of_sin_ge_half wg w hτ0 hsin
      have h2 : Real.exp (50 * (bgpScaleW wg : ℝ) *
          selectorMUWriteHoldTime j) ≤
          Real.exp (50 * (bgpScaleW wg : ℝ) * τ) := by
        apply Real.exp_le_exp.mpr
        nlinarith [hτ.1]
      linarith
    have hmono := intervalIntegral.integral_mono_on hhold_wr
      (continuous_const.intervalIntegrable (μ := MeasureTheory.volume) _ _)
      ((paper3NW4_zKernel_continuous wg w).intervalIntegrable
        (μ := MeasureTheory.volume) _ _)
      hpt
    have hconst : (∫ _ in (selectorMUWriteHoldTime j)..
        (selectorMUWriteReadTime j),
        Real.exp (50 * (bgpScaleW wg : ℝ) * selectorMUWriteHoldTime j)) =
        Real.exp (50 * (bgpScaleW wg : ℝ) * selectorMUWriteHoldTime j) *
        (selectorMUWriteReadTime j - selectorMUWriteHoldTime j) := by
      rw [intervalIntegral.integral_const]
      ring
    have hlen : selectorMUWriteReadTime j - selectorMUWriteHoldTime j =
        Real.pi / 3 := by
      unfold selectorMUWriteReadTime selectorMUWriteHoldTime
      ring
    rw [hconst, hlen] at hmono
    linarith [hmono]
  have hzwr : ∀ i, |sol.z (selectorMUWriteReadTime j) i -
      stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
      Wc i + zcLeg := by
    intro i
    have hafter := z_after_write_bound_repl (sol := sol) (s := i)
      (a := selectorMUWriteHoldTime j) (m := selectorMUWriteReadTime j)
      (b := selectorMUWriteReadTime j)
      (M := stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i)
      (δw := Wc i) (δzh := 0)
      hhold_wr
      (fun τ hτ => selectorSchedule_domain_of_nonneg_structural τ
        (le_trans hhold0 hτ.1))
      (paper3NW4_zKernel_continuous wg w)
      (fun τ hτ => paper3NW4_zKernel_nonneg wg w (le_trans hhold0 hτ.1))
      (fun τ hτ => hmixR τ ⟨hτ.1, le_trans hτ.2 hwr_z⟩ i)
      (fun τ hτ => by
        have hτeq : τ = selectorMUWriteReadTime j :=
          le_antisymm hτ.2 hτ.1
        rw [hτeq, sub_self, abs_zero])
    have h1 := hafter (selectorMUWriteReadTime j) ⟨le_refl _, le_refl _⟩
    have hexp_le : Real.exp (-(∫ τ in (selectorMUWriteHoldTime j)..
        (selectorMUWriteReadTime j),
        (bgpParamsNW wg).A * sol.α τ *
          bGateZ (bgpParamsNW wg).L (sol.μ τ) τ)) ≤
        Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
          selectorMUWriteHoldTime j))) := by
      apply Real.exp_le_exp.mpr
      linarith [hMz]
    have hcontr : Real.exp (-(∫ τ in (selectorMUWriteHoldTime j)..
        (selectorMUWriteReadTime j),
        (bgpParamsNW wg).A * sol.α τ *
          bGateZ (bgpParamsNW wg).L (sol.μ τ) τ)) *
        |sol.z (selectorMUWriteHoldTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤ zcLeg := by
      rw [hzc_def]
      calc Real.exp (-(∫ τ in (selectorMUWriteHoldTime j)..
          (selectorMUWriteReadTime j),
          (bgpParamsNW wg).A * sol.α τ *
            bGateZ (bgpParamsNW wg).L (sol.μ τ) τ)) *
          |sol.z (selectorMUWriteHoldTime j) i -
            stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i|
          ≤ Real.exp (-(Real.pi / 3 *
            Real.exp (50 * (bgpScaleW wg : ℝ) *
              selectorMUWriteHoldTime j))) * (2 * paper3F1CwinDefN) :=
            mul_le_mul hexp_le (hBz i) (abs_nonneg _) (Real.exp_pos _).le
        _ = 2 * paper3F1CwinDefN *
            Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
              selectorMUWriteHoldTime j))) := by ring
    linarith [h1, hcontr]
  -- z trapping on [wr, zOffStart]
  have hztrap : ∀ t ∈ Icc (selectorMUWriteReadTime j)
      (selectorMUZOffStart j), ∀ i,
      |sol.z t i - stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
      Wc i + zcLeg := by
    intro t ht i
    have hmem := paper3N_trapping_on_Icc
      (fun τ => sol.z τ i)
      (fun τ => selectorMixTarget branchU sol.u sol.lam τ i)
      (fun τ => (bgpParamsNW wg).A * sol.α τ *
        bGateZ (bgpParamsNW wg).L (sol.μ τ) τ)
      (lo := stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i -
        (Wc i + zcLeg))
      (hi := stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i +
        (Wc i + zcLeg))
      ht.1
      (paper3NW4_zKernel_continuous wg w)
      (sol.cont_mixTarget i)
      (fun τ hτ => sol.z_hasDeriv τ
        (selectorSchedule_domain_of_nonneg_structural τ
          (le_trans (le_trans hhold0 hhold_wr) hτ.1)) i)
      (fun τ hτ => paper3NW4_zKernel_nonneg wg w
        (le_trans (le_trans hhold0 hhold_wr) hτ.1))
      (fun τ hτ => by
        have hm : |selectorMixTarget branchU sol.u sol.lam τ i -
            stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤ Wc i :=
          hmixR τ ⟨le_trans hhold_wr hτ.1, le_trans hτ.2 ht.2⟩ i
        have habs := abs_le.mp hm
        constructor
        · linarith [habs.1, hzc0]
        · linarith [habs.2, hzc0])
      (by
        have habs := abs_le.mp (hzwr i)
        constructor
        · linarith [habs.1]
        · linarith [habs.2])
    have h1 := hmem.1
    have h2 := hmem.2
    rw [abs_le]
    exact ⟨by linarith, by linarith⟩
  -- the freeze first-exit on [zOffStart, zOffEnd]
  have hz0e : 0 ≤ selectorMUZOffEnd j := le_trans hz0 hz_ze
  have hfz_small : fzLeg ≤ 1 / 1000 := by
    rw [hfz_def]
    exact le_trans (paper3NW4_leg_freeze wg j) (paper3NW4_currency_small wg j)
  have hzatz0 : ∀ i, |sol.z (selectorMUZOffStart j) i -
      stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤ 1 / 100 :=
    fun i => le_trans (hztrap (selectorMUZOffStart j)
      ⟨hwr_z, le_refl _⟩ i) (hWc_small i)
  -- conditional |mix − z| box on a not-yet-exited prefix
  have hpair : ∀ b ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
      (∀ s ∈ Icc (selectorMUZOffStart j) b, ∀ i : Fin d_U,
        |sol.z s i - sol.z (selectorMUZOffStart j) i| ≤ 1) →
      ∀ s ∈ Icc (selectorMUZOffStart j) b, ∀ i : Fin d_U,
        |selectorMixTarget branchU sol.u sol.lam s i - sol.z s i| ≤
          paper3NW4C0 := by
    intro b hb hzbox s hs i
    have hs0 : 0 ≤ s := le_trans hz0 hs.1
    have hz_abs : ∀ σ ∈ Icc (selectorMUZOffStart j) s, ∀ i' : Fin d_U,
        |sol.z σ i'| ≤ 2 * D_U + 2 := by
      intro σ hσ i'
      have h1 := hzbox σ ⟨hσ.1, le_trans hσ.2 hs.2⟩ i'
      have h2 := hzatz0 i'
      have h3 := paper3NW4_enc_abs (paper3F1Cfg w (j + 1)) i'
      have t1 := abs_le.mp h1
      have t2 := abs_le.mp h2
      have t3 := abs_le.mp h3
      rw [abs_le]
      constructor <;> [linarith [t1.1, t2.1, t3.1];
        linarith [t1.2, t2.2, t3.2]]
    have hu_box : ∀ i' : Fin d_U,
        |sol.u s i' -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i'| ≤
          5 * D_U + 2 := by
      intro i'
      have hentry : |sol.u (selectorMUZOffStart j) i'| ≤ 2 * D_U + 2 := by
        have h1 := hT (selectorMUZOffStart j)
          ⟨le_trans hws_hold (le_trans hhold_wr hwr_z), le_refl _⟩ i'
        have h2 := paper3NW4_enc_abs (paper3F1Cfg w j) i'
        have hr : r_LE_U = 1 / 1000 := rfl
        have t1 := abs_le.mp h1
        have t2 := abs_le.mp h2
        rw [abs_le]
        constructor <;> [linarith [t1.1, t2.1]; linarith [t1.2, t2.2]]
      have hmem := paper3N_trapping_on_Icc
        (fun τ => sol.u τ i')
        (fun τ => sol.z τ i')
        (fun τ => (bgpParamsNW wg).A * sol.α τ *
          bGateU (bgpParamsNW wg).L (sol.μ τ) τ)
        (lo := -(2 * D_U + 2)) (hi := 2 * D_U + 2)
        hs.1
        (paper3NW4_uKernel_continuous wg w)
        (sol.cont_z i')
        (fun τ hτ => sol.u_hasDeriv τ
          (selectorSchedule_domain_of_nonneg_structural τ
            (le_trans hz0 hτ.1)) i')
        (fun τ hτ => paper3NW4_uKernel_nonneg wg w (le_trans hz0 hτ.1))
        (fun τ hτ => by
          have := hz_abs τ hτ i'
          exact abs_le.mp this)
        (abs_le.mp hentry)
      have h3 := paper3NW4_enc_abs (paper3F1Cfg w (j + 1)) i'
      have hD8' := paper3Headline_D_U_ge_eight
      have t3 := abs_le.mp h3
      rw [abs_le]
      constructor <;> [linarith [hmem.1, t3.1]; linarith [hmem.2, t3.2]]
    have hmix_abs : |selectorMixTarget branchU sol.u sol.lam s i| ≤
        2 * D_U + 4000 * D_U * (5 * D_U + 2) := by
      refine paper3NW_mixTarget_abs_le_of_branch_abs wg w hs0 ?_ i
      intro i' v
      exact paper3NW4_eval_abs_of_coord_bound v i' (paper3F1Cfg w (j + 1))
        (hu_box i')
    have hzs := hz_abs s ⟨hs.1, le_refl s⟩ i
    have hC0ge : 2 * D_U + 4000 * D_U * (5 * D_U + 2) + (2 * D_U + 2) ≤
        paper3NW4C0 := by
      unfold paper3NW4C0
      nlinarith [paper3Headline_D_U_ge_eight]
    have := paper3NW4_abs_sub_le_add
      (a := selectorMixTarget branchU sol.u sol.lam s i)
      (b := sol.z s i)
    linarith
  have hfreeze : ∀ t ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
      ∀ i : Fin d_U,
      |sol.z t i - sol.z (selectorMUZOffStart j) i| ≤ fzLeg := by
    -- first-exit at level 1
    have hexit : ∀ t ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
        ∀ i : Fin d_U,
        |sol.z t i - sol.z (selectorMUZOffStart j) i| ≤ 1 := by
      by_contra hcon
      push_neg at hcon
      obtain ⟨tb, htb, i0, hi0⟩ := hcon
      set Bad : Set ℝ := Icc (selectorMUZOffStart j) tb ∩
        ⋃ i : Fin d_U, {s : ℝ |
          1 ≤ |sol.z s i - sol.z (selectorMUZOffStart j) i|} with hBadDef
      have hclosed : IsClosed Bad := by
        refine isClosed_Icc.inter (isClosed_iUnion_of_finite fun i => ?_)
        exact isClosed_le continuous_const
          (((sol.cont_z i).sub continuous_const).abs)
      have htb_mem : tb ∈ Bad :=
        ⟨⟨htb.1, le_refl tb⟩, Set.mem_iUnion.mpr ⟨i0, hi0.le⟩⟩
      have hne : Bad.Nonempty := ⟨tb, htb_mem⟩
      have hbdd : BddBelow Bad := ⟨selectorMUZOffStart j, fun s hs => hs.1.1⟩
      have hmem_inf : sInf Bad ∈ Bad := hclosed.csInf_mem hne hbdd
      have hZinf : selectorMUZOffStart j ≤ sInf Bad :=
        le_csInf hne fun b hb => hb.1.1
      have hinf_tb : sInf Bad ≤ tb := csInf_le hbdd htb_mem
      have hinfE : sInf Bad ≤ selectorMUZOffEnd j :=
        le_trans hinf_tb htb.2
      have hZlt : selectorMUZOffStart j < sInf Bad := by
        rcases lt_or_eq_of_le hZinf with h | h
        · exact h
        · exfalso
          obtain ⟨i, hi⟩ := Set.mem_iUnion.mp hmem_inf.2
          rw [← h] at hi
          simp only [Set.mem_setOf_eq, sub_self, abs_zero] at hi
          linarith
      have hzbox_pre : ∀ s ∈ Icc (selectorMUZOffStart j) (sInf Bad),
          ∀ i : Fin d_U,
          |sol.z s i - sol.z (selectorMUZOffStart j) i| ≤ 1 := by
        intro s hs i
        rcases lt_or_eq_of_le hs.2 with hlt | heq
        · by_contra hgt
          push_neg at hgt
          have hmem : s ∈ Bad :=
            ⟨⟨hs.1, le_trans hs.2 hinf_tb⟩,
              Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
          exact absurd (csInf_le hbdd hmem) (not_le.mpr hlt)
        · have hf : Continuous fun τ : ℝ =>
              |sol.z τ i - sol.z (selectorMUZOffStart j) i| :=
            ((sol.cont_z i).sub continuous_const).abs
          have hev : ∀ᶠ τ in nhdsWithin (sInf Bad) (Set.Iio (sInf Bad)),
              |sol.z τ i - sol.z (selectorMUZOffStart j) i| ≤ 1 := by
            filter_upwards [Ioo_mem_nhdsLT hZlt] with τ hτ
            by_contra hgt
            push_neg at hgt
            have hmem : τ ∈ Bad :=
              ⟨⟨hτ.1.le, le_trans hτ.2.le hinf_tb⟩,
                Set.mem_iUnion.mpr ⟨i, hgt.le⟩⟩
            exact absurd (csInf_le hbdd hmem) (not_le.mpr hτ.2)
          have hlim := le_of_tendsto
            (hf.continuousWithinAt
              (s := Set.Iio (sInf Bad)) (x := sInf Bad)) hev
          rw [heq]
          exact hlim
      obtain ⟨i, hi⟩ := Set.mem_iUnion.mp hmem_inf.2
      simp only [Set.mem_setOf_eq] at hi
      have hbox := hpair (sInf Bad) ⟨hZinf, hinfE⟩ hzbox_pre
      have hdrift := paper3NW4_z_drift_of_sin_nonpos wg w i
        paper3NW4C0_nonneg hz0
        (fun τ hτ => paper3NW4_sin_nonpos_zOff j hτ.1
          (le_trans hτ.2 hinfE))
        (fun τ hτ => hbox τ hτ i)
        (sInf Bad) ⟨hZinf, le_refl _⟩
      have : |sol.z (sInf Bad) i - sol.z (selectorMUZOffStart j) i| ≤
          fzLeg := by
        rw [hfz_def]
        exact hdrift
      linarith [hfz_small]
    -- with the exit level maintained the drift is unconditional
    intro t ht i
    have hbox := hpair (selectorMUZOffEnd j) ⟨hz_ze, le_refl _⟩
      (fun s hs i' => hexit s hs i')
    have hdrift := paper3NW4_z_drift_of_sin_nonpos wg w i
      paper3NW4C0_nonneg hz0
      (fun τ hτ => paper3NW4_sin_nonpos_zOff j hτ.1 hτ.2)
      (fun τ hτ => hbox τ hτ i)
      t ht
    rw [hfz_def]
    exact hdrift
  -- conclusion
  intro t ht i
  have h1 := hfreeze t ht i
  have h2 := hztrap (selectorMUZOffStart j) ⟨hwr_z, le_refl _⟩ i
  calc |sol.z t i - stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i|
      ≤ |sol.z t i - sol.z (selectorMUZOffStart j) i| +
        |sol.z (selectorMUZOffStart j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| :=
        abs_sub_le _ _ _
    _ ≤ fzLeg + (Wc i + zcLeg) := add_le_add h1 h2
    _ = Wc i + zcLeg + fzLeg := by ring

/-- The total decaying one-cycle source at NW rates. -/
def paper3NW4Src (wg : ℕ) (j : ℕ) : ℝ :=
  6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j +
  2 * paper3F1CwinDefN *
    Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
      selectorMUWriteHoldTime j))) +
  paper3NW4C0 *
    Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) /
    (200 * (bgpScaleW wg : ℝ)) +
  5 * D_U *
    Real.exp (-(2 * Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
      selectorMUUActiveStart j))) +
  (4 * D_U + 3) *
    Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffEnd j)) /
    (200 * (bgpScaleW wg : ℝ))

/-- The six source legs in the uniform currency. -/
theorem paper3NW4Src_le (wg : ℕ) (j : ℕ) :
    paper3NW4Src wg j ≤
      6 * Real.exp (-(20 * (bgpScaleW wg : ℝ))) * Real.exp (-(2 * (j : ℝ))) := by
  have h1 := paper3NW4_leg_drift wg j
  have h2 := paper3NW4_leg_eps wg j
  have h3 := paper3NW4_leg_zc wg j
  have h4 := paper3NW4_leg_freeze wg j
  have h5 := paper3NW4_leg_copy wg j
  have h6 := paper3NW4_leg_tail wg j
  unfold paper3NW4Src
  linarith

/-- Orderings for the u-active subwindow. -/
theorem paper3NW4_zOffStart_le_uActiveStart (j : ℕ) :
    selectorMUZOffStart j ≤ selectorMUUActiveStart j := by
  unfold selectorMUZOffStart selectorMUUActiveStart
  have := Real.pi_pos
  linarith

theorem paper3NW4_uActiveStart_le_end (j : ℕ) :
    selectorMUUActiveStart j ≤ selectorMUUActiveEnd j := by
  unfold selectorMUUActiveStart selectorMUUActiveEnd
  have := Real.pi_pos
  linarith

theorem paper3NW4_uActiveEnd_le_zOffEnd (j : ℕ) :
    selectorMUUActiveEnd j ≤ selectorMUZOffEnd j := by
  unfold selectorMUUActiveEnd selectorMUZOffEnd
  have := Real.pi_pos
  push_cast
  linarith

theorem paper3NW4_zOffEnd_le_ws_succ (j : ℕ) :
    selectorMUZOffEnd j ≤ selectorMUWriteStartTime (j + 1) := by
  unfold selectorMUZOffEnd selectorMUWriteStartTime
  have := Real.pi_pos
  push_cast
  linarith

/-- **The one-cycle NW multiplier step.** -/
theorem paper3NW4_one_cycle (wg w j : ℕ)
    (htube0 : ∀ i,
      |((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN)
    (hwin : ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW wg) w).z t i -
        ((paper3HeadlineSolFamNW wg) w).u t i| ≤ paper3F1CwinDefN) :
    ∀ i : Fin d_U,
      |((paper3HeadlineSolFamNW wg) w).u
          (selectorMUWriteStartTime (j + 1)) i -
        stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
      stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
      paper3NW4Src wg j := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  set sol := (paper3HeadlineSolFamNW wg) w with hsol
  obtain ⟨hT, hD⟩ := paper3NW4_tube_maintenance wg w j htube0 hwin
  have hzoff := paper3NW4_z_off_box wg w j htube0 hwin
  set Wc : Fin d_U → ℝ := fun i =>
    stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
      |sol.u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
      (6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j) with hWc_def
  set zcLeg : ℝ := 2 * paper3F1CwinDefN *
    Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
      selectorMUWriteHoldTime j))) with hzc_def
  set fzLeg : ℝ := paper3NW4C0 *
    Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) /
    (200 * (bgpScaleW wg : ℝ)) with hfz_def
  set cpLeg : ℝ := 5 * D_U *
    Real.exp (-(2 * Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
      selectorMUUActiveStart j))) with hcp_def
  set tlLeg : ℝ := (4 * D_U + 3) *
    Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffEnd j)) /
    (200 * (bgpScaleW wg : ℝ)) with htl_def
  have hS0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hD8 := paper3Headline_D_U_ge_eight
  have hz0 : 0 ≤ selectorMUZOffStart j := by
    unfold selectorMUZOffStart
    have hπ := Real.pi_pos
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith
  have hz0e : 0 ≤ selectorMUZOffEnd j :=
    le_trans hz0 (paper3NW4_zOffStart_le_zOffEnd j)
  have hsm := paper3NW4_currency_small wg j
  have hzbox : ∀ t ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
      ∀ i : Fin d_U,
      |sol.z t i - stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
        Wc i + zcLeg + fzLeg := hzoff
  have hWc_small : ∀ i, Wc i ≤ 8 / 1000 := by
    intro i
    have hd := le_trans (paper3NW4_leg_drift wg j) hsm
    have he := le_trans (paper3NW4_leg_eps wg j) hsm
    have hmult := coordMultiplierU_le_six (paper3F1Cfg w j) i
    have hBE : |sol.u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U :=
      le_trans (htube0 i) paper3NW4_TubeRadiusN_le_r
