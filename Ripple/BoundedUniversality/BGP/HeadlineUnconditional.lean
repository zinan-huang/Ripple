    exact (hAα.mul hgateZ).mul hdiff
  have he_deriv : ∀ t ∈ Set.Icc a b,
      HasDerivAt e (-(kU t) * e t + src t) t := by
    intro t ht
    have ha0 : 0 ≤ a := by
      dsimp [a]
      unfold selectorMUWriteReadTime
      positivity
    have ht0 : 0 ≤ t := le_trans ha0 ht.1
    have hdom : t ∈ selectorSchedule.domain :=
      selectorSchedule_domain_of_nonneg_structural t ht0
    have hz := (sol w).z_hasDeriv t hdom i
    have hu := (sol w).u_hasDeriv t hdom i
    have hsub := hz.sub hu
    convert hsub using 1
    simp only [e, kU, src]
    ring
  have hbase :=
    abs_inhomogeneous_decay_bound e src kU
      (a := a) (b := b) (E0 := Bread) (S := Bsrc)
      hab hk_cont hsrc_cont he_deriv
      (by simpa [e, a] using hread i)
      (by simpa [src, kU, a, b] using hsource i)
  simpa [e, kU, a, b] using hbase


def paper3RecoveryCrMin (_wg _j : ℕ) : ℝ :=
  (9 / 10 : ℝ) ^ paper3HeadlineM

def paper3RecoveryCrMax (_wg _j : ℕ) : ℝ :=
  1

def paper3RecoveryCgMin (_wg _j : ℕ) : ℝ :=
  ((3 / 4 : ℝ) ^ paper3HeadlineM) * ((paper3WarmGainC : ℚ) : ℝ)

def paper3RecoveryGap (_wg _j : ℕ) : ℝ :=
  selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos

def paper3RecoveryB (wg j : ℕ) : ℝ :=
  paper3RecoveryCgMin wg j * paper3RecoveryGap wg j / 2 -
    paper3RecoveryCrMax wg j

def paper3RecoveryK (_wg _j : ℕ) : ℕ :=
  25

theorem paper3WarmGainC_le_warmGainQ (w : ℕ) :
    ((paper3WarmGainC : ℚ) : ℝ) ≤ ((paper3WarmGainQ w : ℚ) : ℝ) := by
  have hpow_ge : (1 : ℚ) ≤ (6 : ℚ) ^ w :=
    one_le_pow₀ (by norm_num : (1 : ℚ) ≤ 6)
  have hC_nonneg : (0 : ℚ) ≤ paper3WarmGainC := by
    norm_num [paper3WarmGainC]
  have hmul_q : paper3WarmGainC ≤ paper3WarmGainQ w := by
    unfold paper3WarmGainQ
    nlinarith [mul_le_mul_of_nonneg_left hpow_ge hC_nonneg]
  exact_mod_cast hmul_q

theorem paper3RecoveryGap_ge_fifteen_sixteen (wg j : ℕ) :
    (15 / 16 : ℝ) ≤ paper3RecoveryGap wg j := by
  rw [paper3RecoveryGap, selectorReplicatorGapVal,
    paper3UniversalGateAtoms_errSel]
  have hN2 : (2 : ℝ) ≤ Fintype.card UniversalLocalView := by
    exact_mod_cast paper3HeadlineHCardTwo
  have hNpos : (0 : ℝ) < Fintype.card UniversalLocalView := by
    linarith
  unfold paper3HeadlineEta
  push_cast
  field_simp [ne_of_gt hNpos]
  nlinarith [hN2]

theorem paper3RecoveryGap_le_one (wg j : ℕ) :
    paper3RecoveryGap wg j ≤ 1 := by
  rw [paper3RecoveryGap, selectorReplicatorGapVal]
  have herr_nonneg :
      0 ≤ (gateSelectorAtomsCoordN
        (universalGateAtoms paper3HeadlineEta paper3HeadlineEta_pos)).errSel := by
    rw [GateSelectorAtomsN.errSel]
    exact Finset.sum_nonneg fun a _ha =>
      (universalGateAtoms paper3HeadlineEta paper3HeadlineEta_pos a).err_nonneg
  linarith

theorem paper3RecoveryCrMin_pos (wg j : ℕ) :
    0 < paper3RecoveryCrMin wg j := by
  norm_num [paper3RecoveryCrMin, paper3HeadlineM]

theorem paper3RecoveryCrMin_le_crMax (wg j : ℕ) :
    paper3RecoveryCrMin wg j ≤ paper3RecoveryCrMax wg j := by
  norm_num [paper3RecoveryCrMin, paper3RecoveryCrMax, paper3HeadlineM]

theorem paper3RecoveryCgMin_nonneg (wg j : ℕ) :
    0 ≤ paper3RecoveryCgMin wg j := by
  norm_num [paper3RecoveryCgMin, paper3HeadlineM, paper3WarmGainC]

theorem paper3RecoveryGap_nonneg (wg j : ℕ) :
    0 ≤ paper3RecoveryGap wg j :=
  le_trans (by norm_num : (0 : ℝ) ≤ 15 / 16)
    (paper3RecoveryGap_ge_fifteen_sixteen wg j)

theorem paper3RecoveryGap_le_gapVal (wg j : ℕ) :
    paper3RecoveryGap wg j ≤
      selectorReplicatorGapVal paper3HeadlineEta paper3HeadlineEta_pos := by
  rfl

theorem paper3RecoveryB_eq (wg j : ℕ) :
    paper3RecoveryB wg j =
      paper3RecoveryCgMin wg j * paper3RecoveryGap wg j / 2 -
        paper3RecoveryCrMax wg j := by
  rfl

theorem paper3RecoveryB_pos (wg j : ℕ) :
    0 < paper3RecoveryB wg j := by
  have hgap := paper3RecoveryGap_ge_fifteen_sixteen wg j
  have hcoef_nonneg : 0 ≤ paper3RecoveryCgMin wg j :=
    paper3RecoveryCgMin_nonneg wg j
  have hmul :
      paper3RecoveryCgMin wg j * (15 / 16 : ℝ) ≤
        paper3RecoveryCgMin wg j * paper3RecoveryGap wg j :=
    mul_le_mul_of_nonneg_left hgap hcoef_nonneg
  have hnum :
      0 <
        ((3 / 4 : ℝ) ^ paper3HeadlineM *
          ((paper3WarmGainC : ℚ) : ℝ) * (15 / 16) / 2 - 1) := by
    norm_num [paper3HeadlineM, paper3WarmGainC]
  unfold paper3RecoveryB paper3RecoveryCgMin paper3RecoveryCrMax
  nlinarith

theorem paper3RecoveryBDelta (wg j : ℕ) :
    (paper3RecoveryK wg j : ℝ) ≤
      paper3RecoveryB wg j * selectorMURecoveryDelta := by
  have hgap := paper3RecoveryGap_ge_fifteen_sixteen wg j
  have hnum :
      (25 : ℝ) ≤
        (((3 / 4 : ℝ) ^ paper3HeadlineM *
            ((paper3WarmGainC : ℚ) : ℝ) * (15 / 16) / 2 - 1) *
          selectorMURecoveryDelta) := by
    norm_num [paper3HeadlineM, paper3WarmGainC, selectorMURecoveryDelta]
  have hcoef_nonneg : 0 ≤ paper3RecoveryCgMin wg j :=
    paper3RecoveryCgMin_nonneg wg j
  have hmul :
      paper3RecoveryCgMin wg j * (15 / 16 : ℝ) ≤
        paper3RecoveryCgMin wg j * paper3RecoveryGap wg j :=
    mul_le_mul_of_nonneg_left hgap hcoef_nonneg
  unfold paper3RecoveryK paper3RecoveryB paper3RecoveryCgMin paper3RecoveryCrMax
  nlinarith [hnum, hmul, selectorMURecoveryDelta_pos]

theorem paper3RecoveryPow (wg j : ℕ) :
    1 + paper3RecoveryB wg j / paper3RecoveryCrMin wg j ≤
      (2 : ℝ) ^ paper3RecoveryK wg j := by
  have hgap := paper3RecoveryGap_le_one wg j
  have hnum :
      1 + (((3 / 4 : ℝ) ^ paper3HeadlineM *
          ((paper3WarmGainC : ℚ) : ℝ) * (1 / 2) - 1) /
          ((9 / 10 : ℝ) ^ paper3HeadlineM)) ≤ (2 : ℝ) ^ (25 : ℕ) := by
    norm_num [paper3HeadlineM, paper3WarmGainC]
  have hcoef_nonneg : 0 ≤ paper3RecoveryCgMin wg j :=
    paper3RecoveryCgMin_nonneg wg j
  have hmul :
      paper3RecoveryCgMin wg j * paper3RecoveryGap wg j ≤
        paper3RecoveryCgMin wg j * 1 :=
    mul_le_mul_of_nonneg_left hgap hcoef_nonneg
  have hmul_unfold :
      (((3 / 4 : ℝ) ^ paper3HeadlineM * ((paper3WarmGainC : ℚ) : ℝ)) *
          paper3RecoveryGap wg j) ≤
        ((3 / 4 : ℝ) ^ paper3HeadlineM * ((paper3WarmGainC : ℚ) : ℝ)) * 1 := by
    simpa [paper3RecoveryCgMin] using hmul
  have hB :
      paper3RecoveryCgMin wg j * paper3RecoveryGap wg j / 2 -
          paper3RecoveryCrMax wg j ≤
        ((3 / 4 : ℝ) ^ paper3HeadlineM *
          ((paper3WarmGainC : ℚ) : ℝ) * (1 / 2) - 1) := by
    unfold paper3RecoveryCgMin paper3RecoveryCrMax
    nlinarith [hmul_unfold]
  have hcr_pos : 0 < paper3RecoveryCrMin wg j :=
    paper3RecoveryCrMin_pos wg j
  have hdiv := div_le_div_of_nonneg_right hB hcr_pos.le
  have hdiv_unfold :
      (paper3RecoveryCgMin wg j * paper3RecoveryGap wg j / 2 -
          paper3RecoveryCrMax wg j) / ((9 / 10 : ℝ) ^ paper3HeadlineM) ≤
        (((3 / 4 : ℝ) ^ paper3HeadlineM *
            ((paper3WarmGainC : ℚ) : ℝ) * (1 / 2) - 1) /
          ((9 / 10 : ℝ) ^ paper3HeadlineM)) := by
    simpa [paper3RecoveryCrMin] using hdiv
  unfold paper3RecoveryB paper3RecoveryCrMin paper3RecoveryK
  linarith

theorem paper3RecoveryCosLower (j : ℕ) {u : ℝ}
    (hu : u ∈ Icc (selectorMUWriteStartTime j) (selectorMUSelectStartTime j)) :
    (4 / 5 : ℝ) ≤ Real.cos u := by
  have hπpos : 0 < Real.pi := Real.pi_pos
  set x : ℝ := u - 2 * Real.pi * (j : ℝ) with hx
  have hcos : Real.cos u = Real.cos x := by
    have hrewrite : u = x + (j : ℕ) * (2 * Real.pi) := by
      rw [hx]
      ring
    conv_lhs => rw [hrewrite]
    rw [Real.cos_add_nat_mul_two_pi]
  have hx0 : 0 ≤ x := by
    rw [hx]
    have hleft := hu.1
    simp [selectorMUWriteStartTime] at hleft
    linarith [hleft]
  have hxle : x ≤ Real.pi / 5 := by
    rw [hx]
    have hright := hu.2
    have hdelta : selectorMURecoveryDelta ≤ Real.pi / 30 := by
      simp [selectorMURecoveryDelta]
      nlinarith [Real.pi_gt_three]
    simp [selectorMUSelectStartTime, selectorMUWriteStartTime] at hright
    nlinarith [hright, hdelta]
  have hpi5le : Real.pi / 5 ≤ Real.pi := by
    linarith [hπpos]
  have hmono : Real.cos (Real.pi / 5) ≤ Real.cos x :=
    Real.cos_le_cos_of_nonneg_of_le_pi hx0 hpi5le hxle
  have hfour : (4 / 5 : ℝ) ≤ Real.cos (Real.pi / 5) := by
    rw [Real.cos_pi_div_five]
    have hsqrt : (11 / 5 : ℝ) ≤ Real.sqrt 5 := by
      rw [Real.le_sqrt (by norm_num : (0 : ℝ) ≤ 11 / 5)
        (by norm_num : (0 : ℝ) ≤ 5)]
      norm_num
    linarith
  rw [hcos]
  linarith

theorem paper3RecoveryCrBounds (wg j : ℕ) :
    ∀ u ∈ Icc (selectorMUWriteStartTime j) (selectorMUSelectStartTime j),
      paper3RecoveryCrMin wg j ≤
          ((1 + Real.cos u) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ) ∧
        ((1 + Real.cos u) / 2) ^ paper3HeadlineM *
            (paper3HeadlineKappa : ℝ) ≤ paper3RecoveryCrMax wg j := by
  intro u hu
  have hcos45 : (4 / 5 : ℝ) ≤ Real.cos u :=
    paper3RecoveryCosLower j hu
  constructor
  · have hbase : (9 / 10 : ℝ) ≤ (1 + Real.cos u) / 2 := by
      linarith
    simpa [paper3RecoveryCrMin, paper3HeadlineM, paper3HeadlineKappa, mul_one]
      using pow_le_pow_left₀ (by norm_num : (0 : ℝ) ≤ 9 / 10) hbase 20
  · have hbase_nonneg : 0 ≤ (1 + Real.cos u) / 2 := by
      nlinarith [Real.neg_one_le_cos u]
    have hbase_le : (1 + Real.cos u) / 2 ≤ 1 := by
      nlinarith [Real.cos_le_one u]
    simpa [paper3RecoveryCrMax, paper3HeadlineM, paper3HeadlineKappa, mul_one]
      using (pow_le_one₀ hbase_nonneg hbase_le :
        ((1 + Real.cos u) / 2) ^ 20 ≤ 1)

theorem paper3RecoveryCgMinLe (wg j : ℕ) :
    ∀ u ∈ Icc (selectorMUWriteStartTime j) (selectorMUSelectStartTime j),
      paper3RecoveryCgMin wg j ≤
        ((1 + Real.sin u) / 2) ^ paper3HeadlineM *
          (((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * u)) := by
  intro u hu
  have hgate : u ∈
      Set.Icc (2 * Real.pi * (j : ℝ) + Real.pi / 6)
        (2 * Real.pi * (j : ℝ) + Real.pi / 2) := by
    refine ⟨?_, ?_⟩
    · simpa [selectorMUWriteStartTime] using hu.1
    · have hsel_hold : selectorMUSelectStartTime j ≤ selectorMUWriteHoldTime j :=
        le_of_lt (selectorMUSelectStart_lt_hold j)
      have hright : u ≤ selectorMUWriteHoldTime j := le_trans hu.2 hsel_hold
      simpa [selectorMUWriteHoldTime] using hright
  have hsin : (1 : ℝ) / 2 ≤ Real.sin u :=
    sin_ge_half_of_gate_window j hgate
  have hsin_base : (3 / 4 : ℝ) ≤ (1 + Real.sin u) / 2 := by
    linarith
  have hsin_pow :
      (3 / 4 : ℝ) ^ paper3HeadlineM ≤
        ((1 + Real.sin u) / 2) ^ paper3HeadlineM := by
    simpa [paper3HeadlineM] using
      (pow_le_pow_left₀ (by norm_num : (0 : ℝ) ≤ 3 / 4) hsin_base 20)
  have hC_le_warm :
      ((paper3WarmGainC : ℚ) : ℝ) ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) :=
    paper3WarmGainC_le_warmGainQ wg
  have hu_nonneg : 0 ≤ u :=
    le_trans (selectorMUWriteStartTime_nonneg j) hu.1
  have hcα_nonneg : 0 ≤ bgpParams38.cα := by
    norm_num [bgpParams38]
  have hexp_one : (1 : ℝ) ≤ Real.exp (bgpParams38.cα * u) :=
    Real.one_le_exp_iff.mpr (mul_nonneg hcα_nonneg hu_nonneg)
  have hwarm_nonneg : 0 ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) :=
    paper3WarmGainQ_nonneg wg
  have hC_le_warm_exp :
      ((paper3WarmGainC : ℚ) : ℝ) ≤
        ((paper3WarmGainQ wg : ℚ) : ℝ) * Real.exp (bgpParams38.cα * u) := by
    calc
      ((paper3WarmGainC : ℚ) : ℝ) ≤
          ((paper3WarmGainQ wg : ℚ) : ℝ) := hC_le_warm
      _ ≤ ((paper3WarmGainQ wg : ℚ) : ℝ) *
          Real.exp (bgpParams38.cα * u) := by
        simpa using mul_le_mul_of_nonneg_left hexp_one hwarm_nonneg
  exact
    mul_le_mul hsin_pow hC_le_warm_exp
      (by norm_num [paper3WarmGainC])
      (pow_nonneg (by nlinarith [Real.neg_one_le_sin u]) paper3HeadlineM)

theorem paper3UniversalPval_continuous_of_cont_u
