/-! ### The F1-NW layer: NW clones of the F1-N core

Diagonal (single-`w`) word-coupled clones of the F1-N layer: the write-window
helpers, the (1/5)-(3/5) analytic inputs, the endpoint recurrence, the joint
step core and the assemblies down to `paper3F1NW_weightedDefect_summable`.
Levels (window hulls, recurrence constants `paper3F1CwinDefN`,
`paper3F1TubeRadiusN`, `10·bgpScale`, `bgpScale·e^{198/199}`) are kept at the
plain N scale — they are rate-independent hull data, and the PROVED
(4/5)/(5/5)-NW inputs consume exactly these N-level constants; only the
family, the gate RATES (`450·bgpScale → 450·bgpScaleW w` etc.) and the
kernel masses switch to the word-coupled scale. -/

/-- The word-coupled prefix drift envelope is dominated by the plain-N one:
the NW rate is faster, the reserve transfers for free. -/
theorem δuWritePrefixNW_le_δuWritePrefixN (w : ℕ) {Bzu : ℝ}
    (hBzu0 : 0 ≤ Bzu) (j : ℕ) :
    δuWritePrefixNW w Bzu j ≤ δuWritePrefixN Bzu j := by
  unfold δuWritePrefixNW δuWritePrefixN
  have hrate : selectorUSettledRate_N ≤ selectorUSettledRate_NW w := by
    rw [selectorUSettledRate_N_eq, selectorUSettledRate_NW_eq w]
    nlinarith [bgpScaleR_le_bgpScaleWR w, bgpScaleR_pos]
  have hws0 : 0 ≤ selectorMUWriteStartTime j :=
    selectorMUWriteStartTime_nonneg j
  have hexp : Real.exp (-(selectorUSettledRate_NW w * selectorMUWriteStartTime j)) ≤
      Real.exp (-(selectorUSettledRate_N * selectorMUWriteStartTime j)) := by
    apply Real.exp_le_exp.mpr
    nlinarith [mul_le_mul_of_nonneg_right hrate hws0]
  have hπ : (0 : ℝ) ≤ Real.pi / 3 := by positivity
  exact mul_le_mul_of_nonneg_left
    (mul_le_mul_of_nonneg_left hexp hπ) hBzu0

/-- The word-coupled settled drift envelope is dominated by the plain-N one. -/
theorem δuSettledNW_le_δuSettledN (w : ℕ) {Bzu : ℝ}
    (hBzu0 : 0 ≤ Bzu) (j : ℕ) :
    δuSettledNW w Bzu j ≤ δuSettledN Bzu j := by
  unfold δuSettledNW δuSettledN
  have hrate : selectorUSettledRate_N ≤ selectorUSettledRate_NW w := by
    rw [selectorUSettledRate_N_eq, selectorUSettledRate_NW_eq w]
    nlinarith [bgpScaleR_le_bgpScaleWR w, bgpScaleR_pos]
  have hwh0 : 0 ≤ selectorMUWriteHoldTime j := by
    unfold selectorMUWriteHoldTime
    positivity
  have hexp : Real.exp (-(selectorUSettledRate_NW w * selectorMUWriteHoldTime j)) ≤
      Real.exp (-(selectorUSettledRate_N * selectorMUWriteHoldTime j)) := by
    apply Real.exp_le_exp.mpr
    nlinarith [mul_le_mul_of_nonneg_right hrate hwh0]
  have hπ : (0 : ℝ) ≤ Real.pi / 3 := by positivity
  exact mul_le_mul_of_nonneg_left
    (mul_le_mul_of_nonneg_left hexp hπ) hBzu0


/-! #### The crude inter-read mixture-box constants and their arithmetic -/

/-- Trap-hull constant for the read-to-z-off `z` box:
`Cwin + 2·D_U + 1` covers the read-time entry `|z(wr)| ≤ Cwin + r + 2·D_U`
and the `2·D_U` mix range. -/
noncomputable def paper3F1MixC0NW : ℝ :=
  paper3F1CwinDefN + 2 * D_U + 1

/-- The crude inter-read `|mix − z|` box level:
`Emix + C0 + 2` where `Emix = 2·D_U + 4000·D_U·(C0 + 1 + 2·D_U)` is the
affine branch-evaluation hull over the `C0 + 1` coordinate box. -/
noncomputable def paper3F1MixCrudeBoxNW : ℝ :=
  2 * D_U + 4000 * D_U * (paper3F1MixC0NW + 1 + 2 * D_U) +
    paper3F1MixC0NW + 2

theorem paper3F1MixC0NW_nonneg : 0 ≤ paper3F1MixC0NW := by
  unfold paper3F1MixC0NW
  have h1 := paper3F1CwinDefN_nonneg
  have h2 := D_U_nonneg
  linarith

theorem paper3F1MixCrudeBoxNW_nonneg : 0 ≤ paper3F1MixCrudeBoxNW := by
  unfold paper3F1MixCrudeBoxNW
  have h1 := paper3F1MixC0NW_nonneg
  have h2 := D_U_nonneg
  nlinarith

/-- The crude box swallows the segment-A bound `2·D_U + C0`. -/
theorem paper3F1MixCrudeBoxNW_ge_segA :
    2 * D_U + paper3F1MixC0NW ≤ paper3F1MixCrudeBoxNW := by
  unfold paper3F1MixCrudeBoxNW
  have h1 := paper3F1MixC0NW_nonneg
  have h2 := D_U_nonneg
  nlinarith

theorem paper3NW_mixCrudeBox_le_exp_generic {s : ℝ} (hs : 4 ≤ s) :
    2 * (2 * s) +
      4000 * (2 * s) * ((s * Real.exp 200 + 2 * (2 * s) + 1) + 1 + 2 * (2 * s)) +
      (s * Real.exp 200 + 2 * (2 * s) + 1) + 2 ≤ Real.exp (230 * s) := by
  have hE1 : (1 : ℝ) ≤ Real.exp 200 := by
    calc (1 : ℝ) = Real.exp 0 := Real.exp_zero.symm
      _ ≤ Real.exp 200 := Real.exp_le_exp.mpr (by norm_num)
  have hE0 : (0 : ℝ) ≤ Real.exp 200 := le_trans zero_le_one hE1
  have hY1 : (1 : ℝ) ≤ Real.exp (2 * s) := by
    calc (1 : ℝ) = Real.exp 0 := Real.exp_zero.symm
      _ ≤ Real.exp (2 * s) := Real.exp_le_exp.mpr (by linarith)
  have hY0 : (0 : ℝ) ≤ Real.exp (2 * s) := le_trans zero_le_one hY1
  have hsexp : s + 1 ≤ Real.exp s := Real.add_one_le_exp s
  have hsY : s ≤ Real.exp (2 * s) := by
    have h2 : Real.exp s ≤ Real.exp (2 * s) := Real.exp_le_exp.mpr (by linarith)
    linarith
  have hs2Y : s ^ 2 ≤ Real.exp (2 * s) := by
    have h2 : Real.exp s * Real.exp s = Real.exp (2 * s) := by
      rw [← Real.exp_add]; congr 1; ring
    nlinarith [mul_self_le_mul_self (show (0 : ℝ) ≤ s by linarith)
      (show s ≤ Real.exp s by linarith)]
  have hYE1 : (1 : ℝ) ≤ Real.exp (2 * s) * Real.exp 200 := by
    nlinarith [mul_le_mul_of_nonneg_left hE1 hY0]
  have hYE0 : (0 : ℝ) ≤ Real.exp (2 * s) * Real.exp 200 := le_trans zero_le_one hYE1
  have p1 : s ^ 2 * Real.exp 200 ≤ Real.exp (2 * s) * Real.exp 200 :=
    mul_le_mul_of_nonneg_right hs2Y hE0
  have p2 : s * Real.exp 200 ≤ Real.exp (2 * s) * Real.exp 200 :=
    mul_le_mul_of_nonneg_right hsY hE0
  have p3 : s ^ 2 ≤ Real.exp (2 * s) * Real.exp 200 := by
    nlinarith [mul_le_mul_of_nonneg_left hE1 hY0]
  have p4 : s ≤ Real.exp (2 * s) * Real.exp 200 := by
    nlinarith [mul_le_mul_of_nonneg_left hE1 hY0]
  have key : 2 * (2 * s) +
      4000 * (2 * s) * ((s * Real.exp 200 + 2 * (2 * s) + 1) + 1 + 2 * (2 * s)) +
      (s * Real.exp 200 + 2 * (2 * s) + 1) + 2
      ≤ 88012 * (Real.exp (2 * s) * Real.exp 200) := by
    nlinarith [p1, p2, p3, p4, hYE1]
  have h356 : (357 : ℝ) ≤ Real.exp 356 := by
    have := Real.add_one_le_exp (356 : ℝ); linarith
  have h712 : (127449 : ℝ) ≤ Real.exp 712 := by
    have h2 : Real.exp 356 * Real.exp 356 = Real.exp 712 := by
      rw [← Real.exp_add]; norm_num
    nlinarith [mul_self_le_mul_self (show (0 : ℝ) ≤ 357 by norm_num) h356]
  have hbig : (88012 : ℝ) ≤ Real.exp (228 * s - 200) := by
    have hmono : Real.exp 712 ≤ Real.exp (228 * s - 200) :=
      Real.exp_le_exp.mpr (by linarith)
    linarith
  have hstep : (88012 : ℝ) * (Real.exp (2 * s) * Real.exp 200)
      ≤ Real.exp (228 * s - 200) * (Real.exp (2 * s) * Real.exp 200) :=
    mul_le_mul_of_nonneg_right hbig hYE0
  have hsplit : Real.exp (228 * s - 200) * (Real.exp (2 * s) * Real.exp 200)
      = Real.exp (230 * s) := by
    rw [← Real.exp_add, ← Real.exp_add]; congr 1; ring
  linarith [key, hstep, hsplit.le]

theorem paper3NW_freeze_kill_generic {s sW a : ℝ} (hs : 4 ≤ s) (hssW : s ≤ sW) (ha : 3 ≤ a) :
    Real.exp (230 * s) * Real.exp (-(200 * sW * a)) / (200 * sW) ≤ 1 / 2 := by
  have hsW4 : (4 : ℝ) ≤ sW := le_trans hs hssW
  have hsW0 : (0 : ℝ) < 200 * sW := by linarith
  have hcomb : Real.exp (230 * s) * Real.exp (-(200 * sW * a))
      = Real.exp (230 * s - 200 * sW * a) := by
    rw [← Real.exp_add]; congr 1
  have hle0 : 230 * s - 200 * sW * a ≤ 0 := by
    have h1 : 200 * sW * 3 ≤ 200 * sW * a :=
      mul_le_mul_of_nonneg_left ha (by linarith)
    linarith
  have h1 : Real.exp (230 * s - 200 * sW * a) ≤ 1 := by
    calc Real.exp (230 * s - 200 * sW * a) ≤ Real.exp 0 := Real.exp_le_exp.mpr hle0
      _ = 1 := Real.exp_zero
  rw [hcomb, div_le_iff₀ hsW0]
  nlinarith

theorem paper3NW_earlyPiece_arith_big {sR X Bv : ℝ} (hs1 : 1 ≤ sR) (hB0 : 0 ≤ Bv)
    (hBle : Bv ≤ Real.exp (230 * sR)) (hX : Real.exp (175 * sR) ≤ X) :
    Real.exp (-(2 * Real.pi / 3 * X)) * (X * Bv) * (Real.pi / 3) ≤ 1 / 2 := by
  have hX0 : (0 : ℝ) < X := lt_of_lt_of_le (Real.exp_pos _) hX
  have hpi3 : (3 : ℝ) ≤ Real.pi := Real.pi_gt_three.le
  have hpi4 : Real.pi ≤ 4 := Real.pi_le_four
  have hA : Real.exp (-(2 * Real.pi / 3 * X)) ≤ Real.exp (-(2 * X)) := by
    apply Real.exp_le_exp.mpr
    have h : 2 * X ≤ 2 * Real.pi / 3 * X := by
      nlinarith [mul_nonneg (sub_nonneg.mpr hpi3) hX0.le]
    linarith
  have hXe : X * Real.exp (-(2 * X)) ≤ Real.exp (-X) := by
    have h1 : X ≤ Real.exp X := by
      have := Real.add_one_le_exp X; linarith
    have h2 : Real.exp X * Real.exp (-(2 * X)) = Real.exp (-X) := by
      rw [← Real.exp_add]; congr 1; ring
    calc X * Real.exp (-(2 * X)) ≤ Real.exp X * Real.exp (-(2 * X)) :=
          mul_le_mul_of_nonneg_right h1 (Real.exp_pos _).le
      _ = Real.exp (-X) := h2
  have hBv : Real.exp (-X) * Bv ≤ Real.exp (230 * sR - X) := by
    have h2 : Real.exp (-X) * Real.exp (230 * sR) = Real.exp (230 * sR - X) := by
      rw [← Real.exp_add]; congr 1; ring
    calc Real.exp (-X) * Bv ≤ Real.exp (-X) * Real.exp (230 * sR) :=
          mul_le_mul_of_nonneg_left hBle (Real.exp_pos _).le
      _ = Real.exp (230 * sR - X) := h2
  have hq : (175 * sR) ^ 2 / 4 ≤ Real.exp (175 * sR) := by
    have h1 : 175 * sR / 2 + 1 ≤ Real.exp (175 * sR / 2) := Real.add_one_le_exp _
    have h2 : Real.exp (175 * sR / 2) * Real.exp (175 * sR / 2) = Real.exp (175 * sR) := by
      rw [← Real.exp_add]; congr 1; ring
    nlinarith [mul_self_le_mul_self (show (0 : ℝ) ≤ 175 * sR / 2 + 1 by linarith) h1]
  have hX2 : 230 * sR + 2 ≤ X := by
    nlinarith [sq_nonneg (sR - 1)]
  have hsmall : Real.exp (230 * sR - X) ≤ 3 / 8 := by
    have h3 : (3 : ℝ) ≤ Real.exp 2 := by
      have := Real.add_one_le_exp (2 : ℝ); linarith
    have hm : Real.exp (230 * sR - X) ≤ Real.exp (-2 : ℝ) :=
      Real.exp_le_exp.mpr (by linarith)
    have hinv : Real.exp (-2 : ℝ) * Real.exp (2 : ℝ) = 1 := by
      rw [← Real.exp_add]; norm_num
    have hp : (0 : ℝ) ≤ Real.exp (-2 : ℝ) := (Real.exp_pos _).le
    nlinarith [mul_le_mul_of_nonneg_left h3 hp]
  have hcore : Real.exp (-(2 * Real.pi / 3 * X)) * (X * Bv) ≤ 3 / 8 := by
    calc Real.exp (-(2 * Real.pi / 3 * X)) * (X * Bv)
        ≤ Real.exp (-(2 * X)) * (X * Bv) :=
          mul_le_mul_of_nonneg_right hA (mul_nonneg hX0.le hB0)
      _ = (X * Real.exp (-(2 * X))) * Bv := by ring
      _ ≤ Real.exp (-X) * Bv := mul_le_mul_of_nonneg_right hXe hB0
      _ ≤ Real.exp (230 * sR - X) := hBv
      _ ≤ 3 / 8 := hsmall
  have hpos : (0 : ℝ) ≤ Real.exp (-(2 * Real.pi / 3 * X)) * (X * Bv) :=
    mul_nonneg (Real.exp_pos _).le (mul_nonneg hX0.le hB0)
  calc Real.exp (-(2 * Real.pi / 3 * X)) * (X * Bv) * (Real.pi / 3)
      ≤ (3 / 8) * (Real.pi / 3) := mul_le_mul_of_nonneg_right hcore (by linarith)
    _ ≤ (3 / 8) * (4 / 3) := by linarith
    _ ≤ 1 / 2 := by norm_num

/-- Symbolic cap: the crude box is at most `e^{230·bgpScale}`. -/
theorem paper3F1MixCrudeBoxNW_le_exp :
    paper3F1MixCrudeBoxNW ≤ Real.exp (230 * (bgpScale : ℝ)) := by
  have hgen := paper3NW_mixCrudeBox_le_exp_generic bgpScaleR_ge_four
  have hD : (D_U : ℝ) ≤ 2 * (bgpScale : ℝ) := D_U_le_two_bgpScale
  have hD0 := D_U_nonneg
  have hCwin : paper3F1CwinDefN ≤ (bgpScale : ℝ) * Real.exp (200 : ℝ) :=
    paper3F1CwinDefN_le_scale_exp200
  have hCwin0 := paper3F1CwinDefN_nonneg
  have hs0 : (0 : ℝ) < (bgpScale : ℝ) := bgpScaleR_pos
  have hE0 : (0 : ℝ) ≤ Real.exp (200 : ℝ) := (Real.exp_pos _).le
  unfold paper3F1MixCrudeBoxNW paper3F1MixC0NW
  have hB : (paper3F1CwinDefN + 2 * D_U + 1) + 1 + 2 * D_U ≤
      ((bgpScale : ℝ) * Real.exp 200 + 2 * (2 * (bgpScale : ℝ)) + 1) + 1 +
        2 * (2 * (bgpScale : ℝ)) := by nlinarith
  have hB0 : (0 : ℝ) ≤ (paper3F1CwinDefN + 2 * D_U + 1) + 1 + 2 * D_U := by
    nlinarith
  have hDD : 4000 * D_U ≤ 4000 * (2 * (bgpScale : ℝ)) := by nlinarith
  have hDD0 : (0 : ℝ) ≤ 4000 * (2 * (bgpScale : ℝ)) := by nlinarith
  have hprod := mul_le_mul hDD hB hB0 hDD0
  nlinarith [hgen, hprod]

/-- Freeze kill at the schedule: the crude box times the suppressed z-off
gate mass is strictly below `1`. -/
theorem paper3F1MixCrudeBoxNW_freeze_lt_one (w j : ℕ) :
    paper3F1MixCrudeBoxNW *
      Real.exp (-(200 * (bgpScaleW w : ℝ) * selectorMUZOffStart j)) /
      (200 * (bgpScaleW w : ℝ)) < 1 := by
  have ha3 : (3 : ℝ) ≤ selectorMUZOffStart j := by
    unfold selectorMUZOffStart
    nlinarith [Real.pi_gt_three, (Nat.cast_nonneg j : (0 : ℝ) ≤ (j : ℝ)),
      Real.pi_pos]
  have hkill := paper3NW_freeze_kill_generic bgpScaleR_ge_four
    (bgpScaleR_le_bgpScaleWR w) ha3
  have hCle := paper3F1MixCrudeBoxNW_le_exp
  have hden : (0 : ℝ) < 200 * (bgpScaleW w : ℝ) := by
    nlinarith [bgpScaleWR_pos w]
  have hexp0 := (Real.exp_pos
    (-(200 * (bgpScaleW w : ℝ) * selectorMUZOffStart j))).le
  have h1 : paper3F1MixCrudeBoxNW *
      Real.exp (-(200 * (bgpScaleW w : ℝ) * selectorMUZOffStart j)) /
      (200 * (bgpScaleW w : ℝ)) ≤
      Real.exp (230 * (bgpScale : ℝ)) *
        Real.exp (-(200 * (bgpScaleW w : ℝ) * selectorMUZOffStart j)) /
        (200 * (bgpScaleW w : ℝ)) :=
    paper3NW4_div_mono hden
      (mul_le_mul_of_nonneg_right hCle hexp0)
  linarith [hkill]

/-- Generalized-radius affine branch-evaluation box (the
`paper3NW4_eval_abs_of_coord_bound` shape at an arbitrary radius `R`). -/
theorem paper3NW4_eval_abs_of_coord_bound_gen (v : UniversalLocalView)
    (i : Fin d_U) (c : UConf) {R : ℝ} (hR : 0 ≤ R) {x : Fin d_U → ℝ}
    (hx : |x i - stackMachineEncodingU.enc c i| ≤ R) :
    |BranchData.evalBranch (branchU v) x i| ≤
      2 * D_U + 4000 * D_U * R := by
  classical
  set xe : Fin d_U → ℝ := fun i' => stackMachineEncodingU.enc c i'
    with hxe_def
  have hr : r_LE_U = 1 / 1000 := rfl
  have hte : EncodingTube stackMachineEncodingU r_LE_U c xe := by
    intro i'
    rw [hxe_def]
    simp only [sub_self, abs_zero]
    norm_num [hr]
  have hee := branchU_evalBranch_abs_le_two_D_U hte v i
  have hdiff : |BranchData.evalBranch (branchU v) x i -
      BranchData.evalBranch (branchU v) xe i| =
      |(((branchU v).action i).scale : ℝ)| * |x i - xe i| := by
    show |BranchAction.evalReal B_U ((branchU v).action i) (x i) -
      BranchAction.evalReal B_U ((branchU v).action i) (xe i)| = _
    exact BranchAction.affine_lipschitz B_U _ _ _
  have hscale := paper3NW4_branchU_scale_abs v i
  have hD0 := D_U_nonneg
  have hxen : |x i - xe i| ≤ R := by
    rw [hxe_def]
    exact hx
  have h1 : |BranchData.evalBranch (branchU v) x i -
      BranchData.evalBranch (branchU v) xe i| ≤ 4000 * D_U * R := by
    rw [hdiff]
    calc |(((branchU v).action i).scale : ℝ)| * |x i - xe i|
        ≤ (4000 * D_U) * R :=
          mul_le_mul hscale hxen (abs_nonneg _) (by nlinarith)
      _ = 4000 * D_U * R := by ring
  calc |BranchData.evalBranch (branchU v) x i|
      ≤ |BranchData.evalBranch (branchU v) x i -
          BranchData.evalBranch (branchU v) xe i| +
        |BranchData.evalBranch (branchU v) xe i| := by
        have := abs_sub_le (BranchData.evalBranch (branchU v) x i)
          (BranchData.evalBranch (branchU v) xe i) 0
        simpa using this
    _ ≤ 4000 * D_U * R + 2 * D_U := add_le_add h1 hee
    _ = 2 * D_U + 4000 * D_U * R := by ring

/-- **The prewrite-tail u-tube, extracted from the `paper3NW4_one_cycle`
first-exit**: conditional on the cycle-`j` boundary tube and window envelope,
the word-coupled `u` stays within `1/3` of the NEXT encoding on the whole
prewrite tail `[zOffEnd j, ws (j+1)]`.  (Verbatim prefix of the one-cycle
proof; the payoff is the third-tube branch hull on the tail, which the
inter-read mixture box discharge consumes.) -/
theorem paper3NW4_tail_tube (wg w j : ℕ)
    (htube0 : ∀ i,
      |((paper3HeadlineSolFamNW wg) w).u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤
        paper3F1TubeRadiusN paper3F1CwinDefN)
    (hwin : ∀ i : Fin d_U, ∀ t ∈ Icc (selectorMUWriteStartTime j)
        (selectorMUWriteReadTime j),
      |((paper3HeadlineSolFamNW wg) w).z t i -
        ((paper3HeadlineSolFamNW wg) w).u t i| ≤ paper3F1CwinDefN) :
    ∀ t ∈ Icc (selectorMUZOffEnd j) (selectorMUWriteStartTime (j + 1)),
      ∀ i : Fin d_U,
        |((paper3HeadlineSolFamNW wg) w).u t i -
          stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤ 1 / 3 := by
  classical
  haveI : Nonempty UniversalLocalView := ⟨defaultLocalViewU⟩
  set sol := (paper3HeadlineSolFamNW wg) w with hsol
  obtain ⟨hT, hD⟩ := paper3NW4_tube_maintenance wg w j htube0 hwin
  have hzoff := paper3NW4_z_off_box wg w j htube0 hwin
  set Wc : Fin d_U → ℝ := fun i =>
    stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
      |sol.u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| +
      (6 * paper3NW4Drift wg j + 4 * D_U * paper3NW4EpsLam wg j) with hWc_def
  set zcLeg : ℝ := 2 * paper3F1CwinDefN *
    Real.exp (-(Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
      selectorMUWriteHoldTime j))) with hzc_def
  set fzLeg : ℝ := paper3NW4C0 *
    Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffStart j)) /
    (200 * (bgpScaleW wg : ℝ)) with hfz_def
  set cpLeg : ℝ := 5 * D_U *
    Real.exp (-(2 * Real.pi / 3 * Real.exp (50 * (bgpScaleW wg : ℝ) *
      selectorMUUActiveStart j))) with hcp_def
  set tlLeg : ℝ := (4 * D_U + 3) *
    Real.exp (-(200 * (bgpScaleW wg : ℝ) * selectorMUZOffEnd j)) /
    (200 * (bgpScaleW wg : ℝ)) with htl_def
  have hS0 : (0 : ℝ) < (bgpScaleW wg : ℝ) := bgpScaleWR_pos wg
  have hD8 := paper3Headline_D_U_ge_eight
  have hz0 : 0 ≤ selectorMUZOffStart j := by
    unfold selectorMUZOffStart
    have hπ := Real.pi_pos
    have hj : (0 : ℝ) ≤ (j : ℝ) := Nat.cast_nonneg j
    nlinarith
  have hz0e : 0 ≤ selectorMUZOffEnd j :=
    le_trans hz0 (paper3NW4_zOffStart_le_zOffEnd j)
  have hsm := paper3NW4_currency_small wg j
  have hzbox : ∀ t ∈ Icc (selectorMUZOffStart j) (selectorMUZOffEnd j),
      ∀ i : Fin d_U,
      |sol.z t i - stackMachineEncodingU.enc (paper3F1Cfg w (j + 1)) i| ≤
        Wc i + zcLeg + fzLeg := hzoff
  have hWc_small : ∀ i, Wc i ≤ 8 / 1000 := by
    intro i
    have hd := le_trans (paper3NW4_leg_drift wg j) hsm
    have he := le_trans (paper3NW4_leg_eps wg j) hsm
    have hmult := coordMultiplierU_le_six (paper3F1Cfg w j) i
    have hBE : |sol.u (selectorMUWriteStartTime j) i -
        stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ r_LE_U :=
      le_trans (htube0 i) paper3NW4_TubeRadiusN_le_r
    have hBE0 := abs_nonneg (sol.u (selectorMUWriteStartTime j) i -
      stackMachineEncodingU.enc (paper3F1Cfg w j) i)
    have hr : r_LE_U = 1 / 1000 := rfl
    have hm : stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
        |sol.u (selectorMUWriteStartTime j) i -
          stackMachineEncodingU.enc (paper3F1Cfg w j) i| ≤ 6 / 1000 := by
      calc stackMachineEncodingU.coordMultiplier (paper3F1Cfg w j) i *
          |sol.u (selectorMUWriteStartTime j) i -
            stackMachineEncodingU.enc (paper3F1Cfg w j) i|
          ≤ 6 * r_LE_U := mul_le_mul hmult hBE hBE0 (by norm_num)
        _ = 6 / 1000 := by rw [hr]; ring
    rw [hWc_def]
    linarith
