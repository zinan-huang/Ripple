/-- Focused version of `SingletonIndexModFiveWitness` for the test
`E={2}` exceptional construction.

The dynamical part is useful and formalized above, but this fixed index does
not close all `d % 6 = 5`: for some `d`, `Nat.choose (d+1) 2` has no odd
prime divisor with valuation one, so the final exact-degree construction must
allow a variable singleton index. -/
def SingletonTwoModFiveWitness : Prop :=
  ∀ (d : ℕ), 5 ≤ d → Odd d → d % 6 = 5 →
    ∃ (j : Fin (d + 2)) (ν : ℝ) (q : ℚ) (P : Polynomial ℤ),
      j.val = 2 ∧
      ν ∈ Set.Icc (0 : ℝ) 1 ∧
      0 ≤ (q : ℝ) ∧ (q : ℝ) ≤ 1 ∧
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn ν = 0 ∧
      (((q : ℝ) < ν ∧
          ∀ y, (q : ℝ) ≤ y → y < ν →
            0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y) ∨
       (ν < (q : ℝ) ∧
          ∀ y, ν < y → y ≤ (q : ℝ) →
            (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y < 0)) ∧
      P.natDegree = d ∧
      Polynomial.eval₂ (Int.castRingHom ℝ) ν P = 0 ∧
      Irreducible P

/-- Minimal remaining algebraic input for closing the fixed `E={2}` branch.

All dynamical and polynomial-evaluation work is already formalized; this
property isolates the remaining irreducibility theorem. -/
def SingletonTwoIrreducibilityWitness : Prop :=
  ∀ (d : ℕ), 5 ≤ d → d % 6 = 5 → Irreducible (singletonTwoRootPolynomial d)

/-- Newton-polygon version of the remaining fixed `E={2}` algebraic input.

This is the form suited for an Eisenstein-Dumas proof.  It is not an
additional modeling assumption: `singletonTwoNewtonPolygonWitness_of_irreducibility`
below converts it back to the direct root polynomial by `mirror`. -/
def SingletonTwoNewtonPolygonWitness : Prop :=
  ∀ (d : ℕ), 5 ≤ d → d % 6 = 5 →
    Irreducible (singletonTwoNewtonPolygonPolynomial d)

def SingletonTwoClosedNewtonWitness : Prop :=
  ∀ (d : ℕ), 5 ≤ d → d % 6 = 5 →
    Irreducible (singletonTwoClosedNewtonPolynomial d)

theorem singletonTwoNewtonPolygonWitness_of_closed
    (hC : SingletonTwoClosedNewtonWitness) : SingletonTwoNewtonPolygonWitness := by
  intro d hd5 hmod
  have hodd : Odd d := by
    rw [Nat.odd_iff]
    omega
  rw [singletonTwoNewtonPolygonPolynomial_eq_closed d (by omega) hodd]
  exact hC d hd5 hmod

theorem singletonTwoIrreducibilityWitness_of_newtonPolygon
    (hN : SingletonTwoNewtonPolygonWitness) : SingletonTwoIrreducibilityWitness := by
  intro d hd5 hmod
  exact singletonTwoRootPolynomial_irreducible_of_newtonPolygon (hN d hd5 hmod)

theorem singletonTwoIrreducibilityWitness_of_closed
    (hC : SingletonTwoClosedNewtonWitness) : SingletonTwoIrreducibilityWitness :=
  singletonTwoIrreducibilityWitness_of_newtonPolygon
    (singletonTwoNewtonPolygonWitness_of_closed hC)

/-- The fixed `E={2}` branch follows from irreducibility of its displayed
degree-`d` root polynomial. -/
theorem singletonTwoModFiveWitness_of_irreducibility
    (hI : SingletonTwoIrreducibilityWitness) : SingletonTwoModFiveWitness := by
  intro d hd5 _hodd hmod
  obtain ⟨ν, q, hνq, hq0, hq1, hroot, hpos, _hcomp⟩ :=
    singletonTwo_root_exists_and_computable_mod5 d hd5 hmod
  refine ⟨⟨2, by omega⟩, ν, q, singletonTwoRootPolynomial d, rfl, ?_, hq0, hq1,
    hroot, ?_, singletonTwoRootPolynomial_natDegree d (by omega), ?_, hI d hd5 hmod⟩
  · exact ⟨le_trans hq0 (le_of_lt hνq.1), le_of_lt hνq.2⟩
  · exact Or.inl ⟨hνq.1, hpos⟩
  · exact singletonTwoRootPolynomial_eval_of_drift_root d (by omega)
      (lt_of_le_of_lt hq0 hνq.1) hroot

theorem singletonTwoModFiveWitness_of_newtonPolygon
    (hN : SingletonTwoNewtonPolygonWitness) : SingletonTwoModFiveWitness :=
  singletonTwoModFiveWitness_of_irreducibility
    (singletonTwoIrreducibilityWitness_of_newtonPolygon hN)

