private lemma singletonTwoNewtonPolygonPolynomial_eq_closed
    (d : ℕ) (hd : 2 ≤ d) (hodd : Odd d) :
    singletonTwoNewtonPolygonPolynomial d = singletonTwoClosedNewtonPolynomial d := by
  ext n
  by_cases hnlt : n < d
  · have hnle : n ≤ d := le_of_lt hnlt
    unfold singletonTwoNewtonPolygonPolynomial singletonTwoClosedNewtonPolynomial
    rw [Polynomial.coeff_neg, Polynomial.coeff_mirror,
      singletonTwoRootPolynomial_natDegree d (by omega : 1 ≤ d),
      singletonTwoRootPolynomial_natTrailingDegree d, Nat.add_zero]
    have hrev : Polynomial.revAt d n = d - n := by
      rw [Polynomial.revAt_le hnle]
    rw [hrev]
    have hpos : 0 < d - n := by omega
    rw [singletonTwoRootPolynomial_coeff_pos_eq_closed d (d - n) hpos hodd]
    rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow,
      if_neg (show n ≠ d by omega), zero_sub, Polynomial.coeff_C_mul]
    have hX :
        (Polynomial.X * ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff (d - n) =
          (((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff n := by
      have hdneq : d - n = (d - n - 1) + 1 := by omega
      rw [hdneq, Polynomial.coeff_X_mul]
      change (((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff (d - n - 1) =
        (((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff n
      rw [show d - n - 1 = d - 1 - n by omega]
      have heven : Even (d - 1) := by
        obtain ⟨m, hm⟩ := hodd
        exact ⟨m, by omega⟩
      exact coeff_X_sub_one_pow_symm_of_even (d - 1) n heven (by omega)
    rw [hX]
  · have hdn : d ≤ n := le_of_not_gt hnlt
    by_cases hneq : n = d
    · subst n
      unfold singletonTwoNewtonPolygonPolynomial singletonTwoClosedNewtonPolynomial
      rw [Polynomial.coeff_neg, Polynomial.coeff_mirror,
        singletonTwoRootPolynomial_natDegree d (by omega : 1 ≤ d),
        singletonTwoRootPolynomial_natTrailingDegree d, Nat.add_zero,
        Polynomial.revAt_le (le_refl d), Nat.sub_self,
        singletonTwoRootPolynomial_coeff_zero]
      rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow_self]
      have hterm :
          (Polynomial.C (Nat.choose (d + 1) 2 : ℤ) *
            ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff d = 0 := by
        have hdeg :
            (Polynomial.C (Nat.choose (d + 1) 2 : ℤ) *
              ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).natDegree < d := by
          rw [Polynomial.natDegree_C_mul]
          · have hbase : ((Polynomial.X : Polynomial ℤ) - 1).natDegree = 1 := by
              simpa using Polynomial.natDegree_X_sub_C (1 : ℤ)
            rw [Polynomial.natDegree_pow, hbase]
            omega
          · exact Int.ofNat_ne_zero.mpr (Nat.choose_pos (by omega : 2 ≤ d + 1)).ne'
        exact Polynomial.coeff_eq_zero_of_natDegree_lt hdeg
      rw [hterm]
      ring
    · have hgt : d < n := lt_of_le_of_ne hdn (Ne.symm hneq)
      have hN :
          (singletonTwoNewtonPolygonPolynomial d).coeff n = 0 := by
        apply Polynomial.coeff_eq_zero_of_natDegree_lt
        rw [singletonTwoNewtonPolygonPolynomial_natDegree d (by omega : 1 ≤ d)]
        exact hgt
      have hC :
          (singletonTwoClosedNewtonPolynomial d).coeff n = 0 := by
        apply Polynomial.coeff_eq_zero_of_natDegree_lt
        rw [singletonTwoClosedNewtonPolynomial_natDegree d hd]
        exact hgt
      rw [hN, hC]

private lemma singletonTwoNewtonPolygonPolynomial_coeff_dvd_choose
