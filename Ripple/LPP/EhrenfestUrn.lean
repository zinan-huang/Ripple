        6 ∣ c ∧ c % p = 1 ∧ 4 ∣ c ∧ 3 ^ q ∣ c ∧
        1 < t ∧ t < c ∧ p < q ∧ q < c ∧
        ¬ q ∣ c ∧ ¬ q ∣ t ∧ Nat.Coprime c t ∧
