    exact hp2not_nat hp2_nat

def HasSquarefreePrimeFactor (n : ℕ) : Prop :=
  ∃ p : ℕ, p.Prime ∧ p ∣ n ∧ ¬ p ^ 2 ∣ n

def HasOddSquarefreePrimeFactor (n : ℕ) : Prop :=
  ∃ p : ℕ, p.Prime ∧ p ≠ 2 ∧ p ∣ n ∧ ¬ p ^ 2 ∣ n

def SquarefullNat (n : ℕ) : Prop :=
  ∀ p : ℕ, p.Prime → p ∣ n → p ^ 2 ∣ n

def OddSquarefullNat (n : ℕ) : Prop :=
  ∀ p : ℕ, p.Prime → p ≠ 2 → p ∣ n → p ^ 2 ∣ n

def SquarefullAwayFromSixNat (n : ℕ) : Prop :=
  ∀ p : ℕ, p.Prime → p ≠ 2 → p ≠ 3 → p ∣ n → p ^ 2 ∣ n

def SquarefullAwayFromThirtyNat (n : ℕ) : Prop :=
  ∀ p : ℕ, p.Prime → p ≠ 2 → p ≠ 3 → p ≠ 5 → p ∣ n → p ^ 2 ∣ n

/-- Final squarefull-tail interface exposed by the multi-singleton route.

After the finite checks and the `j=2,...,6` singleton reductions, the
remaining non-Catalan arithmetic dependency is this narrow assertion: in the
exceptional congruence class, once `d = 6m - 1` is large and `9 | m`, the two
linear factors `d` and `m` cannot both be squarefull. -/
def NoSquarefullPairTailNat : Prop :=
  ∀ d : ℕ, 50000 ≤ d → d % 6 = 5 → 3 ^ 2 ∣ ((d + 1) / 6) →
    ¬ (SquarefullNat d ∧ SquarefullNat ((d + 1) / 6))

private lemma not_squarefullNat_iff_hasSquarefreePrimeFactor (n : ℕ) :
    ¬ SquarefullNat n ↔ HasSquarefreePrimeFactor n := by
  unfold SquarefullNat HasSquarefreePrimeFactor
  push Not
  rfl

private lemma not_oddSquarefullNat_iff_hasOddSquarefreePrimeFactor (n : ℕ) :
    ¬ OddSquarefullNat n ↔ HasOddSquarefreePrimeFactor n := by
  unfold OddSquarefullNat HasOddSquarefreePrimeFactor
  push Not
  rfl

