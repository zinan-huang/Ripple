        ((((d + 1 : ℕ) : ℝ) * ((d - 1 : ℕ) : ℝ) *
          ((d - 2 : ℕ) : ℝ) * ((d - 3 : ℕ) : ℝ) *
          ((d - 4 : ℕ) : ℝ)) / (23040 * (d : ℝ) ^ 4)) *
