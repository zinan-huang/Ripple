/-- The mirror-side polynomial for the fixed `E={2}` branch.

This is the Newton-polygon form of `singletonTwoRootPolynomial`: its lower
coefficients are all divisible by `Nat.choose (d+1) 2`, while the leading
coefficient is a unit. -/
private noncomputable def singletonTwoNewtonPolygonPolynomial (d : ℕ) : Polynomial ℤ :=
  - (singletonTwoRootPolynomial d).mirror

/-- Closed Newton-polygon form expected to coincide with
`singletonTwoNewtonPolygonPolynomial` for odd `d`.

This is the polynomial whose Newton polygon is directly visible:
`X^d - choose(d+1,2) * (X-1)^(d-1)`. -/
private noncomputable def singletonTwoClosedNewtonPolynomial (d : ℕ) : Polynomial ℤ :=
  Polynomial.X ^ d -
    Polynomial.C (Nat.choose (d + 1) 2 : ℤ) *
      ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)

/-- Trinomial form Mobius-equivalent to the fixed `E={2}` Newton-side
polynomial:

`Y^d - choose(d+1,2) * Y + choose(d+1,2)`.

For `Y = X/(X-1)`, multiplying by `(X-1)^d` gives
`X^d - choose(d+1,2) * (X-1)^(d-1)`, the closed form of the Newton-side
polynomial. -/
private noncomputable def singletonTwoTrinomialPolynomial (d : ℕ) : Polynomial ℤ :=
  Polynomial.X ^ d -
    Polynomial.C (Nat.choose (d + 1) 2 : ℤ) * Polynomial.X +
    Polynomial.C (Nat.choose (d + 1) 2 : ℤ)

private lemma singletonTwoTrinomialPolynomial_natDegree (d : ℕ) (hd : 2 ≤ d) :
    (singletonTwoTrinomialPolynomial d).natDegree = d := by
  unfold singletonTwoTrinomialPolynomial
  rw [Polynomial.natDegree_add_eq_left_of_natDegree_lt]
  · rw [Polynomial.natDegree_sub_eq_left_of_natDegree_lt]
    · simpa using Polynomial.natDegree_X_pow (R := ℤ) d
    · rw [Polynomial.natDegree_C_mul_X]
      · rw [Polynomial.natDegree_X_pow]
        omega
      · exact Int.ofNat_ne_zero.mpr (Nat.choose_pos (by omega : 2 ≤ d + 1)).ne'
  · rw [Polynomial.natDegree_sub_eq_left_of_natDegree_lt]
    · rw [Polynomial.natDegree_X_pow]
      rw [Polynomial.natDegree_C]
      omega
    · rw [Polynomial.natDegree_C_mul_X]
      · rw [Polynomial.natDegree_X_pow]
        omega
      · exact Int.ofNat_ne_zero.mpr (Nat.choose_pos (by omega : 2 ≤ d + 1)).ne'

private lemma singletonTwoTrinomialPolynomial_monic (d : ℕ) (hd : 2 ≤ d) :
    (singletonTwoTrinomialPolynomial d).Monic := by
  change (singletonTwoTrinomialPolynomial d).leadingCoeff = 1
  rw [Polynomial.leadingCoeff, singletonTwoTrinomialPolynomial_natDegree d hd]
  unfold singletonTwoTrinomialPolynomial
  rw [Polynomial.coeff_add, Polynomial.coeff_sub, Polynomial.coeff_X_pow_self]
  rw [Polynomial.coeff_C_mul, Polynomial.coeff_X_of_ne_one (R := ℤ) (by omega : d ≠ 1)]
  rw [Polynomial.coeff_C_ne_zero (a := (Nat.choose (d + 1) 2 : ℤ))
    (show d ≠ 0 by omega)]
  ring

private lemma coeff_X_sub_one_pow_symm_of_even (e n : ℕ) (he : Even e) (hn : n ≤ e) :
    (((Polynomial.X : Polynomial ℤ) - 1) ^ e).coeff (e - n) =
      (((Polynomial.X : Polynomial ℤ) - 1) ^ e).coeff n := by
  have hpoly :
      ((Polynomial.X : Polynomial ℤ) - 1) = Polynomial.X + Polynomial.C (-1 : ℤ) := by
    simp [sub_eq_add_neg]
  rw [hpoly, Polynomial.coeff_X_add_C_pow, Polynomial.coeff_X_add_C_pow]
  rw [Nat.choose_symm hn, Nat.sub_sub_self hn]
  have hiff : Even n ↔ Even (e - n) := by
    constructor
    · rintro ⟨b, hb⟩
      obtain ⟨a, ha⟩ := he
      refine ⟨a - b, by omega⟩
    · rintro ⟨b, hb⟩
      obtain ⟨a, ha⟩ := he
      refine ⟨a - b, by omega⟩
  rw [neg_one_pow_congr (R := ℤ) hiff]

private lemma singletonTwoClosedNewtonPolynomial_natDegree (d : ℕ) (hd : 2 ≤ d) :
    (singletonTwoClosedNewtonPolynomial d).natDegree = d := by
  unfold singletonTwoClosedNewtonPolynomial
  rw [Polynomial.natDegree_sub_eq_left_of_natDegree_lt]
  · rw [Polynomial.natDegree_X_pow]
  · rw [Polynomial.natDegree_C_mul]
    · have hbase : ((Polynomial.X : Polynomial ℤ) - 1).natDegree = 1 := by
        simpa using Polynomial.natDegree_X_sub_C (1 : ℤ)
      rw [Polynomial.natDegree_pow, hbase, Polynomial.natDegree_X_pow]
      omega
    · exact Int.ofNat_ne_zero.mpr (Nat.choose_pos (by omega : 2 ≤ d + 1)).ne'

private lemma singletonTwoClosedNewtonPolynomial_monic (d : ℕ) (hd : 2 ≤ d) :
    (singletonTwoClosedNewtonPolynomial d).Monic := by
  change (singletonTwoClosedNewtonPolynomial d).leadingCoeff = 1
  rw [Polynomial.leadingCoeff, singletonTwoClosedNewtonPolynomial_natDegree d hd]
  unfold singletonTwoClosedNewtonPolynomial
  rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow_self]
  have hdeg :
      (Polynomial.C (Nat.choose (d + 1) 2 : ℤ) *
        ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).natDegree < d := by
    rw [Polynomial.natDegree_C_mul]
    · have hbase : ((Polynomial.X : Polynomial ℤ) - 1).natDegree = 1 := by
        simpa using Polynomial.natDegree_X_sub_C (1 : ℤ)
      rw [Polynomial.natDegree_pow, hbase]
      omega
    · exact Int.ofNat_ne_zero.mpr (Nat.choose_pos (by omega : 2 ≤ d + 1)).ne'
  rw [Polynomial.coeff_eq_zero_of_natDegree_lt hdeg]
  ring

private lemma singletonTwoClosedNewtonPolynomial_coeff_zero (d : ℕ) (hd : 1 ≤ d) (hodd : Odd d) :
    (singletonTwoClosedNewtonPolynomial d).coeff 0 =
      - (Nat.choose (d + 1) 2 : ℤ) := by
  unfold singletonTwoClosedNewtonPolynomial
  rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow]
  rw [if_neg (show 0 ≠ d by omega), zero_sub, Polynomial.coeff_C_mul]
  have hpow : (((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff 0 = 1 := by
    rw [Polynomial.coeff_zero_eq_eval_zero]
    simp
    obtain ⟨m, hm⟩ := hodd
    rw [hm]
    have hsub : 2 * m + 1 - 1 = 2 * m := by omega
    rw [hsub, pow_mul]
    norm_num
  rw [hpow]
  ring

private lemma singletonTwoClosedNewtonPolynomial_coeff_dvd_choose
    (d n : ℕ) (hn : n < d) :
    (Nat.choose (d + 1) 2 : ℤ) ∣ (singletonTwoClosedNewtonPolynomial d).coeff n := by
  unfold singletonTwoClosedNewtonPolynomial
  rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow]
  rw [if_neg (show n ≠ d by omega), zero_sub, Polynomial.coeff_C_mul]
  exact dvd_neg.mpr ⟨(((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff n, rfl⟩

private lemma singletonTwoClosedNewtonPolynomial_pow_padicValNat_choose_dvd_coeff
    (d n p : ℕ) (hn : n < d) (hp : p.Prime) :
    (p : ℤ) ^ padicValNat p (Nat.choose (d + 1) 2) ∣
      (singletonTwoClosedNewtonPolynomial d).coeff n := by
  have hchoose_pos : 0 < Nat.choose (d + 1) 2 := Nat.choose_pos (by omega)
  have hpow_dvd_nat : p ^ padicValNat p (Nat.choose (d + 1) 2) ∣
      Nat.choose (d + 1) 2 := by
    haveI : Fact p.Prime := ⟨hp⟩
    exact pow_padicValNat_dvd
  have hpow_dvd_int :
      (p : ℤ) ^ padicValNat p (Nat.choose (d + 1) 2) ∣
        (Nat.choose (d + 1) 2 : ℤ) := by
    exact_mod_cast hpow_dvd_nat
  exact hpow_dvd_int.trans (singletonTwoClosedNewtonPolynomial_coeff_dvd_choose d n hn)

private lemma singletonTwoClosedNewtonPolynomial_coeff_zero_not_dvd_padicValNat_succ
    (d p : ℕ) (hd : 1 ≤ d) (hodd : Odd d) (hp : p.Prime) :
    ¬ (p : ℤ) ^ (padicValNat p (Nat.choose (d + 1) 2) + 1) ∣
      (singletonTwoClosedNewtonPolynomial d).coeff 0 := by
  intro hdiv
  haveI : Fact p.Prime := ⟨hp⟩
  have hchoose_pos : 0 < Nat.choose (d + 1) 2 := Nat.choose_pos (by omega)
  have hdivC_int :
      (p : ℤ) ^ (padicValNat p (Nat.choose (d + 1) 2) + 1) ∣
        (Nat.choose (d + 1) 2 : ℤ) := by
    rw [singletonTwoClosedNewtonPolynomial_coeff_zero d hd hodd] at hdiv
    exact dvd_neg.mp hdiv
  have hdivC_nat :
      p ^ (padicValNat p (Nat.choose (d + 1) 2) + 1) ∣
        Nat.choose (d + 1) 2 := by
    exact_mod_cast hdivC_int
  have hle :
      padicValNat p (Nat.choose (d + 1) 2) + 1 ≤
        padicValNat p (Nat.choose (d + 1) 2) :=
    (padicValNat_dvd_iff_le hchoose_pos.ne').mp hdivC_nat
  omega

private theorem singletonTwoClosedNewtonPolynomial_dumas_coefficient_data
    (d p : ℕ) (hd : 2 ≤ d) (hodd : Odd d) (hp : p.Prime) :
    (singletonTwoClosedNewtonPolynomial d).Monic ∧
      (singletonTwoClosedNewtonPolynomial d).natDegree = d ∧
      (p : ℤ) ^ padicValNat p (Nat.choose (d + 1) 2) ∣
        (singletonTwoClosedNewtonPolynomial d).coeff 0 ∧
      ¬ (p : ℤ) ^ (padicValNat p (Nat.choose (d + 1) 2) + 1) ∣
        (singletonTwoClosedNewtonPolynomial d).coeff 0 ∧
      ∀ n, n < d →
        (p : ℤ) ^ padicValNat p (Nat.choose (d + 1) 2) ∣
          (singletonTwoClosedNewtonPolynomial d).coeff n := by
  refine ⟨singletonTwoClosedNewtonPolynomial_monic d hd,
    singletonTwoClosedNewtonPolynomial_natDegree d hd, ?_, ?_, ?_⟩
  · exact singletonTwoClosedNewtonPolynomial_pow_padicValNat_choose_dvd_coeff d 0 p
      (by omega) hp
  · exact singletonTwoClosedNewtonPolynomial_coeff_zero_not_dvd_padicValNat_succ d p
      (by omega) hodd hp
  · intro n hn
    exact singletonTwoClosedNewtonPolynomial_pow_padicValNat_choose_dvd_coeff d n p hn hp

private lemma singletonTwoClosedNewtonPolynomial_map_zmod_eq_X_pow
    (d p : ℕ) (hpdvd : p ∣ Nat.choose (d + 1) 2) :
    (singletonTwoClosedNewtonPolynomial d).map (Int.castRingHom (ZMod p)) =
      (Polynomial.X : Polynomial (ZMod p)) ^ d := by
  have hCz : ((Nat.choose (d + 1) 2 : ℤ) : ZMod p) = 0 := by
    rw [ZMod.intCast_zmod_eq_zero_iff_dvd]
    exact_mod_cast hpdvd
  have hCz_nat : ((Nat.choose (d + 1) 2 : ℕ) : ZMod p) = 0 := by
    exact_mod_cast hCz
  have hCz_map :
      (Int.castRingHom (ZMod p)) (Nat.choose (d + 1) 2 : ℤ) = 0 := hCz
  unfold singletonTwoClosedNewtonPolynomial
  simp only [Polynomial.map_sub, Polynomial.map_mul, Polynomial.map_pow, Polynomial.map_X,
    Polynomial.map_C]
  rw [hCz_map]
  simp

private lemma polynomial_dvd_X_pow_associated_X_pow
    {F : Type*} [Field F] {g : Polynomial F} {d : ℕ}
    (hdiv : g ∣ (Polynomial.X : Polynomial F) ^ d) :
    ∃ m : ℕ, m ≤ d ∧ Associated g ((Polynomial.X : Polynomial F) ^ m) := by
  obtain ⟨m, hm, hassoc⟩ :=
    (dvd_prime_pow (Polynomial.irreducible_X (R := F)).prime d).mp hdiv
  exact ⟨m, hm, hassoc⟩

private lemma singletonTwoClosedNewtonPolynomial_map_factor_associated_X_pow
    (d p : ℕ) [Fact p.Prime] {g : Polynomial ℤ}
    (hpdvd : p ∣ Nat.choose (d + 1) 2)
    (hgdiv : g ∣ singletonTwoClosedNewtonPolynomial d) :
    ∃ m : ℕ, m ≤ d ∧
      Associated (g.map (Int.castRingHom (ZMod p)))
        ((Polynomial.X : Polynomial (ZMod p)) ^ m) := by
  have hdiv :
      g.map (Int.castRingHom (ZMod p)) ∣
        (Polynomial.X : Polynomial (ZMod p)) ^ d := by
    rw [← singletonTwoClosedNewtonPolynomial_map_zmod_eq_X_pow d p hpdvd]
    exact Polynomial.map_dvd _ hgdiv
  exact polynomial_dvd_X_pow_associated_X_pow (F := ZMod p) hdiv

private lemma singletonTwoClosedNewtonPolynomial_monic_factor_map_eq_X_pow
    (d p : ℕ) [Fact p.Prime] {g : Polynomial ℤ}
    (hpdvd : p ∣ Nat.choose (d + 1) 2)
    (hgdiv : g ∣ singletonTwoClosedNewtonPolynomial d)
    (hgmonic : g.Monic) :
    ∃ m : ℕ, m ≤ d ∧
      g.map (Int.castRingHom (ZMod p)) =
        (Polynomial.X : Polynomial (ZMod p)) ^ m := by
  obtain ⟨m, hm, hassoc⟩ :=
    singletonTwoClosedNewtonPolynomial_map_factor_associated_X_pow
      d p hpdvd hgdiv
  exact ⟨m, hm,
    Polynomial.eq_of_monic_of_associated
      (hgmonic.map (Int.castRingHom (ZMod p)))
      (Polynomial.monic_X_pow m)
      hassoc⟩

private lemma singletonTwoClosedNewtonPolynomial_monic_factor_natDegree_map_eq
    (d p : ℕ) [Fact p.Prime] {g : Polynomial ℤ}
    (hpdvd : p ∣ Nat.choose (d + 1) 2)
    (hgdiv : g ∣ singletonTwoClosedNewtonPolynomial d)
    (hgmonic : g.Monic) :
    ∃ m : ℕ, m ≤ d ∧ g.natDegree = m ∧
      g.map (Int.castRingHom (ZMod p)) =
        (Polynomial.X : Polynomial (ZMod p)) ^ m := by
  obtain ⟨m, hm, hmap⟩ :=
    singletonTwoClosedNewtonPolynomial_monic_factor_map_eq_X_pow
      d p hpdvd hgdiv hgmonic
  have hdeg := congrArg Polynomial.natDegree hmap
  have hdeg_map :
      (g.map (Int.castRingHom (ZMod p))).natDegree = g.natDegree :=
    hgmonic.natDegree_map (Int.castRingHom (ZMod p))
  rw [hdeg_map, Polynomial.natDegree_X_pow] at hdeg
  exact ⟨m, hm, hdeg, hmap⟩

private lemma singletonTwoClosedNewtonPolynomial_monic_factor_coeff_dvd_of_lt_natDegree
    (d p : ℕ) [Fact p.Prime] {g : Polynomial ℤ}
    (hpdvd : p ∣ Nat.choose (d + 1) 2)
    (hgdiv : g ∣ singletonTwoClosedNewtonPolynomial d)
    (hgmonic : g.Monic) :
    ∀ n, n < g.natDegree → (p : ℤ) ∣ g.coeff n := by
  obtain ⟨m, _hm, hdeg, hmap⟩ :=
    singletonTwoClosedNewtonPolynomial_monic_factor_natDegree_map_eq
      d p hpdvd hgdiv hgmonic
  intro n hn
  have hn_m : n ≠ m := by omega
  have hcoeff := congrArg (fun P : Polynomial (ZMod p) => P.coeff n) hmap
  simp [Polynomial.coeff_map, Polynomial.coeff_X_pow, hn_m] at hcoeff
  exact (ZMod.intCast_zmod_eq_zero_iff_dvd (g.coeff n) p).mp hcoeff

private lemma singletonTwoClosedNewtonPolynomial_monic_factor_coeff_zero_dvd
    (d p : ℕ) [Fact p.Prime] {g : Polynomial ℤ}
    (hpdvd : p ∣ Nat.choose (d + 1) 2)
    (hgdiv : g ∣ singletonTwoClosedNewtonPolynomial d)
    (hgmonic : g.Monic) (hgpos : 0 < g.natDegree) :
    (p : ℤ) ∣ g.coeff 0 := by
  exact singletonTwoClosedNewtonPolynomial_monic_factor_coeff_dvd_of_lt_natDegree
    d p hpdvd hgdiv hgmonic 0 hgpos

private lemma singletonTwoClosedNewtonPolynomial_monic_factorization_coeff_zero_dvd_sq
    (d p : ℕ) [Fact p.Prime] {g h : Polynomial ℤ}
    (hpdvd : p ∣ Nat.choose (d + 1) 2)
    (hgmonic : g.Monic) (hhmonic : h.Monic)
    (hgpos : 0 < g.natDegree) (hhpos : 0 < h.natDegree)
    (hfac : singletonTwoClosedNewtonPolynomial d = g * h) :
    (p : ℤ) ^ 2 ∣ (singletonTwoClosedNewtonPolynomial d).coeff 0 := by
  have hgdiv : g ∣ singletonTwoClosedNewtonPolynomial d := ⟨h, hfac⟩
  have hhdiv : h ∣ singletonTwoClosedNewtonPolynomial d := ⟨g, by rw [hfac, mul_comm]⟩
  have hg0 : (p : ℤ) ∣ g.coeff 0 :=
    singletonTwoClosedNewtonPolynomial_monic_factor_coeff_zero_dvd
      d p hpdvd hgdiv hgmonic hgpos
  have hh0 : (p : ℤ) ∣ h.coeff 0 :=
    singletonTwoClosedNewtonPolynomial_monic_factor_coeff_zero_dvd
      d p hpdvd hhdiv hhmonic hhpos
  have hcoeff :
      (singletonTwoClosedNewtonPolynomial d).coeff 0 = g.coeff 0 * h.coeff 0 := by
    rw [hfac, Polynomial.coeff_mul]
    simp
  rw [hcoeff]
  simpa [pow_two] using mul_dvd_mul hg0 hh0

private lemma singletonTwoClosedNewtonPolynomial_monic_factor_constant_pow_dvd
    (d p e : ℕ) {g h : Polynomial ℤ}
    (_hgmonic : g.Monic)
    (hdeg_sum : g.natDegree + h.natDegree = d)
    (hCdiv : (p : ℤ) ^ e ∣ (Nat.choose (d + 1) 2 : ℤ))
    (hfac : singletonTwoClosedNewtonPolynomial d = g * h) :
    (p : ℤ) ^ (e * g.natDegree) ∣ (g.coeff 0) ^ d := by
  obtain ⟨c, hc⟩ := hCdiv
  let B : Polynomial ℤ := ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)
  let A : Polynomial ℤ := Polynomial.C c * B
  let r := g.natDegree
  have hX :
      (Polynomial.X : Polynomial ℤ) ^ d =
        Polynomial.C ((p : ℤ) ^ e) * A + g * h := by
    rw [← hfac]
    unfold singletonTwoClosedNewtonPolynomial
    dsimp [A, B]
    rw [hc]
    simp only [Polynomial.C_mul]
    ring
  have hres_add :
      Polynomial.resultant g ((Polynomial.X : Polynomial ℤ) ^ d) r d =
        Polynomial.resultant g (Polynomial.C ((p : ℤ) ^ e) * A) r d := by
    rw [hX]
    rw [Polynomial.resultant_add_mul_right (f := g)
      (g := Polynomial.C ((p : ℤ) ^ e) * A) (p := h)
      (m := r) (n := d)]
    · dsimp [r]
      omega
    · dsimp [r]
      exact le_rfl
  have hres_scale :
      Polynomial.resultant g (Polynomial.C ((p : ℤ) ^ e) * A) r d =
        ((p : ℤ) ^ e) ^ r * Polynomial.resultant g A r d := by
    rw [Polynomial.resultant_C_mul_right]
  have hres_X :
      Polynomial.resultant g ((Polynomial.X : Polynomial ℤ) ^ d) r d =
        (-1 : ℤ) ^ (r * d) * (g.coeff 0) ^ d := by
    exact Polynomial.resultant_X_pow_right g r d (by dsimp [r]; exact le_rfl)
  have heq :
      (-1 : ℤ) ^ (r * d) * (g.coeff 0) ^ d =
        ((p : ℤ) ^ e) ^ r * Polynomial.resultant g A r d := by
    rw [← hres_X, hres_add, hres_scale]
  have hdiv_signed :
      ((p : ℤ) ^ e) ^ r ∣
        (-1 : ℤ) ^ (r * d) * (g.coeff 0) ^ d := ⟨Polynomial.resultant g A r d, heq⟩
  have hunit_sign : IsUnit ((-1 : ℤ) ^ (r * d)) := by
    exact (by norm_num : IsUnit (-1 : ℤ)).pow (r * d)
  have hdiv : ((p : ℤ) ^ e) ^ r ∣ (g.coeff 0) ^ d :=
    (IsUnit.dvd_mul_left hunit_sign).mp hdiv_signed
  simpa [r, pow_mul] using hdiv

private lemma padicValInt_pow_of_ne_zero
    (p n : ℕ) [Fact p.Prime] {z : ℤ} (hz : z ≠ 0) :
    padicValInt p (z ^ n) = n * padicValInt p z := by
  simp [padicValInt, Int.natAbs_pow, padicValNat.pow n (Int.natAbs_ne_zero.mpr hz)]

private lemma padicValInt_le_of_pow_dvd_pow
    (p N d : ℕ) [Fact p.Prime] {z : ℤ} (hz : z ≠ 0)
    (hdiv : (p : ℤ) ^ N ∣ z ^ d) :
    N ≤ d * padicValInt p z := by
  have h := (padicValInt_dvd_iff (p := p) N (z ^ d)).mp hdiv
  rcases h with hzero | hle
  · exact False.elim (pow_ne_zero d hz hzero)
  · rwa [padicValInt_pow_of_ne_zero p d hz] at hle

private lemma singletonTwoClosedNewtonPolynomial_monic_factor_constant_valuation_lower
    (d p e : ℕ) [Fact p.Prime] {g h : Polynomial ℤ}
    (hgmonic : g.Monic)
    (hdeg_sum : g.natDegree + h.natDegree = d)
    (hg0 : g.coeff 0 ≠ 0)
    (hCdiv : (p : ℤ) ^ e ∣ (Nat.choose (d + 1) 2 : ℤ))
    (hfac : singletonTwoClosedNewtonPolynomial d = g * h) :
    e * g.natDegree ≤ d * padicValInt p (g.coeff 0) := by
  exact padicValInt_le_of_pow_dvd_pow p (e * g.natDegree) d hg0
    (singletonTwoClosedNewtonPolynomial_monic_factor_constant_pow_dvd
      d p e hgmonic hdeg_sum hCdiv hfac)

private lemma dumas_degree_eq_zero_or_full_of_valuation_bounds
    {d e r s a b : ℕ} (hcop : Nat.Coprime d e) (hrle : r ≤ d)
    (hdeg : r + s = d) (hval : a + b = e)
    (hg : e * r ≤ d * a) (hh : e * s ≤ d * b) :
    r = 0 ∨ r = d := by
  have heq : e * r = d * a := by
    nlinarith
  have hdvd_er : d ∣ e * r := ⟨a, heq⟩
  have hdvd_r : d ∣ r := (hcop.dvd_mul_left).mp hdvd_er
  by_cases hd0 : d = 0
  · left
    exact Nat.eq_zero_of_le_zero (by simpa [hd0] using hrle)
  rcases hdvd_r with ⟨k, hk⟩
  by_cases hk0 : k = 0
  · left
    rw [hk, hk0, mul_zero]
  · right
    have hkpos : 1 ≤ k := Nat.pos_of_ne_zero hk0
    have hk_le : k ≤ 1 := by
      nlinarith [hrle, hk, Nat.pos_of_ne_zero hd0]
    have hk1 : k = 1 := le_antisymm hk_le hkpos
    rw [hk, hk1, mul_one]

private lemma dumas_degree_dvd_mul_of_valuation_bounds
    {d e r s a b : ℕ} (hdeg : r + s = d) (hval : a + b = e)
    (hg : e * r ≤ d * a) (hh : e * s ≤ d * b) :
    d ∣ e * r := by
  have heq : e * r = d * a := by
    nlinarith
  exact ⟨a, heq⟩

private lemma padicValInt_eq_of_pow_dvd_not_dvd_succ
    (p e : ℕ) [Fact p.Prime] {z : ℤ} (hz : z ≠ 0)
    (hdiv : (p : ℤ) ^ e ∣ z)
    (hnot : ¬ (p : ℤ) ^ (e + 1) ∣ z) :
    padicValInt p z = e := by
  have hle : e ≤ padicValInt p z := by
    have h := (padicValInt_dvd_iff (p := p) e z).mp hdiv
    exact h.resolve_left hz
  have hlt : ¬ e + 1 ≤ padicValInt p z := by
    intro hle_succ
    exact hnot ((padicValInt_dvd_iff (p := p) (e + 1) z).mpr (Or.inr hle_succ))
  omega

private lemma singletonTwoClosedNewtonPolynomial_factor_constant_valuation_sum
    (d p e : ℕ) [Fact p.Prime] {g h : Polynomial ℤ}
    (hf0 : (singletonTwoClosedNewtonPolynomial d).coeff 0 ≠ 0)
    (hfval : padicValInt p ((singletonTwoClosedNewtonPolynomial d).coeff 0) = e)
    (hfac : singletonTwoClosedNewtonPolynomial d = g * h) :
    padicValInt p (g.coeff 0) + padicValInt p (h.coeff 0) = e := by
  have hcoeff :
      (singletonTwoClosedNewtonPolynomial d).coeff 0 = g.coeff 0 * h.coeff 0 := by
    rw [hfac, Polynomial.coeff_mul]
    simp
  have hg0 : g.coeff 0 ≠ 0 := by
    intro hz
    exact hf0 (by rw [hcoeff, hz, zero_mul])
  have hh0 : h.coeff 0 ≠ 0 := by
    intro hz
    exact hf0 (by rw [hcoeff, hz, mul_zero])
  have hmul := padicValInt.mul (p := p) hg0 hh0
  rw [← hcoeff, hfval] at hmul
  exact hmul.symm

private lemma singletonTwoClosedNewtonPolynomial_coeff_zero_padicValInt
    (d p : ℕ) (hd : 1 ≤ d) (hodd : Odd d) :
    padicValInt p ((singletonTwoClosedNewtonPolynomial d).coeff 0) =
      padicValNat p (Nat.choose (d + 1) 2) := by
  rw [singletonTwoClosedNewtonPolynomial_coeff_zero d hd hodd]
  simp [padicValInt]

private lemma singletonTwoClosedNewtonPolynomial_monic_factor_degree_dvd_mul_valuation
    (d p : ℕ) [Fact p.Prime] {g h : Polynomial ℤ}
    (hd : 2 ≤ d) (hodd : Odd d) (hgmonic : g.Monic) (hhmonic : h.Monic)
    (hfac : singletonTwoClosedNewtonPolynomial d = g * h) :
    d ∣ padicValNat p (Nat.choose (d + 1) 2) * g.natDegree := by
  set C : ℕ := Nat.choose (d + 1) 2
  set e : ℕ := padicValNat p C
  have hdegP : (singletonTwoClosedNewtonPolynomial d).natDegree = d :=
    singletonTwoClosedNewtonPolynomial_natDegree d hd
  have hdeg_sum : g.natDegree + h.natDegree = d := by
    have hdeg_mul := hgmonic.natDegree_mul hhmonic
    rw [← hfac, hdegP] at hdeg_mul
    exact hdeg_mul.symm
  have hC_pos : 0 < C := by
    dsimp [C]
    exact Nat.choose_pos (by omega : 2 ≤ d + 1)
  have hf0 : (singletonTwoClosedNewtonPolynomial d).coeff 0 ≠ 0 := by
    rw [singletonTwoClosedNewtonPolynomial_coeff_zero d (by omega) hodd]
    exact neg_ne_zero.mpr (Int.ofNat_ne_zero.mpr hC_pos.ne')
  have hcoeff :
      (singletonTwoClosedNewtonPolynomial d).coeff 0 = g.coeff 0 * h.coeff 0 := by
    rw [hfac, Polynomial.coeff_mul]
    simp
  have hg0 : g.coeff 0 ≠ 0 := by
    intro hz
    exact hf0 (by rw [hcoeff, hz, zero_mul])
  have hh0 : h.coeff 0 ≠ 0 := by
    intro hz
    exact hf0 (by rw [hcoeff, hz, mul_zero])
  have hpow_nat : p ^ e ∣ C := by
    dsimp [e]
    exact pow_padicValNat_dvd
  have hCdiv : (p : ℤ) ^ e ∣ (C : ℤ) := by
    exact_mod_cast hpow_nat
  have hfval :
      padicValInt p ((singletonTwoClosedNewtonPolynomial d).coeff 0) = e := by
    dsimp [e, C]
    exact singletonTwoClosedNewtonPolynomial_coeff_zero_padicValInt d p (by omega) hodd
  have hval_sum :
      padicValInt p (g.coeff 0) + padicValInt p (h.coeff 0) = e :=
    singletonTwoClosedNewtonPolynomial_factor_constant_valuation_sum
      d p e hf0 hfval hfac
  have hg_lower :
      e * g.natDegree ≤ d * padicValInt p (g.coeff 0) :=
    singletonTwoClosedNewtonPolynomial_monic_factor_constant_valuation_lower
      d p e hgmonic hdeg_sum hg0 hCdiv hfac
  have hh_lower :
      e * h.natDegree ≤ d * padicValInt p (h.coeff 0) :=
    singletonTwoClosedNewtonPolynomial_monic_factor_constant_valuation_lower
      d p e hhmonic (by rw [Nat.add_comm]; exact hdeg_sum) hh0 hCdiv (by
        rw [mul_comm]
        exact hfac)
  simpa [e, C] using
    dumas_degree_dvd_mul_of_valuation_bounds hdeg_sum hval_sum hg_lower hh_lower

private theorem singletonTwoClosedNewtonPolynomial_irreducible_of_dumas_prime
    (d p : ℕ) (hd : 2 ≤ d) (hodd : Odd d) (hp : p.Prime)
    (hcop : Nat.Coprime d (padicValNat p (Nat.choose (d + 1) 2))) :
    Irreducible (singletonTwoClosedNewtonPolynomial d) := by
  haveI : Fact p.Prime := ⟨hp⟩
  set C : ℕ := Nat.choose (d + 1) 2
  set e : ℕ := padicValNat p C
  have hmon : (singletonTwoClosedNewtonPolynomial d).Monic :=
    singletonTwoClosedNewtonPolynomial_monic d hd
  have hdegP : (singletonTwoClosedNewtonPolynomial d).natDegree = d :=
    singletonTwoClosedNewtonPolynomial_natDegree d hd
  have hP_ne_one : singletonTwoClosedNewtonPolynomial d ≠ 1 := by
    intro h
    have hdeg := congrArg Polynomial.natDegree h
    rw [hdegP, Polynomial.natDegree_one] at hdeg
    omega
  rw [hmon.irreducible_iff_natDegree, and_iff_right hP_ne_one]
  intro u v humon hvmon hmul
  have hdeg_sum : u.natDegree + v.natDegree = d := by
    have hdeg_mul := humon.natDegree_mul hvmon
    rw [hmul, hdegP] at hdeg_mul
    exact hdeg_mul.symm
  have hC_pos : 0 < C := by
    dsimp [C]
    exact Nat.choose_pos (by omega : 2 ≤ d + 1)
  have hf0 : (singletonTwoClosedNewtonPolynomial d).coeff 0 ≠ 0 := by
    rw [singletonTwoClosedNewtonPolynomial_coeff_zero d (by omega) hodd]
    exact neg_ne_zero.mpr (Int.ofNat_ne_zero.mpr hC_pos.ne')
  have hcoeff :
      (singletonTwoClosedNewtonPolynomial d).coeff 0 = u.coeff 0 * v.coeff 0 := by
    rw [← hmul, Polynomial.coeff_mul]
    simp
  have hu0 : u.coeff 0 ≠ 0 := by
    intro hz
    exact hf0 (by rw [hcoeff, hz, zero_mul])
  have hv0 : v.coeff 0 ≠ 0 := by
    intro hz
    exact hf0 (by rw [hcoeff, hz, mul_zero])
  have hpow_nat : p ^ e ∣ C := by
    dsimp [e]
    exact pow_padicValNat_dvd
  have hCdiv : (p : ℤ) ^ e ∣ (C : ℤ) := by
    exact_mod_cast hpow_nat
  have hfval :
      padicValInt p ((singletonTwoClosedNewtonPolynomial d).coeff 0) = e := by
    dsimp [e, C]
    exact singletonTwoClosedNewtonPolynomial_coeff_zero_padicValInt d p (by omega) hodd
  have hval_sum :
      padicValInt p (u.coeff 0) + padicValInt p (v.coeff 0) = e :=
    singletonTwoClosedNewtonPolynomial_factor_constant_valuation_sum
      d p e hf0 hfval hmul.symm
  have hu_lower :
      e * u.natDegree ≤ d * padicValInt p (u.coeff 0) :=
    singletonTwoClosedNewtonPolynomial_monic_factor_constant_valuation_lower
      d p e humon hdeg_sum hu0 hCdiv hmul.symm
  have hv_lower :
      e * v.natDegree ≤ d * padicValInt p (v.coeff 0) :=
    singletonTwoClosedNewtonPolynomial_monic_factor_constant_valuation_lower
      d p e hvmon (by rw [Nat.add_comm]; exact hdeg_sum) hv0 hCdiv (by
        rw [mul_comm]
        exact hmul.symm)
  have hdich :
      u.natDegree = 0 ∨ u.natDegree = d :=
    dumas_degree_eq_zero_or_full_of_valuation_bounds
      (by simpa [e, C] using hcop) (by omega) hdeg_sum hval_sum hu_lower hv_lower
  rcases hdich with hu0deg | hudeg
  · exact Or.inl hu0deg
  · right
    omega

private theorem singletonTwoClosedNewtonPolynomial_irreducible_of_eisenstein_data
    (d : ℕ) (hd : 2 ≤ d) (𝓟 : Ideal ℤ) (hprime : 𝓟.IsPrime)
    (hmem : ∀ {n : ℕ}, n < d → (singletonTwoClosedNewtonPolynomial d).coeff n ∈ 𝓟)
    (hnot : (singletonTwoClosedNewtonPolynomial d).coeff 0 ∉ 𝓟 ^ 2) :
