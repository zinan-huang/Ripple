        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
          (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
          c < a ∧
          (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
          (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
        (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
        3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
        ((q ∣ a - 1 ∧
            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q)
    (hqa : ¬ q ∣ a - 1) :
    a ^ p ≡ 1 [MOD q ^ q] := by
  have hobs_full := hobs
  rcases hobs with
    ⟨_hp, _hq, _hpd, _hqd,
      _hp_odd, _hq_odd, _hp_ne_three, _hq_ne_three,
      _hp5, _hq5, _hp_ne_q, _hp_lt_q,
      _h6a, _hb_mod_six, _hp_dvd_b, _hq_dvd_b, _hp_sq_dvd_b,
      _hcop_ab, _hp_not_dvd_a, hq_not_dvd_a,
      _ha_mod_p, _hp_val_eq, _hq_dvd_pval, _hp_pow_dvd_a_sub_one,
      _hp_big_pow_dvd_a_sub_one, _hc_branch,
      _hhalf_pow, _hthree_q_dvd_a, _hthree_pq_dvd_bq_succ,
      _hthree_pq_dvd_b_succ, _hq_side, _ha, _hb⟩
  have hdiv : q ^ q ∣ a ^ p - 1 :=
    obstruction_right_branch_upper_pow_sub_one_qpow_dvd
      (d := d) (b := b) hobs_full hqa
  have ha_pos : 1 ≤ a := Nat.one_le_iff_ne_zero.mpr (by
    intro ha0
    exact hq_not_dvd_a (by rw [ha0]; exact dvd_zero q))
  have hap_pos : 1 ≤ a ^ p := one_le_pow₀ ha_pos
  exact ((Nat.modEq_iff_dvd' hap_pos).mpr hdiv).symm

private lemma obstruction_descended_base_gt_exponents
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
