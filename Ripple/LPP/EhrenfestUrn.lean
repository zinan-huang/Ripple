private lemma one_add_deep_scaled_pow_sub_linear_dvd_prime_succ
    (q n T r : ℕ) (hn : 3 ≤ n) :
    q ^ (n + 1) ∣
      (1 + q ^ (n - 1) * T) ^ r -
        (1 + r * (q ^ (n - 1) * T)) := by
  have hsq : q ^ (n + 1) ∣ (q ^ (n - 1) * T) ^ 2 := by
    have hpow : q ^ (n + 1) ∣ q ^ (2 * (n - 1)) :=
      pow_dvd_pow q (by omega : n + 1 ≤ 2 * (n - 1))
    have hdiv : q ^ (n + 1) ∣ q ^ (2 * (n - 1)) * T ^ 2 :=
      dvd_mul_of_dvd_left hpow (T ^ 2)
    convert hdiv using 1
    ring
  exact dvd_trans hsq (pow_one_add_sub_linear_dvd_sq (q ^ (n - 1) * T) r)

private lemma one_add_mul_le_one_add_pow (x r : ℕ) :
    1 + r * x ≤ (1 + x) ^ r := by
  induction r with
  | zero =>
      simp
  | succ r ih =>
      rw [pow_succ]
      calc
        1 + (r + 1) * x ≤ (1 + r * x) * (1 + x) := by
          nlinarith [Nat.zero_le (r * x * x)]
        _ ≤ (1 + x) ^ r * (1 + x) := by
          exact Nat.mul_le_mul_right (1 + x) ih

private lemma q_unit_of_pow_unit_of_depth_three
    {q t n V : ℕ} (hq : q.Prime) (ht_gt_one : 1 < t) (hn3 : 3 ≤ n)
    (htq_eq : t ^ q - 1 = q ^ n * V)
    (hval_tq :
      padicValNat q (t ^ q - 1) = padicValNat q (t - 1) + 1)
    (hqV : ¬ q ∣ V) :
    ∃ T : ℕ,
      t - 1 = q ^ (n - 1) * T ∧ ¬ q ∣ T ∧ V ≡ T [MOD q] := by
  haveI : Fact q.Prime := ⟨hq⟩
  have ht_sub_ne_zero : t - 1 ≠ 0 := by omega
  have hV_ne_zero : V ≠ 0 := by
    intro hV0
    exact hqV (by rw [hV0]; exact dvd_zero q)
  have hval_tq_eq_n : padicValNat q (t ^ q - 1) = n := by
    rw [htq_eq, padicValNat.mul (pow_ne_zero n hq.ne_zero) hV_ne_zero,
      padicValNat.prime_pow, padicValNat.eq_zero_of_not_dvd hqV, add_zero]
  have hval_t_eq_pred : padicValNat q (t - 1) = n - 1 := by
    omega
  have hdiv_t : q ^ (n - 1) ∣ t - 1 := by
    apply (padicValNat_dvd_iff (n - 1) (t - 1)).2
    exact Or.inr (by rw [hval_t_eq_pred])
  rcases hdiv_t with ⟨T, hT⟩
  have hqT : ¬ q ∣ T := by
    intro hqT
    rcases hqT with ⟨K, hK⟩
    have hqn_dvd_t : q ^ n ∣ t - 1 := by
      refine ⟨K, ?_⟩
      rw [hT, hK]
      calc
        q ^ (n - 1) * (q * K) = (q ^ (n - 1) * q) * K := by ring
        _ = q ^ n * K := by
          rw [← pow_succ, Nat.sub_add_cancel (by omega : 1 ≤ n)]
    rcases (padicValNat_dvd_iff n (t - 1)).1 hqn_dvd_t with hzero | hle
    · exact ht_sub_ne_zero hzero
    · omega
  have ht_eq : t = 1 + q ^ (n - 1) * T := by omega
  have hqx : q * (q ^ (n - 1) * T) = q ^ n * T := by
    calc
      q * (q ^ (n - 1) * T) = (q * q ^ (n - 1)) * T := by ring
      _ = (q ^ (n - 1) * q) * T := by rw [mul_comm q (q ^ (n - 1))]
      _ = q ^ n * T := by
        rw [← pow_succ, Nat.sub_add_cancel (by omega : 1 ≤ n)]
  have hge_linear : 1 + q ^ n * T ≤ t ^ q := by
    rw [ht_eq]
    simpa [hqx] using one_add_mul_le_one_add_pow (q ^ (n - 1) * T) q
  have hres :
      q ^ (n + 1) ∣ t ^ q - (1 + q ^ n * T) := by
    simpa [ht_eq, hqx] using
      one_add_deep_scaled_pow_sub_linear_dvd_prime_succ q n T q hn3
  have hpow_modeq :
      t ^ q ≡ 1 + q ^ n * T [MOD q ^ (n + 1)] := by
    exact ((Nat.modEq_iff_dvd' hge_linear).mpr hres).symm
  have hscaled0 :
      t ^ q - 1 ≡ (1 + q ^ n * T) - 1 [MOD q ^ (n + 1)] :=
    Nat.ModEq.sub (by omega : 1 ≤ t ^ q)
      (by omega : 1 ≤ 1 + q ^ n * T) hpow_modeq (Nat.ModEq.refl 1)
  have hscaled :
      q ^ n * V ≡ q ^ n * T [MOD q ^ (n + 1)] := by
    simpa [htq_eq] using hscaled0
  have hscaled' :
      q ^ n * V ≡ q ^ n * T [MOD q ^ n * q] := by
    simpa [pow_succ] using hscaled
  have hVT : V ≡ T [MOD q] :=
    Nat.ModEq.mul_left_cancel' (pow_ne_zero n hq.ne_zero) hscaled'
  exact ⟨T, hT, hqT, hVT⟩

private lemma q_unit_of_pow_unit_of_depth_two
    {q t V : ℕ} (hq : q.Prime) (hq_ge_three : 3 ≤ q) (ht_gt_one : 1 < t)
    (htq_eq : t ^ q - 1 = q ^ 2 * V)
    (hval_tq :
      padicValNat q (t ^ q - 1) = padicValNat q (t - 1) + 1)
    (hqV : ¬ q ∣ V) :
    ∃ T : ℕ, t - 1 = q ^ (2 - 1) * T ∧ ¬ q ∣ T ∧ V ≡ T [MOD q] := by
  haveI : Fact q.Prime := ⟨hq⟩
  have ht_sub_ne_zero : t - 1 ≠ 0 := by omega
  have hV_ne_zero : V ≠ 0 := by
    intro hV0
    exact hqV (by rw [hV0]; exact dvd_zero q)
  have hval_tq_eq_two : padicValNat q (t ^ q - 1) = 2 := by
    rw [htq_eq, padicValNat.mul (pow_ne_zero 2 hq.ne_zero) hV_ne_zero,
      padicValNat.prime_pow, padicValNat.eq_zero_of_not_dvd hqV, add_zero]
  have hval_t_eq_one : padicValNat q (t - 1) = 1 := by
    omega
  have hdiv_t_pow : q ^ 1 ∣ t - 1 := by
    apply (padicValNat_dvd_iff 1 (t - 1)).2
    exact Or.inr (by rw [hval_t_eq_one])
  have hdiv_t : q ∣ t - 1 := by
    simpa using hdiv_t_pow
  rcases hdiv_t with ⟨T, hTq⟩
  have hT : t - 1 = q ^ (2 - 1) * T := by
    simpa using hTq
  have hqT : ¬ q ∣ T := by
    intro hqT
    rcases hqT with ⟨K, hK⟩
    have hq_sq_dvd_t : q ^ 2 ∣ t - 1 := by
      refine ⟨K, ?_⟩
      rw [hTq, hK]
      ring
    rcases (padicValNat_dvd_iff 2 (t - 1)).1 hq_sq_dvd_t with hzero | hle
    · exact ht_sub_ne_zero hzero
    · omega
  have ht_eq : t = 1 + q * T := by omega
  have hq_cube_dvd_pow : q * q * q ∣ q ^ q := by
    have hpow : q ^ 3 ∣ q ^ q := pow_dvd_pow q hq_ge_three
    convert hpow using 1
    ring
  rcases ZMod.exists_one_add_mul_pow_prime_eq (R := ℕ) (p := q)
      (u := q) (v := q) hq (dvd_refl q) hq_cube_dvd_pow T with
    ⟨Y, hY⟩
  have htq_sub_eq_unit : t ^ q - 1 = q ^ 2 * (T + q * Y) := by
    rw [ht_eq, hY]
    rw [Nat.add_sub_cancel_left]
    simpa [pow_two, mul_assoc]
  have hV_eq : V = T + q * Y := by
    apply Nat.mul_left_cancel (pow_pos hq.pos 2)
    calc
      q ^ 2 * V = t ^ q - 1 := htq_eq.symm
      _ = q ^ 2 * (T + q * Y) := htq_sub_eq_unit
  have hVT : V ≡ T [MOD q] := by
    rw [hV_eq]
    simp [Nat.add_comm, Nat.mul_comm]
  exact ⟨T, hT, hqT, hVT⟩

