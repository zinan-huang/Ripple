  have h6 : 6 ∣ d + 1 := by omega
  have hm : d + 1 = 6 * m := by
    rw [show 6 * m = m * 6 by rw [mul_comm]]
    exact (Nat.div_mul_cancel h6).symm
  have hp_d_succ : p ∣ d + 1 := by
    rw [hm]
    exact dvd_mul_of_dvd_right hpm 6
  have hp_not_d : ¬ p ∣ d := by
    intro hpd
    have hp_one : p ∣ (d + 1) - d := Nat.dvd_sub hp_d_succ hpd
    exact hp.not_dvd_one (by simpa using hp_one)
  have hp_not_d_sub_one : ¬ p ∣ d - 1 := by
    intro hpd1
    have hp_two : p ∣ (d + 1) - (d - 1) := Nat.dvd_sub hp_d_succ hpd1
    have hd_pos : 0 < d := by
      have hle : d % 6 ≤ d := Nat.mod_le d 6
      omega
    have hp_dvd_two : p ∣ 2 := by
      have hdiff : (d + 1) - (d - 1) = 2 := by omega
