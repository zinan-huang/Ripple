      intro n hn
      exact hmem (by
        rw [singletonTwoClosedNewtonPolynomial_natDegree d hd] at hn
        exact hn)) hnot
  exact hE.irreducible hprime hmon.isPrimitive (by
    rw [singletonTwoClosedNewtonPolynomial_natDegree d hd]
    omega)

private theorem singletonTwoClosedNewtonPolynomial_irreducible_of_eisenstein_choose_mem
    (d : ℕ) (hd : 2 ≤ d) (hodd : Odd d) (𝓟 : Ideal ℤ) (hprime : 𝓟.IsPrime)
    (hCmem : (Nat.choose (d + 1) 2 : ℤ) ∈ 𝓟)
    (hnot : - (Nat.choose (d + 1) 2 : ℤ) ∉ 𝓟 ^ 2) :
