        (S := S) (C := C) (T := T) (beta := beta)
        (coeff := fun j => Nat.choose q (j - 1))
        hq hq_ge_five hm_gt_two hval rfl
    have hq_dvd_qpow : q ∣ q ^ (m - 2) :=
