    dsimp [P]
    exact prime_pow_succ_dvd_scaled_mul_scaled p n C T q hn
  have hrest_right_sq : p ^ (n + 1) ∣ (P * C) * ((P * T) ^ 2 * R) :=
    dvd_mul_of_dvd_right hrest_left (P * C)
  have hrest_right :
