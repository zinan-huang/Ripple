  have hC₁_pos : 0 < C₁ := by
    cases C₁ with
    | zero =>
        rw [Nat.mul_zero] at hC₁_scale
        omega
    | succ C₁ => omega
  have hT₁_pos : 0 < T₁ := by
    cases T₁ with
    | zero =>
        rw [Nat.mul_zero] at hT₁_scale
        omega
    | succ T₁ => omega
  have hR₁_pos : 0 < R₁ := by
    cases R₁ with
    | zero =>
        rw [Nat.mul_zero] at hR₁_scale
