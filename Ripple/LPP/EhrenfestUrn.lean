/-- `j=3` exceptional-class reduction to a single arithmetic obstruction.

This theorem does not prove the obstruction impossible.  It says that if the
three simultaneous squarefull conditions below are impossible for all large
`d ≡ 5 mod 6`, then the singleton-index witness follows. -/
theorem singletonIndexModFiveWitness_of_no_choose_three_squarefull_obstruction
    (hV : ∀ (d : ℕ), 53 ≤ d → d % 6 = 5 →
      ¬ (SquarefullNat d ∧
        OddSquarefullNat ((d + 1) / 6) ∧
        OddSquarefullNat (d - 1))) :
    SingletonIndexModFiveWitness := by
  apply singletonIndexModFiveWitness_of_named_choose_three_factor_squarefree_cover
  intro d hd53 hmod
  by_cases hd_sqfree : HasSquarefreePrimeFactor d
  · exact Or.inl hd_sqfree
  by_cases hm_sqfree : HasOddSquarefreePrimeFactor ((d + 1) / 6)
  · exact Or.inr (Or.inl hm_sqfree)
  by_cases hdm_sqfree : HasOddSquarefreePrimeFactor (d - 1)
  · exact Or.inr (Or.inr hdm_sqfree)
  exfalso
  apply hV d hd53 hmod
  refine ⟨?_, ?_, ?_⟩
  · by_contra hsq
    exact hd_sqfree ((not_squarefullNat_iff_hasSquarefreePrimeFactor d).mp hsq)
  · by_contra hsq
    exact hm_sqfree
      ((not_oddSquarefullNat_iff_hasOddSquarefreePrimeFactor ((d + 1) / 6)).mp hsq)
  · by_contra hsq
    exact hdm_sqfree
      ((not_oddSquarefullNat_iff_hasOddSquarefreePrimeFactor (d - 1)).mp hsq)

theorem singletonIndexModFiveWitness_of_singletonOne_kummer
    (hV : ∀ (d : ℕ), 3 ≤ d → Odd d → d % 6 = 5 →
      ∀ p : ℕ, p.Prime → p ∣ d → ∀ b : ℚ,
        b ^ p ≠ (1 : ℚ) / (((d + 1 : ℕ) : ℚ))) :
    SingletonIndexModFiveWitness := by
  intro d hd hodd hmod
  obtain ⟨ν, q, hν, hq0, hq1, hroot, hmono, hcomp, hP_root⟩ :=
    singletonOne_root_exists_and_computable d (by omega)
  refine ⟨⟨1, by omega⟩, ν, q, singletonOneRootPolynomial d,
    by norm_num, by
      simp
      omega, hν, hq0, hq1, hroot, hmono,
    singletonOneRootPolynomial_natDegree d (by omega), hP_root, ?_⟩
  exact singletonOneRootPolynomial_irreducible_of_kummer d (by omega) hodd (hV d hd hodd hmod)

/-- Pointwise arithmetic interface for the exceptional congruence class.

For each `d % 6 = 5`, either the singleton-one Kummer obstruction is absent,
or the fixed `E={2}` Dumas prime-cover condition supplies irreducibility. -/
def SingletonModFiveArithmeticWitness : Prop :=
  ∀ (d : ℕ), 5 ≤ d → Odd d → d % 6 = 5 →
    (∀ p : ℕ, p.Prime → p ∣ d → ∀ b : ℚ,
      b ^ p ≠ (1 : ℚ) / (((d + 1 : ℕ) : ℚ))) ∨
    (∀ q : ℕ, q.Prime → q ∣ d →
      ∃ p : ℕ, p.Prime ∧
        ¬ q ∣ padicValNat p (Nat.choose (d + 1) 2))

/-- A prime-power formulation of the remaining exceptional-class arithmetic.

The second branch says that the triangular number `choose(d+1,2)` is not a
`q`-th power for any prime divisor `q` of `d`.  This is converted to the
Dumas prime-cover condition by `dumas_prime_cover_of_choose_two_not_pow`. -/
def SingletonModFivePowerWitness : Prop :=
  ∀ (d : ℕ), 5 ≤ d → Odd d → d % 6 = 5 →
    (∀ p : ℕ, p.Prime → p ∣ d → ∀ b : ℚ,
      b ^ p ≠ (1 : ℚ) / (((d + 1 : ℕ) : ℚ))) ∨
    (∀ q : ℕ, q.Prime → q ∣ d →
      ¬ ∃ a : ℕ, Nat.choose (d + 1) 2 = a ^ q)

def SingletonModFiveNatPowerWitness : Prop :=
  ∀ (d : ℕ), 5 ≤ d → Odd d → d % 6 = 5 →
    (∀ p : ℕ, p.Prime → p ∣ d → ¬ ∃ a : ℕ, d + 1 = a ^ p) ∨
    (∀ q : ℕ, q.Prime → q ∣ d →
      ¬ ∃ a : ℕ, Nat.choose (d + 1) 2 = a ^ q)

private lemma prime_dvd_mod_six_five_ne_two_ne_three
    {d p : ℕ} (hmod : d % 6 = 5) (hp : p.Prime) (hpd : p ∣ d) :
    p ≠ 2 ∧ p ≠ 3 ∧ Odd p := by
  have hp_ne_two : p ≠ 2 := by
    intro hp2
    subst hp2
    obtain ⟨m, hm⟩ := hpd
    omega
  have hp_ne_three : p ≠ 3 := by
    intro hp3
    subst hp3
    obtain ⟨m, hm⟩ := hpd
    omega
  exact ⟨hp_ne_two, hp_ne_three, Nat.Prime.odd_of_ne_two hp hp_ne_two⟩

private lemma base_dvd_six_of_succ_pow_mod_six_five
    {d a p : ℕ} (hmod : d % 6 = 5) (ha : d + 1 = a ^ p) :
    6 ∣ a := by
  have h6_dvd_d1 : 6 ∣ d + 1 := by
    use (d + 1) / 6
    omega
  have h2_dvd_pow : 2 ∣ a ^ p := by
    rw [← ha]
    exact dvd_trans (by norm_num : 2 ∣ 6) h6_dvd_d1
  have h3_dvd_pow : 3 ∣ a ^ p := by
    rw [← ha]
    exact dvd_trans (by norm_num : 3 ∣ 6) h6_dvd_d1
  have hprime_three : Nat.Prime 3 := by decide
  exact (by decide : Nat.Coprime 2 3).mul_dvd_of_dvd_of_dvd
    (Nat.prime_two.dvd_of_dvd_pow h2_dvd_pow)
    (hprime_three.dvd_of_dvd_pow h3_dvd_pow)

private lemma base_pow_not_mod_six_one_of_pow_mod_six_five
    {d b q : ℕ} (hmod : d % 6 = 5) (hb : d = b ^ q) :
    b % 6 ≠ 1 := by
  intro hb_one
  have hb_modeq : b ≡ 1 [MOD 6] := by
    have h := (Nat.mod_modEq b 6).symm
    rwa [hb_one] at h
  have hpow_modeq : b ^ q ≡ 1 [MOD 6] := by
    simpa using Nat.ModEq.pow q hb_modeq
  have hd_modeq : d ≡ 5 [MOD 6] := by
    have h := (Nat.mod_modEq d 6).symm
    rwa [hmod] at h
  have hfive : b ^ q ≡ 5 [MOD 6] := by
    rwa [hb] at hd_modeq
  have h15 : 1 ≡ 5 [MOD 6] := hpow_modeq.symm.trans hfive
  have h_eq : (1 : ℕ) = 5 :=
    Nat.ModEq.eq_of_lt_of_lt h15 (by norm_num) (by norm_num)
  norm_num at h_eq

private lemma base_pow_not_dvd_two_three_of_pow_mod_six_five
    {d b q : ℕ} (hmod : d % 6 = 5) (hq : q ≠ 0) (hb : d = b ^ q) :
    ¬ 2 ∣ b ∧ ¬ 3 ∣ b := by
  have hnot_two_d : ¬ 2 ∣ d := by
    intro h
    obtain ⟨m, hm⟩ := h
    omega
  have hnot_three_d : ¬ 3 ∣ d := by
    intro h
    obtain ⟨m, hm⟩ := h
    omega
  constructor
  · intro h2b
    have h2pow : 2 ∣ b ^ q := dvd_pow h2b hq
    rw [← hb] at h2pow
    exact hnot_two_d h2pow
  · intro h3b
    have h3pow : 3 ∣ b ^ q := dvd_pow h3b hq
    rw [← hb] at h3pow
    exact hnot_three_d h3pow

private lemma base_mod_six_eq_five_of_pow_mod_six_five
    {d b q : ℕ} (hmod : d % 6 = 5) (hq : q ≠ 0) (hb : d = b ^ q) :
    b % 6 = 5 := by
  obtain ⟨hnot_two, hnot_three⟩ :=
    base_pow_not_dvd_two_three_of_pow_mod_six_five hmod hq hb
  have hnot_one := base_pow_not_mod_six_one_of_pow_mod_six_five hmod hb
  have hlt : b % 6 < 6 := Nat.mod_lt b (by norm_num)
  interval_cases h : b % 6
  · exfalso
    exact hnot_two ((Nat.dvd_iff_mod_eq_zero).mpr (by omega))
  · exfalso
    exact hnot_one rfl
  · exfalso
    exact hnot_two ((Nat.dvd_iff_mod_eq_zero).mpr (by omega))
  · exfalso
    exact hnot_three ((Nat.dvd_iff_mod_eq_zero).mpr (by omega))
  · exfalso
    exact hnot_two ((Nat.dvd_iff_mod_eq_zero).mpr (by omega))
  · rfl

private lemma coprime_bases_of_consecutive_powers
    {d a b p q : ℕ} (hp0 : p ≠ 0) (hq0 : q ≠ 0)
    (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    Nat.Coprime a b := by
  have hg_dvd_ap : Nat.gcd a b ∣ a ^ p :=
    dvd_pow (Nat.gcd_dvd_left a b) hp0
  have hg_dvd_bq : Nat.gcd a b ∣ b ^ q :=
    dvd_pow (Nat.gcd_dvd_right a b) hq0
  have hle : b ^ q ≤ a ^ p := by
    rw [← hb, ← ha]
    omega
  have hg_dvd_one : Nat.gcd a b ∣ 1 := by
    have hsub : a ^ p - b ^ q = 1 := by
      rw [← ha, ← hb]
      omega
    simpa [hsub] using Nat.dvd_sub hg_dvd_ap hg_dvd_bq
  exact Nat.coprime_iff_gcd_eq_one.mpr (Nat.eq_one_of_dvd_one hg_dvd_one)

private lemma upper_base_mod_exponent_prime_eq_one_of_consecutive_powers
    {d a p : ℕ} (hp : p.Prime) (hpd : p ∣ d) (hp_not_dvd_a : ¬ p ∣ a)
    (ha : d + 1 = a ^ p) :
    a % p = 1 := by
  have hcop_ap : a.Coprime p := (hp.coprime_iff_not_dvd).mpr hp_not_dvd_a |>.symm
  have hfermat : a ^ (p - 1) ≡ 1 [MOD p] :=
    Nat.ModEq.pow_card_sub_one_eq_one hp hcop_ap
  have hap_modeq : a ^ p ≡ a [MOD p] := by
    have hmul := Nat.ModEq.mul_left a hfermat
    conv_lhs => rw [show p = p - 1 + 1 by exact (Nat.sub_add_cancel hp.one_le).symm]
    rw [pow_succ]
    simpa [mul_comm] using hmul
  have hd_modeq_zero : d ≡ 0 [MOD p] := Nat.modEq_zero_iff_dvd.mpr hpd
  have hap_modeq_one : a ^ p ≡ 1 [MOD p] := by
    have h := Nat.ModEq.add_right 1 hd_modeq_zero
    simpa [ha] using h
  have ha_modeq_one : a ≡ 1 [MOD p] := hap_modeq.symm.trans hap_modeq_one
  have hmod_modeq : a % p ≡ 1 [MOD p] := (Nat.mod_modEq a p).trans ha_modeq_one
  exact Nat.ModEq.eq_of_lt_of_lt hmod_modeq
    (Nat.mod_lt a hp.pos) hp.one_lt

private lemma obstruction_padicVal_p_eq
    {d a b p q : ℕ} (hd : 0 < d) (hp : p.Prime) (hp_odd : Odd p)
    (hq0 : q ≠ 0) (h6a : 6 ∣ a) (hp_not_dvd_a : ¬ p ∣ a)
    (ha_mod_p : a % p = 1) (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    padicValNat p (a - 1) + 1 = q * padicValNat p b := by
  haveI : Fact p.Prime := ⟨hp⟩
  have ha_ne_zero : a ≠ 0 := by
    intro haz
    rw [haz, zero_pow hp.ne_zero] at ha
    omega
  have ha_ge_one : 1 ≤ a := Nat.one_le_iff_ne_zero.mpr ha_ne_zero
  have ha_gt_one : 1 < a := by
    obtain ⟨m, hm⟩ := h6a
    rcases m with _ | m
    · omega
    · omega
  have ha_modeq_one : a ≡ 1 [MOD p] := by
    have h : (1 : ℕ) ≡ a [MOD p] := by
      simpa [ha_mod_p] using Nat.mod_modEq a p
    exact h.symm
  have hp_dvd_a_sub_one : p ∣ a - 1 :=
    (Nat.modEq_iff_dvd' ha_ge_one).mp ha_modeq_one.symm
  have hb_ne_zero : b ≠ 0 := by
    intro hbz
    rw [hbz, zero_pow hq0] at hb
    omega
  have hpow_sub : a ^ p - 1 = b ^ q := by
    rw [← ha, ← hb]
    omega
  have hval_lte :
      padicValNat p (a ^ p - 1 ^ p) =
        padicValNat p (a - 1) + padicValNat p p :=
    padicValNat.pow_sub_pow hp_odd ha_gt_one hp_dvd_a_sub_one hp_not_dvd_a hp.ne_zero
  rw [one_pow, hpow_sub, padicValNat.pow q hb_ne_zero, padicValNat_self] at hval_lte
  exact hval_lte.symm

private lemma five_le_of_prime_odd_ne_three
    {p : ℕ} (hp : p.Prime) (hodd : Odd p) (hp_ne_three : p ≠ 3) :
    5 ≤ p := by
  by_contra hlt
  have hp_two_le : 2 ≤ p := hp.two_le
  have hp_ne_two : p ≠ 2 := by
    intro hp2
    subst hp2
    rcases hodd with ⟨k, hk⟩
    omega
  have hp_ne_four : p ≠ 4 := by
    intro hp4
    subst hp4
    exact (by decide : ¬ Nat.Prime 4) hp
  omega

private lemma dvd_padicVal_succ_of_obstruction_padicVal_eq
    {a b p q : ℕ}
    (hval : padicValNat p (a - 1) + 1 = q * padicValNat p b) :
    q ∣ padicValNat p (a - 1) + 1 := by
  exact ⟨padicValNat p b, hval⟩

private lemma lt_of_dvd_pred_of_five_le
    {p q : ℕ} (hq5 : 5 ≤ q) (h : p ∣ q - 1) :
    p < q := by
  have hpos : 0 < q - 1 := by omega
  have hle : p ≤ q - 1 := Nat.le_of_dvd hpos h
  omega

private lemma obstruction_padicVal_q_eq_of_dvd_a_sub_one
    {d a b p q : ℕ} (hd : 0 < d) (hq : q.Prime) (hq_odd : Odd q)
    (hp0 : p ≠ 0) (ha_gt_one : 1 < a) (hq_dvd_a_sub_one : q ∣ a - 1)
    (hq_not_dvd_a : ¬ q ∣ a) (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    padicValNat q (a - 1) + padicValNat q p = q * padicValNat q b := by
  haveI : Fact q.Prime := ⟨hq⟩
  have hb_ne_zero : b ≠ 0 := by
    intro hbz
    rw [hbz, zero_pow hq.ne_zero] at hb
    have hd_zero : d = 0 := hb
    rw [hd_zero] at ha
    have hap_gt_one : 1 < a ^ p := one_lt_pow₀ ha_gt_one hp0
    omega
  have hpow_sub : a ^ p - 1 = b ^ q := by
    rw [← ha, ← hb]
    omega
  have hval_lte :
      padicValNat q (a ^ p - 1 ^ p) =
        padicValNat q (a - 1) + padicValNat q p :=
    padicValNat.pow_sub_pow hq_odd ha_gt_one hq_dvd_a_sub_one hq_not_dvd_a hp0
  rw [one_pow, hpow_sub, padicValNat.pow q hb_ne_zero] at hval_lte
  exact hval_lte.symm

private lemma exponent_dvd_padicVal_upper_sub_one_of_prime_ne
    {d a b p q ℓ : ℕ} (hℓ : ℓ.Prime) (hℓ_odd : Odd ℓ)
    (hℓp : ℓ ≠ p) (hp : p.Prime) (hq : q.Prime)
    (ha_gt_one : 1 < a) (hℓ_dvd_a_sub_one : ℓ ∣ a - 1)
    (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    q ∣ padicValNat ℓ (a - 1) := by
  haveI : Fact ℓ.Prime := ⟨hℓ⟩
  haveI : Fact p.Prime := ⟨hp⟩
  have ha_ge_one : 1 ≤ a := by omega
  have hℓ_not_dvd_a : ¬ ℓ ∣ a := by
    intro hℓa
    have hsub : ℓ ∣ a - (a - 1) := Nat.dvd_sub hℓa hℓ_dvd_a_sub_one
    have hpred : a - 1 + 1 = a := Nat.sub_add_cancel ha_ge_one
    have hdiff : a - (a - 1) = 1 := by omega
    rw [hdiff] at hsub
    exact hℓ.not_dvd_one hsub
  have hb_ne_zero : b ≠ 0 := by
    intro hbz
    rw [hbz, zero_pow hq.ne_zero] at hb
    have hd_zero : d = 0 := hb
    rw [hd_zero] at ha
    have hap_gt_one : 1 < a ^ p := one_lt_pow₀ ha_gt_one hp.ne_zero
    omega
  have hpow_sub : a ^ p - 1 = b ^ q := by
    rw [← ha, ← hb]
    omega
  have hval_lte :
      padicValNat ℓ (a ^ p - 1 ^ p) =
        padicValNat ℓ (a - 1) + padicValNat ℓ p :=
    padicValNat.pow_sub_pow hℓ_odd ha_gt_one hℓ_dvd_a_sub_one hℓ_not_dvd_a hp.ne_zero
  have hzero : padicValNat ℓ p = 0 := padicValNat_primes hℓp
  rw [one_pow, hpow_sub, padicValNat.pow q hb_ne_zero, hzero, add_zero] at hval_lte
  exact ⟨padicValNat ℓ b, hval_lte.symm⟩

private lemma exponent_prime_dvd_q_sub_one_of_not_dvd_a_sub_one
    {d a b p q : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hq_dvd_b : q ∣ b) (hq_not_dvd_a : ¬ q ∣ a)
    (hq_not_dvd_a_sub_one : ¬ q ∣ a - 1)
    (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    p ∣ q - 1 := by
  haveI : Fact p.Prime := ⟨hp⟩
  haveI : NeZero q := ⟨hq.ne_zero⟩
  have hcop_aq : a.Coprime q := (hq.coprime_iff_not_dvd).mpr hq_not_dvd_a |>.symm
  let u : (ZMod q)ˣ := ZMod.unitOfCoprime a hcop_aq
  have hq_dvd_d : q ∣ d := by
    rw [hb]
    exact dvd_pow hq_dvd_b hq.ne_zero
  have hap_modeq_one : a ^ p ≡ 1 [MOD q] := by
    have hd0 : d ≡ 0 [MOD q] := Nat.modEq_zero_iff_dvd.mpr hq_dvd_d
    have h := Nat.ModEq.add_right 1 hd0
    simpa [ha] using h
  have hu_pow : u ^ p = 1 := by
    ext
    change ((u : ZMod q) ^ p) = (1 : ZMod q)
    rw [ZMod.coe_unitOfCoprime]
    rw [← Nat.cast_pow]
    simpa using (ZMod.natCast_eq_natCast_iff (a ^ p) 1 q).mpr hap_modeq_one
  have ha_ne_zero : a ≠ 0 := by
    intro haz
    exact hq_not_dvd_a (by rw [haz]; exact dvd_zero q)
  have ha_ge_one : 1 ≤ a := Nat.one_le_iff_ne_zero.mpr ha_ne_zero
  have hu_ne_one : u ≠ 1 := by
    intro hu
    have ha_cast_one : (a : ZMod q) = 1 := by
      calc
        (a : ZMod q) = (u : ZMod q) := by
          simp [u, ZMod.coe_unitOfCoprime]
        _ = (1 : ZMod q) := by rw [hu]; rfl
    have ha_modeq_one : a ≡ 1 [MOD q] :=
      (ZMod.natCast_eq_natCast_iff a 1 q).mp (by
        simpa using ha_cast_one)
    exact hq_not_dvd_a_sub_one
      ((Nat.modEq_iff_dvd' ha_ge_one).mp ha_modeq_one.symm)
  have horder : orderOf u = p := orderOf_eq_prime hu_pow hu_ne_one
  have horder_dvd : orderOf u ∣ Nat.card (ZMod q)ˣ := orderOf_dvd_natCard u
  rw [horder, Nat.card_eq_fintype_card, ZMod.card_units_eq_totient q,
    Nat.totient_prime hq] at horder_dvd
  exact horder_dvd

private lemma q_adic_branch_of_q_le_p
    {a b p q : ℕ} (hle : q ≤ p)
    (hside :
      (q ∣ a - 1 ∧
          padicValNat q (a - 1) = q * padicValNat q b ∧
          q ^ q ∣ a - 1) ∨
        (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) :
    q ∣ a - 1 ∧
      padicValNat q (a - 1) = q * padicValNat q b ∧
      q ^ q ∣ a - 1 := by
  rcases hside with h | h
  · exact h
  · exact False.elim (by omega)

private lemma order_branch_of_not_q_dvd_a_sub_one
    {a b p q : ℕ} (hq_not : ¬ q ∣ a - 1)
    (hside :
      (q ∣ a - 1 ∧
          padicValNat q (a - 1) = q * padicValNat q b ∧
          q ^ q ∣ a - 1) ∨
        (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) :
    p ∣ q - 1 ∧ p < q := by
  rcases hside with h | h
  · exact False.elim (hq_not h.1)
  · exact ⟨h.2.1, h.2.2⟩

private lemma q_adic_branch_clean_of_ne
    {a b p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p ≠ q)
    (hbranch :
      q ∣ a - 1 ∧
        padicValNat q (a - 1) + padicValNat q p = q * padicValNat q b) :
    q ∣ a - 1 ∧ padicValNat q (a - 1) = q * padicValNat q b := by
  rcases hbranch with ⟨hq_dvd, hval⟩
  haveI : Fact p.Prime := ⟨hp⟩
  haveI : Fact q.Prime := ⟨hq⟩
  have hzero : padicValNat q p = 0 := padicValNat_primes (Ne.symm hpq)
  omega

private lemma pow_pred_exponent_dvd_base_sub_one_of_padic_obstruction
    {a b p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hb0 : b ≠ 0) (hp_dvd_b : p ∣ b)
    (hval : padicValNat p (a - 1) + 1 = q * padicValNat p b) :
    p ^ (q - 1) ∣ a - 1 := by
  haveI : Fact p.Prime := ⟨hp⟩
  have hb_val_pos : 1 ≤ padicValNat p b :=
    one_le_padicValNat_of_dvd hb0 hp_dvd_b
  have hq_pos : 1 ≤ q := le_of_lt hq.one_lt
  have hq_le_val_succ : q ≤ padicValNat p (a - 1) + 1 := by
    rw [hval]
    simpa using Nat.mul_le_mul_left q hb_val_pos
  have hle : q - 1 ≤ padicValNat p (a - 1) := by omega
  exact (padicValNat_dvd_iff (q - 1) (a - 1)).2 (Or.inr hle)

private lemma q_dvd_padicVal_sub_pred_of_padic_obstruction
    {a b p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hb0 : b ≠ 0)
    (hp_dvd_b : p ∣ b)
    (hval : padicValNat p (a - 1) + 1 = q * padicValNat p b) :
    q ∣ padicValNat p (a - 1) - (q - 1) := by
  haveI : Fact p.Prime := ⟨hp⟩
  have hb_val_pos : 1 ≤ padicValNat p b :=
    one_le_padicValNat_of_dvd hb0 hp_dvd_b
  refine ⟨padicValNat p b - 1, ?_⟩
  have hq_pos : 1 ≤ q := le_of_lt hq.one_lt
  have hval_decomp :
      padicValNat p (a - 1) + 1 =
        q * (padicValNat p b - 1) + q := by
    rw [hval]
    have hb_decomp :
        padicValNat p b = (padicValNat p b - 1) + 1 :=
      (Nat.sub_add_cancel hb_val_pos).symm
    rw [hb_decomp]
    rw [show padicValNat p b - 1 + 1 - 1 = padicValNat p b - 1 by omega]
    ring
  have hrewrite :
      padicValNat p (a - 1) - (q - 1) =
        q * (padicValNat p b - 1) := by
    omega
  exact hrewrite

private lemma exists_prime_pred_mul_qpow_of_scaled_padicVals
    {N p q : ℕ} (hp : p.Prime) (hq0 : q ≠ 0) (hN0 : N ≠ 0)
    (hpred : p ^ (q - 1) ∣ N)
    (hpval : q ∣ padicValNat p N - (q - 1))
    (hother : ∀ ℓ : ℕ, ℓ.Prime → ℓ ≠ p → q ∣ padicValNat ℓ N) :
    ∃ A : ℕ, N = p ^ (q - 1) * A ^ q := by
  haveI : Fact p.Prime := ⟨hp⟩
  let M := N / p ^ (q - 1)
  have hM0 : M ≠ 0 := by
    intro hM
    have hcancel : M * p ^ (q - 1) = N := by
      simpa [M] using Nat.div_mul_cancel hpred
    rw [hM, zero_mul] at hcancel
    exact hN0 hcancel.symm
  have hM_vals : ∀ ℓ : ℕ, ℓ.Prime → q ∣ padicValNat ℓ M := by
    intro ℓ hℓ
    by_cases hℓp : ℓ = p
    · subst ℓ
      have hvalM :
          padicValNat p M = padicValNat p N - (q - 1) := by
        simpa [M] using padicValNat.div_pow hpred
      rw [hvalM]
      exact hpval
    · haveI : Fact ℓ.Prime := ⟨hℓ⟩
      have hcop : Nat.Coprime ℓ (p ^ (q - 1)) := by
        apply Nat.Coprime.pow_right
        exact (hℓ.coprime_iff_not_dvd).mpr (by
          intro hdiv
          exact hℓp ((Nat.prime_dvd_prime_iff_eq hℓ hp).mp hdiv))
      have hvalM :
          padicValNat ℓ M = padicValNat ℓ N := by
        simpa [M] using padicValNat.div' hcop hpred
      rw [hvalM]
      exact hother ℓ hℓ hℓp
  obtain ⟨A, hA⟩ := nat_is_pow_of_forall_prime_dvd_padicValNat hM0 hq0 hM_vals
  refine ⟨A, ?_⟩
  calc
    N = M * p ^ (q - 1) := by
      simpa [M] using (Nat.div_mul_cancel hpred).symm
    _ = p ^ (q - 1) * M := by rw [mul_comm]
    _ = p ^ (q - 1) * A ^ q := by rw [hA]

private lemma exists_prime_mul_qpow_of_padicVal_eq_one
    {N p q : ℕ} (hp : p.Prime) (hq0 : q ≠ 0) (hN0 : N ≠ 0)
    (hpval : padicValNat p N = 1)
    (hother : ∀ ℓ : ℕ, ℓ.Prime → ℓ ≠ p → q ∣ padicValNat ℓ N) :
    ∃ B : ℕ, N = p * B ^ q := by
  haveI : Fact p.Prime := ⟨hp⟩
  have hp_dvd_N : p ∣ N := by
    have hp_pow_dvd : p ^ 1 ∣ N :=
      (padicValNat_dvd_iff 1 N).2 (Or.inr (by rw [hpval]))
    simpa using hp_pow_dvd
  let M := N / p
  have hM0 : M ≠ 0 := by
    intro hM
    have hcancel : M * p = N := by
      simpa [M] using Nat.div_mul_cancel hp_dvd_N
    rw [hM, zero_mul] at hcancel
    exact hN0 hcancel.symm
  have hM_vals : ∀ ℓ : ℕ, ℓ.Prime → q ∣ padicValNat ℓ M := by
    intro ℓ hℓ
    by_cases hℓp : ℓ = p
    · subst ℓ
      have hvalM :
          padicValNat p M = padicValNat p N - 1 := by
        have hp_pow_dvd : p ^ 1 ∣ N := by
          simpa using hp_dvd_N
        simpa [M] using padicValNat.div_pow hp_pow_dvd
      rw [hvalM, hpval]
      exact dvd_zero q
    · haveI : Fact ℓ.Prime := ⟨hℓ⟩
      have hcop : Nat.Coprime ℓ p :=
        (hℓ.coprime_iff_not_dvd).mpr (by
          intro hdiv
          exact hℓp ((Nat.prime_dvd_prime_iff_eq hℓ hp).mp hdiv))
      have hvalM :
          padicValNat ℓ M = padicValNat ℓ N := by
        simpa [M] using padicValNat.div' hcop hp_dvd_N
      rw [hvalM]
      exact hother ℓ hℓ hℓp
  obtain ⟨B, hB⟩ := nat_is_pow_of_forall_prime_dvd_padicValNat hM0 hq0 hM_vals
  refine ⟨B, ?_⟩
  calc
    N = M * p := by
      simpa [M] using (Nat.div_mul_cancel hp_dvd_N).symm
    _ = p * M := by rw [mul_comm]
    _ = p * B ^ q := by rw [hB]

private lemma upper_sub_one_eq_prime_pred_mul_qpow_of_obstruction
    {d a b p q : ℕ} (hp : p.Prime) (hq : q.Prime) (h6a : 6 ∣ a)
    (hb0 : b ≠ 0) (hp_dvd_b : p ∣ b)
    (ha_gt_one : 1 < a)
    (hval : padicValNat p (a - 1) + 1 = q * padicValNat p b)
    (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    ∃ A : ℕ, a - 1 = p ^ (q - 1) * A ^ q := by
  have hN0 : a - 1 ≠ 0 := by omega
  apply exists_prime_pred_mul_qpow_of_scaled_padicVals hp hq.ne_zero hN0
  · exact pow_pred_exponent_dvd_base_sub_one_of_padic_obstruction
      hp hq hb0 hp_dvd_b hval
  · exact q_dvd_padicVal_sub_pred_of_padic_obstruction
      hp hq hb0 hp_dvd_b hval
  · intro ℓ hℓ hℓp
    by_cases hℓ_dvd : ℓ ∣ a - 1
    · by_cases hℓ_two : ℓ = 2
      · subst ℓ
        have h2a : 2 ∣ a := dvd_trans (by norm_num : 2 ∣ 6) h6a
        have h2_one : 2 ∣ 1 := by
          have hsub : 2 ∣ a - (a - 1) := Nat.dvd_sub h2a hℓ_dvd
          have ha_ge_one : 1 ≤ a := by omega
          have hdiff : a - (a - 1) = 1 := by omega
          rwa [hdiff] at hsub
        exact False.elim (Nat.prime_two.not_dvd_one h2_one)
      · have hℓ_odd : Odd ℓ := by
          have hodd_or_even := Nat.even_or_odd ℓ
          rcases hodd_or_even with heven | hodd
          · exfalso
            obtain ⟨k, hk⟩ := heven
            have h2_dvd_ell : 2 ∣ ℓ := by omega
            have h2_eq_ell : 2 = ℓ :=
              (Nat.prime_dvd_prime_iff_eq Nat.prime_two hℓ).mp h2_dvd_ell
            exact hℓ_two h2_eq_ell.symm
          · exact hodd
        exact exponent_dvd_padicVal_upper_sub_one_of_prime_ne
          hℓ hℓ_odd hℓp hp hq ha_gt_one hℓ_dvd ha hb
    · rw [padicValNat.eq_zero_of_not_dvd hℓ_dvd]
      exact dvd_zero q

private lemma pow_two_mul_pred_exponent_dvd_base_sub_one_of_padic_obstruction
    {a b p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hb0 : b ≠ 0)
    (hp_sq_dvd_b : p ^ 2 ∣ b)
    (hval : padicValNat p (a - 1) + 1 = q * padicValNat p b) :
    p ^ (2 * q - 1) ∣ a - 1 := by
  haveI : Fact p.Prime := ⟨hp⟩
  have hb_val_ge_two : 2 ≤ padicValNat p b := by
    rcases (padicValNat_dvd_iff 2 b).1 hp_sq_dvd_b with hb_zero | hge
    · exact False.elim (hb0 hb_zero)
    · exact hge
  have hq_pos : 1 ≤ q := le_of_lt hq.one_lt
  have hle : 2 * q - 1 ≤ padicValNat p (a - 1) := by
    have hmul : 2 * q ≤ q * padicValNat p b := by
      nlinarith
    omega
  exact (padicValNat_dvd_iff (2 * q - 1) (a - 1)).2 (Or.inr hle)

private lemma geom_sum_mul_sub_one_eq_pow_sub_one
    {a n : ℕ} (ha : 1 ≤ a) :
    (∑ i ∈ Finset.range n, a ^ i) * (a - 1) = a ^ n - 1 := by
  have h :=
    (Commute.all (a - 1) (1 : ℕ)).geom_sum₂_mul_add n
  rw [Nat.sub_add_cancel ha, geom_sum₂_with_one, one_pow] at h
  omega

private lemma geom_sum_mul_sub_one_eq_lower_power
    {d a b p q : ℕ} (ha_pos : 1 ≤ a)
    (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    (∑ i ∈ Finset.range p, a ^ i) * (a - 1) = b ^ q := by
  rw [geom_sum_mul_sub_one_eq_pow_sub_one ha_pos]
  rw [← ha, ← hb]
  omega

private lemma padicValNat_geom_sum_eq_one_of_padic_obstruction
    {d a b p q : ℕ} (hp : p.Prime)
    (ha_gt_one : 1 < a) (hb0 : b ≠ 0)
    (hval : padicValNat p (a - 1) + 1 = q * padicValNat p b)
    (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    padicValNat p (∑ i ∈ Finset.range p, a ^ i) = 1 := by
  haveI : Fact p.Prime := ⟨hp⟩
  let S := ∑ i ∈ Finset.range p, a ^ i
  have hS_pos : 0 < S := by
    have hmem : 0 ∈ Finset.range p := by
      exact Finset.mem_range.mpr hp.pos
    have hterm_pos : 0 < a ^ 0 := by simp
    exact lt_of_lt_of_le hterm_pos (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hmem)
  have hS0 : S ≠ 0 := Nat.pos_iff_ne_zero.mp hS_pos
  have ha_sub0 : a - 1 ≠ 0 := by omega
  have hprod : S * (a - 1) = b ^ q := by
    simpa [S] using geom_sum_mul_sub_one_eq_lower_power
      (by omega : 1 ≤ a) ha hb
  have hval_prod :
      padicValNat p S + padicValNat p (a - 1) =
        q * padicValNat p b := by
    have hleft :
        padicValNat p (S * (a - 1)) =
          padicValNat p S + padicValNat p (a - 1) := by
      rw [padicValNat.mul hS0 ha_sub0]
    have hright :
        padicValNat p (b ^ q) = q * padicValNat p b := by
      rw [padicValNat.pow q hb0]
    rw [hprod, hright] at hleft
    exact hleft.symm
  show padicValNat p S = 1
  omega

private lemma geom_sum_eq_prime_mul_qpow_of_padic_obstruction
    {d a b p q : ℕ} (hp : p.Prime) (hq : q.Prime) (h6a : 6 ∣ a)
    (ha_gt_one : 1 < a) (hb0 : b ≠ 0)
    (hval : padicValNat p (a - 1) + 1 = q * padicValNat p b)
    (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    ∃ B : ℕ, (∑ i ∈ Finset.range p, a ^ i) = p * B ^ q := by
  let S := ∑ i ∈ Finset.range p, a ^ i
  have hS_pos : 0 < S := by
    have hmem : 0 ∈ Finset.range p := Finset.mem_range.mpr hp.pos
    have hterm_pos : 0 < a ^ 0 := by simp
    exact lt_of_lt_of_le hterm_pos (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hmem)
  have hS0 : S ≠ 0 := Nat.pos_iff_ne_zero.mp hS_pos
  have ha_sub0 : a - 1 ≠ 0 := by omega
  have hprod : S * (a - 1) = b ^ q := by
    simpa [S] using geom_sum_mul_sub_one_eq_lower_power
      (by omega : 1 ≤ a) ha hb
  apply exists_prime_mul_qpow_of_padicVal_eq_one hp hq.ne_zero hS0
  · simpa [S] using padicValNat_geom_sum_eq_one_of_padic_obstruction
      hp ha_gt_one hb0 hval ha hb
  · intro ℓ hℓ hℓp
    haveI : Fact ℓ.Prime := ⟨hℓ⟩
    have hA_dvd : q ∣ padicValNat ℓ (a - 1) := by
      by_cases hℓ_dvd : ℓ ∣ a - 1
      · by_cases hℓ_two : ℓ = 2
        · subst ℓ
          have h2a : 2 ∣ a := dvd_trans (by norm_num : 2 ∣ 6) h6a
          have h2_one : 2 ∣ 1 := by
            have hsub : 2 ∣ a - (a - 1) := Nat.dvd_sub h2a hℓ_dvd
            have hdiff : a - (a - 1) = 1 := by omega
            rwa [hdiff] at hsub
          exact False.elim (Nat.prime_two.not_dvd_one h2_one)
        · have hℓ_odd : Odd ℓ := by
            have hodd_or_even := Nat.even_or_odd ℓ
            rcases hodd_or_even with heven | hodd
            · exfalso
              obtain ⟨k, hk⟩ := heven
              have h2_dvd_ell : 2 ∣ ℓ := by omega
              have h2_eq_ell : 2 = ℓ :=
                (Nat.prime_dvd_prime_iff_eq Nat.prime_two hℓ).mp h2_dvd_ell
              exact hℓ_two h2_eq_ell.symm
            · exact hodd
          exact exponent_dvd_padicVal_upper_sub_one_of_prime_ne
            hℓ hℓ_odd hℓp hp hq ha_gt_one hℓ_dvd ha hb
      · rw [padicValNat.eq_zero_of_not_dvd hℓ_dvd]
        exact dvd_zero q
    have hval_prod :
        padicValNat ℓ S + padicValNat ℓ (a - 1) =
          q * padicValNat ℓ b := by
      have hleft :
          padicValNat ℓ (S * (a - 1)) =
            padicValNat ℓ S + padicValNat ℓ (a - 1) := by
        rw [padicValNat.mul hS0 ha_sub0]
      have hright :
          padicValNat ℓ (b ^ q) = q * padicValNat ℓ b := by
        rw [padicValNat.pow q hb0]
      rw [hprod, hright] at hleft
      exact hleft.symm
    rcases hA_dvd with ⟨t, ht⟩
    refine ⟨padicValNat ℓ b - t, ?_⟩
    have hmul_le : q * t ≤ q * padicValNat ℓ b := by
      calc
        q * t = padicValNat ℓ (a - 1) := ht.symm
        _ ≤ padicValNat ℓ S + padicValNat ℓ (a - 1) := by omega
        _ = q * padicValNat ℓ b := hval_prod
    have ht_le : t ≤ padicValNat ℓ b := by
      exact Nat.le_of_mul_le_mul_left hmul_le hq.pos
    have hrewrite :
        padicValNat ℓ S = q * (padicValNat ℓ b - t) := by
      have hsum :
          padicValNat ℓ S + q * t = q * padicValNat ℓ b := by
        simpa [ht] using hval_prod
      have hb_decomp :
          padicValNat ℓ b = (padicValNat ℓ b - t) + t :=
        (Nat.sub_add_cancel ht_le).symm
      have hright :
          q * (padicValNat ℓ b - t) + q * t =
            q * padicValNat ℓ b := by
        calc
          q * (padicValNat ℓ b - t) + q * t =
              q * ((padicValNat ℓ b - t) + t) := by rw [Nat.mul_add]
          _ = q * padicValNat ℓ b := by rw [Nat.sub_add_cancel ht_le]
      exact Nat.add_right_cancel (by
        calc
          padicValNat ℓ S + q * t = q * padicValNat ℓ b := hsum
          _ = q * (padicValNat ℓ b - t) + q * t := hright.symm)
    exact hrewrite

private lemma three_pow_exponent_dvd_upper_base_of_two_mul_qpow_eq_ppow
    {a e p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p ≠ q)
    (ha0 : a ≠ 0) (h6a : 6 ∣ a) (hpow : a ^ p = 2 * e ^ q) :
    3 ^ q ∣ a := by
  haveI : Fact (Nat.Prime 3) := ⟨by decide⟩
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  have he0 : e ≠ 0 := by
    intro he
    have ha_pow_ne_zero : a ^ p ≠ 0 := pow_ne_zero p ha0
    rw [he, zero_pow hq.ne_zero, mul_zero] at hpow
    exact ha_pow_ne_zero hpow
  have h3_dvd_a : 3 ∣ a := dvd_trans (by norm_num : 3 ∣ 6) h6a
  have hval_left : padicValNat 3 (a ^ p) = p * padicValNat 3 a := by
    rw [padicValNat.pow p ha0]
  have hval_right : padicValNat 3 (2 * e ^ q) = q * padicValNat 3 e := by
    rw [padicValNat.mul (by norm_num : (2 : ℕ) ≠ 0) (pow_ne_zero q he0),
      padicValNat.pow q he0, padicValNat_primes (by norm_num : (3 : ℕ) ≠ 2),
      zero_add]
  have hval_eq : p * padicValNat 3 a = q * padicValNat 3 e := by
    rw [hpow, hval_right] at hval_left
    exact hval_left.symm
  have hq_dvd_pval : q ∣ p * padicValNat 3 a := ⟨padicValNat 3 e, hval_eq⟩
  have hq_not_dvd_p : ¬ q ∣ p := by
    intro hqp
    exact hpq ((Nat.prime_dvd_prime_iff_eq hq hp).mp hqp).symm
  have hq_dvd_val : q ∣ padicValNat 3 a :=
    (hq.dvd_mul.mp hq_dvd_pval).resolve_left hq_not_dvd_p
  have hval_pos : 1 ≤ padicValNat 3 a :=
    one_le_padicValNat_of_dvd ha0 h3_dvd_a
  have hq_le_val : q ≤ padicValNat 3 a := by
    obtain ⟨t, ht⟩ := hq_dvd_val
    cases t with
    | zero =>
        rw [mul_zero] at ht
        omega
    | succ t =>
        rw [ht]
        exact Nat.le_mul_of_pos_right q (Nat.succ_pos t)
  exact (padicValNat_dvd_iff q a).2 (Or.inr hq_le_val)

private lemma three_pow_left_exponent_dvd_rhs_base_of_two_mul_qpow_eq_ppow
    {c s p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p ≠ q)
    (hc0 : c ≠ 0) (h6c : 6 ∣ c) (hpow : c ^ p = 2 * s ^ q) :
    3 ^ p ∣ s := by
  haveI : Fact (Nat.Prime 3) := ⟨by decide⟩
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  have hs0 : s ≠ 0 := by
    intro hs
    rw [hs, zero_pow hq.ne_zero, mul_zero] at hpow
    exact (pow_ne_zero p hc0) hpow
  have h3_dvd_c : 3 ∣ c := dvd_trans (by norm_num : 3 ∣ 6) h6c
  have h3_dvd_s : 3 ∣ s := by
    have hthree : Nat.Prime 3 := by decide
    have h3_cpow : 3 ∣ c ^ p := dvd_pow h3_dvd_c hp.ne_zero
    have h3_rhs : 3 ∣ 2 * s ^ q := by
      rwa [← hpow]
    have h3_spow : 3 ∣ s ^ q :=
      (hthree.dvd_mul.mp h3_rhs).resolve_left (by norm_num : ¬ 3 ∣ 2)
    exact hthree.dvd_of_dvd_pow h3_spow
  have hval_left : padicValNat 3 (c ^ p) = p * padicValNat 3 c := by
    rw [padicValNat.pow p hc0]
  have hval_right : padicValNat 3 (2 * s ^ q) = q * padicValNat 3 s := by
    rw [padicValNat.mul (by norm_num : (2 : ℕ) ≠ 0) (pow_ne_zero q hs0),
      padicValNat.pow q hs0, padicValNat_primes (by norm_num : (3 : ℕ) ≠ 2),
      zero_add]
  have hval_eq : p * padicValNat 3 c = q * padicValNat 3 s := by
    rw [hpow, hval_right] at hval_left
    exact hval_left.symm
  have hp_dvd_qval : p ∣ q * padicValNat 3 s := ⟨padicValNat 3 c, hval_eq.symm⟩
  have hp_not_dvd_q : ¬ p ∣ q := by
    intro hpq'
    exact hpq ((Nat.prime_dvd_prime_iff_eq hp hq).mp hpq')
  have hp_dvd_val : p ∣ padicValNat 3 s :=
    (hp.dvd_mul.mp hp_dvd_qval).resolve_left hp_not_dvd_q
  have hval_pos : 1 ≤ padicValNat 3 s :=
    one_le_padicValNat_of_dvd hs0 h3_dvd_s
  have hp_le_val : p ≤ padicValNat 3 s := by
    obtain ⟨t, ht⟩ := hp_dvd_val
    cases t with
    | zero =>
        rw [mul_zero] at ht
        omega
    | succ t =>
        rw [ht]
        exact Nat.le_mul_of_pos_right p (Nat.succ_pos t)
  exact (padicValNat_dvd_iff p s).2 (Or.inr hp_le_val)

private lemma two_adic_eq_of_two_mul_qpow_eq_ppow
    {c s p q : ℕ} (_hp : p.Prime) (hq : q.Prime)
    (hc0 : c ≠ 0) (hpow : c ^ p = 2 * s ^ q) :
    p * padicValNat 2 c = 1 + q * padicValNat 2 s := by
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  have hs0 : s ≠ 0 := by
    intro hs
    rw [hs, zero_pow hq.ne_zero, mul_zero] at hpow
    exact (pow_ne_zero p hc0) hpow
  have hleft : padicValNat 2 (c ^ p) = p * padicValNat 2 c := by
    rw [padicValNat.pow p hc0]
  have hright : padicValNat 2 (2 * s ^ q) = 1 + q * padicValNat 2 s := by
    rw [padicValNat.mul (by norm_num : (2 : ℕ) ≠ 0) (pow_ne_zero q hs0),
      padicValNat.pow q hs0, padicValNat_self]
  rw [hpow, hright] at hleft
  exact hleft.symm

private lemma two_adic_base_val_ge_two_of_relation
    {c s p q : ℕ} (hp5 : 5 ≤ p) (hp_lt_q : p < q)
    (hrel : p * padicValNat 2 c = 1 + q * padicValNat 2 s) :
    2 ≤ padicValNat 2 c := by
  let v := padicValNat 2 c
  let w := padicValNat 2 s
  have hrel' : p * v = 1 + q * w := by simpa [v, w] using hrel
  by_contra hv_not
  have hv_le_one : v ≤ 1 := by omega
  rcases Nat.eq_zero_or_pos v with hv0 | hvpos
  · rw [hv0, mul_zero] at hrel'
    omega
  · have hv_eq_one : v = 1 := by omega
    rw [hv_eq_one, mul_one] at hrel'
    by_cases hw0 : w = 0
    · rw [hw0, mul_zero, add_zero] at hrel'
      omega
    · have hw_pos : 0 < w := Nat.pos_of_ne_zero hw0
      have hq_le_mul : q ≤ q * w :=
        Nat.le_mul_of_pos_right q hw_pos
      have hq_lt_rhs : q < 1 + q * w := by omega
      omega

private lemma two_adic_rhs_val_pos_of_relation
    {c s p q : ℕ} (hp5 : 5 ≤ p)
    (hrel : p * padicValNat 2 c = 1 + q * padicValNat 2 s) :
    1 ≤ padicValNat 2 s := by
  let v := padicValNat 2 c
  let w := padicValNat 2 s
  have hrel' : p * v = 1 + q * w := by simpa [v, w] using hrel
  by_contra hw_not
  have hw_zero : w = 0 := by omega
  rw [hw_zero, mul_zero, add_zero] at hrel'
  rcases v with _ | v
  · omega
  · have hp_dvd_one : p ∣ 1 := ⟨v + 1, by simpa [Nat.succ_eq_add_one] using hrel'.symm⟩
    have hp_ne_one : p ≠ 1 := by omega
    exact hp_ne_one (Nat.eq_one_of_dvd_one hp_dvd_one)

private lemma four_dvd_base_of_two_adic_relation
    {c s p q : ℕ} (hp5 : 5 ≤ p) (hp_lt_q : p < q)
    (hrel : p * padicValNat 2 c = 1 + q * padicValNat 2 s) :
    4 ∣ c := by
  have hval : 2 ≤ padicValNat 2 c :=
    two_adic_base_val_ge_two_of_relation hp5 hp_lt_q hrel
  have hdiv : 2 ^ 2 ∣ c :=
    (padicValNat_dvd_iff 2 c).2 (Or.inr hval)
  simpa using hdiv

private lemma two_dvd_rhs_base_of_two_adic_relation
    {c s p q : ℕ} (hp5 : 5 ≤ p)
    (hrel : p * padicValNat 2 c = 1 + q * padicValNat 2 s) :
    2 ∣ s := by
  have hval : 1 ≤ padicValNat 2 s :=
    two_adic_rhs_val_pos_of_relation hp5 hrel
  have hdiv : 2 ^ 1 ∣ s :=
    (padicValNat_dvd_iff 1 s).2 (Or.inr hval)
  simpa using hdiv

private lemma three_dvd_rhs_base_of_three_dvd_left_two_mul_qpow_eq_ppow
    {c s p q : ℕ} (hp : p.Prime) (hq : q.Prime)
    (h3c : 3 ∣ c) (hpow : c ^ p = 2 * s ^ q) :
    3 ∣ s := by
  have hthree : Nat.Prime 3 := by decide
  have h3_cpow : 3 ∣ c ^ p := dvd_pow h3c hp.ne_zero
  have h3_rhs : 3 ∣ 2 * s ^ q := by
    rwa [← hpow]
  have h3_spow : 3 ∣ s ^ q :=
    (hthree.dvd_mul.mp h3_rhs).resolve_left (by norm_num : ¬ 3 ∣ 2)
  exact hthree.dvd_of_dvd_pow h3_spow

private lemma divide_common_three_powers_of_two_mul_qpow_eq_ppow
    {c s p q : ℕ} (h3qc : 3 ^ q ∣ c) (h3ps : 3 ^ p ∣ s)
    (hpow : c ^ p = 2 * s ^ q) :
    ∃ C S : ℕ, c = 3 ^ q * C ∧ s = 3 ^ p * S ∧ C ^ p = 2 * S ^ q := by
  rcases h3qc with ⟨C, hc⟩
  rcases h3ps with ⟨S, hs⟩
  refine ⟨C, S, hc, hs, ?_⟩
  rw [hc, hs] at hpow
  have hscaled : 3 ^ (p * q) * C ^ p = 3 ^ (p * q) * (2 * S ^ q) := by
    calc
      3 ^ (p * q) * C ^ p
          = (3 ^ p) ^ q * C ^ p := by
              rw [pow_mul]
      _ = (3 ^ q) ^ p * C ^ p := by
              rw [pow_right_comm]
      _ = (3 ^ q * C) ^ p := by rw [mul_pow]
      _ = 2 * (3 ^ p * S) ^ q := hpow
      _ = 2 * ((3 ^ p) ^ q * S ^ q) := by rw [mul_pow]
      _ = 2 * (3 ^ (p * q) * S ^ q) := by rw [pow_mul]
      _ = 3 ^ (p * q) * (2 * S ^ q) := by ring
  exact Nat.eq_of_mul_eq_mul_left (pow_pos (by norm_num : 0 < 3) (p * q)) hscaled

private lemma three_pow_mul_exponents_dvd_lower_power_succ
    {a b p q : ℕ} (h3qa : 3 ^ q ∣ a) (ha : a ^ p = b ^ q + 1) :
    3 ^ (p * q) ∣ b ^ q + 1 := by
  have hdiv : (3 ^ q) ^ p ∣ a ^ p := pow_dvd_pow_of_dvd h3qa p
  have hpow : (3 ^ q) ^ p = 3 ^ (p * q) := by
    calc
      (3 ^ q) ^ p = (3 ^ p) ^ q := pow_right_comm 3 q p
      _ = 3 ^ (p * q) := (pow_mul 3 p q).symm
  rw [hpow, ha] at hdiv
  exact hdiv

private lemma pow_exponent_dvd_base_sub_one_of_clean_q_branch
    {a b q : ℕ} (hq : q.Prime) (hb0 : b ≠ 0) (hq_dvd_b : q ∣ b)
    (hval : padicValNat q (a - 1) = q * padicValNat q b) :
    q ^ q ∣ a - 1 := by
  haveI : Fact q.Prime := ⟨hq⟩
  have hb_val_pos : 1 ≤ padicValNat q b :=
    one_le_padicValNat_of_dvd hb0 hq_dvd_b
  have hq_pos : 1 ≤ q := le_of_lt hq.one_lt
  have hle : q ≤ padicValNat q (a - 1) := by
    rw [hval]
    simpa using Nat.mul_le_mul_left q hb_val_pos
  exact (padicValNat_dvd_iff q (a - 1)).2 (Or.inr hle)

private lemma succ_lower_base_dvd_upper_power_of_odd_consecutive_powers
    {a b p q : ℕ} (hq_odd : Odd q)
    (ha : a ^ p = b ^ q + 1) :
    b + 1 ∣ a ^ p := by
  have hdiv : b + 1 ∣ b ^ q + 1 := by
    simpa only [one_pow] using hq_odd.nat_add_dvd_pow_add_pow b 1
  rwa [← ha] at hdiv

private lemma prime_dvd_odd_add_cofactor_iff_dvd_exponent
    {b q r : ℕ} (_hr : r.Prime) (hr_dvd_b_succ : (r : ℤ) ∣ (b : ℤ) + 1) :
    ((r : ℤ) ∣
        ∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) ↔
      r ∣ q := by
  have hsub : (r : ℤ) ∣ (b : ℤ) - (-1 : ℤ) := by
    simpa [sub_eq_add_neg] using hr_dvd_b_succ
  rw [dvd_geom_sum₂_iff_of_dvd_sub (n := q) hsub]
  have hunit : IsUnit ((-1 : ℤ) ^ (q - 1)) := isUnit_neg_one.pow _
  rw [IsUnit.dvd_mul_right hunit]
  norm_cast

private lemma no_prime_dvd_succ_and_odd_add_cofactor
    {b q r : ℕ} (hq : q.Prime) (hq_dvd_b : q ∣ b) (hr : r.Prime)
    (hr_dvd_b_succ : r ∣ b + 1)
    (hr_dvd_cofactor :
      (r : ℤ) ∣
        ∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) :
    False := by
  have hr_dvd_b_succ_int : (r : ℤ) ∣ (b : ℤ) + 1 := by
    exact_mod_cast hr_dvd_b_succ
  have hr_dvd_q : r ∣ q :=
    (prime_dvd_odd_add_cofactor_iff_dvd_exponent hr hr_dvd_b_succ_int).mp
      hr_dvd_cofactor
  have hr_eq_q : r = q := (Nat.prime_dvd_prime_iff_eq hr hq).mp hr_dvd_q
  subst r
  have hq_dvd_one : q ∣ 1 := by
    have hsub : q ∣ (b + 1) - b := Nat.dvd_sub hr_dvd_b_succ hq_dvd_b
    simpa using hsub
  exact hq.not_dvd_one hq_dvd_one

private lemma coprime_succ_and_odd_add_cofactor_natAbs
    {b q : ℕ} (hq : q.Prime) (hq_dvd_b : q ∣ b) :
    Nat.Coprime (b + 1)
      (Int.natAbs
        (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))) := by
  apply Nat.coprime_of_dvd
  intro r hr hr_dvd_b_succ hr_dvd_cofactor_natAbs
  have hr_dvd_cofactor :
      (r : ℤ) ∣
        ∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i) :=
    (Int.natCast_dvd).2 hr_dvd_cofactor_natAbs
  exact (no_prime_dvd_succ_and_odd_add_cofactor hq hq_dvd_b hr
    hr_dvd_b_succ hr_dvd_cofactor).elim

private lemma succ_mul_odd_add_cofactor_eq
    {b q : ℕ} (hq_odd : Odd q) :
    ((b : ℤ) + 1) *
        (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) =
      (b : ℤ) ^ q + 1 := by
  have h :=
    (Commute.all (b : ℤ) (-1 : ℤ)).mul_geom_sum₂ q
  rw [sub_neg_eq_add, hq_odd.neg_one_pow] at h
  simpa [sub_eq_add_neg] using h

private lemma succ_mul_odd_add_cofactor_natAbs_eq
    {a b p q : ℕ} (hq_odd : Odd q) (ha : a ^ p = b ^ q + 1) :
    (b + 1) *
        Int.natAbs
          (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) =
      a ^ p := by
  have h := congrArg Int.natAbs (succ_mul_odd_add_cofactor_eq (b := b) hq_odd)
  simpa [Int.natAbs_mul, Nat.cast_add, Nat.cast_pow, ha] using h

private lemma succ_mul_odd_add_cofactor_natAbs_eq_self
    {b q : ℕ} (hq_odd : Odd q) :
    (b + 1) *
        Int.natAbs
          (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) =
      b ^ q + 1 := by
  have h := congrArg Int.natAbs (succ_mul_odd_add_cofactor_eq (b := b) hq_odd)
  simpa [Int.natAbs_mul, Nat.cast_add, Nat.cast_pow] using h

private lemma odd_add_cofactor_natAbs_modEq_one_of_prime_dvd_base
    {b q : ℕ} (hq : q.Prime) (hq_odd : Odd q) (hq_dvd_b : q ∣ b) :
    Int.natAbs
        (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) ≡
      1 [MOD q] := by
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hprod : (b + 1) * cof = b ^ q + 1 := by
    simpa [cof] using succ_mul_odd_add_cofactor_natAbs_eq_self (b := b) hq_odd
  have hb0 : b ≡ 0 [MOD q] := Nat.modEq_zero_iff_dvd.mpr hq_dvd_b
  have hb1 : b + 1 ≡ 1 [MOD q] := by
    simpa using Nat.ModEq.add_right 1 hb0
  have hbq1 : b ^ q + 1 ≡ 1 [MOD q] := by
    have hbq0 : b ^ q ≡ 0 [MOD q] := by
      have h := hb0.pow q
      rw [zero_pow hq.ne_zero] at h
      exact h
    simpa using Nat.ModEq.add_right 1 hbq0
  have hcof_prod : cof ≡ (b + 1) * cof [MOD q] := by
    simpa [one_mul] using (hb1.mul (Nat.ModEq.refl cof)).symm
  have hprod_modeq : (b + 1) * cof ≡ b ^ q + 1 [MOD q] := by
    rw [hprod]
  exact hcof_prod.trans (hprod_modeq.trans hbq1)

private lemma odd_add_cofactor_natAbs_eq_descended_quotient_power
    {a b c t p q : ℕ} (hq_odd : Odd q)
    (ha : a ^ p = b ^ q + 1) (hc : b + 1 = c ^ p)
    (hdesc : a = c * t ^ q) :
    Int.natAbs
        (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) =
      t ^ (p * q) := by
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hprod : (b + 1) * cof = a ^ p := by
    simpa [cof] using succ_mul_odd_add_cofactor_natAbs_eq (p := p) hq_odd ha
  have htpow : (t ^ q) ^ p = t ^ (p * q) := by
    calc
      (t ^ q) ^ p = t ^ (q * p) := (pow_mul t q p).symm
      _ = t ^ (p * q) := by rw [Nat.mul_comm]
  have hprod_eq : (b + 1) * cof = (b + 1) * t ^ (p * q) := by
    calc
      (b + 1) * cof = a ^ p := hprod
      _ = (c * t ^ q) ^ p := by rw [hdesc]
      _ = c ^ p * (t ^ q) ^ p := by rw [mul_pow]
      _ = (b + 1) * t ^ (p * q) := by rw [← hc, htpow]
  exact Nat.eq_of_mul_eq_mul_left (Nat.succ_pos b) hprod_eq

private lemma coprime_descended_base_quotient
    {a b c t p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hq_odd : Odd q)
    (hq_dvd_b : q ∣ b)
    (ha : a ^ p = b ^ q + 1) (hc : b + 1 = c ^ p)
    (hdesc : a = c * t ^ q) :
    Nat.Coprime c t := by
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hcof_eq : cof = t ^ (p * q) := by
    simpa [cof] using
      odd_add_cofactor_natAbs_eq_descended_quotient_power
        hq_odd ha hc hdesc
  have hcop_succ_cof : Nat.Coprime (b + 1) cof := by
    simpa [cof] using coprime_succ_and_odd_add_cofactor_natAbs hq hq_dvd_b
  have hcop_pow : Nat.Coprime (c ^ p) (t ^ (p * q)) := by
    rw [← hc, ← hcof_eq]
    exact hcop_succ_cof
  have hcop_c_tpow : Nat.Coprime c (t ^ (p * q)) :=
    (Nat.coprime_pow_left_iff hp.pos c (t ^ (p * q))).1 hcop_pow
  exact (Nat.coprime_pow_right_iff (Nat.mul_pos hp.pos hq.pos) c t).1 hcop_c_tpow

private lemma descended_quotient_pow_modEq_one
    {a b c t p q : ℕ} (hq : q.Prime) (hq_odd : Odd q)
    (hq_dvd_b : q ∣ b)
    (ha : a ^ p = b ^ q + 1) (hc : b + 1 = c ^ p)
    (hdesc : a = c * t ^ q) :
    t ^ (p * q) ≡ 1 [MOD q] := by
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hcof_eq : cof = t ^ (p * q) := by
    simpa [cof] using
      odd_add_cofactor_natAbs_eq_descended_quotient_power
        hq_odd ha hc hdesc
  have hcof_mod : cof ≡ 1 [MOD q] := by
    simpa [cof] using
      odd_add_cofactor_natAbs_modEq_one_of_prime_dvd_base hq hq_odd hq_dvd_b
  rwa [hcof_eq] at hcof_mod

private lemma odd_add_cofactor_natAbs_modEq_exponent_of_dvd_succ
    {b c q : ℕ} (hq_odd : Odd q) (hc_dvd : c ∣ b + 1) :
    Int.natAbs
        (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) ≡
      q [MOD c] := by
  classical
  let z : ℤ :=
    ∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)
  have hz_nonneg : 0 ≤ z := by
    have hprod_pos : 0 < ((b : ℤ) + 1) * z := by
      rw [show ((b : ℤ) + 1) * z =
          ((b : ℤ) + 1) *
            (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i)) by
          rfl]
      rw [succ_mul_odd_add_cofactor_eq (b := b) hq_odd]
      positivity
    by_contra hz_neg
    have hz_lt : z < 0 := lt_of_not_ge hz_neg
    have hprod_neg : ((b : ℤ) + 1) * z < 0 :=
      mul_neg_of_pos_of_neg (by positivity) hz_lt
    linarith
  have hb_zmod : ((b : ℤ) : ZMod c) = -1 := by
    have hc_dvd_int : (c : ℤ) ∣ (b : ℤ) + 1 := by
      exact_mod_cast hc_dvd
    have hzero : (((b : ℤ) + 1 : ℤ) : ZMod c) = 0 := by
      rw [ZMod.intCast_zmod_eq_zero_iff_dvd]
      exact hc_dvd_int
    have hadd : ((b : ℤ) : ZMod c) + 1 = 0 := by
      simpa using hzero
    simpa [eq_neg_iff_add_eq_zero] using hadd
  have hterm :
      ∀ i ∈ Finset.range q,
        (((b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i) : ℤ) : ZMod c) = 1 := by
    intro i hi
    have hi_le : i ≤ q - 1 := Nat.le_sub_one_of_lt (Finset.mem_range.mp hi)
    have hodd_pow : (-1 : ZMod c) ^ (q - 1) = 1 := by
      rcases hq_odd with ⟨k, hk⟩
      have hq_pred : q - 1 = 2 * k := by omega
      rw [hq_pred, pow_mul]
      simp
    calc
      (((b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i) : ℤ) : ZMod c)
          = (((b : ℤ) : ZMod c) ^ i) * ((-1 : ZMod c) ^ (q - 1 - i)) := by
            simp
      _ = (-1 : ZMod c) ^ i * (-1 : ZMod c) ^ (q - 1 - i) := by
            rw [hb_zmod]
      _ = (-1 : ZMod c) ^ (i + (q - 1 - i)) := by
            rw [pow_add]
      _ = (-1 : ZMod c) ^ (q - 1) := by
            rw [Nat.add_sub_of_le hi_le]
      _ = 1 := hodd_pow
  have hz_zmod : (z : ZMod c) = q := by
    calc
      (z : ZMod c)
          = ∑ i ∈ Finset.range q,
              (((b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i) : ℤ) : ZMod c) := by
            simp [z]
      _ = ∑ _i ∈ Finset.range q, (1 : ZMod c) := by
            exact Finset.sum_congr rfl hterm
      _ = q := by
            simp
  apply (ZMod.natCast_eq_natCast_iff (Int.natAbs z) q c).mp
  calc
    ((Int.natAbs z : ℕ) : ZMod c) = (z : ZMod c) := by
      rw [← Int.cast_natCast, Int.natAbs_of_nonneg hz_nonneg]
    _ = q := hz_zmod

private lemma descended_quotient_pow_modEq_exponent_mod_base
    {a b c t p q : ℕ} (hp_pos : 0 < p) (hq_odd : Odd q)
    (ha : a ^ p = b ^ q + 1) (hc : b + 1 = c ^ p)
    (hdesc : a = c * t ^ q) :
    t ^ (p * q) ≡ q [MOD c] := by
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hcof_eq : cof = t ^ (p * q) := by
    simpa [cof] using
      odd_add_cofactor_natAbs_eq_descended_quotient_power
        hq_odd ha hc hdesc
  have hc_dvd : c ∣ b + 1 := by
    rw [hc]
    exact dvd_pow_self c hp_pos.ne'
  have hcof_mod : cof ≡ q [MOD c] := by
    simpa [cof] using
      odd_add_cofactor_natAbs_modEq_exponent_of_dvd_succ
        hq_odd hc_dvd
  rwa [hcof_eq] at hcof_mod

private lemma nat_pow_odd_modEq_self_mod_three
    {t n : ℕ} (hn : Odd n) :
    t ^ n ≡ t [MOD 3] := by
  apply (ZMod.natCast_eq_natCast_iff (t ^ n) t 3).mp
  rw [Nat.cast_pow]
  generalize hx : (t : ZMod 3) = x
  rcases hn with ⟨k, hk⟩
  subst n
  fin_cases x
  · change (0 : ZMod 3) ^ (2 * k + 1) = (0 : ZMod 3)
    rw [zero_pow (show 2 * k + 1 ≠ 0 by omega)]
  · change (1 : ZMod 3) ^ (2 * k + 1) = (1 : ZMod 3)
    rw [one_pow]
  · change (2 : ZMod 3) ^ (2 * k + 1) = (2 : ZMod 3)
    have hodd : Odd (2 * k + 1) := ⟨k, by omega⟩
    have htwo : (2 : ZMod 3) = -1 := by decide
    rw [htwo]
    exact hodd.neg_one_pow

private lemma succ_lower_base_is_pow_of_odd_consecutive_powers
    {a b p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hq_odd : Odd q)
    (hq_dvd_b : q ∣ b) (ha : a ^ p = b ^ q + 1) :
    ∃ c : ℕ, b + 1 = c ^ p := by
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hprod : (b + 1) * cof = a ^ p := by
    simpa [cof] using succ_mul_odd_add_cofactor_natAbs_eq hq_odd ha
  have hcof_ne_zero : cof ≠ 0 := by
    intro hzero
    have hpow_pos : 0 < a ^ p := by
      rw [ha]
      omega
    rw [hzero, mul_zero] at hprod
    omega
  exact left_factor_is_pow_of_coprime_mul_eq_pow
    (by omega : b + 1 ≠ 0) hcof_ne_zero hp.ne_zero
    (by
      simpa [cof] using coprime_succ_and_odd_add_cofactor_natAbs hq hq_dvd_b)
    hprod

private lemma succ_power_base_mod_exponent_eq_one
    {b c p : ℕ} (hp : p.Prime) (hpb : p ∣ b) (hpow : b + 1 = c ^ p) :
    c % p = 1 := by
  have hp_not_dvd_c : ¬ p ∣ c := by
    intro hpc
    have hp_dvd_cpow : p ∣ c ^ p := dvd_pow hpc hp.ne_zero
    rw [← hpow] at hp_dvd_cpow
    have hp_dvd_one : p ∣ (b + 1) - b := Nat.dvd_sub hp_dvd_cpow hpb
    have hsub : (b + 1) - b = 1 := by omega
    rw [hsub] at hp_dvd_one
    exact hp.not_dvd_one hp_dvd_one
  exact upper_base_mod_exponent_prime_eq_one_of_consecutive_powers hp hpb
    hp_not_dvd_c hpow

private lemma sq_exponent_dvd_base_of_succ_power_mod_exponent_eq_one
    {b c p : ℕ} (hp : p.Prime) (hp_odd : Odd p)
    (hpow : b + 1 = c ^ p) (hcmod : c % p = 1) :
    p ^ 2 ∣ b := by
  by_cases hc_one : c = 1
  · subst c
    have hb_zero : b = 0 := by
      rw [one_pow] at hpow
      omega
    rw [hb_zero]
    exact dvd_zero _
  have hc_ne_zero : c ≠ 0 := by
    intro hcz
    rw [hcz, zero_pow hp.ne_zero] at hpow
    omega
  have hc_ge_one : 1 ≤ c := Nat.one_le_iff_ne_zero.mpr hc_ne_zero
  have hc_gt_one : 1 < c := by omega
  have hc_modeq_one : c ≡ 1 [MOD p] := by
    have h : (1 : ℕ) ≡ c [MOD p] := by
      simpa [hcmod] using Nat.mod_modEq c p
    exact h.symm
  have hp_dvd_c_sub_one : p ∣ c - 1 :=
    (Nat.modEq_iff_dvd' hc_ge_one).mp hc_modeq_one.symm
  have hp_not_dvd_c : ¬ p ∣ c := by
    intro hpc
    have hmod_zero : c % p = 0 := Nat.dvd_iff_mod_eq_zero.mp hpc
    omega
  haveI : Fact p.Prime := ⟨hp⟩
  have hval_lte :
      padicValNat p (c ^ p - 1 ^ p) =
        padicValNat p (c - 1) + padicValNat p p :=
    padicValNat.pow_sub_pow hp_odd hc_gt_one hp_dvd_c_sub_one hp_not_dvd_c hp.ne_zero
  have hb_eq : c ^ p - 1 = b := by omega
  have hsub_ne_zero : c - 1 ≠ 0 := by omega
  have hval_sub_pos : 1 ≤ padicValNat p (c - 1) :=
    one_le_padicValNat_of_dvd hsub_ne_zero hp_dvd_c_sub_one
  rw [one_pow, hb_eq, padicValNat_self] at hval_lte
  have hval_b_ge_two : 2 ≤ padicValNat p b := by omega
  exact (padicValNat_dvd_iff 2 b).2 (Or.inr hval_b_ge_two)

private lemma order_branch_of_succ_power
    {b c p q : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hq_dvd_b : q ∣ b) (hpow : b + 1 = c ^ p) :
    q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q) := by
  by_cases hqc1 : q ∣ c - 1
  · exact Or.inl hqc1
  · right
    have hq_not_dvd_c : ¬ q ∣ c := by
      intro hqc
      have hq_dvd_cpow : q ∣ c ^ p := dvd_pow hqc hp.ne_zero
      rw [← hpow] at hq_dvd_cpow
      have hq_dvd_one : q ∣ (b + 1) - b := Nat.dvd_sub hq_dvd_cpow hq_dvd_b
      have hsub : (b + 1) - b = 1 := by omega
      rw [hsub] at hq_dvd_one
      exact hq.not_dvd_one hq_dvd_one
    haveI : Fact p.Prime := ⟨hp⟩
    haveI : NeZero q := ⟨hq.ne_zero⟩
    have hcop_cq : c.Coprime q := (hq.coprime_iff_not_dvd).mpr hq_not_dvd_c |>.symm
    let u : (ZMod q)ˣ := ZMod.unitOfCoprime c hcop_cq
    have hcp_modeq_one : c ^ p ≡ 1 [MOD q] := by
      have hb_modeq_zero : b ≡ 0 [MOD q] := Nat.modEq_zero_iff_dvd.mpr hq_dvd_b
      have h := Nat.ModEq.add_right 1 hb_modeq_zero
      simpa [hpow] using h
    have hu_pow : u ^ p = 1 := by
      ext
      change ((u : ZMod q) ^ p) = (1 : ZMod q)
      rw [ZMod.coe_unitOfCoprime]
      rw [← Nat.cast_pow]
      simpa using (ZMod.natCast_eq_natCast_iff (c ^ p) 1 q).mpr hcp_modeq_one
    have hc_ne_zero : c ≠ 0 := by
      intro hcz
      exact hq_not_dvd_c (by rw [hcz]; exact dvd_zero q)
    have hc_ge_one : 1 ≤ c := Nat.one_le_iff_ne_zero.mpr hc_ne_zero
    have hu_ne_one : u ≠ 1 := by
      intro hu
      have hc_cast_one : (c : ZMod q) = 1 := by
        calc
          (c : ZMod q) = (u : ZMod q) := by
            simp [u, ZMod.coe_unitOfCoprime]
          _ = (1 : ZMod q) := by rw [hu]; rfl
      have hc_modeq_one : c ≡ 1 [MOD q] :=
        (ZMod.natCast_eq_natCast_iff c 1 q).mp (by
          simpa using hc_cast_one)
      exact hqc1 ((Nat.modEq_iff_dvd' hc_ge_one).mp hc_modeq_one.symm)
    have horder : orderOf u = p := orderOf_eq_prime hu_pow hu_ne_one
    have horder_dvd : orderOf u ∣ Nat.card (ZMod q)ˣ := orderOf_dvd_natCard u
    rw [horder, Nat.card_eq_fintype_card, ZMod.card_units_eq_totient q,
      Nat.totient_prime hq] at horder_dvd
    have hp_lt_q : p < q := by
      have hpos : 0 < q - 1 := Nat.sub_pos_of_lt hq.one_lt
      have hle : p ≤ q - 1 := Nat.le_of_dvd hpos horder_dvd
      omega
    exact ⟨hqc1, horder_dvd, hp_lt_q⟩

private lemma prime_pow_dvd_succ_of_dvd_odd_power_succ
    {a b p q r n : ℕ} (hq : q.Prime) (hq_odd : Odd q)
    (hq_dvd_b : q ∣ b) (hr : r.Prime) (hn : 0 < n)
    (hr_dvd_b_succ : r ∣ b + 1) (ha : a ^ p = b ^ q + 1)
    (hdiv : r ^ n ∣ b ^ q + 1) :
    r ^ n ∣ b + 1 := by
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hprod_a : (b + 1) * cof = a ^ p := by
    simpa [cof] using succ_mul_odd_add_cofactor_natAbs_eq (p := p) hq_odd ha
  have hprod : (b + 1) * cof = b ^ q + 1 := by
    rw [hprod_a, ha]
  have hdiv_prod : r ^ n ∣ (b + 1) * cof := by
    rwa [hprod]
  have hcop_succ_cof : Nat.Coprime (b + 1) cof := by
    simpa [cof] using coprime_succ_and_odd_add_cofactor_natAbs hq hq_dvd_b
  have hr_not_dvd_cof : ¬ r ∣ cof := by
    intro hrcof
    have hrgcd : r ∣ Nat.gcd (b + 1) cof := Nat.dvd_gcd hr_dvd_b_succ hrcof
    rw [Nat.Coprime.gcd_eq_one hcop_succ_cof] at hrgcd
    exact hr.not_dvd_one hrgcd
  have hcop_r_cof : Nat.Coprime r cof :=
    (hr.coprime_iff_not_dvd).mpr hr_not_dvd_cof
  have hcop_rn_cof : Nat.Coprime (r ^ n) cof :=
    (Nat.coprime_pow_left_iff hn r cof).2 hcop_r_cof
  exact (hcop_rn_cof.dvd_mul_right).mp hdiv_prod

private lemma half_succ_lower_base_is_pow_of_two_mul_odd_power
    {b e q : ℕ} (hq : q.Prime) (hq_odd : Odd q) (hodd_b : Odd b)
    (hq_dvd_b : q ∣ b) (hpow : b ^ q + 1 = 2 * e ^ q) :
    ∃ s : ℕ, (b + 1) / 2 = s ^ q := by
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (b : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hprod_b : (b + 1) * cof = b ^ q + 1 := by
    simpa [cof] using succ_mul_odd_add_cofactor_natAbs_eq_self (b := b) hq_odd
  have hprod_two : (b + 1) * cof = 2 * e ^ q := by
    rw [hprod_b, hpow]
  have htwo_half : 2 * ((b + 1) / 2) = b + 1 := by
    obtain ⟨m, hm⟩ := hodd_b
    subst hm
    omega
  have hhalf_prod : ((b + 1) / 2) * cof = e ^ q := by
    apply Nat.eq_of_mul_eq_mul_left (by norm_num : 0 < 2)
    calc
      2 * (((b + 1) / 2) * cof) = (b + 1) * cof := by
        rw [← mul_assoc, htwo_half]
      _ = 2 * e ^ q := hprod_two
  have hhalf_ne_zero : (b + 1) / 2 ≠ 0 := by
    obtain ⟨m, hm⟩ := hodd_b
    subst hm
    omega
  have he_ne_zero : e ≠ 0 := by
    intro he
    rw [he, zero_pow hq.ne_zero, mul_zero] at hpow
    omega
  have hcof_ne_zero : cof ≠ 0 := by
    intro hcof
    rw [hcof, mul_zero] at hhalf_prod
    exact (pow_ne_zero q he_ne_zero) hhalf_prod.symm
  have hcop_succ_cof : Nat.Coprime (b + 1) cof := by
    simpa [cof] using coprime_succ_and_odd_add_cofactor_natAbs hq hq_dvd_b
  have hhalf_dvd_succ : (b + 1) / 2 ∣ b + 1 := by
    rw [← htwo_half]
    simpa [mul_comm] using dvd_mul_left ((b + 1) / 2) 2
  exact left_factor_is_pow_of_coprime_mul_eq_pow
    hhalf_ne_zero hcof_ne_zero hq.ne_zero
    (hcop_succ_cof.coprime_dvd_left hhalf_dvd_succ)
    hhalf_prod

private lemma prime_pow_dvd_base_of_prime_pow_mul_exponent_dvd_pow
    {c p q r : ℕ} (hr : r.Prime) (hp : p.Prime) (hc0 : c ≠ 0)
    (hdiv : r ^ (p * q) ∣ c ^ p) :
    r ^ q ∣ c := by
  haveI : Fact r.Prime := ⟨hr⟩
  have hval_cp_ge : p * q ≤ padicValNat r (c ^ p) := by
    rcases (padicValNat_dvd_iff (p * q) (c ^ p)).1 hdiv with hzero | hge
    · exact False.elim ((pow_ne_zero p hc0) hzero)
    · exact hge
  rw [padicValNat.pow p hc0] at hval_cp_ge
  have hq_le : q ≤ padicValNat r c := by
    have hp_pos : 0 < p := hp.pos
    nlinarith
  exact (padicValNat_dvd_iff q c).2 (Or.inr hq_le)

private lemma quotient_is_qpow_of_two_mul_qpow_eq_ppow
    {a c e s r p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p ≠ q)
    (ha0 : a ≠ 0) (hc0 : c ≠ 0) (hr : a = c * r)
    (ha_pow : a ^ p = 2 * e ^ q) (hc_pow : c ^ p = 2 * s ^ q) :
    ∃ t : ℕ, r = t ^ q := by
  have hr0 : r ≠ 0 := by
    intro hrz
    rw [hrz, mul_zero] at hr
    exact ha0 hr
  have he0 : e ≠ 0 := by
    intro hez
    rw [hez, zero_pow hq.ne_zero, mul_zero] at ha_pow
    exact (pow_ne_zero p ha0) ha_pow
  have hs0 : s ≠ 0 := by
    intro hsz
    rw [hsz, zero_pow hq.ne_zero, mul_zero] at hc_pow
    exact (pow_ne_zero p hc0) hc_pow
  apply nat_is_pow_of_forall_prime_dvd_padicValNat hr0 hq.ne_zero
  intro ℓ hℓ
  haveI : Fact ℓ.Prime := ⟨hℓ⟩
  have hval_a_mul :
      padicValNat ℓ a = padicValNat ℓ c + padicValNat ℓ r := by
    rw [hr, padicValNat.mul hc0 hr0]
  have hvalA :
      p * (padicValNat ℓ c + padicValNat ℓ r) =
        padicValNat ℓ 2 + q * padicValNat ℓ e := by
    have hleft : padicValNat ℓ (a ^ p) = p * padicValNat ℓ a := by
      rw [padicValNat.pow p ha0]
    have hright : padicValNat ℓ (2 * e ^ q) =
        padicValNat ℓ 2 + q * padicValNat ℓ e := by
      rw [padicValNat.mul (by norm_num : (2 : ℕ) ≠ 0) (pow_ne_zero q he0),
        padicValNat.pow q he0]
    rw [ha_pow, hright, hval_a_mul] at hleft
    exact hleft.symm
  have hvalC :
      p * padicValNat ℓ c = padicValNat ℓ 2 + q * padicValNat ℓ s := by
    have hleft : padicValNat ℓ (c ^ p) = p * padicValNat ℓ c := by
      rw [padicValNat.pow p hc0]
    have hright : padicValNat ℓ (2 * s ^ q) =
        padicValNat ℓ 2 + q * padicValNat ℓ s := by
      rw [padicValNat.mul (by norm_num : (2 : ℕ) ≠ 0) (pow_ne_zero q hs0),
        padicValNat.pow q hs0]
    rw [hc_pow, hright] at hleft
    exact hleft.symm
  have hq_dvd_pval : q ∣ p * padicValNat ℓ r := by
    have hvalA' :
        p * padicValNat ℓ c + p * padicValNat ℓ r =
          padicValNat ℓ 2 + q * padicValNat ℓ e := by
      rw [← Nat.mul_add]
      exact hvalA
    have hle_add :
        padicValNat ℓ 2 + q * padicValNat ℓ s ≤
          padicValNat ℓ 2 + q * padicValNat ℓ e := by
      calc
        padicValNat ℓ 2 + q * padicValNat ℓ s
            = p * padicValNat ℓ c := hvalC.symm
        _ ≤ p * padicValNat ℓ c + p * padicValNat ℓ r := Nat.le_add_right _ _
        _ = padicValNat ℓ 2 + q * padicValNat ℓ e := hvalA'
    have hq_vs_le_qe : q * padicValNat ℓ s ≤ q * padicValNat ℓ e := by
      omega
    have hvs_le_ve : padicValNat ℓ s ≤ padicValNat ℓ e :=
      Nat.le_of_mul_le_mul_left hq_vs_le_qe hq.pos
    have heq_no2 :
        q * padicValNat ℓ e =
          q * padicValNat ℓ s + p * padicValNat ℓ r := by
      omega
    refine ⟨padicValNat ℓ e - padicValNat ℓ s, ?_⟩
    rw [Nat.mul_sub_left_distrib]
    omega
  have hq_not_dvd_p : ¬ q ∣ p := by
    intro hdiv
    exact hpq ((Nat.prime_dvd_prime_iff_eq hq hp).mp hdiv).symm
  exact (hq.dvd_mul.mp hq_dvd_pval).resolve_left hq_not_dvd_p

private lemma pow_add_one_lt_succ_pow
    {b n : ℕ} (hb : 0 < b) (hn : 2 ≤ n) :
    b ^ n + 1 < (b + 1) ^ n := by
  refine Nat.le_induction ?base ?step n hn
  · nlinarith [sq_pos_of_pos hb]
  · intro n hn ih
    have hmul : (b + 1) * (b ^ n + 1) < (b + 1) * (b + 1) ^ n :=
      Nat.mul_lt_mul_of_pos_left ih (by omega)
    have hleft : b ^ (n + 1) + 1 ≤ (b + 1) * (b ^ n + 1) := by
      rw [pow_succ]
      nlinarith [Nat.zero_le (b ^ n)]
    have hright : (b + 1) * (b + 1) ^ n = (b + 1) ^ (n + 1) := by
      rw [pow_succ]
      exact Nat.mul_comm _ _
    exact lt_of_le_of_lt hleft (by simpa [hright] using hmul)

private lemma mul_pow_sub_one_lt_pow_sub_one_of_lt
    {c p q : ℕ} (hc : 1 < c) (hqp : q < p) :
    c ^ (p - q) * (c ^ q - 1) < c ^ p - 1 := by
  have hpq_pos : 0 < p - q := by omega
  have hcpq : c ^ (p - q) * c ^ q = c ^ p := by
    rw [← pow_add]
    congr 1
    omega
  have hfactor_gt_one : 1 < c ^ (p - q) := one_lt_pow₀ hc hpq_pos.ne'
  have hcalc : c ^ (p - q) * (c ^ q - 1) + c ^ (p - q) = c ^ p := by
    calc
      c ^ (p - q) * (c ^ q - 1) + c ^ (p - q)
          = c ^ (p - q) * ((c ^ q - 1) + 1) := by
            rw [Nat.mul_add, mul_one]
      _ = c ^ (p - q) * c ^ q := by
            rw [Nat.sub_add_cancel (Nat.one_le_pow q c (by omega))]
      _ = c ^ p := hcpq
  omega

private lemma lower_adjacent_pow_lt_of_q_lt_p
    {c p q : ℕ} (hc : 1 < c) (hq0 : q ≠ 0) (hqp : q < p) :
    (c ^ q - 1) ^ p < (c ^ p - 1) ^ q := by
  have hpow_split :
      (c ^ q - 1) ^ p = (c ^ q - 1) ^ q * (c ^ q - 1) ^ (p - q) := by
    rw [← pow_add]
    congr 1
    omega
  have hsub_le : c ^ q - 1 ≤ c ^ q := Nat.sub_le _ _
  have hpow_sub_le : (c ^ q - 1) ^ (p - q) ≤ (c ^ q) ^ (p - q) :=
    Nat.pow_le_pow_left hsub_le (p - q)
  have hleft_le :
      (c ^ q - 1) ^ p ≤ (c ^ q - 1) ^ q * (c ^ q) ^ (p - q) := by
    rw [hpow_split]
    exact Nat.mul_le_mul_left _ hpow_sub_le
  have hfactor_lt : c ^ (p - q) * (c ^ q - 1) < c ^ p - 1 :=
    mul_pow_sub_one_lt_pow_sub_one_of_lt hc hqp
  have hright_lt :
      (c ^ q - 1) ^ q * (c ^ q) ^ (p - q) < (c ^ p - 1) ^ q := by
    calc
      (c ^ q - 1) ^ q * (c ^ q) ^ (p - q)
          = (c ^ (p - q) * (c ^ q - 1)) ^ q := by
            rw [mul_pow, pow_right_comm c q (p - q)]
            exact Nat.mul_comm _ _
      _ < (c ^ p - 1) ^ q := Nat.pow_lt_pow_left hfactor_lt hq0
  exact lt_of_le_of_lt hleft_le hright_lt

private lemma upper_adjacent_pow_gt_of_q_lt_p
    {c p q : ℕ} (hc : 1 < c) (hp0 : p ≠ 0) (hq2 : 2 ≤ q) (hqp : q < p) :
    (c ^ p - 1) ^ q + 1 < (c ^ q) ^ p := by
  have hcp_sub_pos : 0 < c ^ p - 1 := by
    have hcp_gt_one : 1 < c ^ p := one_lt_pow₀ hc hp0
    omega
  calc
    (c ^ p - 1) ^ q + 1 < ((c ^ p - 1) + 1) ^ q :=
      pow_add_one_lt_succ_pow hcp_sub_pos hq2
    _ = (c ^ q) ^ p := by
      rw [Nat.sub_add_cancel (Nat.one_le_pow p c (by omega))]
      exact pow_right_comm c p q

private lemma q_lt_p_consecutive_descent_impossible
    {a c p q : ℕ} (hp0 : p ≠ 0) (hq2 : 2 ≤ q)
    (hc : 1 < c) (hqp : q < p)
    (ha : a ^ p = (c ^ p - 1) ^ q + 1) :
    False := by
  have hq0 : q ≠ 0 := by omega
  have hlower := lower_adjacent_pow_lt_of_q_lt_p hc hq0 hqp
  have hupper := upper_adjacent_pow_gt_of_q_lt_p hc hp0 hq2 hqp
  have hlow_pow : (c ^ q - 1) ^ p < a ^ p := by
    rw [ha]
    omega
  have hhigh_pow : a ^ p < (c ^ q) ^ p := by
    rw [ha]
    exact hupper
  have hlow_a : c ^ q - 1 < a := by
    by_contra hnot
    push Not at hnot
    exact not_lt_of_ge (Nat.pow_le_pow_left hnot p) hlow_pow
  have hhigh_a : a < c ^ q := by
    by_contra hnot
    push Not at hnot
    exact not_lt_of_ge (Nat.pow_le_pow_left hnot p) hhigh_pow
  omega

private lemma exponent_primes_ne_of_consecutive_powers
    {d a b p q : ℕ} (hd : 0 < d) (hp : p.Prime) (hq : q.Prime)
    (ha : d + 1 = a ^ p) (hb : d = b ^ q) :
    p ≠ q := by
  intro hpq
  subst hpq
  have hb_ne_zero : b ≠ 0 := by
    intro hbz
    rw [hbz, zero_pow hq.ne_zero] at hb
    omega
  have hb_pos : 0 < b := Nat.pos_of_ne_zero hb_ne_zero
  have hpow_eq : a ^ p = b ^ p + 1 := by
    rw [← ha, ← hb]
  have hbpow_lt : b ^ p < a ^ p := by
    rw [hpow_eq]
    omega
  have hb_lt_a : b < a := by
    by_contra hnot
    push Not at hnot
    exact not_lt_of_ge (Nat.pow_le_pow_left hnot p) hbpow_lt
  have hdiff_pow : a ^ p - b ^ p = 1 := by
    rw [hpow_eq]
    omega
  have hdiff_dvd : a - b ∣ 1 := by
    simpa [hdiff_pow] using Nat.sub_dvd_pow_sub_pow a b p
  have hab_sub : a - b = 1 := Nat.eq_one_of_dvd_one hdiff_dvd
  have ha_eq : a = b + 1 := by omega
  have hgap := pow_add_one_lt_succ_pow hb_pos hp.two_le
  rw [← ha_eq] at hgap
  omega

private lemma singletonModFiveNatPower_branches_fail_gives_consecutive_powers
    {d : ℕ} (_hd : 5 ≤ d) (hodd : Odd d) (hmod : d % 6 = 5)
    (hfail_one :
      ¬ ∀ p : ℕ, p.Prime → p ∣ d → ¬ ∃ a : ℕ, d + 1 = a ^ p)
    (hfail_two :
      ¬ ∀ q : ℕ, q.Prime → q ∣ d →
        ¬ ∃ a : ℕ, Nat.choose (d + 1) 2 = a ^ q) :
    ∃ p q a b : ℕ,
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
      Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
      5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
      6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
      Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
      a % p = 1 ∧
      padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
      q ∣ padicValNat p (a - 1) + 1 ∧
      p ^ (q - 1) ∣ a - 1 ∧
      p ^ (2 * q - 1) ∣ a - 1 ∧
      (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
        3 ^ q ∣ c ∧
        (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
        c < a ∧
        (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
        (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
      (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
      3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
      ((q ∣ a - 1 ∧
          padicValNat q (a - 1) = q * padicValNat q b ∧
          q ^ q ∣ a - 1) ∨
        (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
      d + 1 = a ^ p ∧ d = b ^ q := by
  push Not at hfail_one hfail_two
  obtain ⟨p, hp, hpd, a, ha⟩ := hfail_one
  obtain ⟨q, hq, hqd, z, hz⟩ := hfail_two
  obtain ⟨b, hb⟩ :=
    left_factor_choose_two_is_pow_of_odd
      (by omega : d ≠ 0) hodd hq.ne_zero hz
  obtain ⟨e, he⟩ :=
    right_factor_choose_two_is_pow_of_odd
      (by omega : d ≠ 0) hodd hq.ne_zero hz
  obtain ⟨_, hp_ne_three, hp_odd⟩ :=
    prime_dvd_mod_six_five_ne_two_ne_three hmod hp hpd
  obtain ⟨_, hq_ne_three, hq_odd⟩ :=
    prime_dvd_mod_six_five_ne_two_ne_three hmod hq hqd
  have hp_dvd_b : p ∣ b := by
    apply hp.dvd_of_dvd_pow
    rw [← hb]
    exact hpd
  have hq_dvd_b : q ∣ b := by
    apply hq.dvd_of_dvd_pow
    rw [← hb]
    exact hqd
  have hcop_ab : Nat.Coprime a b :=
    coprime_bases_of_consecutive_powers hp.ne_zero hq.ne_zero ha hb
  have hp_not_dvd_a : ¬ p ∣ a := by
    intro hpa
    have hpgcd : p ∣ Nat.gcd a b := Nat.dvd_gcd hpa hp_dvd_b
    rw [Nat.Coprime.gcd_eq_one hcop_ab] at hpgcd
    exact hp.not_dvd_one hpgcd
  have hq_not_dvd_a : ¬ q ∣ a := by
    intro hqa
    have hqgcd : q ∣ Nat.gcd a b := Nat.dvd_gcd hqa hq_dvd_b
    rw [Nat.Coprime.gcd_eq_one hcop_ab] at hqgcd
    exact hq.not_dvd_one hqgcd
  have ha_mod_p : a % p = 1 :=
    upper_base_mod_exponent_prime_eq_one_of_consecutive_powers hp hpd hp_not_dvd_a ha
  have h6a : 6 ∣ a := base_dvd_six_of_succ_pow_mod_six_five hmod ha
  have ha_ne_zero : a ≠ 0 := by
    intro haz
    rw [haz, zero_pow hp.ne_zero] at ha
    omega
  have ha_gt_one : 1 < a := by
    obtain ⟨m, hm⟩ := h6a
    rcases m with _ | m
    · rw [hm] at ha_ne_zero
      exact False.elim (ha_ne_zero rfl)
    · omega
  have hp_val_eq : padicValNat p (a - 1) + 1 = q * padicValNat p b :=
    obstruction_padicVal_p_eq (by omega : 0 < d) hp hp_odd hq.ne_zero
      h6a
      hp_not_dvd_a ha_mod_p ha hb
  have hq_dvd_pval : q ∣ padicValNat p (a - 1) + 1 :=
    dvd_padicVal_succ_of_obstruction_padicVal_eq hp_val_eq
  have hb_ne_zero : b ≠ 0 := by
    intro hbz
    rw [hbz, zero_pow hq.ne_zero] at hb
    omega
  have hp_pow_dvd_a_sub_one : p ^ (q - 1) ∣ a - 1 :=
    pow_pred_exponent_dvd_base_sub_one_of_padic_obstruction
      hp hq hb_ne_zero hp_dvd_b hp_val_eq
  have hp_ne_q : p ≠ q :=
    exponent_primes_ne_of_consecutive_powers (by omega : 0 < d) hp hq ha hb
  have hb_mod_six : b % 6 = 5 :=
    base_mod_six_eq_five_of_pow_mod_six_five hmod hq.ne_zero hb
  have hb_succ_pow : ∃ c : ℕ, b + 1 = c ^ p ∧ c % p = 1 := by
    have hpow : a ^ p = b ^ q + 1 := by
      rw [← ha, ← hb]
    obtain ⟨c, hc⟩ := succ_lower_base_is_pow_of_odd_consecutive_powers
      hp hq hq_odd hq_dvd_b hpow
    exact ⟨c, hc, succ_power_base_mod_exponent_eq_one hp hp_dvd_b hc⟩
  have htwo_e : a ^ p = 2 * e ^ q := by
    have htwo_half : 2 * ((d + 1) / 2) = d + 1 := by
      obtain ⟨m, hm⟩ := hodd
      subst hm
      omega
    rw [he] at htwo_half
    rw [← ha]
    exact htwo_half.symm
  have hhalf_pow : ∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q :=
    ⟨e, he, htwo_e⟩
  have hthree_q_dvd_a : 3 ^ q ∣ a := by
    exact three_pow_exponent_dvd_upper_base_of_two_mul_qpow_eq_ppow
      hp hq hp_ne_q ha_ne_zero h6a htwo_e
  have hthree_pq_dvd_bq_succ : 3 ^ (p * q) ∣ b ^ q + 1 :=
    three_pow_mul_exponents_dvd_lower_power_succ hthree_q_dvd_a (by
      rw [← ha, ← hb])
  have hthree_dvd_b_succ : 3 ∣ b + 1 := by
    use (b + 1) / 3
    omega
  have hthree_pq_dvd_b_succ : 3 ^ (p * q) ∣ b + 1 :=
    prime_pow_dvd_succ_of_dvd_odd_power_succ
      hq hq_odd hq_dvd_b (by decide : Nat.Prime 3)
      (Nat.mul_pos hp.pos hq.pos) hthree_dvd_b_succ
      (by rw [← ha, ← hb]) hthree_pq_dvd_bq_succ
  have hodd_b : Odd b := by
    refine ⟨b / 2, ?_⟩
    omega
  have hhalf_b_succ_pow : ∃ s : ℕ, (b + 1) / 2 = s ^ q := by
    apply half_succ_lower_base_is_pow_of_two_mul_odd_power hq hq_odd hodd_b hq_dvd_b
    calc
      b ^ q + 1 = d + 1 := by rw [← hb]
      _ = a ^ p := ha
      _ = 2 * e ^ q := htwo_e
  have hb_succ_pow_branch :
      ∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
        3 ^ q ∣ c ∧
        (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
        c < a ∧
        (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
        (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q)) := by
    obtain ⟨c, hc, hcmod⟩ := hb_succ_pow
    obtain ⟨s, hs⟩ := hhalf_b_succ_pow
    have hc0 : c ≠ 0 := by
      intro hcz
      rw [hcz, zero_pow hp.ne_zero] at hc
      omega
    have hthree_cp : 3 ^ (p * q) ∣ c ^ p := by
      simpa [hc] using hthree_pq_dvd_b_succ
    have h6c : 6 ∣ c := base_dvd_six_of_succ_pow_mod_six_five hb_mod_six hc
    have hc_gt_one : 1 < c := by
      have hc_ne_zero : c ≠ 0 := hc0
      obtain ⟨m, hm⟩ := h6c
      rcases m with _ | m
      · exact False.elim (hc_ne_zero (by omega))
      · omega
    have hc_lt_a : c < a := by
      have hb_ge_q : q ≤ b := Nat.le_of_dvd (Nat.pos_of_ne_zero hb_ne_zero) hq_dvd_b
      have hb_gt_one : 1 < b := by omega
      have hb_lt_bq : b < b ^ q := by
        simpa using ((Nat.pow_lt_pow_iff_right hb_gt_one).2 hq.one_lt)
      have hcp_lt_ap : c ^ p < a ^ p := by
        calc
          c ^ p = b + 1 := hc.symm
          _ < b ^ q + 1 := Nat.add_lt_add_right hb_lt_bq 1
          _ = a ^ p := by rw [← ha, ← hb]
      by_contra hnot
      push Not at hnot
      exact not_lt_of_ge (Nat.pow_le_pow_left hnot p) hcp_lt_ap
    have hc_pow_two : c ^ p = 2 * s ^ q := by
      have htwo_half_b : 2 * ((b + 1) / 2) = b + 1 := by
        obtain ⟨m, hm⟩ := hodd_b
        subst hm
        omega
      rw [hs] at htwo_half_b
      rw [← hc]
      exact htwo_half_b.symm
    have hquotient_qpow :
        ∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c := by
      have hpow_ap : a ^ p = b ^ q + 1 := by
        rw [← ha, ← hb]
      have hcp_dvd_ap : c ^ p ∣ a ^ p := by
        rw [← hc]
        exact succ_lower_base_dvd_upper_power_of_odd_consecutive_powers hq_odd hpow_ap
      have hc_dvd_a : c ∣ a :=
        base_dvd_of_same_pow_dvd_same_pow hp.ne_zero hc0 ha_ne_zero hcp_dvd_ap
      obtain ⟨r, hr⟩ := hc_dvd_a
      have hr_gt_one : 1 < r := by
        have hr_ne_zero : r ≠ 0 := by
          intro hrz
          rw [hrz, mul_zero] at hr
          exact ha_ne_zero hr
        have hr_ne_one : r ≠ 1 := by
          intro hr1
          rw [hr1, mul_one] at hr
          omega
        omega
      obtain ⟨t, ht⟩ :=
        quotient_is_qpow_of_two_mul_qpow_eq_ppow hp hq hp_ne_q
          ha_ne_zero hc0 hr htwo_e hc_pow_two
      have ht_gt_one : 1 < t := by
        cases t with
        | zero =>
            rw [zero_pow hq.ne_zero] at ht
            omega
        | succ t =>
            cases t with
            | zero =>
                simp at ht
                omega
            | succ t => omega
      have ht_lt_c : t < c := by
        have ha_c : a ^ p = (c ^ p - 1) ^ q + 1 := by
          calc
            a ^ p = b ^ q + 1 := hpow_ap
            _ = (c ^ p - 1) ^ q + 1 := by
              have hb_eq : b = c ^ p - 1 := by omega
              rw [hb_eq]
        have hcp_sub_pos : 0 < c ^ p - 1 := by
          have hcp_gt_one : 1 < c ^ p := one_lt_pow₀ hc_gt_one hp.ne_zero
          omega
        have hupper_cp : (c ^ p - 1) ^ q + 1 < (c ^ p) ^ q := by
          calc
            (c ^ p - 1) ^ q + 1 < ((c ^ p - 1) + 1) ^ q :=
              pow_add_one_lt_succ_pow hcp_sub_pos hq.two_le
            _ = (c ^ p) ^ q := by
              rw [Nat.sub_add_cancel (Nat.one_le_pow p c (by omega))]
        have ha_lt_cpq : a ^ p < (c ^ p) ^ q := by
          rw [ha_c]
          exact hupper_cp
        have hmul_form : a ^ p = c ^ p * (t ^ q) ^ p := by
          rw [hr, ht, mul_pow]
        have hright_eq : (c ^ p) ^ q = c ^ p * (c ^ (q - 1)) ^ p := by
          calc
            (c ^ p) ^ q = (c ^ p) ^ ((q - 1) + 1) := by
              congr 1
              exact (Nat.sub_add_cancel hq.one_le).symm
            _ = (c ^ p) ^ (q - 1) * c ^ p := by rw [pow_succ]
            _ = c ^ p * (c ^ p) ^ (q - 1) := by rw [mul_comm]
            _ = c ^ p * (c ^ (q - 1)) ^ p := by
              congr 1
              exact pow_right_comm c p (q - 1)
        have hprod_lt : c ^ p * (t ^ q) ^ p < c ^ p * (c ^ (q - 1)) ^ p := by
          rw [← hmul_form, ← hright_eq]
          exact ha_lt_cpq
        have htq_pow_lt : (t ^ q) ^ p < (c ^ (q - 1)) ^ p :=
          lt_of_mul_lt_mul_left hprod_lt (Nat.zero_le _)
        have htq_lt : t ^ q < c ^ (q - 1) := by
          by_contra hnot
          push Not at hnot
          exact not_lt_of_ge (Nat.pow_le_pow_left hnot p) htq_pow_lt
        by_contra hnot
        push Not at hnot
        have hcq_le_tq : c ^ q ≤ t ^ q := Nat.pow_le_pow_left hnot q
        have hpred_lt : q - 1 < q := Nat.pred_lt hq.ne_zero
        have hcpred_lt_cq : c ^ (q - 1) < c ^ q :=
          (Nat.pow_lt_pow_iff_right hc_gt_one).2 hpred_lt
        omega
      exact ⟨r, t, hr, hr_gt_one, ht, ht_gt_one, ht_lt_c⟩
    exact ⟨c, hc, h6c,
      hcmod,
      prime_pow_dvd_base_of_prime_pow_mul_exponent_dvd_pow
        (by decide : Nat.Prime 3) hp hc0 hthree_cp,
      ⟨s, hc_pow_two⟩,
      hc_lt_a,
      hquotient_qpow,
      order_branch_of_succ_power hp hq hq_dvd_b hc⟩
  have hp_sq_dvd_b : p ^ 2 ∣ b := by
    obtain ⟨c, hc, hcmod⟩ := hb_succ_pow
    exact sq_exponent_dvd_base_of_succ_power_mod_exponent_eq_one hp hp_odd hc hcmod
  have hp_big_pow_dvd_a_sub_one : p ^ (2 * q - 1) ∣ a - 1 :=
    pow_two_mul_pred_exponent_dvd_base_sub_one_of_padic_obstruction
      hp hq hb_ne_zero hp_sq_dvd_b hp_val_eq
  have hp5 : 5 ≤ p := five_le_of_prime_odd_ne_three hp hp_odd hp_ne_three
