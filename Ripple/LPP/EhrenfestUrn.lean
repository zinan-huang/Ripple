    Nat.le_of_dvd (Nat.pos_of_ne_zero hc0) h3qc
  have hq_lt_3q : q < 3 ^ q := by
    exact Nat.lt_pow_self (by norm_num : 1 < 3)
  exact ⟨c, t, hc, hdesc, ht_gt_one, ht_lt_c, hp_lt_q,
    lt_of_lt_of_le hq_lt_3q h3q_le_c⟩

private lemma obstruction_q_branch_modEq_summary
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
