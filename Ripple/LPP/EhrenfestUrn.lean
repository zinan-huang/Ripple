      p ^ n * H₁ = H := hH₁_scale.symm
      _ = p ^ n * K := hK
  have hqD : ¬ q ∣ D := by
    intro hqD
    rw [hDK] at hqD
    exact hqK hqD
  have hqC₁ : ¬ q ∣ C₁ := by
    intro hqC₁
    exact hqC (by
      rw [hC₁_scale]
      exact dvd_mul_of_dvd_right hqC₁ (p ^ n))
  have hqT₁ : ¬ q ∣ T₁ := by
    intro hqT₁
    exact hqT (by
      rw [hT₁_scale]
      exact dvd_mul_of_dvd_right hqT₁ (p ^ n))
  have hqH₁ : ¬ q ∣ H₁ := by
    rw [hH₁D]
    exact hqD
  have hU_norm : U = q ^ m * C₁ := by
    apply Nat.mul_left_cancel (pow_pos hp.pos n)
