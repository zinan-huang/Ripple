      ht_gt_one, ht_lt_c, hp_lt_q, hq_lt_c,
      hq_not_c, hq_not_t, hcop_ct, ht_mod_q, ht_mod_c, ht_mod_six,
      h2s, h3s, h6s, h3ps, hp_not_dvd_s,
      h4C, h2S, hC_lt_c, hp_not_dvd_C, hp_not_dvd_S⟩
  rcases obstruction_common_padic_linear_congruence hobs with
    ⟨c₂, t₂, n, U, V, hc₂, hdesc₂, _ht₂_gt_one, _ht₂_lt_c₂,
      hn_pos, hc₂_sub_eq, ht₂_sub_eq, hVU, hpU, hpV, hlin⟩
  have hc₂_pow_eq : c₂ ^ p = c ^ p := by
    rw [← hc₂, hc]
  have hc₂_eq_c : c₂ = c := Nat.pow_left_injective hp.ne_zero hc₂_pow_eq
  have hc_pos : 0 < c := Nat.pos_of_ne_zero (by
    intro hc0
    exact hq_not_c (by rw [hc0]; exact dvd_zero q))
  have ht₂_pow_eq : t₂ ^ q = t ^ q := by
    apply Nat.mul_left_cancel hc_pos
    calc
      c * t₂ ^ q = c₂ * t₂ ^ q := by rw [hc₂_eq_c]
      _ = a := hdesc₂.symm
      _ = c * t ^ q := hdesc
  have ht₂_eq_t : t₂ = t := Nat.pow_left_injective hq.ne_zero ht₂_pow_eq
  have hc_sub_eq : c - 1 = p ^ n * U := by
    rw [← hc₂_eq_c]
    exact hc₂_sub_eq
  have ht_sub_eq : t - 1 = p ^ n * V := by
    rw [← ht₂_eq_t]
