    exact (Nat.mul_dvd_mul_iff_left (pow_pos hq.pos n)).mp hlinear_scaled
  have hcv_split : C + c * V = (C + V) + V * (c - 1) := by
    have hc_form : c = (c - 1) + 1 := by omega
    rw [hc_form]
    have hpred_mul : V * ((c - 1) + 1 - 1) = V * (c - 1) := by
