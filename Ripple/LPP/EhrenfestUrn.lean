/-! ## Ehrenfest rule and drift polynomial -/

/-- An Ehrenfest recoloring rule: k agents interact simultaneously,
and f determines the new state based on the count of black agents.
`f j = true` means "recolor all k drawn balls to black when j of them
were black." -/
structure EhrenfestRule where
  k : ℕ
  k_pos : 0 < k
  f : Fin (k + 1) → Bool

namespace EhrenfestRule

variable (rule : EhrenfestRule)

/-- E_f = {j : f(j) = true}: input counts producing black output. -/
def blackSet : Finset (Fin (rule.k + 1)) :=
  Finset.univ.filter fun j => rule.f j = true

/-- Bernstein basis term: C(k,j) · y^j · (1-y)^{k-j}.
The probability that exactly j of k independent Bernoulli(y) trials
succeed, i.e., the j-th Bernstein basis polynomial of degree k. -/
noncomputable def bernsteinTerm (j : Fin (rule.k + 1)) (y : ℝ) : ℝ :=
  (Nat.choose rule.k j.val : ℝ) * y ^ j.val * (1 - y) ^ (rule.k - j.val)

/-- The drift function b : [0,1] → ℝ.

  b(y) = k · P(Bin(k,y) ∈ E_f) − k·y

Expected per-step change in black proportion, scaled to continuous time.
The roots of b are the equilibria of the mean-field ODE dx/dt = b(x). -/
noncomputable def driftFn (y : ℝ) : ℝ :=
  (rule.k : ℝ) * ∑ j ∈ rule.blackSet, rule.bernsteinTerm j y -
  (rule.k : ℝ) * y

/-! ### Bernstein partition of unity -/

/-- The Bernstein basis forms a partition of unity:
  Σ_{j=0}^k C(k,j) y^j (1-y)^{k-j} = (y + (1-y))^k = 1.
Follows from the binomial theorem. -/
theorem bernstein_sum_eq_one (y : ℝ) :
    ∑ j : Fin (rule.k + 1), rule.bernsteinTerm j y = 1 := by
  simp only [bernsteinTerm]
  -- Reorder factors to match add_pow's output
  have reorder : ∀ j : Fin (rule.k + 1),
      (Nat.choose rule.k j.val : ℝ) * y ^ j.val * (1 - y) ^ (rule.k - j.val) =
      y ^ j.val * (1 - y) ^ (rule.k - j.val) * (Nat.choose rule.k j.val : ℝ) :=
    fun j => by ring
  simp_rw [reorder]
  -- Show the sum equals (y + (1-y))^k = 1^k = 1
  have h := add_pow y (1 - y) rule.k
  rw [add_sub_cancel, one_pow] at h
  -- h : 1 = ∑ m ∈ range (k+1), y^m * (1-y)^(k-m) * C(k,m)
  -- Goal: ∑ j : Fin (k+1), y^j * (1-y)^(k-j) * C(k,j) = 1
  rw [Fin.sum_univ_eq_sum_range
    (fun m => y ^ m * (1 - y) ^ (rule.k - m) * (Nat.choose rule.k m : ℝ)) (rule.k + 1)]
  linarith

/-! ### Evaluation at boundary points -/

private lemma bernsteinTerm_at_zero (j : Fin (rule.k + 1)) :
    rule.bernsteinTerm j 0 = if j = 0 then 1 else 0 := by
  simp only [bernsteinTerm, sub_zero, one_pow, mul_one]
  split_ifs with hj
  · subst hj; simp
  · rw [zero_pow (Fin.val_ne_of_ne hj), mul_zero]

private lemma bernsteinTerm_at_one (j : Fin (rule.k + 1)) :
    rule.bernsteinTerm j 1 =
      if j = Fin.last rule.k then 1 else 0 := by
  simp only [bernsteinTerm, one_pow, mul_one, sub_self]
  split_ifs with hj
  · subst hj; simp [Fin.last]
  · have hv : j.val ≠ rule.k := by
      intro h; exact hj (Fin.ext (by simp [Fin.last, h]))
    rw [zero_pow (by omega), mul_zero]

/-- b(0) = k · 𝟙(0 ∈ E_f). Positive iff the rule activates on all-white input. -/
theorem driftFn_zero :
    rule.driftFn 0 =
      if rule.f (0 : Fin (rule.k + 1)) then (rule.k : ℝ) else 0 := by
  simp only [driftFn, mul_zero, sub_zero]
  simp_rw [bernsteinTerm_at_zero]
  rw [Finset.sum_ite_eq' rule.blackSet 0 (fun _ => (1 : ℝ))]
  simp only [blackSet, Finset.mem_filter, Finset.mem_univ, true_and]
  split_ifs <;> ring

/-- b(1) = k · (𝟙(k ∈ E_f) − 1). Zero iff the rule stabilizes full-black. -/
theorem driftFn_one :
    rule.driftFn 1 =
      if rule.f (Fin.last rule.k) then 0
      else -(rule.k : ℝ) := by
  simp only [driftFn, mul_one]
  simp_rw [bernsteinTerm_at_one]
  rw [Finset.sum_ite_eq' rule.blackSet (Fin.last rule.k) (fun _ => (1 : ℝ))]
  simp only [blackSet, Finset.mem_filter, Finset.mem_univ, true_and]
  split_ifs <;> ring

/-- b(1) ≤ 0. At full-black, the drift is always non-positive. -/
theorem driftFn_one_nonpos : rule.driftFn 1 ≤ 0 := by
  rw [rule.driftFn_one]
  split_ifs
  · exact le_refl _
  · exact neg_nonpos.mpr (Nat.cast_nonneg _)

/-- The drift function is continuous (polynomial in y). -/
theorem driftFn_continuous : Continuous rule.driftFn := by
  apply Continuous.sub
  · apply Continuous.mul continuous_const
    apply continuous_finset_sum
    intro j _
    show Continuous fun y => rule.bernsteinTerm j y
    unfold bernsteinTerm
    exact (continuous_const.mul (continuous_id.pow _)).mul
      ((continuous_const.sub continuous_id).pow _)
  · exact continuous_const.mul continuous_id

/-! ## Complement rule and symmetry -/

/-- The complement rule f̄(j) = ¬f(k−j): swapping black ↔ white. -/
def complement : EhrenfestRule where
  k := rule.k
  k_pos := rule.k_pos
  f := fun j => !(rule.f ⟨rule.k - j.val, by omega⟩)

/-- Drift symmetry: b_{f̄}(y) = −b_f(1−y).
The complement rule mirrors the dynamics about the midpoint y = 1/2.
Proof uses the Bernstein partition of unity and the reflection identity
  B_j(1−y) = B_{k−j}(y). -/
theorem driftFn_complement (y : ℝ) :
    rule.complement.driftFn y = -rule.driftFn (1 - y) := by
  -- The reflection map φ(j) = k − j on Fin(k+1)
  -- Note: complement.k = rule.k definitionally, so Fin(complement.k+1) = Fin(rule.k+1)
  let φ : Fin (rule.k + 1) → Fin (rule.k + 1) :=
    fun j => ⟨rule.k - j.val, by omega⟩
  have hφ_inj : Function.Injective φ := by
    intro a b h; simp only [φ, Fin.mk.injEq] at h; ext; omega
  -- Bernstein reflection: B_j(1−y) = B_{φ(j)}(y)
  have hrefl : ∀ j : Fin (rule.k + 1),
      rule.bernsteinTerm j (1 - y) = rule.bernsteinTerm (φ j) y := by
    intro j; simp only [bernsteinTerm, φ]
    have hj : j.val ≤ rule.k := by omega
    rw [Nat.choose_symm hj, Nat.sub_sub_self hj]; ring
  -- complement.bernsteinTerm = rule.bernsteinTerm
  have hbt : ∀ j, rule.complement.bernsteinTerm j y = rule.bernsteinTerm j y := by
    intro j; simp [bernsteinTerm, complement]
  -- complement.blackSet and blackSet.image φ partition Fin(k+1)
  have hunion : rule.complement.blackSet ∪ rule.blackSet.image φ = Finset.univ := by
    ext j; simp only [Finset.mem_union, Finset.mem_univ, iff_true]
    -- Bool.eq_false_or_eq_true gives b = true ∨ b = false
    rcases Bool.eq_false_or_eq_true (rule.f ⟨rule.k - j.val, by omega⟩) with hf | hf
    · -- f(k-j) = true → ⟨k-j, _⟩ ∈ blackSet → φ(⟨k-j,_⟩) = j → j ∈ image
      right
      refine Finset.mem_image.mpr ⟨⟨rule.k - j.val, by omega⟩, ?_, ?_⟩
      · exact Finset.mem_filter.mpr ⟨Finset.mem_univ _, hf⟩
      · change φ ⟨rule.k - j.val, _⟩ = j
        ext; simp [φ]; omega
    · -- f(k-j) = false → (!f(k-j)) = true → j ∈ complement.blackSet
      left
      simp only [blackSet, complement]
      refine Finset.mem_filter.mpr ⟨Finset.mem_univ _, ?_⟩
      change (!rule.f ⟨rule.k - ↑j, _⟩) = true
      rw [hf]; rfl
  have hdisj : Disjoint rule.complement.blackSet (rule.blackSet.image φ) := by
    rw [Finset.disjoint_left]
    intro j hj hmem
    have hj' := (Finset.mem_filter.mp hj).2
    -- hj' : complement.f j = true, i.e. (!rule.f ⟨k-j,_⟩) = true
    obtain ⟨a, ha_mem, heq⟩ := Finset.mem_image.mp hmem
    have ha := (Finset.mem_filter.mp ha_mem).2
    -- ha : rule.f a = true
    -- j : Fin(complement.k + 1) = Fin(rule.k + 1), so j.val ≤ rule.k
    have hjle : j.val ≤ rule.k := by
      have := j.isLt; change j.val < rule.complement.k + 1 at this; simp [complement] at this
      omega
    have hav : a.val = rule.k - j.val := by
      have := congr_arg Fin.val heq
      simp only [φ] at this
      omega
    -- So rule.f ⟨k-j,_⟩ = true
    have hbound : rule.k - j.val < rule.k + 1 := by omega
    have hft : rule.f ⟨rule.k - j.val, hbound⟩ = true := by
      rwa [show a = ⟨rule.k - j.val, hbound⟩ from Fin.ext hav] at ha
    -- But complement.f j = true means (!rule.f ⟨k-j,_⟩) = true
    simp only [complement] at hj'
    -- hj' : (!rule.f ⟨rule.k - j.val, _⟩) = true
    have : ((!rule.f ⟨rule.k - j.val, _⟩) : Bool) = true := hj'
    rw [hft] at this; simp at this
  -- Key identity: ∑_{complement.blackSet} B_j(y) + ∑_{blackSet} B_j(1-y) = 1
  have hsum : ∑ j ∈ rule.complement.blackSet, rule.bernsteinTerm j y +
      ∑ j ∈ rule.blackSet, rule.bernsteinTerm j (1 - y) = 1 := by
    simp_rw [hrefl]
    rw [← Finset.sum_image (f := fun j => rule.bernsteinTerm j y)
      (fun a _ b _ h => hφ_inj h)]
    -- Goal: ∑_{compl.bs} B_j(y) + ∑_{bs.image φ} B_j(y) = 1
    -- The bound vars may differ (j vs x), so use calc
    have h1 : ∑ j ∈ rule.complement.blackSet, rule.bernsteinTerm j y +
        ∑ j ∈ rule.blackSet.image φ, rule.bernsteinTerm j y =
        ∑ j ∈ rule.complement.blackSet ∪ rule.blackSet.image φ,
          rule.bernsteinTerm j y :=
      (Finset.sum_union hdisj).symm
    rw [h1, hunion]
    exact rule.bernstein_sum_eq_one y
  -- Conclude by linear algebra
  simp only [driftFn]
  have hbt_sum : ∑ j ∈ rule.complement.blackSet, rule.complement.bernsteinTerm j y =
      ∑ j ∈ rule.complement.blackSet, rule.bernsteinTerm j y :=
    Finset.sum_congr rfl (fun j _ => hbt j)
  rw [hbt_sum]
  change (rule.k : ℝ) * ∑ j ∈ rule.complement.blackSet, rule.bernsteinTerm j y -
    (rule.k : ℝ) * y =
    -((rule.k : ℝ) * ∑ j ∈ rule.blackSet, rule.bernsteinTerm j (1 - y) -
    (rule.k : ℝ) * (1 - y))
  nlinarith

/-! ## PIVP constructions -/

/-- Semantic 1D PIVP: dx/dt = b(x), x(0) = x₀, output = x. -/
noncomputable def toPIVP (x₀ : ℚ) : PIVP 1 where
  field := fun x => fun _ => rule.driftFn (x 0)
  init := fun _ => (x₀ : ℝ)
  output := 0

/-- The drift polynomial as MvPolynomial (Fin 1) ℚ for the syntactic PIVP.
Bernstein-form representation:
  k · Σ_{j∈E} C(k,j) · Y^j · (1−Y)^{k−j} − k · Y -/
noncomputable def driftMvPoly : MvPolynomial (Fin 1) ℚ :=
  let Y : MvPolynomial (Fin 1) ℚ := MvPolynomial.X 0
  (rule.k : ℚ) • ∑ j ∈ rule.blackSet,
    (Nat.choose rule.k j.val : ℚ) • (Y ^ j.val * (1 - Y) ^ (rule.k - j.val)) -
  (rule.k : ℚ) • Y

/-- Syntactic PolyPIVP with rational initial data. -/
noncomputable def toPolyPIVP (x₀ : ℚ) : PolyPIVP 1 where
  field := fun _ => rule.driftMvPoly
  init := fun _ => x₀
  output := 0

/-- The syntactic PIVP evaluates to the semantic drift function. -/
theorem toPolyPIVP_eval (x₀ : ℚ) (x : Fin 1 → ℝ) :
    (rule.toPolyPIVP x₀).evalField x 0 = rule.driftFn (x 0) := by
  simp only [PolyPIVP.evalField, toPolyPIVP, driftMvPoly, driftFn]
  -- Rewrite eval₂ as eval₂Hom application so ring hom lemmas apply
  rw [show MvPolynomial.eval₂ (Rat.castHom ℝ) x = ⇑(MvPolynomial.eval₂Hom (Rat.castHom ℝ) x)
    from (MvPolynomial.coe_eval₂Hom (Rat.castHom ℝ) x).symm]
  rw [map_sub, MvPolynomial.eval₂Hom_smul, MvPolynomial.eval₂Hom_smul,
    map_sum, MvPolynomial.eval₂Hom_X']
  simp only [MvPolynomial.eval₂Hom_smul, map_mul, map_pow,
    MvPolynomial.eval₂Hom_X', map_sub, map_one]
  simp only [bernsteinTerm, smul_eq_mul]
  congr 1
  · congr 1
    apply Finset.sum_congr rfl
    intro j _
    -- (Rat.castHom ℝ) ↑(choose k j) needs to become (↑(choose k j) : ℝ)
    simp only [map_natCast]
    ring

/-! ## Two-species embedding for LPP -/

/-- The 2-species vector field: x₀' = b(x₀), x₁' = −b(x₀).
Embeds the 1D Ehrenfest ODE into the LPP framework as a
conservative system on the probability simplex x₀ + x₁ = 1. -/
noncomputable def twoSpeciesField : (Fin 2 → ℝ) → Fin 2 → ℝ :=
  fun x i =>
    if i = (0 : Fin 2) then rule.driftFn (x 0)
    else -rule.driftFn (x 0)

/-- The 2-species field is conservative: x₀' + x₁' = 0. -/
theorem twoSpeciesField_conservative (x : Fin 2 → ℝ) :
    ∑ i : Fin 2, rule.twoSpeciesField x i = 0 := by
  have h0 : rule.twoSpeciesField x 0 = rule.driftFn (x 0) := by
    simp [twoSpeciesField]
  have h1 : rule.twoSpeciesField x 1 = -rule.driftFn (x 0) := by
    simp [twoSpeciesField, show (1 : Fin 2) ≠ (0 : Fin 2) from by decide]
  rw [Fin.sum_univ_two, h0, h1, add_neg_cancel]

end EhrenfestRule

/-! ## Ehrenfest computability

The definition handles both increasing convergence (from below) and
decreasing convergence (from above), since the complement rule
flips the direction. -/

/-- A real number ν ∈ [0,1] is Ehrenfest-computable if some rule (k, f)
and starting proportion x₀ produce a mean-field ODE converging to ν.

Two convergence modes (Theorem 4 in Albenque-Gerin):
- From below: x₀ < ν, b > 0 on [x₀, ν) — trajectory increases to ν.
- From above: ν < x₀, b < 0 on (ν, x₀] — trajectory decreases to ν.
In both cases, convergence is exponential with rate |b'(ν)|. -/
def IsEhrenfestComputable (ν : ℝ) : Prop :=
  ∃ (rule : EhrenfestRule) (x₀ : ℝ),
    x₀ ∈ Set.Icc 0 1 ∧
    (∃ q : ℚ, x₀ = (q : ℝ)) ∧
    ν ∈ Set.Icc 0 1 ∧
    rule.driftFn ν = 0 ∧
    ((x₀ < ν ∧ ∀ y, x₀ ≤ y → y < ν → 0 < rule.driftFn y) ∨
     (ν < x₀ ∧ ∀ y, ν < y → y ≤ x₀ → rule.driftFn y < 0))

namespace IsEhrenfestComputable

/-- Monotone convergence: a solution trapped in [x₀, ν] with positive drift converges to ν.
Given: φ' = b(φ), φ stays in [x₀, ν], b > 0 on [x₀, ν), b(ν) = 0.
Conclusion: φ → ν. -/
private theorem increasing_tendsto
    (rule : EhrenfestRule) (φ : ℝ → ℝ) (x₀ ν : ℝ)
    (hode : ∀ t, 0 ≤ t → HasDerivAt φ (rule.driftFn (φ t)) t)
    (hφ_ge : ∀ t, 0 ≤ t → x₀ ≤ φ t)
    (hφ_le : ∀ t, 0 ≤ t → φ t ≤ ν)
    (hroot : rule.driftFn ν = 0)
    (hpos : ∀ y, x₀ ≤ y → y < ν → 0 < rule.driftFn y) :
    Filter.Tendsto φ Filter.atTop (nhds ν) := by
  have h_drift_nn : ∀ t, 0 ≤ t → 0 ≤ rule.driftFn (φ t) := by
    intro t ht
    rcases eq_or_lt_of_le (hφ_le t ht) with heq | hlt
    · rw [heq, hroot]
    · exact le_of_lt (hpos (φ t) (hφ_ge t ht) hlt)
  have h_mono_on : MonotoneOn φ (Set.Ici 0) := by
    intro s (hs : (0 : ℝ) ≤ s) t (_ht : (0 : ℝ) ≤ t) (hst : s ≤ t)
    exact monotoneOn_of_hasDerivWithinAt_nonneg (convex_Icc s t)
      (fun u ⟨hus, _⟩ => (hode u (le_trans hs hus)).continuousAt.continuousWithinAt)
      (fun u hu => (hode u (le_trans hs (interior_subset hu).1)).hasDerivWithinAt)
      (fun u hu => h_drift_nn u (le_trans hs (interior_subset hu).1))
      (Set.left_mem_Icc.mpr hst) (Set.right_mem_Icc.mpr hst) hst
  set g : ℝ → ℝ := fun t => φ (max t 0)
  have hg_mono : Monotone g := by
    intro s t hst
    show φ (max s 0) ≤ φ (max t 0)
    exact h_mono_on (Set.mem_Ici.mpr (le_max_right _ _))
      (Set.mem_Ici.mpr (le_max_right _ _)) (max_le_max_right 0 hst)
  have hg_bdd : ∀ t, g t ≤ ν := fun t => hφ_le _ (le_max_right _ _)
  have h_bdd : BddAbove (Set.range g) := ⟨ν, fun _ ⟨t, ht⟩ => ht ▸ hg_bdd t⟩
  set L := ⨆ t : ℝ, g t
  have hL_le : L ≤ ν := ciSup_le hg_bdd
  have hg_tend : Filter.Tendsto g Filter.atTop (nhds L) :=
    tendsto_atTop_ciSup hg_mono h_bdd
  have h_ev : ∀ᶠ t in Filter.atTop, g t = φ t := by
    filter_upwards [Filter.eventually_ge_atTop (0 : ℝ)] with t ht
    show φ (max t 0) = φ t; rw [max_eq_left ht]
  have hφ_tend : Filter.Tendsto φ Filter.atTop (nhds L) := hg_tend.congr' h_ev
  have hL_ge : x₀ ≤ L := by
    have : g 0 ≤ L := le_ciSup h_bdd 0
    simp only [g, max_self] at this
    exact le_trans (hφ_ge 0 le_rfl) this
  have h_bL : rule.driftFn L = 0 := by
    by_contra h_ne
    rcases eq_or_lt_of_le hL_le with heq | hlt
    · exact h_ne (heq ▸ hroot)
    · have h_bL_pos : 0 < rule.driftFn L := hpos L hL_ge hlt
      have h_btend : Filter.Tendsto (fun t => rule.driftFn (φ t))
          Filter.atTop (nhds (rule.driftFn L)) :=
        rule.driftFn_continuous.continuousAt.tendsto.comp hφ_tend
      have h_ev_b : ∀ᶠ t in Filter.atTop,
          rule.driftFn L / 2 < rule.driftFn (φ t) :=
        h_btend (Ioi_mem_nhds (by linarith))
      obtain ⟨T, hT⟩ := Filter.eventually_atTop.mp
        (h_ev_b.and (Filter.eventually_ge_atTop (0 : ℝ)))
      set T' := max T 0
      have hT'_nn : (0 : ℝ) ≤ T' := le_max_right _ _
      have hφ_T'_ge : x₀ ≤ φ T' := hφ_ge T' hT'_nn
      have h_grow : ∀ N : ℝ, 0 ≤ N →
          φ T' + rule.driftFn L / 2 * N ≤ φ (T' + N) := by
        intro N hN
        have h_lin_deriv : ∀ u, HasDerivAt (fun s => rule.driftFn L / 2 * s)
            (rule.driftFn L / 2) u := by
          intro u; simpa using (hasDerivAt_id u).const_mul (rule.driftFn L / 2)
        have h_mono_f := monotoneOn_of_hasDerivWithinAt_nonneg (convex_Icc T' (T' + N))
          (fun u ⟨hu1, _⟩ =>
            ((hode u (by linarith)).sub (h_lin_deriv u)).continuousAt.continuousWithinAt)
          (fun u hu =>
            ((hode u (by linarith [hT'_nn, (interior_subset hu).1])).sub
              (h_lin_deriv u)).hasDerivWithinAt)
          (fun u hu => by
            have hu_ge_T : T ≤ u := le_trans (le_max_left _ _) (interior_subset hu).1
            linarith [(hT u hu_ge_T).1])
        have h_le := h_mono_f (Set.left_mem_Icc.mpr (by linarith))
          (Set.right_mem_Icc.mpr (by linarith)) (by linarith : T' ≤ T' + N)
        simp only [Pi.sub_apply] at h_le
        linarith
      have hx0_lt_ν : x₀ < ν := lt_of_le_of_lt hL_ge hlt
      set N := 2 * (ν - x₀ + 1) / rule.driftFn L
      have hN_nn : 0 ≤ N := div_nonneg (by linarith) (le_of_lt h_bL_pos)
      have h1 := h_grow N hN_nn
      have h2 := hφ_le (T' + N) (by linarith)
      have h3 : rule.driftFn L / 2 * N = ν - x₀ + 1 := by
        simp only [N]
        have hne : rule.driftFn L ≠ 0 := ne_of_gt h_bL_pos
        field_simp
      linarith
  rcases eq_or_lt_of_le hL_le with heq | hlt
  · rw [← heq]; exact hφ_tend
  · exact absurd h_bL (ne_of_gt (hpos L hL_ge hlt))

/-- Monotone convergence for the decreasing case: symmetric to increasing_tendsto. -/
private theorem decreasing_tendsto
    (rule : EhrenfestRule) (φ : ℝ → ℝ) (x₀ ν : ℝ)
    (hode : ∀ t, 0 ≤ t → HasDerivAt φ (rule.driftFn (φ t)) t)
    (hφ_ge : ∀ t, 0 ≤ t → ν ≤ φ t)
    (hφ_le : ∀ t, 0 ≤ t → φ t ≤ x₀)
    (hroot : rule.driftFn ν = 0)
    (hneg : ∀ y, ν < y → y ≤ x₀ → rule.driftFn y < 0) :
    Filter.Tendsto φ Filter.atTop (nhds ν) := by
  have h_drift_np : ∀ t, 0 ≤ t → rule.driftFn (φ t) ≤ 0 := by
    intro t ht
    rcases eq_or_lt_of_le (hφ_ge t ht) with heq | hlt
    · rw [← heq, hroot]
    · exact le_of_lt (hneg (φ t) hlt (hφ_le t ht))
  have h_anti_on : AntitoneOn φ (Set.Ici 0) := by
    intro s (hs : (0 : ℝ) ≤ s) t (_ht : (0 : ℝ) ≤ t) (hst : s ≤ t)
    exact antitoneOn_of_hasDerivWithinAt_nonpos (convex_Icc s t)
      (fun u ⟨hus, _⟩ => (hode u (le_trans hs hus)).continuousAt.continuousWithinAt)
      (fun u hu => (hode u (le_trans hs (interior_subset hu).1)).hasDerivWithinAt)
      (fun u hu => h_drift_np u (le_trans hs (interior_subset hu).1))
      (Set.left_mem_Icc.mpr hst) (Set.right_mem_Icc.mpr hst) hst
  set g : ℝ → ℝ := fun t => φ (max t 0)
  have hg_anti : Antitone g := by
    intro s t hst
    show φ (max s 0) ≥ φ (max t 0)
    exact h_anti_on (Set.mem_Ici.mpr (le_max_right _ _))
      (Set.mem_Ici.mpr (le_max_right _ _)) (max_le_max_right 0 hst)
  have hg_bdd : ∀ t, ν ≤ g t := fun t => hφ_ge _ (le_max_right _ _)
  have h_bdd : BddBelow (Set.range g) := ⟨ν, fun _ ⟨t, ht⟩ => ht ▸ hg_bdd t⟩
  set L := ⨅ t : ℝ, g t
  have hL_ge : ν ≤ L := le_ciInf hg_bdd
  have hg_tend : Filter.Tendsto g Filter.atTop (nhds L) :=
    tendsto_atTop_ciInf hg_anti h_bdd
  have h_ev : ∀ᶠ t in Filter.atTop, g t = φ t := by
    filter_upwards [Filter.eventually_ge_atTop (0 : ℝ)] with t ht
    show φ (max t 0) = φ t; rw [max_eq_left ht]
  have hφ_tend : Filter.Tendsto φ Filter.atTop (nhds L) := hg_tend.congr' h_ev
  have hL_le : L ≤ x₀ := by
    have : L ≤ g 0 := ciInf_le h_bdd 0
    simp only [g, max_self] at this
    exact le_trans this (hφ_le 0 le_rfl)
  have h_bL : rule.driftFn L = 0 := by
    by_contra h_ne
    rcases eq_or_lt_of_le hL_ge with heq | hlt
    · exact h_ne (heq ▸ hroot)
    · have h_bL_neg : rule.driftFn L < 0 := hneg L hlt hL_le
      have h_btend : Filter.Tendsto (fun t => rule.driftFn (φ t))
          Filter.atTop (nhds (rule.driftFn L)) :=
        rule.driftFn_continuous.continuousAt.tendsto.comp hφ_tend
      have h_ev_b : ∀ᶠ t in Filter.atTop,
          rule.driftFn (φ t) < rule.driftFn L / 2 :=
        h_btend (Iio_mem_nhds (by linarith))
      obtain ⟨T, hT⟩ := Filter.eventually_atTop.mp
        (h_ev_b.and (Filter.eventually_ge_atTop (0 : ℝ)))
      set T' := max T 0
      have hT'_nn : (0 : ℝ) ≤ T' := le_max_right _ _
      have h_decay : ∀ N : ℝ, 0 ≤ N →
          φ (T' + N) ≤ φ T' + rule.driftFn L / 2 * N := by
        intro N hN
        have h_lin_deriv : ∀ u, HasDerivAt (fun s => rule.driftFn L / 2 * s)
            (rule.driftFn L / 2) u := by
          intro u; simpa using (hasDerivAt_id u).const_mul (rule.driftFn L / 2)
        have h_anti_f := antitoneOn_of_hasDerivWithinAt_nonpos (convex_Icc T' (T' + N))
          (fun u ⟨hu1, _⟩ =>
            ((hode u (by linarith)).sub (h_lin_deriv u)).continuousAt.continuousWithinAt)
          (fun u hu =>
            ((hode u (by linarith [hT'_nn, (interior_subset hu).1])).sub
              (h_lin_deriv u)).hasDerivWithinAt)
          (fun u hu => by
            have hu_ge_T : T ≤ u := le_trans (le_max_left _ _) (interior_subset hu).1
            linarith [(hT u hu_ge_T).1])
        have h_le := h_anti_f (Set.left_mem_Icc.mpr (by linarith))
          (Set.right_mem_Icc.mpr (by linarith)) (by linarith : T' ≤ T' + N)
        simp only [Pi.sub_apply] at h_le
        linarith
      have hν_lt_x0 : ν < x₀ := lt_of_lt_of_le hlt hL_le
      set N := 2 * (x₀ - ν + 1) / (-rule.driftFn L)
      have hN_nn : 0 ≤ N := div_nonneg (by linarith) (by linarith)
      have h1 := h_decay N hN_nn
      have h2 := hφ_ge (T' + N) (by linarith)
      have h3 : rule.driftFn L / 2 * N = -(x₀ - ν + 1) := by
        simp only [N]
        have hne : rule.driftFn L ≠ 0 := ne_of_lt h_bL_neg
        field_simp
      linarith [hφ_le T' hT'_nn]
  rcases eq_or_lt_of_le hL_ge with heq | hlt
  · rw [heq]; exact hφ_tend
  · exact absurd h_bL (ne_of_lt (hneg L hlt hL_le))

/-- Scalar ODE existence with invariant interval [a, b] (increasing case).
Given: v continuous and locally Lipschitz, v ≥ 0 on [a, b], v(b) = 0, v > 0 on [a, b).
Returns: solution φ with φ(0) = a, φ' = v(φ), φ ∈ [a, b]. -/
private theorem scalar_ode_with_invariant_increasing
    (rule : EhrenfestRule) (x₀ ν : ℝ) (q₀ : ℚ)
    (hx₀ : x₀ = (q₀ : ℝ))
    (hle : x₀ ≤ ν)
    (hroot : rule.driftFn ν = 0)
    (hpos : ∀ y, x₀ ≤ y → y < ν → 0 < rule.driftFn y) :
    ∃ φ : ℝ → ℝ, φ 0 = x₀ ∧
      (∀ t, 0 ≤ t → HasDerivAt φ (rule.driftFn (φ t)) t) ∧
      (∀ t, 0 ≤ t → x₀ ≤ φ t ∧ φ t ≤ ν) := by
  rcases eq_or_lt_of_le hle with heq | hlt
  · refine ⟨fun _ => ν, by rw [← heq], fun t _ => ?_,
      fun t _ => ⟨heq ▸ le_refl _, le_refl _⟩⟩
    rw [hroot]; exact hasDerivAt_const t ν
  let w : ℝ → ℝ := fun y => rule.driftFn (max x₀ (min ν y))
  have hw_eq_on : ∀ y, x₀ ≤ y → y ≤ ν → w y = rule.driftFn y := by
    intro y hy1 hy2; show rule.driftFn (max x₀ (min ν y)) = rule.driftFn y
    rw [min_eq_right hy2, max_eq_right hy1]
  have hw_nn : ∀ y, 0 ≤ w y := by
    intro y
    show 0 ≤ rule.driftFn (max x₀ (min ν y))
    have h1 : x₀ ≤ max x₀ (min ν y) := le_max_left _ _
    have h2 : max x₀ (min ν y) ≤ ν := max_le hle (min_le_left _ _)
    rcases eq_or_lt_of_le h2 with heq | hlt'
    · rw [heq, hroot]
    · exact le_of_lt (hpos _ h1 hlt')
  have hw_zero : ∀ y, ν ≤ y → w y = 0 := by
    intro y hy; show rule.driftFn (max x₀ (min ν y)) = 0
    rw [min_eq_left hy, max_eq_right hle, hroot]
  have h_drift_contDiff : ContDiff ℝ ⊤ rule.driftFn := by
    apply ContDiff.sub
    · apply ContDiff.mul contDiff_const
      apply ContDiff.sum
      intro j _
      show ContDiff ℝ ⊤ fun y => rule.bernsteinTerm j y
      unfold EhrenfestRule.bernsteinTerm
      exact (contDiff_const.mul (contDiff_id.pow _)).mul
        ((contDiff_const.sub contDiff_id).pow _)
    · exact contDiff_const.mul contDiff_id
  have h_drift_diff : Differentiable ℝ rule.driftFn :=
    h_drift_contDiff.differentiable (by simp)
  have h_wlip : ∀ R : ℝ, 0 < R → ∃ L : ℝ, ∀ a b : ℝ,
      |a| ≤ R → |b| ≤ R → |w a - w b| ≤ L * |a - b| := by
    intro R _
    have h_cont_deriv : ContinuousOn (deriv rule.driftFn) (Set.Icc x₀ ν) :=
      (h_drift_contDiff.continuous_deriv (by simp)).continuousOn
    obtain ⟨L₀, hL⟩ := isCompact_Icc.exists_bound_of_continuousOn h_cont_deriv
    set L := max L₀ 0
    refine ⟨L, fun a b _ _ => ?_⟩
    have hca : max x₀ (min ν a) ∈ Set.Icc x₀ ν :=
      ⟨le_max_left _ _, max_le hle (min_le_left _ _)⟩
    have hcb : max x₀ (min ν b) ∈ Set.Icc x₀ ν :=
      ⟨le_max_left _ _, max_le hle (min_le_left _ _)⟩
    calc |w a - w b|
        = |rule.driftFn (max x₀ (min ν a)) - rule.driftFn (max x₀ (min ν b))| := rfl
      _ ≤ L * |max x₀ (min ν a) - max x₀ (min ν b)| := by
          have hmvt := Convex.norm_image_sub_le_of_norm_deriv_le
            (fun x _ => h_drift_diff.differentiableAt)
            (fun x hx => (hL x hx).trans (le_max_left L₀ 0))
            (convex_Icc x₀ ν) hcb hca
          rwa [Real.norm_eq_abs, Real.norm_eq_abs] at hmvt
      _ ≤ L * |a - b| := by
          apply mul_le_mul_of_nonneg_left _ (le_max_right L₀ 0)
          calc |max x₀ (min ν a) - max x₀ (min ν b)|
              = |max (min ν a) x₀ - max (min ν b) x₀| := by
                  rw [max_comm x₀ (min ν a), max_comm x₀ (min ν b)]
            _ ≤ |min ν a - min ν b| := abs_max_sub_max_le_abs _ _ _
            _ ≤ max |ν - ν| |a - b| := abs_min_sub_min_le_max _ _ _ _
            _ = |a - b| := by simp
  have h_ode_invariant : ∀ (T' : ℝ), 0 < T' → ∀ (z : ℝ → ℝ),
      z 0 = x₀ →
      (∀ t ∈ Set.Ico (0 : ℝ) T', HasDerivAt z (w (z t)) t) →
      ∀ t ∈ Set.Ico (0 : ℝ) T', x₀ ≤ z t ∧ z t ≤ ν := by
    intro T' _ z hz0 hzode t ⟨h0t, htT'⟩
    have hcont : ContinuousOn z (Set.Icc 0 t) := by
      intro s hs
      exact (hzode s ⟨hs.1, lt_of_le_of_lt hs.2 htT'⟩).continuousAt.continuousWithinAt
    have hdiff : DifferentiableOn ℝ z (interior (Set.Icc 0 t)) := by
      intro s hs; rw [interior_Icc] at hs
      exact (hzode s ⟨le_of_lt hs.1, lt_trans hs.2 htT'⟩).differentiableAt.differentiableWithinAt
    have hderiv_nn : ∀ s ∈ interior (Set.Icc 0 t), 0 ≤ deriv z s := by
      intro s hs; rw [interior_Icc] at hs
      rw [(hzode s ⟨le_of_lt hs.1, lt_trans hs.2 htT'⟩).deriv]
      exact hw_nn (z s)
    have hmono : MonotoneOn z (Set.Icc 0 t) :=
      monotoneOn_of_deriv_nonneg (convex_Icc 0 t) hcont hdiff hderiv_nn
    constructor
    · rw [← hz0]; exact hmono (Set.left_mem_Icc.mpr h0t) (Set.right_mem_Icc.mpr h0t) h0t
    · by_contra h_neg; push Not at h_neg
      have hν_range : ν ∈ Set.Icc (z 0) (z t) := ⟨hz0 ▸ hle, le_of_lt h_neg⟩
      obtain ⟨t₁, ht₁_mem, hzt₁⟩ := intermediate_value_Icc h0t hcont hν_range
      have ht₁_lt : t₁ < t := by
        rcases eq_or_lt_of_le ht₁_mem.2 with heq | hlt'
        · linarith [heq ▸ hzt₁]
        · exact hlt'
      have hcont' : ContinuousOn z (Set.Icc t₁ t) :=
        hcont.mono (Set.Icc_subset_Icc ht₁_mem.1 le_rfl)
      have hdiff' : DifferentiableOn ℝ z (interior (Set.Icc t₁ t)) := by
        intro s hs; rw [interior_Icc] at hs
        exact (hzode s ⟨le_of_lt (lt_of_le_of_lt ht₁_mem.1 hs.1),
          lt_trans hs.2 htT'⟩).differentiableAt.differentiableWithinAt
      have hderiv_le : ∀ s ∈ interior (Set.Icc t₁ t), deriv z s ≤ 0 := by
        intro s hs; rw [interior_Icc] at hs
        rw [(hzode s ⟨le_of_lt (lt_of_le_of_lt ht₁_mem.1 hs.1),
          lt_trans hs.2 htT'⟩).deriv]
        have : ν ≤ z s := by
          rw [← hzt₁]
          exact hmono ht₁_mem ⟨le_trans ht₁_mem.1 (le_of_lt hs.1),
            le_of_lt hs.2⟩ (le_of_lt hs.1)
        rw [hw_zero (z s) this]
      have hanti : AntitoneOn z (Set.Icc t₁ t) :=
        antitoneOn_of_deriv_nonpos (convex_Icc t₁ t) hcont' hdiff' hderiv_le
      have h1 : z t₁ ≤ z t :=
        hmono ht₁_mem (Set.right_mem_Icc.mpr h0t) (le_of_lt ht₁_lt)
      have h2 : z t ≤ z t₁ :=
        hanti (Set.left_mem_Icc.mpr (le_of_lt ht₁_lt))
          (Set.right_mem_Icc.mpr (le_of_lt ht₁_lt)) (le_of_lt ht₁_lt)
      linarith [hzt₁]
  have h_inv : ∀ (T : ℝ), 0 < T → ∀ (x : ℝ → ℝ),
      x 0 = x₀ →
      (∀ t ∈ Set.Ico (0 : ℝ) T, HasDerivAt x (w (x t)) t) →
      ∀ t ∈ Set.Ico (0 : ℝ) T, |x t| ≤ |x₀| + |ν| + 1 := by
    intro T hT x hx0 hxode t ht
    have ⟨hge, hle'⟩ := h_ode_invariant T hT x hx0 hxode t ht
    rw [abs_le]
    exact ⟨by linarith [neg_abs_le x₀, abs_nonneg ν],
           by linarith [le_abs_self ν, abs_nonneg x₀]⟩
  obtain ⟨φ, hφ0, hφ_ode_w, _⟩ :=
    Ripple.scalar_global_existence w x₀ h_wlip (|x₀| + |ν| + 1)
      (by linarith [abs_nonneg x₀, abs_nonneg ν]) h_inv
  have h_φ_inv : ∀ t, 0 ≤ t → x₀ ≤ φ t ∧ φ t ≤ ν := by
    intro t ht
    exact h_ode_invariant (t + 1) (by linarith) φ hφ0
      (fun s hs => hφ_ode_w s hs.1) t ⟨ht, by linarith⟩
  exact ⟨φ, hφ0, fun t ht => by
    rw [← hw_eq_on (φ t) (h_φ_inv t ht).1 (h_φ_inv t ht).2]
    exact hφ_ode_w t ht, h_φ_inv⟩

/-- Scalar ODE existence with invariant interval [a, b] (decreasing case).
Symmetric to increasing: v ≤ 0 on (a, b], v(a) = 0, v < 0 on (a, b]. -/
private theorem scalar_ode_with_invariant_decreasing
    (rule : EhrenfestRule) (x₀ ν : ℝ) (q₀ : ℚ)
    (hx₀ : x₀ = (q₀ : ℝ))
    (hle : ν ≤ x₀)
    (hroot : rule.driftFn ν = 0)
    (hneg : ∀ y, ν < y → y ≤ x₀ → rule.driftFn y < 0) :
    ∃ φ : ℝ → ℝ, φ 0 = x₀ ∧
      (∀ t, 0 ≤ t → HasDerivAt φ (rule.driftFn (φ t)) t) ∧
      (∀ t, 0 ≤ t → ν ≤ φ t ∧ φ t ≤ x₀) := by
  rcases eq_or_lt_of_le hle with heq | hlt
  · refine ⟨fun _ => ν, by rw [heq], fun t _ => ?_,
      fun t _ => ⟨le_refl _, heq ▸ le_refl _⟩⟩
    rw [hroot]; exact hasDerivAt_const t ν
  let w : ℝ → ℝ := fun y => rule.driftFn (min x₀ (max ν y))
  have hw_eq_on : ∀ y, ν ≤ y → y ≤ x₀ → w y = rule.driftFn y := by
    intro y hy1 hy2; show rule.driftFn (min x₀ (max ν y)) = rule.driftFn y
    rw [max_eq_right hy1, min_eq_right hy2]
  have hw_np : ∀ y, w y ≤ 0 := by
    intro y
    show rule.driftFn (min x₀ (max ν y)) ≤ 0
    have h1 : ν ≤ min x₀ (max ν y) := le_min hle (le_max_left _ _)
    have h2 : min x₀ (max ν y) ≤ x₀ := min_le_left _ _
    rcases eq_or_lt_of_le h1 with heq' | hlt'
    · rw [← heq', hroot]
    · exact le_of_lt (hneg _ hlt' h2)
  have hw_zero : ∀ y, y ≤ ν → w y = 0 := by
    intro y hy; show rule.driftFn (min x₀ (max ν y)) = 0
    rw [max_eq_left hy, min_eq_right hle, hroot]
  have h_drift_contDiff : ContDiff ℝ ⊤ rule.driftFn := by
    apply ContDiff.sub
    · apply ContDiff.mul contDiff_const
      apply ContDiff.sum; intro j _
      show ContDiff ℝ ⊤ fun y => rule.bernsteinTerm j y
      unfold EhrenfestRule.bernsteinTerm
      exact (contDiff_const.mul (contDiff_id.pow _)).mul
        ((contDiff_const.sub contDiff_id).pow _)
    · exact contDiff_const.mul contDiff_id
  have h_drift_diff : Differentiable ℝ rule.driftFn :=
    h_drift_contDiff.differentiable (by simp)
  have h_wlip : ∀ R : ℝ, 0 < R → ∃ L : ℝ, ∀ a b : ℝ,
      |a| ≤ R → |b| ≤ R → |w a - w b| ≤ L * |a - b| := by
    intro R _
    have h_cont_deriv : ContinuousOn (deriv rule.driftFn) (Set.Icc ν x₀) :=
      (h_drift_contDiff.continuous_deriv (by simp)).continuousOn
    obtain ⟨L₀, hL⟩ := isCompact_Icc.exists_bound_of_continuousOn h_cont_deriv
    set L := max L₀ 0
    refine ⟨L, fun a b _ _ => ?_⟩
    have hca : min x₀ (max ν a) ∈ Set.Icc ν x₀ :=
      ⟨le_min hle (le_max_left _ _), min_le_left _ _⟩
    have hcb : min x₀ (max ν b) ∈ Set.Icc ν x₀ :=
      ⟨le_min hle (le_max_left _ _), min_le_left _ _⟩
    calc |w a - w b|
        = |rule.driftFn (min x₀ (max ν a)) - rule.driftFn (min x₀ (max ν b))| := rfl
      _ ≤ L * |min x₀ (max ν a) - min x₀ (max ν b)| := by
          have hmvt := Convex.norm_image_sub_le_of_norm_deriv_le
            (fun x _ => h_drift_diff.differentiableAt)
            (fun x hx => (hL x hx).trans (le_max_left L₀ 0))
            (convex_Icc ν x₀) hcb hca
          rwa [Real.norm_eq_abs, Real.norm_eq_abs] at hmvt
      _ ≤ L * |a - b| := by
          apply mul_le_mul_of_nonneg_left _ (le_max_right L₀ 0)
          calc |min x₀ (max ν a) - min x₀ (max ν b)|
            _ ≤ max |x₀ - x₀| |max ν a - max ν b| := abs_min_sub_min_le_max _ _ _ _
            _ = |max ν a - max ν b| := by simp
            _ ≤ max |ν - ν| |a - b| := abs_max_sub_max_le_max _ _ _ _
            _ = |a - b| := by simp
  have h_ode_invariant : ∀ (T' : ℝ), 0 < T' → ∀ (z : ℝ → ℝ),
      z 0 = x₀ →
      (∀ t ∈ Set.Ico (0 : ℝ) T', HasDerivAt z (w (z t)) t) →
      ∀ t ∈ Set.Ico (0 : ℝ) T', ν ≤ z t ∧ z t ≤ x₀ := by
    intro T' _ z hz0 hzode t ⟨h0t, htT'⟩
    have hcont : ContinuousOn z (Set.Icc 0 t) := by
      intro s hs
      exact (hzode s ⟨hs.1, lt_of_le_of_lt hs.2 htT'⟩).continuousAt.continuousWithinAt
    have hdiff : DifferentiableOn ℝ z (interior (Set.Icc 0 t)) := by
      intro s hs; rw [interior_Icc] at hs
      exact (hzode s ⟨le_of_lt hs.1, lt_trans hs.2 htT'⟩).differentiableAt.differentiableWithinAt
    have hderiv_np : ∀ s ∈ interior (Set.Icc 0 t), deriv z s ≤ 0 := by
      intro s hs; rw [interior_Icc] at hs
      rw [(hzode s ⟨le_of_lt hs.1, lt_trans hs.2 htT'⟩).deriv]
      exact hw_np (z s)
    have hanti : AntitoneOn z (Set.Icc 0 t) :=
      antitoneOn_of_deriv_nonpos (convex_Icc 0 t) hcont hdiff hderiv_np
    constructor
    · by_contra h_neg; push Not at h_neg
      have hν_range : ν ∈ Set.Icc (z t) (z 0) := ⟨le_of_lt h_neg, hz0 ▸ hle⟩
      obtain ⟨t₁, ht₁_mem, hzt₁⟩ := intermediate_value_Icc' h0t hcont hν_range
      have ht₁_lt : t₁ < t := by
        rcases eq_or_lt_of_le ht₁_mem.2 with heq' | hlt'
        · linarith [heq' ▸ hzt₁]
        · exact hlt'
      have hcont' : ContinuousOn z (Set.Icc t₁ t) :=
        hcont.mono (Set.Icc_subset_Icc ht₁_mem.1 le_rfl)
      have hdiff' : DifferentiableOn ℝ z (interior (Set.Icc t₁ t)) := by
        intro s hs; rw [interior_Icc] at hs
        exact (hzode s ⟨le_of_lt (lt_of_le_of_lt ht₁_mem.1 hs.1),
          lt_trans hs.2 htT'⟩).differentiableAt.differentiableWithinAt
      have hderiv_nn : ∀ s ∈ interior (Set.Icc t₁ t), 0 ≤ deriv z s := by
        intro s hs; rw [interior_Icc] at hs
        rw [(hzode s ⟨le_of_lt (lt_of_le_of_lt ht₁_mem.1 hs.1),
          lt_trans hs.2 htT'⟩).deriv]
        have : z s ≤ ν := by
          rw [← hzt₁]
          exact hanti ht₁_mem ⟨le_trans ht₁_mem.1 (le_of_lt hs.1), le_of_lt hs.2⟩
            (le_of_lt hs.1)
        linarith [hw_zero (z s) this]
      have hmono' : MonotoneOn z (Set.Icc t₁ t) :=
        monotoneOn_of_deriv_nonneg (convex_Icc t₁ t) hcont' hdiff' hderiv_nn
      have h1 : z t ≤ z t₁ :=
        hanti ht₁_mem (Set.right_mem_Icc.mpr h0t) (le_of_lt ht₁_lt)
      have h2 : z t₁ ≤ z t :=
        hmono' (Set.left_mem_Icc.mpr (le_of_lt ht₁_lt))
          (Set.right_mem_Icc.mpr (le_of_lt ht₁_lt)) (le_of_lt ht₁_lt)
      linarith [hzt₁]
    · rw [← hz0]; exact hanti (Set.left_mem_Icc.mpr h0t) (Set.right_mem_Icc.mpr h0t) h0t
  have h_inv : ∀ (T : ℝ), 0 < T → ∀ (x : ℝ → ℝ),
      x 0 = x₀ →
      (∀ t ∈ Set.Ico (0 : ℝ) T, HasDerivAt x (w (x t)) t) →
      ∀ t ∈ Set.Ico (0 : ℝ) T, |x t| ≤ |x₀| + |ν| + 1 := by
    intro T hT x hx0 hxode t ht
    have ⟨hge, hle'⟩ := h_ode_invariant T hT x hx0 hxode t ht
    rw [abs_le]
    exact ⟨by linarith [neg_abs_le ν, abs_nonneg x₀],
           by linarith [le_abs_self x₀, abs_nonneg ν]⟩
  obtain ⟨φ, hφ0, hφ_ode_w, _⟩ :=
    Ripple.scalar_global_existence w x₀ h_wlip (|x₀| + |ν| + 1)
      (by linarith [abs_nonneg x₀, abs_nonneg ν]) h_inv
  have h_φ_inv : ∀ t, 0 ≤ t → ν ≤ φ t ∧ φ t ≤ x₀ := by
    intro t ht
    exact h_ode_invariant (t + 1) (by linarith) φ hφ0
      (fun s hs => hφ_ode_w s hs.1) t ⟨ht, by linarith⟩
  exact ⟨φ, hφ0, fun t ht => by
    rw [← hw_eq_on (φ t) (h_φ_inv t ht).1 (h_φ_inv t ht).2]
    exact hφ_ode_w t ht, h_φ_inv⟩

/-- Ehrenfest-computable ⊂ LPP-computable.
The Ehrenfest urn is a 2-state system on the probability simplex.
The 1D convergence proof lifts to a 2-species IsLPPComputable witness. -/
noncomputable def toLPPComputable {ν : ℝ} (h : IsEhrenfestComputable ν) :
    IsLPPComputable ν := by
  let rule := h.choose
  let x₀ := h.choose_spec.choose
  have hx01 := h.choose_spec.choose_spec.1
  have hν01 := h.choose_spec.choose_spec.2.2.1
  have hroot := h.choose_spec.choose_spec.2.2.2.1
  have hconv := h.choose_spec.choose_spec.2.2.2.2
  let q₀ := h.choose_spec.choose_spec.2.1.choose
  have hq₀ := h.choose_spec.choose_spec.2.1.choose_spec
  have h_core : ∃ φ : ℝ → ℝ, φ 0 = x₀ ∧
      (∀ t, 0 ≤ t → HasDerivAt φ (rule.driftFn (φ t)) t) ∧
      (∀ t, 0 ≤ t → 0 ≤ φ t ∧ φ t ≤ 1) ∧
      Filter.Tendsto φ Filter.atTop (nhds ν) := by
    rcases hconv with ⟨hle, hpos⟩ | ⟨hle, hneg⟩
    · obtain ⟨φ, hφ0, hφ_ode, hφ_inv⟩ :=
        scalar_ode_with_invariant_increasing rule x₀ ν q₀ hq₀ (le_of_lt hle) hroot hpos
      exact ⟨φ, hφ0, hφ_ode,
        fun t ht => ⟨le_trans hx01.1 (hφ_inv t ht).1, le_trans (hφ_inv t ht).2 hν01.2⟩,
        increasing_tendsto rule φ x₀ ν hφ_ode
          (fun t ht => (hφ_inv t ht).1) (fun t ht => (hφ_inv t ht).2) hroot hpos⟩
    · obtain ⟨φ, hφ0, hφ_ode, hφ_inv⟩ :=
        scalar_ode_with_invariant_decreasing rule x₀ ν q₀ hq₀ (le_of_lt hle) hroot hneg
      exact ⟨φ, hφ0, hφ_ode,
        fun t ht => ⟨le_trans hν01.1 (hφ_inv t ht).1, le_trans (hφ_inv t ht).2 hx01.2⟩,
        decreasing_tendsto rule φ x₀ ν hφ_ode
          (fun t ht => (hφ_inv t ht).1) (fun t ht => (hφ_inv t ht).2) hroot hneg⟩
  let φ := h_core.choose
  have hφ0 := h_core.choose_spec.1
  have hφ_ode := h_core.choose_spec.2.1
  have hφ_inv := h_core.choose_spec.2.2.1
  have hφ_conv := h_core.choose_spec.2.2.2
  refine ⟨2, rule.twoSpeciesField,
    fun t i => if i = (0 : Fin 2) then φ t else 1 - φ t,
    {0}, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · intro i; fin_cases i
    · exact ⟨q₀, hφ0.trans hq₀⟩
    · exact ⟨1 - q₀, by show 1 - φ 0 = ↑(1 - q₀); push_cast; linarith [hφ0.trans hq₀]⟩
  · simp only [Fin.sum_univ_two]; show φ 0 + (1 - φ 0) = 1; ring
  · intro i; fin_cases i
    · show 0 ≤ φ 0; linarith [hφ0, hx01.1]
    · show 0 ≤ 1 - φ 0; linarith [hφ0, hx01.2]
  · intro t _; simp only [Fin.sum_univ_two]; show φ t + (1 - φ t) = 1; ring
  · intro t ht i; fin_cases i
    · exact (hφ_inv t ht).1
    · show 0 ≤ 1 - φ t; linarith [(hφ_inv t ht).2]
  · intro t ht
    refine hasDerivAt_pi.mpr (fun i => ?_)
    fin_cases i
    · show HasDerivAt (fun s => φ s) (rule.driftFn (φ t)) t
      exact hφ_ode t ht
    · show HasDerivAt (fun s => 1 - φ s) (-rule.driftFn (φ t)) t
      have hd := (hasDerivAt_const t (1 : ℝ)).sub (hφ_ode t ht)
      rwa [zero_sub] at hd
  · simp only [Finset.sum_singleton]
    exact hφ_conv

/-- Symmetry about 1/2: if ν is computable, so is 1 − ν.
Uses the complement rule f̄(j) = ¬f(k−j) with initial proportion 1 − x₀.
The identity b_{f̄}(y) = −b_f(1−y) flips increasing ↔ decreasing convergence. -/
theorem symmetric {ν : ℝ} (h : IsEhrenfestComputable ν) :
    IsEhrenfestComputable (1 - ν) := by
  obtain ⟨rule, x₀, hx, hrat, hν, hroot, hconv⟩ := h
  refine ⟨rule.complement, 1 - x₀,
    ⟨by linarith [hx.2], by linarith [hx.1]⟩,
    (by obtain ⟨q, hq⟩ := hrat; exact ⟨1 - q, by push_cast; linarith⟩),
    ⟨by linarith [hν.2], by linarith [hν.1]⟩,
    by rw [rule.driftFn_complement]; simp only [sub_sub_cancel]; linarith,
    ?_⟩
  rcases hconv with ⟨hle, hpos⟩ | ⟨hle, hneg⟩
  · right
    refine ⟨by linarith, fun y hy hle' => ?_⟩
    rw [rule.driftFn_complement]
    have h1 : x₀ ≤ 1 - y := by linarith
    have h2 : 1 - y < ν := by linarith
    linarith [hpos (1 - y) h1 h2]
  · left
    refine ⟨by linarith, fun y hy hlt => ?_⟩
    rw [rule.driftFn_complement]
    have h1 : ν < 1 - y := by linarith
    have h2 : 1 - y ≤ x₀ := by linarith
    linarith [hneg (1 - y) h1 h2]

end IsEhrenfestComputable

/-! ## Concrete examples -/

/-- k=2, E={0}: "repulsion" rule. All-white input → black, otherwise white.
Computes (3 − √5)/2 ≈ 0.382, the square of the reciprocal golden ratio. -/
def goldenRatioRule : EhrenfestRule where
  k := 2
  k_pos := by norm_num
  f := fun j => decide (j.val = 0)

/-- Drift for the golden ratio rule: b(y) = 2(1−y)² − 2y = 2y² − 6y + 2. -/
theorem goldenRatioRule_drift (y : ℝ) :
    goldenRatioRule.driftFn y = 2 * y ^ 2 - 6 * y + 2 := by
  simp only [EhrenfestRule.driftFn, EhrenfestRule.blackSet, EhrenfestRule.bernsteinTerm,
    goldenRatioRule]
  simp only [Finset.sum_filter]
  norm_num [Nat.choose]
  ring

/-- (3 − √5)/2 is Ehrenfest-computable.
The drift 2y² − 6y + 2 = 2(y − (3−√5)/2)(y − (3+√5)/2) has smallest
positive root (3 − √5)/2, and b > 0 on [0, (3−√5)/2). -/
theorem goldenRatio_computable :
    IsEhrenfestComputable ((3 - Real.sqrt 5) / 2) := by
  have h5pos : (0 : ℝ) ≤ 5 := by norm_num
  have hsq5 : Real.sqrt 5 * Real.sqrt 5 = 5 := Real.mul_self_sqrt h5pos
  have hsq5' : Real.sqrt 5 ^ 2 = 5 := Real.sq_sqrt h5pos
  -- √5 ≤ 3
  have hle3 : Real.sqrt 5 ≤ 3 := by
    rw [Real.sqrt_le_left (by norm_num : (0 : ℝ) ≤ 3)]
    norm_num
  -- 1 ≤ √5
  have hge1 : 1 ≤ Real.sqrt 5 := by
    rw [Real.le_sqrt' (by norm_num : (0 : ℝ) < 1)]
    norm_num
  -- Witnesses: goldenRatioRule, x₀ = 0
  refine ⟨goldenRatioRule, 0, ⟨le_refl _, by norm_num⟩, ⟨0, by simp⟩,
    ⟨?_, ?_⟩, ?_, ?_⟩
  -- Goal 1: 0 ≤ (3 - √5) / 2
  · linarith
  -- Goal 2: (3 - √5) / 2 ≤ 1
  · linarith
  -- Goal 3: driftFn ((3 - √5) / 2) = 0
  · rw [goldenRatioRule_drift]
    have : (3 - Real.sqrt 5) / 2 * ((3 - Real.sqrt 5) / 2) =
        (14 - 6 * Real.sqrt 5) / 4 := by nlinarith
    nlinarith
  -- Goal 4: convergence from below
  · left; refine ⟨by nlinarith [hsq5, hle3], fun y hy hlt => ?_⟩
    rw [goldenRatioRule_drift]
    -- Need: 0 < 2 * y ^ 2 - 6 * y + 2 for 0 ≤ y < (3 - √5) / 2
    -- Factor: 2(y - (3-√5)/2)(y - (3+√5)/2)
    -- Since y < (3-√5)/2 < (3+√5)/2, both factors negative → product positive
    have hy_upper : y < (3 - Real.sqrt 5) / 2 := hlt
    have hsqrt5_pos : 0 < Real.sqrt 5 := by linarith
    -- y - (3-√5)/2 < 0
    have h1 : y - (3 - Real.sqrt 5) / 2 < 0 := by linarith
    -- y - (3+√5)/2 < 0 since y < (3-√5)/2 < (3+√5)/2
    have h2 : y - (3 + Real.sqrt 5) / 2 < 0 := by linarith
    -- The product of two negatives is positive
    -- 2y² - 6y + 2 = 2 * (y - (3-√5)/2) * (y - (3+√5)/2)
    -- Expand: 2 * (y² - 3y + (9-5)/4) = 2 * (y² - 3y + 1) = 2y² - 6y + 2 ✓
    nlinarith [mul_neg_of_neg_of_pos h1 (neg_pos.mpr h2)]

/-- k=2, E={0,2}: "parity" rule. Even black-count → black, odd → white.
Computes 1/2. -/
def parityRule : EhrenfestRule where
  k := 2
  k_pos := by norm_num
  f := fun j => decide (j.val % 2 = 0)

/-- Drift for the parity rule: b(y) = 4y² − 6y + 2 = 2(2y−1)(y−1). -/
theorem parityRule_drift (y : ℝ) :
    parityRule.driftFn y = 4 * y ^ 2 - 6 * y + 2 := by
  -- Compute the blackSet (using Fin (parityRule.k + 1) to match bernsteinTerm's domain)
  have hbs : parityRule.blackSet =
      ({(0 : Fin (parityRule.k + 1)), (2 : Fin (parityRule.k + 1))} : Finset _) := by
    unfold parityRule EhrenfestRule.blackSet
    ext x; fin_cases x <;> simp
  -- Compute the full sum over blackSet
  have hsum : ∀ y : ℝ, ∑ j ∈ parityRule.blackSet, parityRule.bernsteinTerm j y =
      (1 - y) ^ 2 + y ^ 2 := by
    intro y
    rw [hbs, Finset.sum_pair (by decide : (0 : Fin (parityRule.k + 1)) ≠ 2)]
    simp [EhrenfestRule.bernsteinTerm, parityRule]
  -- Unfold driftFn (but NOT parityRule) and substitute
  unfold EhrenfestRule.driftFn
  rw [hsum]
  simp [parityRule]
  ring

/-- 1/2 is Ehrenfest-computable (via parityRule, from x₀ = 0). -/
theorem half_computable : IsEhrenfestComputable (1 / 2 : ℝ) := by
  refine ⟨parityRule, 0, ⟨le_refl _, by norm_num⟩, ⟨0, by simp⟩,
    ⟨by norm_num, by norm_num⟩, ?_, ?_⟩
  · rw [parityRule_drift]; ring
  · left; refine ⟨by norm_num, fun y hy hlt => ?_⟩
    rw [parityRule_drift]
    nlinarith [mul_pos (show (0 : ℝ) < 1 - 2 * y by linarith)
      (show (0 : ℝ) < 1 - y by linarith)]

/-- k=3, E={0,3}: "extremal" rule. All-same-color input → black, mixed → white.
Computes 1/3. -/
def oneThirdRule : EhrenfestRule where
  k := 3
  k_pos := by norm_num
  f := fun j => decide (j.val = 0 ∨ j.val = 3)

/-- Drift for the 1/3 rule:
b(y) = 3[(1−y)³ + y³] − 3y = 9y² − 12y + 3 = 3(3y−1)(y−1). -/
theorem oneThirdRule_drift (y : ℝ) :
    oneThirdRule.driftFn y = 9 * y ^ 2 - 12 * y + 3 := by
  -- Compute the blackSet
  have hbs : oneThirdRule.blackSet =
      ({(0 : Fin (oneThirdRule.k + 1)), (3 : Fin (oneThirdRule.k + 1))} : Finset _) := by
    unfold oneThirdRule EhrenfestRule.blackSet
    ext x; fin_cases x <;> simp
  -- Compute the full sum over blackSet
  have hsum : ∀ y : ℝ, ∑ j ∈ oneThirdRule.blackSet, oneThirdRule.bernsteinTerm j y =
      (1 - y) ^ 3 + y ^ 3 := by
    intro y
    rw [hbs, Finset.sum_pair (by decide : (0 : Fin (oneThirdRule.k + 1)) ≠ 3)]
    simp [EhrenfestRule.bernsteinTerm, oneThirdRule]
  -- Unfold driftFn and substitute
  unfold EhrenfestRule.driftFn
  rw [hsum]
  simp [oneThirdRule]
  ring

/-- 1/3 is Ehrenfest-computable (via oneThirdRule, from x₀ = 0). -/
theorem oneThird_computable : IsEhrenfestComputable (1 / 3 : ℝ) := by
  refine ⟨oneThirdRule, 0, ⟨le_refl _, by norm_num⟩, ⟨0, by simp⟩,
    ⟨by norm_num, by norm_num⟩, ?_, ?_⟩
  · rw [oneThirdRule_drift]; ring
  · left; refine ⟨by norm_num, fun y hy hlt => ?_⟩
    rw [oneThirdRule_drift]
    nlinarith [mul_pos (show (0 : ℝ) < 1 - 3 * y by linarith)
      (show (0 : ℝ) < 1 - y by linarith)]

/-! ## Characterization of the Ehrenfest-computable set (Theorem 5)

The computable set L has a remarkable structure combining density
(L is dense in [0,1]), algebraic richness (all degrees represented),
and extreme rational sparsity (only 5 elements of ℚ ∩ [0,1]). -/

/-! ### Threshold rules and density infrastructure -/

/-- Threshold rule: k agents, E = {0, ..., m}. -/
def thresholdRule (k : ℕ) (hk : 0 < k) (m : ℕ) (_hm : m < k) : EhrenfestRule where
  k := k
  k_pos := hk
  f := fun j => decide (j.val ≤ m)

private lemma thresholdRule_zero_mem (k : ℕ) (hk : 0 < k) (m : ℕ) (hm : m < k) :
    (thresholdRule k hk m hm).f 0 = true := by
  simp [thresholdRule]

private lemma thresholdRule_k_not_mem (k : ℕ) (hk : 0 < k) (m : ℕ) (hm : m < k) :
    (thresholdRule k hk m hm).f (Fin.last k) = false := by
  simp [thresholdRule, Fin.last]; omega

private lemma thresholdRule_driftFn_zero (k : ℕ) (hk : 0 < k) (m : ℕ) (hm : m < k) :
    (thresholdRule k hk m hm).driftFn 0 = (k : ℝ) := by
  have h := (thresholdRule k hk m hm).driftFn_zero
  simp only [thresholdRule_zero_mem k hk m hm] at h
  simpa using h

private lemma thresholdRule_driftFn_one (k : ℕ) (hk : 0 < k) (m : ℕ) (hm : m < k) :
    (thresholdRule k hk m hm).driftFn 1 = -(k : ℝ) := by
  set rule := thresholdRule k hk m hm
  have hfk : rule.f (Fin.last rule.k) = false := by
    show decide ((Fin.last rule.k).val ≤ m) = false
    simp [Fin.last, thresholdRule, decide_eq_false_iff_not, Nat.not_le]
    exact hm
  have h := rule.driftFn_one
  simp only [hfk] at h
  exact h

/-- A threshold rule with 0 < drift(0) and drift(1) < 0 has a root in (0,1) by IVT.
Moreover, this root is Ehrenfest-computable from x₀ = 0 (increasing case):
the smallest root ν₀ satisfies drift > 0 on (0, ν₀). -/
private theorem threshold_root_exists_and_computable
    (k : ℕ) (hk : 2 ≤ k) (m : ℕ) (hm : m < k) :
    ∃ ν : ℝ, ν ∈ Set.Ioo 0 1 ∧
      (thresholdRule k (by omega : 0 < k) m hm).driftFn ν = 0 ∧
      (∀ y, 0 ≤ y → y < ν → 0 < (thresholdRule k (by omega : 0 < k) m hm).driftFn y) ∧
      IsEhrenfestComputable ν := by
  set rule := thresholdRule k (by omega : 0 < k) m hm
  have hd0 : rule.driftFn 0 = (k : ℝ) := thresholdRule_driftFn_zero k (by omega) m hm
  have hd1 : rule.driftFn 1 = -(k : ℝ) := thresholdRule_driftFn_one k (by omega) m hm
  have hk_pos : (0 : ℝ) < (k : ℝ) := Nat.cast_pos.mpr (by omega : 0 < k)
  have hd0_pos : (0 : ℝ) < rule.driftFn 0 := by rw [hd0]; exact hk_pos
  have hd1_neg : rule.driftFn 1 < 0 := by rw [hd1]; linarith
  have hcont := rule.driftFn_continuous
  -- Define Z = zeros of drift in [0,1]
  set Z := rule.driftFn ⁻¹' {0} ∩ Set.Icc 0 1
  -- Z is closed: preimage of {0} under continuous map ∩ closed set
  have hZ_closed : IsClosed Z :=
    (isClosed_singleton.preimage hcont).inter isClosed_Icc
  -- Get a root via IVT: drift(0) > 0, drift(1) < 0 → zero in (0,1)
  have hzero_range : (0 : ℝ) ∈ Set.Icc (rule.driftFn 1) (rule.driftFn 0) :=
    ⟨le_of_lt hd1_neg, le_of_lt hd0_pos⟩
  obtain ⟨c, hc_mem, hc_val⟩ := intermediate_value_Icc'
    (show (0 : ℝ) ≤ 1 from by norm_num) hcont.continuousOn hzero_range
  -- c ∈ [0,1] and drift(c) = 0
  have hc_in_Z : c ∈ Z := ⟨Set.mem_preimage.mpr (Set.mem_singleton_iff.mpr hc_val), hc_mem⟩
  have hZ_ne : Z.Nonempty := ⟨c, hc_in_Z⟩
  have hZ_bdd : BddBelow Z := ⟨0, fun y hy => hy.2.1⟩
  -- Take ν₀ = inf Z (smallest root in [0,1])
  set ν₀ := sInf Z
  have hν₀_mem : ν₀ ∈ Z := hZ_closed.csInf_mem hZ_ne hZ_bdd
  have hν₀_root : rule.driftFn ν₀ = 0 := Set.mem_singleton_iff.mp (Set.mem_preimage.mp hν₀_mem.1)
  have hν₀_01 : ν₀ ∈ Set.Icc (0 : ℝ) 1 := hν₀_mem.2
  -- ν₀ > 0 (since drift(0) > 0 ≠ 0)
  have hν₀_pos : 0 < ν₀ := by
    rcases eq_or_lt_of_le hν₀_01.1 with heq | hlt
    · exfalso
      have h0 := hν₀_root; rw [show ν₀ = 0 from heq.symm] at h0; linarith
    · exact hlt
  -- ν₀ < 1 (since drift(1) < 0 ≠ 0)
  have hν₀_lt1 : ν₀ < 1 := by
    rcases eq_or_lt_of_le hν₀_01.2 with heq | hlt
    · exfalso
      have h1 := hν₀_root; rw [show ν₀ = 1 from heq] at h1; linarith
    · exact hlt
  -- drift > 0 on (0, ν₀) by minimality: no root below ν₀
  have hpos : ∀ y, 0 ≤ y → y < ν₀ → 0 < rule.driftFn y := by
    intro y hy hlt
    -- y < ν₀ = inf Z, so y ∉ Z
    have hy_not_Z : y ∉ Z := by
      intro hy_in
      exact not_lt.mpr (csInf_le hZ_bdd hy_in) hlt
    -- y ∉ Z means: either drift(y) ≠ 0 or y ∉ [0,1]
    have hy_01 : y ∈ Set.Icc (0 : ℝ) 1 := ⟨hy, le_of_lt (lt_trans hlt hν₀_lt1)⟩
    have hy_ne : rule.driftFn y ≠ 0 := by
      intro heq
      exact hy_not_Z ⟨Set.mem_preimage.mpr (Set.mem_singleton_iff.mpr heq), hy_01⟩
    -- drift(y) ≠ 0 and drift continuous with drift(0) > 0
    -- By IVT, drift cannot be negative on [0, ν₀) without a zero in between
    by_contra h_neg
    push Not at h_neg
    have h_neg' : rule.driftFn y < 0 := lt_of_le_of_ne h_neg hy_ne
    -- drift(0) > 0 and drift(y) < 0 with 0 < y → root in (0, y) by IVT
    have hzero_range2 : (0 : ℝ) ∈ Set.Icc (rule.driftFn y) (rule.driftFn 0) :=
      ⟨le_of_lt h_neg', le_of_lt hd0_pos⟩
    obtain ⟨z, hz_mem, hz_val⟩ := intermediate_value_Icc'
      hy hcont.continuousOn hzero_range2
    have hz_in_Z : z ∈ Z :=
      ⟨Set.mem_preimage.mpr (Set.mem_singleton_iff.mpr hz_val),
       ⟨hz_mem.1, le_trans hz_mem.2 (le_of_lt (lt_trans hlt hν₀_lt1))⟩⟩
    -- z ∈ Z with z ≤ y < ν₀ = inf Z, contradiction
    exact not_lt.mpr (csInf_le hZ_bdd hz_in_Z) (lt_of_le_of_lt hz_mem.2 hlt)
  -- Conclude: ν₀ ∈ (0,1) and Ehrenfest-computable
  exact ⟨ν₀, ⟨hν₀_pos, hν₀_lt1⟩, hν₀_root, hpos,
    rule, 0, ⟨le_refl _, by norm_num⟩, ⟨0, by simp⟩,
    ⟨le_of_lt hν₀_pos, le_of_lt hν₀_lt1⟩, hν₀_root,
    Or.inl ⟨hν₀_pos, fun y hy hlt => hpos y hy hlt⟩⟩

/-- If a drift is positive at a rational `q` and negative at `1`, then the
first zero in `[q,1]` is Ehrenfest-computable by increasing convergence from
the rational initial condition `q`. -/
private theorem root_exists_and_computable_from_rational_start
    (rule : EhrenfestRule) (q : ℚ)
    (hq0 : 0 ≤ (q : ℝ)) (hq1 : (q : ℝ) < 1)
    (hq_pos : 0 < rule.driftFn (q : ℝ))
    (h1_neg : rule.driftFn 1 < 0) :
    ∃ ν : ℝ, ν ∈ Set.Ioo (q : ℝ) 1 ∧
      rule.driftFn ν = 0 ∧
      (∀ y, (q : ℝ) ≤ y → y < ν → 0 < rule.driftFn y) ∧
      IsEhrenfestComputable ν := by
  have hcont := rule.driftFn_continuous
  set Z := rule.driftFn ⁻¹' {0} ∩ Set.Icc (q : ℝ) 1
  have hZ_closed : IsClosed Z :=
    (isClosed_singleton.preimage hcont).inter isClosed_Icc
  have hzero_range : (0 : ℝ) ∈ Set.Icc (rule.driftFn 1) (rule.driftFn (q : ℝ)) :=
    ⟨le_of_lt h1_neg, le_of_lt hq_pos⟩
  obtain ⟨c, hc_mem, hc_val⟩ := intermediate_value_Icc'
    (le_of_lt hq1) hcont.continuousOn hzero_range
  have hc_in_Z : c ∈ Z := ⟨Set.mem_preimage.mpr (Set.mem_singleton_iff.mpr hc_val), hc_mem⟩
  have hZ_ne : Z.Nonempty := ⟨c, hc_in_Z⟩
  have hZ_bdd : BddBelow Z := ⟨(q : ℝ), fun y hy => hy.2.1⟩
  set ν₀ := sInf Z
  have hν₀_mem : ν₀ ∈ Z := hZ_closed.csInf_mem hZ_ne hZ_bdd
  have hν₀_root : rule.driftFn ν₀ = 0 :=
    Set.mem_singleton_iff.mp (Set.mem_preimage.mp hν₀_mem.1)
  have hν₀_q1 : ν₀ ∈ Set.Icc (q : ℝ) 1 := hν₀_mem.2
  have hq_lt_ν₀ : (q : ℝ) < ν₀ := by
    rcases eq_or_lt_of_le hν₀_q1.1 with heq | hlt
    · exfalso
      have hq_root := hν₀_root
      rw [show ν₀ = (q : ℝ) from heq.symm] at hq_root
      linarith
    · exact hlt
  have hν₀_lt1 : ν₀ < 1 := by
    rcases eq_or_lt_of_le hν₀_q1.2 with heq | hlt
    · exfalso
      have h1_root := hν₀_root
      rw [show ν₀ = 1 from heq] at h1_root
      linarith
    · exact hlt
  have hpos : ∀ y, (q : ℝ) ≤ y → y < ν₀ → 0 < rule.driftFn y := by
    intro y hy hlt
    have hy_not_Z : y ∉ Z := by
      intro hy_in
      exact not_lt.mpr (csInf_le hZ_bdd hy_in) hlt
    have hy_01 : y ∈ Set.Icc (q : ℝ) 1 :=
      ⟨hy, le_of_lt (lt_trans hlt hν₀_lt1)⟩
    have hy_ne : rule.driftFn y ≠ 0 := by
      intro heq
      exact hy_not_Z ⟨Set.mem_preimage.mpr (Set.mem_singleton_iff.mpr heq), hy_01⟩
    by_contra h_nonpos
    push Not at h_nonpos
    have hy_neg : rule.driftFn y < 0 := lt_of_le_of_ne h_nonpos hy_ne
    have hzero_range2 : (0 : ℝ) ∈ Set.Icc (rule.driftFn y) (rule.driftFn (q : ℝ)) :=
      ⟨le_of_lt hy_neg, le_of_lt hq_pos⟩
    obtain ⟨z, hz_mem, hz_val⟩ := intermediate_value_Icc'
      hy hcont.continuousOn hzero_range2
    have hz_in_Z : z ∈ Z :=
      ⟨Set.mem_preimage.mpr (Set.mem_singleton_iff.mpr hz_val),
       ⟨hz_mem.1, le_trans hz_mem.2 (le_of_lt (lt_trans hlt hν₀_lt1))⟩⟩
    exact not_lt.mpr (csInf_le hZ_bdd hz_in_Z) (lt_of_le_of_lt hz_mem.2 hlt)
  exact ⟨ν₀, ⟨hq_lt_ν₀, hν₀_lt1⟩, hν₀_root, hpos,
    rule, (q : ℝ), ⟨hq0, le_of_lt hq1⟩, ⟨q, rfl⟩,
    ⟨le_trans hq0 (le_of_lt hq_lt_ν₀), le_of_lt hν₀_lt1⟩,
    hν₀_root, Or.inl ⟨hq_lt_ν₀, hpos⟩⟩

/-- Chebyshev-type bound for Bernstein tails: if all indices j in a subset S
satisfy |j/k - y| ≥ δ, then the Bernstein mass on S is at most 1/(4kδ²).
Derived from the variance identity ∑ (j/k - y)² B_j(y) = y(1-y)/k ≤ 1/(4k). -/
private lemma bernstein_tail_bound (k : ℕ) (hk : 0 < k)
    (y : ℝ) (hy : y ∈ Set.Icc (0 : ℝ) 1)
    (S : Finset (Fin (k + 1)))
    (δ : ℝ) (hδ : 0 < δ)
    (hS : ∀ j ∈ S, δ ≤ |(y : ℝ) - (j.val : ℝ) / (k : ℝ)|) :
    ∑ j ∈ S, (Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val) ≤
      1 / (4 * (k : ℝ) * δ ^ 2) := by
  have hk_pos : (0 : ℝ) < (k : ℝ) := Nat.cast_pos.mpr hk
  have hδ2 : (0 : ℝ) < δ ^ 2 := pow_pos hδ 2
  -- From hS: for j ∈ S, (y - j/k)² ≥ δ²
  have hS_sq : ∀ j ∈ S,
      δ ^ 2 ≤ (y - (j.val : ℝ) / (k : ℝ)) ^ 2 := by
    intro j hj
    have h := hS j hj
    calc δ ^ 2 ≤ |y - (j.val : ℝ) / (k : ℝ)| ^ 2 := by
            exact pow_le_pow_left₀ hδ.le h 2
      _ = (y - (j.val : ℝ) / (k : ℝ)) ^ 2 := sq_abs _
  -- Each Bernstein term is non-negative
  have hnn : ∀ j : Fin (k + 1),
      0 ≤ (Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val) := by
    intro j
    apply mul_nonneg (mul_nonneg _ _) _
    · exact Nat.cast_nonneg _
    · exact pow_nonneg hy.1 _
    · exact pow_nonneg (by linarith [hy.2]) _
  -- Weighted sum ≤ variance / δ²
  have h_main : δ ^ 2 * ∑ j ∈ S,
      (Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val) ≤
      ∑ j : Fin (k + 1),
      (y - (j.val : ℝ) / (k : ℝ)) ^ 2 *
        ((Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val)) := by
    calc δ ^ 2 * ∑ j ∈ S, _ =
        ∑ j ∈ S, δ ^ 2 * ((Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val)) := by
          rw [Finset.mul_sum]
      _ ≤ ∑ j ∈ S, (y - (j.val : ℝ) / (k : ℝ)) ^ 2 *
            ((Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val)) := by
          apply Finset.sum_le_sum
          intro j hj
          apply mul_le_mul_of_nonneg_right (hS_sq j hj) (hnn j)
      _ ≤ ∑ j : Fin (k + 1), (y - (j.val : ℝ) / (k : ℝ)) ^ 2 *
            ((Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val)) := by
          apply Finset.sum_le_univ_sum_of_nonneg
          intro j
          exact mul_nonneg (sq_nonneg _) (hnn j)
  -- The variance sum equals y(1-y)/k ≤ 1/(4k)
  have h_var : ∑ j : Fin (k + 1),
      (y - (j.val : ℝ) / (k : ℝ)) ^ 2 *
        ((Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val)) ≤
      1 / (4 * (k : ℝ)) := by
    have hk_ne : k ≠ 0 := Nat.pos_iff_ne_zero.mp hk
    let x' : ↑unitInterval := ⟨y, hy.1, hy.2⟩
    have hvar := bernstein.variance hk_ne x'
    simp only [bernstein.z, bernstein_apply, Subtype.coe_mk, x'] at hvar
    calc ∑ j : Fin (k + 1), (y - ↑↑j / ↑k) ^ 2 *
          (↑(k.choose ↑j) * y ^ ↑j * (1 - y) ^ (k - ↑j))
        = y * (1 - y) / (k : ℝ) := hvar
      _ ≤ (1 / 4) / (k : ℝ) := by
          apply div_le_div_of_nonneg_right _ hk_pos.le
          nlinarith [sq_nonneg (y - 1/2)]
      _ = 1 / (4 * (k : ℝ)) := by ring
  -- Combine: δ² * ∑ ≤ 1/(4k), so ∑ ≤ 1/(4kδ²)
  have h_bound := le_trans h_main h_var
  have hsum_nn : 0 ≤ ∑ j ∈ S,
    (Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val) :=
    Finset.sum_nonneg (fun j _ => hnn j)
  calc ∑ j ∈ S, (Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val)
      ≤ 1 / (4 * (k : ℝ)) / δ ^ 2 := by
        rw [le_div_iff₀ hδ2]
        linarith [h_bound]
    _ = 1 / (4 * (k : ℝ) * δ ^ 2) := by ring

private lemma zero_ehrenfest_computable : IsEhrenfestComputable (0 : ℝ) := by
  refine ⟨⟨1, by norm_num, fun _ => false⟩, 1, ⟨by norm_num, le_refl _⟩,
    ⟨1, by simp⟩, ⟨le_refl _, by norm_num⟩, ?_, ?_⟩
  · simp [EhrenfestRule.driftFn, EhrenfestRule.blackSet]
  · right; refine ⟨by norm_num, fun y hy hle => ?_⟩
    simp [EhrenfestRule.driftFn, EhrenfestRule.blackSet, EhrenfestRule.bernsteinTerm]
    linarith

private lemma one_ehrenfest_computable : IsEhrenfestComputable (1 : ℝ) := by
  have h0 := zero_ehrenfest_computable
  convert IsEhrenfestComputable.symmetric h0 using 1; ring

/-- L is dense in [0,1]: the closure of the Ehrenfest-computable set
contains all of [0,1].
Proof: for any α ∈ [0,1], take k large enough so that the Bernstein
polynomial of the step function 𝟙_{[α,1]} gives a root near α. -/
theorem ehrenfest_dense :
    Set.Icc (0 : ℝ) 1 ⊆ closure {ν : ℝ | IsEhrenfestComputable ν} := by
  intro α ⟨hα0, hα1⟩
  rw [Metric.mem_closure_iff]
  intro ε hε
  -- Handle boundary cases
  rcases eq_or_lt_of_le hα0 with heq0 | hα0'
  · exact ⟨0, zero_ehrenfest_computable, by rw [← heq0]; simp [hε]⟩
  rcases eq_or_lt_of_le hα1 with heq1 | hα1'
  · exact ⟨1, one_ehrenfest_computable, by rw [heq1]; simp [hε]⟩
  -- Interior case: α ∈ (0,1). Use threshold rule with large k.
  set ε' := min (ε / 2) (min (α / 2) ((1 - α) / 2)) with hε'_def
  have hε' : 0 < ε' := lt_min (half_pos hε) (lt_min (half_pos hα0') (half_pos (by linarith)))
  have hε'_le_ε : ε' ≤ ε / 2 := min_le_left _ _
  have hε'_le_α : ε' ≤ α / 2 := le_trans (min_le_right _ _) (min_le_left _ _)
  have hε'_le_1α : ε' ≤ (1 - α) / 2 := le_trans (min_le_right _ _) (min_le_right _ _)
  obtain ⟨k, hk_large⟩ := exists_nat_gt (max 2 (1 / (4 * ε' ^ 3)))
  have hk2 : 2 ≤ k := by
    have h2lt : (2 : ℝ) < (k : ℝ) := lt_of_le_of_lt (le_max_left _ _) hk_large
    exact le_of_lt (by exact_mod_cast h2lt)
  have hk_pos : (0 : ℝ) < (k : ℝ) := Nat.cast_pos.mpr (by omega)
  have hk_bound : 1 / (4 * ε' ^ 3) < (k : ℝ) :=
    lt_of_le_of_lt (le_max_right _ _) hk_large
  have htail_small : 1 / (4 * (k : ℝ) * ε' ^ 2) < ε' := by
    have h4ke2 : (0 : ℝ) < 4 * (k : ℝ) * ε' ^ 2 := by positivity
    suffices h : 1 < ε' * (4 * (k : ℝ) * ε' ^ 2) by
      exact (div_lt_iff₀ h4ke2).mpr h
    have h4e3 : (0 : ℝ) < 4 * ε' ^ 3 := by positivity
    have key : 1 < (k : ℝ) * (4 * ε' ^ 3) := by
      calc (1 : ℝ) = 1 / (4 * ε' ^ 3) * (4 * ε' ^ 3) := by
            field_simp
        _ < (k : ℝ) * (4 * ε' ^ 3) := by
            exact mul_lt_mul_of_pos_right hk_bound h4e3
    linarith [show ε' * (4 * (k : ℝ) * ε' ^ 2) = (k : ℝ) * (4 * ε' ^ 3) from by ring]
  set m := Nat.floor (k * α) with hm_def
  have hm_lt_k : m < k := by
    rw [hm_def]
    exact (Nat.floor_lt (by positivity : (0 : ℝ) ≤ ↑k * α)).mpr (by nlinarith)
  have hm_ge_1 : 1 ≤ m := by
    rw [hm_def]
    have hkα_ge_1 : (1 : ℝ) ≤ k * α := by
      have h4e3 : (0 : ℝ) < 4 * ε' ^ 3 := by positivity
      have hk_lower : 1 < (k : ℝ) * (4 * ε' ^ 3) := by
        calc (1 : ℝ) = 1 / (4 * ε' ^ 3) * (4 * ε' ^ 3) := by field_simp
          _ < (k : ℝ) * (4 * ε' ^ 3) := mul_lt_mul_of_pos_right hk_bound h4e3
      have hε'_cube : ε' ^ 3 ≤ (α / 2) ^ 3 := pow_le_pow_left₀ hε'.le hε'_le_α 3
      have hα2 : α ^ 2 ≤ 1 := by nlinarith [sq_nonneg (1 - α)]
      nlinarith [show (α / 2) ^ 3 = α ^ 3 / 8 from by ring,
                 show (0 : ℝ) < α ^ 2 from by positivity]
    exact Nat.floor_pos.mpr hkα_ge_1
  have hm_le_kα : (m : ℝ) ≤ k * α := Nat.floor_le (by positivity)
  have hkα_lt_m1 : k * α < (m : ℝ) + 1 := Nat.lt_floor_add_one _
  -- Key: (m+1)/k ≥ α and m/k ≤ α
  have hm1k_ge_α : α ≤ ((m : ℝ) + 1) / (k : ℝ) := by
    rw [le_div_iff₀ hk_pos]; linarith
  have hmk_le_α : (m : ℝ) / (k : ℝ) ≤ α := by
    rw [div_le_iff₀ hk_pos]; linarith
  -- Get the threshold root with its properties
  obtain ⟨ν, hν_mem, hν_root, hν_pos_below, hν_comp⟩ :=
    threshold_root_exists_and_computable k hk2 m hm_lt_k
  refine ⟨ν, hν_comp, ?_⟩
  rw [Real.dist_eq]
  -- Show |α - ν| < ε by showing α - ε' < ν < α + ε'
  suffices h : α - ε' < ν ∧ ν < α + ε' by
    rw [abs_lt]; constructor <;> linarith [h.1, h.2, hε'_le_ε]
  set rule := thresholdRule k (by omega : 0 < k) m hm_lt_k
  constructor
  · -- Lower bound: ν > α - ε'
    by_contra h_le
    push Not at h_le
    have hν_pos : (0 : ℝ) < ν := hν_mem.1
    -- For j > m: j/k ≥ (m+1)/k ≥ α ≥ ν + ε', so |ν - j/k| ≥ ε'
    have h_compl_bound :
        ∑ j ∈ Finset.univ.filter (fun j : Fin (k+1) => m < j.val),
          rule.bernsteinTerm j ν ≤ 1 / (4 * (k : ℝ) * ε' ^ 2) := by
      have hν01 : ν ∈ Set.Icc (0:ℝ) 1 :=
        ⟨le_of_lt hν_pos, le_of_lt (lt_trans (by linarith : ν < α) hα1')⟩
      exact bernstein_tail_bound k (by omega) ν hν01 _ ε' hε' (fun j hj => by
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hj
        have hj_cast : (m : ℝ) + 1 ≤ (j.val : ℝ) := by exact_mod_cast hj
        have hj_ge : α ≤ (j.val : ℝ) / k := by
          rw [le_div_iff₀ hk_pos]; linarith
        rw [abs_of_nonpos (by linarith : ν - (j.val : ℝ) / k ≤ 0)]
        linarith)
    -- ∑_{blackSet} = 1 - ∑_{complement} ≥ 1 - 1/(4kε'²)
    have h_part : ∑ j ∈ rule.blackSet, rule.bernsteinTerm j ν +
        ∑ j ∈ Finset.univ.filter (fun j : Fin (k+1) => m < j.val),
          rule.bernsteinTerm j ν = 1 := by
      have htotal := rule.bernstein_sum_eq_one ν
      have hbs : rule.blackSet = Finset.univ.filter (fun j : Fin (k+1) => j.val ≤ m) := by
        simp only [EhrenfestRule.blackSet, rule, thresholdRule]
        congr 1; ext j; simp [decide_eq_true_eq]
      have hcomp : Finset.univ.filter (fun j : Fin (k+1) => m < j.val) =
          Finset.univ.filter (fun j : Fin (k+1) => ¬(j.val ≤ m)) := by
        ext j; simp only [Finset.mem_filter, Finset.mem_univ, true_and]; omega
      rw [hbs, hcomp, ← htotal]
      exact Finset.sum_filter_add_sum_filter_not Finset.univ
        (fun j : Fin (k+1) => j.val ≤ m) (fun j => rule.bernsteinTerm j ν)
    have h_cdf_large : ∑ j ∈ rule.blackSet, rule.bernsteinTerm j ν ≥
        1 - 1 / (4 * (k : ℝ) * ε' ^ 2) := by linarith
    have h_drift_pos : 0 < rule.driftFn ν := by
      unfold EhrenfestRule.driftFn
      have : (rule.k : ℝ) = (k : ℝ) := by simp [rule, thresholdRule]
      rw [this]
      nlinarith [htail_small, hε'_le_1α]
    linarith [hν_root]
  · -- Upper bound: ν < α + ε'
    have hαε'_01 : α + ε' ∈ Set.Icc (0:ℝ) 1 := ⟨by linarith, by linarith⟩
    have h_black_bound :
        ∑ j ∈ rule.blackSet, rule.bernsteinTerm j (α + ε') ≤
          1 / (4 * (k : ℝ) * ε' ^ 2) := by
      have h_eq : rule.blackSet = Finset.univ.filter (fun j : Fin (k+1) => j.val ≤ m) := by
        simp only [EhrenfestRule.blackSet, rule, thresholdRule]
        congr 1; ext j; simp [decide_eq_true_eq]
      rw [h_eq]
      exact bernstein_tail_bound k (by omega) (α + ε') hαε'_01 _ ε' hε' (fun j hj => by
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hj
        have hjk : (j.val : ℝ) / k ≤ α := by
          calc (j.val : ℝ) / k ≤ (m : ℝ) / k := by
                apply div_le_div_of_nonneg_right (by exact_mod_cast hj) hk_pos.le
            _ ≤ α := hmk_le_α
        rw [abs_of_nonneg (by linarith : (α + ε') - (j.val : ℝ) / k ≥ 0)]
        linarith)
    have h_drift_neg : rule.driftFn (α + ε') < 0 := by
      unfold EhrenfestRule.driftFn
      have hrk : (rule.k : ℝ) = (k : ℝ) := by simp [rule, thresholdRule]
      rw [hrk]
      nlinarith [htail_small, hε'_le_α]
    -- IVT: drift(0) > 0, drift(α+ε') < 0 → zero in (0, α+ε')
    have h_drift_0 : 0 < rule.driftFn 0 := by
      rw [show rule.driftFn 0 = (k:ℝ) from thresholdRule_driftFn_zero k (by omega) m hm_lt_k]
      exact hk_pos
    have hcont := rule.driftFn_continuous
    have h_ivt : ∃ c ∈ Set.Icc 0 (α + ε'), rule.driftFn c = 0 := by
      have hmem : (0:ℝ) ∈ Set.Icc (rule.driftFn (α + ε')) (rule.driftFn 0) :=
        ⟨le_of_lt h_drift_neg, le_of_lt h_drift_0⟩
      obtain ⟨c, hc_mem, hc_val⟩ := intermediate_value_Icc'
        (by linarith : (0:ℝ) ≤ α + ε') hcont.continuousOn hmem
      exact ⟨c, hc_mem, hc_val⟩
    obtain ⟨c, hc_mem, hc_zero⟩ := h_ivt
    have hν_le_c : ν ≤ c := by
      by_contra h
      push Not at h
      have := hν_pos_below c hc_mem.1 h
      linarith [hc_zero]
    have hν_lt_αε : ν < α + ε' := by
      rcases lt_or_eq_of_le (le_trans hν_le_c hc_mem.2) with h | h
      · exact h
      · have : rule.driftFn (α + ε') = 0 := h ▸ hν_root
        linarith
    exact hν_lt_αε

/-- Auxiliary: the polynomial `(1-X)^d - X` in ℤ[X], whose roots in (0,1)
correspond to Ehrenfest drift zeros for E = {0} rules. -/
private noncomputable def selmerShiftPoly (d : ℕ) : Polynomial ℤ :=
  (Polynomial.C 1 - Polynomial.X) ^ d - Polynomial.X

/-- The polynomial `(1-X)^d - X` has degree d for d ≥ 1. -/
private lemma selmerShiftPoly_natDegree (d : ℕ) (hd : 0 < d) :
    (selmerShiftPoly d).natDegree = d := by
  unfold selmerShiftPoly
  have hdeg_base : (Polynomial.C (1 : ℤ) - Polynomial.X).natDegree = 1 := by
    rw [Polynomial.natDegree_sub, Polynomial.natDegree_X_sub_C]
  have hdeg_pow : ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ d).natDegree = d := by
    rw [Polynomial.natDegree_pow, hdeg_base, Nat.mul_one]
  rcases Nat.lt_or_ge d 2 with hd1 | hd2
  · have hd_eq : d = 1 := by omega
    subst hd_eq
    simp only [pow_one] at hdeg_pow ⊢
    apply le_antisymm
    · calc (Polynomial.C (1 : ℤ) - Polynomial.X - Polynomial.X).natDegree
          ≤ max (Polynomial.C (1 : ℤ) - Polynomial.X).natDegree Polynomial.X.natDegree :=
            Polynomial.natDegree_sub_le _ _
        _ = max 1 1 := by rw [hdeg_base, Polynomial.natDegree_X]
        _ = 1 := Nat.max_self _
    · have hcoeff : (Polynomial.C (1 : ℤ) - Polynomial.X - Polynomial.X).coeff 1 = -2 := by
        simp [Polynomial.coeff_sub, Polynomial.coeff_X, Polynomial.coeff_one]
      exact Polynomial.le_natDegree_of_ne_zero (by rw [hcoeff]; norm_num)
  · have hlt : (Polynomial.X : Polynomial ℤ).natDegree <
        ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ d).natDegree := by
      rw [Polynomial.natDegree_X, hdeg_pow]; omega
    rw [Polynomial.natDegree_sub_eq_left_of_natDegree_lt hlt, hdeg_pow]

/-- For even d ≥ 2: `(1-X)^d - X` is irreducible over ℤ.
Proof: it equals `(X^d - X - 1).comp(X - 1)` up to sign, and X^d - X - 1
is irreducible (Selmer); composition with X - 1 preserves irreducibility. -/
private lemma selmerShiftPoly_irreducible (d : ℕ) (hd : 2 ≤ d) (heven : Even d) :
    Irreducible (selmerShiftPoly d) := by
  -- Key idea: (1-X)^d - X = (X-1)^d - X (even d) = R(X-1) where R = X^d - X - 1 (Selmer)
  -- The automorphism X ↦ X-1 of ℤ[X] preserves irreducibility.
  have hd1 : d ≠ 1 := by omega
  -- Selmer polynomial is irreducible
  have hSelmer : Irreducible
      ((Polynomial.X : Polynomial ℤ) ^ d - Polynomial.X - 1) :=
    Polynomial.X_pow_sub_X_sub_one_irreducible hd1
  -- algEquivAevalXAddC (-1) sends f(X) to f(X + (-1)) = f(X - 1)
  -- It sends (X^d - X - 1) to ((X-1)^d - (X-1) - 1) = (X-1)^d - X = (1-X)^d - X (even d)
  have hrel : selmerShiftPoly d =
      (Polynomial.algEquivAevalXAddC (-1 : ℤ))
        ((Polynomial.X : Polynomial ℤ) ^ d - Polynomial.X - 1) := by
    simp only [selmerShiftPoly]
    -- algEquivAevalXAddC (-1) sends f to f.comp (X + C(-1)) = f.comp (X - C 1)
    -- Unfold in terms of comp
    show (Polynomial.C 1 - Polynomial.X) ^ d - Polynomial.X =
      (Polynomial.algEquivAevalXAddC (-1 : ℤ))
        (Polynomial.X ^ d - Polynomial.X - 1)
    -- Compute the RHS via ring hom properties
    conv_rhs =>
      rw [show (Polynomial.X : Polynomial ℤ) ^ d - Polynomial.X - 1 =
        Polynomial.X ^ d - Polynomial.X - Polynomial.C 1 from by simp]
      simp only [map_sub, map_pow]
    -- Now the RHS image of X under algEquivAevalXAddC (-1)
    have hX_img : (Polynomial.algEquivAevalXAddC (-1 : ℤ)) Polynomial.X =
        Polynomial.X - Polynomial.C 1 := by
      show Polynomial.aeval (Polynomial.X + Polynomial.C (-1 : ℤ)) Polynomial.X =
        Polynomial.X - Polynomial.C 1
      simp [Polynomial.aeval_X, sub_eq_add_neg, Polynomial.C_neg]
    have hC_img : (Polynomial.algEquivAevalXAddC (-1 : ℤ)) (Polynomial.C 1) =
        Polynomial.C 1 := by
      simp [map_one]
    rw [hX_img, hC_img]
    -- Goal: (C 1 - X)^d - X = (X - C 1)^d - (X - C 1) - C 1
    -- For even d: (C 1 - X)^d = (X - C 1)^d, then ring
    have hneg_pow : (Polynomial.C (1 : ℤ) - Polynomial.X) ^ d =
        (Polynomial.X - Polynomial.C 1) ^ d := by
      rw [show Polynomial.C (1 : ℤ) - Polynomial.X = -(Polynomial.X - Polynomial.C 1) from by ring]
      rw [neg_pow, heven.neg_one_pow, one_mul]
    rw [hneg_pow]; ring
  rw [hrel]
  exact (MulEquiv.irreducible_iff
    (f := (Polynomial.algEquivAevalXAddC (-1 : ℤ)).toMulEquiv)).mpr hSelmer

/-- Evaluating `(1-X)^d - X` at a root of the E={0} drift gives 0. -/
private lemma thresholdRule_zero_driftFn_eq (d : ℕ) (hd : 0 < d) (ν : ℝ) :
    (thresholdRule d hd 0 (by omega : 0 < d)).driftFn ν =
    (d : ℝ) * ((1 - ν) ^ d - ν) := by
  set rule := thresholdRule d hd 0 (by omega : 0 < d)
  -- The blackSet for m=0 is exactly {0} since j.val ≤ 0 ↔ j.val = 0 for ℕ
  -- We compute driftFn using the explicit sum
  show (rule.k : ℝ) * ∑ j ∈ rule.blackSet, rule.bernsteinTerm j ν -
    (rule.k : ℝ) * ν = (d : ℝ) * ((1 - ν) ^ d - ν)
  have hrk : (rule.k : ℝ) = (d : ℝ) := by simp [rule, thresholdRule]
  suffices h : ∑ j ∈ rule.blackSet, rule.bernsteinTerm j ν = (1 - ν) ^ d by
    rw [hrk, h]; ring
  -- The only element with val ≤ 0 is ⟨0, _⟩
  have hmem : ∀ j ∈ rule.blackSet, j = (⟨0, by omega⟩ : Fin (d + 1)) := by
    intro j hj
    simp only [EhrenfestRule.blackSet, Finset.mem_filter, Finset.mem_univ, true_and] at hj
    have hj' : (j : ℕ) ≤ 0 := by simpa [rule, thresholdRule, decide_eq_true_eq] using hj
    exact Fin.ext (Nat.le_zero.mp hj')
  have h0_mem : (⟨0, by omega⟩ : Fin (d + 1)) ∈ rule.blackSet := by
    have : rule.f ⟨0, by omega⟩ = true := by simp [rule, thresholdRule]
    exact Finset.mem_filter.mpr ⟨Finset.mem_univ _, this⟩
  have hbt0 : rule.bernsteinTerm ⟨0, by omega⟩ ν = (1 - ν) ^ d := by
    simp [EhrenfestRule.bernsteinTerm, rule, thresholdRule]
  calc ∑ j ∈ rule.blackSet, rule.bernsteinTerm j ν
      = ∑ _j ∈ rule.blackSet, rule.bernsteinTerm ⟨0, by omega⟩ ν := by
        apply Finset.sum_congr rfl
        intro j hj; rw [show j = ⟨0, by omega⟩ from hmem j hj]
    _ = rule.blackSet.card • rule.bernsteinTerm ⟨0, by omega⟩ ν := by
        rw [Finset.sum_const]
    _ = 1 • rule.bernsteinTerm ⟨0, by omega⟩ ν := by
        congr 1
        have hcard : rule.blackSet.card = 1 := by
          have hsub : rule.blackSet ⊆ {⟨0, by omega⟩} := by
            intro j hj; exact Finset.mem_singleton.mpr (hmem j hj)
          have := Finset.card_le_card hsub
          simp at this
          exact Nat.le_antisymm this (Finset.card_pos.mpr ⟨_, h0_mem⟩)
        exact hcard
    _ = (1 - ν) ^ d := by rw [one_smul, hbt0]

private lemma selmerShiftPoly_eval_root (d : ℕ) (hd : 2 ≤ d) (ν : ℝ)
    (hroot : (thresholdRule d (by omega : 0 < d) 0 (by omega : 0 < d)).driftFn ν = 0)
    (hν_pos : 0 < ν) :
    Polynomial.eval₂ (Int.castRingHom ℝ) ν (selmerShiftPoly d) = 0 := by
  have hd_pos : (0 : ℝ) < (d : ℝ) := Nat.cast_pos.mpr (by omega : 0 < d)
  have hkey : (1 - ν) ^ d = ν := by
    have h := thresholdRule_zero_driftFn_eq d (by omega) ν
    rw [hroot] at h
    nlinarith
  have heval : Polynomial.eval₂ (Int.castRingHom ℝ) ν (selmerShiftPoly d) =
      (1 - ν) ^ d - ν := by
    simp only [selmerShiftPoly, Polynomial.eval₂_sub, Polynomial.eval₂_pow,
      Polynomial.eval₂_X, Polynomial.eval₂_C]
    norm_num
  rw [heval, hkey, sub_self]

/-! ### Kummer polynomial irreducibility

**GAP**: The claim that `(d+1)(1-X)^d - 1` is irreducible for all odd d ≥ 3 is FALSE.
Counterexample: d = 63, d+1 = 64 = 4³, and 3 | 63, so the polynomial factors.
The paper (Albenque-Gerin 2012, Theorem 5(iii)) asserts this without proof.

**Current fix direction:** Split into two cases:
- d ≢ 5 mod 6: use E={0}, k=d. The Selmer-type polynomial Y^d + Y - 1 is irreducible.
- d ≡ 5 mod 6: use the paper's singleton construction E={1}. The dynamical part is
  formalized below; the remaining input is the pure algebraic degree witness for
  `(d+1)*(1-X)^d - 1`.

The theorem `ehrenfest_all_algebraic_degrees` remains correct but needs restructuring. -/
/-- For odd d ≥ 3 with d ≢ 5 mod 6: `(1-X)^d - X` is irreducible.
Under substitution Y = 1-X this becomes Y^d + Y - 1, which is irreducible
when d ≢ 5 mod 6 (by the Selmer-type result: Y^n + Y - 1 factors only when
n ≡ 5 mod 6, having factor Y² - Y + 1).

For d ≡ 5 mod 6, the file uses the separate singleton construction below. -/
private theorem X_pow_add_X_sub_one_irreducible_aux {n : ℕ} (hn6 : n % 6 ≠ 5) (z : ℂ) :
    ¬(z ^ n + z - 1 = 0 ∧ 1 + z ^ (n - 1) - z ^ n = 0) := by
  rintro ⟨h1, h2⟩
  have hn2 : 2 ≤ n := by
    by_contra hlt; push Not at hlt
    interval_cases n
    · norm_num at h2
    · exact absurd (show (3 : ℂ) = 0 from by linear_combination h1 + 2 * h2) (by norm_num)
  have z_ne_zero : z ≠ 0 := by
    intro hz; rw [hz, zero_pow (by omega : n ≠ 0)] at h1; norm_num at h1
  -- Multiply h2 by z, use pow_succ to eliminate (n-1) exponent
  have h2z : z + z ^ n - z ^ (n + 1) = 0 := by
    have hmul := mul_eq_zero_of_left h2 z
    have key1 : z ^ (n - 1) * z = z ^ n := by
      have := (pow_succ z (n - 1)).symm
      rwa [Nat.sub_add_cancel (by omega : 1 ≤ n)] at this
    have key2 : z ^ n * z = z ^ (n + 1) := (pow_succ z n).symm
    have heq : (1 + z ^ (n - 1) - z ^ n) * z = z + z ^ n - z ^ (n + 1) := by
      have lhs : (1 + z ^ (n - 1) - z ^ n) * z = z + z ^ (n - 1) * z - z ^ n * z := by ring
      rw [lhs, key1, key2]
    rw [heq] at hmul; exact hmul
  -- z^(n+1) = 1
  have h_zn1 : z ^ (n + 1) = 1 := by linear_combination h1 - h2z
  -- z^2 - z + 1 = 0
  have h_z2 : z ^ 2 - z + 1 = 0 := by
    have h_zn : z ^ n = 1 - z := by linear_combination h1
    have h_zn1_alt : z ^ (n + 1) = z - z ^ 2 := by
      have : z ^ (n + 1) = z ^ n * z := pow_succ z n
      rw [this, h_zn]; ring
    linear_combination h_zn1_alt - h_zn1
  -- z^3 = -1: from z^3 + 1 = (z+1)(z^2-z+1) = 0
  have h_z3 : z ^ 3 = -1 := by linear_combination (z + 1) * h_z2
  -- z^6 = 1
  have h_z6 : z ^ 6 = 1 := by
    have : z ^ 6 = (z ^ 3) ^ 2 := by ring
    rw [this, h_z3]; norm_num
  -- From z^(n+1) = 1 and z^6 = 1: z^((n+1)%6) = 1
  have h_mod : z ^ ((n + 1) % 6) = 1 := by
    have hrw : z ^ (n + 1) = z ^ ((n + 1) % 6) := by
      conv_lhs => rw [show n + 1 = 6 * ((n + 1) / 6) + (n + 1) % 6 from
        (Nat.div_add_mod (n + 1) 6).symm]
      rw [pow_add, pow_mul, h_z6, one_pow, one_mul]
    rw [← hrw]; exact h_zn1
  -- (n+1)%6 = 0, hence n%6 = 5
  have h_n5 : n % 6 = 5 := by
    suffices h_suf : (n + 1) % 6 = 0 by omega
    by_contra hne
    have hpos : 0 < (n + 1) % 6 := Nat.pos_of_ne_zero hne
    have hlt : (n + 1) % 6 < 6 := Nat.mod_lt _ (by omega)
    -- z^m = 1 with 0 < m < 6 contradicts z being primitive 6th root (z^2-z+1=0)
    -- Each case k=1..5 leads to numerical contradiction
    have h_order : ∀ k : ℕ, 0 < k → k < 6 → z ^ k = 1 → False := by
      intro k hk_pos hk_lt hk
      interval_cases k
      · -- k=1: z=1, z^2-z+1 = 1 ≠ 0
        rw [show z = 1 from by simpa using hk] at h_z2; norm_num at h_z2
      · -- k=2: z^2=1, with z^2-z+1=0: 2-z=0, z=2, z^2=4≠1
        exact absurd (show (3:ℂ) = 0 from by
          linear_combination (z + 2) * h_z2 - (z + 1) * hk) (by norm_num)
      · -- k=3: z^3=1, but z^3=-1
        exact absurd (show (2:ℂ) = 0 from by linear_combination h_z3 - hk) (by norm_num)
      · -- k=4: z^4=1. z^4=z*z^3=-z. So -z=1, z=-1. z^2-z+1=3≠0.
        have hz : z + 1 = 0 := by linear_combination -hk + z * h_z3
        exact absurd (show (3:ℂ) = 0 from by
          linear_combination h_z2 - (z - 2) * hz) (by norm_num)
      · -- k=5: z^5=1. z^5=z^2*z^3=-(z-1)=1-z. 1-z=1, z=0. Contradiction.
        exact z_ne_zero (show z = 0 from by
          linear_combination -hk + z ^ 2 * h_z3 - h_z2)
    exact h_order _ hpos hlt h_mod
  exact hn6 h_n5

private theorem X_pow_add_X_sub_one_irreducible (n : ℕ) (hn1 : n ≠ 1) (hn6 : n % 6 ≠ 5) :
    Irreducible ((Polynomial.X : Polynomial ℤ) ^ n + Polynomial.X - 1) := by
  by_cases hn0 : n = 0
  · rw [hn0, pow_zero, show (1 : Polynomial ℤ) + Polynomial.X - 1 = Polynomial.X from by ring]
    exact Polynomial.irreducible_X
  have hn : 1 < n := Nat.one_lt_iff_ne_zero_and_ne_one.mpr ⟨hn0, hn1⟩
  have hp : (Polynomial.X ^ n + Polynomial.X - 1 : Polynomial ℤ) =
      Polynomial.trinomial 0 1 n (-1) 1 1 := by
    simp only [Polynomial.trinomial, Polynomial.C_neg, Polynomial.C_1]; ring
  rw [hp]
  apply Polynomial.IsUnitTrinomial.irreducible_of_coprime'
    ⟨0, 1, n, Nat.zero_lt_one, hn, -1, 1, 1, rfl⟩
  rintro z ⟨h1, h2⟩
  apply X_pow_add_X_sub_one_irreducible_aux (n := n) hn6 z
  rw [Polynomial.trinomial_mirror Nat.zero_lt_one hn
    (-1 : ℤˣ).ne_zero (1 : ℤˣ).ne_zero] at h2
  simp only [Polynomial.trinomial, Polynomial.aeval_add, Polynomial.aeval_mul,
    Polynomial.aeval_X_pow, Polynomial.aeval_C,
    Units.val_neg, Units.val_one, map_neg, map_one] at h1 h2
  exact ⟨by linear_combination h1, by linear_combination h2⟩

private lemma selmerShiftPoly_irreducible_odd (d : ℕ) (hd : 3 ≤ d) (hodd : Odd d)
    (hmod : d % 6 ≠ 5) :
    Irreducible (selmerShiftPoly d) := by
  have hd1 : d ≠ 1 := by omega
  have hIrr : Irreducible ((Polynomial.X : Polynomial ℤ) ^ d + Polynomial.X - 1) :=
    X_pow_add_X_sub_one_irreducible d hd1 hmod
  -- selmerShiftPoly d = (X^d + X - 1) composed with (1-X), an automorphism
  haveI : Invertible (1 : ℤ) := invertibleOne
  letI : Invertible (-1 : ℤ) := invertibleNeg (R := ℤ) 1
  set φ := Polynomial.algEquivCMulXAddC (-1 : ℤ) 1
  have hrel : selmerShiftPoly d = φ (Polynomial.X ^ d + Polynomial.X - 1) := by
    simp only [selmerShiftPoly]
    show (Polynomial.C 1 - Polynomial.X) ^ d - Polynomial.X =
      φ (Polynomial.X ^ d + Polynomial.X - 1)
    conv_rhs =>
      rw [show (Polynomial.X : Polynomial ℤ) ^ d + Polynomial.X - 1 =
        Polynomial.X ^ d + Polynomial.X - Polynomial.C 1 from by simp]
      simp only [map_sub, map_add, map_pow]
    have hX_img : φ Polynomial.X =
        Polynomial.C (-1 : ℤ) * Polynomial.X + Polynomial.C 1 := by
      simp [φ, Polynomial.algEquivCMulXAddC_apply, Polynomial.aeval_X]
    have hC_img : φ (Polynomial.C 1) = Polynomial.C 1 := map_one φ
    rw [hX_img, hC_img]
    simp only [Polynomial.C_neg, Polynomial.C_1]
    ring
  rw [hrel]
  exact (MulEquiv.irreducible_iff (f := φ.toMulEquiv)).mpr hIrr

/-- Candidate Sylvester--Schur-style valuation-one property.

Warning: this exact formulation is too strong and should not be used as a
mathematical theorem.  For example, the previously discussed exceptional
case `n = 12168, k = 2` has `Nat.choose n k` with no prime divisor of
valuation one.  The final `d % 6 = 5` construction must use a corrected
number-theoretic input or a different irreducibility argument. -/
def SylvesterSchurProperty : Prop :=
  ∀ (n k : ℕ), 2 * k < n → ∃ p : ℕ, Nat.Prime p ∧ k < p ∧ padicValNat p (Nat.choose n k) = 1

/-- Valuation-one bridge for the corrected Sylvester--Schur route.

If a prime divisor `p` of `Nat.choose n k` lies above `sqrt n`, then Mathlib's
`Nat.factorization_choose_le_one` says that its multiplicity in the binomial
coefficient is at most one.  Since it divides the binomial coefficient, the
multiplicity is exactly one. -/
private theorem padicValNat_choose_eq_one_of_prime_dvd_of_lt_square
    {n k p : ℕ} (hkn : k ≤ n) (hp : p.Prime)
    (hpdvd : p ∣ Nat.choose n k) (hp2 : n < p ^ 2) :
    padicValNat p (Nat.choose n k) = 1 := by
  have hchoose_ne : Nat.choose n k ≠ 0 := (Nat.choose_pos hkn).ne'
  have hle : (Nat.choose n k).factorization p ≤ 1 :=
    Nat.factorization_choose_le_one hp2
  have hone : 1 ≤ (Nat.choose n k).factorization p :=
    (hp.dvd_iff_one_le_factorization hchoose_ne).mp hpdvd
  have hfac : (Nat.choose n k).factorization p = padicValNat p (Nat.choose n k) :=
    Nat.factorization_def (Nat.choose n k) hp
  omega

private theorem padicValNat_eq_one_of_prime_dvd_not_sq
    {n p : ℕ} (hp : p.Prime) (hpdvd : p ∣ n) (hp2not : ¬ p ^ 2 ∣ n) :
    padicValNat p n = 1 := by
  haveI : Fact p.Prime := ⟨hp⟩
  have hn : n ≠ 0 := by
    intro hn
    exact hp2not (by rw [hn]; exact dvd_zero (p ^ 2))
  have hge : 1 ≤ padicValNat p n := by
    have hpow : p ^ 1 ∣ n := by simpa using hpdvd
    exact (padicValNat_dvd_iff_le hn).mp hpow
  have hnot_ge_two : ¬ 2 ≤ padicValNat p n := by
    intro hge_two
    exact hp2not ((padicValNat_dvd_iff_le hn).mpr hge_two)
  omega

private lemma exists_prime_not_dvd_padicValNat_of_not_pow
    {N q : ℕ} (hN : N ≠ 0) (hq : q ≠ 0)
    (hnot : ¬ ∃ a : ℕ, N = a ^ q) :
    ∃ p : ℕ, p.Prime ∧ ¬ q ∣ padicValNat p N := by
  suffices hforward :
      (∀ p : ℕ, p.Prime → q ∣ padicValNat p N) → ∃ a : ℕ, N = a ^ q by
    by_contra h
    push_neg at h
    exact hnot (hforward h)
  intro h
  refine ⟨Nat.floorRoot q N, ?_⟩
  have hroot_ne : Nat.floorRoot q N ≠ 0 :=
    Nat.floorRoot_ne_zero.mpr ⟨hq, hN⟩
  apply Nat.eq_of_factorization_eq hN (pow_ne_zero q hroot_ne)
  intro p
  rw [Nat.factorization_pow, Nat.factorization_floorRoot]
  by_cases hp : p.Prime
  · have hdiv : q ∣ N.factorization p := by
      simpa [Nat.factorization_def N hp] using h p hp
    have hmul : q * (N.factorization p / q) = N.factorization p := by
      rw [mul_comm]
      exact Nat.div_mul_cancel hdiv
    simpa [Finsupp.floorDiv_apply, hmul]
  · simp [Nat.factorization_eq_zero_of_not_prime N hp]

private lemma nat_is_pow_of_forall_prime_dvd_padicValNat
    {N q : ℕ} (hN : N ≠ 0) (hq : q ≠ 0)
    (h : ∀ p : ℕ, p.Prime → q ∣ padicValNat p N) :
    ∃ a : ℕ, N = a ^ q := by
  refine ⟨Nat.floorRoot q N, ?_⟩
  have hroot_ne : Nat.floorRoot q N ≠ 0 :=
    Nat.floorRoot_ne_zero.mpr ⟨hq, hN⟩
  apply Nat.eq_of_factorization_eq hN (pow_ne_zero q hroot_ne)
  intro p
  rw [Nat.factorization_pow, Nat.factorization_floorRoot]
  by_cases hp : p.Prime
  · have hdiv : q ∣ N.factorization p := by
      simpa [Nat.factorization_def N hp] using h p hp
    have hmul : q * (N.factorization p / q) = N.factorization p := by
      rw [mul_comm]
      exact Nat.div_mul_cancel hdiv
    simpa [Finsupp.floorDiv_apply, hmul]
  · simp [Nat.factorization_eq_zero_of_not_prime N hp]

private lemma left_factor_is_pow_of_coprime_mul_eq_pow
    {x y z q : ℕ} (hx : x ≠ 0) (hy : y ≠ 0) (hq : q ≠ 0)
    (hcop : Nat.Coprime x y) (hxy : x * y = z ^ q) :
    ∃ a : ℕ, x = a ^ q := by
  apply nat_is_pow_of_forall_prime_dvd_padicValNat hx hq
  intro p hp
  by_cases hpx : p ∣ x
  · have hpy : ¬ p ∣ y := by
      intro hpy
      have hpgcd : p ∣ Nat.gcd x y := Nat.dvd_gcd hpx hpy
      rw [Nat.Coprime.gcd_eq_one hcop] at hpgcd
      exact hp.not_dvd_one hpgcd
    haveI : Fact p.Prime := ⟨hp⟩
    have hz : z ≠ 0 := by
      intro hz0
      have hzero : z ^ q = 0 := by rw [hz0, zero_pow hq]
      exact mul_ne_zero hx hy (by rw [hxy, hzero])
    have hval_y : padicValNat p y = 0 := padicValNat.eq_zero_of_not_dvd hpy
    have hval_mul : padicValNat p (x * y) = padicValNat p x := by
      rw [padicValNat.mul hx hy, hval_y, add_zero]
    have hval_pow : padicValNat p (z ^ q) = q * padicValNat p z := by
      rw [padicValNat.pow q hz]
    rw [hxy, hval_pow] at hval_mul
    rw [← hval_mul]
    exact dvd_mul_right q (padicValNat p z)
  · rw [padicValNat.eq_zero_of_not_dvd hpx]
    exact dvd_zero q

private lemma base_dvd_of_same_pow_dvd_same_pow
    {x y n : ℕ} (hn : n ≠ 0) (hx : x ≠ 0) (hy : y ≠ 0)
    (h : x ^ n ∣ y ^ n) :
    x ∣ y := by
  rw [← Nat.factorization_le_iff_dvd hx hy]
  intro p
  have hfac :
      (x ^ n).factorization p ≤ (y ^ n).factorization p :=
    (Nat.factorization_le_iff_dvd (pow_ne_zero n hx) (pow_ne_zero n hy)).mpr h p
  rw [Nat.factorization_pow, Nat.factorization_pow] at hfac
  exact Nat.le_of_mul_le_mul_left hfac (Nat.pos_of_ne_zero hn)

private lemma choose_succ_two_eq_mul_half_of_odd
    (d : ℕ) (hodd : Odd d) :
    Nat.choose (d + 1) 2 = d * ((d + 1) / 2) := by
  obtain ⟨m, hm⟩ := hodd
  subst hm
  have hhalf : (2 * m + 1 + 1) / 2 = m + 1 := by omega
  have hsub : 2 * m + 1 + 1 - 1 = 2 * m + 1 := by omega
  rw [Nat.choose_two_right, hhalf, hsub]
  rw [show (2 * m + 1 + 1) = 2 * (m + 1) by omega]
  rw [show 2 * (m + 1) * (2 * m + 1) = 2 * ((m + 1) * (2 * m + 1)) by ring]
  rw [Nat.mul_div_cancel_left _ (by norm_num : 0 < 2)]
  ring

private lemma coprime_self_half_succ_of_odd
    (d : ℕ) (hodd : Odd d) :
    Nat.Coprime d ((d + 1) / 2) := by
  obtain ⟨m, hm⟩ := hodd
  subst hm
  have hhalf : (2 * m + 1 + 1) / 2 = m + 1 := by omega
  rw [hhalf]
  have hcop2 : Nat.Coprime (2 * m + 1) (2 * (m + 1)) := by
    rw [show 2 * (m + 1) = (2 * m + 1) + 1 by omega]
    exact (Nat.coprime_self_add_right).mpr (Nat.coprime_one_right _)
  exact hcop2.coprime_dvd_right (dvd_mul_left (m + 1) 2)

private lemma left_factor_choose_two_is_pow_of_odd
    {d z q : ℕ} (hd : d ≠ 0) (hodd : Odd d) (hq : q ≠ 0)
    (hpow : Nat.choose (d + 1) 2 = z ^ q) :
    ∃ a : ℕ, d = a ^ q := by
  apply left_factor_is_pow_of_coprime_mul_eq_pow
    hd
    (by
      have hpos : 0 < (d + 1) / 2 := by
        obtain ⟨m, hm⟩ := hodd
        subst hm
        omega
      exact hpos.ne')
    hq
    (coprime_self_half_succ_of_odd d hodd)
  rw [← choose_succ_two_eq_mul_half_of_odd d hodd, hpow]

private lemma right_factor_choose_two_is_pow_of_odd
    {d z q : ℕ} (hd : d ≠ 0) (hodd : Odd d) (hq : q ≠ 0)
    (hpow : Nat.choose (d + 1) 2 = z ^ q) :
    ∃ a : ℕ, (d + 1) / 2 = a ^ q := by
  apply left_factor_is_pow_of_coprime_mul_eq_pow
    (by
      have hpos : 0 < (d + 1) / 2 := by
        obtain ⟨m, hm⟩ := hodd
        subst hm
        omega
      exact hpos.ne')
    hd
    hq
    (coprime_self_half_succ_of_odd d hodd).symm
  rw [mul_comm, ← choose_succ_two_eq_mul_half_of_odd d hodd, hpow]

private lemma dumas_prime_cover_of_choose_two_not_pow
    (d : ℕ) (hd : 1 ≤ d)
    (hnot : ∀ q : ℕ, q.Prime → q ∣ d →
      ¬ ∃ a : ℕ, Nat.choose (d + 1) 2 = a ^ q) :
    ∀ q : ℕ, q.Prime → q ∣ d →
      ∃ p : ℕ, p.Prime ∧
        ¬ q ∣ padicValNat p (Nat.choose (d + 1) 2) := by
  intro q hqprime hqdvd
  have hchoose_ne : Nat.choose (d + 1) 2 ≠ 0 :=
    (Nat.choose_pos (by omega : 2 ≤ d + 1)).ne'
  exact exists_prime_not_dvd_padicValNat_of_not_pow
    hchoose_ne hqprime.ne_zero (hnot q hqprime hqdvd)

private lemma padicValNat_choose_two_eq_padicValNat_d_of_prime_dvd
    {d p : ℕ} (hd : d ≠ 0) (hodd : Odd d) (hp : p.Prime) (hpd : p ∣ d) :
    padicValNat p (Nat.choose (d + 1) 2) = padicValNat p d := by
  have hhalf_pos : 0 < (d + 1) / 2 := by
    obtain ⟨m, hm⟩ := hodd
    subst hm
    omega
  have hhalf_ne : (d + 1) / 2 ≠ 0 := hhalf_pos.ne'
  have hp_not_half : ¬ p ∣ (d + 1) / 2 := by
    intro hphalf
    have hpgcd : p ∣ Nat.gcd d ((d + 1) / 2) := Nat.dvd_gcd hpd hphalf
    rw [Nat.Coprime.gcd_eq_one (coprime_self_half_succ_of_odd d hodd)] at hpgcd
    exact hp.not_dvd_one hpgcd
  haveI : Fact p.Prime := ⟨hp⟩
  rw [choose_succ_two_eq_mul_half_of_odd d hodd]
  rw [padicValNat.mul hd hhalf_ne]
  rw [padicValNat.eq_zero_of_not_dvd hp_not_half, add_zero]

private lemma nat_pow_of_rat_pow_eq_inv_natCast
    {N p : ℕ} (hN : 0 < N) {b : ℚ}
    (hb : b ^ p = (1 : ℚ) / (N : ℚ)) :
    ∃ a : ℕ, N = a ^ p := by
  refine ⟨b.den, ?_⟩
  have hden := congrArg Rat.den hb
  simpa [one_div, Rat.inv_natCast_den_of_pos hN] using hden.symm

private lemma singletonOne_kummer_condition_of_not_nat_pow
    (d : ℕ)
    (hnot : ∀ p : ℕ, p.Prime → p ∣ d → ¬ ∃ a : ℕ, d + 1 = a ^ p) :
    ∀ p : ℕ, p.Prime → p ∣ d → ∀ b : ℚ,
      b ^ p ≠ (1 : ℚ) / (((d + 1 : ℕ) : ℚ)) := by
  intro p hp hpd b hb
  exact hnot p hp hpd
    (nat_pow_of_rat_pow_eq_inv_natCast (by omega : 0 < d + 1) hb)

/-- The exact integer polynomial for the threshold drift equation
`Σ_{j≤m} C(k,j) X^j(1-X)^{k-j} = X`.

This is the direct algebraic content of a threshold-rule root.  It is
intentionally kept separate from the degree-`d` Eisenstein polynomial below:
the latter is a different claim and does **not** follow from the threshold
drift equation as previously stated. -/
private noncomputable def thresholdDriftPolynomial (k m : ℕ) : Polynomial ℤ :=
  (∑ j : Fin (k + 1),
    if j.val ≤ m then
      Polynomial.C (Nat.choose k j.val : ℤ) *
        Polynomial.X ^ j.val *
        (1 - Polynomial.X) ^ (k - j.val)
    else 0) - Polynomial.X

/-! ### The singleton construction `E = {1}`

Albenque--Gerin use the rule `E = {1}`:

`b(y) = k * y * (k * (1-y)^(k-1) - 1)`.

The non-zero equilibrium satisfies `(1-y)^(k-1) = 1/k`.  The dynamical
part below is fully formalized.  The exact-degree claim is kept as a separate
algebraic witness because the naive binomial irreducibility statement needs
number-theoretic side conditions: if `k` is a non-trivial `p`-th power for a
prime `p ∣ k-1`, the degree of this particular singleton root drops. -/

/-- Singleton rule `E = {1}`. -/
def singletonOneRule (k : ℕ) (hk : 1 < k) : EhrenfestRule where
  k := k
  k_pos := by omega
  f := fun j => decide (j.val = 1)

/-- Singleton rule `E = {j}` for an arbitrary non-boundary index. -/
def singletonIndexRule (k : ℕ) (hk : 0 < k) (j : Fin (k + 1)) : EhrenfestRule where
  k := k
  k_pos := hk
  f := fun i => decide (i = j)

private lemma singletonIndexRule_blackSet (k : ℕ) (hk : 0 < k) (j : Fin (k + 1)) :
    (singletonIndexRule k hk j).blackSet = ({j} : Finset (Fin (k + 1))) := by
  ext i
  unfold EhrenfestRule.blackSet singletonIndexRule
  simp

/-- Drift for a singleton rule `E = {j}`. -/
private lemma singletonIndexRule_drift (k : ℕ) (hk : 0 < k) (j : Fin (k + 1))
    (y : ℝ) :
    (singletonIndexRule k hk j).driftFn y =
      (k : ℝ) *
        ((Nat.choose k j.val : ℝ) * y ^ j.val * (1 - y) ^ (k - j.val) - y) := by
  have hbs := singletonIndexRule_blackSet k hk j
  unfold EhrenfestRule.driftFn
  rw [hbs]
  simp [EhrenfestRule.bernsteinTerm, singletonIndexRule]
  ring_nf

/-- Reciprocal-variable polynomial for a singleton-index non-zero root.

For `k = d + 1`, a non-zero root of the singleton rule `E = {j}` satisfies

`choose(k,j) * y^(j-1) * (1-y)^(k-j) = 1`.

With `Z = 1 / y`, this becomes

`Z^d - choose(d+1,j) * (Z-1)^(d+1-j) = 0`.

This is the polynomial intended for the Sylvester-Schur/Eisenstein branch in
the exceptional class. -/
private noncomputable def singletonIndexReciprocalPolynomial
    (d : ℕ) (j : Fin (d + 2)) : Polynomial ℤ :=
  Polynomial.X ^ d -
    Polynomial.C (Nat.choose (d + 1) j.val : ℤ) *
      ((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)

private noncomputable def singletonIndexRootPolynomial
    (d : ℕ) (j : Fin (d + 2)) : Polynomial ℤ :=
  Polynomial.C (Nat.choose (d + 1) j.val : ℤ) *
    Polynomial.X ^ (j.val - 1) *
      (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d + 1 - j.val) -
    Polynomial.C (1 : ℤ)

private lemma singletonIndexRootPolynomial_eval_eq_factor
    (d : ℕ) (j : Fin (d + 2)) (ν : ℝ) :
    Polynomial.eval₂ (Int.castRingHom ℝ) ν (singletonIndexRootPolynomial d j) =
      ((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
        ν ^ (j.val - 1) * (1 - ν) ^ (d + 1 - j.val) - 1 := by
  simp [singletonIndexRootPolynomial, Polynomial.eval₂_sub, Polynomial.eval₂_mul,
    Polynomial.eval₂_pow, Polynomial.eval₂_X, Polynomial.eval₂_C]

private lemma singletonIndexRootPolynomial_eval_of_drift_root
    (d : ℕ) (j : Fin (d + 2)) {ν : ℝ}
    (hj : 1 ≤ j.val) (hν_pos : 0 < ν)
    (hroot :
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn ν = 0) :
    Polynomial.eval₂ (Int.castRingHom ℝ) ν (singletonIndexRootPolynomial d j) = 0 := by
  rw [singletonIndexRootPolynomial_eval_eq_factor]
  rw [singletonIndexRule_drift] at hroot
  have hk_pos : (0 : ℝ) < ((d + 1 : ℕ) : ℝ) := by positivity
  have hinner :
      ((Nat.choose (d + 1) j.val : ℕ) : ℝ) * ν ^ j.val *
          (1 - ν) ^ (d + 1 - j.val) - ν = 0 :=
    (mul_eq_zero.mp hroot).resolve_left hk_pos.ne'
  have hpow : ν ^ j.val = ν ^ (j.val - 1) * ν := by
    calc
      ν ^ j.val = ν ^ (j.val - 1 + 1) := by congr 1; omega
      _ = ν ^ (j.val - 1) * ν := by rw [pow_succ]
  have hrewrite :
      ((Nat.choose (d + 1) j.val : ℕ) : ℝ) * ν ^ j.val *
          (1 - ν) ^ (d + 1 - j.val) - ν =
        (((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
          ν ^ (j.val - 1) * (1 - ν) ^ (d + 1 - j.val) - 1) * ν := by
    rw [hpow]
    ring
  rw [hrewrite] at hinner
  exact (mul_eq_zero.mp hinner).resolve_right hν_pos.ne'

private lemma singletonIndex_drift_pos_of_factor_gt_one
    (d : ℕ) (j : Fin (d + 2)) {y : ℝ}
    (hj : 1 ≤ j.val) (hy : 0 < y)
    (hfactor :
      1 < ((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
        y ^ (j.val - 1) * (1 - y) ^ (d + 1 - j.val)) :
    0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y := by
  rw [singletonIndexRule_drift]
  have hk_pos : (0 : ℝ) < ((d + 1 : ℕ) : ℝ) := by positivity
  have hpow : y ^ j.val = y ^ (j.val - 1) * y := by
    calc
      y ^ j.val = y ^ (j.val - 1 + 1) := by congr 1; omega
      _ = y ^ (j.val - 1) * y := by rw [pow_succ]
  have hrewrite :
      ((Nat.choose (d + 1) j.val : ℕ) : ℝ) * y ^ j.val *
          (1 - y) ^ (d + 1 - j.val) - y =
        (((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
          y ^ (j.val - 1) * (1 - y) ^ (d + 1 - j.val) - 1) * y := by
    rw [hpow]
    ring
  rw [hrewrite]
  exact mul_pos hk_pos (mul_pos (sub_pos.mpr hfactor) hy)

private lemma singletonIndex_drift_neg_of_factor_lt_one
    (d : ℕ) (j : Fin (d + 2)) {y : ℝ}
    (hj : 1 ≤ j.val) (hy : 0 < y)
    (hfactor :
      ((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
        y ^ (j.val - 1) * (1 - y) ^ (d + 1 - j.val) < 1) :
    (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y < 0 := by
  rw [singletonIndexRule_drift]
  have hk_pos : (0 : ℝ) < ((d + 1 : ℕ) : ℝ) := by positivity
  have hpow : y ^ j.val = y ^ (j.val - 1) * y := by
    calc
      y ^ j.val = y ^ (j.val - 1 + 1) := by congr 1; omega
      _ = y ^ (j.val - 1) * y := by rw [pow_succ]
  have hrewrite :
      ((Nat.choose (d + 1) j.val : ℕ) : ℝ) * y ^ j.val *
          (1 - y) ^ (d + 1 - j.val) - y =
        (((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
          y ^ (j.val - 1) * (1 - y) ^ (d + 1 - j.val) - 1) * y := by
    rw [hpow]
    ring
  rw [hrewrite]
  exact mul_neg_of_pos_of_neg hk_pos (mul_neg_of_neg_of_pos (sub_neg.mpr hfactor) hy)

private lemma one_sub_nat_mul_le_pow_one_sub {x : ℝ} (_hx0 : 0 ≤ x) (hx1 : x ≤ 1) :
    ∀ n : ℕ, 1 - (n : ℝ) * x ≤ (1 - x) ^ n := by
  intro n
  induction n with
  | zero => simp
  | succ n ih =>
      have hnon : 0 ≤ 1 - x := sub_nonneg.mpr hx1
      have hnsq : 0 ≤ (n : ℝ) * x ^ 2 := mul_nonneg (Nat.cast_nonneg n) (sq_nonneg x)
      calc
        1 - ((n + 1 : ℕ) : ℝ) * x ≤ (1 - (n : ℝ) * x) * (1 - x) := by
          rw [Nat.cast_add, Nat.cast_one]
          ring_nf
          nlinarith [hnsq]
        _ ≤ (1 - x) ^ n * (1 - x) := mul_le_mul_of_nonneg_right ih hnon
        _ = (1 - x) ^ (n + 1) := by rw [pow_succ]

private lemma singletonOne_factor_gt_one_at_inv_square (d : ℕ) (hd : 0 < d) :
    1 < ((d + 1 : ℕ) : ℝ) *
      (1 - 1 / (((d + 1 : ℕ) : ℝ) ^ 2)) ^ d := by
  set N : ℝ := ((d + 1 : ℕ) : ℝ)
  have hNpos : 0 < N := by positivity
  have hNge1 : 1 ≤ N := by
    dsimp [N]
    exact_mod_cast (Nat.succ_le_succ (Nat.zero_le d))
  have hx0 : 0 ≤ (1 : ℝ) / N ^ 2 := by positivity
  have hx1 : (1 : ℝ) / N ^ 2 ≤ 1 := by
    rw [div_le_one (sq_pos_of_pos hNpos)]
    nlinarith
  have hpow := one_sub_nat_mul_le_pow_one_sub (x := (1 : ℝ) / N ^ 2) hx0 hx1 d
  have hmul := mul_le_mul_of_nonneg_left hpow (le_of_lt hNpos)
  have hbase : 1 < N * (1 - (d : ℝ) * (1 / N ^ 2)) := by
    have hNne : N ≠ 0 := ne_of_gt hNpos
    field_simp [hNne]
    dsimp [N]
    norm_num
    nlinarith [show (0 : ℝ) < d by exact_mod_cast hd]
  exact lt_of_lt_of_le hbase hmul

private noncomputable def singletonOneRootPolynomial (d : ℕ) : Polynomial ℤ :=
  Polynomial.C ((d + 1 : ℕ) : ℤ) *
    (Polynomial.C (1 : ℤ) - Polynomial.X) ^ d -
  Polynomial.C (1 : ℤ)

private lemma singletonOneRootPolynomial_natDegree (d : ℕ) (hd : 0 < d) :
    (singletonOneRootPolynomial d).natDegree = d := by
  have hC_ne : (Polynomial.C ((d + 1 : ℕ) : ℤ) : Polynomial ℤ) ≠ 0 := by
    intro h
    exact (Int.ofNat_ne_zero.mpr (Nat.succ_ne_zero d)) (Polynomial.C_eq_zero.mp h)
  have hbase_deg :
      (Polynomial.C (1 : ℤ) - Polynomial.X).natDegree = 1 := by
    rw [Polynomial.natDegree_sub, Polynomial.natDegree_X_sub_C]
  have hbase_ne : (Polynomial.C (1 : ℤ) - Polynomial.X : Polynomial ℤ) ≠ 0 := by
    intro h
    have hdeg := congrArg Polynomial.natDegree h
    rw [hbase_deg, Polynomial.natDegree_zero] at hdeg
    norm_num at hdeg
  have hmain_deg :
      (Polynomial.C ((d + 1 : ℕ) : ℤ) *
        (Polynomial.C (1 : ℤ) - Polynomial.X) ^ d).natDegree = d := by
    rw [Polynomial.natDegree_mul hC_ne (pow_ne_zero _ hbase_ne), Polynomial.natDegree_C,
      Polynomial.natDegree_pow, hbase_deg, mul_one]
    omega
  unfold singletonOneRootPolynomial
  rw [Polynomial.natDegree_sub_eq_left_of_natDegree_lt]
  · exact hmain_deg
  · rw [hmain_deg, Polynomial.natDegree_C]
    omega

private lemma singletonOneRootPolynomial_coeff_zero (d : ℕ) :
    (singletonOneRootPolynomial d).coeff 0 = (d : ℤ) := by
  simp [singletonOneRootPolynomial, Polynomial.coeff_zero_eq_eval_zero]

private lemma singletonOneBase_leadingCoeff :
    (Polynomial.C (1 : ℤ) - Polynomial.X).leadingCoeff = -1 := by
  have h : (Polynomial.C (1 : ℤ) - Polynomial.X : Polynomial ℤ) =
      - (Polynomial.X - Polynomial.C 1) := by
    ring
  rw [h, Polynomial.leadingCoeff_neg, Polynomial.leadingCoeff_X_sub_C]

private lemma singletonOneBase_natDegree :
    (Polynomial.C (1 : ℤ) - Polynomial.X).natDegree = 1 := by
  rw [Polynomial.natDegree_sub, Polynomial.natDegree_X_sub_C]

private lemma singletonOneRootPolynomial_coeff_degree (d : ℕ) (hd : 0 < d) :
    (singletonOneRootPolynomial d).coeff d = ((d + 1 : ℕ) : ℤ) * (-1 : ℤ) ^ d := by
  rw [singletonOneRootPolynomial, Polynomial.coeff_sub,
    Polynomial.coeff_C_ne_zero (show d ≠ 0 by omega), sub_zero, Polynomial.coeff_C_mul]
  have hpow_deg : ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ d).natDegree = d := by
    rw [Polynomial.natDegree_pow, singletonOneBase_natDegree, mul_one]
  calc
    ↑(d + 1) * ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ d).coeff d
        = ↑(d + 1) * ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ d).leadingCoeff := by
          rw [Polynomial.leadingCoeff, hpow_deg]
    _ = ↑(d + 1) * (Polynomial.C (1 : ℤ) - Polynomial.X).leadingCoeff ^ d := by
          rw [Polynomial.leadingCoeff_pow]
    _ = ↑(d + 1) * (-1 : ℤ) ^ d := by rw [singletonOneBase_leadingCoeff]

private theorem singletonOneRootPolynomial_isPrimitive (d : ℕ) (hd : 0 < d) :
    (singletonOneRootPolynomial d).IsPrimitive := by
  intro r hdiv
  rcases hdiv with ⟨Q, hQ⟩
  have hrd : r ∣ (d : ℤ) := by
    refine ⟨Q.coeff 0, ?_⟩
    have hc : (singletonOneRootPolynomial d).coeff 0 = (Polynomial.C r * Q).coeff 0 := by
      rw [hQ]
    rw [singletonOneRootPolynomial_coeff_zero, Polynomial.coeff_C_mul] at hc
    simpa [mul_comm] using hc
  have hrd1_unit : r ∣ (((d + 1 : ℕ) : ℤ) * (-1 : ℤ) ^ d) := by
    refine ⟨Q.coeff d, ?_⟩
    have hc : (singletonOneRootPolynomial d).coeff d = (Polynomial.C r * Q).coeff d := by
      rw [hQ]
    rw [singletonOneRootPolynomial_coeff_degree d hd, Polynomial.coeff_C_mul] at hc
    simpa [mul_comm] using hc
  have hunit_pow : IsUnit ((-1 : ℤ) ^ d) := isUnit_neg_one.pow d
  have hrd1 : r ∣ (((d + 1 : ℕ) : ℤ)) :=
    (IsUnit.dvd_mul_right hunit_pow).mp hrd1_unit
  rcases hrd with ⟨a, ha⟩
  rcases hrd1 with ⟨b, hb⟩
  have h1 : r ∣ (1 : ℤ) := by
    refine ⟨b - a, ?_⟩
    rw [mul_sub, ← hb, ← ha]
    norm_num
  exact isUnit_iff_dvd_one.mpr h1

private lemma singletonOneRootPolynomial_eval_eq_factor (d : ℕ) (ν : ℝ) :
    Polynomial.eval₂ (Int.castRingHom ℝ) ν (singletonOneRootPolynomial d) =
      ((d + 1 : ℕ) : ℝ) * (1 - ν) ^ d - 1 := by
  simp [singletonOneRootPolynomial, Polynomial.eval₂_sub, Polynomial.eval₂_mul,
    Polynomial.eval₂_pow, Polynomial.eval₂_X, Polynomial.eval₂_C]

private lemma singletonOne_drift (d : ℕ) (y : ℝ) :
    (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨1, by omega⟩).driftFn y =
      ((d + 1 : ℕ) : ℝ) * y *
        (((d + 1 : ℕ) : ℝ) * (1 - y) ^ d - 1) := by
  rw [singletonIndexRule_drift]
  rw [Nat.choose_one_right]
  have hsub : d + 1 - 1 = d := by omega
  rw [hsub]
  ring_nf

private lemma singletonOneRootPolynomial_eval_of_drift_root
    (d : ℕ) {ν : ℝ} (hν_pos : 0 < ν)
    (hroot :
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨1, by omega⟩).driftFn ν = 0) :
    Polynomial.eval₂ (Int.castRingHom ℝ) ν (singletonOneRootPolynomial d) = 0 := by
  rw [singletonOneRootPolynomial_eval_eq_factor]
  rw [singletonOne_drift d] at hroot
  have hk_pos : (0 : ℝ) < ((d + 1 : ℕ) : ℝ) := by positivity
  have hprod_pos : (0 : ℝ) < ((d + 1 : ℕ) : ℝ) * ν := mul_pos hk_pos hν_pos
  exact (mul_eq_zero.mp hroot).resolve_left hprod_pos.ne'

private lemma singletonOneRootPolynomial_map_rat_eq_unit_mul_kummer (d : ℕ) :
    ∃ φ : Polynomial ℚ ≃ₐ[ℚ] Polynomial ℚ,
    (singletonOneRootPolynomial d).map (Int.castRingHom ℚ) =
      Polynomial.C (((d + 1 : ℕ) : ℚ)) *
        φ ((Polynomial.X : Polynomial ℚ) ^ d -
            Polynomial.C ((1 : ℚ) / (((d + 1 : ℕ) : ℚ)))) := by
  haveI : Invertible (1 : ℚ) := invertibleOne
  letI : Invertible (-1 : ℚ) := invertibleNeg (R := ℚ) 1
  set φ := Polynomial.algEquivCMulXAddC (-1 : ℚ) 1
  refine ⟨φ, ?_⟩
  simp only [singletonOneRootPolynomial, map_sub, map_mul, map_pow, map_one, Polynomial.map_C]
  conv_rhs => simp only [map_sub, map_pow]
  have hX : φ Polynomial.X = Polynomial.C (-1 : ℚ) * Polynomial.X + Polynomial.C 1 := by
    simp [φ, Polynomial.algEquivCMulXAddC_apply, Polynomial.aeval_X]
  have hC : φ (Polynomial.C ((1 : ℚ) / (((d + 1 : ℕ) : ℚ)))) =
      Polynomial.C ((1 : ℚ) / (((d + 1 : ℕ) : ℚ))) := by
    simp [φ]
  rw [hX, hC]
  have hlin : Polynomial.C (-1 : ℚ) * Polynomial.X + Polynomial.C 1 =
      Polynomial.C (1 : ℚ) - Polynomial.X := by
    rw [Polynomial.C_neg, Polynomial.C_1]
    ring
  rw [hlin]
  have hN : (((d + 1 : ℕ) : ℚ)) ≠ 0 := by positivity
  have hunit : Polynomial.C (((d + 1 : ℕ) : ℚ)) *
      Polynomial.C ((1 : ℚ) / (((d + 1 : ℕ) : ℚ))) = (1 : Polynomial ℚ) := by
    rw [← Polynomial.C_mul]
    field_simp [hN]
    simp
  rw [mul_sub, hunit]
  simp [singletonOneRootPolynomial, sub_eq_add_neg, Nat.cast_add, Nat.cast_one]

private theorem singletonOneRootPolynomial_map_rat_irreducible_of_kummer
    (d : ℕ) (hodd : Odd d)
    (hNP : ∀ p : ℕ, p.Prime → p ∣ d → ∀ b : ℚ,
      b ^ p ≠ (1 : ℚ) / (((d + 1 : ℕ) : ℚ))) :
    Irreducible ((singletonOneRootPolynomial d).map (Int.castRingHom ℚ)) := by
  obtain ⟨φ, hrel⟩ := singletonOneRootPolynomial_map_rat_eq_unit_mul_kummer d
  let f : Polynomial ℚ := (Polynomial.X : Polynomial ℚ) ^ d -
    Polynomial.C ((1 : ℚ) / (((d + 1 : ℕ) : ℚ)))
  have hbase : Irreducible f := by
    dsimp [f]
    exact X_pow_sub_C_irreducible_of_odd hodd hNP
  have hphi : Irreducible (φ f) :=
    (MulEquiv.irreducible_iff (f := φ.toMulEquiv)).mpr hbase
  rw [hrel]
  have hunit_scalar : IsUnit (Polynomial.C (((d + 1 : ℕ) : ℚ)) : Polynomial ℚ) := by
    apply Polynomial.isUnit_C.mpr
    exact isUnit_iff_ne_zero.mpr (by positivity : (((d + 1 : ℕ) : ℚ)) ≠ 0)
  rw [mul_comm]
  exact (irreducible_mul_isUnit hunit_scalar).mpr hphi

private theorem singletonOneRootPolynomial_irreducible_of_kummer
    (d : ℕ) (hd : 0 < d) (hodd : Odd d)
    (hNP : ∀ p : ℕ, p.Prime → p ∣ d → ∀ b : ℚ,
      b ^ p ≠ (1 : ℚ) / (((d + 1 : ℕ) : ℚ))) :
    Irreducible (singletonOneRootPolynomial d) := by
  exact (Polynomial.IsPrimitive.Int.irreducible_iff_irreducible_map_cast
    (singletonOneRootPolynomial_isPrimitive d hd)).mpr
    (singletonOneRootPolynomial_map_rat_irreducible_of_kummer d hodd hNP)

private lemma singletonIndex_drift_one_neg
    (d : ℕ) (j : Fin (d + 2)) (hj : j.val < d + 1) :
    (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn (1 : ℝ) < 0 := by
  rw [singletonIndexRule_drift]
  have hpow_pos : 0 < d + 1 - j.val := by omega
  rw [sub_self, zero_pow hpow_pos.ne']
  norm_num
  exact lt_of_lt_of_le (by norm_num : (-1 : ℝ) < 0) (Nat.cast_nonneg d)

private theorem singletonIndex_root_exists_and_computable_from_factor_gt_one
    (d : ℕ) (j : Fin (d + 2)) (q : ℚ)
    (hj1 : 1 ≤ j.val) (hjlt : j.val < d + 1)
    (hqpos : 0 < (q : ℝ)) (hq1 : (q : ℝ) < 1)
    (hfactor :
      1 < ((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
        (q : ℝ) ^ (j.val - 1) * (1 - (q : ℝ)) ^ (d + 1 - j.val)) :
    ∃ ν : ℝ,
      ν ∈ Set.Icc (0 : ℝ) 1 ∧ 0 < ν ∧
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn ν = 0 ∧
      ((q : ℝ) < ν ∧
        ∀ y, (q : ℝ) ≤ y → y < ν →
          0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y) ∧
      IsEhrenfestComputable ν := by
  have hq0 : 0 ≤ (q : ℝ) := le_of_lt hqpos
  have hq_pos :
      0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn (q : ℝ) :=
    singletonIndex_drift_pos_of_factor_gt_one d j hj1 hqpos hfactor
  have h1_neg :
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn (1 : ℝ) < 0 :=
    singletonIndex_drift_one_neg d j hjlt
  obtain ⟨ν, hν, hroot, hpos, hcomp⟩ :=
    root_exists_and_computable_from_rational_start
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j) q
      hq0 hq1 hq_pos h1_neg
  refine ⟨ν, ?_, lt_trans hqpos hν.1, hroot, ⟨hν.1, hpos⟩, hcomp⟩
  exact ⟨le_trans hq0 (le_of_lt hν.1), le_of_lt hν.2⟩

private theorem singletonOne_root_exists_and_computable
    (d : ℕ) (hd : 0 < d) :
    ∃ (ν : ℝ) (q : ℚ),
      ν ∈ Set.Icc (0 : ℝ) 1 ∧
      0 ≤ (q : ℝ) ∧ (q : ℝ) ≤ 1 ∧
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨1, by omega⟩).driftFn ν = 0 ∧
      (((q : ℝ) < ν ∧
          ∀ y, (q : ℝ) ≤ y → y < ν →
            0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨1, by omega⟩).driftFn y) ∨
       (ν < (q : ℝ) ∧
          ∀ y, ν < y → y ≤ (q : ℝ) →
            (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨1, by omega⟩).driftFn y < 0)) ∧
      IsEhrenfestComputable ν ∧
      Polynomial.eval₂ (Int.castRingHom ℝ) ν (singletonOneRootPolynomial d) = 0 := by
  let q : ℚ := 1 / (((d + 1 : ℕ) : ℚ) ^ 2)
  have hq_cast : (q : ℝ) = 1 / (((d + 1 : ℕ) : ℝ) ^ 2) := by
    simp [q]
  have hqpos : 0 < (q : ℝ) := by
    rw [hq_cast]
    positivity
  have hq1 : (q : ℝ) < 1 := by
    rw [hq_cast]
    have hN : (1 : ℝ) < ((d + 1 : ℕ) : ℝ) := by
      exact_mod_cast (Nat.succ_lt_succ hd)
    rw [div_lt_one (sq_pos_of_pos (lt_trans zero_lt_one hN))]
    nlinarith [sq_pos_of_pos (lt_trans zero_lt_one hN)]
  have hfactor :
      1 < ((Nat.choose (d + 1) (⟨1, by omega⟩ : Fin (d + 2)).val : ℕ) : ℝ) *
        (q : ℝ) ^ ((⟨1, by omega⟩ : Fin (d + 2)).val - 1) *
          (1 - (q : ℝ)) ^ (d + 1 - (⟨1, by omega⟩ : Fin (d + 2)).val) := by
    simpa [hq_cast, Nat.choose_one_right, Nat.cast_add, Nat.cast_one, div_eq_mul_inv]
      using singletonOne_factor_gt_one_at_inv_square d hd
  obtain ⟨ν, hν, hνpos, hroot, hmono, hcomp⟩ :=
    singletonIndex_root_exists_and_computable_from_factor_gt_one
      d ⟨1, by omega⟩ q (by norm_num) (by simp; omega) hqpos hq1 hfactor
  exact ⟨ν, q, hν, le_of_lt hqpos, le_of_lt hq1, hroot, Or.inl hmono, hcomp,
    singletonOneRootPolynomial_eval_of_drift_root d hνpos hroot⟩

private lemma singletonIndexRootPolynomial_natDegree
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val) :
    (singletonIndexRootPolynomial d j).natDegree = d := by
  have hchoose_pos : 0 < Nat.choose (d + 1) j.val := Nat.choose_pos (by omega)
  have hC_ne : (Polynomial.C (Nat.choose (d + 1) j.val : ℤ) : Polynomial ℤ) ≠ 0 := by
    intro h
    exact (Int.ofNat_ne_zero.mpr hchoose_pos.ne') (Polynomial.C_eq_zero.mp h)
  have hbase_deg :
      (Polynomial.C (1 : ℤ) - Polynomial.X).natDegree = 1 := by
    rw [Polynomial.natDegree_sub, Polynomial.natDegree_X_sub_C]
  have hbase_ne : (Polynomial.C (1 : ℤ) - Polynomial.X : Polynomial ℤ) ≠ 0 := by
    intro h
    have hdeg := congrArg Polynomial.natDegree h
    rw [hbase_deg, Polynomial.natDegree_zero] at hdeg
    norm_num at hdeg
  have hbody_deg :
      (Polynomial.X ^ (j.val - 1) *
        (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d + 1 - j.val)).natDegree = d := by
    rw [Polynomial.natDegree_mul (pow_ne_zero _ Polynomial.X_ne_zero) (pow_ne_zero _ hbase_ne),
      Polynomial.natDegree_pow, Polynomial.natDegree_X, Polynomial.natDegree_pow, hbase_deg]
    omega
  have hmain_deg :
      (Polynomial.C (Nat.choose (d + 1) j.val : ℤ) *
        Polynomial.X ^ (j.val - 1) *
          (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d + 1 - j.val)).natDegree = d := by
    rw [mul_assoc, Polynomial.natDegree_mul hC_ne
      (mul_ne_zero (pow_ne_zero _ Polynomial.X_ne_zero) (pow_ne_zero _ hbase_ne)),
      Polynomial.natDegree_C, hbody_deg]
    omega
  unfold singletonIndexRootPolynomial
  rw [Polynomial.natDegree_sub_eq_left_of_natDegree_lt]
  · exact hmain_deg
  · rw [hmain_deg, Polynomial.natDegree_C]
    omega

private lemma singletonIndexRootPolynomial_coeff_zero
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val) :
    (singletonIndexRootPolynomial d j).coeff 0 = -1 := by
  simp [singletonIndexRootPolynomial, Polynomial.coeff_zero_eq_eval_zero,
    show j.val - 1 ≠ 0 by omega]

private lemma singletonIndexReciprocalPolynomial_natDegree
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val) :
    (singletonIndexReciprocalPolynomial d j).natDegree = d := by
  have hchoose_pos : 0 < Nat.choose (d + 1) j.val := by
    exact Nat.choose_pos (by omega)
  have hC_ne : (Polynomial.C (Nat.choose (d + 1) j.val : ℤ) : Polynomial ℤ) ≠ 0 := by
    intro h
    exact (Int.ofNat_ne_zero.mpr hchoose_pos.ne') (Polynomial.C_eq_zero.mp h)
  have hbase_deg :
      ((Polynomial.X : Polynomial ℤ) - 1).natDegree = 1 := by
    simpa using (Polynomial.natDegree_X_sub_C (R := ℤ) (x := (1 : ℤ)))
  have hbase_ne : ((Polynomial.X : Polynomial ℤ) - 1) ≠ 0 := by
    intro h
    have hdeg := congrArg Polynomial.natDegree h
    rw [hbase_deg, Polynomial.natDegree_zero] at hdeg
    norm_num at hdeg
  have hmain_deg :
      (Polynomial.C (Nat.choose (d + 1) j.val : ℤ) *
        ((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)).natDegree =
        d + 1 - j.val := by
    rw [Polynomial.natDegree_mul hC_ne (pow_ne_zero _ hbase_ne), Polynomial.natDegree_C,
      Polynomial.natDegree_pow, hbase_deg, mul_one]
    omega
  unfold singletonIndexReciprocalPolynomial
  rw [Polynomial.natDegree_sub_eq_left_of_natDegree_lt]
  · rw [Polynomial.natDegree_pow, Polynomial.natDegree_X, mul_one]
  · rw [hmain_deg, Polynomial.natDegree_pow, Polynomial.natDegree_X, mul_one]
    omega

private lemma singletonIndexReciprocalPolynomial_monic
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val) :
    (singletonIndexReciprocalPolynomial d j).Monic := by
  change (singletonIndexReciprocalPolynomial d j).leadingCoeff = 1
  rw [Polynomial.leadingCoeff, singletonIndexReciprocalPolynomial_natDegree d j hj]
  unfold singletonIndexReciprocalPolynomial
  rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow, if_pos rfl]
  have hchoose_pos : 0 < Nat.choose (d + 1) j.val := Nat.choose_pos (by omega)
  have hC_ne : (Polynomial.C (Nat.choose (d + 1) j.val : ℤ) : Polynomial ℤ) ≠ 0 := by
    intro h
    exact (Int.ofNat_ne_zero.mpr hchoose_pos.ne') (Polynomial.C_eq_zero.mp h)
  have hbase_deg :
      ((Polynomial.X : Polynomial ℤ) - 1).natDegree = 1 := by
    simpa using (Polynomial.natDegree_X_sub_C (R := ℤ) (x := (1 : ℤ)))
  have hbase_ne : ((Polynomial.X : Polynomial ℤ) - 1) ≠ 0 := by
    intro h
    have hdeg := congrArg Polynomial.natDegree h
    rw [hbase_deg, Polynomial.natDegree_zero] at hdeg
    norm_num at hdeg
  have hdeg :
      (Polynomial.C (Nat.choose (d + 1) j.val : ℤ) *
        ((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)).natDegree < d := by
    rw [Polynomial.natDegree_mul hC_ne (pow_ne_zero _ hbase_ne), Polynomial.natDegree_C,
      Polynomial.natDegree_pow, hbase_deg, mul_one]
    omega
  rw [Polynomial.coeff_eq_zero_of_natDegree_lt hdeg]
  ring

private lemma singletonIndexReciprocalPolynomial_coeff_dvd_choose
    (d : ℕ) (j : Fin (d + 2)) (n : ℕ) (hn : n < d) :
    (Nat.choose (d + 1) j.val : ℤ) ∣
      (singletonIndexReciprocalPolynomial d j).coeff n := by
  unfold singletonIndexReciprocalPolynomial
  rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow]
  rw [if_neg (show n ≠ d by omega), zero_sub, Polynomial.coeff_C_mul]
  exact dvd_neg.mpr
    ⟨(((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)).coeff n, rfl⟩

private lemma singletonIndexReciprocalPolynomial_coeff_zero
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val) :
    (singletonIndexReciprocalPolynomial d j).coeff 0 =
      - (Nat.choose (d + 1) j.val : ℤ) * (-1 : ℤ) ^ (d + 1 - j.val) := by
  unfold singletonIndexReciprocalPolynomial
  rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow, if_neg (show 0 ≠ d by omega),
    zero_sub, Polynomial.coeff_C_mul]
  rw [Polynomial.coeff_zero_eq_eval_zero]
  simp

private theorem singletonIndexReciprocalPolynomial_irreducible_of_eisenstein_data
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val)
    (𝓟 : Ideal ℤ) (hprime : 𝓟.IsPrime)
    (hmem : ∀ {n : ℕ}, n < d → (singletonIndexReciprocalPolynomial d j).coeff n ∈ 𝓟)
    (hnot : (singletonIndexReciprocalPolynomial d j).coeff 0 ∉ 𝓟 ^ 2) :
    Irreducible (singletonIndexReciprocalPolynomial d j) := by
  have hmon := singletonIndexReciprocalPolynomial_monic d j hj
  have hE : (singletonIndexReciprocalPolynomial d j).IsEisensteinAt 𝓟 :=
    hmon.isEisensteinAt_of_mem_of_notMem hprime.ne_top (by
      intro n hn
      exact hmem (by
        rw [singletonIndexReciprocalPolynomial_natDegree d j hj] at hn
        exact hn)) hnot
  exact hE.irreducible hprime hmon.isPrimitive (by
    rw [singletonIndexReciprocalPolynomial_natDegree d j hj]
    omega)

private theorem singletonIndexReciprocalPolynomial_irreducible_of_eisenstein_choose_mem
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val)
    (𝓟 : Ideal ℤ) (hprime : 𝓟.IsPrime)
    (hCmem : (Nat.choose (d + 1) j.val : ℤ) ∈ 𝓟)
    (hnot : (singletonIndexReciprocalPolynomial d j).coeff 0 ∉ 𝓟 ^ 2) :
    Irreducible (singletonIndexReciprocalPolynomial d j) := by
  apply singletonIndexReciprocalPolynomial_irreducible_of_eisenstein_data d j hj 𝓟 hprime
  · intro n hn
    obtain ⟨m, hm⟩ := singletonIndexReciprocalPolynomial_coeff_dvd_choose d j n hn
    rw [hm]
    exact 𝓟.mul_mem_right m hCmem
  · exact hnot

/-- Direct root polynomial for the focused singleton-two construction.

For `k=d+1`, `E={2}`, every nonzero drift root satisfies
`choose(d+1,2) * X * (1-X)^(d-1) - 1 = 0`. -/
private noncomputable def singletonTwoRootPolynomial (d : ℕ) : Polynomial ℤ :=
  Polynomial.C (Nat.choose (d + 1) 2 : ℤ) *
    Polynomial.X * (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1) -
  Polynomial.C (1 : ℤ)

private lemma singletonTwoRootPolynomial_natDegree (d : ℕ) (hd : 1 ≤ d) :
    (singletonTwoRootPolynomial d).natDegree = d := by
  have hchoose_pos : 0 < Nat.choose (d + 1) 2 := by
    exact Nat.choose_pos (by omega : 2 ≤ d + 1)
  have hC_ne : (Polynomial.C (Nat.choose (d + 1) 2 : ℤ) : Polynomial ℤ) ≠ 0 := by
    intro h
    exact (Int.ofNat_ne_zero.mpr hchoose_pos.ne') (Polynomial.C_eq_zero.mp h)
  have hbase_deg :
      (Polynomial.C (1 : ℤ) - Polynomial.X).natDegree = 1 := by
    rw [Polynomial.natDegree_sub, Polynomial.natDegree_X_sub_C]
  have hbase_ne : (Polynomial.C (1 : ℤ) - Polynomial.X : Polynomial ℤ) ≠ 0 := by
    intro h
    have hdeg := congrArg Polynomial.natDegree h
    rw [hbase_deg, Polynomial.natDegree_zero] at hdeg
    norm_num at hdeg
  have hbody_deg :
      (Polynomial.X * (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).natDegree = d := by
    rw [Polynomial.natDegree_mul Polynomial.X_ne_zero (pow_ne_zero _ hbase_ne),
      Polynomial.natDegree_X, Polynomial.natDegree_pow, hbase_deg]
    omega
  have hmain_deg :
      (Polynomial.C (Nat.choose (d + 1) 2 : ℤ) *
        Polynomial.X * (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).natDegree = d := by
    rw [mul_assoc, Polynomial.natDegree_mul hC_ne
      (mul_ne_zero Polynomial.X_ne_zero (pow_ne_zero _ hbase_ne)), Polynomial.natDegree_C, hbody_deg]
    omega
  unfold singletonTwoRootPolynomial
  rw [Polynomial.natDegree_sub_eq_left_of_natDegree_lt]
  · exact hmain_deg
  · rw [hmain_deg]
    rw [Polynomial.natDegree_C]
    omega

private lemma singletonTwoRootPolynomial_eval_eq_factor (d : ℕ) (ν : ℝ) :
    Polynomial.eval₂ (Int.castRingHom ℝ) ν (singletonTwoRootPolynomial d) =
      ((Nat.choose (d + 1) 2 : ℕ) : ℝ) * ν * (1 - ν) ^ (d - 1) - 1 := by
  simp [singletonTwoRootPolynomial, Polynomial.eval₂_sub, Polynomial.eval₂_mul,
    Polynomial.eval₂_pow, Polynomial.eval₂_X, Polynomial.eval₂_C]

private lemma singletonTwoRootPolynomial_coeff_zero (d : ℕ) :
    (singletonTwoRootPolynomial d).coeff 0 = -1 := by
  simp [singletonTwoRootPolynomial]

private lemma singletonTwoRootPolynomial_trailingCoeff (d : ℕ) :
    (singletonTwoRootPolynomial d).trailingCoeff = -1 := by
  rw [Polynomial.trailingCoeff_eq_coeff_zero]
  · exact singletonTwoRootPolynomial_coeff_zero d
  · rw [singletonTwoRootPolynomial_coeff_zero]
    norm_num

private lemma singletonTwoRootPolynomial_natTrailingDegree (d : ℕ) :
    (singletonTwoRootPolynomial d).natTrailingDegree = 0 := by
  rw [Polynomial.natTrailingDegree_eq_zero]
  right
  rw [singletonTwoRootPolynomial_coeff_zero]
  norm_num

private lemma singletonTwoRootPolynomial_coeff_pos_dvd_choose (d n : ℕ) (hn : 0 < n) :
    (Nat.choose (d + 1) 2 : ℤ) ∣ (singletonTwoRootPolynomial d).coeff n := by
  refine ⟨(Polynomial.X * (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).coeff n, ?_⟩
  rw [singletonTwoRootPolynomial]
  rw [mul_assoc]
  change
    (Polynomial.C (Nat.choose (d + 1) 2 : ℤ) *
          (Polynomial.X * (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)) -
        Polynomial.C (1 : ℤ)).coeff n =
      (Nat.choose (d + 1) 2 : ℤ) *
        (Polynomial.X * (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).coeff n
  rw [Polynomial.coeff_sub, Polynomial.coeff_C_mul]
  rw [Polynomial.coeff_C_ne_zero (a := (1 : ℤ)) (show n ≠ 0 by omega)]
  ring

private lemma singletonTwoBase_leadingCoeff :
    (Polynomial.C (1 : ℤ) - Polynomial.X).leadingCoeff = -1 := by
  have h :
      (Polynomial.C (1 : ℤ) - Polynomial.X : Polynomial ℤ) =
        - (Polynomial.X - Polynomial.C (1 : ℤ)) := by
    ring
  rw [h, Polynomial.leadingCoeff_neg, Polynomial.leadingCoeff_X_sub_C]

private lemma singletonTwoBase_natDegree :
    (Polynomial.C (1 : ℤ) - Polynomial.X).natDegree = 1 := by
  rw [Polynomial.natDegree_sub, Polynomial.natDegree_X_sub_C]

private lemma singletonTwoBase_pow_topCoeff (d : ℕ) (hodd : Odd d) :
    ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).coeff (d - 1) = 1 := by
  have hdeg :
      ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).natDegree = d - 1 := by
    rw [Polynomial.natDegree_pow, singletonTwoBase_natDegree, mul_one]
  calc
    ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).coeff (d - 1)
        = ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).leadingCoeff := by
          rw [Polynomial.leadingCoeff, hdeg]
    _ = (Polynomial.C (1 : ℤ) - Polynomial.X).leadingCoeff ^ (d - 1) := by
          rw [Polynomial.leadingCoeff_pow]
    _ = (-1 : ℤ) ^ (d - 1) := by rw [singletonTwoBase_leadingCoeff]
    _ = 1 := by
          obtain ⟨m, hm⟩ := hodd
          rw [hm]
          have hsub : 2 * m + 1 - 1 = 2 * m := by omega
          rw [hsub, show 2 * m = 2 * m from rfl, pow_mul]
          norm_num

private lemma singletonTwoBase_pow_eq_X_sub_one_pow (d : ℕ) (hodd : Odd d) :
    (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1) =
      ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1) := by
  have hbase :
      (Polynomial.C (1 : ℤ) - Polynomial.X : Polynomial ℤ) =
        - ((Polynomial.X : Polynomial ℤ) - 1) := by
    change (1 - Polynomial.X : Polynomial ℤ) = - (Polynomial.X - 1)
    ring
  have heven : Even (d - 1) := by
    obtain ⟨m, hm⟩ := hodd
    refine ⟨m, by omega⟩
  rw [hbase, heven.neg_pow]

private lemma singletonTwoRootPolynomial_coeff_pos_eq_closed
    (d n : ℕ) (hn : 0 < n) (hodd : Odd d) :
    (singletonTwoRootPolynomial d).coeff n =
      (Nat.choose (d + 1) 2 : ℤ) *
        (Polynomial.X * ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff n := by
  rw [singletonTwoRootPolynomial]
  rw [mul_assoc]
  change
    (Polynomial.C (Nat.choose (d + 1) 2 : ℤ) *
          (Polynomial.X * (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)) -
        Polynomial.C (1 : ℤ)).coeff n =
      (Nat.choose (d + 1) 2 : ℤ) *
        (Polynomial.X * ((Polynomial.X : Polynomial ℤ) - 1) ^ (d - 1)).coeff n
  rw [Polynomial.coeff_sub, Polynomial.coeff_C_mul]
  rw [Polynomial.coeff_C_ne_zero (a := (1 : ℤ)) (show n ≠ 0 by omega)]
  rw [singletonTwoBase_pow_eq_X_sub_one_pow d hodd]
  ring

private lemma singletonTwoRootPolynomial_leadingCoeff
    (d : ℕ) (hd : 1 ≤ d) (hodd : Odd d) :
    (singletonTwoRootPolynomial d).leadingCoeff = (Nat.choose (d + 1) 2 : ℤ) := by
  rw [Polynomial.leadingCoeff, singletonTwoRootPolynomial_natDegree d hd]
  rw [singletonTwoRootPolynomial, mul_assoc, Polynomial.coeff_sub,
    Polynomial.coeff_C_ne_zero (a := (1 : ℤ)) (show d ≠ 0 by omega),
    Polynomial.coeff_C_mul]
  have hd_eq : d = (d - 1) + 1 := by omega
  have hcoeff :
      (Polynomial.X * (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).coeff d = 1 := by
    conv_lhs => rw [hd_eq]
    rw [Polynomial.coeff_X_mul]
    change ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d - 1)).coeff (d - 1) = 1
    exact singletonTwoBase_pow_topCoeff d hodd
  rw [hcoeff]
  ring

/-- Drift formula for the focused exceptional construction `k=d+1`, `E={2}`. -/
private lemma singletonTwo_drift (d : ℕ) (hd : 1 ≤ d) (y : ℝ) :
    (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨2, by omega⟩).driftFn y =
      ((d + 1 : ℕ) : ℝ) * y *
        (((Nat.choose (d + 1) 2 : ℕ) : ℝ) * y * (1 - y) ^ (d - 1) - 1) := by
  rw [singletonIndexRule_drift]
  have hpow : d + 1 - 2 = d - 1 := by omega
  rw [hpow]
  ring_nf

private lemma singletonTwoRootPolynomial_eval_of_drift_root
    (d : ℕ) (hd : 1 ≤ d) {ν : ℝ}
    (hν_pos : 0 < ν)
    (hroot :
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨2, by omega⟩).driftFn ν = 0) :
    Polynomial.eval₂ (Int.castRingHom ℝ) ν (singletonTwoRootPolynomial d) = 0 := by
  rw [singletonTwoRootPolynomial_eval_eq_factor]
  rw [singletonTwo_drift d hd] at hroot
  have hk_pos : (0 : ℝ) < ((d + 1 : ℕ) : ℝ) := by positivity
  have hprod_pos : (0 : ℝ) < ((d + 1 : ℕ) : ℝ) * ν := mul_pos hk_pos hν_pos
  exact (mul_eq_zero.mp hroot).resolve_left hprod_pos.ne'

private lemma isUnit_mirror_iff_int {P : Polynomial ℤ} :
    IsUnit P.mirror ↔ IsUnit P := by
  constructor
  · intro h
    rw [← P.mirror_mirror]
    obtain ⟨r, hr, hP⟩ := Polynomial.isUnit_iff.mp h
    rw [← hP, Polynomial.mirror_C]
    exact Polynomial.isUnit_C.mpr hr
  · intro h
    obtain ⟨r, hr, hP⟩ := Polynomial.isUnit_iff.mp h
    rw [← hP, Polynomial.mirror_C]
    exact Polynomial.isUnit_C.mpr hr

private lemma irreducible_of_irreducible_mirror_int {P : Polynomial ℤ}
    (hP : Irreducible P.mirror) : Irreducible P := by
  refine ⟨?_, ?_⟩
  · intro hunit
    exact hP.not_isUnit (isUnit_mirror_iff_int.mpr hunit)
  · intro A B hmul
    have hmirror : P.mirror = A.mirror * B.mirror := by
      rw [hmul, Polynomial.mirror_mul_of_domain]
    rcases hP.isUnit_or_isUnit hmirror with hA | hB
    · exact Or.inl (isUnit_mirror_iff_int.mp hA)
    · exact Or.inr (isUnit_mirror_iff_int.mp hB)

private lemma singletonIndex_one_sub_X_pow_reflect_coeff
    (e n : ℕ) (hn : n ≤ e) :
    ((Polynomial.C (1 : ℤ) - Polynomial.X) ^ e).coeff (e - n) =
      (((Polynomial.X : Polynomial ℤ) - 1) ^ e).coeff n := by
  have hbase :
      (Polynomial.C (1 : ℤ) - Polynomial.X : Polynomial ℤ) =
        - ((Polynomial.X : Polynomial ℤ) - 1) := by
    change (1 - Polynomial.X : Polynomial ℤ) = - (Polynomial.X - 1)
    ring
  rw [hbase, neg_pow]
  have hCpow :
      ((-1 : Polynomial ℤ) ^ e) = Polynomial.C ((-1 : ℤ) ^ e) := by
    simp
  rw [hCpow]
  rw [Polynomial.coeff_C_mul]
  change (-1 : ℤ) ^ e *
      ((((Polynomial.X : Polynomial ℤ) - 1) ^ e).coeff (e - n)) =
    (((Polynomial.X : Polynomial ℤ) - 1) ^ e).coeff n
  rw [show ((Polynomial.X : Polynomial ℤ) - 1) =
      Polynomial.X + Polynomial.C (-1 : ℤ) by simp [sub_eq_add_neg]]
  rw [Polynomial.coeff_X_add_C_pow, Polynomial.coeff_X_add_C_pow]
  rw [Nat.sub_sub_self hn, Nat.choose_symm hn]
  have hsign : (-1 : ℤ) ^ e * (-1) ^ n = (-1) ^ (e - n) := by
    have hsquare : (-1 : ℤ) ^ n * (-1) ^ n = 1 := by
      rw [← pow_add, show n + n = 2 * n by omega, pow_mul]
      norm_num
    calc
      (-1 : ℤ) ^ e * (-1) ^ n
          = ((-1 : ℤ) ^ (e - n) * (-1) ^ n) * (-1) ^ n := by
              conv_lhs =>
                rw [← Nat.sub_add_cancel hn, pow_add]
      _ = (-1 : ℤ) ^ (e - n) * ((-1) ^ n * (-1) ^ n) := by ring
      _ = (-1 : ℤ) ^ (e - n) := by rw [hsquare, mul_one]
  rw [← mul_assoc, hsign]

private lemma singletonIndexRootPolynomial_body_reflect_coeff
    (d : ℕ) (j : Fin (d + 2)) (n : ℕ) (hj : 2 ≤ j.val) :
    (Polynomial.X ^ (j.val - 1) *
        (Polynomial.C (1 : ℤ) - Polynomial.X) ^ (d + 1 - j.val)).coeff (d - n) =
      (((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)).coeff n := by
  by_cases hn : n ≤ d + 1 - j.val
  · have hidx : d - n = (d + 1 - j.val - n) + (j.val - 1) := by omega
    rw [hidx, Polynomial.coeff_X_pow_mul]
    exact singletonIndex_one_sub_X_pow_reflect_coeff (d + 1 - j.val) n hn
  · rw [Polynomial.coeff_X_pow_mul']
    have hlow : ¬ j.val - 1 ≤ d - n := by omega
    rw [if_neg hlow]
    have hdeg :
        (((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)).natDegree =
          d + 1 - j.val := by
      rw [Polynomial.natDegree_pow]
      have hbase :
          ((Polynomial.X : Polynomial ℤ) - 1).natDegree = 1 := by
        simpa using (Polynomial.natDegree_X_sub_C (R := ℤ) (x := (1 : ℤ)))
      rw [hbase, mul_one]
    rw [Polynomial.coeff_eq_zero_of_natDegree_lt]
    rw [hdeg]
    omega

private lemma singletonIndexRootPolynomial_natTrailingDegree
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val) :
    (singletonIndexRootPolynomial d j).natTrailingDegree = 0 := by
  rw [Polynomial.natTrailingDegree_eq_zero]
  right
  rw [singletonIndexRootPolynomial_coeff_zero d j hj]
  norm_num

private theorem singletonIndexReciprocalPolynomial_eq_neg_mirror_root
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val) :
    singletonIndexReciprocalPolynomial d j =
      - (singletonIndexRootPolynomial d j).mirror := by
  ext n
  by_cases hnlt : n < d
  · unfold singletonIndexReciprocalPolynomial
    rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow, if_neg (show n ≠ d by omega),
      zero_sub, Polynomial.coeff_C_mul]
    rw [Polynomial.coeff_neg, Polynomial.coeff_mirror,
      singletonIndexRootPolynomial_natDegree d j hj,
      singletonIndexRootPolynomial_natTrailingDegree d j hj]
    simp only [Nat.add_zero]
    rw [Polynomial.revAt_le (by omega : n ≤ d)]
    unfold singletonIndexRootPolynomial
    rw [mul_assoc]
    rw [Polynomial.coeff_sub, Polynomial.coeff_C_mul,
      Polynomial.coeff_C_ne_zero (a := (1 : ℤ)) (show d - n ≠ 0 by omega)]
    rw [singletonIndexRootPolynomial_body_reflect_coeff d j n hj]
    ring
  · have hdle : d ≤ n := le_of_not_gt hnlt
    rcases eq_or_lt_of_le hdle with hnd | hdlt
    · subst n
      unfold singletonIndexReciprocalPolynomial
      rw [Polynomial.coeff_sub, Polynomial.coeff_X_pow, if_pos rfl]
      have hchoose_pos : 0 < Nat.choose (d + 1) j.val := Nat.choose_pos (by omega)
      have hC_ne :
          (Polynomial.C (Nat.choose (d + 1) j.val : ℤ) : Polynomial ℤ) ≠ 0 := by
        intro h
        exact (Int.ofNat_ne_zero.mpr hchoose_pos.ne') (Polynomial.C_eq_zero.mp h)
      have hbase_deg :
          (((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)).natDegree =
            d + 1 - j.val := by
        rw [Polynomial.natDegree_pow]
        have hb : ((Polynomial.X : Polynomial ℤ) - 1).natDegree = 1 := by
          simpa using (Polynomial.natDegree_X_sub_C (R := ℤ) (x := (1 : ℤ)))
        rw [hb, mul_one]
      have hbase_ne : (((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)) ≠ 0 := by
        exact pow_ne_zero _ (Polynomial.X_sub_C_ne_zero (1 : ℤ))
      have hdeg :
          (Polynomial.C (Nat.choose (d + 1) j.val : ℤ) *
            ((Polynomial.X : Polynomial ℤ) - 1) ^ (d + 1 - j.val)).natDegree < d := by
        rw [Polynomial.natDegree_mul hC_ne hbase_ne, Polynomial.natDegree_C, hbase_deg]
        omega
      rw [Polynomial.coeff_eq_zero_of_natDegree_lt hdeg]
      rw [Polynomial.coeff_neg, Polynomial.coeff_mirror,
        singletonIndexRootPolynomial_natDegree d j hj,
        singletonIndexRootPolynomial_natTrailingDegree d j hj, Nat.add_zero,
        Polynomial.revAt_le (le_refl d)]
      rw [tsub_self, singletonIndexRootPolynomial_coeff_zero d j hj]
      ring
    · rw [Polynomial.coeff_eq_zero_of_natDegree_lt]
      · rw [Polynomial.coeff_neg, Polynomial.coeff_eq_zero_of_natDegree_lt]
        · simp
        · rwa [Polynomial.mirror_natDegree, singletonIndexRootPolynomial_natDegree d j hj]
      · rwa [singletonIndexReciprocalPolynomial_natDegree d j hj]

private theorem singletonIndexRootPolynomial_irreducible_of_reciprocal_mirror_eq
    (d : ℕ) (j : Fin (d + 2))
    (hmirror :
      singletonIndexReciprocalPolynomial d j =
        - (singletonIndexRootPolynomial d j).mirror)
    (hrec : Irreducible (singletonIndexReciprocalPolynomial d j)) :
    Irreducible (singletonIndexRootPolynomial d j) := by
  apply irreducible_of_irreducible_mirror_int
  have hneg : Irreducible (-(singletonIndexRootPolynomial d j).mirror) := by
    rwa [← hmirror]
  simpa using Associated.rfl.neg_right.irreducible hneg

private theorem singletonIndexRootPolynomial_irreducible_of_reciprocal
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val)
    (hrec : Irreducible (singletonIndexReciprocalPolynomial d j)) :
    Irreducible (singletonIndexRootPolynomial d j) :=
  singletonIndexRootPolynomial_irreducible_of_reciprocal_mirror_eq d j
    (singletonIndexReciprocalPolynomial_eq_neg_mirror_root d j hj) hrec

private theorem singletonIndexRootPolynomial_irreducible_of_eisenstein_choose_mem
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val)
    (𝓟 : Ideal ℤ) (hprime : 𝓟.IsPrime)
    (hCmem : (Nat.choose (d + 1) j.val : ℤ) ∈ 𝓟)
    (hnot : (singletonIndexReciprocalPolynomial d j).coeff 0 ∉ 𝓟 ^ 2) :
    Irreducible (singletonIndexRootPolynomial d j) :=
  singletonIndexRootPolynomial_irreducible_of_reciprocal d j hj
    (singletonIndexReciprocalPolynomial_irreducible_of_eisenstein_choose_mem
      d j hj 𝓟 hprime hCmem hnot)

private theorem singletonIndexRootPolynomial_irreducible_of_prime_dvd_choose_not_square_dvd
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val)
    (p : ℕ) (hp : p.Prime)
    (hpdvd : (p : ℤ) ∣ (Nat.choose (d + 1) j.val : ℤ))
    (hp2not : ¬ (p : ℤ) ^ 2 ∣ (Nat.choose (d + 1) j.val : ℤ)) :
    Irreducible (singletonIndexRootPolynomial d j) := by
  apply singletonIndexRootPolynomial_irreducible_of_eisenstein_choose_mem d j hj
    (Ideal.span ({(p : ℤ)} : Set ℤ))
  · exact (Ideal.span_singleton_prime (by exact_mod_cast hp.ne_zero)).mpr
      (Nat.prime_iff_prime_int.mp hp)
  · exact Ideal.mem_span_singleton.mpr hpdvd
  · intro hmem
    rw [singletonIndexReciprocalPolynomial_coeff_zero d j hj] at hmem
    have hunit : IsUnit (-((-1 : ℤ) ^ (d + 1 - j.val))) := by
      exact IsUnit.of_mul_eq_one (-((-1 : ℤ) ^ (d + 1 - j.val))) (by
        rw [neg_mul_neg, ← pow_two, ← pow_mul]
        norm_num)
    have hmemC : (Nat.choose (d + 1) j.val : ℤ) ∈
        Ideal.span ({(p : ℤ)} : Set ℤ) ^ 2 := by
      have hrewrite :
          - (Nat.choose (d + 1) j.val : ℤ) * (-1 : ℤ) ^ (d + 1 - j.val) =
            -((-1 : ℤ) ^ (d + 1 - j.val)) *
              (Nat.choose (d + 1) j.val : ℤ) := by ring
      rw [hrewrite] at hmem
      exact (Ideal.unit_mul_mem_iff_mem _ hunit).mp hmem
    apply hp2not
    have hmem' : (Nat.choose (d + 1) j.val : ℤ) ∈
        Ideal.span ({((p : ℤ) ^ 2)} : Set ℤ) := by
      simpa [Ideal.span_singleton_pow] using hmemC
    exact Ideal.mem_span_singleton.mp hmem'

private theorem singletonIndexRootPolynomial_irreducible_of_padicValNat_choose_eq_one
    (d : ℕ) (j : Fin (d + 2)) (hj : 2 ≤ j.val)
    (p : ℕ) (hp : p.Prime)
    (hval : padicValNat p (Nat.choose (d + 1) j.val) = 1) :
    Irreducible (singletonIndexRootPolynomial d j) := by
  haveI : Fact p.Prime := ⟨hp⟩
  have hchoose_pos : 0 < Nat.choose (d + 1) j.val := Nat.choose_pos (by omega)
  have hpdvd_nat : p ∣ Nat.choose (d + 1) j.val := by
    apply dvd_of_one_le_padicValNat
    rw [hval]
  have hpdvd_int : (p : ℤ) ∣ (Nat.choose (d + 1) j.val : ℤ) := by
    exact_mod_cast hpdvd_nat
  have hp2not_int : ¬ (p : ℤ) ^ 2 ∣ (Nat.choose (d + 1) j.val : ℤ) := by
    intro hsq_int
    have hsq_nat : p ^ 2 ∣ Nat.choose (d + 1) j.val := by
      exact_mod_cast hsq_int
    have hle : 2 ≤ padicValNat p (Nat.choose (d + 1) j.val) := by
      exact (padicValNat_dvd_iff_le hchoose_pos.ne').mp hsq_nat
    omega
  exact singletonIndexRootPolynomial_irreducible_of_prime_dvd_choose_not_square_dvd
    d j hj p hp hpdvd_int hp2not_int

private lemma prime_sq_not_dvd_mul_of_sq_not_dvd_left_of_not_dvd_right
    {p x y : ℕ} (hp : p.Prime)
    (hp2x : ¬ p ^ 2 ∣ x) (hpy : ¬ p ∣ y) :
    ¬ p ^ 2 ∣ x * y := by
  intro hp2xy
  have hcop_py : Nat.Coprime p y :=
    (hp.coprime_iff_not_dvd).mpr hpy
  have hcop_p2_y : Nat.Coprime (p ^ 2) y :=
    hcop_py.pow_left 2
  exact hp2x (hcop_p2_y.dvd_of_dvd_mul_right hp2xy)

private lemma prime_sq_not_dvd_mul_of_not_dvd_left_of_sq_not_dvd_right
    {p x y : ℕ} (hp : p.Prime)
    (hpx : ¬ p ∣ x) (hp2y : ¬ p ^ 2 ∣ y) :
    ¬ p ^ 2 ∣ x * y := by
  rw [mul_comm]
  exact prime_sq_not_dvd_mul_of_sq_not_dvd_left_of_not_dvd_right
    hp hp2y hpx

private lemma prime_sq_not_dvd_mul_three_of_sq_not_dvd_middle
    {p x y z : ℕ} (hp : p.Prime)
    (hpx : ¬ p ∣ x) (hp2y : ¬ p ^ 2 ∣ y) (hpz : ¬ p ∣ z) :
    ¬ p ^ 2 ∣ x * y * z := by
  rw [mul_assoc]
  apply prime_sq_not_dvd_mul_of_not_dvd_left_of_sq_not_dvd_right hp hpx
  exact prime_sq_not_dvd_mul_of_sq_not_dvd_left_of_not_dvd_right
    hp hp2y hpz

private lemma choose_six_mul_three (m : ℕ) :
    Nat.choose (6 * m) 3 = m * (6 * m - 1) * (6 * m - 2) := by
  rw [Nat.choose_eq_descFactorial_div_factorial]
  norm_num [Nat.descFactorial]
  have hmul :
      (6 * m - 2) * ((6 * m - 1) * (6 * m)) =
        6 * (m * (6 * m - 1) * (6 * m - 2)) := by
    cases m <;> ring_nf
  rw [hmul]
  rw [Nat.mul_div_cancel_left _ (by norm_num : 0 < 6)]

private lemma choose_six_mul_two (m : ℕ) :
    Nat.choose (6 * m) 2 = 3 * m * (6 * m - 1) := by
  rw [Nat.choose_eq_descFactorial_div_factorial]
  norm_num [Nat.descFactorial]
  have hmul :
      (6 * m - 1) * (6 * m) = 2 * (3 * m * (6 * m - 1)) := by
    cases m <;> ring_nf
  rw [hmul]
  rw [Nat.mul_div_cancel_left _ (by norm_num : 0 < 2)]

private lemma choose_succ_two_eq_mod_six_five_factorization
    (d : ℕ) (hmod : d % 6 = 5) :
    Nat.choose (d + 1) 2 = 3 * ((d + 1) / 6) * d := by
  let m := (d + 1) / 6
  have h6 : 6 ∣ d + 1 := by omega
  have hm : d + 1 = 6 * m := by
    rw [show 6 * m = m * 6 by rw [mul_comm]]
    exact (Nat.div_mul_cancel h6).symm
  have hd_eq : 6 * m - 1 = d := by omega
  calc
    Nat.choose (d + 1) 2 = Nat.choose (6 * m) 2 := by rw [hm]
    _ = 3 * m * (6 * m - 1) := choose_six_mul_two m
    _ = 3 * ((d + 1) / 6) * d := by
      rw [hd_eq]

private lemma choose_succ_three_eq_mod_six_five_factorization
    (d : ℕ) (hmod : d % 6 = 5) :
    Nat.choose (d + 1) 3 = ((d + 1) / 6) * d * (d - 1) := by
  let m := (d + 1) / 6
  have h6 : 6 ∣ d + 1 := by omega
  have hm : d + 1 = 6 * m := by
    rw [show 6 * m = m * 6 by rw [mul_comm]]
    exact (Nat.div_mul_cancel h6).symm
  have hd_eq : 6 * m - 1 = d := by omega
  have hdm_eq : 6 * m - 2 = d - 1 := by omega
  calc
    Nat.choose (d + 1) 3 = Nat.choose (6 * m) 3 := by rw [hm]
    _ = m * (6 * m - 1) * (6 * m - 2) := choose_six_mul_three m
    _ = ((d + 1) / 6) * d * (d - 1) := by
      rw [hd_eq, hdm_eq]

private lemma prime_sq_dvd_right_of_sq_dvd_mul_of_not_dvd_left
    {p x y : ℕ} (hp : p.Prime)
    (hpx : ¬ p ∣ x) (hp2xy : p ^ 2 ∣ x * y) :
    p ^ 2 ∣ y := by
  rw [mul_comm] at hp2xy
  have hcop_px : Nat.Coprime p x :=
    (hp.coprime_iff_not_dvd).mpr hpx
  have hcop_p2_x : Nat.Coprime (p ^ 2) x :=
    hcop_px.pow_left 2
  exact hcop_p2_x.dvd_of_dvd_mul_right hp2xy

private lemma prime_sq_dvd_middle_of_sq_dvd_mul_three_of_not_dvd_sides
    {p x y z : ℕ} (hp : p.Prime)
    (hpx : ¬ p ∣ x) (hpz : ¬ p ∣ z) (hp2xyz : p ^ 2 ∣ x * y * z) :
    p ^ 2 ∣ y := by
