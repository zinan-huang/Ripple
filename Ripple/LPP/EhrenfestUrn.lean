  have hp : p.Prime := hobs.1
  have hq : q.Prime := hobs.2.1
  rcases obstruction_descended_full_package hobs with
    ⟨c, t, _s, _C, _S, hc, hdesc, _hc_pow_two,
      _hC, _hS, _hCS, _h6c, _hcmod, _h4c, _h3qc,
