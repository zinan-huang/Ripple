    have hp_tail : p ∣ q ^ (m - 1) * D := by
      have hsub := Nat.dvd_sub hp_linear hp_head
      have hsub_eq :
          ((q + 1) * V + q ^ (m - 1) * D) -
            (q + 1) * V = q ^ (m - 1) * D := by
        omega
      rwa [hsub_eq] at hsub
    exact (hp.dvd_mul.mp hp_tail).resolve_left hp_not_qpow
  have hpD_iff : p ∣ D ↔ p ∣ q + 1 := by
    constructor
    · intro hpD
      by_contra hp_plus_not
      exact hpD_of_not_plus hp_plus_not hpD
    · exact hpD_of_plus
  have hDK : D = K := by
    have hfactor_pos : 0 < p ^ n * q ^ (m - 1) :=
      mul_pos (pow_pos hp.pos n) (pow_pos hq.pos (m - 1))
    apply Nat.mul_left_cancel hfactor_pos
    calc
      (p ^ n * q ^ (m - 1)) * D
          = p ^ n * (q ^ (m - 1) * D) := by ring
      _ = p ^ n * (U - V) := by rw [← hD]
      _ = c - t := hct_p.symm
      _ = q ^ (m - 1) * H := hct_q
      _ = q ^ (m - 1) * (p ^ n * K) := by rw [hK]
      _ = (p ^ n * q ^ (m - 1)) * K := by ring
  have hqD : ¬ q ∣ D := by
    intro hqD'
    rw [hDK] at hqD'
    exact hqK hqD'
  have hp_dvd_pn : p ∣ p ^ n := dvd_pow_self p hn_pos.ne'
  have hp_dvd_csub : p ∣ c - 1 := by
    rw [hc_p]
    exact dvd_mul_of_dvd_left hp_dvd_pn U
  have hp_dvd_tsub : p ∣ t - 1 := by
    rw [ht_p]
    exact dvd_mul_of_dvd_left hp_dvd_pn V
  have hp_not_qpow_m : ¬ p ∣ q ^ m := by
    intro hpqpow
    have hpq : p ∣ q := hp.dvd_of_dvd_pow hpqpow
    exact hp_ne_q ((Nat.prime_dvd_prime_iff_eq hp hq).mp hpq)
  have hp_not_qpow_pred : ¬ p ∣ q ^ (m - 1) := by
    intro hpqpow
    have hpq : p ∣ q := hp.dvd_of_dvd_pow hpqpow
    exact hp_ne_q ((Nat.prime_dvd_prime_iff_eq hp hq).mp hpq)
  have hpC : p ∣ C := by
    have hp_prod : p ∣ q ^ m * C := by rwa [← hc_q]
    exact (hp.dvd_mul.mp hp_prod).resolve_left hp_not_qpow_m
  have hpT : p ∣ T := by
    have hp_prod : p ∣ q ^ (m - 1) * T := by rwa [← ht_q]
    exact (hp.dvd_mul.mp hp_prod).resolve_left hp_not_qpow_pred
  have hpR : p ∣ R := by
    have hp_sum : p ∣ C + T := Nat.dvd_add hpC hpT
    have hp_qR : p ∣ q * R := by rwa [hR] at hp_sum
    have hp_not_q : ¬ p ∣ q := by
      intro hpq
      exact hp_ne_q ((Nat.prime_dvd_prime_iff_eq hp hq).mp hpq)
    exact (hp.dvd_mul.mp hp_qR).resolve_left hp_not_q
  exact ⟨c, t, n, U, V, m, C, T, R, H, D, K,
    hc, hdesc, ht_gt_one, ht_lt_c,
    hn_pos, hc_p, ht_p, hVU, hpU, hpV, hp_sum,
    hm_ge_two, hc_q, ht_q, hT_lt_qC, hqC, hqT,
    hR, hC_pos, hT_pos, hR_pos, hH, hH_pos,
    hct_p, hct_q, hD, hK, hD_pos, hK_pos, hU_eq, hqK,
    hp_linear, hpD_iff, hDK, hqD, hpC, hpT, hpR, hpnD_iff⟩

private lemma obstruction_not_p_dvd_q_sub_one_gap_exact_padic_quotient
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
        padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
          (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
          c < a ∧
          (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
          (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
        (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
        3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
        ((q ∣ a - 1 ∧
            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q)
    (hnot : ¬ p ∣ q - 1) :
    ∃ c t n U V m D E F L : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧
        0 < n ∧ c - 1 = p ^ n * U ∧ t - 1 = p ^ n * V ∧
        V < U ∧ ¬ p ∣ U ∧ ¬ p ∣ V ∧
        2 ≤ m ∧ 0 < D ∧ ¬ q ∣ D ∧
        U = V + q ^ (m - 1) * D ∧
        a - 1 = p ^ n * L ∧
        L = (q + 1) * V + q ^ (m - 1) * D + p ^ n * E ∧
        E = Nat.choose q 2 * V ^ 2 + U * q * V + p ^ n * F ∧
        p ^ (q * (n + 1) - 1 - n) ∣ L ∧
        E ≡ Nat.choose q 2 * V ^ 2 + U * q * V [MOD p] ∧
        F ≡ Nat.choose q 3 * V ^ 3 + U * Nat.choose q 2 * V ^ 2 [MOD p] := by
  have hp : p.Prime := hobs.1
  haveI : Fact p.Prime := ⟨hp⟩
  rcases obstruction_not_p_dvd_q_sub_one_gap_p_dvd_D_iff hobs hnot with
    ⟨c, t, n, U, V, m, C, T, R, H, D, K,
      hc, hdesc, ht_gt_one, ht_lt_c,
      hn_pos, hc_p, ht_p, hVU, hpU, hpV, _hp_sum,
      hm_ge_two, _hc_q, _ht_q, _hT_lt_qC, _hqC, _hqT,
      _hR, _hC_pos, _hT_pos, _hR_pos, _hH, _hH_pos,
      _hct_p, _hct_q, _hD, _hK, hD_pos, _hK_pos, hU_eq, _hqK,
      _hp_linear, _hpD_iff, _hDK, hqD, _hpC, _hpT, _hpR, _hpnD_iff⟩
  rcases obstruction_common_padic_exact_quotient_high_with_E_mod hobs with
    ⟨c₂, t₂, n₂, U₂, V₂, E, F, L,
      hc₂, hdesc₂, _ht₂_gt_one, _ht₂_lt_c,
      _hn₂_pos, hc₂_p, ht₂_p, _hV₂U₂, hpU₂, hpV₂,
      ha_L, hL, hE_eq, hM_L, hE_mod, hF_mod⟩
  have hc₂_pow_eq : c₂ ^ p = c ^ p := by
    rw [← hc₂, hc]
  have hc₂_eq_c : c₂ = c := Nat.pow_left_injective hp.ne_zero hc₂_pow_eq
  have ht₂_pow_eq : t₂ ^ q = t ^ q := by
    have hc_pos : 0 < c := by omega
    apply Nat.mul_left_cancel hc_pos
    calc
      c * t₂ ^ q = c₂ * t₂ ^ q := by rw [hc₂_eq_c]
      _ = a := hdesc₂.symm
      _ = c * t ^ q := hdesc
  have ht₂_eq_t : t₂ = t :=
    Nat.pow_left_injective hobs.2.1.ne_zero ht₂_pow_eq
  have hU_ne_zero : U ≠ 0 := by
    intro hU0
    exact hpU (by rw [hU0]; exact dvd_zero p)
  have hU₂_ne_zero : U₂ ≠ 0 := by
    intro hU0
    exact hpU₂ (by rw [hU0]; exact dvd_zero p)
  have hval_c : padicValNat p (c - 1) = n := by
    rw [hc_p, padicValNat.mul (pow_ne_zero n hp.ne_zero) hU_ne_zero,
      padicValNat.prime_pow, padicValNat.eq_zero_of_not_dvd hpU, add_zero]
  have hval_c₂ : padicValNat p (c - 1) = n₂ := by
    rw [← hc₂_eq_c, hc₂_p,
      padicValNat.mul (pow_ne_zero n₂ hp.ne_zero) hU₂_ne_zero,
      padicValNat.prime_pow, padicValNat.eq_zero_of_not_dvd hpU₂, add_zero]
  have hn₂_eq_n : n₂ = n := by
    rw [← hval_c, hval_c₂]
  have hU₂_eq_U : U₂ = U := by
    apply Nat.mul_left_cancel (pow_pos hp.pos n)
    calc
      p ^ n * U₂ = p ^ n₂ * U₂ := by rw [hn₂_eq_n]
      _ = c₂ - 1 := hc₂_p.symm
      _ = c - 1 := by rw [hc₂_eq_c]
      _ = p ^ n * U := hc_p
  have hV₂_eq_V : V₂ = V := by
    apply Nat.mul_left_cancel (pow_pos hp.pos n)
    calc
      p ^ n * V₂ = p ^ n₂ * V₂ := by rw [hn₂_eq_n]
      _ = t₂ - 1 := ht₂_p.symm
      _ = t - 1 := by rw [ht₂_eq_t]
      _ = p ^ n * V := ht_p
  have ha_L_aligned : a - 1 = p ^ n * L := by
    rw [← hn₂_eq_n]
    exact ha_L
  have hL_gap :
      L = (q + 1) * V + q ^ (m - 1) * D + p ^ n * E := by
    calc
      L = U₂ + q * V₂ + p ^ n₂ * E := hL
      _ = U + q * V + p ^ n * E := by rw [hU₂_eq_U, hV₂_eq_V, hn₂_eq_n]
      _ = (q + 1) * V + q ^ (m - 1) * D + p ^ n * E := by
        rw [hU_eq]
        ring
  have hM_L_aligned : p ^ (q * (n + 1) - 1 - n) ∣ L := by
    simpa [hn₂_eq_n] using hM_L
  have hE_mod_aligned :
      E ≡ Nat.choose q 2 * V ^ 2 + U * q * V [MOD p] := by
    simpa [hU₂_eq_U, hV₂_eq_V] using hE_mod
  have hE_eq_aligned :
      E = Nat.choose q 2 * V ^ 2 + U * q * V + p ^ n * F := by
    simpa [hU₂_eq_U, hV₂_eq_V, hn₂_eq_n] using hE_eq
  have hF_mod_aligned :
      F ≡ Nat.choose q 3 * V ^ 3 + U * Nat.choose q 2 * V ^ 2 [MOD p] := by
    simpa [hU₂_eq_U, hV₂_eq_V] using hF_mod
  exact ⟨c, t, n, U, V, m, D, E, F, L,
    hc, hdesc, ht_gt_one, ht_lt_c,
    hn_pos, hc_p, ht_p, hVU, hpU, hpV,
    hm_ge_two, hD_pos, hqD, hU_eq,
    ha_L_aligned, hL_gap, hE_eq_aligned, hM_L_aligned,
    hE_mod_aligned, hF_mod_aligned⟩

private lemma obstruction_not_p_dvd_q_sub_one_gap_exact_padic_next_quotient
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
        padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
          (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
          c < a ∧
          (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
          (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
        (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
        3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
        ((q ∣ a - 1 ∧
            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q)
    (hnot : ¬ p ∣ q - 1) :
    ∃ c t n U V m D E F L W : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧
        0 < n ∧ c - 1 = p ^ n * U ∧ t - 1 = p ^ n * V ∧
        V < U ∧ ¬ p ∣ U ∧ ¬ p ∣ V ∧
        2 ≤ m ∧ 0 < D ∧ ¬ q ∣ D ∧
        U = V + q ^ (m - 1) * D ∧
        a - 1 = p ^ n * L ∧
        L = (q + 1) * V + q ^ (m - 1) * D + p ^ n * E ∧
        E = Nat.choose q 2 * V ^ 2 + U * q * V + p ^ n * F ∧
        (q + 1) * V + q ^ (m - 1) * D = p ^ n * W ∧
        L = p ^ n * (W + E) ∧
        p ^ ((q * (n + 1) - 1 - n) - n) ∣ W + E ∧
        E ≡ Nat.choose q 2 * V ^ 2 + U * q * V [MOD p] ∧
        F ≡ Nat.choose q 3 * V ^ 3 + U * Nat.choose q 2 * V ^ 2 [MOD p] ∧
        W + E ≡ 0 [MOD p] := by
  have hp : p.Prime := hobs.1
  have hq : q.Prime := hobs.2.1
  rcases obstruction_not_p_dvd_q_sub_one_gap_exact_padic_quotient hobs hnot with
    ⟨c, t, n, U, V, m, D, E, F, L,
      hc, hdesc, ht_gt_one, ht_lt_c,
      hn_pos, hc_p, ht_p, hVU, hpU, hpV,
      hm_ge_two, hD_pos, hqD, hU_eq, ha_L, hL, hE_eq, hM_L, hE_mod, hF_mod⟩
  let A := (q + 1) * V + q ^ (m - 1) * D
  let M := q * (n + 1) - 1 - n
  have hn_le_M : n ≤ M := by
    have hmul_ge : 2 * (n + 1) ≤ q * (n + 1) :=
      Nat.mul_le_mul_right (n + 1) hq.two_le
    dsimp [M]
    omega
  have hpn_dvd_pM : p ^ n ∣ p ^ M :=
    pow_dvd_pow p hn_le_M
  have hpn_dvd_L : p ^ n ∣ L :=
    dvd_trans hpn_dvd_pM hM_L
  have hpn_dvd_tail : p ^ n ∣ p ^ n * E :=
    dvd_mul_right (p ^ n) E
  have hpn_dvd_A : p ^ n ∣ A := by
    have hsum : p ^ n ∣ A + p ^ n * E := by
      rwa [hL] at hpn_dvd_L
    have hsub := Nat.dvd_sub hsum hpn_dvd_tail
    have hsub_eq : (A + p ^ n * E) - p ^ n * E = A := by
      omega
    rwa [hsub_eq] at hsub
  rcases hpn_dvd_A with ⟨W, hW⟩
  have hL_W : L = p ^ n * (W + E) := by
    calc
      L = A + p ^ n * E := hL
      _ = p ^ n * W + p ^ n * E := by rw [hW]
      _ = p ^ n * (W + E) := by ring
  let N := M - n
  have hM_eq : M = n + N := by
    dsimp [N]
    omega
  have hM_factor : p ^ M = p ^ n * p ^ N := by
    rw [hM_eq, pow_add]
  have hN_dvd : p ^ N ∣ W + E := by
    have hdiv : p ^ n * p ^ N ∣ p ^ n * (W + E) := by
      rwa [← hM_factor, ← hL_W]
    exact (Nat.mul_dvd_mul_iff_left (pow_pos hp.pos n)).mp hdiv
  have hN_pos : 0 < N := by
    have hq_ge_two : 2 ≤ q := hq.two_le
    have hmul_ge : 2 * (n + 1) ≤ q * (n + 1) :=
      Nat.mul_le_mul_right (n + 1) hq_ge_two
    have hM_ge_succ : n + 1 ≤ M := by
      dsimp [M]
      omega
    have hM_gt_n : n < M := Nat.lt_of_lt_of_le (Nat.lt_succ_self n) hM_ge_succ
    dsimp [N]
    exact Nat.sub_pos_of_lt hM_gt_n
  have hp_dvd_WE : p ∣ W + E :=
    (dvd_pow_self p hN_pos.ne').trans hN_dvd
  have hWE_mod : W + E ≡ 0 [MOD p] :=
    Nat.modEq_zero_iff_dvd.mpr hp_dvd_WE
  exact ⟨c, t, n, U, V, m, D, E, F, L, W,
    hc, hdesc, ht_gt_one, ht_lt_c,
    hn_pos, hc_p, ht_p, hVU, hpU, hpV,
    hm_ge_two, hD_pos, hqD, hU_eq, ha_L, hL, hE_eq,
    hW, hL_W, by simpa [M, N] using hN_dvd, hE_mod, hF_mod, hWE_mod⟩

private lemma obstruction_not_p_dvd_q_sub_one_gap_exact_padic_next_quotient_mod
