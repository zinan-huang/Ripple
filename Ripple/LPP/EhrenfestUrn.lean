        3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
        ((q ∣ a - 1 ∧
            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q) :
    ∃ c t n U V E F L : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧
        0 < n ∧ c - 1 = p ^ n * U ∧ t - 1 = p ^ n * V ∧
        V < U ∧ ¬ p ∣ U ∧ ¬ p ∣ V ∧
        a - 1 = p ^ n * L ∧
        L = U + q * V + p ^ n * E ∧
        E = Nat.choose q 2 * V ^ 2 + U * q * V + p ^ n * F ∧
        p ^ (q * (n + 1) - 1 - n) ∣ L ∧
        E ≡ Nat.choose q 2 * V ^ 2 + U * q * V [MOD p] ∧
        F ≡ Nat.choose q 3 * V ^ 3 + U * Nat.choose q 2 * V ^ 2 [MOD p] := by
  rcases obstruction_common_padic_unit_quotients_ordered hobs with
    ⟨c, t, n, U, V, hc, hdesc, ht_gt_one, ht_lt_c,
      hn_pos, hc_eq, ht_eq, hVU, hpU, hpV⟩
  rcases hobs with
    ⟨hp, hq, _hpd, _hqd,
      hp_odd, _hq_odd, _hp_ne_three, _hq_ne_three,
      _hp5, _hq5, _hp_ne_q, _hp_lt_q,
      _h6a, hb_mod_six, hp_dvd_b, _hq_dvd_b, _hp_sq_dvd_b,
      _hcop_ab, _hp_not_dvd_a, _hq_not_dvd_a,
      _ha_mod_p, hp_val_eq, _hq_dvd_pval, _hp_pow_dvd_a_sub_one,
      _hp_big_pow_dvd_a_sub_one, _hc_branch,
      _hhalf_pow, _hthree_q_dvd_a, _hthree_pq_dvd_bq_succ,
      _hthree_pq_dvd_b_succ, _hq_side, _ha, _hb⟩
  haveI : Fact p.Prime := ⟨hp⟩
  have hc_mod_p : c % p = 1 :=
    succ_power_base_mod_exponent_eq_one hp hp_dvd_b hc
  have hb0 : b ≠ 0 := by
    intro hb0
    rw [hb0] at hb_mod_six
    norm_num at hb_mod_six
  have hbval :
      padicValNat p b = padicValNat p (c - 1) + 1 :=
    padicValNat_succ_power_base_sub_one hp hp_odd hb0 hc hc_mod_p
  have hU_ne_zero : U ≠ 0 := by
    intro hU0
    exact hpU (by rw [hU0]; exact dvd_zero p)
  have hval_c : padicValNat p (c - 1) = n := by
    rw [hc_eq, padicValNat.mul (pow_ne_zero n hp.ne_zero) hU_ne_zero,
      padicValNat.prime_pow, padicValNat.eq_zero_of_not_dvd hpU, add_zero]
  have hval_succ : padicValNat p (a - 1) + 1 = q * (n + 1) := by
    rw [hp_val_eq, hbval, hval_c]
  let P := p ^ n
  rcases exists_pow_one_add_eq_cubic_add_quartic (P * V) q with ⟨R, hR⟩
  have hc_form : c = 1 + P * U := by
    dsimp [P]
    omega
  have ht_form : t = 1 + P * V := by
    dsimp [P]
    omega
  have ht_pow :
      t ^ q = 1 + q * (P * V) + Nat.choose q 2 * (P * V) ^ 2 +
        Nat.choose q 3 * (P * V) ^ 3 + (P * V) ^ 4 * R := by
    rw [ht_form, hR]
  let Base := Nat.choose q 2 * V ^ 2 + U * q * V
  let Next := Nat.choose q 3 * V ^ 3 + U * Nat.choose q 2 * V ^ 2
  let Tail := V ^ 4 * R + U * Nat.choose q 3 * V ^ 3 + P * U * V ^ 4 * R
  let F := Next + P * Tail
  let E := Base + P * F
  let L := U + q * V + P * E
  have ha_sum : a = 1 + P * L := by
    dsimp [L, E, Base, F, Next, Tail]
    rw [hdesc, hc_form, ht_pow]
    ring
  have ha_L : a - 1 = P * L := by omega
  let A := q * (n + 1) - 1
  let M := A - n
  have hn_le_A : n ≤ A := by
    have hmul_ge : 2 * (n + 1) ≤ q * (n + 1) :=
      Nat.mul_le_mul_right (n + 1) hq.two_le
    dsimp [A]
    omega
  have hM_eq : n + M = A := by
    dsimp [M]
    omega
  have hval_exact : padicValNat p (a - 1) = A := by
    dsimp [A]
    omega
  have hhigh : p ^ (n + M) ∣ a - 1 := by
    apply (padicValNat_dvd_iff (n + M) (a - 1)).2
    exact Or.inr (by rw [hM_eq, hval_exact])
  have hhigh' : P * p ^ M ∣ a - 1 := by
    simpa [P, pow_add] using hhigh
  have hPM_L : P * p ^ M ∣ P * L := by
    rwa [ha_L] at hhigh'
  have hM_dvd_L : p ^ M ∣ L :=
    (Nat.mul_dvd_mul_iff_left (pow_pos hp.pos n)).mp hPM_L
  have hp_dvd_P : p ∣ P := by
    dsimp [P]
    exact dvd_pow_self p hn_pos.ne'
  have htail_zero : P * F ≡ 0 [MOD p] :=
    Nat.modEq_zero_iff_dvd.mpr (dvd_mul_of_dvd_left hp_dvd_P F)
  have hE_mod : E ≡ Base [MOD p] := by
    dsimp [E]
    simpa [add_zero] using
      Nat.ModEq.add (Nat.ModEq.refl Base) htail_zero
  have htail_F_zero : P * Tail ≡ 0 [MOD p] :=
    Nat.modEq_zero_iff_dvd.mpr (dvd_mul_of_dvd_left hp_dvd_P Tail)
  have hF_mod : F ≡ Next [MOD p] := by
    dsimp [F]
    simpa [add_zero] using
      Nat.ModEq.add (Nat.ModEq.refl Next) htail_F_zero
  exact ⟨c, t, n, U, V, E, F, L,
    hc, hdesc, ht_gt_one, ht_lt_c,
    hn_pos, hc_eq, ht_eq, hVU, hpU, hpV,
    ha_L, rfl, rfl, hM_dvd_L,
    by simpa [Base] using hE_mod,
    by simpa [Next] using hF_mod⟩

private lemma obstruction_common_padic_linear_congruence
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
        padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
          (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
          c < a ∧
          (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
          (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
        (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
        3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
        ((q ∣ a - 1 ∧
            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q) :
    ∃ c t n C T : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧
        0 < n ∧ c - 1 = p ^ n * C ∧ t - 1 = p ^ n * T ∧
        T < C ∧ ¬ p ∣ C ∧ ¬ p ∣ T ∧ p ∣ C + q * T := by
  rcases obstruction_common_padic_unit_quotients_ordered_high hobs with
    ⟨c, t, n, C, T, hc, hdesc, ht_gt_one, ht_lt_c,
      hn_pos, hc_eq, ht_eq, hTC, hpC, hpT, hhigh⟩
  rcases hobs with ⟨hp, _hq, _tail⟩
  have hc_gt_one : 1 < c := by omega
  have hlin : p ∣ C + q * T :=
    prime_dvd_linear_of_high_scaled_product hp hn_pos hc_gt_one ht_gt_one
      hc_eq ht_eq hdesc hhigh
  exact ⟨c, t, n, C, T, hc, hdesc, ht_gt_one, ht_lt_c,
    hn_pos, hc_eq, ht_eq, hTC, hpC, hpT, hlin⟩

private lemma obstruction_descended_full_padic_package
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
        padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
