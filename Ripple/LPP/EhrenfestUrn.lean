private lemma prime_pow_dvd_linear_of_deep_scaled_product
    {a c t p q n C T : ℕ} (hp : p.Prime)
    (hc_gt_one : 1 < c) (ht_gt_one : 1 < t)
    (hc_eq : c - 1 = p ^ n * C) (ht_eq : t - 1 = p ^ n * T)
    (hdesc : a = c * t ^ q) (hhigh : p ^ (2 * n) ∣ a - 1) :
    p ^ n ∣ C + q * T := by
  let P := p ^ n
  rcases exists_pow_one_add_eq_linear_add_sq (P * T) q with ⟨R, hR⟩
  have hc_form : c = 1 + P * C := by
    dsimp [P]
    omega
  have ht_form : t = 1 + P * T := by
    dsimp [P]
    omega
  have ht_pow : t ^ q = 1 + q * (P * T) + (P * T) ^ 2 * R := by
    rw [ht_form, hR]
  let Rest := (P * T) ^ 2 * R +
    (P * C) * (q * (P * T) + (P * T) ^ 2 * R)
  have ha_sum : a = 1 + (P * (C + q * T) + Rest) := by
    dsimp [Rest]
    rw [hdesc, hc_form, ht_pow]
    ring
  have ha_sub : a - 1 = P * (C + q * T) + Rest := by
    omega
  have hP2_high : P ^ 2 ∣ a - 1 := by
    simpa [P, pow_mul, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hhigh
  have hsq : P ^ 2 ∣ (P * T) ^ 2 := by
    refine ⟨T ^ 2, ?_⟩
    ring
  have hrest_left : P ^ 2 ∣ (P * T) ^ 2 * R :=
    dvd_mul_of_dvd_left hsq R
  have hcross : P ^ 2 ∣ (P * C) * (q * (P * T)) := by
    refine ⟨C * q * T, ?_⟩
    ring
  have hrest_right_sq : P ^ 2 ∣ (P * C) * ((P * T) ^ 2 * R) :=
    dvd_mul_of_dvd_right hrest_left (P * C)
  have hrest_right :
      P ^ 2 ∣ (P * C) * (q * (P * T) + (P * T) ^ 2 * R) := by
    rw [mul_add]
    exact dvd_add hcross hrest_right_sq
  have hrest : P ^ 2 ∣ Rest := by
    dsimp [Rest]
    exact dvd_add hrest_left hrest_right
  have htotal : P ^ 2 ∣ P * (C + q * T) + Rest := by
    rwa [← ha_sub]
  have hlinear : P ^ 2 ∣ P * (C + q * T) := by
    have hsub := Nat.dvd_sub htotal hrest
    have hsub_eq : (P * (C + q * T) + Rest) - Rest = P * (C + q * T) := by
      omega
    rwa [hsub_eq] at hsub
  have hlinear' : P * P ∣ P * (C + q * T) := by
    simpa [pow_two] using hlinear
  exact (Nat.mul_dvd_mul_iff_left (pow_pos hp.pos n)).mp hlinear'

private lemma obstruction_common_padic_unit_quotients_ordered_high
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
        padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
