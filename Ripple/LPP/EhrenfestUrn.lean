/-- The exceptional `d % 6 = 5` branch from a correctly indexed singleton rule. -/
theorem ehrenfest_all_algebraic_degrees_mod5_singletonIndex
    (d : ℕ) (hd : 3 ≤ d) (hodd : Odd d) (hmod : d % 6 = 5)
    (hW : SingletonIndexModFiveWitness) :
    ∃ ν : ℝ, IsEhrenfestComputable ν ∧
      ∃ P : Polynomial ℤ, P.natDegree = d ∧
      Polynomial.eval₂ (Int.castRingHom ℝ) ν P = 0 ∧ Irreducible P := by
  obtain ⟨j, ν, q, P, hj_pos, hj_lt, hν, hq0, hq1, hroot, hmono,
    hdeg, hP_root, hP_irr⟩ := hW d hd hodd hmod
  refine ⟨ν, ?_, P, hdeg, hP_root, hP_irr⟩
  exact ⟨singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j, (q : ℝ),
    ⟨hq0, hq1⟩, ⟨q, rfl⟩, hν, hroot, hmono⟩

/- Removed legacy threshold/Eisenstein branch.

The deleted branch depended on `ThresholdAlgebraicIdentity`, which asserted that
a threshold-rule root satisfies a degree-`d` Eisenstein polynomial.  That identity
is false as stated; the main theorem now routes the exceptional class through
the singleton construction and its explicit algebraic witness. -/

/-- For every non-exceptional degree `d % 6 ≠ 5`, there exists an
Ehrenfest-computable algebraic number of degree exactly `d` over `ℚ`.

This is the axiom-free Selmer branch of `ehrenfest_all_algebraic_degrees`.
The only remaining degree family is the exceptional congruence class
`d % 6 = 5`, where the previous threshold-polynomial shortcut was false. -/
theorem ehrenfest_all_algebraic_degrees_selmer_case (d : ℕ) (hd : 0 < d)
    (hmod : d % 6 ≠ 5) :
    ∃ ν : ℝ, IsEhrenfestComputable ν ∧
      ∃ P : Polynomial ℤ, P.natDegree = d ∧
      Polynomial.eval₂ (Int.castRingHom ℝ) ν P = 0 ∧ Irreducible P := by
  rcases d.even_or_odd with heven | hodd
  case inl =>
    have hd2 : 2 ≤ d := by obtain ⟨k, hk⟩ := heven; omega
    obtain ⟨ν, hν_mem, hν_root, _, hν_comp⟩ :=
      threshold_root_exists_and_computable d hd2 0 (by omega : 0 < d)
    refine ⟨ν, hν_comp, selmerShiftPoly d, selmerShiftPoly_natDegree d hd, ?_,
      selmerShiftPoly_irreducible d hd2 heven⟩
    exact selmerShiftPoly_eval_root d hd2 ν hν_root hν_mem.1
  case inr =>
    rcases Nat.lt_or_ge d 2 with hd1 | hd3
    · have hd_eq : d = 1 := by omega
      subst hd_eq
      refine ⟨1/2, half_computable, Polynomial.C 2 * Polynomial.X + Polynomial.C (-1), ?_, ?_, ?_⟩
      · rw [Polynomial.natDegree_add_C, Polynomial.natDegree_C_mul_X _ (by norm_num : (2:ℤ) ≠ 0)]
      · simp [Polynomial.eval₂_add, Polynomial.eval₂_mul, Polynomial.eval₂_X,
          Polynomial.eval₂_C]
      · apply Polynomial.irreducible_C_mul_X_add_C (by norm_num : (2:ℤ) ≠ 0)
        exact (IsUnit.of_mul_eq_one ((-1 : ℤ)) (by norm_num : (-1 : ℤ) * (-1) = 1)).isRelPrime_right
    · have hd3' : 3 ≤ d := by
        have hd2le : 2 ≤ d := hd3
        rcases hodd with ⟨m, hm⟩
        omega
      have hd2 : 2 ≤ d := by omega
      obtain ⟨ν, hν_mem, hν_root, _, hν_comp⟩ :=
        threshold_root_exists_and_computable d hd2 0 (by omega : 0 < d)
      refine ⟨ν, hν_comp, selmerShiftPoly d, selmerShiftPoly_natDegree d hd, ?_,
        selmerShiftPoly_irreducible_odd d hd3' hodd hmod⟩
      exact selmerShiftPoly_eval_root d hd2 ν hν_root hν_mem.1


/-- Full algebraic-degree theorem with the corrected singleton-index construction
for the exceptional class.

This theorem does not depend on the legacy false threshold identity.  The only
remaining input is the explicit singleton-index construction witness in the
class `d % 6 = 5`. -/
theorem ehrenfest_all_algebraic_degrees_singleton_mod5
    (d : ℕ) (hd : 0 < d)
    (hW : SingletonIndexModFiveWitness) :
    ∃ ν : ℝ, IsEhrenfestComputable ν ∧
      ∃ P : Polynomial ℤ, P.natDegree = d ∧
      Polynomial.eval₂ (Int.castRingHom ℝ) ν P = 0 ∧ Irreducible P := by
  by_cases hmod : d % 6 = 5
  · have hd3 : 3 ≤ d := by omega
    have hodd : Odd d := by
      rcases d.even_or_odd with heven | hodd
      · obtain ⟨m, hm⟩ := heven
        omega
      · exact hodd
    exact ehrenfest_all_algebraic_degrees_mod5_singletonIndex d hd3 hodd hmod hW
  · exact ehrenfest_all_algebraic_degrees_selmer_case d hd hmod

/-- For every degree d ≥ 1, there exists an Ehrenfest-computable algebraic
number of degree exactly d over ℚ, assuming the remaining pure algebraic
witness for the singleton construction in the exceptional congruence class.

Construction:
- d = 1: ν = 1/2, P = 2X - 1.
- d even, d ≥ 2: E = {0}, k = d. Root satisfies (1-ν)^d = ν.
  Polynomial: (1-X)^d - X, irreducible by Selmer + translation.
- d odd, d ≥ 3, d % 6 ≠ 5: same as even case
  (`selmerShiftPoly` + `X^d+X-1` irreducibility).
- d odd, d ≡ 5 mod 6: singleton-index branch, with the remaining exact-degree
  construction witness stated as `SingletonIndexModFiveWitness`.

The previous version of this theorem used `ThresholdAlgebraicIdentity`; that
identity is false as stated and is intentionally not consumed here. -/
theorem ehrenfest_all_algebraic_degrees (d : ℕ) (hd : 0 < d)
    (hW : SingletonIndexModFiveWitness) :
    ∃ ν : ℝ, IsEhrenfestComputable ν ∧
      ∃ P : Polynomial ℤ, P.natDegree = d ∧
      Polynomial.eval₂ (Int.castRingHom ℝ) ν P = 0 ∧ Irreducible P := by
  exact ehrenfest_all_algebraic_degrees_singleton_mod5 d hd hW

/-- Full all-degree theorem assuming the `j=3` squarefull obstruction is
impossible in the exceptional congruence class.

This is a narrower arithmetic assumption than the older Cassels/Mihăilescu
entries, but it is still an assumption: the remaining work is to prove the
squarefull-obstruction impossibility theorem. -/
theorem ehrenfest_all_algebraic_degrees_choose_three_no_squarefull_obstruction
    (d : ℕ) (hd : 0 < d)
    (hV : ∀ (d : ℕ), 53 ≤ d → d % 6 = 5 →
      ¬ (SquarefullNat d ∧
        OddSquarefullNat ((d + 1) / 6) ∧
        OddSquarefullNat (d - 1))) :
    ∃ ν : ℝ, IsEhrenfestComputable ν ∧
      ∃ P : Polynomial ℤ, P.natDegree = d ∧
      Polynomial.eval₂ (Int.castRingHom ℝ) ν P = 0 ∧ Irreducible P := by
  exact ehrenfest_all_algebraic_degrees d hd
    (singletonIndexModFiveWitness_of_no_choose_three_squarefull_obstruction hV)

