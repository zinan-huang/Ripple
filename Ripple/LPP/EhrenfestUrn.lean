    (hW : CatalanDoubleWieferichCriterionNat)
    (hBound : CatalanExponentBoundNat) :
    NoLowerPrimeDivisorCyclotomicBranchNat := by
  intro x y p q hx hy hp hq hp5 hq5 hpq _hq_dvd_y hpow hcyc
