          (q : ℝ) ^ (j.val - 1) * (1 - (q : ℝ)) ^ (d + 1 - j.val) ∧
        p.Prime ∧ p ∣ Nat.choose (d + 1) j.val ∧ d + 1 < p ^ 2) :
    SingletonIndexModFiveWitness := by
  apply singletonIndexModFiveWitness_of_padic_factor_data
  intro d hd hodd hmod
  obtain ⟨j, q, p, hj2, hjlt, hqpos, hq1, hfactor, hp, hpdvd, hp2⟩ :=
    hD d hd hodd hmod
  exact ⟨j, q, p, hj2, hjlt, hqpos, hq1, hfactor, hp,
    padicValNat_choose_eq_one_of_prime_dvd_of_lt_square
      (by omega : j.val ≤ d + 1) hp hpdvd hp2⟩

