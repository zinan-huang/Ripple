        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
          (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
          c < a ∧
          (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
          (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
        (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
        3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
        ((q ∣ a - 1 ∧
            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q) :
    ∃ c t : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧
        padicValNat p (t - 1) = padicValNat p (c - 1) := by
  rcases obstruction_padicVal_descended_quotient_sub_one_eq_base_sub_one hobs with
    ⟨c, t, hc, hdesc, ht_gt_one, ht_lt_c, htq_val⟩
  rcases hobs with
    ⟨hp, hq, _hpd, _hqd,
      hp_odd, _hq_odd, _hp_ne_three, _hq_ne_three,
      _hp5, _hq5, hp_ne_q, hp_lt_q,
      _h6a, _hb_mod_six, hp_dvd_b, _hq_dvd_b, _hp_sq_dvd_b,
      _hcop_ab, _hp_not_dvd_a, _hq_not_dvd_a,
      ha_mod_p, _hp_val_eq, _hq_dvd_pval, _hp_pow_dvd_a_sub_one,
      _hp_big_pow_dvd_a_sub_one, _hc_branch,
      _hhalf_pow, _hthree_q_dvd_a, _hthree_pq_dvd_bq_succ,
      _hthree_pq_dvd_b_succ, _hq_side, _ha, _hb⟩
  have hc_mod_p : c % p = 1 :=
    succ_power_base_mod_exponent_eq_one hp hp_dvd_b hc
  have hp_dvd_t_sub_one : p ∣ t - 1 :=
    p_dvd_descended_t_sub_one_of_mods hp hq hp_lt_q ha_mod_p hc_mod_p hdesc
  have htq_val_t :
      padicValNat p (t ^ q - 1) = padicValNat p (t - 1) :=
    padicValNat_pow_sub_one_eq_of_prime_ne
      hp hp_odd hq hp_ne_q ht_gt_one hp_dvd_t_sub_one
  exact ⟨c, t, hc, hdesc, ht_gt_one, ht_lt_c, by
    rw [← htq_val_t]
    exact htq_val⟩

private lemma exists_common_padic_unit_quotients
    {c t p : ℕ} (hp : p.Prime)
    (hc_sub_ne_zero : c - 1 ≠ 0) (ht_sub_ne_zero : t - 1 ≠ 0)
    (hp_dvd_c_sub_one : p ∣ c - 1)
    (hval_eq : padicValNat p (t - 1) = padicValNat p (c - 1)) :
    ∃ n C T : ℕ,
      0 < n ∧ c - 1 = p ^ n * C ∧ t - 1 = p ^ n * T ∧
        ¬ p ∣ C ∧ ¬ p ∣ T := by
  haveI : Fact p.Prime := ⟨hp⟩
  let n := padicValNat p (c - 1)
  let C := (c - 1) / p ^ n
  let T := (t - 1) / p ^ n
  have hn_pos : 0 < n := by
    dsimp [n]
    exact one_le_padicValNat_of_dvd hc_sub_ne_zero hp_dvd_c_sub_one
  have hc_dvd : p ^ n ∣ c - 1 := by
    dsimp [n]
    exact pow_padicValNat_dvd
  have ht_dvd : p ^ n ∣ t - 1 := by
    apply (padicValNat_dvd_iff n (t - 1)).2
    right
    dsimp [n]
    omega
  have hc_eq : c - 1 = p ^ n * C := by
    dsimp [C]
    rw [mul_comm]
    exact (Nat.div_mul_cancel hc_dvd).symm
  have ht_eq : t - 1 = p ^ n * T := by
    dsimp [T]
    rw [mul_comm]
    exact (Nat.div_mul_cancel ht_dvd).symm
  have hc_not_succ : ¬ p ^ (n + 1) ∣ c - 1 := by
    intro hdiv
    rcases (padicValNat_dvd_iff (n + 1) (c - 1)).1 hdiv with hzero | hle
    · exact hc_sub_ne_zero hzero
    · dsimp [n] at hle
      omega
  have ht_not_succ : ¬ p ^ (n + 1) ∣ t - 1 := by
    intro hdiv
    rcases (padicValNat_dvd_iff (n + 1) (t - 1)).1 hdiv with hzero | hle
    · exact ht_sub_ne_zero hzero
    · dsimp [n] at hle hval_eq
      omega
  have hp_not_dvd_C : ¬ p ∣ C := by
    intro hpC
    have hdiv : p ^ (n + 1) ∣ p ^ n * C := by
      rw [pow_succ]
      exact mul_dvd_mul_left (p ^ n) hpC
    exact hc_not_succ (by rwa [← hc_eq] at hdiv)
  have hp_not_dvd_T : ¬ p ∣ T := by
    intro hpT
    have hdiv : p ^ (n + 1) ∣ p ^ n * T := by
      rw [pow_succ]
      exact mul_dvd_mul_left (p ^ n) hpT
    exact ht_not_succ (by rwa [← ht_eq] at hdiv)
  exact ⟨n, C, T, hn_pos, hc_eq, ht_eq, hp_not_dvd_C, hp_not_dvd_T⟩

private lemma exists_padic_unit_quotient_of_padicVal_eq
    {N p m : ℕ} (hp : p.Prime) (hN_ne_zero : N ≠ 0)
    (hval : padicValNat p N = m) :
    ∃ U : ℕ, 0 < U ∧ N = p ^ m * U ∧ ¬ p ∣ U := by
  haveI : Fact p.Prime := ⟨hp⟩
  let U := N / p ^ m
  have hdiv : p ^ m ∣ N := by
    apply (padicValNat_dvd_iff m N).2
    exact Or.inr (by rw [hval])
  have hN_eq : N = p ^ m * U := by
    dsimp [U]
    rw [mul_comm]
    exact (Nat.div_mul_cancel hdiv).symm
  have hU_pos : 0 < U := by
    by_contra hnot
    have hU0 : U = 0 := Nat.eq_zero_of_not_pos hnot
    have hN0 : N = 0 := by
      rw [hN_eq, hU0, mul_zero]
    exact hN_ne_zero hN0
  have hnot_succ : ¬ p ^ (m + 1) ∣ N := by
    intro hsucc
    rcases (padicValNat_dvd_iff (m + 1) N).1 hsucc with hzero | hle
    · exact hN_ne_zero hzero
    · omega
  have hpU : ¬ p ∣ U := by
    intro hpU
    have hsucc : p ^ (m + 1) ∣ p ^ m * U := by
      rw [pow_succ]
      exact mul_dvd_mul_left (p ^ m) hpU
    exact hnot_succ (by rwa [← hN_eq] at hsucc)
  exact ⟨U, hU_pos, hN_eq, hpU⟩

private lemma scale_tail_of_common_prime_divisors
    {p q k C R W Z : ℕ} (hp : p.Prime)
    (hC_pos : 0 < C) (hR_pos : 0 < R) (hW_pos : 0 < W) (hZ_pos : 0 < Z)
    (hC : p ∣ C) (hR : p ∣ R) (hW : p ∣ W) (hZ : p ∣ Z)
    (hqC : ¬ q ∣ C) (hqR : ¬ q ∣ R) (hqW : ¬ q ∣ W) (hqZ : ¬ q ∣ Z)
    (hEq : W + C * R = q ^ k * Z) :
    ∃ C0 R0 W0 Z0 : ℕ,
      0 < C0 ∧ 0 < R0 ∧ 0 < W0 ∧ 0 < Z0 ∧
      C = p * C0 ∧ R = p * R0 ∧ W = p * W0 ∧ Z = p * Z0 ∧
      ¬ q ∣ C0 ∧ ¬ q ∣ R0 ∧ ¬ q ∣ W0 ∧ ¬ q ∣ Z0 ∧
      W0 + p * C0 * R0 = q ^ k * Z0 := by
  rcases hC with ⟨C0, hC_eq⟩
  rcases hR with ⟨R0, hR_eq⟩
  rcases hW with ⟨W0, hW_eq⟩
  rcases hZ with ⟨Z0, hZ_eq⟩
  have hC0_pos : 0 < C0 := by
    cases C0 with
    | zero =>
        rw [Nat.mul_zero] at hC_eq
        omega
    | succ C0 =>
        omega
  have hR0_pos : 0 < R0 := by
    cases R0 with
    | zero =>
        rw [Nat.mul_zero] at hR_eq
        omega
    | succ R0 =>
        omega
  have hW0_pos : 0 < W0 := by
    cases W0 with
    | zero =>
        rw [Nat.mul_zero] at hW_eq
        omega
    | succ W0 =>
        omega
  have hZ0_pos : 0 < Z0 := by
    cases Z0 with
    | zero =>
        rw [Nat.mul_zero] at hZ_eq
        omega
    | succ Z0 =>
        omega
  have hqC0 : ¬ q ∣ C0 := by
    intro hqC0
    exact hqC (by
      rw [hC_eq]
      exact dvd_mul_of_dvd_right hqC0 p)
  have hqR0 : ¬ q ∣ R0 := by
    intro hqR0
    exact hqR (by
      rw [hR_eq]
      exact dvd_mul_of_dvd_right hqR0 p)
  have hqW0 : ¬ q ∣ W0 := by
    intro hqW0
    exact hqW (by
      rw [hW_eq]
      exact dvd_mul_of_dvd_right hqW0 p)
  have hqZ0 : ¬ q ∣ Z0 := by
    intro hqZ0
    exact hqZ (by
      rw [hZ_eq]
      exact dvd_mul_of_dvd_right hqZ0 p)
  have hscaled :
      p * (W0 + p * C0 * R0) = p * (q ^ k * Z0) := by
    calc
      p * (W0 + p * C0 * R0) = p * W0 + (p * C0) * (p * R0) := by ring
      _ = W + C * R := by rw [hW_eq, hC_eq, hR_eq]
      _ = q ^ k * Z := hEq
      _ = q ^ k * (p * Z0) := by rw [hZ_eq]
      _ = p * (q ^ k * Z0) := by ring
  have htail : W0 + p * C0 * R0 = q ^ k * Z0 :=
    Nat.mul_left_cancel hp.pos hscaled
  exact ⟨C0, R0, W0, Z0, hC0_pos, hR0_pos, hW0_pos, hZ0_pos,
    hC_eq, hR_eq, hW_eq, hZ_eq, hqC0, hqR0, hqW0, hqZ0, htail⟩

private lemma obstruction_common_padic_unit_quotients
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
        padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
          (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
          c < a ∧
          (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
          (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
        (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
        3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
        ((q ∣ a - 1 ∧
            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q) :
    ∃ c t n C T : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧
        0 < n ∧ c - 1 = p ^ n * C ∧ t - 1 = p ^ n * T ∧
        ¬ p ∣ C ∧ ¬ p ∣ T := by
  rcases obstruction_padicVal_descended_t_sub_one_eq_base_sub_one hobs with
    ⟨c, t, hc, hdesc, ht_gt_one, ht_lt_c, hval_eq⟩
  rcases hobs with
    ⟨hp, _hq, _hpd, _hqd,
      _hp_odd, _hq_odd, _hp_ne_three, _hq_ne_three,
      _hp5, _hq5, _hp_ne_q, _hp_lt_q,
      _h6a, _hb_mod_six, hp_dvd_b, _hq_dvd_b, _hp_sq_dvd_b,
      _htail⟩
  have hc_mod_p : c % p = 1 :=
    succ_power_base_mod_exponent_eq_one hp hp_dvd_b hc
  have hc_ge_one : 1 ≤ c := by omega
  have hp_dvd_c_sub_one : p ∣ c - 1 := by
    have hc_modeq_one : c ≡ 1 [MOD p] := by
      have h : (1 : ℕ) ≡ c [MOD p] := by
        simpa [hc_mod_p] using Nat.mod_modEq c p
      exact h.symm
    exact (Nat.modEq_iff_dvd' hc_ge_one).mp hc_modeq_one.symm
  have hc_sub_ne_zero : c - 1 ≠ 0 := by omega
  have ht_sub_ne_zero : t - 1 ≠ 0 := by omega
  rcases exists_common_padic_unit_quotients hp hc_sub_ne_zero ht_sub_ne_zero
      hp_dvd_c_sub_one hval_eq with
    ⟨n, C, T, hn_pos, hc_eq, ht_eq, hpC, hpT⟩
  exact ⟨c, t, n, C, T, hc, hdesc, ht_gt_one, ht_lt_c,
    hn_pos, hc_eq, ht_eq, hpC, hpT⟩

private lemma obstruction_common_padic_unit_quotients_ordered
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
        padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
          (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
          c < a ∧
          (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
          (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
        (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
        3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
        ((q ∣ a - 1 ∧
            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q) :
    ∃ c t n C T : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧
        0 < n ∧ c - 1 = p ^ n * C ∧ t - 1 = p ^ n * T ∧
        T < C ∧ ¬ p ∣ C ∧ ¬ p ∣ T := by
  rcases obstruction_common_padic_unit_quotients hobs with
    ⟨c, t, n, C, T, hc, hdesc, ht_gt_one, ht_lt_c,
      hn_pos, hc_eq, ht_eq, hpC, hpT⟩
  have htc_sub : t - 1 < c - 1 := by omega
  have hmul_lt : p ^ n * T < p ^ n * C := by
    rwa [hc_eq, ht_eq] at htc_sub
  have hTC : T < C := lt_of_mul_lt_mul_left hmul_lt (Nat.zero_le (p ^ n))
  exact ⟨c, t, n, C, T, hc, hdesc, ht_gt_one, ht_lt_c,
    hn_pos, hc_eq, ht_eq, hTC, hpC, hpT⟩

private lemma exists_pow_one_add_eq_linear_add_sq (x q : ℕ) :
    ∃ R : ℕ, (1 + x) ^ q = 1 + q * x + x ^ 2 * R := by
  induction q with
  | zero =>
      exact ⟨0, by simp⟩
  | succ q ih =>
      rcases ih with ⟨R, hR⟩
      refine ⟨q + R * (1 + x), ?_⟩
      rw [pow_succ, hR]
      ring

private lemma exists_pow_one_add_eq_quadratic_add_cube (x q : ℕ) :
    ∃ R : ℕ, (1 + x) ^ q =
      1 + q * x + Nat.choose q 2 * x ^ 2 + x ^ 3 * R := by
  induction q with
  | zero =>
      exact ⟨0, by simp⟩
  | succ q ih =>
      rcases ih with ⟨R, hR⟩
      refine ⟨Nat.choose q 2 + R * (1 + x), ?_⟩
      have hchoose_succ : Nat.choose (q + 1) 2 = q + Nat.choose q 2 := by
        calc
          Nat.choose (q + 1) 2 = Nat.choose q 1 + Nat.choose q 2 := by
            simpa using Nat.choose_succ_succ q 1
          _ = q + Nat.choose q 2 := by rw [Nat.choose_one_right]
      rw [pow_succ, hR, hchoose_succ]
      ring

private lemma exists_pow_one_add_eq_cubic_add_quartic (x q : ℕ) :
    ∃ R : ℕ, (1 + x) ^ q =
      1 + q * x + Nat.choose q 2 * x ^ 2 +
        Nat.choose q 3 * x ^ 3 + x ^ 4 * R := by
  induction q with
  | zero =>
      exact ⟨0, by simp⟩
  | succ q ih =>
      rcases ih with ⟨R, hR⟩
      refine ⟨Nat.choose q 3 + R * (1 + x), ?_⟩
      have hchoose_two : Nat.choose (q + 1) 2 = q + Nat.choose q 2 := by
        calc
          Nat.choose (q + 1) 2 = Nat.choose q 1 + Nat.choose q 2 := by
            simpa using Nat.choose_succ_succ q 1
          _ = q + Nat.choose q 2 := by rw [Nat.choose_one_right]
      have hchoose_three :
          Nat.choose (q + 1) 3 = Nat.choose q 2 + Nat.choose q 3 := by
        simpa using Nat.choose_succ_succ q 2
      rw [pow_succ, hR, hchoose_two, hchoose_three]
      ring

private lemma pow_one_add_sub_linear_dvd_sq (x q : ℕ) :
    x ^ 2 ∣ (1 + x) ^ q - (1 + q * x) := by
  rcases exists_pow_one_add_eq_linear_add_sq x q with ⟨R, hR⟩
  refine ⟨R, ?_⟩
  omega

private lemma prime_pow_succ_dvd_scaled_square
    (p n T : ℕ) (hn : 0 < n) :
    p ^ (n + 1) ∣ (p ^ n * T) ^ 2 := by
  have hpow : p ^ (n + 1) ∣ p ^ (2 * n) := by
    exact pow_dvd_pow p (by omega : n + 1 ≤ 2 * n)
  have hdiv : p ^ (n + 1) ∣ p ^ (2 * n) * T ^ 2 :=
    dvd_mul_of_dvd_left hpow (T ^ 2)
  convert hdiv using 1
  ring

private lemma one_add_scaled_pow_sub_linear_dvd_prime_succ
    (p n T q : ℕ) (hn : 0 < n) :
    p ^ (n + 1) ∣ (1 + p ^ n * T) ^ q - (1 + q * (p ^ n * T)) := by
  exact dvd_trans (prime_pow_succ_dvd_scaled_square p n T hn)
    (pow_one_add_sub_linear_dvd_sq (p ^ n * T) q)

private lemma prime_pow_two_succ_dvd_scaled_square
    (p n T : ℕ) (hn : 2 ≤ n) :
    p ^ (n + 2) ∣ (p ^ n * T) ^ 2 := by
  have hpow : p ^ (n + 2) ∣ p ^ (2 * n) := by
    exact pow_dvd_pow p (by omega : n + 2 ≤ 2 * n)
  have hdiv : p ^ (n + 2) ∣ p ^ (2 * n) * T ^ 2 :=
    dvd_mul_of_dvd_left hpow (T ^ 2)
  convert hdiv using 1
  ring

private lemma one_add_scaled_pow_sub_linear_dvd_prime_two_succ
    (p n T q : ℕ) (hn : 2 ≤ n) :
    p ^ (n + 2) ∣ (1 + p ^ n * T) ^ q - (1 + q * (p ^ n * T)) := by
  exact dvd_trans (prime_pow_two_succ_dvd_scaled_square p n T hn)
    (pow_one_add_sub_linear_dvd_sq (p ^ n * T) q)

private lemma prime_pow_succ_dvd_scaled_mul_scaled
    (p n C T q : ℕ) (hn : 0 < n) :
    p ^ (n + 1) ∣ (p ^ n * C) * (q * (p ^ n * T)) := by
  have hpow : p ^ (n + 1) ∣ p ^ (2 * n) :=
    pow_dvd_pow p (by omega : n + 1 ≤ 2 * n)
  have hdiv : p ^ (n + 1) ∣ p ^ (2 * n) * (C * q * T) :=
    dvd_mul_of_dvd_left hpow (C * q * T)
  convert hdiv using 1
  ring

private lemma prime_dvd_linear_of_high_scaled_product
    {a c t p q n C T : ℕ} (hp : p.Prime) (hn : 0 < n)
    (hc_gt_one : 1 < c) (ht_gt_one : 1 < t)
    (hc_eq : c - 1 = p ^ n * C) (ht_eq : t - 1 = p ^ n * T)
    (hdesc : a = c * t ^ q) (hhigh : p ^ (n + 1) ∣ a - 1) :
    p ∣ C + q * T := by
  let P := p ^ n
  rcases exists_pow_one_add_eq_linear_add_sq (P * T) q with ⟨R, hR⟩
  have hc_form : c = 1 + P * C := by
    dsimp [P]
    omega
  have ht_form : t = 1 + P * T := by
    dsimp [P]
    omega
  have ht_pow : t ^ q = 1 + q * (P * T) + (P * T) ^ 2 * R := by
    rw [ht_form, hR]
  let Rest := (P * T) ^ 2 * R +
    (P * C) * (q * (P * T) + (P * T) ^ 2 * R)
  have ha_sum : a = 1 + (P * (C + q * T) + Rest) := by
    dsimp [Rest]
    rw [hdesc, hc_form, ht_pow]
    ring
  have ha_sub : a - 1 = P * (C + q * T) + Rest := by
    omega
  have hsq : p ^ (n + 1) ∣ (P * T) ^ 2 := by
    dsimp [P]
    exact prime_pow_succ_dvd_scaled_square p n T hn
  have hrest_left : p ^ (n + 1) ∣ (P * T) ^ 2 * R :=
    dvd_mul_of_dvd_left hsq R
