private theorem singletonTwo_root_exists_and_computable_mod5
    (d : ℕ) (hd5 : 5 ≤ d) (hmod : d % 6 = 5) :
    ∃ (ν : ℝ) (q : ℚ), ν ∈ Set.Ioo (q : ℝ) 1 ∧
      0 ≤ (q : ℝ) ∧ (q : ℝ) ≤ 1 ∧
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨2, by omega⟩).driftFn ν = 0 ∧
      (∀ y, (q : ℝ) ≤ y → y < ν →
        0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨2, by omega⟩).driftFn y) ∧
      IsEhrenfestComputable ν := by
  by_cases hd_eq : d = 5
  · subst hd_eq
    let q : ℚ := (1 : ℚ) / 5
    have hq_cast : (q : ℝ) = (1 : ℝ) / 5 := by norm_num [q]
    have hq0 : 0 ≤ (q : ℝ) := by rw [hq_cast]; norm_num
    have hq1 : (q : ℝ) < 1 := by rw [hq_cast]; norm_num
    have hq_pos :
        0 < (singletonIndexRule (5 + 1) (Nat.zero_lt_succ 5) ⟨2, by omega⟩).driftFn (q : ℝ) := by
      rw [hq_cast]
      exact singletonTwo_drift_pos_of_factor_gt_one 5 (by omega) (by norm_num)
        (by norm_num [Nat.choose])
    have h1_neg :
        (singletonIndexRule (5 + 1) (Nat.zero_lt_succ 5) ⟨2, by omega⟩).driftFn (1 : ℝ) < 0 :=
      singletonTwo_drift_one_neg 5 (by omega)
    obtain ⟨ν, hν, hroot, hpos, hcomp⟩ :=
      root_exists_and_computable_from_rational_start
        (singletonIndexRule (5 + 1) (Nat.zero_lt_succ 5) ⟨2, by omega⟩) q
        hq0 hq1 hq_pos h1_neg
    exact ⟨ν, q, hν, hq0, le_of_lt hq1, hroot, hpos, hcomp⟩
  · have hd11 : 11 ≤ d := by omega
    let q : ℚ := (1 : ℚ) / (2 * (d : ℚ))
    have hd : 1 ≤ d := by omega
    have hq_cast : (q : ℝ) = 1 / (2 * (d : ℝ)) := by
      simp [q]
    have hq0 : 0 ≤ (q : ℝ) := by
      rw [hq_cast]
      positivity
    have hq1 : (q : ℝ) < 1 := by
      rw [hq_cast]
      have hd_real : (1 : ℝ) ≤ d := by exact_mod_cast hd
      rw [div_lt_iff₀ (show (0 : ℝ) < 2 * (d : ℝ) by positivity)]
      nlinarith
    have hq_pos :
        0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨2, by omega⟩).driftFn (q : ℝ) := by
      rw [hq_cast]
      exact singletonTwo_drift_pos_of_factor_gt_one d hd (by positivity)
        (singletonTwo_factor_gt_one_at_inv_two_d_mod5 d hd11)
    have h1_neg :
        (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨2, by omega⟩).driftFn (1 : ℝ) < 0 :=
      singletonTwo_drift_one_neg d (by omega)
    obtain ⟨ν, hν, hroot, hpos, hcomp⟩ :=
      root_exists_and_computable_from_rational_start
        (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) ⟨2, by omega⟩) q
        hq0 hq1 hq_pos h1_neg
    exact ⟨ν, q, hν, hq0, le_of_lt hq1, hroot, hpos, hcomp⟩

/-- Correct exceptional-class construction interface.

Unlike `SingletonOneModFiveAlgebraicWitness`, this does not force the singleton
index to be `1`.  For the Eisenstein/Sylvester-Schur route one should take a
non-boundary singleton index `j`, typically near `sqrt (d+1)`, so that
`Nat.choose (d+1) j` has a prime divisor with valuation exactly one. -/
def SingletonIndexModFiveWitness : Prop :=
  ∀ (d : ℕ), 3 ≤ d → Odd d → d % 6 = 5 →
    ∃ (j : Fin (d + 2)) (ν : ℝ) (q : ℚ) (P : Polynomial ℤ),
      0 < j.val ∧ j.val < d + 1 ∧
      ν ∈ Set.Icc (0 : ℝ) 1 ∧
      0 ≤ (q : ℝ) ∧ (q : ℝ) ≤ 1 ∧
      (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn ν = 0 ∧
      (((q : ℝ) < ν ∧
          ∀ y, (q : ℝ) ≤ y → y < ν →
            0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y) ∨
       (ν < (q : ℝ) ∧
          ∀ y, ν < y → y ≤ (q : ℝ) →
            (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y < 0)) ∧
      P.natDegree = d ∧
      Polynomial.eval₂ (Int.castRingHom ℝ) ν P = 0 ∧
      Irreducible P

theorem singletonIndexModFiveWitness_of_padic_root_data
    (hD : ∀ (d : ℕ), 3 ≤ d → Odd d → d % 6 = 5 →
      ∃ (j : Fin (d + 2)) (ν : ℝ) (q : ℚ) (p : ℕ),
        2 ≤ j.val ∧ j.val < d + 1 ∧
        ν ∈ Set.Icc (0 : ℝ) 1 ∧ 0 < ν ∧
        0 ≤ (q : ℝ) ∧ (q : ℝ) ≤ 1 ∧
        (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn ν = 0 ∧
        (((q : ℝ) < ν ∧
            ∀ y, (q : ℝ) ≤ y → y < ν →
              0 < (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y) ∨
         (ν < (q : ℝ) ∧
            ∀ y, ν < y → y ≤ (q : ℝ) →
              (singletonIndexRule (d + 1) (Nat.zero_lt_succ d) j).driftFn y < 0)) ∧
        p.Prime ∧ padicValNat p (Nat.choose (d + 1) j.val) = 1) :
    SingletonIndexModFiveWitness := by
  intro d hd hodd hmod
  obtain ⟨j, ν, q, p, hj2, hjlt, hν, hνpos, hq0, hq1, hroot, hmono, hp, hval⟩ :=
    hD d hd hodd hmod
  refine ⟨j, ν, q, singletonIndexRootPolynomial d j,
    by omega, hjlt, hν, hq0, hq1, hroot, hmono,
    singletonIndexRootPolynomial_natDegree d j hj2, ?_, ?_⟩
  · exact singletonIndexRootPolynomial_eval_of_drift_root d j (by omega) hνpos hroot
  · exact singletonIndexRootPolynomial_irreducible_of_padicValNat_choose_eq_one d j hj2 p hp hval

theorem singletonIndexModFiveWitness_of_padic_factor_data
    (hD : ∀ (d : ℕ), 3 ≤ d → Odd d → d % 6 = 5 →
      ∃ (j : Fin (d + 2)) (q : ℚ) (p : ℕ),
        2 ≤ j.val ∧ j.val < d + 1 ∧
        0 < (q : ℝ) ∧ (q : ℝ) < 1 ∧
        1 < ((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
          (q : ℝ) ^ (j.val - 1) * (1 - (q : ℝ)) ^ (d + 1 - j.val) ∧
        p.Prime ∧ padicValNat p (Nat.choose (d + 1) j.val) = 1) :
    SingletonIndexModFiveWitness := by
  apply singletonIndexModFiveWitness_of_padic_root_data
  intro d hd hodd hmod
  obtain ⟨j, q, p, hj2, hjlt, hqpos, hq1, hfactor, hp, hval⟩ := hD d hd hodd hmod
  obtain ⟨ν, hν, hνpos, hroot, hmono, hcomp⟩ :=
    singletonIndex_root_exists_and_computable_from_factor_gt_one
      d j q (by omega) hjlt hqpos hq1 hfactor
  exact ⟨j, ν, q, p, hj2, hjlt, hν, hνpos,
    le_of_lt hqpos, le_of_lt hq1, hroot, Or.inl hmono, hp, hval⟩

/-- Variant of `singletonIndexModFiveWitness_of_padic_factor_data` that uses
the squarefree-prime-factor form of the Eisenstein input directly.

This is better suited for `choose(d+1,3)`: it is enough to find a prime `p`
which divides the binomial coefficient but whose square does not. -/
theorem singletonIndexModFiveWitness_of_squarefree_prime_factor_data
    (hD : ∀ (d : ℕ), 3 ≤ d → Odd d → d % 6 = 5 →
      ∃ (j : Fin (d + 2)) (q : ℚ) (p : ℕ),
        2 ≤ j.val ∧ j.val < d + 1 ∧
        0 < (q : ℝ) ∧ (q : ℝ) < 1 ∧
        1 < ((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
          (q : ℝ) ^ (j.val - 1) * (1 - (q : ℝ)) ^ (d + 1 - j.val) ∧
        p.Prime ∧
        (p : ℤ) ∣ (Nat.choose (d + 1) j.val : ℤ) ∧
        ¬ (p : ℤ) ^ 2 ∣ (Nat.choose (d + 1) j.val : ℤ)) :
    SingletonIndexModFiveWitness := by
  intro d hd hodd hmod
  obtain ⟨j, q, p, hj2, hjlt, hqpos, hq1, hfactor, hp, hpdvd, hp2not⟩ :=
    hD d hd hodd hmod
  obtain ⟨ν, hν, hνpos, hroot, hmono, _hcomp⟩ :=
    singletonIndex_root_exists_and_computable_from_factor_gt_one
      d j q (by omega) hjlt hqpos hq1 hfactor
  refine ⟨j, ν, q, singletonIndexRootPolynomial d j,
    by omega, hjlt, hν, le_of_lt hqpos, le_of_lt hq1,
    hroot, Or.inl hmono, singletonIndexRootPolynomial_natDegree d j hj2,
    ?_, ?_⟩
  · exact singletonIndexRootPolynomial_eval_of_drift_root d j
      (by omega) hνpos hroot
  · exact singletonIndexRootPolynomial_irreducible_of_prime_dvd_choose_not_square_dvd
      d j hj2 p hp hpdvd hp2not

/-- Variant of `singletonIndexModFiveWitness_of_padic_factor_data` suited to
the corrected Sylvester--Schur route.

Instead of asking directly for `padicValNat = 1`, it asks for a prime divisor
`p` of the relevant binomial coefficient with `p^2 > d+1`.  Mathlib's
`Nat.factorization_choose_le_one` then supplies valuation one. -/
theorem singletonIndexModFiveWitness_of_large_prime_factor_data
    (hD : ∀ (d : ℕ), 3 ≤ d → Odd d → d % 6 = 5 →
      ∃ (j : Fin (d + 2)) (q : ℚ) (p : ℕ),
        2 ≤ j.val ∧ j.val < d + 1 ∧
        0 < (q : ℝ) ∧ (q : ℝ) < 1 ∧
