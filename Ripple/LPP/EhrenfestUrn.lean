  · exact (Ideal.span_singleton_prime (by exact_mod_cast hp.ne_zero)).mpr
      (Nat.prime_iff_prime_int.mp hp)
  · exact Ideal.mem_span_singleton.mpr hpdvd
  · intro hmem
    apply hp2not
    have hmem' : - (Nat.choose (d + 1) 2 : ℤ) ∈ Ideal.span ({((p : ℤ) ^ 2)} : Set ℤ) := by
      simpa [Ideal.span_singleton_pow] using hmem
    exact dvd_neg.mp (Ideal.mem_span_singleton.mp hmem')

private theorem singletonTwoClosedNewtonPolynomial_irreducible_of_padicValNat_choose_eq_one
    (d : ℕ) (hd : 2 ≤ d) (hodd : Odd d) (p : ℕ) (hp : p.Prime)
    (hval : padicValNat p (Nat.choose (d + 1) 2) = 1) :
    Irreducible (singletonTwoClosedNewtonPolynomial d) := by
  haveI : Fact p.Prime := ⟨hp⟩
  have hchoose_pos : 0 < Nat.choose (d + 1) 2 := Nat.choose_pos (by omega)
  have hpdvd_nat : p ∣ Nat.choose (d + 1) 2 := by
    apply dvd_of_one_le_padicValNat
    rw [hval]
  have hpdvd_int : (p : ℤ) ∣ (Nat.choose (d + 1) 2 : ℤ) := by
    exact_mod_cast hpdvd_nat
  have hp2not_int : ¬ (p : ℤ) ^ 2 ∣ (Nat.choose (d + 1) 2 : ℤ) := by
    intro hsq_int
    have hsq_nat : p ^ 2 ∣ Nat.choose (d + 1) 2 := by
      exact_mod_cast hsq_int
    have hle : 2 ≤ padicValNat p (Nat.choose (d + 1) 2) := by
      exact (padicValNat_dvd_iff_le hchoose_pos.ne').mp hsq_nat
    omega
  exact singletonTwoClosedNewtonPolynomial_irreducible_of_prime_dvd_choose_not_square_dvd
    d hd hodd p hp hpdvd_int hp2not_int

private theorem singletonTwoClosedNewtonPolynomial_irreducible_of_dumas_prime_cover
    (d : ℕ) (hd : 2 ≤ d) (hodd : Odd d)
    (hcover : ∀ q : ℕ, q.Prime → q ∣ d →
      ∃ p : ℕ, p.Prime ∧ ¬ q ∣ padicValNat p (Nat.choose (d + 1) 2)) :
    Irreducible (singletonTwoClosedNewtonPolynomial d) := by
  have hmon : (singletonTwoClosedNewtonPolynomial d).Monic :=
    singletonTwoClosedNewtonPolynomial_monic d hd
  have hdegP : (singletonTwoClosedNewtonPolynomial d).natDegree = d :=
    singletonTwoClosedNewtonPolynomial_natDegree d hd
  have hP_ne_one : singletonTwoClosedNewtonPolynomial d ≠ 1 := by
    intro h
    have hdeg := congrArg Polynomial.natDegree h
    rw [hdegP, Polynomial.natDegree_one] at hdeg
    omega
  rw [hmon.irreducible_iff_natDegree, and_iff_right hP_ne_one]
  intro u v humon hvmon hmul
  have hdeg_sum : u.natDegree + v.natDegree = d := by
    have hdeg_mul := humon.natDegree_mul hvmon
    rw [hmul, hdegP] at hdeg_mul
    exact hdeg_mul.symm
  by_cases hu0 : u.natDegree = 0
  · exact Or.inl hu0
  right
  have hdvd_u : d ∣ u.natDegree := by
    refine (Nat.factorization_le_iff_dvd (by omega : d ≠ 0) hu0).mp ?_
    intro q
    by_cases hqprime : q.Prime
    · by_cases hqdvd : q ∣ d
      · obtain ⟨p, hp, hq_not_dvd_e⟩ := hcover q hqprime hqdvd
        haveI : Fact p.Prime := ⟨hp⟩
        set e : ℕ := padicValNat p (Nat.choose (d + 1) 2)
        have he_ne : e ≠ 0 := by
          intro he0
          exact hq_not_dvd_e (by rw [he0]; exact dvd_zero q)
        have hemul_ne : e * u.natDegree ≠ 0 := mul_ne_zero he_ne hu0
        have hdvd_mul : d ∣ e * u.natDegree := by
          simpa [e] using
            singletonTwoClosedNewtonPolynomial_monic_factor_degree_dvd_mul_valuation
              d p hd hodd humon hvmon hmul.symm
        have hle_mul :
            d.factorization q ≤ (e * u.natDegree).factorization q :=
          (Nat.factorization_le_iff_dvd (by omega : d ≠ 0) hemul_ne).mpr hdvd_mul q
        have he_fac_zero : e.factorization q = 0 :=
          Nat.factorization_eq_zero_of_not_dvd hq_not_dvd_e
        have hmul_fac :
            (e * u.natDegree).factorization q =
              e.factorization q + u.natDegree.factorization q := by
          rw [Nat.factorization_mul he_ne hu0]
          simp
        omega
      · rw [Nat.factorization_eq_zero_of_not_dvd hqdvd]
        omega
    · rw [Nat.factorization_eq_zero_of_not_prime d hqprime]
      omega
  obtain ⟨k, hk⟩ := hdvd_u
  have hk_le : k ≤ 1 := by
    nlinarith [hdeg_sum, Nat.pos_of_ne_zero hu0]
  have hk_pos : 1 ≤ k := by
    by_contra hk0
    push_neg at hk0
    have hk_eq : k = 0 := by omega
    rw [hk, hk_eq, mul_zero] at hu0
    exact hu0 rfl
  have hk1 : k = 1 := le_antisymm hk_le hk_pos
  have hudeg : u.natDegree = d := by
    rw [hk, hk1, mul_one]
  omega

private lemma singletonTwoNewtonPolygonPolynomial_monic (d : ℕ) :
    (singletonTwoNewtonPolygonPolynomial d).Monic := by
  change (singletonTwoNewtonPolygonPolynomial d).leadingCoeff = 1
  simp [singletonTwoNewtonPolygonPolynomial, singletonTwoRootPolynomial_trailingCoeff]

private lemma singletonTwoNewtonPolygonPolynomial_natDegree (d : ℕ) (hd : 1 ≤ d) :
    (singletonTwoNewtonPolygonPolynomial d).natDegree = d := by
  unfold singletonTwoNewtonPolygonPolynomial
