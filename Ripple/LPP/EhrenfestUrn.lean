            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q)
    (hnot : ¬ p ∣ q - 1) :
    ∃ c t : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧
        ¬ q ∣ c ∧ ¬ q ∣ t ∧ Nat.Coprime c t ∧
