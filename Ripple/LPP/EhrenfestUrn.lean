private lemma obstruction_not_p_dvd_q_sub_one_q_common_unit_congruence_depth_two
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
