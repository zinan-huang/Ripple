    exact singletonOneRootPolynomial_irreducible_of_kummer d (by omega) hodd hNP
  · obtain ⟨ν, q, hνq, hq0, hq1, hroot, hpos, _hcomp⟩ :=
      singletonTwo_root_exists_and_computable_mod5 d hd5 hmod
    refine ⟨⟨2, by omega⟩, ν, q, singletonTwoRootPolynomial d,
      by norm_num, by
