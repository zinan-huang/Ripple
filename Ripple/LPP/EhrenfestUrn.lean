private lemma coprime_upper_sub_one_geom_sum_of_not_dvd_lower
    {x y p q : ℕ}
    (hx : 1 < x) (hp : p.Prime) (_hq : q.Prime)
    (hp_not_dvd_y : ¬ p ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    Nat.Coprime (x - 1) (∑ i ∈ Finset.range p, x ^ i) := by
  let S := ∑ i ∈ Finset.range p, x ^ i
  have hx_pos : 1 ≤ x := by omega
  have hprod : S * (x - 1) = y ^ q := by
    have hgeom := geom_sum_mul_sub_one_eq_pow_sub_one (a := x) (n := p) hx_pos
    have hxpow_sub : x ^ p - 1 = y ^ q := by omega
    simpa [S, hxpow_sub] using hgeom
  apply Nat.coprime_of_dvd
  intro r hr hr_dvd_x_sub_one hr_dvd_S
  have hr_dvd_p : r ∣ p := by
    have hx_mod_one : (x : ZMod r) = 1 := by
      have hx_modeq_one : x ≡ 1 [MOD r] :=
        ((Nat.modEq_iff_dvd' hx_pos).mpr hr_dvd_x_sub_one).symm
      simpa using (ZMod.natCast_eq_natCast_iff x 1 r).mpr hx_modeq_one
    have hS_mod : (S : ZMod r) = (p : ZMod r) := by
      calc
        (S : ZMod r)
            = ∑ i ∈ Finset.range p, ((x : ZMod r) ^ i) := by
                simp [S]
        _ = ∑ _i ∈ Finset.range p, (1 : ZMod r) := by
                apply Finset.sum_congr rfl
                intro i _hi
                rw [hx_mod_one, one_pow]
        _ = (p : ZMod r) := by simp
    have hS_zero : (S : ZMod r) = 0 := by
      rw [ZMod.natCast_eq_zero_iff]
      exact hr_dvd_S
    rw [hS_mod] at hS_zero
    rw [ZMod.natCast_eq_zero_iff] at hS_zero
    exact hS_zero
  have hr_eq_p : r = p := (Nat.prime_dvd_prime_iff_eq hr hp).mp hr_dvd_p
  subst r
  have hp_dvd_yq : p ∣ y ^ q := by
    have hp_dvd_prod : p ∣ S * (x - 1) := dvd_mul_of_dvd_right hr_dvd_x_sub_one S
    rwa [hprod] at hp_dvd_prod
  exact hp_not_dvd_y (hp.dvd_of_dvd_pow hp_dvd_yq)

private lemma lowerPrimeDivisorCatalan_upper_pred_qpow_of_not_smaller_dvd_lower
    {x y p q : ℕ}
    (hx : 1 < x) (hp : p.Prime) (hq : q.Prime)
    (hp_not_dvd_y : ¬ p ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    ∃ c : ℕ, x - 1 = c ^ q := by
  let S := ∑ i ∈ Finset.range p, x ^ i
  have hx_sub_ne : x - 1 ≠ 0 := by omega
  have hS_pos : 0 < S := by
    have hmem : 0 ∈ Finset.range p := Finset.mem_range.mpr hp.pos
    have hterm_pos : 0 < x ^ 0 := by simp
    exact lt_of_lt_of_le hterm_pos (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hmem)
  have hprod : (x - 1) * S = y ^ q := by
    have hx_pos : 1 ≤ x := by omega
    have hgeom := geom_sum_mul_sub_one_eq_pow_sub_one (a := x) (n := p) hx_pos
    have hxpow_sub : x ^ p - 1 = y ^ q := by omega
    rw [mul_comm]
    simpa [S, hxpow_sub] using hgeom
  exact left_factor_is_pow_of_coprime_mul_eq_pow hx_sub_ne
    (Nat.ne_of_gt hS_pos) hq.ne_zero
    (coprime_upper_sub_one_geom_sum_of_not_dvd_lower hx hp hq hp_not_dvd_y hpow)
    hprod

private lemma lowerPrimeDivisorCatalan_smaller_dvd_lower_or_upper_pred_qpow
    {x y p q : ℕ}
    (hx : 1 < x) (hp : p.Prime) (hq : q.Prime)
    (hpow : x ^ p = y ^ q + 1) :
    p ∣ y ∨ ∃ c : ℕ, x - 1 = c ^ q := by
  by_cases hp_dvd_y : p ∣ y
  · exact Or.inl hp_dvd_y
  · exact Or.inr
      (lowerPrimeDivisorCatalan_upper_pred_qpow_of_not_smaller_dvd_lower
        hx hp hq hp_dvd_y hpow)

private lemma upper_adjacent_pow_add_one_lt_of_p_lt_q
    {c p q : ℕ} (hc : 1 < c) (hp0 : p ≠ 0) (hpq : p < q) :
    (c ^ q + 1) ^ p < (c ^ p + 1) ^ q := by
  have hqp_pos : 0 < q - p := by omega
  have hcp_pos : 0 < c ^ p := pow_pos (by omega : 0 < c) p
  have hshift_gt_one : 1 < c ^ (q - p) := one_lt_pow₀ hc hqp_pos.ne'
  have hbase_lt : c ^ q + 1 < c ^ (q - p) * (c ^ p + 1) := by
    have hpow_add : c ^ (q - p) * c ^ p = c ^ q := by
      rw [← pow_add]
      congr 1
      omega
    calc
      c ^ q + 1 < c ^ q + c ^ (q - p) := by omega
      _ = c ^ (q - p) * (c ^ p + 1) := by
            rw [Nat.mul_add, hpow_add, mul_one]
  have hleft_lt :
      (c ^ q + 1) ^ p < (c ^ (q - p) * (c ^ p + 1)) ^ p :=
    Nat.pow_lt_pow_left hbase_lt hp0
  have hfactor_lt : (c ^ (q - p)) ^ p < (c ^ p + 1) ^ (q - p) := by
    have hcp_lt : c ^ p < c ^ p + 1 := by omega
    calc
      (c ^ (q - p)) ^ p = (c ^ p) ^ (q - p) := by
        rw [pow_right_comm]
      _ < (c ^ p + 1) ^ (q - p) :=
        Nat.pow_lt_pow_left hcp_lt hqp_pos.ne'
  have hmul_lt :
      (c ^ (q - p)) ^ p * (c ^ p + 1) ^ p <
        (c ^ p + 1) ^ (q - p) * (c ^ p + 1) ^ p :=
    Nat.mul_lt_mul_of_pos_right hfactor_lt (pow_pos (by omega) p)
  have hright_eq :
      (c ^ p + 1) ^ (q - p) * (c ^ p + 1) ^ p =
        (c ^ p + 1) ^ q := by
    rw [← pow_add]
    congr 1
    omega
  calc
    (c ^ q + 1) ^ p
        < (c ^ (q - p) * (c ^ p + 1)) ^ p := hleft_lt
    _ = (c ^ (q - p)) ^ p * (c ^ p + 1) ^ p := by rw [mul_pow]
    _ < (c ^ p + 1) ^ (q - p) * (c ^ p + 1) ^ p := hmul_lt
    _ = (c ^ p + 1) ^ q := hright_eq

private lemma lowerPrimeDivisorCatalan_false_of_upper_pred_qpow
    {x y p q c : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q)
    (hpow : x ^ p = y ^ q + 1)
    (hpred : x - 1 = c ^ q) :
    False := by
  have hx_eq : x = c ^ q + 1 := by omega
  rcases Nat.lt_or_ge c 2 with hc_lt_two | hc_ge_two
  · have hc_one_or_zero : c = 0 ∨ c = 1 := by omega
    rcases hc_one_or_zero with hc0 | hc1
    · subst c
      rw [zero_pow hq.ne_zero] at hpred
      omega
    · subst c
      have hx_two : x = 2 := by
        simpa using hx_eq
      have hyq_eq : y ^ q = 2 ^ p - 1 := by
        have hpow_two : 2 ^ p = y ^ q + 1 := by
          simpa [hx_two] using hpow
        omega
      have hpow_lt : y ^ q < 2 ^ q := by
        rw [hyq_eq]
        have h2p_lt_h2q : 2 ^ p < 2 ^ q :=
          Nat.pow_lt_pow_right (by norm_num : 1 < 2) hpq
        exact lt_of_le_of_lt (Nat.sub_le (2 ^ p) 1) h2p_lt_h2q
      have htwo_le_y : 2 ≤ y := by omega
      have h2q_le_yq : 2 ^ q ≤ y ^ q := Nat.pow_le_pow_left htwo_le_y q
      omega
  · have hc_gt_one : 1 < c := by omega
    have hpow_c : (c ^ q + 1) ^ p = y ^ q + 1 := by
      rwa [hx_eq] at hpow
    have hlow_gap :
        (c ^ q) ^ p + 1 < (c ^ q + 1) ^ p :=
      pow_add_one_lt_succ_pow (by positivity) hp.two_le
    have hlow_pow : (c ^ p) ^ q < y ^ q := by
      have hgap' : (c ^ p) ^ q + 1 < y ^ q + 1 := by
        rw [← hpow_c]
        simpa [pow_right_comm] using hlow_gap
      omega
    have hupper_succ :
        y ^ q + 1 < (c ^ p + 1) ^ q := by
      rw [← hpow_c]
      exact upper_adjacent_pow_add_one_lt_of_p_lt_q hc_gt_one hp.ne_zero hpq
    have hupper_pow : y ^ q < (c ^ p + 1) ^ q := by omega
    have hcp_lt_y : c ^ p < y := by
      by_contra hnot
      push Not at hnot
      exact not_lt_of_ge (Nat.pow_le_pow_left hnot q) hlow_pow
    have hy_lt_succ : y < c ^ p + 1 := by
      by_contra hnot
      push Not at hnot
      exact not_lt_of_ge (Nat.pow_le_pow_left hnot q) hupper_pow
    omega

private lemma lowerPrimeDivisorCatalan_smaller_prime_dvd_lower
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q)
    (hpow : x ^ p = y ^ q + 1) :
    p ∣ y := by
  rcases lowerPrimeDivisorCatalan_smaller_dvd_lower_or_upper_pred_qpow
      hx hp hq hpow with hp_dvd_y | hpred
  · exact hp_dvd_y
  · rcases hpred with ⟨c, hc⟩
    exact False.elim
      (lowerPrimeDivisorCatalan_false_of_upper_pred_qpow
        hx hy hp hq hpq hpow hc)

private lemma lowerPrimeDivisorCatalan_bases_coprime
    {x y p q : ℕ}
    (hp : p.Prime) (hq : q.Prime)
    (hpow : x ^ p = y ^ q + 1) :
    Nat.Coprime x y := by
  apply Nat.coprime_iff_gcd_eq_one.mpr
  have hg_dvd_xp : Nat.gcd x y ∣ x ^ p := dvd_pow (Nat.gcd_dvd_left x y) hp.ne_zero
  have hg_dvd_yq : Nat.gcd x y ∣ y ^ q := dvd_pow (Nat.gcd_dvd_right x y) hq.ne_zero
  have hg_dvd_succ : Nat.gcd x y ∣ y ^ q + 1 := by
    rwa [← hpow]
  have hg_dvd_one : Nat.gcd x y ∣ 1 := by
    have hsub : Nat.gcd x y ∣ (y ^ q + 1) - y ^ q :=
      Nat.dvd_sub hg_dvd_succ hg_dvd_yq
    simpa using hsub
  exact Nat.eq_one_of_dvd_one hg_dvd_one

