private lemma choose_two_three_squarefull_implies_linear_squarefull_obstruction
    (d : ℕ) (hmod : d % 6 = 5)
    (htwo : SquarefullNat (Nat.choose (d + 1) 2))
    (hthree : SquarefullNat (Nat.choose (d + 1) 3)) :
    SquarefullNat d ∧
      OddSquarefullNat ((d + 1) / 6) ∧
      OddSquarefullNat (d - 1) := by
  let m := (d + 1) / 6
  have h6 : 6 ∣ d + 1 := by omega
  have hm : d + 1 = 6 * m := by
    rw [show 6 * m = m * 6 by rw [mul_comm]]
    exact (Nat.div_mul_cancel h6).symm
  have hchoose2 :
      Nat.choose (d + 1) 2 = 3 * m * d :=
    choose_succ_two_eq_mod_six_five_factorization d hmod
  have hchoose3 :
      Nat.choose (d + 1) 3 = m * d * (d - 1) :=
    choose_succ_three_eq_mod_six_five_factorization d hmod
  have hd_pos : 0 < d := by
    have hle : d % 6 ≤ d := Nat.mod_le d 6
    omega
  refine ⟨?_, ?_, ?_⟩
  · intro p hp hpd
    have hp_not_3m : ¬ p ∣ 3 * m := by
      intro hp3m
      rcases hp.dvd_mul.mp hp3m with hp3 | hpm
      · have hp_eq_three : p = 3 :=
          (Nat.prime_dvd_prime_iff_eq hp (by decide : Nat.Prime 3)).mp hp3
        subst hp_eq_three
        have h3mod : d % 3 = 0 := Nat.dvd_iff_mod_eq_zero.mp hpd
        omega
      · have hp_d_succ : p ∣ d + 1 := by
          rw [hm]
          exact dvd_mul_of_dvd_right hpm 6
        have hp_one : p ∣ (d + 1) - d := Nat.dvd_sub hp_d_succ hpd
        exact hp.not_dvd_one (by simpa using hp_one)
