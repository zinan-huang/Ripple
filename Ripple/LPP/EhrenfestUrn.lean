    ∃ c t : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ 1 < t ∧ t < c ∧ p < q ∧ q < c := by
  rcases hobs with
    ⟨hp, hq, _hpd, _hqd,
      _hp_odd, _hq_odd, _hp_ne_three, _hq_ne_three,
      _hp5, _hq5, _hp_ne_q, hp_lt_q,
      _h6a, _hb_mod_six, _hp_dvd_b, _hq_dvd_b, _hp_sq_dvd_b,
      _hcop_ab, _hp_not_dvd_a, _hq_not_dvd_a,
      _ha_mod_p, _hp_val_eq, _hq_dvd_pval, _hp_pow_dvd_a_sub_one,
      _hp_big_pow_dvd_a_sub_one, hc_branch,
      _hhalf_pow, _hthree_q_dvd_a, _hthree_pq_dvd_bq_succ,
      _hthree_pq_dvd_b_succ, _hq_side, _ha, _hb⟩
  rcases hc_branch with
    ⟨c, hc, _h6c, _hcmod, h3qc, _hs, _hc_lt_a, hquot, _hcside⟩
  rcases hquot with ⟨r, t, ha_eq, _hr_gt_one, hr_eq, ht_gt_one, ht_lt_c⟩
