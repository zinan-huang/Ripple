def NoEhrenfestModFivePowerObstruction : Prop :=
  ∀ d a b p q : ℕ, 5 ≤ d → Odd d → d % 6 = 5 →
    (p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
      Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
      5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
      6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
      Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
      a % p = 1 ∧
      padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
      q ∣ padicValNat p (a - 1) + 1 ∧
      p ^ (q - 1) ∣ a - 1 ∧
      p ^ (2 * q - 1) ∣ a - 1 ∧
      (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
        3 ^ q ∣ c ∧
        (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
        c < a ∧
        (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
        (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
      (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
      3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
      ((q ∣ a - 1 ∧
          padicValNat q (a - 1) = q * padicValNat q b ∧
          q ^ q ∣ a - 1) ∨
        (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
      d + 1 = a ^ p ∧ d = b ^ q) → False

private abbrev EhrenfestModFiveObstructionHyp
    (d a b p q : ℕ) : Prop :=
  p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
    Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
    5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
    6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
    Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
    a % p = 1 ∧
    padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
    q ∣ padicValNat p (a - 1) + 1 ∧
    p ^ (q - 1) ∣ a - 1 ∧
    p ^ (2 * q - 1) ∣ a - 1 ∧
    (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
      3 ^ q ∣ c ∧
      (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
      c < a ∧
      (∃ r t : ℕ, a = c * r ∧ 1 < r ∧ r = t ^ q ∧ 1 < t ∧ t < c) ∧
      (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q))) ∧
    (∃ e : ℕ, (d + 1) / 2 = e ^ q ∧ a ^ p = 2 * e ^ q) ∧
    3 ^ q ∣ a ∧ 3 ^ (p * q) ∣ b ^ q + 1 ∧ 3 ^ (p * q) ∣ b + 1 ∧
    ((q ∣ a - 1 ∧
        padicValNat q (a - 1) = q * padicValNat q b ∧
        q ^ q ∣ a - 1) ∨
      (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
