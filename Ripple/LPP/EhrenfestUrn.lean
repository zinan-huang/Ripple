      singletonTwoRootPolynomial_natDegree d (by omega), ?_, ?_⟩
    · exact ⟨le_trans hq0 (le_of_lt hνq.1), le_of_lt hνq.2⟩
    · exact Or.inl ⟨hνq.1, hpos⟩
    · exact singletonTwoRootPolynomial_eval_of_drift_root d (by omega)
        (lt_of_le_of_lt hq0 hνq.1) hroot
    · apply singletonTwoRootPolynomial_irreducible_of_newtonPolygon
      rw [singletonTwoNewtonPolygonPolynomial_eq_closed d (by omega) hodd]
      exact singletonTwoClosedNewtonPolynomial_irreducible_of_dumas_prime_cover
