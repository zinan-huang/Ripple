private lemma choose_three_squarefree_prime_of_degree_squarefree_prime
    {d p : ℕ} (hmod : d % 6 = 5) (hp : p.Prime)
    (hpd : p ∣ d) (hp2d : ¬ p ^ 2 ∣ d) :
    (p : ℤ) ∣ (Nat.choose (d + 1) 3 : ℤ) ∧
      ¬ (p : ℤ) ^ 2 ∣ (Nat.choose (d + 1) 3 : ℤ) := by
  let m := (d + 1) / 6
  have hformula :
      Nat.choose (d + 1) 3 = m * d * (d - 1) :=
    choose_succ_three_eq_mod_six_five_factorization d hmod
  have hp_not_m : ¬ p ∣ m := by
    intro hpm
    have h6 : 6 ∣ d + 1 := by omega
    have hm : d + 1 = 6 * m := by
      rw [show 6 * m = m * 6 by rw [mul_comm]]
      exact (Nat.div_mul_cancel h6).symm
    have hp_d_succ : p ∣ d + 1 := by
      rw [hm]
      exact dvd_mul_of_dvd_right hpm 6
    have hp_one : p ∣ (d + 1) - d := Nat.dvd_sub hp_d_succ hpd
    exact hp.not_dvd_one (by simpa using hp_one)
  have hp_not_d_sub_one : ¬ p ∣ d - 1 := by
    intro hpd1
    have hp_one : p ∣ d - (d - 1) := Nat.dvd_sub hpd hpd1
    exact hp.not_dvd_one (by
      have hd_pos : 0 < d := by
        have hle : d % 6 ≤ d := Nat.mod_le d 6
        omega
      simpa [Nat.sub_sub_self hd_pos] using hp_one)
  have hpdvd_nat : p ∣ Nat.choose (d + 1) 3 := by
    rw [hformula]
    exact dvd_mul_of_dvd_left (dvd_mul_of_dvd_right hpd m) (d - 1)
  have hp2not_nat : ¬ p ^ 2 ∣ Nat.choose (d + 1) 3 := by
    rw [hformula]
    exact prime_sq_not_dvd_mul_three_of_sq_not_dvd_middle
      hp hp_not_m hp2d hp_not_d_sub_one
  constructor
  · exact_mod_cast hpdvd_nat
  · intro hp2_int
    have hp2_nat : p ^ 2 ∣ Nat.choose (d + 1) 3 := by
      exact_mod_cast hp2_int
    exact hp2not_nat hp2_nat

private lemma choose_three_squarefree_prime_of_left_factor_squarefree_odd_prime
    {d p : ℕ} (hmod : d % 6 = 5) (hp : p.Prime) (hp_ne_two : p ≠ 2)
