  rcases obstruction_common_padic_exact_quotient_high_with_E_mod hobs_full with
    ⟨c₂, t₂, n₂, U₂, V₂, E, _F, L,
      hc₂, hdesc₂, _ht₂_gt_one, _ht₂_lt_c,
