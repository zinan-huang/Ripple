      _ = q ^ m * C := hc_q
      _ = q ^ m * (p ^ n * C₁) := by rw [hC₁_scale]
      _ = p ^ n * (q ^ m * C₁) := by ring
  have hpC₁ : ¬ p ∣ C₁ := by
    intro hpC₁
    exact hpU (by
