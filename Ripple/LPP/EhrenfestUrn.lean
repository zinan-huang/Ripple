private lemma lowerPrimeDivisorCatalan_smaller_prime_dvd_upper_sub_one
    {x y p q : ℕ}
    (hx : 1 < x) (hp : p.Prime) (hq : q.Prime)
    (hp_dvd_y : p ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    p ∣ x - 1 := by
  have hcop_xy : Nat.Coprime x y :=
    lowerPrimeDivisorCatalan_bases_coprime hp hq hpow
  have hp_not_dvd_x : ¬ p ∣ x := by
    intro hpx
    have hpgcd : p ∣ Nat.gcd x y := Nat.dvd_gcd hpx hp_dvd_y
    rw [Nat.Coprime.gcd_eq_one hcop_xy] at hpgcd
    exact hp.not_dvd_one hpgcd
  have hcop_xp : x.Coprime p := ((hp.coprime_iff_not_dvd).mpr hp_not_dvd_x).symm
  have hfermat : x ^ (p - 1) ≡ 1 [MOD p] :=
    Nat.ModEq.pow_card_sub_one_eq_one hp hcop_xp
  have hxp_modeq_x : x ^ p ≡ x [MOD p] := by
    have hmul := Nat.ModEq.mul_left x hfermat
    conv_lhs => rw [show p = p - 1 + 1 by exact (Nat.sub_add_cancel hp.one_le).symm]
    rw [pow_succ]
    simpa [mul_comm] using hmul
  have hp_dvd_yq : p ∣ y ^ q := dvd_pow hp_dvd_y hq.ne_zero
  have hyq_modeq_zero : y ^ q ≡ 0 [MOD p] := Nat.modEq_zero_iff_dvd.mpr hp_dvd_yq
  have hxp_modeq_one : x ^ p ≡ 1 [MOD p] := by
    have h := Nat.ModEq.add_right 1 hyq_modeq_zero
    simpa [← hpow] using h
  have hx_modeq_one : x ≡ 1 [MOD p] := hxp_modeq_x.symm.trans hxp_modeq_one
  exact (Nat.modEq_iff_dvd' (by omega : 1 ≤ x)).mp hx_modeq_one.symm

private lemma lowerPrimeDivisorCatalan_lower_base_divisible_by_both
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    p ∣ y ∧ q ∣ y := by
  exact ⟨lowerPrimeDivisorCatalan_smaller_prime_dvd_lower
    hx hy hp hq hpq hpow, hq_dvd_y⟩

private lemma lowerPrimeDivisorCatalan_lower_succ_pow_branch
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    ∃ c : ℕ, y + 1 = c ^ p ∧ c % p = 1 ∧ p ^ 2 ∣ y ∧
      (q ∣ c - 1 ∨ (¬ q ∣ c - 1 ∧ p ∣ q - 1 ∧ p < q)) := by
  have hp_odd : Odd p := hp.odd_of_ne_two (by omega)
  have hq_odd : Odd q := hq.odd_of_ne_two (by omega)
  have hp_dvd_y : p ∣ y :=
    lowerPrimeDivisorCatalan_smaller_prime_dvd_lower hx hy hp hq hpq hpow
  obtain ⟨c, hc⟩ :=
    succ_lower_base_is_pow_of_odd_consecutive_powers hp hq hq_odd hq_dvd_y hpow
  have hcmod : c % p = 1 :=
    succ_power_base_mod_exponent_eq_one hp hp_dvd_y hc
  exact ⟨c, hc, hcmod,
    sq_exponent_dvd_base_of_succ_power_mod_exponent_eq_one hp hp_odd hc hcmod,
    order_branch_of_succ_power hp hq hq_dvd_y hc⟩

private lemma lowerPrimeDivisorCatalan_lower_succ_pow_bounds
    {x y c p q : ℕ}
    (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hpow : x ^ p = y ^ q + 1) (hc : y + 1 = c ^ p) :
    1 < c ∧ c < x ∧ x < c ^ q := by
  have hc_gt_one : 1 < c := by
    by_contra hnot
    push Not at hnot
    have hc_le_one : c ≤ 1 := hnot
    have hcp_le_one : c ^ p ≤ 1 := by
      rcases Nat.eq_zero_or_pos c with hc0 | hcpos
      · subst c
        simp [hp.ne_zero]
      · have hc_eq_one : c = 1 := by omega
        rw [hc_eq_one, one_pow]
    omega
  have hy_eq : y = c ^ p - 1 := by omega
  have hpow_c : x ^ p = (c ^ p - 1) ^ q + 1 := by
    rwa [hy_eq] at hpow
  have hcp_sub_gt_one : 1 < c ^ p - 1 := by omega
  have hc_lt_x : c < x := by
    have hsub_pow_lt :
        c ^ p - 1 < (c ^ p - 1) ^ q := by
      simpa [pow_one] using
        ((Nat.pow_lt_pow_iff_right hcp_sub_gt_one).mpr hq.one_lt :
          (c ^ p - 1) ^ 1 < (c ^ p - 1) ^ q)
    have hcp_lt_xp : c ^ p < x ^ p := by
      rw [hpow_c]
      omega
    by_contra hnot
    push Not at hnot
    exact not_lt_of_ge (Nat.pow_le_pow_left hnot p) hcp_lt_xp
  have hx_lt_cq : x < c ^ q := by
    have hcp_sub_pos : 0 < c ^ p - 1 := by omega
    have hxp_lt :
        x ^ p < (c ^ q) ^ p := by
      calc
        x ^ p = (c ^ p - 1) ^ q + 1 := hpow_c
        _ < ((c ^ p - 1) + 1) ^ q :=
          pow_add_one_lt_succ_pow hcp_sub_pos hq.two_le
        _ = (c ^ p) ^ q := by
          rw [Nat.sub_add_cancel (Nat.one_le_pow p c (by omega))]
        _ = (c ^ q) ^ p := by rw [pow_right_comm]
    by_contra hnot
    push Not at hnot
    exact not_lt_of_ge (Nat.pow_le_pow_left hnot p) hxp_lt
  exact ⟨hc_gt_one, hc_lt_x, hx_lt_cq⟩

private lemma lowerPrimeDivisorCatalan_lower_succ_divides_upper
    {x y c p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hq5 : 5 ≤ q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1) (hc : y + 1 = c ^ p) :
    ∃ r : ℕ, x = c * r ∧ 1 < r ∧ Nat.Coprime c r ∧ r < c ^ (q - 1) := by
  have hq_odd : Odd q := hq.odd_of_ne_two (by omega)
  have hc_ne_zero : c ≠ 0 := by
    intro hcz
    rw [hcz, zero_pow hp.ne_zero] at hc
    omega
  have hx_ne_zero : x ≠ 0 := by omega
  have hcp_dvd_xp : c ^ p ∣ x ^ p := by
    rw [← hc]
    exact succ_lower_base_dvd_upper_power_of_odd_consecutive_powers hq_odd hpow
  have hc_dvd_x : c ∣ x :=
    base_dvd_of_same_pow_dvd_same_pow hp.ne_zero hc_ne_zero hx_ne_zero hcp_dvd_xp
  rcases hc_dvd_x with ⟨r, hr⟩
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (y : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hprod : (y + 1) * cof = x ^ p := by
    simpa [cof] using
      succ_mul_odd_add_cofactor_natAbs_eq (p := p) hq_odd hpow
  have hcof_eq : cof = r ^ p := by
    have hprod' : c ^ p * cof = c ^ p * r ^ p := by
      calc
        c ^ p * cof = x ^ p := by
          simpa [hc] using hprod
        _ = (c * r) ^ p := by rw [hr]
        _ = c ^ p * r ^ p := by rw [mul_pow]
    exact Nat.mul_left_cancel (pow_pos (Nat.pos_of_ne_zero hc_ne_zero) p) hprod'
  have hcop : Nat.Coprime c r := by
    have hcop_succ_cof : Nat.Coprime (y + 1) cof := by
      simpa [cof] using coprime_succ_and_odd_add_cofactor_natAbs hq hq_dvd_y
    have hcop_pow : Nat.Coprime (c ^ p) (r ^ p) := by
      rw [← hc, ← hcof_eq]
      exact hcop_succ_cof
    have hcop_c_rpow : Nat.Coprime c (r ^ p) :=
      (Nat.coprime_pow_left_iff hp.pos c (r ^ p)).1 hcop_pow
    exact (Nat.coprime_pow_right_iff hp.pos c r).1 hcop_c_rpow
  rcases lowerPrimeDivisorCatalan_lower_succ_pow_bounds
      hy hp hq hpow hc with ⟨_hc_gt_one, hc_lt_x, hx_lt_cq⟩
  have hr_gt_one : 1 < r := by
    by_contra hr_not
    have hr_le : r ≤ 1 := le_of_not_gt hr_not
    interval_cases r
    · rw [mul_zero] at hr
      omega
    · rw [mul_one] at hr
      omega
  have hr_lt : r < c ^ (q - 1) := by
    have hcq_eq : c ^ q = c * c ^ (q - 1) := by
      calc
        c ^ q = c ^ ((q - 1) + 1) := by rw [Nat.sub_add_cancel hq.one_le]
        _ = c ^ (q - 1) * c := by rw [pow_succ]
        _ = c * c ^ (q - 1) := by rw [mul_comm]
    have hmul_lt : c * r < c * c ^ (q - 1) := by
      rw [← hr, ← hcq_eq]
      exact hx_lt_cq
    exact lt_of_mul_lt_mul_left hmul_lt (Nat.zero_le c)
  exact ⟨r, hr, hr_gt_one, hcop, hr_lt⟩

private lemma lowerPrimeDivisorCatalan_high_branch_qadicVal_relations
    {x y c p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hc_gt_one : 1 < c)
    (hp : p.Prime) (hq : q.Prime) (hpq : p < q)
    (hq_dvd_y : q ∣ y) (hpow : x ^ p = y ^ q + 1)
    (hhigh : q ^ q ∣ x - 1) (hc : y + 1 = c ^ p) (hqc : q ∣ c - 1) :
    padicValNat q (x - 1) = q * padicValNat q (c - 1) ∧
      padicValNat q y = padicValNat q (c - 1) ∧
      1 ≤ padicValNat q (c - 1) := by
  haveI : Fact q.Prime := ⟨hq⟩
  have hq_ne_two : q ≠ 2 := by
    have hp_two_le : 2 ≤ p := hp.two_le
    omega
  have hq_odd : Odd q := hq.odd_of_ne_two hq_ne_two
  have hq_not_dvd_x : ¬ q ∣ x := by
    intro hq_dvd_x
    have hq_dvd_xp : q ∣ x ^ p := dvd_pow hq_dvd_x hp.ne_zero
    have hq_dvd_yq : q ∣ y ^ q := dvd_pow hq_dvd_y hq.ne_zero
    have hq_dvd_succ : q ∣ y ^ q + 1 := by
      rwa [← hpow]
    have hq_dvd_one : q ∣ 1 := by
      have hsub : q ∣ (y ^ q + 1) - y ^ q :=
        Nat.dvd_sub hq_dvd_succ hq_dvd_yq
      simpa using hsub
    exact hq.not_dvd_one hq_dvd_one
  have hq_not_dvd_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hq_dvd_x_sub_one : q ∣ x - 1 :=
    (dvd_pow_self q hq.pos.ne').trans hhigh
  have hval_x_lte :
      padicValNat q (x ^ p - 1) =
        padicValNat q (x - 1) := by
    have h := padicValNat.pow_sub_pow hq_odd hx hq_dvd_x_sub_one
      hq_not_dvd_x hp.ne_zero
    have hval_p_zero : padicValNat q p = 0 :=
      padicValNat.eq_zero_of_not_dvd hq_not_dvd_p
    simpa [one_pow, hval_p_zero] using h
  have hxpow_sub : x ^ p - 1 = y ^ q := by omega
  have hy0 : y ≠ 0 := by omega
  have hval_x_y :
      padicValNat q (x - 1) = q * padicValNat q y := by
    calc
      padicValNat q (x - 1)
          = padicValNat q (x ^ p - 1) := hval_x_lte.symm
      _ = padicValNat q (y ^ q) := by rw [hxpow_sub]
      _ = q * padicValNat q y := by rw [padicValNat.pow q hy0]
  have hq_not_dvd_c : ¬ q ∣ c := by
    intro hqc_div
    have hq_dvd_cpow : q ∣ c ^ p := dvd_pow hqc_div hp.ne_zero
    rw [← hc] at hq_dvd_cpow
    have hq_dvd_one : q ∣ (y + 1) - y := Nat.dvd_sub hq_dvd_cpow hq_dvd_y
    have hsub : (y + 1) - y = 1 := by omega
    rw [hsub] at hq_dvd_one
    exact hq.not_dvd_one hq_dvd_one
  have hval_c_lte :
      padicValNat q (c ^ p - 1) =
        padicValNat q (c - 1) := by
    have h := padicValNat.pow_sub_pow hq_odd hc_gt_one hqc
      hq_not_dvd_c hp.ne_zero
    have hval_p_zero : padicValNat q p = 0 :=
      padicValNat.eq_zero_of_not_dvd hq_not_dvd_p
    simpa [one_pow, hval_p_zero] using h
  have hy_eq : c ^ p - 1 = y := by omega
  have hval_y_c : padicValNat q y = padicValNat q (c - 1) := by
    calc
      padicValNat q y = padicValNat q (c ^ p - 1) := by
        rw [hy_eq]
      _ = padicValNat q (c - 1) := hval_c_lte
  have hval_c_pos : 1 ≤ padicValNat q (c - 1) := by
    have hc_sub0 : c - 1 ≠ 0 := by omega
    exact one_le_padicValNat_of_dvd hc_sub0 hqc
  exact ⟨by rw [hval_x_y, hval_y_c], hval_y_c, hval_c_pos⟩

private lemma lowerPrimeDivisorCatalan_high_branch_quotient_q_unit
    {x c r q : ℕ} (hx : 1 < x) (hc_gt_one : 1 < c) (hq : q.Prime)
    (hhigh : q ^ q ∣ x - 1) (hqc : q ∣ c - 1)
    (hr : x = c * r) (hr_gt_one : 1 < r) :
    q ∣ r - 1 ∧ ¬ q ∣ r := by
  have hq_dvd_x_sub_one : q ∣ x - 1 :=
    (dvd_pow_self q hq.pos.ne').trans hhigh
  have hx_modeq_one : x ≡ 1 [MOD q] :=
    ((Nat.modEq_iff_dvd' (by omega : 1 ≤ x)).mpr hq_dvd_x_sub_one).symm
  have hc_modeq_one : c ≡ 1 [MOD q] :=
    ((Nat.modEq_iff_dvd' (by omega : 1 ≤ c)).mpr hqc).symm
  have hcr_modeq_one : c * r ≡ 1 [MOD q] := by
    simpa [hr] using hx_modeq_one
  have hcr_modeq_r : c * r ≡ r [MOD q] := by
    simpa [one_mul] using hc_modeq_one.mul (Nat.ModEq.refl r)
  have hr_modeq_one : r ≡ 1 [MOD q] :=
    hcr_modeq_r.symm.trans hcr_modeq_one
  have hq_dvd_r_sub_one : q ∣ r - 1 :=
    (Nat.modEq_iff_dvd' (by omega : 1 ≤ r)).mp hr_modeq_one.symm
  have hq_not_dvd_r : ¬ q ∣ r := by
    intro hqr
    have hq_dvd_one : q ∣ r - (r - 1) := Nat.dvd_sub hqr hq_dvd_r_sub_one
    have hsub : r - (r - 1) = 1 := by omega
    rw [hsub] at hq_dvd_one
    exact hq.not_dvd_one hq_dvd_one
  exact ⟨hq_dvd_r_sub_one, hq_not_dvd_r⟩

private lemma lowerPrimeDivisorCatalan_high_branch_quotient_q_padicVal
    {x c r q : ℕ} (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hq : q.Prime)
    (hval_x : padicValNat q (x - 1) = q * padicValNat q (c - 1))
    (hval_c_pos : 1 ≤ padicValNat q (c - 1))
    (hqc : q ∣ c - 1) (hr : x = c * r) :
    padicValNat q (r - 1) = padicValNat q (c - 1) := by
  have hq_not_c : ¬ q ∣ c := by
    intro hqc_div
    have hq_dvd_one : q ∣ c - (c - 1) := Nat.dvd_sub hqc_div hqc
    have hsub : c - (c - 1) = 1 := by omega
    rw [hsub] at hq_dvd_one
    exact hq.not_dvd_one hq_dvd_one
  have hc_sub_ne_zero : c - 1 ≠ 0 := by omega
  have hhigh :
      padicValNat q (c - 1) + 1 ≤ padicValNat q (x - 1) := by
    rw [hval_x]
    have hq_two : 2 ≤ q := hq.two_le
    nlinarith [hval_c_pos]
  have hmul_pred :
      c * r - 1 = c * (r - 1) + (c - 1) := by
    have hr_succ : r = (r - 1) + 1 := by omega
    conv_lhs => rw [hr_succ]
    rw [mul_add, mul_one]
    omega
  have hdiff : (x - 1) - (c - 1) = c * (r - 1) := by
    rw [hr, hmul_pred]
    omega
  have hback : (x - 1) - c * (r - 1) = c - 1 := by
    rw [hr, hmul_pred]
    omega
  exact padicValNat_factor_eq_of_high_sub
    hq hc_sub_ne_zero hq_not_c hhigh hdiff hback

private lemma lowerPrimeDivisorCatalan_high_branch_q_common_unit_congruence
    {x c r q n C R : ℕ} (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hq : q.Prime)
    (hval_x : padicValNat q (x - 1) = q * padicValNat q (c - 1))
    (_hn_pos : 0 < n)
    (hc_eq : c - 1 = q ^ n * C) (hr_eq : r - 1 = q ^ n * R)
    (hqC : ¬ q ∣ C) (hr : x = c * r) :
    q ^ n ∣ C + R := by
  haveI : Fact q.Prime := ⟨hq⟩
  have hC_ne_zero : C ≠ 0 := by
    intro hC0
    exact hqC (by rw [hC0]; exact dvd_zero q)
  have hval_c_eq_n : padicValNat q (c - 1) = n := by
    rw [hc_eq, padicValNat.mul (pow_ne_zero n hq.ne_zero) hC_ne_zero,
      padicValNat.prime_pow, padicValNat.eq_zero_of_not_dvd hqC, add_zero]
  have hhigh : q ^ (2 * n) ∣ x - 1 := by
    apply (padicValNat_dvd_iff (2 * n) (x - 1)).2
    right
    rw [hval_x, hval_c_eq_n]
    have hq_two : 2 ≤ q := hq.two_le
    nlinarith
  let P := q ^ n
  have hc_form : c = P * C + 1 := by
    dsimp [P]
    omega
  have hr_form : r = P * R + 1 := by
    dsimp [P]
    omega
  have hx_sub_eq : x - 1 = P * (C + R + P * C * R) := by
    rw [hr, hc_form, hr_form]
    dsimp [P]
    ring_nf
    omega
  have hpow_two : q ^ (2 * n) = P * P := by
    dsimp [P]
    rw [← pow_add]
    congr 1
    omega
  have hscaled : P * P ∣ P * (C + R + P * C * R) := by
    rw [← hx_sub_eq, ← hpow_two]
    exact hhigh
  have hsum : P ∣ C + R + P * C * R :=
    (Nat.mul_dvd_mul_iff_left (pow_pos hq.pos n)).mp hscaled
  have htail : P ∣ P * C * R := by
    convert dvd_mul_right P (C * R) using 1
    ring
  have hunit_sum : P ∣ C + R := by
    have hsub := Nat.dvd_sub hsum htail
    have hsub_eq : (C + R + P * C * R) - P * C * R = C + R := by
      omega
    rwa [hsub_eq] at hsub
  exact hunit_sum

private lemma lowerPrimeDivisorCatalan_high_branch_q_second_depth_package
    {x c r q n C R : ℕ} (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hq : q.Prime)
    (hval_x : padicValNat q (x - 1) = q * padicValNat q (c - 1))
    (hn_pos : 0 < n)
    (hc_eq : c - 1 = q ^ n * C) (hr_eq : r - 1 = q ^ n * R)
    (hqC : ¬ q ∣ C) (hqR : ¬ q ∣ R) (hr : x = c * r) :
    ∃ W : ℕ, 0 < W ∧ C + R = q ^ n * W ∧
      x - 1 = q ^ (2 * n) * (W + C * R) ∧
      2 * n + padicValNat q (W + C * R) = q * n := by
  haveI : Fact q.Prime := ⟨hq⟩
  have hC_ne_zero : C ≠ 0 := by
    intro hC0
    exact hqC (by rw [hC0]; exact dvd_zero q)
  have hR_ne_zero : R ≠ 0 := by
    intro hR0
    exact hqR (by rw [hR0]; exact dvd_zero q)
  have hval_c_eq_n : padicValNat q (c - 1) = n := by
    rw [hc_eq, padicValNat.mul (pow_ne_zero n hq.ne_zero) hC_ne_zero,
      padicValNat.prime_pow, padicValNat.eq_zero_of_not_dvd hqC, add_zero]
  have hunit_depth : q ^ n ∣ C + R :=
    lowerPrimeDivisorCatalan_high_branch_q_common_unit_congruence
      hc_gt_one hr_gt_one hq hval_x hn_pos hc_eq hr_eq hqC hr
  rcases hunit_depth with ⟨W, hW⟩
  have hW_pos : 0 < W := by
    cases W with
    | zero =>
        rw [mul_zero] at hW
        omega
    | succ W =>
        omega
  let P := q ^ n
  have hc_form : c = P * C + 1 := by
    dsimp [P]
    omega
  have hr_form : r = P * R + 1 := by
    dsimp [P]
    omega
  have hx_sub_first : x - 1 = P * (C + R + P * C * R) := by
    rw [hr, hc_form, hr_form]
    dsimp [P]
    ring_nf
    omega
  have hpow_two : q ^ (2 * n) = P * P := by
    dsimp [P]
    rw [← pow_add]
    congr 1
    omega
  have hx_sub_second : x - 1 = q ^ (2 * n) * (W + C * R) := by
    rw [hx_sub_first, hW, hpow_two]
    ring
  have htail_ne_zero : W + C * R ≠ 0 := by omega
  have hval_x_eq_qn : padicValNat q (x - 1) = q * n := by
    rw [hval_x, hval_c_eq_n]
  have hval_second :
      padicValNat q (x - 1) =
        2 * n + padicValNat q (W + C * R) := by
    rw [hx_sub_second,
      padicValNat.mul (pow_ne_zero (2 * n) hq.ne_zero) htail_ne_zero,
      padicValNat.prime_pow]
  have htail_val : 2 * n + padicValNat q (W + C * R) = q * n := by
    rw [← hval_second]
    exact hval_x_eq_qn
  exact ⟨W, hW_pos, hW, hx_sub_second, htail_val⟩

private lemma lowerPrimeDivisorCatalan_high_branch_quotient_p_unit
    {x y c r p q : ℕ} (hx : 1 < x) (hp : p.Prime) (hq : q.Prime)
    (hp_dvd_y : p ∣ y) (hpow : x ^ p = y ^ q + 1)
    (hcmod : c % p = 1) (hr : x = c * r) (hr_gt_one : 1 < r) :
    p ∣ r - 1 ∧ ¬ p ∣ r := by
  have hp_dvd_x_sub_one : p ∣ x - 1 :=
    lowerPrimeDivisorCatalan_smaller_prime_dvd_upper_sub_one
      hx hp hq hp_dvd_y hpow
  have hx_modeq_one : x ≡ 1 [MOD p] :=
    ((Nat.modEq_iff_dvd' (by omega : 1 ≤ x)).mpr hp_dvd_x_sub_one).symm
  have hc_modeq_one : c ≡ 1 [MOD p] := by
    have h : (1 : ℕ) ≡ c [MOD p] := by
      simpa [hcmod] using Nat.mod_modEq c p
    exact h.symm
  have hcr_modeq_one : c * r ≡ 1 [MOD p] := by
    simpa [hr] using hx_modeq_one
  have hcr_modeq_r : c * r ≡ r [MOD p] := by
    simpa [one_mul] using hc_modeq_one.mul (Nat.ModEq.refl r)
  have hr_modeq_one : r ≡ 1 [MOD p] :=
    hcr_modeq_r.symm.trans hcr_modeq_one
  have hp_dvd_r_sub_one : p ∣ r - 1 :=
    (Nat.modEq_iff_dvd' (by omega : 1 ≤ r)).mp hr_modeq_one.symm
  have hp_not_dvd_r : ¬ p ∣ r := by
    intro hpr
    have hp_dvd_one : p ∣ r - (r - 1) := Nat.dvd_sub hpr hp_dvd_r_sub_one
    have hsub : r - (r - 1) = 1 := by omega
    rw [hsub] at hp_dvd_one
    exact hp.not_dvd_one hp_dvd_one
  exact ⟨hp_dvd_r_sub_one, hp_not_dvd_r⟩

private lemma lowerPrimeDivisorCatalan_high_branch_quotient_pow_mods
    {x y c r p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hq5 : 5 ≤ q)
    (hq_dvd_y : q ∣ y) (hpow : x ^ p = y ^ q + 1)
    (hc : y + 1 = c ^ p) (hr : x = c * r) :
    r ^ p ≡ 1 [MOD q] ∧ r ^ p ≡ q [MOD c] ∧
      r ^ p ≡ q [MOD c ^ p] := by
  have hq_odd : Odd q := hq.odd_of_ne_two (by omega)
  have hc_ne_zero : c ≠ 0 := by
    intro hcz
    rw [hcz, zero_pow hp.ne_zero] at hc
    omega
  let cof : ℕ :=
    Int.natAbs
      (∑ i ∈ Finset.range q, (y : ℤ) ^ i * (-1 : ℤ) ^ (q - 1 - i))
  have hprod : (y + 1) * cof = x ^ p := by
    simpa [cof] using
      succ_mul_odd_add_cofactor_natAbs_eq (p := p) hq_odd hpow
  have hcof_eq : cof = r ^ p := by
    have hprod' : c ^ p * cof = c ^ p * r ^ p := by
      calc
        c ^ p * cof = x ^ p := by
          simpa [hc] using hprod
        _ = (c * r) ^ p := by rw [hr]
        _ = c ^ p * r ^ p := by rw [mul_pow]
    exact Nat.mul_left_cancel (pow_pos (Nat.pos_of_ne_zero hc_ne_zero) p) hprod'
  have hmod_q : r ^ p ≡ 1 [MOD q] := by
    have hcof_mod : cof ≡ 1 [MOD q] := by
      simpa [cof] using
        odd_add_cofactor_natAbs_modEq_one_of_prime_dvd_base hq hq_odd hq_dvd_y
    rwa [hcof_eq] at hcof_mod
  have hmod_c : r ^ p ≡ q [MOD c] := by
    have hc_dvd : c ∣ y + 1 := by
      rw [hc]
      exact dvd_pow_self c hp.ne_zero
    have hcof_mod : cof ≡ q [MOD c] := by
      simpa [cof] using
        odd_add_cofactor_natAbs_modEq_exponent_of_dvd_succ hq_odd hc_dvd
    rwa [hcof_eq] at hcof_mod
  have hmod_cp : r ^ p ≡ q [MOD c ^ p] := by
    have hcp_dvd : c ^ p ∣ y + 1 := by
      rw [hc]
    have hcof_mod : cof ≡ q [MOD c ^ p] := by
      simpa [cof] using
        odd_add_cofactor_natAbs_modEq_exponent_of_dvd_succ hq_odd hcp_dvd
    rwa [hcof_eq] at hcof_mod
  exact ⟨hmod_q, hmod_c, hmod_cp⟩

private lemma lowerPrimeDivisorCatalan_high_branch_prime_lt_bounds
    {c r p q : ℕ} (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hcmod : c % p = 1) (hqc : q ∣ c - 1)
    (hpr : p ∣ r - 1) (hqr : q ∣ r - 1) :
    p < c ∧ q < c ∧ p < r ∧ q < r := by
  have hp_lt_c : p < c := by
    have hdiv : p * (c / p) + c % p = c := Nat.div_add_mod c p
    rw [hcmod] at hdiv
    have hquot_pos : 0 < c / p := by
      by_contra hnot
      have hquot_zero : c / p = 0 := Nat.eq_zero_of_not_pos hnot
      rw [hquot_zero, mul_zero, zero_add] at hdiv
      omega
    have hp_le_mul : p ≤ p * (c / p) := by
      calc
        p = p * 1 := by rw [mul_one]
        _ ≤ p * (c / p) := Nat.mul_le_mul_left p hquot_pos
    omega
  have hq_lt_c : q < c := by
    have hc_sub_pos : 0 < c - 1 := by omega
    have hq_le : q ≤ c - 1 := Nat.le_of_dvd hc_sub_pos hqc
    omega
  have hp_lt_r : p < r := by
    have hr_sub_pos : 0 < r - 1 := by omega
    have hp_le : p ≤ r - 1 := Nat.le_of_dvd hr_sub_pos hpr
    omega
  have hq_lt_r : q < r := by
    have hr_sub_pos : 0 < r - 1 := by omega
    have hq_le : q ≤ r - 1 := Nat.le_of_dvd hr_sub_pos hqr
    omega
  exact ⟨hp_lt_c, hq_lt_c, hp_lt_r, hq_lt_r⟩

private lemma lowerPrimeDivisorCatalan_high_branch_quotient_pow_eq
    {c r p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hq5 : 5 ≤ q)
    (hpq : p < q) (hnot : ¬ p ∣ q - 1) (hc_gt_one : 1 < c)
    (hr_lt : r < c ^ (q - 1)) (hq_lt_r : q < r)
    (hqc : q ∣ c - 1) (hcmod : c % p = 1) (hpr : p ∣ r - 1)
    (hq_not_r : ¬ q ∣ r)
    (hmod_q : r ^ p ≡ 1 [MOD q]) (hmod_c : r ^ p ≡ q [MOD c])
    (hmod_cp : r ^ p ≡ q [MOD c ^ p]) :
    ∃ s : ℕ, 0 < s ∧ r ^ p = q + c * s ∧ c ^ (p - 1) ∣ s ∧
      s < c ^ ((q - 1) * p - 1) ∧
      p < s ∧ q < s ∧
      s ≡ 1 [MOD q] ∧ q + s ≡ 1 [MOD p] ∧
      ¬ q ∣ s ∧ ¬ p ∣ s ∧ Nat.Coprime r s ∧
      (∃ u v : ℕ, 0 < u ∧ 0 < v ∧
        s = q * u + 1 ∧ u + 1 = p * v) := by
  have hq_lt_rpow : q < r ^ p :=
    lt_of_lt_of_le hq_lt_r (Nat.le_self_pow hp.ne_zero r)
  have hc_dvd : c ∣ r ^ p - q :=
    (Nat.modEq_iff_dvd' (le_of_lt hq_lt_rpow)).mp hmod_c.symm
  rcases hc_dvd with ⟨s, hs⟩
  have hs_pos : 0 < s := by
    cases s with
    | zero =>
        rw [mul_zero] at hs
        omega
    | succ s =>
        omega
  have hspow : r ^ p = q + c * s := by omega
  have hcpred_dvd_s : c ^ (p - 1) ∣ s := by
    have hcp_dvd : c ^ p ∣ r ^ p - q :=
      (Nat.modEq_iff_dvd' (le_of_lt hq_lt_rpow)).mp hmod_cp.symm
    have hdiff : r ^ p - q = c * s := by omega
    have hc_pos : 0 < c := by omega
    have hcp_split : c ^ p = c * c ^ (p - 1) := by
      calc
        c ^ p = c ^ ((p - 1) + 1) := by
          rw [Nat.sub_add_cancel hp.pos]
        _ = c ^ (p - 1) * c := by rw [pow_succ]
        _ = c * c ^ (p - 1) := by rw [mul_comm]
    have hmul : c * c ^ (p - 1) ∣ c * s := by
      rwa [← hcp_split, ← hdiff]
    exact (Nat.mul_dvd_mul_iff_left hc_pos).mp hmul
  have hrpow_lt : r ^ p < c ^ ((q - 1) * p) := by
    have hlt : r ^ p < (c ^ (q - 1)) ^ p :=
      Nat.pow_lt_pow_left hr_lt hp.ne_zero
    simpa [pow_mul] using hlt
  have hcs_lt : c * s < c ^ ((q - 1) * p) := by
    calc
      c * s < q + c * s := by omega
      _ = r ^ p := hspow.symm
      _ < c ^ ((q - 1) * p) := hrpow_lt
  have hE_pos : 0 < (q - 1) * p := by
    exact mul_pos (by omega) hp.pos
  have hpow_split :
      c ^ ((q - 1) * p) = c * c ^ ((q - 1) * p - 1) := by
    calc
      c ^ ((q - 1) * p)
          = c ^ (((q - 1) * p - 1) + 1) := by
              rw [Nat.sub_add_cancel (Nat.succ_le_iff.mpr hE_pos)]
      _ = c ^ ((q - 1) * p - 1) * c := by rw [pow_succ]
      _ = c * c ^ ((q - 1) * p - 1) := by rw [mul_comm]
  have hs_lt : s < c ^ ((q - 1) * p - 1) := by
    have hmul_lt : c * s < c * c ^ ((q - 1) * p - 1) := by
      rwa [← hpow_split]
    exact lt_of_mul_lt_mul_left hmul_lt (Nat.zero_le c)
  have hs_modeq_one_q : s ≡ 1 [MOD q] := by
    have hq_modeq_zero : q ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr dvd_rfl
    have hc_modeq_one_q : c ≡ 1 [MOD q] :=
      ((Nat.modEq_iff_dvd' (by omega : 1 ≤ c)).mpr hqc).symm
    have hcs_modeq_s : c * s ≡ s [MOD q] := by
      simpa [one_mul] using hc_modeq_one_q.mul (Nat.ModEq.refl s)
    have hqcs_modeq_s : q + c * s ≡ s [MOD q] := by
      simpa [zero_add] using Nat.ModEq.add hq_modeq_zero hcs_modeq_s
    have hqcs_modeq_one : q + c * s ≡ 1 [MOD q] := by
      simpa [← hspow] using hmod_q
    exact hqcs_modeq_s.symm.trans hqcs_modeq_one
  have hq_s_modeq_one_p : q + s ≡ 1 [MOD p] := by
    have hr_modeq_one_p : r ≡ 1 [MOD p] :=
      ((Nat.modEq_iff_dvd' (by omega : 1 ≤ r)).mpr hpr).symm
    have hrp_modeq_one_p : r ^ p ≡ 1 [MOD p] := by
      simpa using Nat.ModEq.pow p hr_modeq_one_p
    have hc_modeq_one_p : c ≡ 1 [MOD p] := by
      have h : (1 : ℕ) ≡ c [MOD p] := by
        simpa [hcmod] using Nat.mod_modEq c p
      exact h.symm
    have hcs_modeq_s : c * s ≡ s [MOD p] := by
      simpa [one_mul] using hc_modeq_one_p.mul (Nat.ModEq.refl s)
    have hqcs_modeq_qs : q + c * s ≡ q + s [MOD p] :=
      Nat.ModEq.add (Nat.ModEq.refl q) hcs_modeq_s
    have hqcs_modeq_one : q + c * s ≡ 1 [MOD p] := by
      simpa [← hspow] using hrp_modeq_one_p
    exact hqcs_modeq_qs.symm.trans hqcs_modeq_one
  have hq_not_s : ¬ q ∣ s := by
    intro hqs
    have hs_modeq_zero : s ≡ 0 [MOD q] := Nat.modEq_zero_iff_dvd.mpr hqs
    have hone_zero : (1 : ℕ) ≡ 0 [MOD q] :=
      hs_modeq_one_q.symm.trans hs_modeq_zero
    exact hq.not_dvd_one (Nat.modEq_zero_iff_dvd.mp hone_zero)
  have hp_not_s : ¬ p ∣ s := by
    intro hps
    have hs_modeq_zero : s ≡ 0 [MOD p] := Nat.modEq_zero_iff_dvd.mpr hps
    have hq_s_modeq_q : q + s ≡ q [MOD p] := by
      simpa [add_zero] using Nat.ModEq.add (Nat.ModEq.refl q) hs_modeq_zero
    have hq_modeq_one : q ≡ 1 [MOD p] :=
      hq_s_modeq_q.symm.trans hq_s_modeq_one_p
    exact hnot ((Nat.modEq_iff_dvd' hq.one_le).mp hq_modeq_one.symm)
  have hp_not_dvd_q : ¬ p ∣ q := by
    intro hpq_dvd
    have hp_eq_q : p = q :=
      (Nat.prime_dvd_prime_iff_eq hp hq).mp hpq_dvd
    omega
  have hs_ne_one : s ≠ 1 := by
    intro hs_eq_one
    have hq_succ_modeq_one : q + 1 ≡ 1 [MOD p] := by
      simpa [hs_eq_one] using hq_s_modeq_one_p
    have hp_dvd_q : p ∣ q := by
      have hdiv : p ∣ (q + 1) - 1 :=
        (Nat.modEq_iff_dvd' (by omega : 1 ≤ q + 1)).mp
          hq_succ_modeq_one.symm
      simpa using hdiv
    exact hp_not_dvd_q hp_dvd_q
  have hq_lt_s : q < s := by
    have hq_le_s : q ≤ s := by
      by_contra hnot_le
      have hs_lt_q : s < q := by omega
      have hs_eq_one : s = 1 :=
        Nat.ModEq.eq_of_lt_of_lt hs_modeq_one_q hs_lt_q hq.one_lt
      exact hs_ne_one hs_eq_one
    have hq_ne_s : q ≠ s := by
      intro hq_eq_s
      exact hq_not_s (by rw [← hq_eq_s])
    exact lt_of_le_of_ne hq_le_s hq_ne_s
  have hp_lt_s : p < s := lt_trans hpq hq_lt_s
  have hcop_rs : Nat.Coprime r s := by
    apply Nat.coprime_of_dvd
    intro ell hell hellr hells
    have hell_dvd_rpow : ell ∣ r ^ p := dvd_pow hellr hp.ne_zero
    have hell_dvd_cs : ell ∣ c * s := dvd_mul_of_dvd_right hells c
    have hell_dvd_qcs : ell ∣ q + c * s := by
      rwa [← hspow]
    have hell_dvd_q : ell ∣ q := by
      have hsub : ell ∣ (q + c * s) - c * s :=
        Nat.dvd_sub hell_dvd_qcs hell_dvd_cs
      have hsub_eq : (q + c * s) - c * s = q := by omega
      rwa [hsub_eq] at hsub
    have hell_eq_q : ell = q :=
      (Nat.prime_dvd_prime_iff_eq hell hq).mp hell_dvd_q
    subst ell
    exact hq_not_r hellr
  have hs_quot :
      ∃ u v : ℕ, 0 < u ∧ 0 < v ∧
        s = q * u + 1 ∧ u + 1 = p * v := by
    have hq_dvd_s_pred : q ∣ s - 1 :=
      (Nat.modEq_iff_dvd' (by omega : 1 ≤ s)).mp hs_modeq_one_q.symm
    rcases hq_dvd_s_pred with ⟨u, hu⟩
    have hu_pos : 0 < u := by
      cases u with
      | zero =>
          rw [mul_zero] at hu
          omega
      | succ u =>
          omega
    have hs_eq : s = q * u + 1 := by omega
    have hp_dvd_qs_pred : p ∣ q + s - 1 :=
      (Nat.modEq_iff_dvd' (by omega : 1 ≤ q + s)).mp
        hq_s_modeq_one_p.symm
    have hq_s_pred_eq : q + s - 1 = q * (u + 1) := by
      rw [hs_eq]
      calc
        q + (q * u + 1) - 1 = q + q * u := by omega
        _ = q * (u + 1) := by ring
    have hp_dvd_q_mul : p ∣ q * (u + 1) := by
      rwa [hq_s_pred_eq] at hp_dvd_qs_pred
    have hp_dvd_u_succ : p ∣ u + 1 :=
      (hp.dvd_mul.mp hp_dvd_q_mul).resolve_left hp_not_dvd_q
    rcases hp_dvd_u_succ with ⟨v, hv⟩
    have hv_pos : 0 < v := by
      cases v with
      | zero =>
          rw [mul_zero] at hv
          omega
      | succ v =>
          omega
    exact ⟨u, v, hu_pos, hv_pos, hs_eq, hv⟩
  exact ⟨s, hs_pos, hspow, hcpred_dvd_s, hs_lt, hp_lt_s, hq_lt_s,
    hs_modeq_one_q, hq_s_modeq_one_p, hq_not_s, hp_not_s, hcop_rs,
    hs_quot⟩

private lemma high_branch_s_pow_modEq_one_contradiction
    {s p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p < q)
    (hq_s_modeq_one_p : q + s ≡ 1 [MOD p])
    (hp_not_s : ¬ p ∣ s) (hsq_modeq_one : s ^ q ≡ 1 [MOD p]) :
    False := by
  haveI : NeZero p := ⟨hp.ne_zero⟩
  have hcop_sp : Nat.Coprime s p :=
    ((hp.coprime_iff_not_dvd).mpr hp_not_s).symm
  let u : (ZMod p)ˣ := ZMod.unitOfCoprime s hcop_sp
  have hu_pow : u ^ q = 1 := by
    ext
    change ((u : ZMod p) ^ q) = (1 : ZMod p)
    rw [ZMod.coe_unitOfCoprime]
    rw [← Nat.cast_pow]
    simpa using (ZMod.natCast_eq_natCast_iff (s ^ q) 1 p).mpr hsq_modeq_one
  have horder_dvd_q : orderOf u ∣ q := orderOf_dvd_of_pow_eq_one hu_pow
  have horder_dvd_psub : orderOf u ∣ p - 1 := by
    have horder_dvd_card : orderOf u ∣ Nat.card (ZMod p)ˣ := orderOf_dvd_natCard u
    rwa [Nat.card_eq_fintype_card, ZMod.card_units_eq_totient p,
      Nat.totient_prime hp] at horder_dvd_card
  have hq_not_dvd_psub : ¬ q ∣ p - 1 := by
    intro hqdiv
    have hpos : 0 < p - 1 := Nat.sub_pos_of_lt hp.one_lt
    have hle : q ≤ p - 1 := Nat.le_of_dvd hpos hqdiv
    omega
  have hu_one : u = 1 := by
    rcases (Nat.dvd_prime hq).mp horder_dvd_q with horder_one | horder_q
    · exact orderOf_eq_one_iff.mp horder_one
    · exact False.elim (hq_not_dvd_psub (by rwa [horder_q] at horder_dvd_psub))
  have hs_cast_one : (s : ZMod p) = 1 := by
    calc
      (s : ZMod p) = (u : ZMod p) := by
        simp [u, ZMod.coe_unitOfCoprime]
      _ = (1 : ZMod p) := by rw [hu_one]; rfl
  have hs_modeq_one : s ≡ 1 [MOD p] :=
    (ZMod.natCast_eq_natCast_iff s 1 p).mp (by
      simpa using hs_cast_one)
  have hq_s_modeq_q_one : q + s ≡ q + 1 [MOD p] :=
    Nat.ModEq.add_left q hs_modeq_one
  have hq_one_modeq_one : q + 1 ≡ 1 [MOD p] :=
    hq_s_modeq_q_one.symm.trans hq_s_modeq_one_p
  have hp_dvd_q : p ∣ q := by
    have hdiv : p ∣ (q + 1) - 1 :=
      (Nat.modEq_iff_dvd' (by omega : 1 ≤ q + 1)).mp
        hq_one_modeq_one.symm
    simpa using hdiv
  have hp_eq_q : p = q :=
    (Nat.prime_dvd_prime_iff_eq hp hq).mp hp_dvd_q
  omega

private lemma lowerPrimeDivisorCatalan_high_branch_s_quotient_depth
    {c r p q n C R s u v : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q) (hn_pos : 0 < n) (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hc_eq : c - 1 = q ^ n * C) (hr_eq : r - 1 = q ^ n * R)
    (hspow : r ^ p = q + c * s) (hs_eq : s = q * u + 1)
    (huv : u + 1 = p * v) :
    q ^ (n - 1) ∣ v := by
  have hqn_dvd_r_sub : q ^ n ∣ r - 1 := ⟨R, hr_eq⟩
  have hr_modeq_one : r ≡ 1 [MOD q ^ n] :=
    ((Nat.modEq_iff_dvd' (by omega : 1 ≤ r)).mpr hqn_dvd_r_sub).symm
  have hrp_modeq_one : r ^ p ≡ 1 [MOD q ^ n] := by
    simpa using Nat.ModEq.pow p hr_modeq_one
  have hqn_dvd_rp_sub : q ^ n ∣ r ^ p - 1 :=
    (Nat.modEq_iff_dvd' (by exact one_le_pow₀ (by omega : 1 ≤ r))).mp
      hrp_modeq_one.symm
  have hqn_dvd_rhs_sub : q ^ n ∣ q + c * s - 1 := by
    simpa [hspow] using hqn_dvd_rp_sub
  have hqn_dvd_tail : q ^ n ∣ q ^ n * C * s := by
    simpa [mul_assoc] using dvd_mul_right (q ^ n) (C * s)
  have hqn_dvd_qu : q ^ n ∣ q * (u + 1) := by
    have hsub := Nat.dvd_sub hqn_dvd_rhs_sub hqn_dvd_tail
    have hc_form : c = 1 + q ^ n * C := by omega
    have hsub_eq : (q + c * s - 1) - q ^ n * C * s = q * (u + 1) := by
      rw [hc_form, hs_eq]
      have hsum_add :
          q * (u + 1) + q ^ n * C * (q * u + 1) + 1 =
            q + (1 + q ^ n * C) * (q * u + 1) := by
        ring
      omega
    rwa [hsub_eq] at hsub
  have hpow_split : q ^ n = q * q ^ (n - 1) := by
    calc
      q ^ n = q ^ ((n - 1) + 1) := by
        rw [Nat.sub_add_cancel (by omega : 1 ≤ n)]
      _ = q ^ (n - 1) * q := by rw [pow_succ]
      _ = q * q ^ (n - 1) := by rw [mul_comm]
  have hqpow_dvd_u_succ : q ^ (n - 1) ∣ u + 1 := by
    have hmul : q * q ^ (n - 1) ∣ q * (u + 1) := by
      simpa [hpow_split] using hqn_dvd_qu
    exact (Nat.mul_dvd_mul_iff_left hq.pos).mp hmul
  have hqpow_dvd_pv : q ^ (n - 1) ∣ p * v := by
    simpa [huv] using hqpow_dvd_u_succ
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hcop_qp : Nat.Coprime q p :=
    (hq.coprime_iff_not_dvd).mpr hq_not_p
  have hcop_qpow_p : Nat.Coprime (q ^ (n - 1)) p :=
    hcop_qp.pow_left (n - 1)
  exact hcop_qpow_p.dvd_of_dvd_mul_left hqpow_dvd_pv

private lemma scaled_tail_quadratic_residue_mod
    {p q C0 R0 W0 : ℕ}
    (hscaled_sum : q ∣ C0 + R0)
    (hscaled_tail : q ∣ W0 + p * C0 * R0) :
    W0 ≡ p * C0 * C0 [MOD q] ∧
      W0 ≡ p * R0 * R0 [MOD q] := by
  have hsum0 : C0 + R0 ≡ 0 [MOD q] :=
    Nat.modEq_zero_iff_dvd.mpr hscaled_sum
  have htail0 : W0 + p * C0 * R0 ≡ 0 [MOD q] :=
    Nat.modEq_zero_iff_dvd.mpr hscaled_tail
  have hquadC0 : p * C0 * C0 + p * C0 * R0 ≡ 0 [MOD q] := by
    have hmul : C0 * (C0 + R0) ≡ C0 * 0 [MOD q] :=
      Nat.ModEq.mul_left C0 hsum0
    have hmul_p : p * (C0 * (C0 + R0)) ≡ p * (C0 * 0) [MOD q] :=
      Nat.ModEq.mul_left p hmul
    simpa [left_distrib, right_distrib, mul_assoc] using hmul_p
  have hquadR0 : p * R0 * R0 + p * C0 * R0 ≡ 0 [MOD q] := by
    have hmul : R0 * (C0 + R0) ≡ R0 * 0 [MOD q] :=
      Nat.ModEq.mul_left R0 hsum0
    have hmul_p : p * (R0 * (C0 + R0)) ≡ p * (R0 * 0) [MOD q] :=
      Nat.ModEq.mul_left p hmul
    simpa [left_distrib, right_distrib, mul_assoc, mul_comm, mul_left_comm,
      add_comm]
      using hmul_p
  have hC_same :
      W0 + p * C0 * R0 ≡ p * C0 * C0 + p * C0 * R0 [MOD q] :=
    htail0.trans hquadC0.symm
  have hR_same :
      W0 + p * C0 * R0 ≡ p * R0 * R0 + p * C0 * R0 [MOD q] :=
    htail0.trans hquadR0.symm
  exact ⟨Nat.ModEq.add_right_cancel' (p * C0 * R0) hC_same,
    Nat.ModEq.add_right_cancel' (p * C0 * R0) hR_same⟩

private lemma scaled_tail_quadratic_residue_mod_sq_of_two_le
    {p q n C0 R0 W0 Z0 : ℕ}
    (hq5 : 5 ≤ q) (hn_two : 2 ≤ n)
    (hscaled_sum : C0 + R0 = q ^ n * W0)
    (hscaled_tail : W0 + p * C0 * R0 = q ^ ((q - 2) * n) * Z0) :
    (q ^ 2 ∣ C0 + R0 ∧ q ^ 2 ∣ W0 + p * C0 * R0) ∧
      (W0 ≡ p * C0 * C0 [MOD q ^ 2] ∧
        W0 ≡ p * R0 * R0 [MOD q ^ 2]) := by
  have hq2_sum : q ^ 2 ∣ C0 + R0 := by
    rw [hscaled_sum]
    exact dvd_mul_of_dvd_left (pow_dvd_pow q hn_two) W0
  have hq2_tail : q ^ 2 ∣ W0 + p * C0 * R0 := by
    rw [hscaled_tail]
    have hpow : q ^ 2 ∣ q ^ ((q - 2) * n) :=
      pow_dvd_pow q (by
        have hq_sub_pos : 1 ≤ q - 2 := by omega
        have hprod : 1 * 2 ≤ (q - 2) * n :=
          Nat.mul_le_mul hq_sub_pos hn_two
        omega)
    exact dvd_mul_of_dvd_left hpow Z0
  have hquad := scaled_tail_quadratic_residue_mod hq2_sum hq2_tail
  exact ⟨⟨hq2_sum, hq2_tail⟩, hquad⟩

private lemma scaled_tail_cube_dvd
    {p q n C0 R0 W0 Z0 : ℕ}
    (hq5 : 5 ≤ q) (hn_pos : 0 < n)
    (hscaled_tail : W0 + p * C0 * R0 = q ^ ((q - 2) * n) * Z0) :
    q ^ 3 ∣ W0 + p * C0 * R0 := by
  rw [hscaled_tail]
  have hpow : q ^ 3 ∣ q ^ ((q - 2) * n) :=
    pow_dvd_pow q (by
      have hq_sub : 3 ≤ q - 2 := by omega
      have hn_one : 1 ≤ n := by omega
      have hprod : 3 * 1 ≤ (q - 2) * n :=
        Nat.mul_le_mul hq_sub hn_one
      omega)
  exact dvd_mul_of_dvd_left hpow Z0

private lemma scaled_tail_depth_one_cubic_mod
    {p q n C0 R0 W0 : ℕ}
    (hn_one : n = 1)
    (hscaled_sum : C0 + R0 = q ^ n * W0)
    (htail_cube : q ^ 3 ∣ W0 + p * C0 * R0) :
    W0 + p * q * C0 * W0 ≡ p * C0 * C0 [MOD q ^ 3] := by
  have htail0 : W0 + p * C0 * R0 ≡ 0 [MOD q ^ 3] :=
    Nat.modEq_zero_iff_dvd.mpr htail_cube
  have hadd :
      W0 + p * C0 * R0 + p * C0 * C0 ≡
        0 + p * C0 * C0 [MOD q ^ 3] :=
    Nat.ModEq.add htail0 (Nat.ModEq.refl (p * C0 * C0))
  have hsum : C0 + R0 = q * W0 := by
    simpa [hn_one] using hscaled_sum
  have hleft :
      W0 + p * C0 * R0 + p * C0 * C0 =
        W0 + p * q * C0 * W0 := by
    calc
      W0 + p * C0 * R0 + p * C0 * C0 =
          W0 + p * C0 * (C0 + R0) := by ring
      _ = W0 + p * C0 * (q * W0) := by rw [hsum]
      _ = W0 + p * q * C0 * W0 := by ring
  simpa [hleft] using hadd

private lemma tail_signed_first_order_quotient
    {p q A W : ℕ} (hq : q.Prime)
    (hmod1 : W ≡ p * A * A [MOD q])
    (hmod2 : W + p * q * A * W ≡ p * A * A [MOD q ^ 2]) :
    ∃ D : ℤ,
      (W : ℤ) - (p * A * A : ℤ) = (q : ℤ) * D ∧
      D + (p * A * W : ℤ) ≡ 0 [ZMOD q] := by
  have hdiv1 : (q : ℤ) ∣ (W : ℤ) - (p * A * A : ℤ) := by
    simpa using (Nat.modEq_iff_dvd.mp hmod1.symm)
  rcases hdiv1 with ⟨D, hD⟩
  refine ⟨D, hD, ?_⟩
  have hdiv2 : ((q ^ 2 : ℕ) : ℤ) ∣
      (p * A * A : ℤ) - (W + p * q * A * W : ℤ) := by
    simpa using (Nat.modEq_iff_dvd.mp hmod2)
  have hq2_eq : ((q ^ 2 : ℕ) : ℤ) = (q : ℤ) * (q : ℤ) := by
    norm_num [pow_two]
  have hdiff_eq :
      (p * A * A : ℤ) - (W + p * q * A * W : ℤ) =
        -((q : ℤ) * (D + (p * A * W : ℤ))) := by
    linarith
  have hq2_dvd : (q : ℤ) * (q : ℤ) ∣
      (q : ℤ) * (D + (p * A * W : ℤ)) := by
    rw [← hq2_eq]
    have hneg : ((q ^ 2 : ℕ) : ℤ) ∣
        -((q : ℤ) * (D + (p * A * W : ℤ))) := by
      simpa [hdiff_eq] using hdiv2
    exact dvd_neg.mp hneg
  have hq_ne_zero_int : (q : ℤ) ≠ 0 := by exact_mod_cast hq.ne_zero
  have hq_dvd : (q : ℤ) ∣ D + (p * A * W : ℤ) := by
    exact (mul_dvd_mul_iff_left hq_ne_zero_int).mp hq2_dvd
  exact Int.modEq_zero_iff_dvd.mpr hq_dvd

private lemma tail_signed_first_order_quotient_unit
    {p q A W : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p < q)
    (hqA : ¬ q ∣ A) (hqW : ¬ q ∣ W)
    (hmod1 : W ≡ p * A * A [MOD q])
    (hmod2 : W + p * q * A * W ≡ p * A * A [MOD q ^ 2]) :
    ∃ D : ℤ,
      (W : ℤ) - (p * A * A : ℤ) = (q : ℤ) * D ∧
      D + (p * A * W : ℤ) ≡ 0 [ZMOD q] ∧
      ¬ (q : ℤ) ∣ D := by
  rcases tail_signed_first_order_quotient hq hmod1 hmod2 with
    ⟨D, hD, hDmod⟩
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hq_not_B_nat : ¬ q ∣ p * A * W := by
    intro hdiv
    have hdiv' : q ∣ p * (A * W) := by simpa [mul_assoc] using hdiv
    rcases hq.dvd_mul.mp hdiv' with hqp | hqAW
    · exact hq_not_p hqp
    · rcases hq.dvd_mul.mp hqAW with hqA' | hqW'
      · exact hqA hqA'
      · exact hqW hqW'
  have hq_not_B_int : ¬ (q : ℤ) ∣ (p * A * W : ℤ) := by
    intro hdiv
    exact hq_not_B_nat (Int.natCast_dvd_natCast.mp hdiv)
  have hq_not_D : ¬ (q : ℤ) ∣ D := by
    intro hqD
    have hqDplus : (q : ℤ) ∣ D + (p * A * W : ℤ) :=
      Int.modEq_zero_iff_dvd.mp hDmod
    have hqB : (q : ℤ) ∣ (p * A * W : ℤ) := by
      have hsub : (q : ℤ) ∣ (D + (p * A * W : ℤ)) - D :=
        dvd_sub hqDplus hqD
      simpa using hsub
    exact hq_not_B_int hqB
  exact ⟨D, hD, hDmod, hq_not_D⟩

private lemma tail_signed_first_order_exact
    {p q A W Z0 : ℕ} (hq5 : 5 ≤ q) {D : ℤ}
    (hD : (W : ℤ) - (p * A * A : ℤ) = (q : ℤ) * D)
    (htail : W + p * q * A * W =
      p * A * A + q ^ (q - 2) * Z0) :
    D + (p * A * W : ℤ) = (q : ℤ) ^ (q - 3) * (Z0 : ℤ) := by
  have htail_int :
      (W : ℤ) + (p * q * A * W : ℤ) =
        (p * A * A : ℤ) + ((q ^ (q - 2) * Z0 : ℕ) : ℤ) := by
    exact_mod_cast htail
  have hmain :
      ((W : ℤ) - (p * A * A : ℤ)) + (p * q * A * W : ℤ) =
        ((q ^ (q - 2) * Z0 : ℕ) : ℤ) := by
    linarith
  have hleft :
      ((W : ℤ) - (p * A * A : ℤ)) + (p * q * A * W : ℤ) =
        (q : ℤ) * (D + (p * A * W : ℤ)) := by
    rw [hD]
    ring
  have hpow_split :
      (q : ℤ) ^ (q - 2) = (q : ℤ) * (q : ℤ) ^ (q - 3) := by
    rw [show q - 2 = (q - 3) + 1 by omega]
    rw [pow_succ]
    ring
  have hright : ((q ^ (q - 2) * Z0 : ℕ) : ℤ) =
      (q : ℤ) * ((q : ℤ) ^ (q - 3) * (Z0 : ℤ)) := by
    norm_num
    rw [hpow_split]
    ring
  have hscaled :
      (q : ℤ) * (D + (p * A * W : ℤ)) =
        (q : ℤ) * ((q : ℤ) ^ (q - 3) * (Z0 : ℤ)) := by
    rw [← hleft, hmain, hright]
  have hq_ne_zero_int : (q : ℤ) ≠ 0 := by
    have hq_ne_zero : q ≠ 0 := by omega
    exact_mod_cast hq_ne_zero
  exact mul_left_cancel₀ hq_ne_zero_int hscaled

private lemma tail_signed_first_order_pair_relation
    {p q C R W : ℕ} {DC DR : ℤ} (hq : q.Prime)
    (hsum : C + R = q * W)
    (hDC : (W : ℤ) - (p * C * C : ℤ) = (q : ℤ) * DC)
    (hDR : (W : ℤ) - (p * R * R : ℤ) = (q : ℤ) * DR) :
    DC - DR = (p * W : ℤ) * ((R : ℤ) - (C : ℤ)) := by
  have hsum_int : (C : ℤ) + (R : ℤ) = (q : ℤ) * (W : ℤ) := by
    exact_mod_cast hsum
  have hscaled :
      (q : ℤ) * (DC - DR) =
        (q : ℤ) * ((p * W : ℤ) * ((R : ℤ) - (C : ℤ))) := by
    have hdiff : (q : ℤ) * DC - (q : ℤ) * DR =
        (p * R * R : ℤ) - (p * C * C : ℤ) := by
      linarith
    calc
      (q : ℤ) * (DC - DR) = (q : ℤ) * DC - (q : ℤ) * DR := by ring
      _ = (p * R * R : ℤ) - (p * C * C : ℤ) := hdiff
      _ = (p : ℤ) * ((R : ℤ) - (C : ℤ)) * ((R : ℤ) + (C : ℤ)) := by
        ring
      _ = (p : ℤ) * ((R : ℤ) - (C : ℤ)) * ((q : ℤ) * (W : ℤ)) := by
        rw [show (R : ℤ) + (C : ℤ) = (q : ℤ) * (W : ℤ) by linarith]
      _ = (q : ℤ) * ((p * W : ℤ) * ((R : ℤ) - (C : ℤ))) := by
        ring
  have hq_ne_zero_int : (q : ℤ) ≠ 0 := by exact_mod_cast hq.ne_zero
  exact mul_left_cancel₀ hq_ne_zero_int hscaled

private lemma scaled_sum_signed_difference_unit
    {q C R W : ℕ} (hq : q.Prime) (hq_ne_two : q ≠ 2)
    (hsum : C + R = q * W) (hqR : ¬ q ∣ R) :
    ¬ (q : ℤ) ∣ (R : ℤ) - (C : ℤ) := by
  intro hdiff
  have hsum_dvd : (q : ℤ) ∣ (C : ℤ) + (R : ℤ) := by
    refine ⟨W, ?_⟩
    exact_mod_cast hsum
  have htwoR_int : (q : ℤ) ∣ (2 * R : ℕ) := by
    have hadd : (q : ℤ) ∣ ((C : ℤ) + (R : ℤ)) + ((R : ℤ) - (C : ℤ)) :=
      dvd_add hsum_dvd hdiff
    have hrewrite :
        ((C : ℤ) + (R : ℤ)) + ((R : ℤ) - (C : ℤ)) = (2 * R : ℕ) := by
      norm_num
      ring
    rwa [hrewrite] at hadd
  have htwoR_nat : q ∣ 2 * R := Int.natCast_dvd_natCast.mp htwoR_int
  rcases hq.dvd_mul.mp htwoR_nat with hq_two | hq_R
  · exact hq_ne_two ((Nat.prime_dvd_prime_iff_eq hq Nat.prime_two).mp hq_two)
  · exact hqR hq_R

private lemma tail_signed_first_order_pair_difference_unit
    {p q C R W : ℕ} {DC DR : ℤ} (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q) (hsum : C + R = q * W)
    (hqR : ¬ q ∣ R) (hqW : ¬ q ∣ W)
    (hrel : DC - DR = (p * W : ℤ) * ((R : ℤ) - (C : ℤ))) :
    ¬ (q : ℤ) ∣ DC - DR := by
  intro hdiff
  have hq_not_p_int : ¬ (q : ℤ) ∣ (p : ℤ) := by
    intro hdiv
    have hdiv_nat : q ∣ p := Int.natCast_dvd_natCast.mp hdiv
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hdiv_nat)
  have hq_not_W_int : ¬ (q : ℤ) ∣ (W : ℤ) := by
    intro hdiv
    exact hqW (Int.natCast_dvd_natCast.mp hdiv)
  have hq_not_pW_int : ¬ (q : ℤ) ∣ (p * W : ℤ) := by
    intro hdiv
    have hdiv' : (q : ℤ) ∣ (p : ℤ) * (W : ℤ) := by
      simpa using hdiv
    rcases (Prime.dvd_mul (Nat.prime_iff_prime_int.mp hq)).mp hdiv' with hp_div | hW_div
    · exact hq_not_p_int hp_div
    · exact hq_not_W_int hW_div
  have hq_not_diff_int : ¬ (q : ℤ) ∣ (R : ℤ) - (C : ℤ) :=
    scaled_sum_signed_difference_unit hq (by have hp2 := hp.two_le; omega) hsum hqR
  have hprod : (q : ℤ) ∣ (p * W : ℤ) * ((R : ℤ) - (C : ℤ)) := by
    simpa [hrel] using hdiff
  rcases (Prime.dvd_mul (Nat.prime_iff_prime_int.mp hq)).mp hprod with hpW_div | hRC_div
  · exact hq_not_pW_int hpW_div
  · exact hq_not_diff_int hRC_div

private lemma quotient_linearized_first_order_mod
    {c r p q n C0 R0 s u V : ℕ}
    (hp : p.Prime) (hq : q.Prime) (hpq : p < q) (hn_pos : 0 < n)
    (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hc_eq : c - 1 = q ^ n * (p * C0))
    (hr_eq : r - 1 = q ^ n * (p * R0))
    (hspow : r ^ p = q + c * s)
    (hs_eq : s = q * u + 1)
    (hlin : q + s - 1 = p * q ^ n * V) :
    V + C0 ≡ p * R0 [MOD q] := by
  let P := q ^ n
  let M := q ^ (n + 1)
  have hP_ne_zero : P ≠ 0 := pow_ne_zero n hq.ne_zero
  have hpow_succ : M = P * q := by
    dsimp [M, P]
    rw [pow_succ]
  have hc_form : c = 1 + P * (p * C0) := by
    dsimp [P]
    omega
  have hr_form : r = 1 + P * (p * R0) := by
    dsimp [P]
    omega
  have hge_linear : 1 + p * (P * (p * R0)) ≤ r ^ p := by
    rw [hr_form]
    simpa [P] using one_add_mul_le_one_add_pow (q ^ n * (p * R0)) p
  have hlhs :
      r ^ p ≡ 1 + p * (P * (p * R0)) [MOD M] := by
    have hdiv :
        M ∣ r ^ p - (1 + p * (P * (p * R0))) := by
      simpa [M, P, hr_form] using
        one_add_scaled_pow_sub_linear_dvd_prime_succ q n (p * R0) p hn_pos
    exact ((Nat.modEq_iff_dvd' hge_linear).mpr hdiv).symm
  have hqu : q * (u + 1) = p * P * V := by
    have hq_s_pred : q + s - 1 = q * (u + 1) := by
      rw [hs_eq]
      calc
        q + (q * u + 1) - 1 = (q + q * u) + 1 - 1 := by ring
        _ = q + q * u := Nat.add_sub_cancel (q + q * u) 1
        _ = q * (u + 1) := by ring
    rw [← hq_s_pred, hlin]
  have hrhs_eq :
      q + c * s =
        1 + P * (p * (V + C0)) + M * (p * C0 * u) := by
    rw [hc_form, hs_eq, hpow_succ]
    dsimp [P] at hqu ⊢
    nlinarith [hqu]
  have hrhs :
      q + c * s ≡ 1 + P * (p * (V + C0)) [MOD M] := by
    rw [hrhs_eq]
    have hzero : M * (p * C0 * u) ≡ 0 [MOD M] :=
      Nat.modEq_zero_iff_dvd.mpr (dvd_mul_right M (p * C0 * u))
    simpa [add_assoc, add_comm, add_left_comm] using
      Nat.ModEq.add (Nat.ModEq.refl (1 + P * (p * (V + C0)))) hzero
  have hsame_add :
      1 + P * (p * (p * R0)) ≡ 1 + P * (p * (V + C0)) [MOD M] := by
    have hstep : 1 + p * (P * (p * R0)) ≡
        1 + P * (p * (V + C0)) [MOD M] :=
      hlhs.symm.trans (by simpa [hspow] using hrhs)
    simpa [mul_assoc, mul_comm, mul_left_comm] using hstep
  have hscaled :
      P * (p * (p * R0)) ≡ P * (p * (V + C0)) [MOD M] :=
    Nat.ModEq.add_left_cancel' 1 hsame_add
  have hcancelP : p * (p * R0) ≡ p * (V + C0) [MOD q] := by
    have hscaled' :
        P * (p * (p * R0)) ≡ P * (p * (V + C0)) [MOD P * q] := by
      simpa [hpow_succ] using hscaled
    exact Nat.ModEq.mul_left_cancel' hP_ne_zero hscaled'
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hcop_qp : Nat.Coprime q p :=
    (hq.coprime_iff_not_dvd).mpr hq_not_p
  have hcancelp : p * R0 ≡ V + C0 [MOD q] := by
    exact Nat.ModEq.cancel_left_of_coprime hcop_qp hcancelP
  exact hcancelp.symm

private lemma quotient_p_dvd_V_add_C0_mul_s
    {c r p q n C0 R0 s V : ℕ}
    (hp : p.Prime) (hq : q.Prime) (hn_pos : 0 < n)
    (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hc_eq : c - 1 = q ^ n * (p * C0))
    (hr_eq : r - 1 = q ^ n * (p * R0))
    (hspow : r ^ p = q + c * s)
    (hlin : q + s - 1 = p * q ^ n * V) :
    p ∣ V + C0 * s := by
  let P := p * q ^ n
  have hP_pos : 0 < P := by
    dsimp [P]
    exact Nat.mul_pos hp.pos (pow_pos hq.pos n)
  have hr_form : r = 1 + q ^ n * (p * R0) := by omega
  have hc_form : c = 1 + q ^ n * (p * C0) := by omega
  have hr_form' : r = 1 + P * R0 := by
    rw [hr_form]
    dsimp [P]
    ring
  rcases exists_pow_one_add_eq_linear_add_sq (P * R0) p with ⟨L, hL⟩
  have hhigh : P * p ∣ r ^ p - 1 := by
    rw [hr_form', hL]
    have hsub :
        (1 + p * (P * R0) + (P * R0) ^ 2 * L) - 1 =
          p * (P * R0) + (P * R0) ^ 2 * L := by omega
    rw [hsub]
    have hfirst : P * p ∣ p * (P * R0) := by
      refine ⟨R0, ?_⟩
      ring
    have hsecond : P * p ∣ (P * R0) ^ 2 * L := by
      refine ⟨q ^ n * R0 ^ 2 * L, ?_⟩
      dsimp [P]
      ring
    exact dvd_add hfirst hsecond
  have htail_eq : r ^ p - 1 = P * (V + C0 * s) := by
    have htail_split :
        q + c * s - 1 = (q + s - 1) + q ^ n * (p * C0) * s := by
      rw [hc_form]
      calc
        q + (1 + q ^ n * (p * C0)) * s - 1 =
            q + (s + q ^ n * (p * C0) * s) - 1 := by ring
        _ = (q + s - 1) + q ^ n * (p * C0) * s := by
          have hqs : 1 ≤ q + s :=
            Nat.succ_le_of_lt (Nat.add_pos_left hq.pos s)
          rw [show q + (s + q ^ n * (p * C0) * s) =
              q ^ n * (p * C0) * s + (q + s) by ring]
          rw [Nat.add_sub_assoc hqs]
          ring
    calc
      r ^ p - 1 = q + c * s - 1 := by rw [hspow]
      _ = (q + s - 1) + q ^ n * (p * C0) * s := htail_split
      _ = p * q ^ n * V + q ^ n * (p * C0) * s := by rw [hlin]
      _ = P * (V + C0 * s) := by
        dsimp [P]
        ring
  have hscaled : P * p ∣ P * (V + C0 * s) := by
    rwa [htail_eq] at hhigh
  exact (Nat.mul_dvd_mul_iff_left hP_pos).mp hscaled

private lemma quotient_V_C0_mod_p
    {p q C0 s V : ℕ}
    (hp_dvd : p ∣ V + C0 * s)
    (hq_s_modeq_one_p : q + s ≡ 1 [MOD p]) :
    V + C0 ≡ q * C0 [MOD p] := by
  have hzero : V + C0 * s ≡ 0 [MOD p] :=
    Nat.modEq_zero_iff_dvd.mpr hp_dvd
  have hC_qs : C0 * (q + s) ≡ C0 * 1 [MOD p] :=
    Nat.ModEq.mul_left C0 hq_s_modeq_one_p
  have hC_split : C0 * s + q * C0 ≡ C0 [MOD p] := by
    simpa [left_distrib, right_distrib, mul_assoc, mul_comm,
      mul_left_comm, add_assoc, add_comm, add_left_comm] using hC_qs
  have hsum_left :
      V + (C0 * s + q * C0) ≡ V + C0 [MOD p] :=
    Nat.ModEq.add_left V hC_split
  have hsum_right :
      V + (C0 * s + q * C0) ≡ q * C0 [MOD p] := by
    have h := Nat.ModEq.add hzero (Nat.ModEq.refl (q * C0))
    simpa [add_assoc, add_comm, add_left_comm] using h
  exact hsum_left.symm.trans hsum_right

private lemma quotient_depth_one_second_order_mod
    {c r p q C0 R0 s u V : ℕ}
    (hp : p.Prime) (hq : q.Prime) (hpq : p < q)
    (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hc_eq : c - 1 = q * (p * C0))
    (hr_eq : r - 1 = q * (p * R0))
    (hspow : r ^ p = q + c * s)
    (hs_eq : s = q * u + 1)
    (hlin : q + s - 1 = p * q * V) :
    p * R0 + q * (p * Nat.choose p 2 * R0 * R0) ≡
      V + C0 + q * C0 * u [MOD q ^ 2] := by
  let A := p * R0
  have hq_ne_zero : q ≠ 0 := hq.ne_zero
  have hc_form : c = 1 + q * (p * C0) := by omega
  have hr_form : r = 1 + q * A := by
    dsimp [A]
    omega
  rcases exists_pow_one_add_eq_quadratic_add_cube (q * A) p with
    ⟨L, hL⟩
  have hlhs :
      r ^ p ≡
        1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A)
          [MOD q ^ 3] := by
    rw [hr_form, hL]
    have hzero : (q * A) ^ 3 * L ≡ 0 [MOD q ^ 3] := by
      have hdiv : q ^ 3 ∣ (q * A) ^ 3 * L := by
        have hpow : (q * A) ^ 3 = q ^ 3 * A ^ 3 := by ring_nf
        rw [hpow]
        simpa [mul_assoc] using dvd_mul_right (q ^ 3) (A ^ 3 * L)
      exact Nat.modEq_zero_iff_dvd.mpr hdiv
    have hbase :
        1 + p * (q * A) + Nat.choose p 2 * (q * A) ^ 2
          ≡
        1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A)
          [MOD q ^ 3] := by
      have heq :
          1 + p * (q * A) + Nat.choose p 2 * (q * A) ^ 2 =
            1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) := by
        ring_nf
      exact heq ▸ Nat.ModEq.refl _
    have hwith_zero :
        (1 + p * (q * A) + Nat.choose p 2 * (q * A) ^ 2) +
            (q * A) ^ 3 * L
          ≡
        (1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A)) + 0
          [MOD q ^ 3] :=
      Nat.ModEq.add hbase hzero
    simpa [add_assoc, mul_assoc, mul_comm, mul_left_comm] using hwith_zero
  have hqu : q * (u + 1) = p * q * V := by
    have hq_s_pred : q + s - 1 = q * (u + 1) := by
      rw [hs_eq]
      calc
        q + (q * u + 1) - 1 = (q + q * u) + 1 - 1 := by ring
        _ = q + q * u := Nat.add_sub_cancel (q + q * u) 1
        _ = q * (u + 1) := by ring
    rw [← hq_s_pred, hlin]
  have hrhs_eq :
      q + c * s =
        1 + q * (p * (V + C0)) + q ^ 2 * (p * C0 * u) := by
    rw [hc_form, hs_eq]
    nlinarith [hqu]
  have hrhs :
      q + c * s ≡
        1 + q * (p * (V + C0)) + q ^ 2 * (p * C0 * u)
          [MOD q ^ 3] := by
    rw [hrhs_eq]
  have hsame_add :
      1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) ≡
        1 + q * (p * (V + C0)) + q ^ 2 * (p * C0 * u)
          [MOD q ^ 3] :=
    hlhs.symm.trans (by simpa [hspow] using hrhs)
  have hsame :
      q * (p * A + q * (Nat.choose p 2 * A * A)) ≡
        q * (p * (V + C0) + q * (p * C0 * u)) [MOD q * q ^ 2] := by
    have hcancel_one :
        q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) ≡
          q * (p * (V + C0)) + q ^ 2 * (p * C0 * u)
            [MOD q ^ 3] := by
      have hgrouped :
          1 + (q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A)) ≡
            1 + (q * (p * (V + C0)) + q ^ 2 * (p * C0 * u))
              [MOD q ^ 3] := by
        simpa [add_assoc] using hsame_add
      exact Nat.ModEq.add_left_cancel' 1 hgrouped
    have hmod : q ^ 3 = q * q ^ 2 := by ring
    have hcancel_one' :
        q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) ≡
          q * (p * (V + C0)) + q ^ 2 * (p * C0 * u)
            [MOD q * q ^ 2] := by
      simpa [hmod] using hcancel_one
    convert hcancel_one' using 1
    · ring
    · ring
  have hcancelq :
      p * A + q * (Nat.choose p 2 * A * A) ≡
        p * (V + C0) + q * (p * C0 * u) [MOD q ^ 2] :=
    Nat.ModEq.mul_left_cancel' hq_ne_zero hsame
  have hp_scaled :
      p * (p * R0 + q * (p * Nat.choose p 2 * R0 * R0)) ≡
        p * (V + C0 + q * C0 * u) [MOD q ^ 2] := by
    simpa [A, left_distrib, mul_assoc, mul_comm, mul_left_comm] using hcancelq
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hcop_qp : Nat.Coprime q p :=
    (hq.coprime_iff_not_dvd).mpr hq_not_p
  have hcop_q2p : Nat.Coprime (q ^ 2) p :=
    hcop_qp.pow_left 2
  exact Nat.ModEq.cancel_left_of_coprime hcop_q2p hp_scaled

private lemma quotient_depth_one_second_order_exact
    {c r p q C0 R0 s u V : ℕ}
    (hp : p.Prime) (hq : q.Prime)
    (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hc_eq : c - 1 = q * (p * C0))
    (hr_eq : r - 1 = q * (p * R0))
    (hspow : r ^ p = q + c * s)
    (hs_eq : s = q * u + 1)
    (hlin : q + s - 1 = p * q * V) :
    ∃ L : ℕ,
      p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L =
        V + C0 + q * C0 * u := by
  let A := p * R0
  have hc_form : c = 1 + q * (p * C0) := by omega
  have hr_form : r = 1 + q * A := by
    dsimp [A]
    omega
  rcases exists_pow_one_add_eq_quadratic_add_cube (q * A) p with
    ⟨L0, hL0⟩
  have hlhs :
      r ^ p =
        1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) +
          q ^ 3 * (A ^ 3 * L0) := by
    rw [hr_form, hL0]
    ring_nf
  have hqu : u + 1 = p * V := by
    have hq_s_pred : q + s - 1 = q * (u + 1) := by
      rw [hs_eq]
      calc
        q + (q * u + 1) - 1 = (q + q * u) + 1 - 1 := by ring
        _ = q + q * u := Nat.add_sub_cancel (q + q * u) 1
        _ = q * (u + 1) := by ring
    have hscaled : q * (u + 1) = q * (p * V) := by
      calc
        q * (u + 1) = q + s - 1 := hq_s_pred.symm
        _ = p * q * V := hlin
        _ = q * (p * V) := by ring
    exact Nat.mul_left_cancel hq.pos hscaled
  have hrhs :
      q + c * s =
        1 + q * (p * (V + C0)) + q ^ 2 * (p * C0 * u) := by
    rw [hc_form, hs_eq]
    nlinarith [hqu]
  have hsame :
      1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) +
          q ^ 3 * (A ^ 3 * L0) =
        1 + q * (p * (V + C0)) + q ^ 2 * (p * C0 * u) := by
    rw [← hlhs, hspow, hrhs]
  have hsame_no_one :
      q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) +
          q ^ 3 * (A ^ 3 * L0) =
        q * (p * (V + C0)) + q ^ 2 * (p * C0 * u) := by
    have hgroup :
        1 + (q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) +
            q ^ 3 * (A ^ 3 * L0)) =
          1 + (q * (p * (V + C0)) + q ^ 2 * (p * C0 * u)) := by
      simpa [add_assoc] using hsame
    exact Nat.add_left_cancel hgroup
  have hq_cancel :
      p * A + q * (Nat.choose p 2 * A * A) + q ^ 2 * (A ^ 3 * L0) =
        p * (V + C0) + q * (p * C0 * u) := by
    have hgroup :
        q * (p * A + q * (Nat.choose p 2 * A * A) +
            q ^ 2 * (A ^ 3 * L0)) =
          q * (p * (V + C0) + q * (p * C0 * u)) := by
      convert hsame_no_one using 1 <;> ring
    exact Nat.mul_left_cancel hq.pos hgroup
  refine ⟨p ^ 2 * R0 ^ 3 * L0, ?_⟩
  apply Nat.mul_left_cancel hp.pos
  calc
    p * (p * R0 + q * (p * Nat.choose p 2 * R0 * R0) +
        q ^ 2 * (p ^ 2 * R0 ^ 3 * L0))
        = p * A + q * (Nat.choose p 2 * A * A) + q ^ 2 * (A ^ 3 * L0) := by
          dsimp [A]
          ring
    _ = p * (V + C0) + q * (p * C0 * u) := hq_cancel
    _ = p * (V + C0 + q * C0 * u) := by ring

private lemma quotient_depth_one_third_order_exact
    {c r p q C0 R0 s u V : ℕ}
    (hp : p.Prime) (hq : q.Prime)
    (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hc_eq : c - 1 = q * (p * C0))
    (hr_eq : r - 1 = q * (p * R0))
    (hspow : r ^ p = q + c * s)
    (hs_eq : s = q * u + 1)
    (hlin : q + s - 1 = p * q * V) :
    ∃ L : ℕ,
      p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L =
          V + C0 + q * C0 * u ∧
        L ≡ p ^ 2 * Nat.choose p 3 * R0 ^ 3 [MOD q] := by
  let A := p * R0
  have hc_form : c = 1 + q * (p * C0) := by omega
  have hr_form : r = 1 + q * A := by
    dsimp [A]
    omega
  rcases exists_pow_one_add_eq_cubic_add_quartic (q * A) p with
    ⟨L0, hL0⟩
  have hlhs :
      r ^ p =
        1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) +
          q ^ 3 * (Nat.choose p 3 * A ^ 3) + q ^ 4 * (A ^ 4 * L0) := by
    rw [hr_form, hL0]
    ring_nf
  have hqu : u + 1 = p * V := by
    have hq_s_pred : q + s - 1 = q * (u + 1) := by
      rw [hs_eq]
      calc
        q + (q * u + 1) - 1 = (q + q * u) + 1 - 1 := by ring
        _ = q + q * u := Nat.add_sub_cancel (q + q * u) 1
        _ = q * (u + 1) := by ring
    have hscaled : q * (u + 1) = q * (p * V) := by
      calc
        q * (u + 1) = q + s - 1 := hq_s_pred.symm
        _ = p * q * V := hlin
        _ = q * (p * V) := by ring
    exact Nat.mul_left_cancel hq.pos hscaled
  have hrhs :
      q + c * s =
        1 + q * (p * (V + C0)) + q ^ 2 * (p * C0 * u) := by
    rw [hc_form, hs_eq]
    nlinarith [hqu]
  have hsame :
      1 + q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) +
          q ^ 3 * (Nat.choose p 3 * A ^ 3) + q ^ 4 * (A ^ 4 * L0) =
        1 + q * (p * (V + C0)) + q ^ 2 * (p * C0 * u) := by
    rw [← hlhs, hspow, hrhs]
  have hsame_no_one :
      q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) +
          q ^ 3 * (Nat.choose p 3 * A ^ 3) + q ^ 4 * (A ^ 4 * L0) =
        q * (p * (V + C0)) + q ^ 2 * (p * C0 * u) := by
    have hgroup :
        1 + (q * (p * A) + q ^ 2 * (Nat.choose p 2 * A * A) +
            q ^ 3 * (Nat.choose p 3 * A ^ 3) + q ^ 4 * (A ^ 4 * L0)) =
          1 + (q * (p * (V + C0)) + q ^ 2 * (p * C0 * u)) := by
      simpa [add_assoc] using hsame
    exact Nat.add_left_cancel hgroup
  have hq_cancel :
      p * A + q * (Nat.choose p 2 * A * A) +
          q ^ 2 * (Nat.choose p 3 * A ^ 3) + q ^ 3 * (A ^ 4 * L0) =
        p * (V + C0) + q * (p * C0 * u) := by
    have hgroup :
        q * (p * A + q * (Nat.choose p 2 * A * A) +
            q ^ 2 * (Nat.choose p 3 * A ^ 3) + q ^ 3 * (A ^ 4 * L0)) =
          q * (p * (V + C0) + q * (p * C0 * u)) := by
      convert hsame_no_one using 1 <;> ring
    exact Nat.mul_left_cancel hq.pos hgroup
  let L := p ^ 2 * Nat.choose p 3 * R0 ^ 3 + q * p ^ 3 * R0 ^ 4 * L0
  refine ⟨L, ?_, ?_⟩
  · apply Nat.mul_left_cancel hp.pos
    calc
      p * (p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L)
          = p * A + q * (Nat.choose p 2 * A * A) +
              q ^ 2 * (Nat.choose p 3 * A ^ 3) + q ^ 3 * (A ^ 4 * L0) := by
            dsimp [A, L]
            ring
      _ = p * (V + C0) + q * (p * C0 * u) := hq_cancel
      _ = p * (V + C0 + q * C0 * u) := by ring
  · dsimp [L]
    have hzero : q * p ^ 3 * R0 ^ 4 * L0 ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr (by
        refine ⟨p ^ 3 * R0 ^ 4 * L0, ?_⟩
        ring)
    simpa [add_assoc, add_comm, add_left_comm] using
      Nat.ModEq.add (Nat.ModEq.refl (p ^ 2 * Nat.choose p 3 * R0 ^ 3)) hzero

private lemma quotient_V_combo_depth_one_second_order_mod
    {p q C0 R0 W0 u V : ℕ}
    (hscaled_sum_one : C0 + R0 = q * W0)
    (hdepth_second :
      p * R0 + q * (p * Nat.choose p 2 * R0 * R0) ≡
        V + C0 + q * C0 * u [MOD q ^ 2]) :
    V + (p + 1) * C0 + q * C0 * u ≡
      q * (p * W0 + p * Nat.choose p 2 * R0 * R0) [MOD q ^ 2] := by
  let K := p * Nat.choose p 2 * R0 * R0
  have hadd :
      p * R0 + q * K + p * C0 ≡
        V + C0 + q * C0 * u + p * C0 [MOD q ^ 2] := by
    simpa [K, add_assoc, add_comm, add_left_comm] using
      Nat.ModEq.add hdepth_second (Nat.ModEq.refl (p * C0))
  have hleft_eq :
      p * R0 + q * K + p * C0 = q * (p * W0 + K) := by
    calc
      p * R0 + q * K + p * C0 = p * (C0 + R0) + q * K := by ring
      _ = p * (q * W0) + q * K := by rw [hscaled_sum_one]
      _ = q * (p * W0 + K) := by ring
  rw [hleft_eq] at hadd
  exact_mod_cast (by
    simpa [K, add_assoc, add_comm, add_left_comm, mul_add, mul_assoc, mul_comm,
      mul_left_comm] using hadd.symm)

private lemma quotient_depth_one_second_order_p_factor_quotient
    {p q C0 R0 u V L : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q) (hR0_pos : 0 < R0) (hqR0 : ¬ q ∣ R0)
    (hV_C0_mod_p : V + C0 ≡ q * C0 [MOD p])
    (hu_succ : u + 1 = p * V)
    (hdepth :
      p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L =
        V + C0 + q * C0 * u) :
    ∃ T1 : ℕ, 0 < T1 ∧
      V + C0 + q * C0 * u = p * T1 ∧
      T1 ≡ R0 [MOD q] ∧ ¬ q ∣ T1 := by
  have hbase_mod :
      V + C0 + q * C0 * u ≡ q * C0 + q * C0 * u [MOD p] :=
    Nat.ModEq.add_right (q * C0 * u) hV_C0_mod_p
  have hright_zero : q * C0 + q * C0 * u ≡ 0 [MOD p] := by
    have heq : q * C0 + q * C0 * u = q * C0 * (u + 1) := by ring
    rw [heq, hu_succ]
    exact Nat.modEq_zero_iff_dvd.mpr (by
      refine ⟨q * C0 * V, ?_⟩
      ring)
  have hp_dvd_rhs : p ∣ V + C0 + q * C0 * u :=
    Nat.modEq_zero_iff_dvd.mp (hbase_mod.trans hright_zero)
  have hp_dvd_left :
      p ∣ p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L := by
    rw [hdepth]
    exact hp_dvd_rhs
  let Ppart := p * R0 + q * (p * Nat.choose p 2 * R0 * R0)
  have hp_dvd_Ppart : p ∣ Ppart := by
    dsimp [Ppart]
    refine Nat.dvd_add (dvd_mul_right p R0) ?_
    refine ⟨q * Nat.choose p 2 * R0 * R0, ?_⟩
    ring
  have hdiff :
      (p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L) -
        Ppart = q ^ 2 * L := by
    dsimp [Ppart]
    omega
  have hp_dvd_q2L : p ∣ q ^ 2 * L := by
    have hsub := Nat.dvd_sub hp_dvd_left hp_dvd_Ppart
    rwa [hdiff] at hsub
  have hp_not_q : ¬ p ∣ q := by
    intro hpq_dvd
    have hp_eq_q : p = q := (Nat.prime_dvd_prime_iff_eq hp hq).mp hpq_dvd
    omega
  have hp_not_q2 : ¬ p ∣ q ^ 2 := by
    intro hpq2
    exact hp_not_q (hp.dvd_of_dvd_pow hpq2)
  have hpL : p ∣ L :=
    (hp.dvd_mul.mp hp_dvd_q2L).resolve_left hp_not_q2
  rcases hpL with ⟨L0, hL⟩
  refine ⟨R0 + q * (Nat.choose p 2 * R0 * R0) + q ^ 2 * L0, ?_, ?_, ?_, ?_⟩
  · omega
  · calc
      V + C0 + q * C0 * u =
          p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L := hdepth.symm
      _ = p * (R0 + q * (Nat.choose p 2 * R0 * R0) + q ^ 2 * L0) := by
        rw [hL]
        ring
  · have hzero1 : q * (Nat.choose p 2 * R0 * R0) ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr
        (dvd_mul_right q (Nat.choose p 2 * R0 * R0))
    have hzero2 : q ^ 2 * L0 ≡ 0 [MOD q] := by
      exact Nat.modEq_zero_iff_dvd.mpr
        ((dvd_pow_self q (by norm_num : 2 ≠ 0)).trans
          (dvd_mul_right (q ^ 2) L0))
    have hmod := Nat.ModEq.add
      (Nat.ModEq.add (Nat.ModEq.refl R0) hzero1) hzero2
    simpa [add_assoc, add_comm, add_left_comm] using hmod
  · intro hqT1
    have hT1_mod_zero :
        R0 + q * (Nat.choose p 2 * R0 * R0) + q ^ 2 * L0 ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr hqT1
    have hR0_zero : R0 ≡ 0 [MOD q] := by
      have hmod :
          R0 + q * (Nat.choose p 2 * R0 * R0) + q ^ 2 * L0 ≡
            R0 [MOD q] := by
        have hzero1 : q * (Nat.choose p 2 * R0 * R0) ≡ 0 [MOD q] :=
          Nat.modEq_zero_iff_dvd.mpr
            (dvd_mul_right q (Nat.choose p 2 * R0 * R0))
        have hzero2 : q ^ 2 * L0 ≡ 0 [MOD q] := by
          exact Nat.modEq_zero_iff_dvd.mpr
            ((dvd_pow_self q (by norm_num : 2 ≠ 0)).trans
              (dvd_mul_right (q ^ 2) L0))
        have htmp := Nat.ModEq.add
          (Nat.ModEq.add (Nat.ModEq.refl R0) hzero1) hzero2
        simpa [add_assoc, add_comm, add_left_comm] using htmp
      exact hmod.symm.trans hT1_mod_zero
    exact hqR0 (Nat.modEq_zero_iff_dvd.mp hR0_zero)

private lemma prime_not_dvd_choose_two_of_lt
    {p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p < q) :
    ¬ q ∣ Nat.choose p 2 := by
  intro hdiv
  have hp_gt_one : 1 < p := hp.one_lt
  have htwo : 2 * Nat.choose p 2 = p * (p - 1) := by
    rw [Nat.choose_two_right]
    rw [mul_comm]
    exact Nat.div_two_mul_two_of_even (Nat.even_mul_pred_self p)
  have hq_dvd_prod : q ∣ p * (p - 1) := by
    rw [← htwo]
    exact dvd_mul_of_dvd_right hdiv 2
  rcases hq.dvd_mul.mp hq_dvd_prod with hq_p | hq_p_pred
  · have hle : q ≤ p := Nat.le_of_dvd hp.pos hq_p
    omega
  · have hpred_pos : 0 < p - 1 := by omega
    have hle : q ≤ p - 1 := Nat.le_of_dvd hpred_pos hq_p_pred
    omega

private lemma prime_not_dvd_choose_three_of_lt
    {p q : ℕ} (hq : q.Prime) (hp5 : 5 ≤ p) (hpq : p < q) :
    ¬ q ∣ Nat.choose p 3 := by
  intro hdiv
  have hchoose_ne_zero : Nat.choose p 3 ≠ 0 := by
    exact Nat.choose_ne_zero (by omega : 3 ≤ p)
  have hfactor_pos : (Nat.choose p 3).factorization q ≠ 0 :=
    ne_of_gt (hq.factorization_pos_of_dvd hchoose_ne_zero hdiv)
  have hfactor_zero : (Nat.choose p 3).factorization q = 0 :=
    Nat.factorization_choose_eq_zero_of_lt hpq
  exact hfactor_pos hfactor_zero

private lemma third_order_main_term_q_unit
    {p q R0 : ℕ} (hp : p.Prime) (hq : q.Prime) (hp5 : 5 ≤ p)
    (hpq : p < q) (hqR0 : ¬ q ∣ R0) :
    ¬ q ∣ p ^ 2 * Nat.choose p 3 * R0 ^ 3 := by
  intro hdiv
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hq_not_p2 : ¬ q ∣ p ^ 2 := by
    intro hqp2
    exact hq_not_p (hq.dvd_of_dvd_pow hqp2)
  have hq_not_choose : ¬ q ∣ Nat.choose p 3 :=
    prime_not_dvd_choose_three_of_lt hq hp5 hpq
  have hq_not_R0_pow : ¬ q ∣ R0 ^ 3 := by
    intro hqpow
    exact hqR0 (hq.dvd_of_dvd_pow hqpow)
  have hdiv' : q ∣ (p ^ 2 * Nat.choose p 3) * R0 ^ 3 := by
    simpa [mul_assoc] using hdiv
  rcases hq.dvd_mul.mp hdiv' with hleft | hright
  · rcases hq.dvd_mul.mp hleft with hp2_dvd | hchoose_dvd
    · exact hq_not_p2 hp2_dvd
    · exact hq_not_choose hchoose_dvd
  · exact hq_not_R0_pow hright

private lemma third_order_shift_main_term_q_unit
    {p q R0 : ℕ} (hp : p.Prime) (hq : q.Prime) (hp5 : 5 ≤ p)
    (hpq : p < q) (hqR0 : ¬ q ∣ R0) :
    ¬ q ∣ p * Nat.choose p 3 * R0 ^ 3 := by
  intro hdiv
  exact third_order_main_term_q_unit hp hq hp5 hpq hqR0
    (by
      have hmul := dvd_mul_of_dvd_right hdiv p
      simpa [pow_two, mul_assoc, mul_comm, mul_left_comm] using hmul)

private lemma quotient_depth_one_third_order_p_factor_remainder
    {p q C0 R0 u V L : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hR0_pos : 0 < R0)
    (hqR0 : ¬ q ∣ R0)
    (hV_C0_mod_p : V + C0 ≡ q * C0 [MOD p])
    (hu_succ : u + 1 = p * V)
    (hdepth :
      p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L =
        V + C0 + q * C0 * u)
    (hLmod : L ≡ p ^ 2 * Nat.choose p 3 * R0 ^ 3 [MOD q]) :
    ∃ B : ℕ,
      L = p * B ∧
      B ≡ p * Nat.choose p 3 * R0 ^ 3 [MOD q] ∧
      ¬ q ∣ B := by
  have hp_dvd_L : p ∣ L := by
    have hbase_mod :
        V + C0 + q * C0 * u ≡ q * C0 + q * C0 * u [MOD p] :=
      Nat.ModEq.add_right (q * C0 * u) hV_C0_mod_p
    have hright_zero : q * C0 + q * C0 * u ≡ 0 [MOD p] := by
      have heq : q * C0 + q * C0 * u = q * C0 * (u + 1) := by ring
      rw [heq, hu_succ]
      exact Nat.modEq_zero_iff_dvd.mpr (by
        refine ⟨q * C0 * V, ?_⟩
        ring)
    have hp_dvd_rhs : p ∣ V + C0 + q * C0 * u :=
      Nat.modEq_zero_iff_dvd.mp (hbase_mod.trans hright_zero)
    have hp_dvd_left :
        p ∣ p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L := by
      rw [hdepth]
      exact hp_dvd_rhs
    let Ppart := p * R0 + q * (p * Nat.choose p 2 * R0 * R0)
    have hp_dvd_Ppart : p ∣ Ppart := by
      dsimp [Ppart]
      refine Nat.dvd_add (dvd_mul_right p R0) ?_
      refine ⟨q * Nat.choose p 2 * R0 * R0, ?_⟩
      ring
    have hdiff :
        (p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L) -
          Ppart = q ^ 2 * L := by
      dsimp [Ppart]
      omega
    have hp_dvd_q2L : p ∣ q ^ 2 * L := by
      have hsub := Nat.dvd_sub hp_dvd_left hp_dvd_Ppart
      rwa [hdiff] at hsub
    have hp_not_q : ¬ p ∣ q := by
      intro hpq_dvd
      have hp_eq_q : p = q := (Nat.prime_dvd_prime_iff_eq hp hq).mp hpq_dvd
      omega
    have hp_not_q2 : ¬ p ∣ q ^ 2 := by
      intro hpq2
      exact hp_not_q (hp.dvd_of_dvd_pow hpq2)
    exact (hp.dvd_mul.mp hp_dvd_q2L).resolve_left hp_not_q2
  rcases hp_dvd_L with ⟨B, hL_B⟩
  have hBmod : B ≡ p * Nat.choose p 3 * R0 ^ 3 [MOD q] := by
    have hmod_scaled :
        p * B ≡ p * (p * Nat.choose p 3 * R0 ^ 3) [MOD q] := by
      rw [hL_B] at hLmod
      simpa [pow_two, mul_assoc, mul_comm, mul_left_comm] using hLmod
    have hq_not_p : ¬ q ∣ p := by
      intro hqp
      exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
    have hcop_qp : Nat.Coprime q p :=
      (hq.coprime_iff_not_dvd).mpr hq_not_p
    exact Nat.ModEq.cancel_left_of_coprime hcop_qp hmod_scaled
  refine ⟨B, hL_B, hBmod, ?_⟩
  intro hqB
  have hmain_zero :
      p * Nat.choose p 3 * R0 ^ 3 ≡ 0 [MOD q] :=
    hBmod.symm.trans (Nat.modEq_zero_iff_dvd.mpr hqB)
  exact third_order_shift_main_term_q_unit hp hq hp5 hpq hqR0
    (Nat.modEq_zero_iff_dvd.mp hmain_zero)

private lemma quotient_depth_one_second_order_p_factor_shift
    {p q C0 R0 u V L : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q) (hR0_pos : 0 < R0) (hqR0 : ¬ q ∣ R0)
    (hV_C0_mod_p : V + C0 ≡ q * C0 [MOD p])
    (hu_succ : u + 1 = p * V)
    (hdepth :
      p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L =
        V + C0 + q * C0 * u) :
    ∃ A T1 : ℕ, 0 < A ∧ 0 < T1 ∧
      V + C0 + q * C0 * u = p * T1 ∧
      T1 = R0 + q * A ∧
      (∃ B : ℕ, A = Nat.choose p 2 * R0 * R0 + q * B) ∧
      A ≡ Nat.choose p 2 * R0 * R0 [MOD q] ∧
      ¬ q ∣ A ∧
      T1 ≡ R0 [MOD q] ∧
      ¬ q ∣ T1 := by
  have hbase_mod :
      V + C0 + q * C0 * u ≡ q * C0 + q * C0 * u [MOD p] :=
    Nat.ModEq.add_right (q * C0 * u) hV_C0_mod_p
  have hright_zero : q * C0 + q * C0 * u ≡ 0 [MOD p] := by
    have heq : q * C0 + q * C0 * u = q * C0 * (u + 1) := by ring
    rw [heq, hu_succ]
    exact Nat.modEq_zero_iff_dvd.mpr (by
      refine ⟨q * C0 * V, ?_⟩
      ring)
  have hp_dvd_rhs : p ∣ V + C0 + q * C0 * u :=
    Nat.modEq_zero_iff_dvd.mp (hbase_mod.trans hright_zero)
  have hp_dvd_left :
      p ∣ p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L := by
    rw [hdepth]
    exact hp_dvd_rhs
  let Ppart := p * R0 + q * (p * Nat.choose p 2 * R0 * R0)
  have hp_dvd_Ppart : p ∣ Ppart := by
    dsimp [Ppart]
    refine Nat.dvd_add (dvd_mul_right p R0) ?_
    refine ⟨q * Nat.choose p 2 * R0 * R0, ?_⟩
    ring
  have hdiff :
      (p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L) -
        Ppart = q ^ 2 * L := by
    dsimp [Ppart]
    omega
  have hp_dvd_q2L : p ∣ q ^ 2 * L := by
    have hsub := Nat.dvd_sub hp_dvd_left hp_dvd_Ppart
    rwa [hdiff] at hsub
  have hp_not_q : ¬ p ∣ q := by
    intro hpq_dvd
    have hp_eq_q : p = q := (Nat.prime_dvd_prime_iff_eq hp hq).mp hpq_dvd
    omega
  have hp_not_q2 : ¬ p ∣ q ^ 2 := by
    intro hpq2
    exact hp_not_q (hp.dvd_of_dvd_pow hpq2)
  have hpL : p ∣ L :=
    (hp.dvd_mul.mp hp_dvd_q2L).resolve_left hp_not_q2
  rcases hpL with ⟨L0, hL⟩
  let A := Nat.choose p 2 * R0 * R0 + q * L0
  have hA_mod_main :
      A ≡ Nat.choose p 2 * R0 * R0 [MOD q] := by
    dsimp [A]
    have hzero : q * L0 ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr (dvd_mul_right q L0)
    have hmod := Nat.ModEq.add
      (Nat.ModEq.refl (Nat.choose p 2 * R0 * R0)) hzero
    simpa [add_assoc, add_comm, add_left_comm] using hmod
  have hq_not_A : ¬ q ∣ A := by
    intro hqA
    have hprod_dvd : q ∣ Nat.choose p 2 * R0 * R0 := by
      have hprod_zero :
          Nat.choose p 2 * R0 * R0 ≡ 0 [MOD q] :=
        hA_mod_main.symm.trans (Nat.modEq_zero_iff_dvd.mpr hqA)
      exact Nat.modEq_zero_iff_dvd.mp hprod_zero
    have hq_not_choose : ¬ q ∣ Nat.choose p 2 :=
      prime_not_dvd_choose_two_of_lt hp hq hpq
    have hprod_dvd' : q ∣ Nat.choose p 2 * (R0 * R0) := by
      simpa [mul_assoc] using hprod_dvd
    rcases hq.dvd_mul.mp hprod_dvd' with hq_choose | hq_R0_sq
    · exact hq_not_choose hq_choose
    · rcases hq.dvd_mul.mp hq_R0_sq with hq_R0 | hq_R0
      · exact hqR0 hq_R0
      · exact hqR0 hq_R0
  have hA_pos : 0 < A := by
    by_contra hA_nonpos
    have hA_zero : A = 0 := by omega
    exact hq_not_A (by rw [hA_zero]; exact dvd_zero q)
  refine ⟨A, R0 + q * A, hA_pos, ?_, ?_, rfl, ⟨L0, rfl⟩,
    hA_mod_main, hq_not_A, ?_, ?_⟩
  · omega
  · calc
      V + C0 + q * C0 * u =
          p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L := hdepth.symm
      _ = p * (R0 + q * A) := by
        dsimp [A]
        rw [hL]
        ring
  · dsimp [A]
    have hzero : q * (Nat.choose p 2 * R0 * R0 + q * L0) ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr
        (dvd_mul_right q (Nat.choose p 2 * R0 * R0 + q * L0))
    have hmod := Nat.ModEq.add (Nat.ModEq.refl R0) hzero
    simpa [add_assoc, add_comm, add_left_comm] using hmod
  · intro hqT1
    have hT1_mod : R0 + q * A ≡ R0 [MOD q] := by
      have hzero : q * A ≡ 0 [MOD q] :=
        Nat.modEq_zero_iff_dvd.mpr (dvd_mul_right q A)
      simpa using Nat.ModEq.add (Nat.ModEq.refl R0) hzero
    have hR0_zero : R0 ≡ 0 [MOD q] :=
      hT1_mod.symm.trans (Nat.modEq_zero_iff_dvd.mpr hqT1)
    exact hqR0 (Nat.modEq_zero_iff_dvd.mp hR0_zero)

private lemma quotient_V_combo_depth_one_exact
    {p q C0 R0 W0 u V : ℕ}
    (hscaled_sum_one : C0 + R0 = q * W0)
    (hdepth_exact :
      ∃ L : ℕ,
        p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L =
          V + C0 + q * C0 * u) :
    ∃ L : ℕ,
      V + (p + 1) * C0 + q * C0 * u =
        q * (p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L) := by
  rcases hdepth_exact with ⟨L, hL⟩
  refine ⟨L, ?_⟩
  calc
    V + (p + 1) * C0 + q * C0 * u =
        (V + C0 + q * C0 * u) + p * C0 := by ring
    _ = (p * R0 + q * (p * Nat.choose p 2 * R0 * R0) + q ^ 2 * L) +
        p * C0 := by rw [← hL]
    _ = p * (C0 + R0) + q * (p * Nat.choose p 2 * R0 * R0) +
        q ^ 2 * L := by ring
    _ = p * (q * W0) + q * (p * Nat.choose p 2 * R0 * R0) +
        q ^ 2 * L := by rw [hscaled_sum_one]
    _ = q * (p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L) := by ring

private lemma quotient_V_combo_depth_one_exact_p_dvd_remainder
    {p q C0 R0 W0 u V L U : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q)
    (hV_C0_mod_p : V + C0 ≡ q * C0 [MOD p])
    (hu_succ : u + 1 = p * U)
    (hcombo :
      V + (p + 1) * C0 + q * C0 * u =
        q * (p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L)) :
    p ∣ L := by
  have hbase_mod :
      V + C0 + q * C0 * u ≡ q * C0 + q * C0 * u [MOD p] :=
    Nat.ModEq.add_right (q * C0 * u) hV_C0_mod_p
  have hright_zero : q * C0 + q * C0 * u ≡ 0 [MOD p] := by
    have heq : q * C0 + q * C0 * u = q * C0 * (u + 1) := by ring
    rw [heq, hu_succ]
    exact Nat.modEq_zero_iff_dvd.mpr (by
      refine ⟨q * C0 * U, ?_⟩
      ring)
  have hbase_zero : V + C0 + q * C0 * u ≡ 0 [MOD p] :=
    hbase_mod.trans hright_zero
  have hpC_zero : p * C0 ≡ 0 [MOD p] :=
    Nat.modEq_zero_iff_dvd.mpr (dvd_mul_right p C0)
  have hleft_zero : V + (p + 1) * C0 + q * C0 * u ≡ 0 [MOD p] := by
    have hsum := Nat.ModEq.add hbase_zero hpC_zero
    have hleft :
        V + (p + 1) * C0 + q * C0 * u =
          (V + C0 + q * C0 * u) + p * C0 := by ring
    rw [hleft]
    exact hsum
  have hp_dvd_left : p ∣ V + (p + 1) * C0 + q * C0 * u :=
    Nat.modEq_zero_iff_dvd.mp hleft_zero
  have hp_dvd_q_bracket :
      p ∣ q * (p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L) := by
    rw [hcombo] at hp_dvd_left
    exact hp_dvd_left
  have hp_not_q : ¬ p ∣ q := by
    intro hpq_dvd
    have hp_eq_q : p = q := (Nat.prime_dvd_prime_iff_eq hp hq).mp hpq_dvd
    omega
  have hp_dvd_bracket :
      p ∣ p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L :=
    (hp.dvd_mul.mp hp_dvd_q_bracket).resolve_left hp_not_q
  have hp_dvd_p_part : p ∣ p * W0 + p * Nat.choose p 2 * R0 * R0 :=
    Nat.dvd_add (dvd_mul_right p W0)
      (by
        refine ⟨Nat.choose p 2 * R0 * R0, ?_⟩
        ring)
  have hdiff :
      (p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L) -
        (p * W0 + p * Nat.choose p 2 * R0 * R0) = q * L := by
    omega
  have hp_dvd_qL : p ∣ q * L := by
    have hsub := Nat.dvd_sub hp_dvd_bracket hp_dvd_p_part
    rwa [hdiff] at hsub
  exact (hp.dvd_mul.mp hp_dvd_qL).resolve_left hp_not_q

private lemma quotient_V_combo_depth_one_p_factor_quotient
    {p q C0 R0 W0 u V L : ℕ} (hW0_pos : 0 < W0)
    (hcombo :
      V + (p + 1) * C0 + q * C0 * u =
        q * (p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L))
    (hpL : p ∣ L)
    (hnot_q2 :
      ¬ q ^ 2 ∣ V + (p + 1) * C0 + q * C0 * u) :
    ∃ T0 : ℕ, 0 < T0 ∧
      V + (p + 1) * C0 + q * C0 * u = q * (p * T0) ∧
      T0 ≡ W0 + Nat.choose p 2 * R0 * R0 [MOD q] ∧
      ¬ q ∣ T0 := by
  rcases hpL with ⟨L0, hL⟩
  refine ⟨W0 + Nat.choose p 2 * R0 * R0 + q * L0, ?_, ?_, ?_, ?_⟩
  · omega
  · calc
      V + (p + 1) * C0 + q * C0 * u =
          q * (p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L) := hcombo
      _ = q * (p * (W0 + Nat.choose p 2 * R0 * R0 + q * L0)) := by
        rw [hL]
        ring
  · have hzero : q * L0 ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr (dvd_mul_right q L0)
    have hmod := Nat.ModEq.add
      (Nat.ModEq.refl (W0 + Nat.choose p 2 * R0 * R0)) hzero
    simpa [add_assoc, add_comm, add_left_comm] using hmod
  · intro hqT0
    rcases hqT0 with ⟨K, hK⟩
    have hq2_combo : q ^ 2 ∣ V + (p + 1) * C0 + q * C0 * u := by
      rw [show
        V + (p + 1) * C0 + q * C0 * u =
          q * (p * (W0 + Nat.choose p 2 * R0 * R0 + q * L0)) by
            calc
              V + (p + 1) * C0 + q * C0 * u =
                  q * (p * W0 + p * Nat.choose p 2 * R0 * R0 + q * L) := hcombo
              _ = q * (p * (W0 + Nat.choose p 2 * R0 * R0 + q * L0)) := by
                rw [hL]
                ring,
        hK]
      refine ⟨p * K, ?_⟩
      ring
    exact hnot_q2 hq2_combo

private lemma prime_not_dvd_prime_add_choose_two
    {p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hp5 : 5 ≤ p) (hpq : p < q) :
    ¬ q ∣ p + Nat.choose p 2 := by
  intro hdiv
  have htwo : 2 * (p + Nat.choose p 2) = p * (p + 1) := by
    have hchoose : 2 * Nat.choose p 2 = p * (p - 1) := by
      rw [Nat.choose_two_right]
      rw [mul_comm]
      exact Nat.div_two_mul_two_of_even (Nat.even_mul_pred_self p)
    calc
      2 * (p + Nat.choose p 2) = 2 * p + 2 * Nat.choose p 2 := by ring
      _ = 2 * p + p * (p - 1) := by rw [hchoose]
      _ = p * (p + 1) := by
        cases p with
        | zero => norm_num
        | succ n =>
            simp
            ring
  have hq_dvd_prod : q ∣ p * (p + 1) := by
    rw [← htwo]
    exact dvd_mul_of_dvd_right hdiv 2
  rcases hq.dvd_mul.mp hq_dvd_prod with hq_p | hq_p_succ
  · have hle : q ≤ p := Nat.le_of_dvd hp.pos hq_p
    omega
  · have hle : q ≤ p + 1 :=
      Nat.le_of_dvd (by omega : 0 < p + 1) hq_p_succ
    have hq_eq : q = p + 1 := by omega
    have hp_odd : Odd p := hp.odd_of_ne_two (by omega)
    have hq_odd : Odd q := hq.odd_of_ne_two (by omega)
    rcases hp_odd with ⟨a, hp_eq⟩
    rcases hq_odd with ⟨b, hq_eq_odd⟩
    rw [hq_eq, hp_eq] at hq_eq_odd
    omega

private lemma depth_one_combo_bracket_not_dvd
    {p q R0 W0 : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hqR0 : ¬ q ∣ R0)
    (hW0_mod_R0_sq : W0 ≡ p * R0 * R0 [MOD q]) :
    ¬ q ∣ p * W0 + p * Nat.choose p 2 * R0 * R0 := by
  intro hdiv
  have hbracket_mod :
      p * W0 + p * Nat.choose p 2 * R0 * R0 ≡
        p * (p + Nat.choose p 2) * R0 * R0 [MOD q] := by
    have hmul := Nat.ModEq.mul_left p hW0_mod_R0_sq
    have hadd := Nat.ModEq.add hmul
      (Nat.ModEq.refl (p * Nat.choose p 2 * R0 * R0))
    simpa [left_distrib, mul_add, add_assoc, add_comm, add_left_comm,
      mul_assoc, mul_comm, mul_left_comm] using hadd
  have hzero_left :
      p * W0 + p * Nat.choose p 2 * R0 * R0 ≡ 0 [MOD q] :=
    Nat.modEq_zero_iff_dvd.mpr hdiv
  have hprod_dvd : q ∣ p * (p + Nat.choose p 2) * R0 * R0 :=
    Nat.modEq_zero_iff_dvd.mp (hbracket_mod.symm.trans hzero_left)
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hq_not_p_choose : ¬ q ∣ p + Nat.choose p 2 :=
    prime_not_dvd_prime_add_choose_two hp hq hp5 hpq
  have hprod_dvd' : q ∣ (p * (p + Nat.choose p 2)) * (R0 * R0) := by
    simpa [mul_assoc] using hprod_dvd
  rcases hq.dvd_mul.mp hprod_dvd' with hq_left | hq_R0_sq
  · rcases hq.dvd_mul.mp hq_left with hq_p | hq_p_choose
    · exact hq_not_p hq_p
    · exact hq_not_p_choose hq_p_choose
  · rcases hq.dvd_mul.mp hq_R0_sq with hq_R0 | hq_R0
    · exact hqR0 hq_R0
    · exact hqR0 hq_R0

private lemma quotient_V_combo_depth_one_not_sq_dvd
    {p q C0 R0 W0 u V : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hqR0 : ¬ q ∣ R0)
    (hW0_mod_R0_sq : W0 ≡ p * R0 * R0 [MOD q])
    (hcombo_depth :
      V + (p + 1) * C0 + q * C0 * u ≡
        q * (p * W0 + p * Nat.choose p 2 * R0 * R0) [MOD q ^ 2]) :
    ¬ q ^ 2 ∣ V + (p + 1) * C0 + q * C0 * u := by
  intro hq2_combo
  let B := p * W0 + p * Nat.choose p 2 * R0 * R0
  have hcombo0 :
      V + (p + 1) * C0 + q * C0 * u ≡ 0 [MOD q ^ 2] :=
    Nat.modEq_zero_iff_dvd.mpr hq2_combo
  have hqB0 : q * B ≡ 0 [MOD q ^ 2] := by
    simpa [B] using hcombo_depth.symm.trans hcombo0
  have hq2_dvd_qB : q ^ 2 ∣ q * B :=
    Nat.modEq_zero_iff_dvd.mp hqB0
  have hq_dvd_B : q ∣ B := by
    have hmul : q * q ∣ q * B := by
      simpa [pow_two] using hq2_dvd_qB
    exact (Nat.mul_dvd_mul_iff_left hq.pos).mp hmul
  exact depth_one_combo_bracket_not_dvd hp hq hp5 hpq hqR0 hW0_mod_R0_sq
    (by simpa [B] using hq_dvd_B)

private lemma exists_exact_q_unit_quotient
    {q A : ℕ} (hdiv : q ∣ A) (hnot_sq : ¬ q ^ 2 ∣ A) :
    ∃ T : ℕ, 0 < T ∧ A = q * T ∧ ¬ q ∣ T := by
  rcases hdiv with ⟨T, hT⟩
  have hT_pos : 0 < T := by
    cases T with
    | zero =>
        rw [mul_zero] at hT
        exact False.elim (hnot_sq (by rw [hT]; exact dvd_zero (q ^ 2)))
    | succ T =>
        omega
  have hq_not_T : ¬ q ∣ T := by
    intro hqT
    rcases hqT with ⟨K, hK⟩
    apply hnot_sq
    refine ⟨K, ?_⟩
    rw [hT, hK]
    ring_nf
  exact ⟨T, hT_pos, hT, hq_not_T⟩

private lemma exact_q_quotient_mod_of_mod_sq
    {q A B T : ℕ} (hq_ne_zero : q ≠ 0)
    (hA : A = q * T) (hmod : A ≡ q * B [MOD q ^ 2]) :
    T ≡ B [MOD q] := by
  have hmod' : q * T ≡ q * B [MOD q * q] := by
    simpa [hA, pow_two] using hmod
  exact Nat.ModEq.mul_left_cancel' hq_ne_zero hmod'

private lemma quotient_linearized_second_order_mod
    {c r p q n C0 R0 s u V : ℕ}
    (hp : p.Prime) (hq : q.Prime) (hpq : p < q) (hn_two : 2 ≤ n)
    (hc_gt_one : 1 < c) (hr_gt_one : 1 < r)
    (hc_eq : c - 1 = q ^ n * (p * C0))
    (hr_eq : r - 1 = q ^ n * (p * R0))
    (hspow : r ^ p = q + c * s)
    (hs_eq : s = q * u + 1)
    (hlin : q + s - 1 = p * q ^ n * V) :
    p * R0 ≡ V + C0 + q * C0 * u [MOD q ^ 2] := by
  let P := q ^ n
  let M := q ^ (n + 2)
  have hP_ne_zero : P ≠ 0 := pow_ne_zero n hq.ne_zero
  have hpow_two : M = P * q ^ 2 := by
    dsimp [M, P]
    calc
      q ^ (n + 2) = q ^ n * q ^ 2 := by rw [← pow_add]
      _ = q ^ n * q ^ 2 := rfl
  have hc_form : c = 1 + P * (p * C0) := by
    dsimp [P]
    omega
  have hr_form : r = 1 + P * (p * R0) := by
    dsimp [P]
    omega
  have hge_linear : 1 + p * (P * (p * R0)) ≤ r ^ p := by
    rw [hr_form]
    simpa [P] using one_add_mul_le_one_add_pow (q ^ n * (p * R0)) p
  have hlhs :
      r ^ p ≡ 1 + p * (P * (p * R0)) [MOD M] := by
    have hdiv :
        M ∣ r ^ p - (1 + p * (P * (p * R0))) := by
      simpa [M, P, hr_form] using
        one_add_scaled_pow_sub_linear_dvd_prime_two_succ q n (p * R0) p
          hn_two
    exact ((Nat.modEq_iff_dvd' hge_linear).mpr hdiv).symm
  have hqu : q * (u + 1) = p * P * V := by
    have hq_s_pred : q + s - 1 = q * (u + 1) := by
      rw [hs_eq]
      calc
        q + (q * u + 1) - 1 = (q + q * u) + 1 - 1 := by ring
        _ = q + q * u := Nat.add_sub_cancel (q + q * u) 1
        _ = q * (u + 1) := by ring
    rw [← hq_s_pred, hlin]
  have hrhs_eq :
      q + c * s =
        1 + P * (p * (V + C0)) + P * q * (p * C0 * u) := by
    rw [hc_form, hs_eq]
    dsimp [P] at hqu ⊢
    nlinarith [hqu]
  have hrhs :
      q + c * s ≡
        1 + P * (p * (V + C0)) + P * q * (p * C0 * u) [MOD M] := by
    rw [hrhs_eq]
  have hsame_add :
      1 + P * (p * (p * R0)) ≡
        1 + P * (p * (V + C0)) + P * q * (p * C0 * u) [MOD M] := by
    have hstep : 1 + p * (P * (p * R0)) ≡
        1 + P * (p * (V + C0)) + P * q * (p * C0 * u) [MOD M] :=
      hlhs.symm.trans (by simpa [hspow] using hrhs)
    simpa [mul_assoc, mul_comm, mul_left_comm] using hstep
  have hscaled :
      P * (p * (p * R0)) ≡
        P * (p * (V + C0)) + P * q * (p * C0 * u) [MOD M] :=
    have hsame_grouped :
        1 + P * (p * (p * R0)) ≡
          1 + (P * (p * (V + C0)) + P * q * (p * C0 * u)) [MOD M] := by
      simpa [add_assoc] using hsame_add
    Nat.ModEq.add_left_cancel' 1 hsame_grouped
  have hcancelP :
      p * (p * R0) ≡ p * (V + C0) + q * (p * C0 * u) [MOD q ^ 2] := by
    have hscaled_grouped :
        P * (p * (p * R0)) ≡
          P * (p * (V + C0)) + P * q * (p * C0 * u) [MOD P * q ^ 2] := by
      simpa [hpow_two] using hscaled
    have hscaled' :
        P * (p * (p * R0)) ≡
          P * (p * (V + C0) + q * (p * C0 * u)) [MOD P * q ^ 2] := by
      convert hscaled_grouped using 1
      ring
    exact Nat.ModEq.mul_left_cancel' hP_ne_zero hscaled'
  have hp_scaled :
      p * (p * R0) ≡ p * (V + C0 + q * C0 * u) [MOD q ^ 2] := by
    simpa [left_distrib, mul_assoc, mul_comm, mul_left_comm] using hcancelP
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hcop_qp : Nat.Coprime q p :=
    (hq.coprime_iff_not_dvd).mpr hq_not_p
  have hcop_q2p : Nat.Coprime (q ^ 2) p :=
    hcop_qp.pow_left 2
  exact Nat.ModEq.cancel_left_of_coprime hcop_q2p hp_scaled

private lemma quotient_linearized_second_order_unit_mod
    {p q C0 R0 u V : ℕ}
    (hq_dvd_u_succ : q ∣ u + 1)
    (hsecond : p * R0 ≡ V + C0 + q * C0 * u [MOD q ^ 2]) :
    p * R0 + q * C0 ≡ V + C0 [MOD q ^ 2] := by
  have hzero : q * C0 * u + q * C0 ≡ 0 [MOD q ^ 2] := by
    have hdiv : q ^ 2 ∣ q * C0 * u + q * C0 := by
      rcases hq_dvd_u_succ with ⟨k, hk⟩
      refine ⟨C0 * k, ?_⟩
      calc
        q * C0 * u + q * C0 = q * C0 * (u + 1) := by ring
        _ = q * C0 * (q * k) := by rw [hk]
        _ = q ^ 2 * (C0 * k) := by ring
    exact Nat.modEq_zero_iff_dvd.mpr hdiv
  have hright :
      V + C0 + q * C0 * u + q * C0 ≡ V + C0 [MOD q ^ 2] := by
    have htmp : V + C0 + (q * C0 * u + q * C0) ≡ V + C0 + 0 [MOD q ^ 2] :=
      Nat.ModEq.add (Nat.ModEq.refl (V + C0)) hzero
    simpa [add_assoc, add_comm, add_left_comm] using htmp
  have hadd :
      p * R0 + q * C0 ≡ V + C0 + q * C0 * u + q * C0 [MOD q ^ 2] :=
    Nat.ModEq.add hsecond (Nat.ModEq.refl (q * C0))
  exact hadd.trans hright

private lemma quotient_V_combo_second_order_mod
    {p q n C0 R0 W0 V : ℕ}
    (hn_two : 2 ≤ n)
    (hscaled_sum : C0 + R0 = q ^ n * W0)
    (hsecond_unit : p * R0 + q * C0 ≡ V + C0 [MOD q ^ 2]) :
    V + (p + 1) * C0 ≡ q * C0 [MOD q ^ 2] := by
  have hq2_dvd_sum : q ^ 2 ∣ C0 + R0 := by
    rw [hscaled_sum]
    exact dvd_mul_of_dvd_left (pow_dvd_pow q hn_two) W0
  have hsum0 : C0 + R0 ≡ 0 [MOD q ^ 2] :=
    Nat.modEq_zero_iff_dvd.mpr hq2_dvd_sum
  have hp_sum0 : p * R0 + p * C0 ≡ 0 [MOD q ^ 2] := by
    have hmul : p * (C0 + R0) ≡ p * 0 [MOD q ^ 2] :=
      Nat.ModEq.mul_left p hsum0
    simpa [left_distrib, mul_assoc, add_comm] using hmul
  have hleft0 : p * R0 + q * C0 + p * C0 ≡ q * C0 [MOD q ^ 2] := by
    have htmp : (p * R0 + p * C0) + q * C0 ≡ 0 + q * C0 [MOD q ^ 2] :=
      Nat.ModEq.add hp_sum0 (Nat.ModEq.refl (q * C0))
    simpa [add_assoc, add_comm, add_left_comm] using htmp
  have hstep :
      p * R0 + q * C0 + p * C0 ≡ V + C0 + p * C0 [MOD q ^ 2] :=
    Nat.ModEq.add hsecond_unit (Nat.ModEq.refl (p * C0))
  have hright : V + C0 + p * C0 ≡ q * C0 [MOD q ^ 2] :=
    hstep.symm.trans hleft0
  simpa [mul_add, add_assoc, add_comm, add_left_comm, mul_comm, mul_left_comm,
    mul_assoc] using hright

private lemma quotient_V_combo_not_sq_dvd_of_second
    {p q C0 V : ℕ} (hq : q.Prime) (hqC0 : ¬ q ∣ C0)
    (hcombo_sq : V + (p + 1) * C0 ≡ q * C0 [MOD q ^ 2]) :
    ¬ q ^ 2 ∣ V + (p + 1) * C0 := by
  intro hq2_combo
  have hcombo0 : V + (p + 1) * C0 ≡ 0 [MOD q ^ 2] :=
    Nat.modEq_zero_iff_dvd.mpr hq2_combo
  have hqC0_zero : q * C0 ≡ 0 [MOD q ^ 2] :=
    hcombo_sq.symm.trans hcombo0
  have hq2_dvd_qC0 : q ^ 2 ∣ q * C0 :=
    Nat.modEq_zero_iff_dvd.mp hqC0_zero
  have hq_dvd_C0 : q ∣ C0 := by
    have hmul : q * q ∣ q * C0 := by
      simpa [pow_two] using hq2_dvd_qC0
    exact (Nat.mul_dvd_mul_iff_left hq.pos).mp hmul
  exact hqC0 hq_dvd_C0

private lemma quotient_V_linear_combo_mod
    {p q C0 R0 V : ℕ}
    (hscaled_sum : q ∣ C0 + R0)
    (hV_C0_mod : V + C0 ≡ p * R0 [MOD q]) :
    V + (p + 1) * C0 ≡ 0 [MOD q] := by
  have hsum0 : C0 + R0 ≡ 0 [MOD q] :=
    Nat.modEq_zero_iff_dvd.mpr hscaled_sum
  have hp_sum0 : p * C0 + p * R0 ≡ 0 [MOD q] := by
    have hmul : p * (C0 + R0) ≡ p * 0 [MOD q] :=
      Nat.ModEq.mul_left p hsum0
    simpa [left_distrib, mul_assoc] using hmul
  have hstep :
      (V + C0) + p * C0 ≡ p * R0 + p * C0 [MOD q] :=
    Nat.ModEq.add hV_C0_mod (Nat.ModEq.refl (p * C0))
  have hright0 : p * R0 + p * C0 ≡ 0 [MOD q] := by
    simpa [add_comm] using hp_sum0
  have hleft0 : (V + C0) + p * C0 ≡ 0 [MOD q] :=
    hstep.trans hright0
  simpa [mul_add, add_assoc, add_comm, add_left_comm, mul_comm, mul_left_comm,
    mul_assoc] using hleft0

private lemma quotient_V_not_dvd
    {p q C0 V : ℕ}
    (hq : q.Prime) (hnot : ¬ p ∣ q - 1) (hpq : p < q)
    (hqC0 : ¬ q ∣ C0)
    (hV_combo : V + (p + 1) * C0 ≡ 0 [MOD q]) :
    ¬ q ∣ V := by
  intro hqV
  have hV0 : V ≡ 0 [MOD q] := Nat.modEq_zero_iff_dvd.mpr hqV
  have hprod0 : (p + 1) * C0 ≡ 0 [MOD q] := by
    have hsum0 : V + (p + 1) * C0 ≡ V + 0 [MOD q] :=
      hV_combo.trans hV0.symm
    simpa [add_zero] using Nat.ModEq.add_left_cancel' V hsum0
  have hq_prod : q ∣ (p + 1) * C0 :=
    Nat.modEq_zero_iff_dvd.mp hprod0
  rcases hq.dvd_mul.mp hq_prod with hq_p_succ | hq_C0
  · have hp_succ_eq_q : p + 1 = q := by
      exact Nat.le_antisymm (by omega)
        (Nat.le_of_dvd (by omega : 0 < p + 1) hq_p_succ)
    have hp_dvd_q_pred : p ∣ q - 1 := by
      rw [← hp_succ_eq_q]
      simp
    exact hnot hp_dvd_q_pred
  · exact hqC0 hq_C0

private lemma quotient_linearized_not_next_qpow_dvd
    {p q n s V : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p < q)
    (hqV : ¬ q ∣ V) (hlin : q + s - 1 = p * q ^ n * V) :
    ¬ q ^ (n + 1) ∣ q + s - 1 := by
  intro hnext
  have hpow_succ : q ^ (n + 1) = q ^ n * q := by
    rw [pow_succ]
  have hnext' : q ^ n * q ∣ q ^ n * (p * V) := by
    have hnext0 : q ^ (n + 1) ∣ q ^ n * (p * V) := by
      rw [hlin] at hnext
      simpa [mul_assoc, mul_comm, mul_left_comm] using hnext
    simpa [hpow_succ] using hnext0
  have hq_dvd_pV : q ∣ p * V :=
    (Nat.mul_dvd_mul_iff_left (pow_pos hq.pos n)).mp hnext'
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  rcases hq.dvd_mul.mp hq_dvd_pV with hqp | hqV'
  · exact hq_not_p hqp
  · exact hqV hqV'

private lemma quotient_u_succ_not_next_qpow_dvd
    {p q n u V : ℕ} (hp : p.Prime) (hq : q.Prime) (hpq : p < q)
    (hn_pos : 0 < n) (hqV : ¬ q ∣ V)
    (hu_succ_eq_scaled : u + 1 = p * q ^ (n - 1) * V) :
    ¬ q ^ n ∣ u + 1 := by
  intro hnext
  have hpow_split : q ^ n = q ^ (n - 1) * q := by
    calc
      q ^ n = q ^ ((n - 1) + 1) := by
        rw [Nat.sub_add_cancel (by omega : 1 ≤ n)]
      _ = q ^ (n - 1) * q := by rw [pow_succ]
  have hnext' : q ^ (n - 1) * q ∣ q ^ (n - 1) * (p * V) := by
    have hnext0 : q ^ n ∣ p * q ^ (n - 1) * V := by
      rw [hu_succ_eq_scaled] at hnext
      exact hnext
    simpa [hpow_split, mul_assoc, mul_comm, mul_left_comm] using hnext0
  have hq_dvd_pV : q ∣ p * V :=
    (Nat.mul_dvd_mul_iff_left (pow_pos hq.pos (n - 1))).mp hnext'
  have hq_not_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  rcases hq.dvd_mul.mp hq_dvd_pV with hqp | hqV'
  · exact hq_not_p hqp
  · exact hqV hqV'

private lemma prime_common_dvd_upper_sub_one_geom_sum_eq_smaller
    {x p r : ℕ}
    (hx : 1 < x) (hp : p.Prime) (hr : r.Prime)
    (hr_dvd_x_sub_one : r ∣ x - 1)
    (hr_dvd_S : r ∣ ∑ i ∈ Finset.range p, x ^ i) :
    r = p := by
  let S := ∑ i ∈ Finset.range p, x ^ i
  have hx_pos : 1 ≤ x := by omega
  have hr_dvd_p : r ∣ p := by
    have hx_mod_one : (x : ZMod r) = 1 := by
      have hx_modeq_one : x ≡ 1 [MOD r] :=
        ((Nat.modEq_iff_dvd' hx_pos).mpr hr_dvd_x_sub_one).symm
      simpa using (ZMod.natCast_eq_natCast_iff x 1 r).mpr hx_modeq_one
    have hS_mod : (S : ZMod r) = (p : ZMod r) := by
      calc
        (S : ZMod r)
            = ∑ i ∈ Finset.range p, ((x : ZMod r) ^ i) := by
                simp [S]
        _ = ∑ _i ∈ Finset.range p, (1 : ZMod r) := by
                apply Finset.sum_congr rfl
                intro i _hi
                rw [hx_mod_one, one_pow]
        _ = (p : ZMod r) := by simp
    have hS_zero : (S : ZMod r) = 0 := by
      rw [ZMod.natCast_eq_zero_iff]
      simpa [S] using hr_dvd_S
    rw [hS_mod] at hS_zero
    rw [ZMod.natCast_eq_zero_iff] at hS_zero
    exact hS_zero
  exact (Nat.prime_dvd_prime_iff_eq hr hp).mp hr_dvd_p

private lemma prime_not_dvd_geom_sum_of_dvd_upper_sub_one_ne_smaller
    {x p r : ℕ}
    (hx : 1 < x) (hp : p.Prime) (hr : r.Prime) (hrp : r ≠ p)
    (hr_dvd_x_sub_one : r ∣ x - 1) :
    ¬ r ∣ ∑ i ∈ Finset.range p, x ^ i := by
  intro hr_dvd_S
  exact hrp (prime_common_dvd_upper_sub_one_geom_sum_eq_smaller
    hx hp hr hr_dvd_x_sub_one hr_dvd_S)

private lemma lowerPrimeDivisorCatalan_other_prime_padicVal_upper_sub_one_dvd
    {x y p q ℓ : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hℓ : ℓ.Prime) (hℓp : ℓ ≠ p)
    (hpow : x ^ p = y ^ q + 1) :
    q ∣ padicValNat ℓ (x - 1) := by
  by_cases hℓ_dvd_x_sub_one : ℓ ∣ x - 1
  · let S := ∑ i ∈ Finset.range p, x ^ i
    haveI : Fact ℓ.Prime := ⟨hℓ⟩
    have hS_pos : 0 < S := by
      have hmem : 0 ∈ Finset.range p := Finset.mem_range.mpr hp.pos
      have hterm_pos : 0 < x ^ 0 := by simp
      exact lt_of_lt_of_le hterm_pos
        (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hmem)
    have hS0 : S ≠ 0 := Nat.ne_of_gt hS_pos
    have hx_sub0 : x - 1 ≠ 0 := by omega
    have hy0 : y ≠ 0 := by omega
    have hprod : S * (x - 1) = y ^ q := by
      have hx_pos : 1 ≤ x := by omega
      have hgeom := geom_sum_mul_sub_one_eq_pow_sub_one (a := x) (n := p) hx_pos
      have hxpow_sub : x ^ p - 1 = y ^ q := by omega
      simpa [S, hxpow_sub] using hgeom
    have hℓ_not_dvd_S : ¬ ℓ ∣ S := by
      simpa [S] using
        prime_not_dvd_geom_sum_of_dvd_upper_sub_one_ne_smaller
          hx hp hℓ hℓp hℓ_dvd_x_sub_one
    have hval_S : padicValNat ℓ S = 0 := padicValNat.eq_zero_of_not_dvd hℓ_not_dvd_S
    have hval_prod :
        padicValNat ℓ S + padicValNat ℓ (x - 1) =
          q * padicValNat ℓ y := by
      have hleft :
          padicValNat ℓ (S * (x - 1)) =
            padicValNat ℓ S + padicValNat ℓ (x - 1) := by
        rw [padicValNat.mul hS0 hx_sub0]
      have hright :
          padicValNat ℓ (y ^ q) = q * padicValNat ℓ y := by
        rw [padicValNat.pow q hy0]
      rw [hprod, hright] at hleft
      exact hleft.symm
    rw [hval_S, zero_add] at hval_prod
    exact ⟨padicValNat ℓ y, hval_prod⟩
  · rw [padicValNat.eq_zero_of_not_dvd hℓ_dvd_x_sub_one]
    exact dvd_zero q

private lemma lowerPrimeDivisorCatalan_padicVal_geom_sum_eq_one
    {x y p q : ℕ}
    (hx : 1 < x) (hp : p.Prime) (hq : q.Prime) (hp5 : 5 ≤ p)
    (hp_dvd_y : p ∣ y) (hp_dvd_x_sub_one : p ∣ x - 1)
    (hpow : x ^ p = y ^ q + 1) :
    padicValNat p (∑ i ∈ Finset.range p, x ^ i) = 1 := by
  let S := ∑ i ∈ Finset.range p, x ^ i
  haveI : Fact p.Prime := ⟨hp⟩
  have hS_pos : 0 < S := by
    have hmem : 0 ∈ Finset.range p := Finset.mem_range.mpr hp.pos
    have hterm_pos : 0 < x ^ 0 := by simp
    exact lt_of_lt_of_le hterm_pos
      (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hmem)
  have hS0 : S ≠ 0 := Nat.ne_of_gt hS_pos
  have hx_sub0 : x - 1 ≠ 0 := by omega
  have hcop_xy : Nat.Coprime x y :=
    lowerPrimeDivisorCatalan_bases_coprime hp hq hpow
  have hp_not_dvd_x : ¬ p ∣ x := by
    intro hpx
    have hpgcd : p ∣ Nat.gcd x y := Nat.dvd_gcd hpx hp_dvd_y
    rw [Nat.Coprime.gcd_eq_one hcop_xy] at hpgcd
    exact hp.not_dvd_one hpgcd
  have hval_pow :
      padicValNat p (x ^ p - 1) = padicValNat p (x - 1) + 1 := by
    have hp_odd : Odd p := hp.odd_of_ne_two (by omega)
    have h := padicValNat.pow_sub_pow hp_odd hx hp_dvd_x_sub_one
      hp_not_dvd_x hp.ne_zero
    have hp_self : padicValNat p p = 1 := by
      simp [padicValNat_self]
    rwa [one_pow, hp_self] at h
  have hprod : S * (x - 1) = x ^ p - 1 := by
    have hx_pos : 1 ≤ x := by omega
    simpa [S] using geom_sum_mul_sub_one_eq_pow_sub_one (a := x) (n := p) hx_pos
  have hval_prod :
      padicValNat p S + padicValNat p (x - 1) =
        padicValNat p (x ^ p - 1) := by
    have hleft :
        padicValNat p (S * (x - 1)) =
          padicValNat p S + padicValNat p (x - 1) := by
      rw [padicValNat.mul hS0 hx_sub0]
    rw [hprod] at hleft
    exact hleft.symm
  rw [hval_pow] at hval_prod
  have hcomm :
      padicValNat p S + padicValNat p (x - 1) =
        1 + padicValNat p (x - 1) := by
    calc
      padicValNat p S + padicValNat p (x - 1)
          = padicValNat p (x - 1) + 1 := hval_prod
      _ = 1 + padicValNat p (x - 1) := by rw [Nat.add_comm]
  exact Nat.add_right_cancel hcomm

private lemma lowerPrimeDivisorCatalan_smaller_prime_padicVal_upper_sub_one_eq
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q)
    (hpow : x ^ p = y ^ q + 1) :
    padicValNat p (x - 1) + 1 = q * padicValNat p y := by
  let S := ∑ i ∈ Finset.range p, x ^ i
  haveI : Fact p.Prime := ⟨hp⟩
  have hp_dvd_y : p ∣ y :=
    lowerPrimeDivisorCatalan_smaller_prime_dvd_lower hx hy hp hq hpq hpow
  have hp_dvd_x_sub_one : p ∣ x - 1 :=
    lowerPrimeDivisorCatalan_smaller_prime_dvd_upper_sub_one
      hx hp hq hp_dvd_y hpow
  have hS_val :
      padicValNat p S = 1 :=
    lowerPrimeDivisorCatalan_padicVal_geom_sum_eq_one
      hx hp hq hp5 hp_dvd_y hp_dvd_x_sub_one hpow
  have hS_pos : 0 < S := by
    have hmem : 0 ∈ Finset.range p := Finset.mem_range.mpr hp.pos
    have hterm_pos : 0 < x ^ 0 := by simp
    exact lt_of_lt_of_le hterm_pos
      (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hmem)
  have hS0 : S ≠ 0 := Nat.ne_of_gt hS_pos
  have hx_sub0 : x - 1 ≠ 0 := by omega
  have hy0 : y ≠ 0 := by omega
  have hprod : S * (x - 1) = y ^ q := by
    have hx_pos : 1 ≤ x := by omega
    have hgeom := geom_sum_mul_sub_one_eq_pow_sub_one (a := x) (n := p) hx_pos
    have hxpow_sub : x ^ p - 1 = y ^ q := by omega
    simpa [S, hxpow_sub] using hgeom
  have hval_prod :
      padicValNat p S + padicValNat p (x - 1) =
        q * padicValNat p y := by
    have hleft :
        padicValNat p (S * (x - 1)) =
          padicValNat p S + padicValNat p (x - 1) := by
      rw [padicValNat.mul hS0 hx_sub0]
    have hright :
        padicValNat p (y ^ q) = q * padicValNat p y := by
      rw [padicValNat.pow q hy0]
    rw [hprod, hright] at hleft
    exact hleft.symm
  rw [hS_val] at hval_prod
  omega

private lemma lowerPrimeDivisorCatalan_upper_sub_one_eq_prime_pred_mul_qpow
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q)
    (hpow : x ^ p = y ^ q + 1) :
    ∃ A : ℕ, x - 1 = p ^ (q - 1) * A ^ q := by
  have hp_dvd_y : p ∣ y :=
    lowerPrimeDivisorCatalan_smaller_prime_dvd_lower hx hy hp hq hpq hpow
  have hval :
      padicValNat p (x - 1) + 1 = q * padicValNat p y :=
    lowerPrimeDivisorCatalan_smaller_prime_padicVal_upper_sub_one_eq
      hx hy hp hq hp5 hpq hpow
  have hy0 : y ≠ 0 := by omega
  have hx_sub0 : x - 1 ≠ 0 := by omega
  apply exists_prime_pred_mul_qpow_of_scaled_padicVals hp hq.ne_zero hx_sub0
  · exact pow_pred_exponent_dvd_base_sub_one_of_padic_obstruction
      hp hq hy0 hp_dvd_y hval
  · exact q_dvd_padicVal_sub_pred_of_padic_obstruction
      hp hq hy0 hp_dvd_y hval
  · intro ℓ hℓ hℓp
    exact lowerPrimeDivisorCatalan_other_prime_padicVal_upper_sub_one_dvd
      hx hy hp hq hℓ hℓp hpow

private lemma lowerPrimeDivisorCatalan_geom_sum_eq_prime_mul_qpow
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q)
    (hpow : x ^ p = y ^ q + 1) :
    ∃ B : ℕ, (∑ i ∈ Finset.range p, x ^ i) = p * B ^ q := by
  let S := ∑ i ∈ Finset.range p, x ^ i
  have hS_pos : 0 < S := by
    have hmem : 0 ∈ Finset.range p := Finset.mem_range.mpr hp.pos
    have hterm_pos : 0 < x ^ 0 := by simp
    exact lt_of_lt_of_le hterm_pos
      (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hmem)
  have hS0 : S ≠ 0 := Nat.ne_of_gt hS_pos
  have hx_sub0 : x - 1 ≠ 0 := by omega
  have hy0 : y ≠ 0 := by omega
  have hp_dvd_y : p ∣ y :=
    lowerPrimeDivisorCatalan_smaller_prime_dvd_lower hx hy hp hq hpq hpow
  have hp_dvd_x_sub_one : p ∣ x - 1 :=
    lowerPrimeDivisorCatalan_smaller_prime_dvd_upper_sub_one
      hx hp hq hp_dvd_y hpow
  have hS_val :
      padicValNat p S = 1 :=
    lowerPrimeDivisorCatalan_padicVal_geom_sum_eq_one
      hx hp hq hp5 hp_dvd_y hp_dvd_x_sub_one hpow
  have hprod : S * (x - 1) = y ^ q := by
    have hx_pos : 1 ≤ x := by omega
    have hgeom := geom_sum_mul_sub_one_eq_pow_sub_one (a := x) (n := p) hx_pos
    have hxpow_sub : x ^ p - 1 = y ^ q := by omega
    simpa [S, hxpow_sub] using hgeom
  apply exists_prime_mul_qpow_of_padicVal_eq_one hp hq.ne_zero hS0 hS_val
  intro ℓ hℓ hℓp
  haveI : Fact ℓ.Prime := ⟨hℓ⟩
  have hA_dvd : q ∣ padicValNat ℓ (x - 1) :=
    lowerPrimeDivisorCatalan_other_prime_padicVal_upper_sub_one_dvd
      hx hy hp hq hℓ hℓp hpow
  have hval_prod :
      padicValNat ℓ S + padicValNat ℓ (x - 1) =
        q * padicValNat ℓ y := by
    have hleft :
        padicValNat ℓ (S * (x - 1)) =
          padicValNat ℓ S + padicValNat ℓ (x - 1) := by
      rw [padicValNat.mul hS0 hx_sub0]
    have hright :
        padicValNat ℓ (y ^ q) = q * padicValNat ℓ y := by
      rw [padicValNat.pow q hy0]
    rw [hprod, hright] at hleft
    exact hleft.symm
  rcases hA_dvd with ⟨t, ht⟩
  refine ⟨padicValNat ℓ y - t, ?_⟩
  have hmul_le : q * t ≤ q * padicValNat ℓ y := by
    calc
      q * t = padicValNat ℓ (x - 1) := ht.symm
      _ ≤ padicValNat ℓ S + padicValNat ℓ (x - 1) := by omega
      _ = q * padicValNat ℓ y := hval_prod
  have ht_le : t ≤ padicValNat ℓ y :=
    Nat.le_of_mul_le_mul_left hmul_le hq.pos
  have hsum :
      padicValNat ℓ S + q * t = q * padicValNat ℓ y := by
    simpa [ht] using hval_prod
  have hright :
      q * (padicValNat ℓ y - t) + q * t =
        q * padicValNat ℓ y := by
    calc
      q * (padicValNat ℓ y - t) + q * t =
          q * ((padicValNat ℓ y - t) + t) := by rw [Nat.mul_add]
      _ = q * padicValNat ℓ y := by rw [Nat.sub_add_cancel ht_le]
  exact Nat.add_right_cancel (by
    calc
      padicValNat ℓ S + q * t = q * padicValNat ℓ y := hsum
      _ = q * (padicValNat ℓ y - t) + q * t := hright.symm)

private lemma lowerPrimeDivisorCatalan_cassels_p_shape
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    ∃ A B : ℕ,
      x - 1 = p ^ (q - 1) * A ^ q ∧
        (∑ i ∈ Finset.range p, x ^ i) = p * B ^ q ∧
        y = p * A * B ∧ (q ∣ A ∨ q ∣ B) := by
  rcases lowerPrimeDivisorCatalan_upper_sub_one_eq_prime_pred_mul_qpow
      hx hy hp hq hp5 hpq hpow with ⟨A, hA⟩
  rcases lowerPrimeDivisorCatalan_geom_sum_eq_prime_mul_qpow
      hx hy hp hq hp5 hpq hpow with ⟨B, hB⟩
  let S := ∑ i ∈ Finset.range p, x ^ i
  have hprod : S * (x - 1) = y ^ q := by
    have hx_pos : 1 ≤ x := by omega
    have hgeom := geom_sum_mul_sub_one_eq_pow_sub_one (a := x) (n := p) hx_pos
    have hxpow_sub : x ^ p - 1 = y ^ q := by omega
    simpa [S, hxpow_sub] using hgeom
  have hshape :
      (p * B ^ q) * (p ^ (q - 1) * A ^ q) = (p * A * B) ^ q := by
    have hp_pow : p * p ^ (q - 1) = p ^ q := by
      calc
        p * p ^ (q - 1) = p ^ (q - 1) * p := by rw [mul_comm]
        _ = p ^ ((q - 1) + 1) := by rw [pow_succ]
        _ = p ^ q := by rw [Nat.sub_add_cancel hq.one_le]
    calc
      (p * B ^ q) * (p ^ (q - 1) * A ^ q)
          = (p * p ^ (q - 1)) * (A ^ q * B ^ q) := by ring
      _ = p ^ q * (A ^ q * B ^ q) := by rw [hp_pow]
      _ = (p * A * B) ^ q := by
        rw [mul_pow, mul_pow]
        ring
  have hy_pow : y ^ q = (p * A * B) ^ q := by
    calc
      y ^ q = S * (x - 1) := hprod.symm
      _ = (p * B ^ q) * (p ^ (q - 1) * A ^ q) := by
        rw [hA]
        dsimp [S]
        rw [hB]
      _ = (p * A * B) ^ q := hshape
  have hy_eq : y = p * A * B :=
    Nat.pow_left_injective hq.ne_zero hy_pow
  have hq_not_dvd_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hq_dvd_AB : q ∣ A * B := by
    have hq_dvd_pAB : q ∣ p * (A * B) := by
      simpa [hy_eq, mul_assoc] using hq_dvd_y
    exact (hq.dvd_mul.mp hq_dvd_pAB).resolve_left hq_not_dvd_p
  exact ⟨A, B, hA, hB, hy_eq, hq.dvd_mul.mp hq_dvd_AB⟩

private lemma lowerPrimeDivisorCatalan_not_lower_prime_dvd_upper_base
    {x y p q : ℕ}
    (hp : p.Prime) (hq : q.Prime) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    ¬ q ∣ x := by
  intro hq_dvd_x
  have hq_dvd_xp : q ∣ x ^ p := dvd_pow hq_dvd_x hp.ne_zero
  have hq_dvd_yq : q ∣ y ^ q := dvd_pow hq_dvd_y hq.ne_zero
  have hq_dvd_succ : q ∣ y ^ q + 1 := by
    rwa [← hpow]
  have hq_dvd_one : q ∣ 1 := by
    have hsub : q ∣ (y ^ q + 1) - y ^ q :=
      Nat.dvd_sub hq_dvd_succ hq_dvd_yq
    simpa using hsub
  exact hq.not_dvd_one hq_dvd_one

private lemma lowerPrimeDivisorCatalan_cassels_left_branch_factor
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1)
    (hqx : q ∣ x - 1) :
    ∃ A B : ℕ,
      x - 1 = p ^ (q - 1) * A ^ q ∧
        (∑ i ∈ Finset.range p, x ^ i) = p * B ^ q ∧
        y = p * A * B ∧ q ∣ A := by
  rcases lowerPrimeDivisorCatalan_cassels_p_shape
      hx hy hp hq hp5 hpq hq_dvd_y hpow with
    ⟨A, B, hA, hB, hy_eq, _hqAB⟩
  have hq_not_dvd_p : ¬ q ∣ p := by
    intro hqp
    exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
  have hcop_q_p : Nat.Coprime q p :=
    (hq.coprime_iff_not_dvd).mpr hq_not_dvd_p
  have hcop_q_ppow : Nat.Coprime q (p ^ (q - 1)) :=
    hcop_q_p.pow_right (q - 1)
  have hq_not_dvd_ppow : ¬ q ∣ p ^ (q - 1) := by
    intro hqpow
    have hqgcd : q ∣ Nat.gcd q (p ^ (q - 1)) :=
      Nat.dvd_gcd (dvd_refl q) hqpow
    rw [Nat.Coprime.gcd_eq_one hcop_q_ppow] at hqgcd
    exact hq.not_dvd_one hqgcd
  have hq_dvd_prod : q ∣ p ^ (q - 1) * A ^ q := by
    rwa [← hA]
  have hq_dvd_Apow : q ∣ A ^ q :=
    (hq.dvd_mul.mp hq_dvd_prod).resolve_left hq_not_dvd_ppow
  exact ⟨A, B, hA, hB, hy_eq, hq.dvd_of_dvd_pow hq_dvd_Apow⟩

private lemma lowerPrimeDivisorCatalan_cassels_right_branch_factor
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1)
    (hqx : ¬ q ∣ x - 1) :
    ∃ A B : ℕ,
      x - 1 = p ^ (q - 1) * A ^ q ∧
        (∑ i ∈ Finset.range p, x ^ i) = p * B ^ q ∧
        y = p * A * B ∧ ¬ q ∣ A ∧ q ∣ B := by
  rcases lowerPrimeDivisorCatalan_cassels_p_shape
      hx hy hp hq hp5 hpq hq_dvd_y hpow with
    ⟨A, B, hA, hB, hy_eq, hqAB⟩
  have hq_not_A : ¬ q ∣ A := by
    intro hqA
    have hqAq : q ∣ A ^ q := dvd_pow hqA hq.ne_zero
    have hq_prod : q ∣ p ^ (q - 1) * A ^ q :=
      dvd_mul_of_dvd_right hqAq (p ^ (q - 1))
    exact hqx (by rwa [← hA] at hq_prod)
  exact ⟨A, B, hA, hB, hy_eq, hq_not_A, hqAB.resolve_left hq_not_A⟩

private lemma lowerPrimeDivisorCatalan_left_branch_upper_base_modEq_one_qpow
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1)
    (hqx : q ∣ x - 1) :
    x ≡ 1 [MOD q ^ q] := by
  rcases lowerPrimeDivisorCatalan_cassels_left_branch_factor
      hx hy hp hq hp5 hpq hq_dvd_y hpow hqx with
    ⟨A, _B, hA, _hB, _hy_eq, hqA⟩
  have hqpow_A : q ^ q ∣ A ^ q := pow_dvd_pow_of_dvd hqA q
  have hqpow_x_sub_one : q ^ q ∣ x - 1 := by
    rw [hA]
    exact dvd_mul_of_dvd_right hqpow_A (p ^ (q - 1))
  exact ((Nat.modEq_iff_dvd' (by omega : 1 ≤ x)).mpr hqpow_x_sub_one).symm

private lemma lowerPrimeDivisorCatalan_right_branch_geom_sum_qpow_dvd
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1)
    (hqx : ¬ q ∣ x - 1) :
    q ^ q ∣ ∑ i ∈ Finset.range p, x ^ i := by
  rcases lowerPrimeDivisorCatalan_cassels_right_branch_factor
      hx hy hp hq hp5 hpq hq_dvd_y hpow hqx with
    ⟨_A, B, _hA, hB, _hy_eq, _hq_not_A, hqB⟩
  have hqBpow : q ^ q ∣ B ^ q := pow_dvd_pow_of_dvd hqB q
  have hq_dvd_pB : q ^ q ∣ p * B ^ q :=
    dvd_mul_of_dvd_right hqBpow p
  rwa [hB]

private lemma lowerPrimeDivisorCatalan_right_branch_upper_base_order_eq
    {x y p q : ℕ}
    (hx : 1 < x) (hp : p.Prime) (hq : q.Prime)
    (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1)
    (hqx : ¬ q ∣ x - 1) :
    ∃ hcop : Nat.Coprime x q,
      orderOf (ZMod.unitOfCoprime x hcop) = p := by
  haveI : Fact p.Prime := ⟨hp⟩
  haveI : NeZero q := ⟨hq.ne_zero⟩
  have hq_not_dvd_x : ¬ q ∣ x :=
    lowerPrimeDivisorCatalan_not_lower_prime_dvd_upper_base hp hq hq_dvd_y hpow
  let hcop_xq : Nat.Coprime x q :=
    (hq.coprime_iff_not_dvd).mpr hq_not_dvd_x |>.symm
  let u : (ZMod q)ˣ := ZMod.unitOfCoprime x hcop_xq
  have hxp_modeq_one : x ^ p ≡ 1 [MOD q] := by
    have hq_dvd_yq : q ∣ y ^ q := dvd_pow hq_dvd_y hq.ne_zero
    have hyq_zero : y ^ q ≡ 0 [MOD q] :=
      Nat.modEq_zero_iff_dvd.mpr hq_dvd_yq
    have h := Nat.ModEq.add_right 1 hyq_zero
    simpa [← hpow] using h
  have hu_pow : u ^ p = 1 := by
    ext
    change ((u : ZMod q) ^ p) = (1 : ZMod q)
    rw [ZMod.coe_unitOfCoprime]
    rw [← Nat.cast_pow]
    simpa using (ZMod.natCast_eq_natCast_iff (x ^ p) 1 q).mpr hxp_modeq_one
  have hx_ge_one : 1 ≤ x := by omega
  have hu_ne_one : u ≠ 1 := by
    intro hu
    have hx_cast_one : (x : ZMod q) = 1 := by
      calc
        (x : ZMod q) = (u : ZMod q) := by
          simp [u, ZMod.coe_unitOfCoprime]
        _ = (1 : ZMod q) := by rw [hu]; rfl
    have hx_modeq_one : x ≡ 1 [MOD q] :=
      (ZMod.natCast_eq_natCast_iff x 1 q).mp (by
        simpa using hx_cast_one)
    exact hqx ((Nat.modEq_iff_dvd' hx_ge_one).mp hx_modeq_one.symm)
  exact ⟨hcop_xq, orderOf_eq_prime hu_pow hu_ne_one⟩

private lemma lowerPrimeDivisorCatalan_right_branch_upper_pow_modEq_one_qpow
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1)
    (hqx : ¬ q ∣ x - 1) :
    x ^ p ≡ 1 [MOD q ^ q] := by
  let S := ∑ i ∈ Finset.range p, x ^ i
  have hSdiv : q ^ q ∣ S := by
    simpa [S] using lowerPrimeDivisorCatalan_right_branch_geom_sum_qpow_dvd
      hx hy hp hq hp5 hpq hq_dvd_y hpow hqx
  have hprod : S * (x - 1) = x ^ p - 1 := by
    simpa [S] using geom_sum_mul_sub_one_eq_pow_sub_one
      (a := x) (n := p) (by omega : 1 ≤ x)
  have hdiv : q ^ q ∣ x ^ p - 1 := by
    rw [← hprod]
    exact dvd_mul_of_dvd_left hSdiv (x - 1)
  have hxp_pos : 1 ≤ x ^ p := one_le_pow₀ (by omega : 1 ≤ x)
  exact ((Nat.modEq_iff_dvd' hxp_pos).mpr hdiv).symm

private lemma lowerPrimeDivisorCatalan_q_branch_modEq_summary
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    x ≡ 1 [MOD q ^ q] ∨
      (∃ hcop : Nat.Coprime x q,
        orderOf (ZMod.unitOfCoprime x hcop) = p ∧
          x ^ p ≡ 1 [MOD q ^ q]) := by
  by_cases hqx : q ∣ x - 1
  · exact Or.inl
      (lowerPrimeDivisorCatalan_left_branch_upper_base_modEq_one_qpow
        hx hy hp hq hp5 hpq hq_dvd_y hpow hqx)
  · right
    rcases lowerPrimeDivisorCatalan_right_branch_upper_base_order_eq
        hx hp hq hq_dvd_y hpow hqx with ⟨hcop, horder⟩
    exact ⟨hcop, horder,
      lowerPrimeDivisorCatalan_right_branch_upper_pow_modEq_one_qpow
        hx hy hp hq hp5 hpq hq_dvd_y hpow hqx⟩

private lemma lowerPrimeDivisorCatalan_high_qadic_or_cyclotomic
    {x y p q : ℕ}
    (hx : 1 < x) (_hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1) :
    q ^ q ∣ x - 1 ∨ p ∣ q - 1 := by
  have hq_not_dvd_x : ¬ q ∣ x :=
    lowerPrimeDivisorCatalan_not_lower_prime_dvd_upper_base hp hq hq_dvd_y hpow
  have hqpow_dvd_xp_sub_one : q ^ q ∣ x ^ p - 1 := by
    have hqpow_dvd_yq : q ^ q ∣ y ^ q := pow_dvd_pow_of_dvd hq_dvd_y q
    have hxpow_sub : x ^ p - 1 = y ^ q := by omega
    rwa [hxpow_sub]
  by_cases hqx1 : q ∣ x - 1
  · left
    haveI : Fact q.Prime := ⟨hq⟩
    have hq_ne_two : q ≠ 2 := by
      have hp2 : 2 ≤ p := hp.two_le
      omega
    have hq_odd : Odd q := hq.odd_of_ne_two hq_ne_two
    have hq_not_dvd_p : ¬ q ∣ p := by
      intro hqp
      exact not_le_of_gt hpq (Nat.le_of_dvd hp.pos hqp)
    have hval_zero : padicValNat q p = 0 := padicValNat.eq_zero_of_not_dvd hq_not_dvd_p
    have hval_pow :
        padicValNat q (x ^ p - 1) = padicValNat q (x - 1) := by
      have h := padicValNat.pow_sub_pow hq_odd hx hqx1 hq_not_dvd_x hp.ne_zero
      rwa [one_pow, hval_zero, add_zero] at h
    have hle_q : q ≤ padicValNat q (x - 1) := by
      rcases (padicValNat_dvd_iff q (x ^ p - 1)).mp hqpow_dvd_xp_sub_one with hzero | hle
      · have hxpow_one : x ^ p = 1 := by omega
        have hxpow_gt_one : 1 < x ^ p := one_lt_pow₀ hx hp.ne_zero
        omega
      · rwa [hval_pow] at hle
    exact (padicValNat_dvd_iff q (x - 1)).mpr (Or.inr hle_q)
  · right
    exact exponent_prime_dvd_q_sub_one_of_not_dvd_a_sub_one
      (d := y ^ q) (a := x) (b := y) hp hq hq_dvd_y hq_not_dvd_x hqx1
      (by simpa using hpow.symm) rfl

private lemma lowerPrimeDivisorCatalan_not_cyclotomic_package
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q) (hq_dvd_y : q ∣ y)
    (hpow : x ^ p = y ^ q + 1) (hnot : ¬ p ∣ q - 1) :
    q ^ q ∣ x - 1 ∧
      ∃ c : ℕ, y + 1 = c ^ p ∧ c % p = 1 ∧ p ^ 2 ∣ y ∧ q ∣ c - 1 := by
  have hhigh : q ^ q ∣ x - 1 :=
    (lowerPrimeDivisorCatalan_high_qadic_or_cyclotomic
      hx hy hp hq hpq hq_dvd_y hpow).resolve_right hnot
  rcases lowerPrimeDivisorCatalan_lower_succ_pow_branch
      hx hy hp hq hp5 hpq hq_dvd_y hpow with
    ⟨c, hc, hcmod, hp2_dvd_y, hbranch⟩
  have hqc : q ∣ c - 1 := by
    rcases hbranch with hqc | hcyc
    · exact hqc
    · exact False.elim (hnot hcyc.2.1)
  exact ⟨hhigh, c, hc, hcmod, hp2_dvd_y, hqc⟩

theorem noLowerPrimeDivisorCatalanNat_of_branch_contradictions
    (hB : NoLowerPrimeDivisorBranchContradictionsNat) :
    NoLowerPrimeDivisorCatalanNat := by
  rcases hB with ⟨hHigh, hCyc⟩
  intro x y p q hx hy hp hq hp5 hq5 hpq hq_dvd_y hpow
  rcases lowerPrimeDivisorCatalan_high_qadic_or_cyclotomic
      hx hy hp hq hpq hq_dvd_y hpow with hhigh | hcyc
  · exact hHigh x y p q hx hy hp hq hp5 hq5 hpq hq_dvd_y hpow hhigh
  · exact hCyc x y p q hx hy hp hq hp5 hq5 hpq hq_dvd_y hpow hcyc

theorem noLowerPrimeDivisorCatalanNat_of_packaged_branch_contradictions
    (hB : NoLowerPrimeDivisorPackagedBranchContradictionsNat) :
    NoLowerPrimeDivisorCatalanNat := by
  rcases hB with ⟨hHigh, hCyc⟩
  intro x y p q hx hy hp hq hp5 hq5 hpq hq_dvd_y hpow
  by_cases hcyc : p ∣ q - 1
  · exact hCyc x y p q hx hy hp hq hp5 hq5 hpq hq_dvd_y hpow hcyc
  · rcases lowerPrimeDivisorCatalan_not_cyclotomic_package
        hx hy hp hq hp5 hpq hq_dvd_y hpow hcyc with
      ⟨hhigh, c, hc, hcmod, hp2_dvd_y, hqc⟩
    rcases lowerPrimeDivisorCatalan_lower_succ_pow_bounds
        hy hp hq hpow hc with ⟨hc_gt_one, hc_lt_x, hx_lt_cq⟩
    rcases lowerPrimeDivisorCatalan_lower_succ_divides_upper
        hx hy hp hq hq5 hq_dvd_y hpow hc with
      ⟨r, hr, hr_gt_one, hcop_cr, hr_lt⟩
    rcases lowerPrimeDivisorCatalan_high_branch_qadicVal_relations
        hx hy hc_gt_one hp hq hpq hq_dvd_y hpow hhigh hc hqc with
      ⟨hval_x, hval_y, hval_c_pos⟩
    rcases lowerPrimeDivisorCatalan_high_branch_quotient_q_unit
        hx hc_gt_one hq hhigh hqc hr hr_gt_one with
      ⟨hqr, hq_not_r⟩
    have hval_r :
        padicValNat q (r - 1) = padicValNat q (c - 1) :=
      lowerPrimeDivisorCatalan_high_branch_quotient_q_padicVal
        hc_gt_one hr_gt_one hq hval_x hval_c_pos hqc hr
    have hp_dvd_y : p ∣ y := by
      exact (show p ∣ p ^ 2 by rw [pow_two]; exact dvd_mul_right p p).trans
        hp2_dvd_y
    rcases lowerPrimeDivisorCatalan_high_branch_quotient_p_unit
        hx hp hq hp_dvd_y hpow hcmod hr hr_gt_one with
      ⟨hpr, hp_not_r⟩
    have hq_units :
        ∃ n C R W : ℕ, 0 < n ∧ 0 < W ∧
          0 < C ∧ 0 < R ∧
          c - 1 = q ^ n * C ∧ r - 1 = q ^ n * R ∧
          C + R = q ^ n * W ∧ ¬ q ∣ C ∧ ¬ q ∣ R ∧
          ¬ q ∣ W ∧
          x - 1 = q ^ (2 * n) * (W + C * R) ∧
          2 * n + padicValNat q (W + C * R) = q * n ∧
          3 * n ≤ padicValNat q (W + C * R) ∧
          q ^ (3 * n) ∣ W + C * R ∧
          (∃ Z : ℕ, 0 < Z ∧
            W + C * R = q ^ ((q - 2) * n) * Z ∧
            ¬ q ∣ Z ∧ p ∣ C ∧ p ∣ R ∧ p ∣ W ∧ p ∣ Z ∧
            p ≤ C ∧ p ≤ R ∧ p ≤ W ∧ p ≤ Z ∧
            (∃ C0 R0 W0 Z0 : ℕ,
              0 < C0 ∧ 0 < R0 ∧ 0 < W0 ∧ 0 < Z0 ∧
              C = p * C0 ∧ R = p * R0 ∧ W = p * W0 ∧
              Z = p * Z0 ∧
              ¬ q ∣ C0 ∧ ¬ q ∣ R0 ∧ ¬ q ∣ W0 ∧
              ¬ q ∣ Z0 ∧
              C0 + R0 = q ^ n * W0 ∧
              W0 + p * C0 * R0 =
                q ^ ((q - 2) * n) * Z0 ∧
              q ∣ C0 + R0 ∧ q ∣ W0 + p * C0 * R0 ∧
              ¬ q ∣ C0 * R0 ∧ ¬ q ∣ p * C0 * R0) ∧
            (∀ s u v : ℕ, 0 < s → r ^ p = q + c * s →
              s = q * u + 1 → u + 1 = p * v →
                q ^ (n - 1) ∣ v)) := by
      rcases exists_common_padic_unit_quotients hq
          (by omega : c - 1 ≠ 0) (by omega : r - 1 ≠ 0) hqc hval_r with
        ⟨n, C, R, hn_pos, hc_eq, hr_eq, hqC, hqR⟩
      rcases lowerPrimeDivisorCatalan_high_branch_q_second_depth_package
          hc_gt_one hr_gt_one hq hval_x hn_pos hc_eq hr_eq hqC hqR hr with
        ⟨W, hW_pos, hW, hx_second, htail_val⟩
      have hC_pos : 0 < C := by
        by_contra hnot
        have hC0 : C = 0 := Nat.eq_zero_of_not_pos hnot
        exact hqC (by rw [hC0]; exact dvd_zero q)
      have hR_pos : 0 < R := by
        by_contra hnot
        have hR0 : R = 0 := Nat.eq_zero_of_not_pos hnot
        exact hqR (by rw [hR0]; exact dvd_zero q)
      have htail_ge_three : 3 * n ≤ padicValNat q (W + C * R) := by
        nlinarith [hq5, htail_val]
      have htail_dvd_three : q ^ (3 * n) ∣ W + C * R := by
        haveI : Fact q.Prime := ⟨hq⟩
        apply (padicValNat_dvd_iff (3 * n) (W + C * R)).2
        exact Or.inr htail_ge_three
      have hq_tail : q ∣ W + C * R := by
        exact (dvd_pow_self q (by omega : 3 * n ≠ 0)).trans htail_dvd_three
      have hqW : ¬ q ∣ W := by
        intro hqW
        have hqCR : q ∣ C * R := by
          have hsub := Nat.dvd_sub hq_tail hqW
          have hsub_eq : (W + C * R) - W = C * R := by omega
          rwa [hsub_eq] at hsub
        rcases hq.dvd_mul.mp hqCR with hqC' | hqR'
        · exact hqC hqC'
        · exact hqR hqR'
      have htail_val_exact :
          padicValNat q (W + C * R) = (q - 2) * n := by
        have hdecomp : q * n = 2 * n + (q - 2) * n := by
          calc
            q * n = ((q - 2) + 2) * n := by
              rw [Nat.sub_add_cancel (by omega : 2 ≤ q)]
            _ = (q - 2) * n + 2 * n := by rw [Nat.add_mul]
            _ = 2 * n + (q - 2) * n := by rw [Nat.add_comm]
        exact Nat.add_left_cancel
          (show 2 * n + padicValNat q (W + C * R) =
              2 * n + (q - 2) * n from by
            calc
              2 * n + padicValNat q (W + C * R) = q * n := htail_val
              _ = 2 * n + (q - 2) * n := hdecomp)
      have htail_ne_zero : W + C * R ≠ 0 := by omega
      rcases exists_padic_unit_quotient_of_padicVal_eq hq htail_ne_zero
          htail_val_exact with
        ⟨Z, hZ_pos, hZ_eq, hqZ⟩
      have hp_ne_q : p ≠ q := by omega
      have hp_not_qpow_n : ¬ p ∣ q ^ n := by
        intro hpqpow
        have hpq_dvd : p ∣ q := hp.dvd_of_dvd_pow hpqpow
        exact hp_ne_q ((Nat.prime_dvd_prime_iff_eq hp hq).mp hpq_dvd)
      have hp_not_qpow_tail : ¬ p ∣ q ^ ((q - 2) * n) := by
        intro hpqpow
        have hpq_dvd : p ∣ q := hp.dvd_of_dvd_pow hpqpow
        exact hp_ne_q ((Nat.prime_dvd_prime_iff_eq hp hq).mp hpq_dvd)
      have hp_dvd_c_sub_one : p ∣ c - 1 := by
        have hc_modeq_one : c ≡ 1 [MOD p] := by
          have h : (1 : ℕ) ≡ c [MOD p] := by
            simpa [hcmod] using Nat.mod_modEq c p
          exact h.symm
