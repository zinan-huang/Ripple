theorem singletonModFiveNatPowerWitness_of_no_power_obstruction
    (hO : NoEhrenfestModFivePowerObstruction) :
    SingletonModFiveNatPowerWitness := by
  intro d hd hodd hmod
  by_cases hnot_one :
      ∀ p : ℕ, p.Prime → p ∣ d → ¬ ∃ a : ℕ, d + 1 = a ^ p
  · exact Or.inl hnot_one
  · by_cases hnot_two :
        ∀ q : ℕ, q.Prime → q ∣ d →
          ¬ ∃ a : ℕ, Nat.choose (d + 1) 2 = a ^ q
    · exact Or.inr hnot_two
    · exfalso
      obtain ⟨p, q, a, b, hobs⟩ :=
        singletonModFiveNatPower_branches_fail_gives_consecutive_powers
          hd hodd hmod hnot_one hnot_two
      exact hO d a b p q hd hodd hmod hobs

/-- Narrow no-solution form of the remaining Catalan/Cassels dependency.

In the Ehrenfest obstruction the lower exponent prime `q` already divides the
lower base.  Cassels' standard divisibility conclusion `q | x` would therefore
contradict coprimality immediately, but the project-specific content needed is
equivalently the absence of such a Catalan-type equation. -/
def NoLowerPrimeDivisorCatalanNat : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime →
    5 ≤ p → 5 ≤ q → p < q → q ∣ y → x ^ p = y ^ q + 1 → False

/-- The high `q`-adic branch of the remaining Catalan/Cassels dependency. -/
def NoLowerPrimeDivisorHighQadicBranchNat : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime →
    5 ≤ p → 5 ≤ q → p < q → q ∣ y → x ^ p = y ^ q + 1 →
      q ^ q ∣ x - 1 → False

/-- The cyclotomic branch of the remaining Catalan/Cassels dependency. -/
def NoLowerPrimeDivisorCyclotomicBranchNat : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime →
    5 ≤ p → 5 ≤ q → p < q → q ∣ y → x ^ p = y ^ q + 1 →
      p ∣ q - 1 → False

/-- A sharpened high `q`-adic branch after the local Cassels package.

Compared with `NoLowerPrimeDivisorHighQadicBranchNat`, this interface includes
the extra consequences already proved in Lean: the lower successor is a
`p`-th power, the lower base is divisible by `p^2`, and the non-cyclotomic
branch forces `q | c-1`. -/
def NoLowerPrimeDivisorPackagedHighBranchNat : Prop :=
  ∀ x y c r p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime →
    5 ≤ p → 5 ≤ q → p < q → q ∣ y → x ^ p = y ^ q + 1 →
      ¬ p ∣ q - 1 → q ^ q ∣ x - 1 → y + 1 = c ^ p →
        c % p = 1 → p ^ 2 ∣ y → q ∣ c - 1 →
          1 < c → c < x → x < c ^ q →
            x = c * r → 1 < r → Nat.Coprime c r → r < c ^ (q - 1) →
              padicValNat q (x - 1) = q * padicValNat q (c - 1) →
                padicValNat q y = padicValNat q (c - 1) →
                  1 ≤ padicValNat q (c - 1) →
                    q ∣ r - 1 →
                      padicValNat q (r - 1) = padicValNat q (c - 1) →
                      (∃ n C R W : ℕ, 0 < n ∧ 0 < W ∧
                        0 < C ∧ 0 < R ∧
                        c - 1 = q ^ n * C ∧ r - 1 = q ^ n * R ∧
                        C + R = q ^ n * W ∧ ¬ q ∣ C ∧ ¬ q ∣ R ∧
                        ¬ q ∣ W ∧
                        x - 1 = q ^ (2 * n) * (W + C * R) ∧
                        2 * n + padicValNat q (W + C * R) = q * n ∧
                        3 * n ≤ padicValNat q (W + C * R) ∧
                        q ^ (3 * n) ∣ W + C * R ∧
                        (∃ Z : ℕ, 0 < Z ∧
                          W + C * R = q ^ ((q - 2) * n) * Z ∧
                          ¬ q ∣ Z ∧ p ∣ C ∧ p ∣ R ∧ p ∣ W ∧ p ∣ Z ∧
                          p ≤ C ∧ p ≤ R ∧ p ≤ W ∧ p ≤ Z ∧
                          (∃ C0 R0 W0 Z0 : ℕ,
                            0 < C0 ∧ 0 < R0 ∧ 0 < W0 ∧ 0 < Z0 ∧
                            C = p * C0 ∧ R = p * R0 ∧ W = p * W0 ∧
                            Z = p * Z0 ∧
                            ¬ q ∣ C0 ∧ ¬ q ∣ R0 ∧ ¬ q ∣ W0 ∧
                            ¬ q ∣ Z0 ∧
                            C0 + R0 = q ^ n * W0 ∧
                            W0 + p * C0 * R0 =
                              q ^ ((q - 2) * n) * Z0 ∧
                            q ∣ C0 + R0 ∧ q ∣ W0 + p * C0 * R0 ∧
                            ¬ q ∣ C0 * R0 ∧ ¬ q ∣ p * C0 * R0) ∧
                          (∀ s u v : ℕ, 0 < s → r ^ p = q + c * s →
                            s = q * u + 1 → u + 1 = p * v →
                              q ^ (n - 1) ∣ v))) →
                      ¬ q ∣ r →
                      p ∣ r - 1 → ¬ p ∣ r →
                        r ^ p ≡ 1 [MOD q] → r ^ p ≡ q [MOD c] →
                          r ^ p ≡ q [MOD c ^ p] →
                          p < c → q < c → p < r → q < r →
                            (∃ s : ℕ, 0 < s ∧ r ^ p = q + c * s ∧
                              c ^ (p - 1) ∣ s ∧
                              s < c ^ ((q - 1) * p - 1) ∧
                              p < s ∧ q < s ∧
                              s ≡ 1 [MOD q] ∧ q + s ≡ 1 [MOD p] ∧
                              ¬ q ∣ s ∧ ¬ p ∣ s ∧ Nat.Coprime r s ∧
                              (∃ u v : ℕ, 0 < u ∧ 0 < v ∧
                                s = q * u + 1 ∧ u + 1 = p * v)) → False

/-- The exact two-branch form left after Cassels' local reduction. -/
def NoLowerPrimeDivisorBranchContradictionsNat : Prop :=
  NoLowerPrimeDivisorHighQadicBranchNat ∧
    NoLowerPrimeDivisorCyclotomicBranchNat

/-- Sharpened two-branch form using the packaged high `q`-adic branch. -/
def NoLowerPrimeDivisorPackagedBranchContradictionsNat : Prop :=
  NoLowerPrimeDivisorPackagedHighBranchNat ∧
    NoLowerPrimeDivisorCyclotomicBranchNat

/-- The high-branch dependency after all Catalan-shaped data has been stripped
away.

This is the actual local arithmetic core left by the current proof path.  It
mentions only the quotient factorization `x = c*r`, the common `q`-adic unit
decomposition of `c-1` and `r-1`, and the final quotient
`r^p = q + c*s`, `s = q*u + 1`, `u+1 = p*v`, including the proved depth
constraint `q^(n-1) | v`. -/
def NoLowerPrimeDivisorPackagedHighBranchCoreNat : Prop :=
  ∀ c r p q : ℕ, p.Prime → q.Prime → 5 ≤ p → 5 ≤ q → p < q →
    ¬ p ∣ q - 1 → c % p = 1 → q ∣ c - 1 →
      1 < c → 1 < r → Nat.Coprime c r → r < c ^ (q - 1) →
        ¬ q ∣ r → p ∣ r - 1 → ¬ p ∣ r →
          r ^ p ≡ 1 [MOD q] → r ^ p ≡ q [MOD c] →
            r ^ p ≡ q [MOD c ^ p] →
            p < c → q < c → p < r → q < r →
              (∃ n C R W Z C0 R0 W0 Z0 s u v V : ℕ,
                0 < n ∧ 0 < W ∧ 0 < C ∧ 0 < R ∧ 0 < Z ∧
                0 < C0 ∧ 0 < R0 ∧ 0 < W0 ∧ 0 < Z0 ∧
                c - 1 = q ^ n * C ∧ r - 1 = q ^ n * R ∧
                C + R = q ^ n * W ∧ ¬ q ∣ C ∧ ¬ q ∣ R ∧
                ¬ q ∣ W ∧
                W + C * R = q ^ ((q - 2) * n) * Z ∧ ¬ q ∣ Z ∧
                p ∣ C ∧ p ∣ R ∧ p ∣ W ∧ p ∣ Z ∧
                C = p * C0 ∧ R = p * R0 ∧ W = p * W0 ∧
                Z = p * Z0 ∧
                ¬ q ∣ C0 ∧ ¬ q ∣ R0 ∧ ¬ q ∣ W0 ∧ ¬ q ∣ Z0 ∧
                C0 + R0 = q ^ n * W0 ∧
                W0 + p * C0 * R0 = q ^ ((q - 2) * n) * Z0 ∧
                q ∣ C0 + R0 ∧ q ∣ W0 + p * C0 * R0 ∧
                ¬ q ∣ C0 * R0 ∧ ¬ q ∣ p * C0 * R0 ∧
                W0 ≡ p * C0 * C0 [MOD q] ∧
                W0 ≡ p * R0 * R0 [MOD q] ∧
                q ^ 3 ∣ W0 + p * C0 * R0 ∧
                (n = 1 →
                  W0 + p * q * C0 * W0 ≡ p * C0 * C0 [MOD q ^ 3]) ∧
                (n = 1 →
                  W0 + p * q * W0 * R0 ≡ p * R0 * R0 [MOD q ^ 3]) ∧
                (n = 1 →
                  W0 + p * q * C0 * W0 ≡ p * C0 * C0 [MOD q ^ 2]) ∧
                (n = 1 →
                  W0 + p * q * W0 * R0 ≡ p * R0 * R0 [MOD q ^ 2]) ∧
                (n = 1 →
                  ∃ D : ℤ,
                    (W0 : ℤ) - (p * C0 * C0 : ℤ) = (q : ℤ) * D ∧
                    D + (p * C0 * W0 : ℤ) ≡ 0 [ZMOD q] ∧
                    ¬ (q : ℤ) ∣ D) ∧
                (n = 1 →
                  ∃ D : ℤ,
                    (W0 : ℤ) - (p * R0 * R0 : ℤ) = (q : ℤ) * D ∧
                    D + (p * W0 * R0 : ℤ) ≡ 0 [ZMOD q] ∧
                    ¬ (q : ℤ) ∣ D) ∧
                (n = 1 →
                  W0 + p * q * C0 * W0 =
                    p * C0 * C0 + q ^ (q - 2) * Z0 ∧ ¬ q ∣ Z0) ∧
                (n = 1 →
                  W0 + p * q * W0 * R0 =
                    p * R0 * R0 + q ^ (q - 2) * Z0 ∧ ¬ q ∣ Z0) ∧
                (n = 1 →
                  ∃ D : ℤ,
                    (W0 : ℤ) - (p * C0 * C0 : ℤ) = (q : ℤ) * D ∧
                    D + (p * C0 * W0 : ℤ) =
                      (q : ℤ) ^ (q - 3) * (Z0 : ℤ) ∧
                    ¬ (q : ℤ) ∣ D) ∧
                (n = 1 →
                  ∃ D : ℤ,
                    (W0 : ℤ) - (p * R0 * R0 : ℤ) = (q : ℤ) * D ∧
                    D + (p * W0 * R0 : ℤ) =
                      (q : ℤ) ^ (q - 3) * (Z0 : ℤ) ∧
                    ¬ (q : ℤ) ∣ D) ∧
                (n = 1 →
                  ∃ DC DR : ℤ,
                    (W0 : ℤ) - (p * C0 * C0 : ℤ) = (q : ℤ) * DC ∧
                    (W0 : ℤ) - (p * R0 * R0 : ℤ) = (q : ℤ) * DR ∧
                    DC + (p * C0 * W0 : ℤ) =
                      (q : ℤ) ^ (q - 3) * (Z0 : ℤ) ∧
                    DR + (p * W0 * R0 : ℤ) =
                      (q : ℤ) ^ (q - 3) * (Z0 : ℤ) ∧
                    DC - DR =
                      (p * W0 : ℤ) * ((R0 : ℤ) - (C0 : ℤ)) ∧
                    ¬ (q : ℤ) ∣ DC ∧ ¬ (q : ℤ) ∣ DR ∧
                    ¬ (q : ℤ) ∣ DC - DR) ∧
                (n = 1 →
                  W0 + p * q * C0 * W0 ≡ p * C0 * C0 [MOD q ^ (q - 2)]) ∧
                (n = 1 →
                  W0 + p * q * W0 * R0 ≡ p * R0 * R0 [MOD q ^ (q - 2)]) ∧
                (n = 1 →
                  q ^ (q - 2) ∣
                    (W0 + p * q * C0 * W0) - p * C0 * C0) ∧
                (n = 1 →
                  q ^ (q - 2) ∣
                    (W0 + p * q * W0 * R0) - p * R0 * R0) ∧
                (n = 1 →
                  padicValNat q
                    ((W0 + p * q * C0 * W0) - p * C0 * C0) = q - 2) ∧
                (n = 1 →
                  padicValNat q
                    ((W0 + p * q * W0 * R0) - p * R0 * R0) = q - 2) ∧
                (2 ≤ n → q ^ 2 ∣ C0 + R0 ∧
                  q ^ 2 ∣ W0 + p * C0 * R0) ∧
                (2 ≤ n → W0 ≡ p * C0 * C0 [MOD q ^ 2] ∧
                  W0 ≡ p * R0 * R0 [MOD q ^ 2]) ∧
                0 < s ∧ r ^ p = q + c * s ∧ c ^ (p - 1) ∣ s ∧
                s < c ^ ((q - 1) * p - 1) ∧
                p < s ∧ q < s ∧
                s ≡ 1 [MOD q] ∧ q + s ≡ 1 [MOD p] ∧
                ¬ q ∣ s ∧ ¬ p ∣ s ∧ Nat.Coprime r s ∧
                0 < u ∧ 0 < v ∧ s = q * u + 1 ∧
                u + 1 = p * v ∧ q ^ (n - 1) ∣ v ∧
                0 < V ∧ v = q ^ (n - 1) * V ∧
                u + 1 = p * q ^ (n - 1) * V ∧
                (2 ≤ n → q ∣ u + 1 ∧ ¬ q ∣ u) ∧
                ¬ q ^ n ∣ u + 1 ∧
                q + s - 1 = p * q ^ n * V ∧
                V + C0 ≡ p * R0 [MOD q] ∧
                p ∣ V + C0 * s ∧
                V + C0 ≡ q * C0 [MOD p] ∧
                (n = 1 →
                  p * R0 + q * (p * Nat.choose p 2 * R0 * R0) ≡
                    V + C0 + q * C0 * u [MOD q ^ 2]) ∧
                (n = 1 →
                  ∃ L : ℕ,
                    p * R0 + q * (p * Nat.choose p 2 * R0 * R0) +
                      q ^ 2 * L =
                        V + C0 + q * C0 * u) ∧
                (n = 1 →
                  ∃ L : ℕ,
                    p * R0 + q * (p * Nat.choose p 2 * R0 * R0) +
                        q ^ 2 * L =
                      V + C0 + q * C0 * u ∧
                    L ≡ p ^ 2 * Nat.choose p 3 * R0 ^ 3 [MOD q] ∧
                    ¬ q ∣ L) ∧
                (n = 1 →
                  ∃ L B : ℕ,
                    p * R0 + q * (p * Nat.choose p 2 * R0 * R0) +
                        q ^ 2 * L =
                      V + C0 + q * C0 * u ∧
                    L = p * B ∧
                    B ≡ p * Nat.choose p 3 * R0 ^ 3 [MOD q] ∧
                    ¬ q ∣ B) ∧
                (n = 1 →
                  ∃ T1 : ℕ, 0 < T1 ∧
                    V + C0 + q * C0 * u = p * T1 ∧
                    T1 ≡ R0 [MOD q] ∧ ¬ q ∣ T1) ∧
                (n = 1 →
                  V + (p + 1) * C0 + q * C0 * u ≡
                    q * (p * W0 + p * Nat.choose p 2 * R0 * R0)
                      [MOD q ^ 2]) ∧
                (n = 1 →
                  ∃ L : ℕ,
                    V + (p + 1) * C0 + q * C0 * u =
                      q * (p * W0 + p * Nat.choose p 2 * R0 * R0 +
                        q * L)) ∧
                (n = 1 →
                  ∃ L : ℕ,
                    V + (p + 1) * C0 + q * C0 * u =
                        q * (p * W0 + p * Nat.choose p 2 * R0 * R0 +
                          q * L) ∧
                      p ∣ L) ∧
                (n = 1 →
                  ∃ T0 : ℕ, 0 < T0 ∧
                    V + (p + 1) * C0 + q * C0 * u = q * (p * T0) ∧
                    T0 ≡ W0 + Nat.choose p 2 * R0 * R0 [MOD q] ∧
                    ¬ q ∣ T0) ∧
                (n = 1 →
                  ∃ T0 T1 : ℕ, 0 < T0 ∧ 0 < T1 ∧
                    V + C0 + q * C0 * u = p * T1 ∧
                    V + (p + 1) * C0 + q * C0 * u = q * (p * T0) ∧
                    T1 + C0 = q * T0 ∧
                    T1 ≡ R0 [MOD q] ∧
                    T0 ≡ W0 + Nat.choose p 2 * R0 * R0 [MOD q] ∧
                    ¬ q ∣ T1 ∧ ¬ q ∣ T0) ∧
                (n = 1 →
                  ∃ A T0 T1 : ℕ, 0 < A ∧ 0 < T0 ∧ 0 < T1 ∧
                    V + C0 + q * C0 * u = p * T1 ∧
                    V + (p + 1) * C0 + q * C0 * u = q * (p * T0) ∧
                    T1 = R0 + q * A ∧ T0 = W0 + A ∧
                    T1 - R0 = q * A ∧ T0 - W0 = A ∧
                    q ∣ T1 - R0 ∧ ¬ q ^ 2 ∣ T1 - R0 ∧
                    ¬ q ∣ T0 - W0 ∧
                    padicValNat q (T1 - R0) = 1 ∧
                    padicValNat q (T0 - W0) = 0 ∧
                    padicValNat q A = 0 ∧
                    T1 + C0 = q * T0 ∧
                    (∃ B : ℕ, A = Nat.choose p 2 * R0 * R0 + q * B) ∧
                    (∃ B : ℕ,
                      T1 = R0 + q * (Nat.choose p 2 * R0 * R0) +
                        q ^ 2 * B ∧
                      T0 = W0 + Nat.choose p 2 * R0 * R0 + q * B) ∧
                    (∃ B : ℕ,
                      T1 - R0 =
                          q * (Nat.choose p 2 * R0 * R0) + q ^ 2 * B ∧
                        T0 - W0 = Nat.choose p 2 * R0 * R0 + q * B) ∧
                    A ≡ Nat.choose p 2 * R0 * R0 [MOD q] ∧
                    ¬ q ∣ A ∧
                    ¬ q ∣ Nat.choose p 2 * R0 * R0 ∧
                    ¬ q ∣ (p + Nat.choose p 2) * R0 * R0 ∧
                    padicValNat q (Nat.choose p 2 * R0 * R0) = 0 ∧
                    padicValNat q ((p + Nat.choose p 2) * R0 * R0) = 0 ∧
                    T1 ≡ R0 [MOD q] ∧
                    T1 ≡ R0 + q * (Nat.choose p 2 * R0 * R0) [MOD q ^ 2] ∧
                    T1 - R0 ≡ q * (Nat.choose p 2 * R0 * R0) [MOD q ^ 2] ∧
                    T0 ≡ W0 + Nat.choose p 2 * R0 * R0 [MOD q] ∧
                    T0 - W0 ≡ Nat.choose p 2 * R0 * R0 [MOD q] ∧
                    T0 ≡ (p + Nat.choose p 2) * R0 * R0 [MOD q] ∧
                    padicValNat q T1 = 0 ∧ padicValNat q T0 = 0 ∧
                    ¬ q ∣ V + C0 + q * C0 * u ∧
                    q ∣ V + (p + 1) * C0 + q * C0 * u ∧
                    ¬ q ^ 2 ∣ V + (p + 1) * C0 + q * C0 * u ∧
                    padicValNat q (V + C0 + q * C0 * u) = 0 ∧
                    padicValNat q
                      (V + (p + 1) * C0 + q * C0 * u) = 1 ∧
                    ¬ q ∣ T1 ∧ ¬ q ∣ T0) ∧
                (n = 1 →
                  ∃ A B T0 T1 : ℕ, 0 < A ∧ 0 < T0 ∧ 0 < T1 ∧
                    V + C0 + q * C0 * u = p * T1 ∧
                    V + (p + 1) * C0 + q * C0 * u = q * (p * T0) ∧
                    T1 = R0 + q * A ∧ T0 = W0 + A ∧
                    A = Nat.choose p 2 * R0 * R0 + q * B ∧
                    B ≡ p * Nat.choose p 3 * R0 ^ 3 [MOD q] ∧
                    ¬ q ∣ B ∧
                    T1 = R0 + q * (Nat.choose p 2 * R0 * R0) +
                      q ^ 2 * B ∧
                    T0 = W0 + Nat.choose p 2 * R0 * R0 + q * B) ∧
                (n = 1 →
                  ¬ q ^ 2 ∣ V + (p + 1) * C0 + q * C0 * u) ∧
                (n = 1 →
                  ∃ T : ℕ, 0 < T ∧
                    V + (p + 1) * C0 + q * C0 * u = q * T ∧
                    T ≡ p * W0 + p * Nat.choose p 2 * R0 * R0 [MOD q] ∧
                    ¬ q ∣ T) ∧
                (2 ≤ n → p * R0 ≡ V + C0 + q * C0 * u [MOD q ^ 2]) ∧
                (2 ≤ n → p * R0 + q * C0 ≡ V + C0 [MOD q ^ 2]) ∧
                V + (p + 1) * C0 ≡ 0 [MOD q] ∧
                (2 ≤ n → V + (p + 1) * C0 ≡ q * C0 [MOD q ^ 2]) ∧
                (2 ≤ n → ¬ q ^ 2 ∣ V + (p + 1) * C0) ∧
                (2 ≤ n →
                  ∃ T : ℕ, 0 < T ∧
                    V + (p + 1) * C0 = q * T ∧
                    T ≡ C0 [MOD q] ∧ ¬ q ∣ T) ∧
                (2 ≤ n →
                  padicValNat q (V + (p + 1) * C0) = 1) ∧
                ¬ q ∣ V ∧ ¬ q ^ (n + 1) ∣ q + s - 1) → False

/-- Sharpened two-branch form using the quotient-only high branch core. -/
def NoLowerPrimeDivisorCoreBranchContradictionsNat : Prop :=
  NoLowerPrimeDivisorPackagedHighBranchCoreNat ∧
    NoLowerPrimeDivisorCyclotomicBranchNat

/-- Cassels' upper-base divisibility theorem in exactly the range used here.

For a Catalan-shaped equation `x^p = y^q + 1` with prime exponents at least
five, the larger/lower-side exponent prime `q` divides the upper base `x`.
Together with `q | y`, this immediately contradicts coprimality of `x` and
`y`. -/
def CatalanCasselsUpperDivisorNat : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime →
    5 ≤ p → 5 ≤ q → x ^ p = y ^ q + 1 → q ∣ x

/-- Lower-prime Cassels upper-base divisibility frontier.

This is the exact range used by the Ehrenfest exceptional-class obstruction:
the normalized descent produces consecutive prime powers with `p < q`.
The full symmetric Cassels statement implies this, but the reverse-direction
`q < p` branch is irrelevant to the LPP proof. -/
def CatalanCasselsUpperDivisorNatLT : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime →
    5 ≤ p → 5 ≤ q → p < q → x ^ p = y ^ q + 1 → q ∣ x

/-- Standard natural-number form of Mihăilescu's theorem/Catalan's conjecture.

This is not used as an axiom in this file.  It is a precise interface for the
external theorem whose full formal proof would immediately close the narrower
`NoLowerPrimeDivisorCatalanNat` dependency below. -/
def MihailescuCatalanNat : Prop :=
  ∀ x y m n : ℕ, 1 < x → 1 < y → 1 < m → 1 < n →
    x ^ m = y ^ n + 1 → x = 3 ∧ m = 2 ∧ y = 2 ∧ n = 3

/-- Mihăilescu's double-Wieferich criterion for an odd-prime Catalan solution.

This is one of the standard intermediate theorems in Schoof's exposition:
for a nontrivial odd-prime solution `x^p = y^q + 1`, both exponent primes form
a double-Wieferich pair.  It is kept as a named interface so the final
cyclotomic proof can be decomposed into standard components. -/
def CatalanDoubleWieferichCriterionNat : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime → Odd p → Odd q →
    x ^ p = y ^ q + 1 →
      p ^ (q - 1) ≡ 1 [MOD q ^ 2] ∧ q ^ (p - 1) ≡ 1 [MOD p ^ 2]

/-- Mihăilescu's congruence alternative for an odd-prime Catalan solution. -/
def CatalanCongruenceAlternativeNat : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime → Odd p → Odd q →
    x ^ p = y ^ q + 1 → p ∣ q - 1 ∨ q ∣ p - 1

/-- Lower-prime specialization of the congruence alternative.

This is the exact non-cyclotomic input needed by the LPP obstruction route:
in the branch where the larger exponent prime `q` already divides the lower
base and `p < q`, any Catalan-shaped solution must be cyclotomic, i.e.
`p | q-1`. -/
def CatalanLowerPrimeCyclotomicAlternativeNat : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime →
    5 ≤ p → 5 ≤ q → p < q → q ∣ y →
      x ^ p = y ^ q + 1 → p ∣ q - 1

/-- Mihăilescu's exponent bound for an odd-prime Catalan solution. -/
def CatalanExponentBoundNat : Prop :=
  ∀ x y p q : ℕ, 1 < x → 1 < y → p.Prime → q.Prime → Odd p → Odd q →
    x ^ p = y ^ q + 1 → p < 4 * q ^ 2 ∧ q < 4 * p ^ 2

theorem catalanCasselsUpperDivisorNat_of_mihailescu
    (hM : MihailescuCatalanNat) :
    CatalanCasselsUpperDivisorNat := by
  intro x y p q hx hy hp hq hp5 _hq5 hpow
  exfalso
  rcases hM x y p q hx hy hp.one_lt hq.one_lt hpow with
    ⟨_hx3, hp2, _hy2, _hq3⟩
  omega

theorem catalanCasselsUpperDivisorNatLT_of_cassels_upper_divisor
    (hK : CatalanCasselsUpperDivisorNat) :
    CatalanCasselsUpperDivisorNatLT := by
  intro x y p q hx hy hp hq hp5 hq5 _hpq hpow
  exact hK x y p q hx hy hp hq hp5 hq5 hpow

theorem catalanCasselsUpperDivisorNatLT_of_mihailescu
    (hM : MihailescuCatalanNat) :
    CatalanCasselsUpperDivisorNatLT :=
  catalanCasselsUpperDivisorNatLT_of_cassels_upper_divisor
    (catalanCasselsUpperDivisorNat_of_mihailescu hM)

theorem noLowerPrimeDivisorCatalanNat_of_mihailescu
    (hM : MihailescuCatalanNat) :
    NoLowerPrimeDivisorCatalanNat := by
  intro x y p q hx hy hp hq hp5 _hq5 _hpq _hq_dvd_y hpow
  rcases hM x y p q hx hy hp.one_lt hq.one_lt hpow with
    ⟨_hx3, hp2, _hy2, _hq3⟩
  omega

theorem catalanDoubleWieferichCriterionNat_of_mihailescu
    (hM : MihailescuCatalanNat) :
    CatalanDoubleWieferichCriterionNat := by
  intro x y p q hx hy hp hq hp_odd _hq_odd hpow
  exfalso
  rcases hM x y p q hx hy hp.one_lt hq.one_lt hpow with
    ⟨_hx3, hp2, _hy2, _hq3⟩
  rw [hp2] at hp_odd
  rcases hp_odd with ⟨k, hk⟩
  omega

theorem catalanCongruenceAlternativeNat_of_mihailescu
    (hM : MihailescuCatalanNat) :
    CatalanCongruenceAlternativeNat := by
  intro x y p q hx hy hp hq hp_odd _hq_odd hpow
  exfalso
  rcases hM x y p q hx hy hp.one_lt hq.one_lt hpow with
    ⟨_hx3, hp2, _hy2, _hq3⟩
  rw [hp2] at hp_odd
  rcases hp_odd with ⟨k, hk⟩
  omega

theorem catalanLowerPrimeCyclotomicAlternativeNat_of_congruence_alternative
    (hAlt : CatalanCongruenceAlternativeNat) :
    CatalanLowerPrimeCyclotomicAlternativeNat := by
  intro x y p q hx hy hp hq _hp5 _hq5 hpq _hq_dvd_y hpow
  have hp_odd : Odd p := hp.odd_of_ne_two (by omega)
  have hq_odd : Odd q := hq.odd_of_ne_two (by omega)
  rcases hAlt x y p q hx hy hp hq hp_odd hq_odd hpow with hp_dvd | hq_dvd
  · exact hp_dvd
  · have hle : q ≤ p - 1 := Nat.le_of_dvd (by omega : 0 < p - 1) hq_dvd
    omega

theorem catalanLowerPrimeCyclotomicAlternativeNat_of_mihailescu
    (hM : MihailescuCatalanNat) :
    CatalanLowerPrimeCyclotomicAlternativeNat :=
  catalanLowerPrimeCyclotomicAlternativeNat_of_congruence_alternative
    (catalanCongruenceAlternativeNat_of_mihailescu hM)

theorem catalanExponentBoundNat_of_mihailescu
    (hM : MihailescuCatalanNat) :
    CatalanExponentBoundNat := by
  intro x y p q hx hy hp hq hp_odd _hq_odd hpow
  exfalso
  rcases hM x y p q hx hy hp.one_lt hq.one_lt hpow with
    ⟨_hx3, hp2, _hy2, _hq3⟩
  rw [hp2] at hp_odd
  rcases hp_odd with ⟨k, hk⟩
  omega

/-- Direct form of the paper's exceptional-class disjunction from Mihăilescu.

If the singleton-one Kummer condition and the singleton-two triangular-number
condition both fail, the already-formalized descent package produces
consecutive prime powers `a^p = b^q + 1` with `p,q ≥ 5`; Mihăilescu rules this
out immediately. -/
theorem singletonModFiveNatPowerWitness_of_mihailescu
    (hM : MihailescuCatalanNat) :
    SingletonModFiveNatPowerWitness := by
  intro d hd hodd hmod
  by_cases hA :
      ∀ p : ℕ, p.Prime → p ∣ d → ¬ ∃ a : ℕ, d + 1 = a ^ p
  · exact Or.inl hA
  · by_cases hB :
        ∀ q : ℕ, q.Prime → q ∣ d →
          ¬ ∃ a : ℕ, Nat.choose (d + 1) 2 = a ^ q
    · exact Or.inr hB
    · exfalso
      obtain ⟨p, q, a, b, hp, hq, _hpd, _hqd,
        _hp_odd, _hq_odd, _hp_ne_three, _hq_ne_three,
        hp5, _hq5, _hp_ne_q, _hp_lt_q,
        h6a, hb_mod_six, _hp_dvd_b, _hq_dvd_b, _hp_sq_dvd_b,
        _hcop_ab, _hp_not_dvd_a, _hq_not_dvd_a,
        _ha_mod_p, _hp_val_eq, _hq_dvd_pval, _hp_pow_dvd_a_sub_one,
        _hp_big_pow_dvd_a_sub_one, _hb_succ_pow_branch, _hhalf_pow,
        _hthree_q_dvd_a, _hthree_pq_dvd_bq_succ, _hthree_pq_dvd_b_succ,
        _hq_side, ha, hb⟩ :=
          singletonModFiveNatPower_branches_fail_gives_consecutive_powers
            hd hodd hmod hA hB
      have ha_ne_zero : a ≠ 0 := by
        intro haz
        rw [haz, zero_pow hp.ne_zero] at ha
        omega
      have ha_gt_one : 1 < a := by
        obtain ⟨m, hm⟩ := h6a
        cases m with
        | zero =>
            rw [mul_zero] at hm
            exact False.elim (ha_ne_zero (by omega))
        | succ m =>
            omega
      have hb_gt_one : 1 < b := by
        have hb_mod_lt : b % 6 < 6 := Nat.mod_lt b (by norm_num : 0 < 6)
        omega
      have hpow : a ^ p = b ^ q + 1 := by
        rw [← ha, ← hb]
      rcases hM a b p q ha_gt_one hb_gt_one hp.one_lt hq.one_lt hpow with
        ⟨_ha3, hp2, _hb2, _hq3⟩
      omega

theorem lowerPrimeDivisorCatalan_p_square_dvd_q_sub_one_of_double_wieferich
    (hW : CatalanDoubleWieferichCriterionNat)
    {x y p q : ℕ}
    (hx : 1 < x) (hy : 1 < y) (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hpq : p < q)
    (hcyc : p ∣ q - 1)
    (hpow : x ^ p = y ^ q + 1) :
    p ^ 2 ∣ q - 1 := by
  haveI : Fact p.Prime := ⟨hp⟩
  have hp_odd : Odd p := hp.odd_of_ne_two (by omega)
  have hq_odd : Odd q := hq.odd_of_ne_two (by omega)
  have hwie : q ^ (p - 1) ≡ 1 [MOD p ^ 2] :=
    (hW x y p q hx hy hp hq hp_odd hq_odd hpow).2
  have hp_not_dvd_q : ¬ p ∣ q := by
    intro hpq_dvd
    have hp_eq_q : p = q := (Nat.prime_dvd_prime_iff_eq hp hq).mp hpq_dvd
    omega
  have hp_not_dvd_pred : ¬ p ∣ p - 1 := by
    intro hpred
    have hle : p ≤ p - 1 := Nat.le_of_dvd (by omega : 0 < p - 1) hpred
    omega
  have hval_pred : padicValNat p (p - 1) = 0 :=
    padicValNat.eq_zero_of_not_dvd hp_not_dvd_pred
  have hp_pred_ne_zero : p - 1 ≠ 0 := by omega
  have hval_pow :
      padicValNat p (q ^ (p - 1) - 1) =
        padicValNat p (q - 1) := by
    have h := padicValNat.pow_sub_pow hp_odd hq.one_lt hcyc
      hp_not_dvd_q hp_pred_ne_zero
    rwa [one_pow, hval_pred, add_zero] at h
  have hdiv_pow : p ^ 2 ∣ q ^ (p - 1) - 1 := by
    have hge : 1 ≤ q ^ (p - 1) := one_le_pow₀ (le_of_lt hq.one_lt)
    exact (Nat.modEq_iff_dvd' hge).mp hwie.symm
  have hpow_sub_ne_zero : q ^ (p - 1) - 1 ≠ 0 := by
    have hpow_gt_one : 1 < q ^ (p - 1) :=
      one_lt_pow₀ hq.one_lt hp_pred_ne_zero
    omega
  have hval_pow_ge_two : 2 ≤ padicValNat p (q ^ (p - 1) - 1) := by
    rcases (padicValNat_dvd_iff 2 (q ^ (p - 1) - 1)).mp hdiv_pow with
      hzero | hle
    · exact False.elim (hpow_sub_ne_zero hzero)
    · exact hle
  have hval_q_sub_ge_two : 2 ≤ padicValNat p (q - 1) := by
    rwa [hval_pow] at hval_pow_ge_two
  exact (padicValNat_dvd_iff 2 (q - 1)).mpr (Or.inr hval_q_sub_ge_two)

private lemma no_prime_between_one_and_four_square_of_square_dvd_pred
    {p q : ℕ} (hp : p.Prime) (hq : q.Prime)
    (hp5 : 5 ≤ p) (hq5 : 5 ≤ q)
    (_hpq : p < q) (hp2_dvd_q_pred : p ^ 2 ∣ q - 1)
    (hq_bound : q < 4 * p ^ 2) :
    False := by
  rcases hp2_dvd_q_pred with ⟨k, hk⟩
  have hq_eq : q = p ^ 2 * k + 1 := by omega
  have hk_pos : 0 < k := by
    by_contra hk_nonpos
    have hk0 : k = 0 := by omega
    rw [hk0] at hq_eq
    omega
  have hmul_lt : p ^ 2 * k < p ^ 2 * 4 := by
    calc
      p ^ 2 * k < p ^ 2 * k + 1 := Nat.lt_succ_self _
      _ = q := hq_eq.symm
      _ < 4 * p ^ 2 := hq_bound
      _ = p ^ 2 * 4 := by ring
  have hk_lt_four : k < 4 :=
    lt_of_mul_lt_mul_left hmul_lt (by positivity : 0 ≤ p ^ 2)
  have hk_le_three : k ≤ 3 := by omega
  have hp_odd : Odd p := hp.odd_of_ne_two (by omega)
  have hq_odd : Odd q := hq.odd_of_ne_two (by omega)
  interval_cases k
  · rcases hp_odd with ⟨u, hp_eq⟩
    rcases hq_odd with ⟨v, hq_odd_eq⟩
    rw [hq_eq, hp_eq] at hq_odd_eq
    ring_nf at hq_odd_eq
    omega
  · have hp_ne_three : p ≠ 3 := by omega
    have hthree_not_dvd_p : ¬ 3 ∣ p := by
      intro h3p
      have h3eqp : 3 = p :=
        (Nat.prime_dvd_prime_iff_eq Nat.prime_three hp).mp h3p
      omega
    have hp_mod_ne_zero : p % 3 ≠ 0 := by
      intro hmod
      exact hthree_not_dvd_p (Nat.dvd_iff_mod_eq_zero.mpr hmod)
    have hp_mod_lt : p % 3 < 3 := Nat.mod_lt p (by norm_num : 0 < 3)
    have hp_mod_cases : p % 3 = 1 ∨ p % 3 = 2 := by omega
    rcases hp_mod_cases with hpmod | hpmod
    · let t := p / 3
      have hp_decomp : p = 3 * t + 1 := by
        calc
          p = p % 3 + 3 * (p / 3) := by rw [Nat.mod_add_div]
          _ = 3 * t + 1 := by omega
      have h3q : 3 ∣ q := by
        use 6 * t ^ 2 + 4 * t + 1
        rw [hq_eq, hp_decomp]
        ring
      have hq_eq_three : q = 3 :=
        ((Nat.prime_dvd_prime_iff_eq Nat.prime_three hq).mp h3q).symm
      omega
    · let t := p / 3
      have hp_decomp : p = 3 * t + 2 := by
        calc
          p = p % 3 + 3 * (p / 3) := by rw [Nat.mod_add_div]
          _ = 3 * t + 2 := by omega
      have h3q : 3 ∣ q := by
        use 6 * t ^ 2 + 8 * t + 3
        rw [hq_eq, hp_decomp]
        ring
      have hq_eq_three : q = 3 :=
        ((Nat.prime_dvd_prime_iff_eq Nat.prime_three hq).mp h3q).symm
      omega
  · rcases hp_odd with ⟨u, hp_eq⟩
    rcases hq_odd with ⟨v, hq_odd_eq⟩
    rw [hq_eq, hp_eq] at hq_odd_eq
    ring_nf at hq_odd_eq
    omega

