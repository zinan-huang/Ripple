private lemma quotient_order_branch_of_pow_mul_modeq_one
    {t p q : ℕ} (hp : p.Prime) (hq : q.Prime)
    (ht_gt_one : 1 < t) (hqt : ¬ q ∣ t)
    (hpow : t ^ (p * q) ≡ 1 [MOD q]) :
    q ∣ t - 1 ∨ p ∣ q - 1 := by
  by_cases hqt1 : q ∣ t - 1
  · exact Or.inl hqt1
  · right
    haveI : NeZero q := ⟨hq.ne_zero⟩
    have hcop_tq : t.Coprime q := (hq.coprime_iff_not_dvd).mpr hqt |>.symm
    let u : (ZMod q)ˣ := ZMod.unitOfCoprime t hcop_tq
    have hu_pow : u ^ (p * q) = 1 := by
      ext
      change ((u : ZMod q) ^ (p * q)) = (1 : ZMod q)
      rw [ZMod.coe_unitOfCoprime]
      rw [← Nat.cast_pow]
      simpa using (ZMod.natCast_eq_natCast_iff (t ^ (p * q)) 1 q).mpr hpow
    have ht_pos : 1 ≤ t := le_of_lt ht_gt_one
    have hu_ne_one : u ≠ 1 := by
      intro hu
      have ht_cast_one : (t : ZMod q) = 1 := by
        calc
          (t : ZMod q) = (u : ZMod q) := by
            simp [u, ZMod.coe_unitOfCoprime]
          _ = (1 : ZMod q) := by rw [hu]; rfl
      have ht_modeq_one : t ≡ 1 [MOD q] :=
        (ZMod.natCast_eq_natCast_iff t 1 q).mp (by
          simpa using ht_cast_one)
      exact hqt1 ((Nat.modEq_iff_dvd' ht_pos).mp ht_modeq_one.symm)
    have horder_dvd_pq : orderOf u ∣ p * q := orderOf_dvd_of_pow_eq_one hu_pow
    have horder_dvd_qsub : orderOf u ∣ q - 1 := by
      have horder_dvd_card : orderOf u ∣ Nat.card (ZMod q)ˣ := orderOf_dvd_natCard u
      rwa [Nat.card_eq_fintype_card, ZMod.card_units_eq_totient q,
        Nat.totient_prime hq] at horder_dvd_card
    have hq_not_dvd_qsub : ¬ q ∣ q - 1 := by
      intro hqdiv
      have hpos : 0 < q - 1 := Nat.sub_pos_of_lt hq.one_lt
      have hle : q ≤ q - 1 := Nat.le_of_dvd hpos hqdiv
      omega
    have hq_not_dvd_order : ¬ q ∣ orderOf u := by
      intro hqdiv
      exact hq_not_dvd_qsub (dvd_trans hqdiv horder_dvd_qsub)
    have hcop_order_q : Nat.Coprime (orderOf u) q :=
      ((hq.coprime_iff_not_dvd).mpr hq_not_dvd_order).symm
    have horder_dvd_p : orderOf u ∣ p :=
      (hcop_order_q.dvd_mul_right).mp horder_dvd_pq
    rcases (Nat.dvd_prime hp).mp horder_dvd_p with horder_one | horder_p
    · exact False.elim (hu_ne_one (orderOf_eq_one_iff.mp horder_one))
    · rwa [horder_p] at horder_dvd_qsub

private lemma obstruction_descended_quotient_order_branch
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
        Nat.Coprime a b ∧ ¬ p ∣ a ∧ ¬ q ∣ a ∧
        a % p = 1 ∧
        padicValNat p (a - 1) + 1 = q * padicValNat p b ∧
        q ∣ padicValNat p (a - 1) + 1 ∧
        p ^ (q - 1) ∣ a - 1 ∧
        p ^ (2 * q - 1) ∣ a - 1 ∧
        (∃ c : ℕ, b + 1 = c ^ p ∧ 6 ∣ c ∧ c % p = 1 ∧
          3 ^ q ∣ c ∧
          (∃ s : ℕ, c ^ p = 2 * s ^ q) ∧
