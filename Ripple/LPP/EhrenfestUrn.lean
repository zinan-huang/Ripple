private lemma q_dvd_sum_Icc_of_q_dvd_terms
    {q lo hi : ℕ} {f : ℕ → ℕ}
    (h : ∀ j, lo ≤ j → j ≤ hi → q ∣ f j) :
    q ∣ ∑ j ∈ Finset.Icc lo hi, f j := by
  exact Finset.dvd_sum (fun j hj => h j (Finset.mem_Icc.mp hj).1 (Finset.mem_Icc.mp hj).2)

