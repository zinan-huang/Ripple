private lemma ten_mul_choose_succ_six_eq_mod_six_five_factorization
    (d : ℕ) (hd : 5 ≤ d) (hmod : d % 6 = 5) :
    10 * Nat.choose (d + 1) 6 =
      ((d + 1) / 6) * d * (3 * ((d + 1) / 6) - 1) *
        (2 * ((d + 1) / 6) - 1) * (3 * ((d + 1) / 6) - 2) *
        (6 * ((d + 1) / 6) - 5) := by
  let m := (d + 1) / 6
  have h6 : 6 ∣ d + 1 := by omega
  have hm : d + 1 = 6 * m := by
    rw [show 6 * m = m * 6 by rw [mul_comm]]
    exact (Nat.div_mul_cancel h6).symm
  have hdm : d = 6 * m - 1 := by omega
  apply Nat.cast_injective (R := ℝ)
  have hcast := singletonSix_choose_six_cast d hd
  have hm_real : ((d : ℝ) + 1) = 6 * (m : ℝ) := by exact_mod_cast hm
  have hdm_real : (d : ℝ) = 6 * (m : ℝ) - 1 := by
    rw [hdm, Nat.cast_sub (by omega : 1 ≤ 6 * m)]
    norm_num
  have h3m1_real : ((3 * m - 1 : ℕ) : ℝ) = 3 * (m : ℝ) - 1 := by
    rw [Nat.cast_sub (by omega : 1 ≤ 3 * m)]
    norm_num
  have h2m1_real : ((2 * m - 1 : ℕ) : ℝ) = 2 * (m : ℝ) - 1 := by
    rw [Nat.cast_sub (by omega : 1 ≤ 2 * m)]
    norm_num
  have h3m2_real : ((3 * m - 2 : ℕ) : ℝ) = 3 * (m : ℝ) - 2 := by
    rw [Nat.cast_sub (by omega : 2 ≤ 3 * m)]
    norm_num
  have h6m5_real : ((6 * m - 5 : ℕ) : ℝ) = 6 * (m : ℝ) - 5 := by
    rw [Nat.cast_sub (by omega : 5 ≤ 6 * m)]
    norm_num
  have hdiv : (d + 1) / 6 = m := rfl
  norm_num [Nat.cast_mul, hcast, Nat.cast_add, Nat.cast_one,
    Nat.cast_sub (by omega : 1 ≤ d), Nat.cast_sub (by omega : 2 ≤ d),
    Nat.cast_sub (by omega : 3 ≤ d), Nat.cast_sub (by omega : 4 ≤ d)]
  rw [hm_real, hdm_real, h3m1_real, h2m1_real, h3m2_real, h6m5_real, hdiv]
  ring_nf

private lemma singletonSix_factor_at_inv_two_d (d : ℕ) (hd : 5 ≤ d) :
    ((Nat.choose (d + 1) 6 : ℕ) : ℝ) * (1 / (2 * (d : ℝ))) ^ 5 *
        (1 - 1 / (2 * (d : ℝ))) ^ (d - 5) =
      ((((d + 1 : ℕ) : ℝ) * ((d - 1 : ℕ) : ℝ) *
          ((d - 2 : ℕ) : ℝ) * ((d - 3 : ℕ) : ℝ) *
          ((d - 4 : ℕ) : ℝ)) / (23040 * (d : ℝ) ^ 4)) *
        (1 - 1 / (2 * (d : ℝ))) ^ (d - 5) := by
  have hd_ne : (d : ℝ) ≠ 0 := by positivity
  rw [singletonSix_choose_six_cast d hd]
  field_simp [hd_ne]
  ring

private lemma singletonSix_pow_lower_at_inv_two_d (d : ℕ) (hd : 5 ≤ d) :
    (((d + 1 : ℕ) : ℝ) / (2 * (d : ℝ))) ≤
      (1 - 1 / (2 * (d : ℝ))) ^ (d - 5) := by
  have hlower := singletonFive_pow_lower_at_inv_two_d d (by omega : 4 ≤ d)
  have hbase_nonneg : 0 ≤ (1 - 1 / (2 * (d : ℝ))) := by
    have hd_real : (5 : ℝ) ≤ d := by exact_mod_cast hd
    have hden_pos : (0 : ℝ) < 2 * (d : ℝ) := by positivity
    rw [sub_nonneg]
    rw [div_le_iff₀ hden_pos]
    nlinarith
  have hbase_le_one : (1 - 1 / (2 * (d : ℝ))) ≤ 1 := by
    have hinv_nonneg : 0 ≤ 1 / (2 * (d : ℝ)) := by positivity
    nlinarith
  have hpow_nonneg : 0 ≤ (1 - 1 / (2 * (d : ℝ))) ^ (d - 5) :=
    pow_nonneg hbase_nonneg _
  have hpow_mono :
      (1 - 1 / (2 * (d : ℝ))) ^ (d - 4) ≤
        (1 - 1 / (2 * (d : ℝ))) ^ (d - 5) := by
    rw [show d - 4 = d - 5 + 1 by omega, pow_succ]
    exact mul_le_of_le_one_right hpow_nonneg hbase_le_one
  exact le_trans hlower hpow_mono

private lemma singletonSix_factor_gt_one_at_inv_two_d_large
