  have hsub1 : d + 1 - 2 = d - 1 := by omega
  have hsub2 : d + 1 - 3 = d - 2 := by omega
  have hsub3 : d + 1 - 4 = d - 3 := by omega
  have hsub4 : d + 1 - 5 = d - 4 := by omega
  rw [hsub1, hsub2, hsub3, hsub4] at hdiv0 ⊢
