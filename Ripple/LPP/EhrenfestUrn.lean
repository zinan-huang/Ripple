  apply singletonTwoClosedNewtonPolynomial_irreducible_of_eisenstein_data d hd 𝓟 hprime
  · intro n hn
    obtain ⟨m, hm⟩ := singletonTwoClosedNewtonPolynomial_coeff_dvd_choose d n hn
    rw [hm]
