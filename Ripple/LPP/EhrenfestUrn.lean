            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q) :
    ∃ c t s C S n U V : ℕ,
      b + 1 = c ^ p ∧ a = c * t ^ q ∧ c ^ p = 2 * s ^ q ∧
        c = 3 ^ q * C ∧ s = 3 ^ p * S ∧ C ^ p = 2 * S ^ q ∧
