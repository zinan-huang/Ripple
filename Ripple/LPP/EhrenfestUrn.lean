  have hd5 : 5 ≤ d := by
    have hle : d % 6 ≤ d := Nat.mod_le d 6
    omega
  obtain ⟨j, ν, q, P, hj2, hν, hq0, hq1, hroot, hmono, hdeg, hP_root, hP_irr⟩ :=
