private lemma obstruction_cassels_left_branch_factor
    {d a b p q : ℕ}
    (hobs :
      p.Prime ∧ q.Prime ∧ p ∣ d ∧ q ∣ d ∧
        Odd p ∧ Odd q ∧ p ≠ 3 ∧ q ≠ 3 ∧
        5 ≤ p ∧ 5 ≤ q ∧ p ≠ q ∧ p < q ∧
        6 ∣ a ∧ b % 6 = 5 ∧ p ∣ b ∧ q ∣ b ∧ p ^ 2 ∣ b ∧
