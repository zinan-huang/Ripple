    rwa [← hA]
  have hq_dvd_Apow : q ∣ A ^ q :=
    (hq.dvd_mul.mp hq_dvd_prod).resolve_left hq_not_dvd_ppow
  exact ⟨A, B, hA, hB, hb_eq, hq.dvd_of_dvd_pow hq_dvd_Apow⟩

