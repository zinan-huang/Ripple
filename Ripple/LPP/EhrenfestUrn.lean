private theorem singletonTwoClosedNewtonPolynomial_irreducible_of_prime_dvd_choose_not_square_dvd
    (d : ℕ) (hd : 2 ≤ d) (hodd : Odd d) (p : ℕ) (hp : p.Prime)
    (hpdvd : (p : ℤ) ∣ (Nat.choose (d + 1) 2 : ℤ))
    (hp2not : ¬ (p : ℤ) ^ 2 ∣ (Nat.choose (d + 1) 2 : ℤ)) :
    Irreducible (singletonTwoClosedNewtonPolynomial d) := by
  apply singletonTwoClosedNewtonPolynomial_irreducible_of_eisenstein_choose_mem d hd hodd
