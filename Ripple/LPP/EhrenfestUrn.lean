    hq_not_c, hq_not_t, hcop_ct,
    quotient_order_branch_of_pow_mul_modeq_one hp hq ht_gt_one hq_not_t ht_pow⟩

private lemma p_dvd_descended_t_sub_one_of_mods
    {a c t p q : ℕ} (hp : p.Prime) (hq : q.Prime) (hp_lt_q : p < q)
    (ha_mod_p : a % p = 1) (hc_mod_p : c % p = 1)
    (hdesc : a = c * t ^ q) :
    p ∣ t - 1 := by
  haveI : NeZero p := ⟨hp.ne_zero⟩
  have ha_modeq_one : a ≡ 1 [MOD p] := by
    have h : (1 : ℕ) ≡ a [MOD p] := by
      simpa [ha_mod_p] using Nat.mod_modEq a p
    exact h.symm
  have hc_modeq_one : c ≡ 1 [MOD p] := by
    have h : (1 : ℕ) ≡ c [MOD p] := by
      simpa [hc_mod_p] using Nat.mod_modEq c p
    exact h.symm
  have htq_modeq_one : t ^ q ≡ 1 [MOD p] := by
    have hmul : c * t ^ q ≡ 1 * t ^ q [MOD p] :=
      Nat.ModEq.mul_right (t ^ q) hc_modeq_one
    have hdesc_modeq : a ≡ t ^ q [MOD p] := by
      rw [hdesc]
      simpa using hmul
    exact hdesc_modeq.symm.trans ha_modeq_one
  have hp_not_dvd_t : ¬ p ∣ t := by
    intro hpt
    have htq_zero : t ^ q ≡ 0 [MOD p] :=
      Nat.modEq_zero_iff_dvd.mpr (dvd_pow hpt hq.ne_zero)
    have hone_zero : 1 ≡ 0 [MOD p] := htq_modeq_one.symm.trans htq_zero
    exact hp.not_dvd_one (Nat.modEq_zero_iff_dvd.mp hone_zero)
  have ht_pos : 1 ≤ t := Nat.one_le_iff_ne_zero.mpr (by
    intro ht0
    exact hp_not_dvd_t (by rw [ht0]; exact dvd_zero p))
  have hcop_tp : t.Coprime p := (hp.coprime_iff_not_dvd).mpr hp_not_dvd_t |>.symm
  let u : (ZMod p)ˣ := ZMod.unitOfCoprime t hcop_tp
  have hu_pow : u ^ q = 1 := by
    ext
    change ((u : ZMod p) ^ q) = (1 : ZMod p)
    rw [ZMod.coe_unitOfCoprime]
    rw [← Nat.cast_pow]
    simpa using (ZMod.natCast_eq_natCast_iff (t ^ q) 1 p).mpr htq_modeq_one
  have horder_dvd_q : orderOf u ∣ q := orderOf_dvd_of_pow_eq_one hu_pow
  have horder_dvd_psub : orderOf u ∣ p - 1 := by
    have horder_dvd_card : orderOf u ∣ Nat.card (ZMod p)ˣ := orderOf_dvd_natCard u
    rwa [Nat.card_eq_fintype_card, ZMod.card_units_eq_totient p,
      Nat.totient_prime hp] at horder_dvd_card
  have hq_not_dvd_psub : ¬ q ∣ p - 1 := by
    intro hqdiv
    have hpos : 0 < p - 1 := Nat.sub_pos_of_lt hp.one_lt
    have hle : q ≤ p - 1 := Nat.le_of_dvd hpos hqdiv
    omega
  have hu_one : u = 1 := by
    rcases (Nat.dvd_prime hq).mp horder_dvd_q with horder_one | horder_q
    · exact orderOf_eq_one_iff.mp horder_one
    · exact False.elim (hq_not_dvd_psub (by rwa [horder_q] at horder_dvd_psub))
  have ht_cast_one : (t : ZMod p) = 1 := by
    calc
      (t : ZMod p) = (u : ZMod p) := by
        simp [u, ZMod.coe_unitOfCoprime]
      _ = (1 : ZMod p) := by rw [hu_one]; rfl
  have ht_modeq_one : t ≡ 1 [MOD p] :=
    (ZMod.natCast_eq_natCast_iff t 1 p).mp (by
      simpa using ht_cast_one)
  exact (Nat.modEq_iff_dvd' ht_pos).mp ht_modeq_one.symm

