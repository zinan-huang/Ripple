      hval_base_expr, hval_combo_expr,
      hqT1, hqT0⟩
  have hV_depth_one_p_factor_shift_pair_third :
      n = 1 →
        ∃ A B T0 T1 : ℕ, 0 < A ∧ 0 < T0 ∧ 0 < T1 ∧
          V + C0 + q * C0 * u = p * T1 ∧
          V + (p + 1) * C0 + q * C0 * u = q * (p * T0) ∧
