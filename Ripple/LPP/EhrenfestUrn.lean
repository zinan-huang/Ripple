private abbrev SingletonIndexSquarefreeFactorData (d : ℕ) : Prop :=
  ∃ (j : Fin (d + 2)) (q : ℚ) (p : ℕ),
    2 ≤ j.val ∧ j.val < d + 1 ∧
    0 < (q : ℝ) ∧ (q : ℝ) < 1 ∧
    1 < ((Nat.choose (d + 1) j.val : ℕ) : ℝ) *
      (q : ℝ) ^ (j.val - 1) * (1 - (q : ℝ)) ^ (d + 1 - j.val) ∧
    p.Prime ∧
    (p : ℤ) ∣ (Nat.choose (d + 1) j.val : ℤ) ∧
    ¬ (p : ℤ) ^ 2 ∣ (Nat.choose (d + 1) j.val : ℤ)

