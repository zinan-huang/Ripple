private lemma q_dvd_descended_t_sub_one_of_a_c_sub_one
    {a c t q : ℕ} (hq : q.Prime)
    (hc_pos : 1 ≤ c) (ht_pos : 1 ≤ t)
    (hqt : ¬ q ∣ t) (ha : a = c * t ^ q)
    (hqa : q ∣ a - 1) (hqc : q ∣ c - 1) :
    q ∣ t - 1 := by
  have hcop_tq : t.Coprime q := (hq.coprime_iff_not_dvd).mpr hqt |>.symm
  have ht_pow_modeq : t ^ q ≡ t [MOD q] := by
    have hfermat : t ^ (q - 1) ≡ 1 [MOD q] :=
      Nat.ModEq.pow_card_sub_one_eq_one hq hcop_tq
    calc
      t ^ q = t ^ ((q - 1) + 1) := by
        congr 1
        exact (Nat.sub_add_cancel hq.one_le).symm
      _ = t ^ (q - 1) * t := by rw [pow_succ]
      _ ≡ 1 * t [MOD q] := Nat.ModEq.mul_right t hfermat
      _ = t := by rw [one_mul]
  have hc_modeq_one : c ≡ 1 [MOD q] :=
    ((Nat.modEq_iff_dvd' hc_pos).mpr hqc).symm
  have ha_pos : 1 ≤ a := by
    rw [ha]
    exact Nat.succ_le_of_lt (mul_pos (Nat.pos_of_ne_zero (by omega)) (pow_pos (by omega) q))
  have ha_modeq_one : a ≡ 1 [MOD q] :=
    ((Nat.modEq_iff_dvd' ha_pos).mpr hqa).symm
  have ha_modeq_t : a ≡ t [MOD q] := by
    rw [ha]
    simpa [one_mul] using hc_modeq_one.mul ht_pow_modeq
  exact (Nat.modEq_iff_dvd' ht_pos).mp (ha_modeq_one.symm.trans ha_modeq_t)

