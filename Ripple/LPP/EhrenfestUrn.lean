private lemma pow_self_modEq_one_mod_sq_of_dvd_sub_one
    {t q : ℕ} (_hq : q.Prime) (ht : 1 ≤ t) (hqt : q ∣ t - 1) :
    t ^ q ≡ 1 [MOD q ^ 2] := by
  rcases hqt with ⟨T, hT⟩
  have ht_form : t = 1 + q * T := by omega
  rcases exists_pow_one_add_eq_linear_add_sq (q * T) q with ⟨R, hR⟩
  rw [ht_form, hR]
  symm
  apply (Nat.modEq_iff_dvd' (by omega : 1 ≤ 1 + q * (q * T) + (q * T) ^ 2 * R)).mpr
  have hsub :
      (1 + q * (q * T) + (q * T) ^ 2 * R) - 1 =
        q * (q * T) + (q * T) ^ 2 * R := by omega
  rw [hsub]
  have hfirst : q ^ 2 ∣ q * (q * T) := by
    convert dvd_mul_right (q ^ 2) T using 1
    ring
  have hsquare : q ^ 2 ∣ (q * T) ^ 2 := by
    convert dvd_mul_right (q ^ 2) (T ^ 2) using 1
    ring
  have hsecond : q ^ 2 ∣ (q * T) ^ 2 * R :=
    dvd_mul_of_dvd_left hsquare R
  exact dvd_add hfirst hsecond

private lemma lower_half_root_base_two_wieferich_modEq
    {c s p q : ℕ}
    (hq : q.Prime) (hc_ge_one : 1 ≤ c) (hs_ge_one : 1 ≤ s)
    (hq_sq_c : q ^ 2 ∣ c - 1) (hc_pow_two : c ^ p = 2 * s ^ q)
    (htwo_s : 2 * s ≡ 1 [MOD q]) :
    2 ^ (q - 1) ≡ 1 [MOD q ^ 2] := by
  have htwos_ge_one : 1 ≤ 2 * s := by omega
