            padicValNat q (a - 1) = q * padicValNat q b ∧
            q ^ q ∣ a - 1) ∨
          (¬ q ∣ a - 1 ∧ p ∣ q - 1 ∧ p < q)) ∧
        d + 1 = a ^ p ∧ d = b ^ q)
    (hqa : q ∣ a - 1) :
    ∃ A B : ℕ,
      a - 1 = p ^ (q - 1) * A ^ q ∧
        (∑ i ∈ Finset.range p, a ^ i) = p * B ^ q ∧
        b = p * A * B ∧ q ∣ A := by
  rcases obstruction_cassels_p_shape hobs with
    ⟨A, B, hA, hB, hb_eq, _hqAB⟩
  rcases hobs with ⟨hp, hq, _hpd, _hqd, _hp_odd, _hq_odd,
    _hp_ne_three, _hq_ne_three, _hp5, _hq5, hp_ne_q, _tail⟩
  have hq_not_dvd_p : ¬ q ∣ p := by
    intro hqp
    exact hp_ne_q ((Nat.prime_dvd_prime_iff_eq hq hp).mp hqp).symm
  have hcop_q_p : Nat.Coprime q p :=
    (hq.coprime_iff_not_dvd).mpr hq_not_dvd_p
  have hcop_q_ppow : Nat.Coprime q (p ^ (q - 1)) :=
    hcop_q_p.pow_right (q - 1)
  have hq_not_dvd_ppow : ¬ q ∣ p ^ (q - 1) := by
    intro hqpow
    have hqgcd : q ∣ Nat.gcd q (p ^ (q - 1)) :=
