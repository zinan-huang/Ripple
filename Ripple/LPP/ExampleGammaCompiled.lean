set_option maxHeartbeats 800000 in
private lemma gammaCompiledJump_injective :
    Function.Injective gammaCompiledJump := by
  intro a b hab
  fin_cases a <;> fin_cases b <;> first | rfl | (exfalso; revert hab; native_decide)

private theorem gammaCompiledRate_sum_eq (k : Fin 32) (x : Fin 21 → ℝ) :
    (∑ j : Fin 32, if gammaCompiledJump j = gammaCompiledJump k then gammaCompiledRate j x else 0) =
      gammaCompiledRate k x := by
  conv_lhs => rw [Finset.sum_eq_single k
    (fun j _ hjk => by simp [show gammaCompiledJump j ≠ gammaCompiledJump k from
      fun h => hjk (gammaCompiledJump_injective h)])
    (fun hk => absurd (Finset.mem_univ k) hk)]
  simp

set_option maxHeartbeats 0 in
theorem gammaCompiledRateSpec_drift_eq :
    gammaCompiledRateSpec.drift = gammaCompiledField := by
  ext x i
  simp only [RateSpec.drift, gammaCompiledRateSpec]
  rw [Finset.sum_image (fun a _ b _ h => gammaCompiledJump_injective h)]
  simp_rw [gammaCompiledRate_sum_eq]
  fin_cases i <;> (
    simp only [Finset.sum_fin_eq_sum_range, Finset.sum_range_succ, Finset.sum_range_zero,
      gammaCompiledJump, gammaCompiledRate, jumpProd, jumpDegr, gammaCompiledField]
    norm_num
    simp (config := { decide := true }) only [ite_true, ite_false, zero_add, add_zero]
    try ring)

theorem gammaCompiled_exists_instantQVRate_bound_uniform :
    ∃ C > 0, ∀ (N : ℕ) (hN : 0 < N)
      (x : Fin 21 → Fin (N + 1)),
      (DensityDepCTMC.mk N hN gammaCompiledRateSpec).instantQVRate x ≤
        C / (N : ℝ) := by
  obtain ⟨B, hBpos, hB⟩ :=
    gammaCompiledRateSpec.exists_rate_bound_on_ball 1 zero_lt_one
  refine ⟨B * (gammaCompiledRateSpec.jumps.card : ℝ) *
      gammaCompiledRateSpec.jumpNormBound ^ 2 + 1, by positivity, ?_⟩
  intro N hN x
  let M : DensityDepCTMC 21 := DensityDepCTMC.mk N hN gammaCompiledRateSpec
  let b := (M.rateSpec.jumpNormBound / (M.N : ℝ)) ^ 2
  let a : (Fin 21 → ℤ) → ℝ :=
    fun ℓ => (M.N : ℝ) * M.rateSpec.rate ℓ (M.scaledState x)
  have hNpos : 0 < (M.N : ℝ) := Nat.cast_pos.mpr M.hN
  have hb_nonneg : 0 ≤ b := by
    dsimp [b]
    exact sq_nonneg _
  have ha_nonneg : ∀ ℓ ∈ M.rateSpec.jumps, 0 ≤ a ℓ := by
    intro ℓ hℓ
    dsimp [a]
    apply mul_nonneg (Nat.cast_nonneg _)
    exact M.rateSpec.rate_nonneg ℓ hℓ (M.scaledState x) fun i =>
      div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _)
  have hsum_rate :
      (∑ ℓ ∈ M.rateSpec.jumps, M.rateSpec.rate ℓ (M.scaledState x)) ≤
        (M.rateSpec.jumps.card : ℝ) * B := by
    calc
      ∑ ℓ ∈ M.rateSpec.jumps, M.rateSpec.rate ℓ (M.scaledState x)
          ≤ ∑ _ℓ ∈ M.rateSpec.jumps, B := by
            apply Finset.sum_le_sum
            intro ℓ hℓ
            exact (le_abs_self _).trans
              (hB ℓ hℓ (M.scaledState x) (M.scaledState_norm_le x))
      _ = (M.rateSpec.jumps.card : ℝ) * B := by
            rw [Finset.sum_const, nsmul_eq_mul]
  have hmain :
      (∑ y : Fin 21 → Fin (M.N + 1),
        M.offDiagRate x y * ‖M.scaledState y - M.scaledState x‖ ^ 2) ≤
        (B * (M.rateSpec.jumps.card : ℝ) *
            M.rateSpec.jumpNormBound ^ 2 + 1) / (M.N : ℝ) := by
    calc
      ∑ y : Fin 21 → Fin (M.N + 1),
          M.offDiagRate x y * ‖M.scaledState y - M.scaledState x‖ ^ 2
          ≤ ∑ y : Fin 21 → Fin (M.N + 1),
              ∑ ℓ ∈ M.rateSpec.jumps.filter
                (fun ℓ : Fin 21 → ℤ => ∀ i, (y i : ℤ) - (x i : ℤ) = ℓ i),
                  a ℓ * b := by
            exact Finset.sum_le_sum fun y _ =>
              (M.offDiagRate_mul_scaledState_sub_sq_le x y).trans_eq (by simp [a, b])
      _ = ∑ y : Fin 21 → Fin (M.N + 1),
              ∑ ℓ ∈ M.rateSpec.jumps,
                if (∀ i, (y i : ℤ) - (x i : ℤ) = ℓ i) then a ℓ * b else 0 := by
            apply Finset.sum_congr rfl
            intro y _
            rw [Finset.sum_filter]
      _ = ∑ ℓ ∈ M.rateSpec.jumps,
              ∑ y : Fin 21 → Fin (M.N + 1),
                if (∀ i, (y i : ℤ) - (x i : ℤ) = ℓ i) then a ℓ * b else 0 := by
            rw [Finset.sum_comm]
      _ = ∑ ℓ ∈ M.rateSpec.jumps,
              ∑ y ∈ (Finset.univ : Finset (Fin 21 → Fin (M.N + 1))).filter
                (fun y : Fin 21 → Fin (M.N + 1) =>
                  ∀ i, (y i : ℤ) - (x i : ℤ) = ℓ i), a ℓ * b := by
            apply Finset.sum_congr rfl
            intro ℓ _
            rw [Finset.sum_filter]
      _ ≤ ∑ ℓ ∈ M.rateSpec.jumps, a ℓ * b := by
            apply Finset.sum_le_sum
            intro ℓ hℓ
            exact M.sum_matchingStates_const_le x ℓ
              (mul_nonneg (ha_nonneg ℓ hℓ) hb_nonneg)
      _ = ((M.N : ℝ) * ∑ ℓ ∈ M.rateSpec.jumps,
            M.rateSpec.rate ℓ (M.scaledState x)) * b := by
            simp [a, Finset.mul_sum, Finset.sum_mul, mul_assoc]
      _ ≤ ((M.N : ℝ) * ((M.rateSpec.jumps.card : ℝ) * B)) * b := by
            gcongr
      _ = B * (M.rateSpec.jumps.card : ℝ) * M.rateSpec.jumpNormBound ^ 2 /
            (M.N : ℝ) := by
            dsimp [b]
            field_simp [ne_of_gt hNpos]
      _ ≤ (B * (M.rateSpec.jumps.card : ℝ) *
              M.rateSpec.jumpNormBound ^ 2 + 1) / (M.N : ℝ) := by
            gcongr
            linarith
  simpa [DensityDepCTMC.instantQVRate, M, DensityDepCTMC.mk] using hmain

/-- The compiled gamma PIVP. -/
noncomputable def gammaCompiledPIVP : PIVP 21 where
  field := gammaCompiledField
  init := gammaCompiledInit
  output := 13

private lemma hasDerivAt_minSq (s : ℝ) :
    HasDerivAt (fun x => min x (0 : ℝ) ^ 2) (2 * min s 0) s := by
  rcases lt_or_ge s 0 with hs | hs
  · rw [show 2 * min s 0 = (2 : ℝ) * s ^ (2 - 1) from by rw [min_eq_left hs.le]; ring]
    exact (hasDerivAt_pow 2 s).congr_of_eventuallyEq
      (Filter.eventuallyEq_iff_exists_mem.mpr ⟨Set.Iio 0, Iio_mem_nhds hs, fun x hx => by
        simp [min_eq_left (Set.mem_Iio.mp hx).le]⟩)
  · rcases eq_or_lt_of_le hs with rfl | hs'
    · simp only [min_self, mul_zero]
      rw [hasDerivAt_iff_isLittleO_nhds_zero]
      simp only [zero_add, smul_zero, min_self, zero_pow (by norm_num : 2 ≠ 0), sub_zero]
      rw [Asymptotics.isLittleO_iff]
      intro c hc
      filter_upwards [Metric.ball_mem_nhds (0 : ℝ) hc] with h hh
      rw [Metric.mem_ball, dist_zero_right, Real.norm_eq_abs] at hh
      simp only [Real.norm_eq_abs]
      rw [abs_of_nonneg (sq_nonneg _)]
      calc min h 0 ^ 2 ≤ h ^ 2 := by
              rcases le_or_gt h 0 with hle | hgt
              · rw [min_eq_left hle]
              · rw [min_eq_right hgt.le, zero_pow (by norm_num : 2 ≠ 0)]; exact sq_nonneg h
          _ = |h| ^ 2 := (sq_abs h).symm
          _ = |h| * |h| := by ring
          _ ≤ c * |h| := mul_le_mul_of_nonneg_right hh.le (abs_nonneg h)
    · rw [show 2 * min s 0 = 0 from by rw [min_eq_right hs'.le]; ring]
      exact (hasDerivAt_const s (0 : ℝ)).congr_of_eventuallyEq
        (Filter.eventuallyEq_iff_exists_mem.mpr ⟨Set.Ioi 0, Ioi_mem_nhds hs', fun x hx => by
          simp [min_eq_right (Set.mem_Ioi.mp hx).le]⟩)

/-! ### Structural lemmas for ODE existence

The compiled gamma field has three structural properties that together
imply forward invariance of the nonneg orthant + conservation + boundedness:

1. **x_uno constant**: field_19 = 0, so y_19(t) = 1.
2. **x_0 factor**: every field_i (i ≠ 19) has y_20 as a factor.
3. **e decoupled**: field_8 = y_20 * (1 - y_8), so y_8 stays in [0,1).
-/

set_option maxHeartbeats 8000000 in
-- Conservation: ∑ field_i = 0
theorem gammaCompiledField_conservative : IsConservative gammaCompiledField := by
  intro x
  simp only [Fin.sum_univ_succ, Fin.sum_univ_zero, gammaCompiledField,
    Matrix.cons_val_zero, Matrix.cons_val_succ]
  ring

theorem gammaCompiledField_19_eq_zero (y : Fin 21 → ℝ) :
    gammaCompiledField y 19 = 0 := by
  simp [gammaCompiledField]

theorem gammaCompiledField_8_eq (y : Fin 21 → ℝ) :
    gammaCompiledField y 8 = y 20 * (y 19 - y 8) * y 19 := by
  unfold gammaCompiledField
  show -(y 8 * y 20 * y 19) + y 20 * y 19 * y 19 = y 20 * (y 19 - y 8) * y 19
  ring

set_option maxHeartbeats 4000000 in
/-- Every field component has y 20 as a factor (for i ≠ 19). -/
theorem gammaCompiledField_x0_factor (y : Fin 21 → ℝ) (i : Fin 21) (h : i ≠ 19)
    (h20 : y 20 = 0) : gammaCompiledField y i = 0 := by
  fin_cases i <;> (try exact absurd rfl h) <;>
    unfold gammaCompiledField <;> simp [h20]

set_option maxHeartbeats 16000000 in
/-- At y_j = 0 with all y_k ≥ 0 and y_8 ≤ y_19:
the compiled field points inward (or tangent) to the nonneg orthant.
The condition y_8 ≤ y_19 is needed for species 9 (Esym). -/
theorem gammaCompiledField_nonneg_boundary
    (y : Fin 21 → ℝ) (hnn : ∀ k, 0 ≤ y k) (h8_19 : y 8 ≤ y 19)
    (j : Fin 21) (hj : y j = 0) : 0 ≤ gammaCompiledField y j := by
  have h0 := hnn 0; have h1 := hnn 1; have h2 := hnn 2
  have h3 := hnn 3; have h4 := hnn 4; have h5 := hnn 5
  have h6 := hnn 6; have h7 := hnn 7; have h8 := hnn 8
  have h9 := hnn 9; have h10 := hnn 10; have h11 := hnn 11
  have h12 := hnn 12; have h13 := hnn 13; have h14 := hnn 14
  have h15 := hnn 15; have h16 := hnn 16; have h17 := hnn 17
  have h18 := hnn 18; have h19 := hnn 19; have h20 := hnn 20
  have h_sub : (0 : ℝ) ≤ y 19 - y 8 := sub_nonneg.mpr h8_19
  fin_cases j <;>
    simp only [gammaCompiledField, Matrix.cons_val_zero', Matrix.cons_val_succ'] <;>
    (first
    | have := show y 0 = 0 from hj | have := show y 1 = 0 from hj
    | have := show y 2 = 0 from hj | have := show y 3 = 0 from hj
    | have := show y 4 = 0 from hj | have := show y 5 = 0 from hj
    | have := show y 6 = 0 from hj | have := show y 7 = 0 from hj
    | have := show y 8 = 0 from hj | have := show y 9 = 0 from hj
    | have := show y 10 = 0 from hj | have := show y 11 = 0 from hj
    | have := show y 12 = 0 from hj | have := show y 13 = 0 from hj
    | have := show y 14 = 0 from hj | have := show y 15 = 0 from hj
    | have := show y 16 = 0 from hj | have := show y 17 = 0 from hj
    | have := show y 18 = 0 from hj | have := show y 19 = 0 from hj
    | have := show y 20 = 0 from hj) <;>
    (try rw [this]) <;> ring_nf <;>
    (first | positivity |
     nlinarith [mul_nonneg (mul_nonneg h20 h19) h_sub])

/-- Local Lipschitz for gammaCompiledField (via drift_lipschitz_on_ball). -/
theorem gammaCompiledField_locally_lipschitz :
    ∀ R : ℝ, 0 < R → ∃ L : ℝ, ∀ x y : Fin 21 → ℝ,
      ‖x‖ ≤ R → ‖y‖ ≤ R → ‖gammaCompiledField x - gammaCompiledField y‖ ≤ L * ‖x - y‖ := by
  intro R hR
  obtain ⟨L, hL_pos, hL_bd⟩ := gammaCompiledRateSpec.drift_lipschitz_on_ball R hR
  exact ⟨L, fun x y hx hy => by
    rw [← gammaCompiledRateSpec_drift_eq]; exact hL_bd x y hx hy⟩

/-  Global ODE solution existence for the compiled gamma system.

Proof strategy (decoupled invariance chain):
1. y_19 = 1 always (field_19 = 0)
2. y_20 > 0 always (field_20 = y_20 * H(y), factor form, y_20(0) ≈ 0.983 > 0)
3. y_8 ≤ y_19 always (field_8 = y_20*(y_19-y_8), y_8(0) = 0 ≤ y_19(0) = 1/242)
4. All y_i ≥ 0 (nonneg boundary condition uses 1-3)
5. ∑ y_i = 1 (conservation, unit simplex)
6. 0 ≤ y_i ≤ 1 → ‖y‖ ≤ 1 → apply Picard-Lindelöf
-/
/-- Step 1: y_19 is constant (= gammaCompiledInit 19 = 1/242). -/
private theorem gammaCompiled_y19_const
    (T : ℝ) (hT : 0 < T) (y : ℝ → Fin 21 → ℝ)
    (hy0 : y 0 = gammaCompiledInit)
    (hode : ∀ t ∈ Set.Ico (0 : ℝ) T, HasDerivAt y (gammaCompiledField (y t)) t)
    (t : ℝ) (ht : t ∈ Set.Ico (0 : ℝ) T) : y t 19 = y 0 19 := by
  set g : ℝ → ℝ := fun s => y s 19
  have hg_deriv : ∀ s ∈ Set.Ico (0 : ℝ) T, HasDerivAt g 0 s := by
    intro s hs
    have h := hasDerivAt_pi.mp (hode s hs) 19
    simp only [gammaCompiledField_19_eq_zero] at h
    exact h
  have hg_cont : ContinuousOn g (Set.Icc 0 t) := fun s hs =>
    (hg_deriv s ⟨hs.1, lt_of_le_of_lt hs.2 ht.2⟩).continuousAt.continuousWithinAt
  have h_const : ∀ s ∈ Set.Icc (0 : ℝ) t, g s = g 0 :=
    constant_of_has_deriv_right_zero hg_cont
      (fun s hs => (hg_deriv s ⟨hs.1, lt_of_lt_of_le hs.2 ht.2.le⟩).hasDerivWithinAt)
  exact h_const t ⟨ht.1, le_refl t⟩

/-- Step 2: y_8 ≤ y_19 (1-D Gronwall on the overshoot). -/
private theorem gammaCompiled_y8_le_y19
    (T : ℝ) (hT : 0 < T) (y : ℝ → Fin 21 → ℝ)
    (hy0 : y 0 = gammaCompiledInit)
    (hode : ∀ t ∈ Set.Ico (0 : ℝ) T, HasDerivAt y (gammaCompiledField (y t)) t)
    (t : ℝ) (ht : t ∈ Set.Ico (0 : ℝ) T) : y t 8 ≤ y t 19 := by
  rcases eq_or_lt_of_le ht.1 with rfl | ht_pos
  · rw [hy0]; simp [gammaCompiledInit]
  have hy19 : ∀ s ∈ Set.Ico (0 : ℝ) T, y s 19 = y 0 19 :=
    fun s hs => gammaCompiled_y19_const T hT y hy0 hode s hs
  set G : ℝ → ℝ := fun s => min (y s 19 - y s 8) 0 ^ 2
  have hG_zero : G 0 = 0 := by
    simp only [G]; rw [hy0]; simp [gammaCompiledInit]
  have hfield8 : ∀ s ∈ Set.Ico (0 : ℝ) T,
      HasDerivAt (fun u => y u 8) (y s 20 * (y s 19 - y s 8) * y s 19) s := by
    intro s hs
    have h := hasDerivAt_pi.mp (hode s hs) 8
    rw [gammaCompiledField_8_eq] at h
    exact h
  have hfield19 : ∀ s ∈ Set.Ico (0 : ℝ) T,
      HasDerivAt (fun u => y u 19) 0 s := by
    intro s hs
    have h := hasDerivAt_pi.mp (hode s hs) 19
    rw [gammaCompiledField_19_eq_zero] at h
    exact h
  have hG_hasDerivAt : ∀ s ∈ Set.Ico (0 : ℝ) T, HasDerivAt G
      (2 * min (y s 19 - y s 8) 0 *
        (-(y s 20 * (y s 19 - y s 8) * y s 19))) s := by
    intro s hs
    have h1 := (hasDerivAt_minSq (y s 19 - y s 8)).comp s
      ((hfield19 s hs).sub (hfield8 s hs))
    simp only [Function.comp_def, G] at h1 ⊢
    convert h1 using 1; ring
  have hIcc_sub : Set.Icc (0 : ℝ) t ⊆ Set.Ico (0 : ℝ) T := fun s hs =>
    ⟨hs.1, lt_of_le_of_lt hs.2 ht.2⟩
  have hG_cont : ContinuousOn G (Set.Icc (0 : ℝ) t) := fun s hs =>
    (hG_hasDerivAt s (hIcc_sub hs)).continuousAt.continuousWithinAt
  have hy_cont : ContinuousOn y (Set.Icc (0 : ℝ) t) := fun s hs =>
    (hode s (hIcc_sub hs)).continuousAt.continuousWithinAt
  have h_norm_cont : ContinuousOn (fun s => ‖y s‖) (Set.Icc (0 : ℝ) t) :=
    (hy_cont.norm)
  obtain ⟨s₀, _, h_max⟩ := isCompact_Icc.exists_isMaxOn
    (Set.nonempty_Icc.mpr ht_pos.le) h_norm_cont
  set M := ‖y s₀‖ + 1
  have hM_pos : 0 < M := by linarith [norm_nonneg (y s₀)]
  have hM_bound : ∀ s ∈ Set.Icc (0 : ℝ) t, ‖y s‖ ≤ M := fun s hs => by
    have h : ‖y s‖ ≤ ‖y s₀‖ := h_max hs; linarith
  have hG_bound : ∀ s ∈ Set.Ico (0 : ℝ) t, 2 * min (y s 19 - y s 8) 0 *
      (-(y s 20 * (y s 19 - y s 8) * y s 19)) ≤ 2 * M * M * G s := by
    intro s hs
    by_cases h : y s 8 ≤ y s 19
    · simp only [G, show min (y s 19 - y s 8) 0 = 0 from min_eq_right (by linarith)]
      ring_nf; norm_num
    · push_neg at h
      have hmin : min (y s 19 - y s 8) 0 = y s 19 - y s 8 := min_eq_left (by linarith)
      have h20_bound : |y s 20| ≤ M := by
        have h1 : ‖(y s) (20 : Fin 21)‖ ≤ ‖y s‖ := norm_le_pi_norm (f := y s) (20 : Fin 21)
        rw [Real.norm_eq_abs] at h1
        exact h1.trans (hM_bound s (Set.Ico_subset_Icc_self hs))
      have h19_bound : |y s 19| ≤ M := by
        have h1 : ‖(y s) (19 : Fin 21)‖ ≤ ‖y s‖ := norm_le_pi_norm (f := y s) (19 : Fin 21)
        rw [Real.norm_eq_abs] at h1
        exact h1.trans (hM_bound s (Set.Ico_subset_Icc_self hs))
      simp only [G, hmin]
      have key : -(y s 20 * y s 19) ≤ M * M :=
        calc -(y s 20 * y s 19) ≤ |-(y s 20 * y s 19)| := le_abs_self _
        _ = |y s 20 * y s 19| := abs_neg _
        _ = |y s 20| * |y s 19| := abs_mul _ _
        _ ≤ M * M := mul_le_mul h20_bound h19_bound (abs_nonneg _) (le_of_lt hM_pos)
      nlinarith [sq_nonneg (y s 19 - y s 8)]
  have hG_le_zero : G t ≤ 0 := by
    have h_gw := le_gronwallBound_of_liminf_deriv_right_le (δ := 0) (K := 2 * M * M) (ε := 0)
      hG_cont
      (fun s hs _ hr =>
        ((hG_hasDerivAt s (hIcc_sub (Set.Ico_subset_Icc_self hs))).hasDerivWithinAt).liminf_right_slope_le hr)
      (le_of_eq hG_zero)
      (fun s hs => by simp only [add_zero]; exact hG_bound s hs)
      t (Set.right_mem_Icc.mpr ht.1)
    linarith [gronwallBound_ε0_δ0 (2 * M * M) (t - 0)]
  have hG_nonneg : 0 ≤ G t := sq_nonneg _
  have hG_eq : G t = 0 := le_antisymm hG_le_zero hG_nonneg
  have hmin_zero : min (y t 19 - y t 8) 0 = 0 := by
    nlinarith [sq_nonneg (min (y t 19 - y t 8) 0)]
  linarith [min_le_left (y t 19 - y t 8) (0 : ℝ)]

/-- Step 3: All coordinates are nonneg (squared-negative-mass Gronwall).
Uses y_8 ≤ y_19 to verify the boundary condition for species 9. -/
private theorem gammaCompiled_nonneg
    (T : ℝ) (hT : 0 < T) (y : ℝ → Fin 21 → ℝ)
    (hy0 : y 0 = gammaCompiledInit)
    (hode : ∀ t ∈ Set.Ico (0 : ℝ) T, HasDerivAt y (gammaCompiledField (y t)) t)
    (t : ℝ) (ht : t ∈ Set.Ico (0 : ℝ) T) (i : Fin 21) : 0 ≤ y t i := by
  rcases eq_or_lt_of_le ht.1 with rfl | ht_pos
  · rw [hy0]; fin_cases i <;> simp [gammaCompiledInit] <;> norm_num
  set F : ℝ → ℝ := fun s => ∑ j : Fin 21, min (y s j) 0 ^ 2
  set F_deriv : ℝ → ℝ := fun s =>
    ∑ j : Fin 21, 2 * min (y s j) 0 * gammaCompiledField (y s) j
  have hF_zero : F 0 = 0 := by
    simp only [F]; apply Finset.sum_eq_zero; intro j _
    simp only [hy0]; fin_cases j <;> simp [gammaCompiledInit] <;> norm_num
  have hF_hasDerivAt : ∀ s ∈ Set.Ico (0 : ℝ) T, HasDerivAt F (F_deriv s) s := by
    intro s hs
    have h := HasDerivAt.sum fun j (_ : j ∈ Finset.univ) =>
      (hasDerivAt_minSq (y s j)).comp s (hasDerivAt_pi.mp (hode s hs) j)
    simp only [Function.comp_def] at h
    exact h.congr_of_eventuallyEq
      (Filter.Eventually.of_forall fun u => by simp only [F, Finset.sum_apply])
  have ht_lt_T : t < T := ht.2
  have hIcc_sub : Set.Icc (0 : ℝ) t ⊆ Set.Ico (0 : ℝ) T := fun s hs =>
    ⟨hs.1, lt_of_le_of_lt hs.2 ht_lt_T⟩
  have hF_cont : ContinuousOn F (Set.Icc (0 : ℝ) t) := fun s hs =>
    (hF_hasDerivAt s (hIcc_sub hs)).continuousAt.continuousWithinAt
  have hy_cont : ContinuousOn y (Set.Icc (0 : ℝ) t) := fun s hs =>
    (hode s (hIcc_sub hs)).continuousAt.continuousWithinAt
  have h_norm_cont : ContinuousOn (fun s => ‖y s‖) (Set.Icc (0 : ℝ) t) :=
    hy_cont.norm
  obtain ⟨s₀, _, h_max⟩ := isCompact_Icc.exists_isMaxOn
    (Set.nonempty_Icc.mpr ht_pos.le) h_norm_cont
  set M : ℝ := ‖y s₀‖ + 1
  have hM_pos : 0 < M := by linarith [norm_nonneg (y s₀)]
  have hM_bound : ∀ s ∈ Set.Icc (0 : ℝ) t, ‖y s‖ ≤ M := fun s hs => by
    have h : ‖y s‖ ≤ ‖y s₀‖ := h_max hs; linarith
  obtain ⟨L₀, hL₀⟩ := gammaCompiledField_locally_lipschitz M hM_pos
  set L := max L₀ 0
  have hL_nn : (0 : ℝ) ≤ L := le_max_right _ _
  have hL : ∀ x z : Fin 21 → ℝ, ‖x‖ ≤ M → ‖z‖ ≤ M →
      ‖gammaCompiledField x - gammaCompiledField z‖ ≤ L * ‖x - z‖ := fun x z hx hz =>
    (hL₀ x z hx hz).trans (mul_le_mul_of_nonneg_right (le_max_left _ _) (norm_nonneg _))
  have hF_bound : ∀ s ∈ Set.Ico (0 : ℝ) t, F_deriv s ≤ 2 * L * (21 : ℝ) * F s := by
    intro s hs
    set m : Fin 21 → ℝ := fun j => min (y s j) 0
    set yp : Fin 21 → ℝ := fun j => max (y s j) 0
    have hm_nonpos : ∀ j, m j ≤ 0 := fun j => min_le_right _ _
    have hyp_nn : ∀ j, 0 ≤ yp j := fun j => le_max_right _ _
    have hym_eq : y s - yp = m := funext fun j => by
      simp only [Pi.sub_apply, yp, m]; linarith [min_add_max (y s j) (0 : ℝ)]
    have hyp_le : ‖yp‖ ≤ M := by
      rw [pi_norm_le_iff_of_nonneg (by linarith [hM_pos])]
      intro j
      calc ‖yp j‖ = yp j := by rw [Real.norm_eq_abs, abs_of_nonneg (hyp_nn j)]
        _ = max (y s j) 0 := rfl
        _ ≤ |y s j| := max_le (le_abs_self _) (abs_nonneg _)
        _ = ‖(y s) j‖ := (Real.norm_eq_abs _).symm
        _ ≤ ‖y s‖ := norm_le_pi_norm (f := y s) j
        _ ≤ M := hM_bound s (Set.Ico_subset_Icc_self hs)
    have h_field_lip_at : ‖gammaCompiledField (y s) - gammaCompiledField yp‖ ≤ L * ‖m‖ := by
      calc ‖gammaCompiledField (y s) - gammaCompiledField yp‖
          ≤ L * ‖y s - yp‖ := hL _ _ (hM_bound s (Set.Ico_subset_Icc_self hs)) hyp_le
        _ = L * ‖m‖ := by rw [hym_eq]
    have h_split : F_deriv s = (∑ j, 2 * m j * gammaCompiledField yp j) +
        (∑ j, 2 * m j * (gammaCompiledField (y s) j - gammaCompiledField yp j)) := by
      simp only [F_deriv, ← Finset.sum_add_distrib]; congr 1; ext j; ring
    have hy8_19 : y s 8 ≤ y s 19 :=
      gammaCompiled_y8_le_y19 T hT y hy0 hode s (hIcc_sub (Set.Ico_subset_Icc_self hs))
    have hyp_8_19 : yp 8 ≤ yp 19 := by
      simp only [yp]; exact max_le_max_right 0 hy8_19
    have h_first : ∑ j, 2 * m j * gammaCompiledField yp j ≤ 0 := Finset.sum_nonpos fun j _ => by
      rcases le_or_gt 0 (y s j) with hge | hlt
      · simp [m, min_eq_right hge]
      · have hyp_j : yp j = 0 := by simp [yp, max_eq_right hlt.le]
        have h_nonneg : 0 ≤ gammaCompiledField yp j :=
          gammaCompiledField_nonneg_boundary yp hyp_nn hyp_8_19 j hyp_j
        exact mul_nonpos_of_nonpos_of_nonneg
          (mul_nonpos_of_nonneg_of_nonpos (by norm_num : (0 : ℝ) ≤ 2) (hm_nonpos j))
          h_nonneg
    have h_norm_sq : ‖m‖ * ‖m‖ ≤ F s := by
      suffices h : ‖m‖ * ‖m‖ ≤ ∑ j : Fin 21, m j ^ 2 by
        exact h.trans (le_of_eq (by simp [F, m]))
      haveI : Nonempty (Fin 21) := ⟨0⟩
      obtain ⟨k, _, hk⟩ := Finset.exists_max_image Finset.univ
        (fun j => ‖m j‖) Finset.univ_nonempty
      have h_eq : ‖m‖ = ‖m k‖ := le_antisymm
        ((pi_norm_le_iff_of_nonneg (norm_nonneg _)).mpr fun j => hk j (Finset.mem_univ _))
        (norm_le_pi_norm (f := m) k)
      calc ‖m‖ * ‖m‖ = ‖m k‖ ^ 2 := by rw [h_eq, sq]
        _ = (m k) ^ 2 := by rw [Real.norm_eq_abs, sq_abs]
        _ ≤ ∑ j, (m j) ^ 2 :=
          Finset.single_le_sum (fun j _ => sq_nonneg _) (Finset.mem_univ k)
    have h_second : ∑ j, 2 * m j * (gammaCompiledField (y s) j - gammaCompiledField yp j) ≤ 2 * L * (21 : ℝ) * F s := by
      have h_term : ∀ j, 2 * m j * (gammaCompiledField (y s) j - gammaCompiledField yp j) ≤
          2 * (-m j) * ‖gammaCompiledField (y s) - gammaCompiledField yp‖ := by
        intro j
        have hv_j : |gammaCompiledField (y s) j - gammaCompiledField yp j| ≤ ‖gammaCompiledField (y s) - gammaCompiledField yp‖ := by
          rw [← Real.norm_eq_abs, ← Pi.sub_apply]; exact norm_le_pi_norm (f := gammaCompiledField (y s) - gammaCompiledField yp) j
        nlinarith [hm_nonpos j, le_abs_self (gammaCompiledField (y s) j - gammaCompiledField yp j),
          neg_abs_le (gammaCompiledField (y s) j - gammaCompiledField yp j),
          norm_nonneg (gammaCompiledField (y s) - gammaCompiledField yp)]
      calc ∑ j, 2 * m j * (gammaCompiledField (y s) j - gammaCompiledField yp j)
          ≤ ∑ j, 2 * (-m j) * ‖gammaCompiledField (y s) - gammaCompiledField yp‖ :=
            Finset.sum_le_sum fun j _ => h_term j
        _ = 2 * ‖gammaCompiledField (y s) - gammaCompiledField yp‖ * ∑ j : Fin 21, (-m j) := by
            rw [Finset.mul_sum]; congr 1; ext j; ring
        _ ≤ 2 * (L * ‖m‖) * ((21 : ℝ) * ‖m‖) := by
            apply mul_le_mul
            · exact mul_le_mul_of_nonneg_left h_field_lip_at (by norm_num)
            · calc ∑ j : Fin 21, (-m j) = ∑ j : Fin 21, ‖m j‖ := by
                    congr 1; ext j; rw [Real.norm_eq_abs, abs_of_nonpos (hm_nonpos j)]
                _ ≤ Fintype.card (Fin 21) • ‖m‖ := Pi.sum_norm_apply_le_norm _
                _ = (21 : ℝ) * ‖m‖ := by rw [Fintype.card_fin, nsmul_eq_mul]; norm_num
            · exact Finset.sum_nonneg fun j _ => neg_nonneg.mpr (hm_nonpos j)
            · exact mul_nonneg (by norm_num : (0 : ℝ) ≤ 2) (mul_nonneg hL_nn (norm_nonneg _))
        _ = 2 * L * (21 : ℝ) * (‖m‖ * ‖m‖) := by ring
        _ ≤ 2 * L * (21 : ℝ) * F s := by
            exact mul_le_mul_of_nonneg_left h_norm_sq
              (mul_nonneg (mul_nonneg (by norm_num) hL_nn) (by positivity))
    linarith [h_split, h_first, h_second]
  set K := 2 * L * (21 : ℝ)
  have hF_le_zero : F t ≤ 0 := by
    have h_gw := le_gronwallBound_of_liminf_deriv_right_le (δ := 0) (K := K) (ε := 0)
      hF_cont
      (fun s hs _ hr =>
        ((hF_hasDerivAt s (hIcc_sub (Set.Ico_subset_Icc_self hs))).hasDerivWithinAt).liminf_right_slope_le hr)
      (le_of_eq hF_zero)
      (fun s hs => by simp only [add_zero]; exact hF_bound s hs)
      t (Set.right_mem_Icc.mpr ht.1)
    linarith [gronwallBound_ε0_δ0 K (t - 0)]
  have hF_nonneg : 0 ≤ F t := Finset.sum_nonneg fun j _ => sq_nonneg _
  have hF_eq_zero : F t = 0 := le_antisymm hF_le_zero hF_nonneg
  have h_summand : min (y t i) 0 ^ 2 = 0 := by
    have h1 : min (y t i) 0 ^ 2 ≤ ∑ j : Fin 21, min (y t j) 0 ^ 2 :=
      Finset.single_le_sum (fun k _ => sq_nonneg (min (y t k) 0)) (Finset.mem_univ i)
    change min (y t i) 0 ^ 2 ≤ F t at h1
    linarith [sq_nonneg (min (y t i) 0)]
  have h_min_zero : min (y t i) 0 = 0 := by nlinarith [sq_nonneg (min (y t i) 0)]
  linarith [min_le_left (y t i) (0 : ℝ)]

/-- On any local solution, the nonneg orthant with ∑ = 1 is forward invariant,
giving ‖y‖ ≤ 1. -/
private theorem gammaCompiled_invariant_bound :
    ∀ (T : ℝ), 0 < T → ∀ (y : ℝ → Fin 21 → ℝ),
      y 0 = gammaCompiledInit →
      (∀ t ∈ Set.Ico (0 : ℝ) T, HasDerivAt y (gammaCompiledField (y t)) t) →
      ∀ t ∈ Set.Ico (0 : ℝ) T, ‖y t‖ ≤ 1 := by
  intro T hT y hy0 hode t ht
  have h_nn : ∀ i, 0 ≤ y t i := gammaCompiled_nonneg T hT y hy0 hode t ht
  have h_cons : ∑ i, y t i = ∑ i, y 0 i := by
    exact conservative_local_sum_const gammaCompiledField_conservative T hT y hode t ht
  have h_sum_init : ∑ i : Fin 21, gammaCompiledInit i = 1 := by
    norm_num [gammaCompiledInit, Fin.sum_univ_succ, Fin.sum_univ_zero,
      Matrix.cons_val_zero, Matrix.cons_val_succ, Fin.val_zero, Fin.val_succ]
  have h_sum : ∑ i, y t i = 1 := by rw [h_cons, hy0]; exact_mod_cast h_sum_init
  rw [pi_norm_le_iff_of_nonneg (by norm_num : (0 : ℝ) ≤ 1)]
  intro i
  have hi_le : y t i ≤ ∑ j, y t j :=
    Finset.single_le_sum (fun j _ => h_nn j) (Finset.mem_univ i)
  rw [Real.norm_eq_abs, abs_of_nonneg (h_nn i)]
  linarith

theorem gammaCompiledPIVP_exists_solution :
    ∃ sol : PIVP.Solution gammaCompiledPIVP,
      gammaCompiledPIVP.IsBounded sol.trajectory := by
  have h_lip := gammaCompiledField_locally_lipschitz
  have h := locally_lipschitz_bounded_global_ode_proved
    gammaCompiledField gammaCompiledInit h_lip 1 one_pos
    (fun T hT y hy0 hode t ht =>
      gammaCompiled_invariant_bound T hT y hy0 hode t ht)
  obtain ⟨y, hy0, hy_ode⟩ := h
  refine ⟨⟨y, hy0, hy_ode⟩, ⟨1, one_pos, fun t ht => ?_⟩⟩
  change ‖y t‖ ≤ 1
  rcases eq_or_lt_of_le ht with rfl | ht_pos
  · rw [hy0]
    rw [pi_norm_le_iff_of_nonneg (by norm_num : (0 : ℝ) ≤ 1)]
    intro i; fin_cases i <;> simp [gammaCompiledInit] <;> norm_num
  · exact gammaCompiled_invariant_bound (t + 1) (by linarith) y hy0
      (fun s hs => hy_ode s hs.1) t ⟨ht, by linarith⟩

private theorem gammaCompiled_exists_continuous_solution :
    ∃ y : ℝ → Fin 21 → ℝ, y 0 = gammaCompiledInit ∧
      (∀ t : ℝ, 0 ≤ t → HasDerivAt y (gammaCompiledField (y t)) t) ∧ Continuous y :=
  locally_lipschitz_bounded_global_ode_proved_continuous
    gammaCompiledField gammaCompiledInit gammaCompiledField_locally_lipschitz 1 one_pos
    gammaCompiled_invariant_bound

noncomputable def gammaCompiledSol : ℝ → Fin 21 → ℝ :=
  gammaCompiled_exists_continuous_solution.choose

private theorem gammaCompiledSol_init : gammaCompiledSol 0 = gammaCompiledInit :=
  gammaCompiled_exists_continuous_solution.choose_spec.1

private theorem gammaCompiledSol_hasDerivAt (t : ℝ) (ht : 0 ≤ t) :
    HasDerivAt gammaCompiledSol (gammaCompiledField (gammaCompiledSol t)) t :=
  gammaCompiled_exists_continuous_solution.choose_spec.2.1 t ht

theorem gammaCompiledSol_continuous : Continuous gammaCompiledSol :=
  gammaCompiled_exists_continuous_solution.choose_spec.2.2

noncomputable def gammaCompiledMeanField : Kurtz.MeanFieldSolution 21 gammaCompiledRateSpec where
  sol := gammaCompiledSol
  x₀ := gammaCompiledInit
  sol_ode := by
    intro t ht
    show HasDerivAt gammaCompiledSol (gammaCompiledRateSpec.drift (gammaCompiledSol t)) t
    rw [gammaCompiledRateSpec_drift_eq]
    exact gammaCompiledSol_hasDerivAt t ht
  sol_init := gammaCompiledSol_init

theorem gammaCompiledSol_norm_le_one (t : ℝ) (ht : 0 ≤ t) :
    ‖gammaCompiledSol t‖ ≤ 1 := by
  rcases eq_or_lt_of_le ht with rfl | ht_pos
  · rw [gammaCompiledSol_init]
    rw [pi_norm_le_iff_of_nonneg (by norm_num : (0 : ℝ) ≤ 1)]
    intro i; fin_cases i <;> simp [gammaCompiledInit] <;> norm_num
  · exact gammaCompiled_invariant_bound (t + 1) (by linarith) gammaCompiledSol
      gammaCompiledSol_init (fun s hs => gammaCompiledSol_hasDerivAt s hs.1)
      t ⟨ht, by linarith⟩

theorem gammaCompiledSol_measurable : Measurable gammaCompiledSol :=
  gammaCompiledSol_continuous.measurable

private theorem gammaCompiledField_continuous : Continuous gammaCompiledField := by
  have h_lip := gammaCompiledField_locally_lipschitz
  rw [continuous_def]
  intro s hs
  rw [Metric.isOpen_iff] at hs ⊢
  intro x hx
  obtain ⟨ε, hε, hball⟩ := hs (gammaCompiledField x) hx
  obtain ⟨L, hL⟩ := h_lip (‖x‖ + 1) (by linarith [norm_nonneg x])
  set δ := min (ε / (max L 1)) 1
  have hδ : 0 < δ := lt_min (div_pos hε (lt_max_of_lt_right one_pos)) one_pos
  refine ⟨δ, hδ, fun y hy => hball ?_⟩
  rw [Metric.mem_ball] at hy ⊢
  rw [dist_eq_norm] at hy ⊢
  have hy_bound : ‖y‖ ≤ ‖x‖ + 1 := by
    calc ‖y‖ ≤ ‖x‖ + ‖y - x‖ := norm_le_insert' y x
      _ ≤ ‖x‖ + δ := by linarith [hy.le]
      _ ≤ ‖x‖ + 1 := by linarith [min_le_right (ε / max L 1) 1]
  rw [norm_sub_rev]
  calc ‖gammaCompiledField x - gammaCompiledField y‖
      ≤ L * ‖x - y‖ := hL x y (le_of_lt (by linarith [norm_nonneg x])) hy_bound
    _ ≤ max L 1 * ‖x - y‖ := by
        apply mul_le_mul_of_nonneg_right (le_max_left L 1) (norm_nonneg _)
    _ < max L 1 * (ε / max L 1) := by
        apply mul_lt_mul_of_pos_left _ (lt_max_of_lt_right one_pos)
        calc ‖x - y‖ = ‖y - x‖ := by rw [norm_sub_rev]
          _ < δ := hy
          _ ≤ ε / max L 1 := min_le_left _ _
    _ = ε := mul_div_cancel₀ ε (ne_of_gt (lt_max_of_lt_right one_pos))

theorem gammaCompiledSol_drift_intervalIntegrable (i : Fin 21) {t : ℝ} (ht : 0 ≤ t) :
    IntervalIntegrable
      (fun s : ℝ => (gammaCompiledRateSpec.drift (gammaCompiledSol s)) i)
      MeasureTheory.volume (0 : ℝ) t := by
  have h_cont : Continuous (fun s : ℝ => (gammaCompiledField (gammaCompiledSol s)) i) :=
    (continuous_apply i).comp (gammaCompiledField_continuous.comp gammaCompiledSol_continuous)
  have h_eq : (fun s => (gammaCompiledRateSpec.drift (gammaCompiledSol s)) i) =
      (fun s => (gammaCompiledField (gammaCompiledSol s)) i) := by
    ext s; exact congr_fun (congr_fun gammaCompiledRateSpec_drift_eq (gammaCompiledSol s)) i
  rw [h_eq]; exact h_cont.intervalIntegrable 0 t

/- **Uniform O(T/N) frozen martingale sup bound.**
Required by `kurtz_finite_horizon_generic_v2`.

**Status: open — requires ~600 lines of new infrastructure.**

## Why it's hard

The standard Doob L2 route needs `BoundaryCompatibleOnSimplex`, which fails
for reaction 22: jump `jumpDegr 9` with rate `(y₉+y₈)·y₂₀·y₁₉`. At x₉=0 the
jump is unrealizable but rate = y₈·y₂₀·y₁₉ ≠ 0. This is the ONLY BC-violating
reaction (all 31 others verified OK).

No CRN restructuring can fix this: the jump jumpDegr 9 couples species 9 and
20, so moving the y₈·y₂₀·y₁₉ term to production changes the species-20 drift.
Smooth approximations (y₉/(y₉+δ)) with fixed δ have O(1) interior drift error.

## Recommended strategy: generator-martingale decomposition

**Key existing infrastructure:** `generatorMartingalePart` is already defined
at `DensityDependent.lean:9822`. It uses `generatorDrift` (realizable jumps
only) instead of `rateSpec.drift`.

**Step 1 — Decomposition:**
  `frozenMartingalePart(t) = frozenGeneratorMP(t) + ∫₀ᵗ driftDiff(X(s)/N) ds`
where `driftDiff = generatorDrift - abstractDrift` is nonzero ONLY at boundary
states {x₉=0}. Magnitude: `‖driftDiff‖ ≤ √2 · y₈·y₂₀·y₁₉ · 1_{x₉=0}`.
~20 lines.

**Step 2 — Doob L2 for generatorMP:**
The `frozenGeneratorMP` agrees with `frozenClockSkeletonVec` at sojourn points
BY CONSTRUCTION (both use generatorDrift centering). So the affine bridge
  `sup ‖gMP‖² ≤ c₁·skeletonSupSq + c₂·jumpSqSum`
holds WITHOUT BC. Applying `frozenMartingalePart_DoobL2_general` (adapted for
gMP) gives `∫ sup ‖gMP‖² ≤ A·C₀·T/N`. ~300 lines (bridge + Doob adaptation).

**Step 3 — Boundary occupation bound (system-specific):**
For x₀ close to gammaCompiledInit: y₁₉ = 1/242 is CONSTANT (field component
19 = 0). y₈ starts at 0 and grows toward y₁₉ via f₈ = y₂₀·y₁₉·(y₁₉−y₈),
so y₈ < y₁₉ for all t. Therefore f₉ = y₂₀·(y₈−y₁₉)·(y₉−y₁₉) > 0 at y₉=0,
meaning the ODE boundary {y₉=0} is TRANSIENT.

For the CTMC:
• Production rate of species 9 at x₉=0: N·y₂₀·y₁₉² ≈ N·1.68e⁻⁵ (O(N))
• Degradation rate at x₉=1: (1/N+y₈)·y₂₀·y₁₉ ≈ y₂₀·y₁₉/N (O(1/N))
• Return probability to x₉=0 from x₉=1: O(1/N)
• E[total boundary occupation] = O(1/N)

So `E[(∫ driftDiff)²] ≤ 2T · E[∫ 1_{x₉=0}] = O(T/N)`.

Combined: `∫ sup ‖FMP‖² ≤ 2·A·C₀·T/N + 2·O(T/N) = O(T/N)`. ✓

The strategy (Fable oracle insight, 2026-07-03):
1. The drift error A(t) = ∫₀ᵗ y₈y₂₀y₁₉·1_{X₉=0} ds has FAVORABLE SIGN for coordinate 9
   (pushes y₉ up), so by pathwise Grönwall + the M* Doob bound, the boundary set
   {t : X₉(t)=0} is confined to [0, C·sup‖M*‖]. This gives A ≤ C·S² pathwise.
2. Combined with the crude bound A ≤ CT: A² ≤ min(CS², CT)² ≤ CS²·CT, so
   E[A²] ≤ CT·E[S²] ≤ C'T²/N from the already-proven M* Doob bound.
3. No Poisson birth-process infrastructure or gambler's ruin needed — only
   deterministic per-ω Grönwall comparisons + the M* Doob L² theorem. -/


/-- Generalized Doob L² bound: given an integrable upper bound `F` satisfying the
affine bridge, `∫ F ≤ frozenMartingalePartDoobL2Constant d * ∫ QVRate`.
This is `frozenMartingalePart_DoobL2_general` with `F` and `hF_int` as parameters
instead of hardcoding `frozenMartingalePart`. The proof is the same calc chain. -/
private theorem doobL2_of_affineBridge_custom
    (M : DensityDepCTMC d) (x₀ : Fin d → Fin (M.N + 1))
    (T : ℝ) (_hT : 0 < T) (n : ℕ)
    (F : M.canonicalRecordΩ → ℝ)
    (hF_int : Integrable F (M.canonicalRecordMeasure x₀))
    (hAffineBridge :
      F ≤ᵐ[M.canonicalRecordMeasure x₀]
      fun records =>
        (4 / 3 : ℝ) * M.frozenClockSkeletonSupSq T n records +
          4 * M.frozenTruncatedJumpSqSum T n records)
    (hClockQV :
      M.frozenClockTruncatedQVIntegralSum x₀ T n ≤
        ∫ records, (∫ s in Set.Icc (0 : ℝ) T,
          M.instantQVRate ((M.canonicalPathMap records).frozenStateAt s))
          ∂M.canonicalRecordMeasure x₀) :
    ∫ records, F records ∂M.canonicalRecordMeasure x₀ ≤
      DensityDepCTMC.frozenMartingalePartDoobL2Constant d *
        ∫ records, (∫ s in Set.Icc (0 : ℝ) T,
          M.instantQVRate ((M.canonicalPathMap records).frozenStateAt s))
          ∂M.canonicalRecordMeasure x₀ := by
  let μ := M.canonicalRecordMeasure x₀
  let A' : M.canonicalRecordΩ → ℝ := fun records =>
    M.frozenClockSkeletonSupSq T n records
  let J' : M.canonicalRecordΩ → ℝ := fun records =>
    M.frozenTruncatedJumpSqSum T n records
  let Q' : ℝ := M.frozenClockTruncatedQVIntegralSum x₀ T n
  let R' : ℝ :=
    ∫ records, (∫ s in Set.Icc (0 : ℝ) T,
      M.instantQVRate ((M.canonicalPathMap records).frozenStateAt s)) ∂μ
  have hA_int : Integrable A' μ := by
    simpa [A', μ] using M.integrable_frozenClockSkeletonSupSq x₀ T n
  have hJ_int : Integrable J' μ := by
    dsimp [J', DensityDepCTMC.frozenTruncatedJumpSqSum]
    exact MeasureTheory.integrable_finsetSum (Finset.range n) fun k _hk => by
      simpa using M.integrable_truncatedJumpSqIncrementFromHistory_next x₀ T k
  have hBridge_int :
      Integrable
        (fun records : M.canonicalRecordΩ =>
          (4 / 3 : ℝ) * A' records + 4 * J' records) μ :=
    (hA_int.const_mul (4 / 3 : ℝ)).add (hJ_int.const_mul 4)
  have hmono :
      ∫ records, F records ∂μ ≤
        ∫ records, ((4 / 3 : ℝ) * A' records + 4 * J' records) ∂μ :=
    MeasureTheory.integral_mono_ae hF_int hBridge_int
      (by simpa [A', J'] using hAffineBridge)
  have hA_le :
      ∫ records, A' records ∂μ ≤
        (4 * (Fintype.card (Fin d) : ℝ)) * Q' := by
    simpa [A', Q', μ] using
      M.integral_frozenClockTruncated_vector_sup_sq_le_vector_qv x₀ T n
  have hJ_eq :
      ∫ records, J' records ∂μ = Q' := by
    simpa [J', Q', μ] using
      M.integral_frozenTruncatedJumpSqSum_eq_clockTruncatedQV x₀ T n
  have hQ_le_R : Q' ≤ R' := by
    simpa [Q', R', μ] using hClockQV
  calc
    ∫ records, F records ∂μ
        ≤ ∫ records, ((4 / 3 : ℝ) * A' records + 4 * J' records) ∂μ := hmono
    _ = (4 / 3 : ℝ) * ∫ records, A' records ∂μ +
          4 * ∫ records, J' records ∂μ := by
          rw [MeasureTheory.integral_add (hA_int.const_mul _) (hJ_int.const_mul _)]
          rw [MeasureTheory.integral_const_mul, MeasureTheory.integral_const_mul]
    _ ≤ (4 / 3 : ℝ) * ((4 * (Fintype.card (Fin d) : ℝ)) * Q') + 4 * Q' := by
          have hmulA := mul_le_mul_of_nonneg_left hA_le
            (by norm_num : (0 : ℝ) ≤ 4 / 3)
          rw [hJ_eq]; nlinarith
    _ = DensityDepCTMC.frozenMartingalePartDoobL2Constant d * Q' := by
          simp only [DensityDepCTMC.frozenMartingalePartDoobL2Constant]; ring
    _ ≤ DensityDepCTMC.frozenMartingalePartDoobL2Constant d * R' :=
          mul_le_mul_of_nonneg_left hQ_le_R
            (le_of_lt (DensityDepCTMC.frozenMartingalePartDoobL2Constant_pos d))
    _ = DensityDepCTMC.frozenMartingalePartDoobL2Constant d *
        ∫ records, (∫ s in Set.Icc (0 : ℝ) T,
          M.instantQVRate ((M.canonicalPathMap records).frozenStateAt s))
          ∂M.canonicalRecordMeasure x₀ := by simp [R', μ]

/-- Uniform QV rate bound: the constant C₀ depends only on `gammaCompiledRateSpec`,
not on N. This is needed because `gammaCompiled_generatorMP_sup_sq_bound` quantifies
`∃ C_doob` before `∀ N`. -/
private lemma gammaCompiled_instantQVRate_uniform_bound :
    ∃ C₀ > 0, ∀ (N : ℕ) (hN : 0 < N) (x : Fin 21 → Fin (N + 1)),
      (DensityDepCTMC.mk N hN gammaCompiledRateSpec).instantQVRate x ≤ C₀ / (N : ℝ) := by
  obtain ⟨B, hBpos, hB⟩ := gammaCompiledRateSpec.exists_rate_bound_on_ball 1 zero_lt_one
  let C₀ : ℝ := B * (gammaCompiledRateSpec.jumps.card : ℝ) *
    gammaCompiledRateSpec.jumpNormBound ^ 2 + 1
  refine ⟨C₀, by positivity, fun N hN x => ?_⟩
  let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
  have hNpos : (0 : ℝ) < N := Nat.cast_pos.mpr hN
  let b := (M.rateSpec.jumpNormBound / (M.N : ℝ)) ^ 2
  let a : (Fin 21 → ℤ) → ℝ := fun ℓ => (M.N : ℝ) * M.rateSpec.rate ℓ (M.scaledState x)
  have hb_nonneg : 0 ≤ b := sq_nonneg _
  have ha_nonneg : ∀ ℓ ∈ M.rateSpec.jumps, 0 ≤ a ℓ := by
    intro ℓ hℓ; dsimp [a]
    exact mul_nonneg (Nat.cast_nonneg _)
      (M.rateSpec.rate_nonneg ℓ hℓ (M.scaledState x) fun i =>
        div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _))
  have hsum_rate :
      (∑ ℓ ∈ M.rateSpec.jumps, M.rateSpec.rate ℓ (M.scaledState x)) ≤
        (M.rateSpec.jumps.card : ℝ) * B := by
    calc ∑ ℓ ∈ M.rateSpec.jumps, M.rateSpec.rate ℓ (M.scaledState x)
        ≤ ∑ _ℓ ∈ M.rateSpec.jumps, B :=
          Finset.sum_le_sum fun ℓ hℓ =>
            (le_abs_self _).trans (hB ℓ hℓ (M.scaledState x) (M.scaledState_norm_le x))
      _ = (M.rateSpec.jumps.card : ℝ) * B := by rw [Finset.sum_const, nsmul_eq_mul]
  show M.instantQVRate x ≤ C₀ / (N : ℝ)
  simp only [DensityDepCTMC.instantQVRate]
  calc ∑ y : Fin 21 → Fin (M.N + 1),
        M.offDiagRate x y * ‖M.scaledState y - M.scaledState x‖ ^ 2
      ≤ ∑ y, ∑ ℓ ∈ M.rateSpec.jumps.filter
          (fun ℓ : Fin 21 → ℤ => ∀ i, (y i : ℤ) - (x i : ℤ) = ℓ i), a ℓ * b :=
        Finset.sum_le_sum fun y _ =>
          (M.offDiagRate_mul_scaledState_sub_sq_le x y).trans_eq (by simp [a, b])
    _ = ∑ y : Fin 21 → Fin (M.N + 1), ∑ ℓ ∈ M.rateSpec.jumps,
          if (∀ i, (y i : ℤ) - (x i : ℤ) = ℓ i) then a ℓ * b else 0 := by
        apply Finset.sum_congr rfl; intro y _; rw [Finset.sum_filter]
    _ = ∑ ℓ ∈ M.rateSpec.jumps, ∑ y : Fin 21 → Fin (M.N + 1),
          if (∀ i, (y i : ℤ) - (x i : ℤ) = ℓ i) then a ℓ * b else 0 := by
        rw [Finset.sum_comm]
    _ = ∑ ℓ ∈ M.rateSpec.jumps,
          ∑ y ∈ (Finset.univ : Finset (Fin 21 → Fin (M.N + 1))).filter
            (fun y : Fin 21 → Fin (M.N + 1) => ∀ i, (y i : ℤ) - (x i : ℤ) = ℓ i), a ℓ * b := by
        apply Finset.sum_congr rfl; intro ℓ _; rw [Finset.sum_filter]
    _ ≤ ∑ ℓ ∈ M.rateSpec.jumps, a ℓ * b :=
        Finset.sum_le_sum fun ℓ hℓ =>
          M.sum_matchingStates_const_le x ℓ (mul_nonneg (ha_nonneg ℓ hℓ) hb_nonneg)
    _ = ((M.N : ℝ) * ∑ ℓ ∈ M.rateSpec.jumps, M.rateSpec.rate ℓ (M.scaledState x)) * b := by
        simp [a, Finset.mul_sum, Finset.sum_mul, mul_assoc]
    _ ≤ ((M.N : ℝ) * ((M.rateSpec.jumps.card : ℝ) * B)) * b := by gcongr
    _ = B * (M.rateSpec.jumps.card : ℝ) * M.rateSpec.jumpNormBound ^ 2 / (M.N : ℝ) := by
        dsimp [b]; field_simp [ne_of_gt hNpos]
    _ ≤ C₀ / (M.N : ℝ) := by gcongr; linarith

/-- **Doob L² bound for the generator-centered martingale M*.**
Uses min(F, G_n) + monotone convergence to go from the record-dependent-n bridge
to a fixed integral bound. -/
private lemma gammaCompiled_generatorMP_sup_sq_bound {T : ℝ} (hT : 0 < T) :
    ∃ C_doob : ℝ, 0 < C_doob ∧
    ∀ (N : ℕ) (hN : 0 < N)
    (x₀ : Fin 21 → Fin (N + 1))
    (_hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀)
    (_hclose : ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ ≤ 1 / ↑N),
    let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
    MeasureTheory.Integrable
      (fun records => ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
        ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2)
      (M.canonicalRecordMeasure x₀) ∧
    ∫ records, ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
      ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
    ∂M.canonicalRecordMeasure x₀
    ≤ C_doob * T / ↑N := by
  obtain ⟨C₀, hC₀_pos, hqv_bound⟩ := gammaCompiled_instantQVRate_uniform_bound
  let A := DensityDepCTMC.frozenMartingalePartDoobL2Constant 21
  have hA_pos := DensityDepCTMC.frozenMartingalePartDoobL2Constant_pos 21
  refine ⟨A * C₀, mul_pos hA_pos hC₀_pos, fun N hN x₀ hinit hclose => ?_⟩
  let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
  let μ := M.canonicalRecordMeasure x₀
  have hNpos : (0 : ℝ) < N := Nat.cast_pos.mpr hN
  -- Integrability
  have hF_int := M.canonical_frozen_generatorMP_sup_sq_integrable x₀ T hT
  refine ⟨hF_int, ?_⟩
  -- Abbreviations
  let F : M.canonicalRecordΩ → ℝ := fun records =>
    ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
      ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
  let G : ℕ → M.canonicalRecordΩ → ℝ := fun n records =>
    (4 / 3 : ℝ) * M.frozenClockSkeletonSupSq T n records +
      4 * M.frozenTruncatedJumpSqSum T n records
  let R : ℝ := ∫ records, (∫ s in Set.Icc (0 : ℝ) T,
    M.instantQVRate ((M.canonicalPathMap records).frozenStateAt s)) ∂μ
  -- Step 1: G_n monotone in n
  have hG_mono : ∀ records, Monotone fun n => G n records := by
    intro records
    apply monotone_nat_of_le_succ; intro n; dsimp [G]
    gcongr
    · exact M.frozenClockSkeletonSupSq_mono T n records
    · exact M.frozenTruncatedJumpSqSum_mono T n records
  -- Step 2: F_n = min(F, G_n), monotone, F_n → F a.e.
  let H : ℕ → M.canonicalRecordΩ → ℝ := fun n records => min (F records) (G n records)
  have hH_le_G : ∀ n records, H n records ≤ G n records := fun n records => min_le_right _ _
  have hH_mono : ∀ᵐ records ∂μ, Monotone fun n => H n records := by
    filter_upwards with records n₁ n₂ h
    exact min_le_min_left _ (hG_mono records h)
  have hH_tendsto : ∀ᵐ records ∂μ, Filter.Tendsto (fun n => H n records) Filter.atTop (nhds (F records)) := by
    have hbridge := frozenGeneratorMP_bridge_ae M x₀ hinit hT
    filter_upwards [hbridge] with records ⟨n₀, hle⟩
    apply tendsto_nhds_of_eventually_eq
    filter_upwards [Filter.Ici_mem_atTop n₀] with n hn
    simp only [H]
    rw [min_eq_left]
    exact hle.trans (hG_mono records hn)
  -- Step 3: H n integrable
  have hG_int : ∀ n, Integrable (G n) μ := by
    intro n; dsimp [G, μ]
    exact ((M.integrable_frozenClockSkeletonSupSq x₀ T n).const_mul (4 / 3 : ℝ)).add
      ((MeasureTheory.integrable_finsetSum (Finset.range n) fun k _ => by
        simpa using M.integrable_truncatedJumpSqIncrementFromHistory_next x₀ T k).const_mul 4)
  have hH_int : ∀ n, Integrable (H n) μ := by
    intro n; exact hF_int.inf (hG_int n)
  -- Step 4: MCT gives ∫ H n → ∫ F
  have hMCT : Filter.Tendsto (fun n => ∫ records, H n records ∂μ) Filter.atTop
      (nhds (∫ records, F records ∂μ)) :=
    MeasureTheory.integral_tendsto_of_tendsto_of_monotone hH_int hF_int hH_mono hH_tendsto
  -- Step 5: Each ∫ H n ≤ A * R (via doobL2_of_affineBridge_custom)
  have hH_bound : ∀ n, ∫ records, H n records ∂μ ≤ A * R := by
    intro n
    have hAffineBridge : H n ≤ᵐ[μ] G n :=
      Filter.Eventually.of_forall fun records => hH_le_G n records
    have hClockQV := M.frozenClockTruncatedQVIntegralSum_le_frozenQV_setIntegral
      x₀ hinit T hT n
    exact doobL2_of_affineBridge_custom M x₀ T hT n (H n) (hH_int n) hAffineBridge hClockQV
  -- Step 6: ∫ F ≤ A * R (by MCT limit)
  have hF_le_AR : ∫ records, F records ∂μ ≤ A * R :=
    le_of_tendsto' hMCT hH_bound
  -- Step 7: R ≤ C₀ * T / N (double integral QV bound)
  have hR_bound : R ≤ C₀ / ↑N * T := by
    dsimp [R, μ]
    calc ∫ records, (∫ s in Set.Icc (0 : ℝ) T,
          M.instantQVRate ((M.canonicalPathMap records).frozenStateAt s)) ∂μ
        ≤ ∫ _records, (C₀ / ↑N * T) ∂μ :=
          MeasureTheory.integral_mono_of_nonneg
            (Filter.Eventually.of_forall fun records =>
              MeasureTheory.setIntegral_nonneg measurableSet_Icc
                fun s _hs => M.instantQVRate_nonneg _)
            (integrable_const _)
            (Filter.Eventually.of_forall fun records => by
              calc ∫ s in Set.Icc (0 : ℝ) T,
                    M.instantQVRate ((M.canonicalPathMap records).frozenStateAt s)
                  ≤ ‖∫ s in Set.Icc (0 : ℝ) T,
                      M.instantQVRate ((M.canonicalPathMap records).frozenStateAt s)‖ :=
                    le_abs_self _
                _ ≤ C₀ / ↑N * MeasureTheory.volume.real (Set.Icc (0 : ℝ) T) :=
                    MeasureTheory.norm_setIntegral_le_of_norm_le_const measure_Icc_lt_top
                      fun s _hs => by
                        rw [Real.norm_eq_abs, abs_of_nonneg (M.instantQVRate_nonneg _)]
                        exact hqv_bound N hN _
                _ = C₀ / ↑N * T := by
                    rw [Measure.real_def, Real.volume_Icc,
                      ENNReal.toReal_ofReal (by linarith : (0 : ℝ) ≤ T - 0)]; ring)
      _ = C₀ / ↑N * T := by simp [MeasureTheory.integral_const]
  -- Combine: ∫ F ≤ A * C₀ * T / N
  calc ∫ records, F records ∂μ ≤ A * R := hF_le_AR
    _ ≤ A * (C₀ / ↑N * T) := mul_le_mul_of_nonneg_left hR_bound (le_of_lt hA_pos)
    _ = A * C₀ * T / ↑N := by ring

