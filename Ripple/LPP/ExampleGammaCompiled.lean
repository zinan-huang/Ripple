        |M.frozenGeneratorMartingalePart M.canonicalPathMap u records i| ≤ S) →
      ‖M.frozenMartingalePart M.canonicalPathMap s records -
        M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ≤
        484 * (1 + 2 * T ^ 2 + 2 * T) * S := by
  intro M records hrec hinitFrozen hsim h19const s hs0 hsT S hy19 hS_nn hS_bound
