theorem gammaCompiled_driftZeroAtAbsorbingOnSimplex (N : ℕ) (hN : 0 < N) :
    (DensityDepCTMC.mk N hN gammaCompiledRateSpec).DriftZeroAtAbsorbingOnSimplex := by
  intro x hsimp hexit
  set y := fun i => (x i : ℝ) / (↑N : ℝ) with hy_def
  -- It suffices to show all 32 individual rates are 0
  suffices hrate : ∀ k : Fin 32, gammaCompiledRate k y = 0 by
    ext i; simp only [RateSpec.drift, Pi.zero_apply]
    apply Finset.sum_eq_zero; intro ℓ _
    suffices gammaCompiledRateSpec.rate ℓ y = 0 by rw [this, mul_zero]
    show (∑ k : Fin 32, if gammaCompiledJump k = ℓ then gammaCompiledRate k y else 0) = 0
    exact Finset.sum_eq_zero fun k _ => by split_ifs <;> [exact hrate k; rfl]
  -- Case: x 20 = 0
  by_cases hx20 : (x 20 : ℕ) = 0
  · intro k
    have hy20 : y 20 = 0 := by
      show (x 20 : ℝ) / (↑N : ℝ) = 0
      rw [show (x 20 : ℝ) = ((x 20 : ℕ) : ℝ) from rfl, hx20, Nat.cast_zero, zero_div]
    exact gammaCompiledRate_zero_of_x0_zero k y hy20
  · -- Case: x 20 > 0
    have hx20pos : 0 < (x 20 : ℕ) := Nat.pos_of_ne_zero hx20
    have hNpos : (0 : ℝ) < ↑N := Nat.cast_pos.mpr hN
    have hy20pos : 0 < y 20 := div_pos (Nat.cast_pos.mpr hx20pos) hNpos
    -- Link M.N to N so omega can use both
    have hMN : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).N = N := rfl
    -- Simplex: ∑ (x j) = N, so for j ≠ 20: (x j) + (x 20) ≤ N
    have hsum : ∑ j : Fin 21, (x j : ℕ) = N := hsimp
    have hpairle : ∀ j : Fin 21, j ≠ (20 : Fin 21) →
        (x j : ℕ) + (x 20 : ℕ) ≤ N := by
      intro j hj
      set f : Fin 21 → ℕ := fun i => (x i : ℕ)
      have hfs : ∑ i, f i = N := hsum
      calc f j + f (20 : Fin 21)
          = ∑ i ∈ ({j, (20 : Fin 21)} : Finset (Fin 21)), f i := (Finset.sum_pair hj).symm
        _ ≤ ∑ i, f i := Finset.sum_le_sum_of_subset_of_nonneg (Finset.subset_univ _)
            (fun _ _ _ => Nat.zero_le _)
        _ = N := hfs
    -- Helper: construct jumpProd target and prove rate = 0
    have hprod_zero : ∀ (s : Fin 21) (hs : s ≠ (20 : Fin 21)) (k : Fin 32)
        (hk : gammaCompiledJump k = jumpProd s),
        gammaCompiledRate k y = 0 := by
      intro s hs k hk
      have hs_lt : (x s : ℕ) + 1 < N + 1 := by have := hpairle s hs; have := hMN; omega
      have h20_sub : (x 20 : ℕ) - 1 < N + 1 := by have := hMN; omega
      apply gammaCompiledRate_zero_of_valid_target N hN x hexit k
        (fun i => if i = s then ⟨(x s : ℕ) + 1, hs_lt⟩
                  else if i = (20 : Fin 21) then ⟨(x 20 : ℕ) - 1, h20_sub⟩
                  else x i)
      · -- z ≠ x
        intro hzx; have := congr_fun hzx s
        simp only [ite_true] at this
        exact absurd this (by simp [Fin.ext_iff])
      · -- matching: (z j : ℤ) - (x j : ℤ) = gammaCompiledJump k j
        rw [hk]; intro j; simp only [jumpProd]
        by_cases hjs : j = s
        · subst hjs; simp only [ite_true, Fin.val_mk]; push_cast; ring
        · by_cases hj20 : j = (20 : Fin 21)
          · subst hj20; simp only [if_neg hjs, ite_true, Fin.val_mk]; omega
          · simp only [if_neg hjs, if_neg hj20, sub_self]
    -- Helper: construct jumpDegr target and prove rate = 0 (when x j > 0)
    have hdegr_zero : ∀ (j : Fin 21) (hj : j ≠ (20 : Fin 21))
        (hjpos : 0 < (x j : ℕ)) (k : Fin 32)
        (hk : gammaCompiledJump k = jumpDegr j),
        gammaCompiledRate k y = 0 := by
      intro j hj hjpos k hk
      have hj_sub : (x j : ℕ) - 1 < N + 1 := by have := hMN; omega
      have h20_add : (x 20 : ℕ) + 1 < N + 1 := by have := hpairle j hj; have := hMN; omega
      apply gammaCompiledRate_zero_of_valid_target N hN x hexit k
        (fun i => if i = j then ⟨(x j : ℕ) - 1, hj_sub⟩
                  else if i = (20 : Fin 21) then ⟨(x 20 : ℕ) + 1, h20_add⟩
                  else x i)
      · intro hzx; have := congr_fun hzx j
        simp only [ite_true] at this
        exact absurd this (by simp [Fin.ext_iff]; omega)
      · rw [hk]; intro i; simp only [jumpDegr]
        by_cases hij : i = j
        · subst hij; simp only [ite_true, Fin.val_mk]; omega
        · by_cases hi20 : i = (20 : Fin 21)
          · subst hi20; simp only [if_neg hij, ite_true, Fin.val_mk]; omega
          · simp only [if_neg hij, if_neg hi20, sub_self]
    -- y 19 = 0: from production rate k=6 (= y 20 * y 19 * y 19) being 0
    have hy19 : y 19 = 0 := by
      have h6 := hprod_zero 8 (by decide) 6 (by native_decide)
      simp only [gammaCompiledRate] at h6
      rcases mul_eq_zero.mp h6 with h | h
      · exact (mul_eq_zero.mp h).resolve_left hy20pos.ne'
      · exact h
    -- Helper: y j = 0 when (x j : ℕ) = 0
    have hyzero : ∀ j : Fin 21, (x j : ℕ) = 0 → y j = 0 := by
      intro j hj0; show (x j : ℝ) / ↑N = 0
      rw [show (x j : ℝ) = ((x j : ℕ) : ℝ) from rfl, hj0, Nat.cast_zero, zero_div]
    -- Now prove all 32 rates are 0 by fin_cases
    intro k; fin_cases k
    -- k = 0: jumpProd 0
    · exact hprod_zero 0 (by decide) _ (by native_decide)
    -- k = 1: jumpProd 1
    · exact hprod_zero 1 (by decide) _ (by native_decide)
    -- k = 2: jumpProd 2
    · exact hprod_zero 2 (by decide) _ (by native_decide)
    -- k = 3: jumpProd 3
    · exact hprod_zero 3 (by decide) _ (by native_decide)
    -- k = 4: jumpProd 6
    · exact hprod_zero 6 (by decide) _ (by native_decide)
    -- k = 5: jumpProd 7
    · exact hprod_zero 7 (by decide) _ (by native_decide)
    -- k = 6: jumpProd 8
    · exact hprod_zero 8 (by decide) _ (by native_decide)
    -- k = 7: jumpProd 9
    · exact hprod_zero 9 (by decide) _ (by native_decide)
    -- k = 8: jumpProd 10
    · exact hprod_zero 10 (by decide) _ (by native_decide)
    -- k = 9: jumpProd 11
    · exact hprod_zero 11 (by decide) _ (by native_decide)
    -- k = 10: jumpProd 12
    · exact hprod_zero 12 (by decide) _ (by native_decide)
    -- k = 11: jumpProd 13
    · exact hprod_zero 13 (by decide) _ (by native_decide)
    -- k = 12: jumpProd 14
    · exact hprod_zero 14 (by decide) _ (by native_decide)
    -- k = 13: jumpProd 15
    · exact hprod_zero 15 (by decide) _ (by native_decide)
    -- k = 14: jumpProd 16
    · exact hprod_zero 16 (by decide) _ (by native_decide)
    -- k = 15: jumpProd 18
    · exact hprod_zero 18 (by decide) _ (by native_decide)
    -- k = 16: jumpDegr 2, rate = y 2 * y 20 * y 19 → 0 by y 19 = 0
    · simp only [gammaCompiledRate, hy19, mul_zero]
    -- k = 17: jumpDegr 3, rate = y 3 * y 20 * y 19 → 0
    · simp only [gammaCompiledRate, hy19, mul_zero]
    -- k = 18: jumpDegr 4, rate = y 4 * y 20 * y 19 → 0
    · simp only [gammaCompiledRate, hy19, mul_zero]
    -- k = 19: jumpDegr 5, rate = y 5 * y 5 * y 20
    · by_cases h : (x 5 : ℕ) = 0
      · simp only [gammaCompiledRate, hyzero 5 h, zero_mul]
      · exact hdegr_zero 5 (by decide) (Nat.pos_of_ne_zero h) _ (by native_decide)
    -- k = 20: jumpDegr 7, rate = y 7 * y 20 * y 19 → 0
    · simp only [gammaCompiledRate, hy19, mul_zero]
    -- k = 21: jumpDegr 8, rate = y 8 * y 20 * y 19 → 0
