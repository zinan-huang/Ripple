private lemma gammaCompiled_frozenStateAt_inSimplex (N : ℕ) (hN : 0 < N)
    (records : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalRecordΩ)
    (hsim : ∀ n, (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex
      (((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n))
    (t : ℝ) :
    (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex
      (((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).frozenStateAt t) := by
  set path := (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records with hpath_def
  by_cases hex : ∃ n, t < path.times n
  · let n := Nat.find hex
    have hmin : ∀ k ∈ Finset.range n, ¬ t < path.times k := by
      intro k hk
      exact Nat.find_min hex (Finset.mem_range.mp hk)
    rw [show path.frozenStateAt t = path.stateSeq n from
      path.frozenStateAt_eq_stateSeq_of_first_time_gt t n (Nat.find_spec hex) hmin]
    exact hsim n
  · have hno : ∀ m, ¬ t < path.times m := by
      intro m hm; exact hex ⟨m, hm⟩
    by_cases hstab : ∃ n, path.stateSeq n = path.stateSeq (n + 1)
    · let n := Nat.find hstab
      have hmin : ∀ k ∈ Finset.range n,
          path.stateSeq k ≠ path.stateSeq (k + 1) := by
        intro k hk
        exact Nat.find_min hstab (Finset.mem_range.mp hk)
      rw [show path.frozenStateAt t = path.stateSeq n from
        path.frozenStateAt_eq_stateSeq_of_first_stable t n hno
          (Nat.find_spec hstab) hmin]
      exact hsim n
    · have hnostable : ∀ n, path.stateSeq n ≠ path.stateSeq (n + 1) := by
        intro n hn; exact hstab ⟨n, hn⟩
      rw [show path.frozenStateAt t = path.init from
        path.frozenStateAt_eq_init_of_no_time_gt_of_no_stable t hno hnostable]
      convert hsim 0 using 1

