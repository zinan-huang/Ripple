private lemma trilinear_lip {n : ℕ} (a b c : Fin n)
    (R : ℝ) (hR : 0 < R)
    (x y : Fin n → ℝ) (hx : ‖x‖ ≤ R) (hy : ‖y‖ ≤ R) :
    ‖x a * x b * x c - y a * y b * y c‖ ≤ 3 * R ^ 2 * ‖x - y‖ := by
  have hxa : |x a| ≤ R := (norm_le_pi_norm x a).trans hx
  have hxb : |x b| ≤ R := (norm_le_pi_norm x b).trans hx
  have hyb : |y b| ≤ R := (norm_le_pi_norm y b).trans hy
  have hyc : |y c| ≤ R := (norm_le_pi_norm y c).trans hy
  have hdc : |x c - y c| ≤ ‖x - y‖ := by
    rw [show x c - y c = (x - y) c from by simp [Pi.sub_apply]]
    exact norm_le_pi_norm (x - y) c
  have hdb : |x b - y b| ≤ ‖x - y‖ := by
    rw [show x b - y b = (x - y) b from by simp [Pi.sub_apply]]
    exact norm_le_pi_norm (x - y) b
  have hda : |x a - y a| ≤ ‖x - y‖ := by
    rw [show x a - y a = (x - y) a from by simp [Pi.sub_apply]]
    exact norm_le_pi_norm (x - y) a
  have split : x a * x b * x c - y a * y b * y c =
    x a * x b * (x c - y c) + x a * (x b - y b) * y c + (x a - y a) * y b * y c := by ring
  rw [split, Real.norm_eq_abs]
  calc |x a * x b * (x c - y c) + x a * (x b - y b) * y c + (x a - y a) * y b * y c|
      ≤ |x a * x b * (x c - y c)| + |x a * (x b - y b) * y c| + |(x a - y a) * y b * y c| := by
        calc |x a * x b * (x c - y c) + x a * (x b - y b) * y c + (x a - y a) * y b * y c|
            ≤ |x a * x b * (x c - y c) + x a * (x b - y b) * y c| + |(x a - y a) * y b * y c| :=
              abs_add_le _ _
          _ ≤ (|x a * x b * (x c - y c)| + |x a * (x b - y b) * y c|) + |(x a - y a) * y b * y c| :=
              add_le_add (abs_add_le _ _) le_rfl
    _ = |x a| * |x b| * |x c - y c| + |x a| * |x b - y b| * |y c| +
        |x a - y a| * |y b| * |y c| := by
        simp only [abs_mul]
    _ ≤ R * R * ‖x - y‖ + R * ‖x - y‖ * R + ‖x - y‖ * R * R := by
        gcongr
    _ = 3 * R ^ 2 * ‖x - y‖ := by ring

/-- Lipschitz bound for a single trilinear term. -/
private lemma single_tri_lip {n : ℕ} (a b c : Fin n)
    (R : ℝ) (hR : 0 < R)
    (x y : Fin n → ℝ) (hx : ‖x‖ ≤ R) (hy : ‖y‖ ≤ R) :
    |x a * x b * x c - y a * y b * y c| ≤ (6 * R ^ 2 + 1) * ‖x - y‖ := by
  have h := trilinear_lip a b c R hR x y hx hy
  rw [Real.norm_eq_abs] at h
  nlinarith [sq_nonneg R, norm_nonneg (x - y)]

/-- Lipschitz bound for a sum of two trilinear terms. -/
private lemma sum2_tri_lip {n : ℕ} (a₁ b₁ c₁ a₂ b₂ c₂ : Fin n)
    (R : ℝ) (hR : 0 < R)
    (x y : Fin n → ℝ) (hx : ‖x‖ ≤ R) (hy : ‖y‖ ≤ R) :
    |(x a₁ * x b₁ * x c₁ + x a₂ * x b₂ * x c₂) -
     (y a₁ * y b₁ * y c₁ + y a₂ * y b₂ * y c₂)| ≤ (6 * R ^ 2 + 1) * ‖x - y‖ := by
  have h₁ := trilinear_lip a₁ b₁ c₁ R hR x y hx hy
  have h₂ := trilinear_lip a₂ b₂ c₂ R hR x y hx hy
  rw [Real.norm_eq_abs] at h₁ h₂
  have hsplit : (x a₁ * x b₁ * x c₁ + x a₂ * x b₂ * x c₂) -
     (y a₁ * y b₁ * y c₁ + y a₂ * y b₂ * y c₂) =
     (x a₁ * x b₁ * x c₁ - y a₁ * y b₁ * y c₁) +
     (x a₂ * x b₂ * x c₂ - y a₂ * y b₂ * y c₂) := by ring
  rw [hsplit]
  have := abs_add_le (x a₁ * x b₁ * x c₁ - y a₁ * y b₁ * y c₁)
    (x a₂ * x b₂ * x c₂ - y a₂ * y b₂ * y c₂)
  nlinarith [sq_nonneg R, norm_nonneg (x - y)]

/-- Lipschitz bound for a trilinear term with coefficient 2. -/
private lemma coeff2_tri_lip {n : ℕ} (a b c : Fin n)
    (R : ℝ) (hR : 0 < R)
    (x y : Fin n → ℝ) (hx : ‖x‖ ≤ R) (hy : ‖y‖ ≤ R) :
    |2 * x a * x b * x c - 2 * y a * y b * y c| ≤ (6 * R ^ 2 + 1) * ‖x - y‖ := by
  have h := trilinear_lip a b c R hR x y hx hy
  rw [Real.norm_eq_abs] at h
  have hsplit : 2 * x a * x b * x c - 2 * y a * y b * y c =
    2 * (x a * x b * x c - y a * y b * y c) := by ring
  rw [hsplit, abs_mul, show |(2 : ℝ)| = 2 from by norm_num]
  nlinarith [sq_nonneg R, norm_nonneg (x - y)]

/-- Paired jump: species i gains 1, x₀ loses 1. Sum = 0. -/
