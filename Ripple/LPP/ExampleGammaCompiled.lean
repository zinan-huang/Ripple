/-- If exitRate = 0 and there exists a valid target state z matching gammaCompiledJump k,
then gammaCompiledRate k at the scaled state is 0. -/
private lemma gammaCompiledRate_zero_of_valid_target (N : ℕ) (hN : 0 < N)
    (x : Fin 21 → Fin (N + 1))
    (hexit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).toQMatrix.exitRate x = 0)
    (k : Fin 32) (z : Fin 21 → Fin (N + 1)) (hzne : z ≠ x)
    (hmatch : ∀ j : Fin 21, (z j : ℤ) - (x j : ℤ) = gammaCompiledJump k j) :
    gammaCompiledRate k (fun i => (x i : ℝ) / (↑N : ℝ)) = 0 := by
  set M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
  set y := fun i => (x i : ℝ) / (↑N : ℝ)
  have hynonneg : ∀ i, 0 ≤ y i := fun i => div_nonneg (Nat.cast_nonneg _) (Nat.cast_nonneg _)
  have hNpos : (0 : ℝ) < ↑N := Nat.cast_pos.mpr hN
  -- Step 1: exitRate = 0 → offDiagRate(x, z) = 0
  have hoff : M.offDiagRate x z = 0 := by
    have hqr : M.toQMatrix.rate x z = 0 :=
      QMatrix.IsAbsorbing.rate_eq_zero M.toQMatrix hexit z (Ne.symm hzne)
    change M.qMatrixRate x z = 0 at hqr
    rwa [DensityDepCTMC.qMatrixRate, if_neg (Ne.symm hzne)] at hqr
  -- Step 2: offDiagRate = ∑ N * rate(ℓ)(y) = 0, extract N * rate(jump_k)(y) = 0
  rw [DensityDepCTMC.offDiagRate, if_neg (Ne.symm hzne)] at hoff
  have hjfilt : gammaCompiledJump k ∈ gammaCompiledRateSpec.jumps.filter
      (fun ℓ => ∀ j, (↑(z j) : ℤ) - ↑(x j) = ℓ j) :=
    Finset.mem_filter.mpr ⟨Finset.mem_image_of_mem _ (Finset.mem_univ _), hmatch⟩
  have hnn : ∀ ℓ ∈ gammaCompiledRateSpec.jumps.filter
      (fun ℓ => ∀ j, (↑(z j) : ℤ) - ↑(x j) = ℓ j),
      0 ≤ (↑N : ℝ) * gammaCompiledRateSpec.rate ℓ y :=
    fun ℓ hℓ => mul_nonneg hNpos.le
      (gammaCompiledRateSpec.rate_nonneg ℓ (Finset.mem_filter.mp hℓ).1 y hynonneg)
  -- Step 3: rate(jump_k)(y) = 0
  have hrate : gammaCompiledRateSpec.rate (gammaCompiledJump k) y = 0 :=
    (mul_eq_zero.mp (le_antisymm
      ((Finset.single_le_sum hnn hjfilt).trans hoff.le) (hnn _ hjfilt))).resolve_left hNpos.ne'
  -- Step 4: gammaCompiledRate k y is a nonneg summand of rate = 0, hence 0
  change (∑ k' : Fin 32, if gammaCompiledJump k' = gammaCompiledJump k
    then gammaCompiledRate k' y else 0) = 0 at hrate
  have hterms_nn : ∀ k' : Fin 32, 0 ≤ (if gammaCompiledJump k' = gammaCompiledJump k
      then gammaCompiledRate k' y else 0) := by
    intro k'; split_ifs
    · fin_cases k' <;> simp only [gammaCompiledRate] <;>
        first
          | exact le_refl 0
          | (apply_rules [mul_nonneg, add_nonneg, hynonneg]; try norm_num)
    · exact le_refl 0
  exact le_antisymm
    ((if_pos rfl ▸ Finset.single_le_sum (fun k' _ => hterms_nn k') (Finset.mem_univ k)).trans
      hrate.le)
    (by have := hterms_nn k; rwa [if_pos rfl] at this)

