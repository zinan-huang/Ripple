/-- The compiled gamma RateSpec (32 paired reactions, each conservative). -/
noncomputable def gammaCompiledRateSpec : RateSpec 21 where
  jumps := Finset.image gammaCompiledJump Finset.univ
  rate := fun ℓ y =>
    ∑ k : Fin 32, if gammaCompiledJump k = ℓ then gammaCompiledRate k y else 0
  rate_nonneg := by
    intro ℓ _ x hx
    apply Finset.sum_nonneg
    intro k _
    split_ifs
    · fin_cases k <;> simp only [gammaCompiledRate]
      all_goals first
        | exact le_refl 0
        | (apply_rules [mul_nonneg, add_nonneg, hx]; try norm_num)
    · exact le_refl _
  rate_support := by
    intro ℓ hℓ
    ext x; simp only [Pi.zero_apply]
    apply Finset.sum_eq_zero
    intro k _
    have : gammaCompiledJump k ≠ ℓ := by
      intro h; exact hℓ (Finset.mem_image.mpr ⟨k, Finset.mem_univ k, h⟩)
    simp [this]
  rate_lipschitz := by
    intro ℓ _ R hR
    refine ⟨32 * (6 * R ^ 2 + 1), by positivity, ?_⟩
    intro x y hx hy
    have hδ := norm_nonneg (x - y)
    -- Per-rate Lipschitz bound via helper lemmas
    have hrate_lip : ∀ k : Fin 32,
        |gammaCompiledRate k x - gammaCompiledRate k y| ≤
          (6 * R ^ 2 + 1) * ‖x - y‖ := by
      intro k
      fin_cases k <;> simp only [gammaCompiledRate] <;>
        first
        | exact single_tri_lip _ _ _ R hR x y hx hy
        | exact sum2_tri_lip _ _ _ _ _ _ R hR x y hx hy
        | exact coeff2_tri_lip _ _ _ R hR x y hx hy
    rw [show (fun x => ∑ k : Fin 32,
        if gammaCompiledJump k = ℓ then gammaCompiledRate k x else 0) x -
      (fun x => ∑ k : Fin 32,
        if gammaCompiledJump k = ℓ then gammaCompiledRate k x else 0) y =
      ∑ k : Fin 32, ((if gammaCompiledJump k = ℓ then gammaCompiledRate k x else 0) -
        (if gammaCompiledJump k = ℓ then gammaCompiledRate k y else 0)) from by
      simp [Finset.sum_sub_distrib]]
    rw [Real.norm_eq_abs]
    calc |∑ k : Fin 32, _|
        ≤ ∑ k : Fin 32, |((if gammaCompiledJump k = ℓ then gammaCompiledRate k x else 0) -
            (if gammaCompiledJump k = ℓ then gammaCompiledRate k y else 0))| :=
          Finset.abs_sum_le_sum_abs _ _
      _ ≤ ∑ _k : Fin 32, ((6 * R ^ 2 + 1) * ‖x - y‖) := by
          apply Finset.sum_le_sum
          intro k _
          split_ifs with h
          · exact hrate_lip k
          · simp only [sub_self, abs_zero]; positivity
      _ = (32 : ℝ) * ((6 * R ^ 2 + 1) * ‖x - y‖) := by
          rw [Finset.sum_const, Finset.card_univ, Fintype.card_fin, nsmul_eq_mul]
          push_cast; ring
      _ = (32 * (6 * R ^ 2 + 1)) * ‖x - y‖ := by ring

/-- Each paired jump sums to 0 — mass is conserved. -/
theorem gammaCompiled_conservativeJumps (N : ℕ) (hN : 0 < N) :
    (DensityDepCTMC.mk N hN gammaCompiledRateSpec).ConservativeJumps := by
  intro ℓ hℓ
  change ℓ ∈ Finset.image gammaCompiledJump Finset.univ at hℓ
  simp only [Finset.mem_image, Finset.mem_univ, true_and] at hℓ
  obtain ⟨k, rfl⟩ := hℓ
  fin_cases k <;> native_decide

private lemma gammaCompiledRate_zero_of_x0_zero (k : Fin 32) (y : Fin 21 → ℝ)
    (h20 : y 20 = 0) : gammaCompiledRate k y = 0 := by
  fin_cases k <;> simp only [gammaCompiledRate, h20, mul_zero, zero_mul, add_zero]

private lemma gammaCompiledRateSpec_rate_zero_of_x0_zero (ℓ : Fin 21 → ℤ) (y : Fin 21 → ℝ)
    (h20 : y 20 = 0) : gammaCompiledRateSpec.rate ℓ y = 0 := by
  change (∑ k : Fin 32, if gammaCompiledJump k = ℓ then gammaCompiledRate k y else 0) = 0
  apply Finset.sum_eq_zero
  intro k _
  split_ifs
  · exact gammaCompiledRate_zero_of_x0_zero k y h20
  · rfl

