/-- Norm bound (unsquared): ‖M−M*‖ ≤ 484·(1+2T²+2T)·√(sup‖M*‖²).
The content of the confinement proof; squaring is done in the next lemma. -/
private lemma gammaCompiled_confinement_norm_le {T : ℝ} (hT : 0 < T)
    (N : ℕ) (hN : 0 < N) (hN484 : 484 < N)
    (x₀ : Fin 21 → Fin (N + 1))
    (hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀)
    (hclose : ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ ≤ 1 / ↑N)
    (records : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalRecordΩ)
    (hrec : (records 0).2 = x₀)
    (hinitFrozen :
      (DensityDepCTMC.mk N hN gammaCompiledRateSpec).frozenInitialCondition
        (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records =
        fun i => (↑(x₀ i) : ℝ) / ↑N)
    (hsim : ∀ n, (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex
      (((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n))
    (h19const : ∀ n,
      ((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n 19 =
      x₀ 19)
    (s : ℝ) (hs0 : 0 ≤ s) (hsT : s ≤ T) :
    let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
    ‖M.frozenMartingalePart M.canonicalPathMap s records -
     M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ≤
    484 * (1 + 2 * T ^ 2 + 2 * T) *
      Real.sqrt (⨆ (u : ℝ) (_ : 0 ≤ u ∧ u ≤ T),
        ‖M.frozenGeneratorMartingalePart M.canonicalPathMap u records‖ ^ 2) := by
  intro M
  set S := Real.sqrt (⨆ (u : ℝ) (_ : 0 ≤ u ∧ u ≤ T),
    ‖M.frozenGeneratorMartingalePart M.canonicalPathMap u records‖ ^ 2) with hSdef
  -- Step 1: y₁₉ ≥ 1/484
  have hy19 : (1 : ℝ) / 484 ≤ (↑(x₀ 19) : ℝ) / ↑N := by
    have hNpos : (0 : ℝ) < ↑N := Nat.cast_pos.mpr hN
    have h19_init : gammaCompiledInit 19 = 1 / 242 := by
      simp [gammaCompiledInit]
    have hcomp : ‖(((fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit) 19)‖ ≤
        ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ :=
      norm_le_pi_norm ((fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit) 19
    simp only [Pi.sub_apply] at hcomp
    have habs : |(↑(x₀ 19) : ℝ) / ↑N - gammaCompiledInit 19| ≤ 1 / ↑N := by
      rw [Real.norm_eq_abs] at hcomp; linarith
    rw [h19_init] at habs
    have hN484_real : (484 : ℝ) < ↑N := by exact_mod_cast hN484
    have hN_inv_le : (1 : ℝ) / ↑N ≤ 1 / 484 :=
      one_div_le_one_div_of_le (by norm_num : (0 : ℝ) < 484) (le_of_lt hN484_real)
    rw [abs_le] at habs
    nlinarith [habs.1, hN_inv_le]
  -- Step 2: S bounds |M*_i| pointwise
  have hS_nn : 0 ≤ S := Real.sqrt_nonneg _
  obtain ⟨C_star, _, hCstar⟩ :=
    M.exists_frozenGeneratorMP_norm_bound M.canonicalPathMap T (le_of_lt hT)
  have hG_bdd : BddAbove (Set.range fun u => ⨆ _ : 0 ≤ u ∧ u ≤ T,
      ‖M.frozenGeneratorMartingalePart M.canonicalPathMap u records‖ ^ 2) :=
    ⟨C_star ^ 2, by
      rintro _ ⟨u, rfl⟩
      exact Real.iSup_le (fun ⟨hu0, huT⟩ =>
        pow_le_pow_left₀ (norm_nonneg _) (hCstar u records hu0 huT) 2) (sq_nonneg _)⟩
  have hS_bound : ∀ u, 0 ≤ u → u ≤ T → ∀ i,
      |M.frozenGeneratorMartingalePart M.canonicalPathMap u records i| ≤ S := by
    intro u hu0 huT i
    have hcomp : |M.frozenGeneratorMartingalePart M.canonicalPathMap u records i| ≤
        ‖M.frozenGeneratorMartingalePart M.canonicalPathMap u records‖ := by
      simpa [Real.norm_eq_abs] using
        norm_le_pi_norm (M.frozenGeneratorMartingalePart M.canonicalPathMap u records) i
    have hnorm_le_S : ‖M.frozenGeneratorMartingalePart M.canonicalPathMap u records‖ ≤ S := by
      rw [hSdef]
      rw [← Real.sqrt_sq (norm_nonneg _)]
      exact Real.sqrt_le_sqrt (le_ciSup_of_le hG_bdd u
        (le_ciSup_of_le ⟨C_star ^ 2, by
          rintro _ ⟨⟨_, _⟩, rfl⟩
          exact pow_le_pow_left₀ (norm_nonneg _) (hCstar u records hu0 huT) 2⟩
          ⟨hu0, huT⟩ le_rfl))
    linarith
  -- Step 3: bound ‖M-M*‖ by boundary integral via almost-BC
  -- (M-M*)_i = ∫genDrift_i - ∫drift_i, and only reaction 22 contributes at boundary x₉=0)
  -- ‖M-M*‖ ≤ ∫₀ˢ rate(22,y)·1_{x₉=0} du ≤ ∫₀ᵀ rate(22,y)·1_{x₉=0} du
  have hA_bound : ‖M.frozenMartingalePart M.canonicalPathMap s records -
      M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ≤
      484 * (1 + 2 * T ^ 2 + 2 * T) * S := by
    exact gammaCompiled_confinement_norm_le_core hT N hN hN484 x₀ hinit hclose
      records hrec hinitFrozen hsim h19const s hs0 hsT S hy19 hS_nn hS_bound
  exact hA_bound

