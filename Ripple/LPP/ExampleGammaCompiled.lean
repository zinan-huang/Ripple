/-- Core confinement: for N > 484, the drift mismatch ‖M−M*‖² at each time s
is bounded by 484²·(1+2T²+2T)²·sup‖M*‖² (the pointwise confinement claim). -/
private lemma gammaCompiled_confinement_pointwise {T : ℝ} (hT : 0 < T)
    (N : ℕ) (hN : 0 < N) (hN484 : 484 < N)
    (x₀ : Fin 21 → Fin (N + 1))
    (hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀)
    (hclose : ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ ≤ 1 / ↑N)
    (records : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalRecordΩ)
    (hrec : (records 0).2 = x₀)
    (hinitFrozen :
      (DensityDepCTMC.mk N hN gammaCompiledRateSpec).frozenInitialCondition
        (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records =
        fun i => (↑(x₀ i) : ℝ) / ↑N)
    (hsim : ∀ n, (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex
      (((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n))
    (h19const : ∀ n,
      ((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n 19 =
      x₀ 19)
    (s : ℝ) (hs0 : 0 ≤ s) (hsT : s ≤ T) :
    let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
    ‖M.frozenMartingalePart M.canonicalPathMap s records -
     M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2 ≤
    (484 : ℝ) ^ 2 * (1 + 2 * T ^ 2 + 2 * T) ^ 2 *
      (⨆ (u : ℝ) (_ : 0 ≤ u ∧ u ≤ T),
        ‖M.frozenGeneratorMartingalePart M.canonicalPathMap u records‖ ^ 2) := by
  intro M
  have hnorm := gammaCompiled_confinement_norm_le hT N hN hN484 x₀ hinit hclose
    records hrec hinitFrozen hsim h19const s hs0 hsT
  set G := ⨆ (u : ℝ) (_ : 0 ≤ u ∧ u ≤ T),
    ‖M.frozenGeneratorMartingalePart M.canonicalPathMap u records‖ ^ 2 with hGdef
  have hG_nn : 0 ≤ G := Real.iSup_nonneg fun u =>
    Real.iSup_nonneg fun _ => sq_nonneg _
  have hsqrt_sq : Real.sqrt G ^ 2 = G :=
    Real.sq_sqrt hG_nn
  calc ‖M.frozenMartingalePart M.canonicalPathMap s records -
       M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
      ≤ (484 * (1 + 2 * T ^ 2 + 2 * T) * Real.sqrt G) ^ 2 :=
        pow_le_pow_left₀ (norm_nonneg _) hnorm 2
    _ = (484 : ℝ) ^ 2 * (1 + 2 * T ^ 2 + 2 * T) ^ 2 * (Real.sqrt G ^ 2) := by ring
    _ = (484 : ℝ) ^ 2 * (1 + 2 * T ^ 2 + 2 * T) ^ 2 * G := by rw [hsqrt_sq]

set_option maxHeartbeats 6400000
/-- Pathwise confinement bound: sup ‖M−M*‖² ≤ K · sup ‖M*‖² + K/N².
The drift mismatch is nonzero only when reaction 22 is infeasible (X₉=0).
For small N (≤ 484), a crude triangle-inequality bound suffices;
for large N, the process equation confines the boundary time integral. -/
private lemma gammaCompiled_drift_mismatch_pathwise {T : ℝ} (hT : 0 < T) :
    ∃ K : ℝ, 0 < K ∧
    ∀ (N : ℕ) (hN : 0 < N) (x₀ : Fin 21 → Fin (N + 1))
    (_hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀)
    (_hclose : ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ ≤ 1 / ↑N)
    (records : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalRecordΩ)
    (_hrec : (records 0).2 = x₀)
    (_hinitFrozen :
      (DensityDepCTMC.mk N hN gammaCompiledRateSpec).frozenInitialCondition
        (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records =
        fun i => (↑(x₀ i) : ℝ) / ↑N)
    (_hsim : ∀ n, (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex
      (((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n))
    (_h19const : ∀ n,
      ((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n 19 =
      x₀ 19),
    let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
    (⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
      ‖M.frozenMartingalePart M.canonicalPathMap s records -
       M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) ≤
    K * (⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
      ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) +
    K / (↑N : ℝ) ^ 2 := by
  have h_pathwise_confinement :
      ∃ K : ℝ, 0 < K ∧
      ∀ (N : ℕ) (hN : 0 < N) (x₀ : Fin 21 → Fin (N + 1))
      (_hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀)
      (_hclose : ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ ≤ 1 / ↑N)
      (records : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalRecordΩ)
      (_hrec : (records 0).2 = x₀)
      (_hinitFrozen :
        (DensityDepCTMC.mk N hN gammaCompiledRateSpec).frozenInitialCondition
          (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records =
          fun i => (↑(x₀ i) : ℝ) / ↑N)
      (_hsim : ∀ n, (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex
        (((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n))
      (_h19const : ∀ n,
        ((DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap records).stateSeq n 19 =
        x₀ 19),
      let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
      (⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
        ‖M.frozenMartingalePart M.canonicalPathMap s records -
         M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) ≤
      K * (⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
        ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) +
      K / (↑N : ℝ) ^ 2 := by
      have hdet : ∀ (n : ℕ) (hn : 0 < n), ∃ B : ℝ, 0 < B ∧
          ∀ (records : (DensityDepCTMC.mk n hn gammaCompiledRateSpec).canonicalRecordΩ)
            (s : ℝ), 0 ≤ s → s ≤ T →
            ‖(DensityDepCTMC.mk n hn gammaCompiledRateSpec).frozenMartingalePart
                (DensityDepCTMC.mk n hn gammaCompiledRateSpec).canonicalPathMap s records -
              (DensityDepCTMC.mk n hn gammaCompiledRateSpec).frozenGeneratorMartingalePart
                (DensityDepCTMC.mk n hn gammaCompiledRateSpec).canonicalPathMap s records‖ ^ 2 ≤ B := by
        intro n hn
        let M := DensityDepCTMC.mk n hn gammaCompiledRateSpec
        obtain ⟨K₁, hK₁_pos, hK₁_bound⟩ :=
          M.exists_frozenMartingalePart_norm_bound M.canonicalPathMap T (le_of_lt hT)
        obtain ⟨K₂, hK₂_pos, hK₂_bound⟩ :=
          M.exists_frozenGeneratorMP_norm_bound M.canonicalPathMap T (le_of_lt hT)
        refine ⟨(K₁ + K₂) ^ 2, by positivity, ?_⟩
        intro records s hs0 hsT
        have hnorm :
            ‖M.frozenMartingalePart M.canonicalPathMap s records -
              M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ≤ K₁ + K₂ :=
          (norm_sub_le _ _).trans
            (add_le_add (hK₁_bound s records hs0 hsT) (hK₂_bound s records hs0 hsT))
        exact pow_le_pow_left₀ (norm_nonneg _) hnorm 2
      let Bfun : ℕ → ℝ := fun n =>
        if hn : 0 < n then Classical.choose (hdet n hn) else 0
      let Bmax : ℝ := (Finset.Icc 1 484).sup' ⟨1, by simp⟩ Bfun
      let A : ℝ := (484 : ℝ) ^ 2 * (1 + 2 * T ^ 2 + 2 * T) ^ 2
      let K : ℝ := max A ((484 : ℝ) ^ 2 * Bmax) + 1
      have hBfun_spec : ∀ {n : ℕ} (hn : 0 < n),
          0 < Bfun n ∧
          ∀ (records : (DensityDepCTMC.mk n hn gammaCompiledRateSpec).canonicalRecordΩ)
            (s : ℝ), 0 ≤ s → s ≤ T →
            ‖(DensityDepCTMC.mk n hn gammaCompiledRateSpec).frozenMartingalePart
                (DensityDepCTMC.mk n hn gammaCompiledRateSpec).canonicalPathMap s records -
              (DensityDepCTMC.mk n hn gammaCompiledRateSpec).frozenGeneratorMartingalePart
                (DensityDepCTMC.mk n hn gammaCompiledRateSpec).canonicalPathMap s records‖ ^ 2 ≤
              Bfun n := by
        intro n hn
        dsimp [Bfun]
        rw [dif_pos hn]
        exact Classical.choose_spec (hdet n hn)
      have hBmax_nonneg : 0 ≤ Bmax := by
        have h1 : 0 < Bfun 1 := (hBfun_spec (by norm_num : 0 < 1)).1
        have hle : Bfun 1 ≤ Bmax := by
          exact Finset.le_sup' (s := Finset.Icc 1 484) (f := Bfun) (by simp)
        exact (le_of_lt h1).trans hle
      have hA_nonneg : 0 ≤ A := by
        dsimp [A]
        positivity
      have hK_pos : 0 < K := by
        dsimp [K]
        nlinarith [le_max_left A ((484 : ℝ) ^ 2 * Bmax), hA_nonneg]
      refine ⟨K, hK_pos, ?_⟩
      intro N hN x₀ hinit hclose records hrec hinitFrozen hsim h19const
      let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
      let Fdiff : ℝ := ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
        ‖M.frozenMartingalePart M.canonicalPathMap s records -
         M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
      let Fstar : ℝ := ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
        ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
      have hFstar_nonneg : 0 ≤ Fstar :=
        Real.iSup_nonneg fun s => Real.iSup_nonneg fun _ => sq_nonneg _
      have hK_nonneg : 0 ≤ K := le_of_lt hK_pos
      by_cases hlarge : 484 < N
      · have hA_le_K : A ≤ K := by
          dsimp [K]
          linarith [le_max_left A ((484 : ℝ) ^ 2 * Bmax)]
        have hrhs_nonneg : 0 ≤ A * Fstar := mul_nonneg hA_nonneg hFstar_nonneg
        have hFdiff_le_A :
            Fdiff ≤ A * Fstar := by
          dsimp [Fdiff, Fstar]
          refine Real.iSup_le (fun s => ?_) hrhs_nonneg
          refine Real.iSup_le (fun hs => ?_) hrhs_nonneg
          have hpt := gammaCompiled_confinement_pointwise hT N hN hlarge x₀ hinit hclose
            records hrec hinitFrozen hsim h19const s hs.1 hs.2
          simpa [M, A] using hpt
        have hAF_le_KF : A * Fstar ≤ K * Fstar :=
          mul_le_mul_of_nonneg_right hA_le_K hFstar_nonneg
        have hdiv_nonneg : 0 ≤ K / (↑N : ℝ) ^ 2 :=
          div_nonneg hK_nonneg (sq_nonneg _)
        dsimp [Fdiff, Fstar] at hFdiff_le_A hAF_le_KF
        calc
          (⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
            ‖M.frozenMartingalePart M.canonicalPathMap s records -
             M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2)
              = Fdiff := rfl
          _ ≤ A * Fstar := hFdiff_le_A
          _ ≤ K * Fstar := hAF_le_KF
          _ ≤ K * Fstar + K / (↑N : ℝ) ^ 2 := by linarith
      · have hNle : N ≤ 484 := Nat.le_of_not_gt hlarge
        have hmem : N ∈ Finset.Icc 1 484 := by
          simp [Finset.mem_Icc, Nat.succ_le_of_lt hN, hNle]
        have hBN_le_Bmax : Bfun N ≤ Bmax :=
          Finset.le_sup' (s := Finset.Icc 1 484) (f := Bfun) hmem
        have hBN_bound := (hBfun_spec hN).2 records
        have hBN_nonneg : 0 ≤ Bfun N := le_of_lt (hBfun_spec hN).1
        have hFdiff_le_BN : Fdiff ≤ Bfun N := by
          dsimp [Fdiff]
          refine Real.iSup_le (fun s => ?_) hBN_nonneg
          refine Real.iSup_le (fun hs => ?_) hBN_nonneg
          simpa [M] using hBN_bound s hs.1 hs.2
        have hK_ge_484B : (484 : ℝ) ^ 2 * Bmax ≤ K := by
          dsimp [K]
          linarith [le_max_right A ((484 : ℝ) ^ 2 * Bmax)]
        have hNreal_pos : 0 < (N : ℝ) := Nat.cast_pos.mpr hN
        have hN2_pos : 0 < (N : ℝ) ^ 2 := sq_pos_of_pos hNreal_pos
        have hNsq_le : (N : ℝ) ^ 2 ≤ (484 : ℝ) ^ 2 := by
          exact pow_le_pow_left₀ (Nat.cast_nonneg N) (by exact_mod_cast hNle : (N : ℝ) ≤ 484) 2
        have hBmax_le_scaled : Bmax ≤ ((484 : ℝ) ^ 2 * Bmax) / (N : ℝ) ^ 2 := by
          rw [le_div_iff₀ hN2_pos]
          have hmul := mul_le_mul_of_nonneg_right hNsq_le hBmax_nonneg
          nlinarith
        have hscaled_le_Kdiv :
            ((484 : ℝ) ^ 2 * Bmax) / (N : ℝ) ^ 2 ≤ K / (N : ℝ) ^ 2 :=
          div_le_div_of_nonneg_right hK_ge_484B (le_of_lt hN2_pos)
        have hBN_le_Kdiv : Bfun N ≤ K / (N : ℝ) ^ 2 :=
          hBN_le_Bmax.trans (hBmax_le_scaled.trans hscaled_le_Kdiv)
        have hKFstar_nonneg : 0 ≤ K * Fstar := mul_nonneg hK_nonneg hFstar_nonneg
        dsimp [Fdiff, Fstar] at hFdiff_le_BN
        calc
          (⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
            ‖M.frozenMartingalePart M.canonicalPathMap s records -
             M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2)
              = Fdiff := rfl
          _ ≤ Bfun N := hFdiff_le_BN
          _ ≤ K / (↑N : ℝ) ^ 2 := hBN_le_Kdiv
          _ ≤ K * Fstar + K / (↑N : ℝ) ^ 2 := by linarith
  exact h_pathwise_confinement

/-- Integrability of sup ‖M−M*‖² from pathwise boundedness. -/
private lemma gammaCompiled_drift_mismatch_integrable {T : ℝ} (hT : 0 < T)
    (N : ℕ) (hN : 0 < N) (x₀ : Fin 21 → Fin (N + 1))
    (_hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀) :
    let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
    MeasureTheory.Integrable
      (fun records => ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
        ‖M.frozenMartingalePart M.canonicalPathMap s records -
         M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2)
      (M.canonicalRecordMeasure x₀) := by
  intro M
  obtain ⟨K₁, hK₁_pos, hK₁_bound⟩ :=
    M.exists_frozenMartingalePart_norm_bound M.canonicalPathMap T (le_of_lt hT)
  obtain ⟨K₂, hK₂_pos, hK₂_bound⟩ :=
    M.exists_frozenGeneratorMP_norm_bound M.canonicalPathMap T (le_of_lt hT)
  have hC_nonneg : (0 : ℝ) ≤ (K₁ + K₂) ^ 2 := by positivity
  -- Pathwise deterministic bound on ‖M(s) − M*(s)‖².
  have hdiff_sq_bound : ∀ (s : ℝ) (records : M.canonicalRecordΩ), 0 ≤ s → s ≤ T →
      ‖M.frozenMartingalePart M.canonicalPathMap s records -
       M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2 ≤
      (K₁ + K₂) ^ 2 := by
    intro s records hs0 hsT
    have hnorm : ‖M.frozenMartingalePart M.canonicalPathMap s records -
        M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ≤ K₁ + K₂ :=
      (norm_sub_le _ _).trans (add_le_add (hK₁_bound s records hs0 hsT)
        (hK₂_bound s records hs0 hsT))
    exact pow_le_pow_left₀ (norm_nonneg _) hnorm 2
  -- Fixed-time measurability of ‖M(t) − M*(t)‖².
  have hmeas_diff_sq : ∀ t : ℝ, Measurable (fun records : M.canonicalRecordΩ =>
      ‖M.frozenMartingalePart M.canonicalPathMap t records -
       M.frozenGeneratorMartingalePart M.canonicalPathMap t records‖ ^ 2) :=
    fun t => (measurable_norm.comp
      ((M.measurable_canonicalFrozenMartingalePart t).sub
        (M.measurable_canonicalFrozenGeneratorMartingalePart t))).pow measurable_const
  -- Rational-time and endpoint proxies.
  let ratProxy : M.canonicalRecordΩ → ℝ := fun records =>
    ⨆ (q : ℚ) (_ : 0 ≤ (q : ℝ) ∧ (q : ℝ) ≤ T),
      ‖M.frozenMartingalePart M.canonicalPathMap (q : ℝ) records -
       M.frozenGeneratorMartingalePart M.canonicalPathMap (q : ℝ) records‖ ^ 2
  let endProxy : M.canonicalRecordΩ → ℝ := fun records =>
    ‖M.frozenMartingalePart M.canonicalPathMap T records -
     M.frozenGeneratorMartingalePart M.canonicalPathMap T records‖ ^ 2
  let proxy : M.canonicalRecordΩ → ℝ := fun records =>
    max (ratProxy records) (endProxy records)
  have hratProxy_meas : Measurable (fun records : M.canonicalRecordΩ =>
      ⨆ (q : ℚ) (_ : 0 ≤ (q : ℝ) ∧ (q : ℝ) ≤ T),
        ‖M.frozenMartingalePart M.canonicalPathMap (q : ℝ) records -
         M.frozenGeneratorMartingalePart M.canonicalPathMap (q : ℝ) records‖ ^ 2) := by
    apply Measurable.iSup
    intro q
    exact (hmeas_diff_sq (q : ℝ)).iSup_Prop _
  have hproxy_meas : Measurable proxy := hratProxy_meas.max (hmeas_diff_sq T)
  -- The proxy is integrable: it is measurable and uniformly bounded.
  have hproxy_int : MeasureTheory.Integrable proxy (M.canonicalRecordMeasure x₀) := by
    refine MeasureTheory.Integrable.of_bound
      hproxy_meas.aestronglyMeasurable ((K₁ + K₂) ^ 2) ?_
    filter_upwards with records
    have hrat_nonneg : 0 ≤ ratProxy records := by
      dsimp [ratProxy]
      exact Real.iSup_nonneg fun q => Real.iSup_nonneg fun _ => sq_nonneg _
    have hproxy_nonneg : 0 ≤ proxy records :=
      le_trans hrat_nonneg (le_max_left (ratProxy records) (endProxy records))
    have hrat_le : ratProxy records ≤ (K₁ + K₂) ^ 2 := by
      dsimp [ratProxy]
      refine Real.iSup_le (fun q => ?_) hC_nonneg
      refine Real.iSup_le (fun hq => ?_) hC_nonneg
      exact hdiff_sq_bound (q : ℝ) records hq.1 hq.2
    have hend_le : endProxy records ≤ (K₁ + K₂) ^ 2 :=
      hdiff_sq_bound T records (le_of_lt hT) le_rfl
    rw [Real.norm_eq_abs, abs_of_nonneg hproxy_nonneg]
    exact max_le hrat_le hend_le
  -- A.e. the proxy equals the real-time supremum, by right-continuity of M − M*.
  have heq : proxy =ᵐ[M.canonicalRecordMeasure x₀]
      (fun records : M.canonicalRecordΩ =>
        ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
          ‖M.frozenMartingalePart M.canonicalPathMap s records -
           M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) := by
    filter_upwards
      [M.canonical_frozenMartingalePart_forall_continuousWithinAt_Ici_ae x₀,
       M.canonical_frozenGeneratorMartingalePart_forall_continuousWithinAt_Ici_ae x₀]
      with records hcontM hcontG
    have hfcont : ∀ t : ℝ, ContinuousWithinAt
        (fun s => ‖M.frozenMartingalePart M.canonicalPathMap s records -
          M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2)
        (Set.Ici t) t :=
      fun t => (((hcontM t).sub (hcontG t)).norm.pow 2)
    have hfbound : ∀ s : ℝ, 0 ≤ s → s ≤ T →
        ‖M.frozenMartingalePart M.canonicalPathMap s records -
         M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2 ≤
        (K₁ + K₂) ^ 2 :=
      fun s hs0 hsT => hdiff_sq_bound s records hs0 hsT
    have hle := DensityDepCTMC.realSup_le_ratSup_max_endpoint_of_right_continuous
      (fun s => ‖M.frozenMartingalePart M.canonicalPathMap s records -
        M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2)
      T (le_of_lt hT) hfcont ⟨(K₁ + K₂) ^ 2, hfbound⟩
      (fun s _hs0 _hsT => sq_nonneg _)
    have hinner_bdd : ∀ s : ℝ,
        BddAbove (Set.range fun _ : 0 ≤ s ∧ s ≤ T =>
          ‖M.frozenMartingalePart M.canonicalPathMap s records -
           M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) := by
      intro s
      refine ⟨(K₁ + K₂) ^ 2, ?_⟩
      rintro y ⟨hs, rfl⟩
      exact hfbound s hs.1 hs.2
    have houter_bdd : BddAbove (Set.range fun s : ℝ =>
        ⨆ (_ : 0 ≤ s ∧ s ≤ T),
          ‖M.frozenMartingalePart M.canonicalPathMap s records -
           M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) := by
      refine ⟨(K₁ + K₂) ^ 2, ?_⟩
      rintro y ⟨s, rfl⟩
      exact Real.iSup_le (fun hs => hfbound s hs.1 hs.2) hC_nonneg
    have hrat_le :
        (⨆ (q : ℚ) (_ : 0 ≤ (q : ℝ) ∧ (q : ℝ) ≤ T),
          ‖M.frozenMartingalePart M.canonicalPathMap (q : ℝ) records -
           M.frozenGeneratorMartingalePart M.canonicalPathMap (q : ℝ) records‖ ^ 2) ≤
        (⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
          ‖M.frozenMartingalePart M.canonicalPathMap s records -
           M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) := by
      refine Real.iSup_le (fun q => ?_) (Real.iSup_nonneg fun s =>
        Real.iSup_nonneg fun _ => sq_nonneg _)
      refine Real.iSup_le (fun hq => ?_) (Real.iSup_nonneg fun s =>
        Real.iSup_nonneg fun _ => sq_nonneg _)
      exact le_trans (le_ciSup (hinner_bdd (q : ℝ)) hq) (le_ciSup houter_bdd (q : ℝ))
    have hend_le :
        ‖M.frozenMartingalePart M.canonicalPathMap T records -
         M.frozenGeneratorMartingalePart M.canonicalPathMap T records‖ ^ 2 ≤
        (⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
          ‖M.frozenMartingalePart M.canonicalPathMap s records -
           M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2) :=
      le_trans (le_ciSup (hinner_bdd T) ⟨le_of_lt hT, le_rfl⟩) (le_ciSup houter_bdd T)
    exact (le_antisymm hle (max_le hrat_le hend_le)).symm
  exact hproxy_int.congr heq

/-- **Drift mismatch bound: E[sup ‖M − M*‖²] ≤ C(T) · T / N.**
Decomposes into pathwise confinement bound + M* Doob L² bound. -/
private lemma gammaCompiled_drift_mismatch_sup_sq_bound {T : ℝ} (hT : 0 < T) :
    ∃ C_drift : ℝ, 0 < C_drift ∧
    ∀ (N : ℕ) (hN : 0 < N)
    (x₀ : Fin 21 → Fin (N + 1))
    (_hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀)
    (_hclose : ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ ≤ 1 / ↑N),
    let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
    MeasureTheory.Integrable
      (fun records => ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
        ‖M.frozenMartingalePart M.canonicalPathMap s records -
         M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2)
      (M.canonicalRecordMeasure x₀) ∧
    ∫ records, ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
      ‖M.frozenMartingalePart M.canonicalPathMap s records -
       M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
    ∂M.canonicalRecordMeasure x₀
    ≤ C_drift * T / ↑N := by
  obtain ⟨C_doob, hC_doob_pos, hDoob⟩ := gammaCompiled_generatorMP_sup_sq_bound hT
  obtain ⟨K, hK_pos, hK_pw⟩ := gammaCompiled_drift_mismatch_pathwise hT
  refine ⟨K * C_doob + K / T, by positivity, fun N hN x₀ hinit hclose => ?_⟩
  let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
  let μ := M.canonicalRecordMeasure x₀
  let F_diff := fun records : M.canonicalRecordΩ => ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
    ‖M.frozenMartingalePart M.canonicalPathMap s records -
     M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
  let F_star := fun records : M.canonicalRecordΩ => ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
    ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
  obtain ⟨hDoob_int, hDoob_bound⟩ := hDoob N hN x₀ hinit hclose
  have hF_diff_int : MeasureTheory.Integrable F_diff μ :=
    gammaCompiled_drift_mismatch_integrable hT N hN x₀ hinit
  have hrec_ae : ∀ᵐ records ∂μ, (records 0).2 = x₀ :=
    (M.toQMatrix.canonicalRecordMeasure_record_zero_eq_init_ae x₀).mono
      fun records h => by rw [h]
  have hinitFrozen_ae : ∀ᵐ records ∂μ,
      M.frozenInitialCondition M.canonicalPathMap records =
        fun i => (↑(x₀ i) : ℝ) / ↑N :=
    M.canonical_frozenInitialCondition_eq_scaledState_ae x₀
  have hsim_ae : ∀ᵐ records ∂μ,
      ∀ n, M.InSimplex ((M.canonicalPathMap records).stateSeq n) :=
    M.canonicalPathMap_stateSeq_inSimplex_ae_of_conservative x₀
      (gammaCompiled_conservativeJumps N hN) hinit
  have h19const_ae : ∀ᵐ records ∂μ,
      ∀ n, (M.canonicalPathMap records).stateSeq n 19 = x₀ 19 :=
    gammaCompiled_stateSeq_19_const_ae N hN x₀ hinit
  have hpw_ae : ∀ᵐ records ∂μ,
      F_diff records ≤ K * F_star records + K / (↑N : ℝ) ^ 2 :=
    (hrec_ae.and (hinitFrozen_ae.and (hsim_ae.and h19const_ae))).mono
      fun records ⟨hrec, hinitFrozen, hsim, h19const⟩ =>
        hK_pw N hN x₀ hinit hclose records hrec hinitFrozen hsim h19const
  have hNpos : (0 : ℝ) < ↑N := Nat.cast_pos.mpr hN
  constructor
  · exact hF_diff_int
  · have hRHS_int : MeasureTheory.Integrable
        (fun records => K * F_star records + K / (↑N : ℝ) ^ 2) μ :=
      (hDoob_int.const_mul K).add (MeasureTheory.integrable_const _)
    have hint_const : ∫ _records, (K / (↑N : ℝ) ^ 2) ∂μ = K / (↑N : ℝ) ^ 2 := by
      simp [MeasureTheory.integral_const]
    have hint_split : ∫ records, (K * F_star records + K / (↑N : ℝ) ^ 2) ∂μ =
        K * ∫ records, F_star records ∂μ + K / (↑N : ℝ) ^ 2 := by
      rw [MeasureTheory.integral_add (hDoob_int.const_mul K) (MeasureTheory.integrable_const _),
          MeasureTheory.integral_const_mul, hint_const]
    calc ∫ records, F_diff records ∂μ
        ≤ ∫ records, (K * F_star records + K / (↑N : ℝ) ^ 2) ∂μ :=
          MeasureTheory.integral_mono_ae hF_diff_int hRHS_int hpw_ae
      _ = K * ∫ records, F_star records ∂μ + K / (↑N : ℝ) ^ 2 := hint_split
      _ ≤ K * (C_doob * T / ↑N) + K / (↑N : ℝ) ^ 2 := by gcongr
      _ ≤ (K * C_doob + K / T) * T / ↑N := by
          have hN1 : (1 : ℝ) ≤ ↑N := by exact_mod_cast hN
          have hNsq : (↑N : ℝ) ≤ (↑N : ℝ) ^ 2 := by
            nlinarith [sq_nonneg ((↑N : ℝ) - 1)]
          have hKdiv : K / (↑N : ℝ) ^ 2 ≤ K / ↑N :=
            div_le_div_of_nonneg_left (by positivity) hNpos hNsq
          have hassoc : K * (C_doob * T / ↑N) = K * C_doob * T / ↑N := by ring
          have hrhs : (K * C_doob + K / T) * T / ↑N = K * C_doob * T / ↑N + K / ↑N := by
            field_simp
          linarith

private lemma le_real_iSup₂_of_bounded {f : ℝ → ℝ} {s T : ℝ}
    (hs0 : 0 ≤ s) (hsT : s ≤ T)
    (hbdd : ∃ K, 0 ≤ K ∧ ∀ t, 0 ≤ t → t ≤ T → f t ≤ K) :
    f s ≤ ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T), f s := by
  obtain ⟨K, hK_nn, hK⟩ := hbdd
  have hinner : ∀ t, BddAbove (Set.range fun _ : 0 ≤ t ∧ t ≤ T => f t) := by
    intro t; exact ⟨K, by rintro y ⟨⟨ht0, htT⟩, rfl⟩; exact hK t ht0 htT⟩
  have houter : BddAbove (Set.range fun t : ℝ => ⨆ (_ : 0 ≤ t ∧ t ≤ T), f t) := by
    refine ⟨K, ?_⟩
    rintro y ⟨t, rfl⟩
    exact Real.iSup_le (fun ⟨ht0, htT⟩ => hK t ht0 htT) hK_nn
  exact le_trans (le_ciSup (hinner s) ⟨hs0, hsT⟩) (le_ciSup houter s)

private lemma norm_sq_le_two_add_two_sub {E : Type*} [SeminormedAddCommGroup E]
    (x y : E) : ‖x‖ ^ 2 ≤ 2 * ‖y‖ ^ 2 + 2 * ‖x - y‖ ^ 2 := by
  have h_tri : ‖x‖ ≤ ‖y‖ + ‖x - y‖ := by
    calc ‖x‖ = ‖y + (x - y)‖ := by congr 1; abel
      _ ≤ ‖y‖ + ‖x - y‖ := norm_add_le _ _
  nlinarith [pow_le_pow_left₀ (norm_nonneg x) h_tri 2,
    two_mul_le_add_sq ‖y‖ ‖x - y‖]

/-- Pathwise bound for the generator-centered martingale M*.
Mirrors `exists_frozenMartingalePart_norm_bound` but for `frozenGeneratorMartingalePart`. -/
private theorem exists_frozenGeneratorMP_norm_bound
    {d : ℕ} [NeZero d] (M : DensityDepCTMC d)
    {Ω : Type*} [MeasurableSpace Ω]
    (pathMap : Ω → CTMCPath (Fin d → Fin (M.N + 1))) (T : ℝ) (hT : 0 ≤ T) :
    ∃ C > 0, ∀ (t : ℝ) (ω : Ω), 0 ≤ t → t ≤ T →
      ‖M.frozenGeneratorMartingalePart pathMap t ω‖ ≤ C := by
  have hd_pos : 0 < (Fintype.card (Fin d) : ℝ) := Nat.cast_pos.mpr Fintype.card_pos
  let D : ℝ := ∑ i : Fin d, ∑ x : Fin d → Fin (M.N + 1), ‖M.generatorDrift x i‖
  have hD_nonneg : 0 ≤ D :=
    Finset.sum_nonneg fun i _ => Finset.sum_nonneg fun x _ => norm_nonneg _
  refine ⟨D * T + 3, by positivity, ?_⟩
  intro t ω ht0 htT
  have hproc : ‖M.frozenDensityProcess pathMap t ω‖ ≤ 1 :=
    M.frozenDensityProcess_norm_le pathMap t ω
  have hinit : ‖M.frozenInitialCondition pathMap ω‖ ≤ 1 :=
    M.frozenDensityProcess_norm_le pathMap 0 ω
  have hint : ‖(fun i => ∫ s in Set.Icc (0 : ℝ) t,
      (M.generatorDrift ((pathMap ω).frozenStateAt s)) i)‖ ≤ D * T := by
    have hDT_nonneg : 0 ≤ D * T := mul_nonneg hD_nonneg (le_trans ht0 htT)
    rw [pi_norm_le_iff_of_nonneg hDT_nonneg]
    intro i
    rw [Real.norm_eq_abs]
    have hbd : ∀ s ∈ Set.Icc (0 : ℝ) t,
        ‖(M.generatorDrift ((pathMap ω).frozenStateAt s)) i‖ ≤ D := by
      intro s _
      calc ‖M.generatorDrift ((pathMap ω).frozenStateAt s) i‖
          ≤ ∑ x : Fin d → Fin (M.N + 1), ‖M.generatorDrift x i‖ :=
            Finset.single_le_sum (f := fun x => ‖M.generatorDrift x i‖)
              (fun _ _ => norm_nonneg _) (Finset.mem_univ _)
        _ ≤ D := Finset.single_le_sum
            (f := fun i => ∑ x : Fin d → Fin (M.N + 1), ‖M.generatorDrift x i‖)
            (fun _ _ => Finset.sum_nonneg fun _ _ => norm_nonneg _)
            (Finset.mem_univ i)
    calc |∫ s in Set.Icc (0 : ℝ) t,
            (M.generatorDrift ((pathMap ω).frozenStateAt s)) i|
        = ‖∫ s in Set.Icc (0 : ℝ) t,
            (M.generatorDrift ((pathMap ω).frozenStateAt s)) i‖ := (Real.norm_eq_abs _).symm
      _ ≤ D * volume.real (Set.Icc (0 : ℝ) t) :=
          norm_setIntegral_le_of_norm_le_const measure_Icc_lt_top hbd
      _ = D * t := by rw [Real.volume_real_Icc_of_le ht0]; ring
      _ ≤ D * T := mul_le_mul_of_nonneg_left htT hD_nonneg
  calc ‖M.frozenGeneratorMartingalePart pathMap t ω‖
      = ‖M.frozenDensityProcess pathMap t ω - M.frozenInitialCondition pathMap ω -
          (fun i => ∫ s in Set.Icc (0 : ℝ) t,
            (M.generatorDrift ((pathMap ω).frozenStateAt s)) i)‖ := rfl
    _ ≤ ‖M.frozenDensityProcess pathMap t ω - M.frozenInitialCondition pathMap ω‖ +
          ‖(fun i => ∫ s in Set.Icc (0 : ℝ) t,
            (M.generatorDrift ((pathMap ω).frozenStateAt s)) i)‖ := norm_sub_le _ _
    _ ≤ (‖M.frozenDensityProcess pathMap t ω‖ + ‖M.frozenInitialCondition pathMap ω‖) +
          ‖(fun i => ∫ s in Set.Icc (0 : ℝ) t,
            (M.generatorDrift ((pathMap ω).frozenStateAt s)) i)‖ := by
        gcongr; exact norm_sub_le _ _
    _ ≤ (1 + 1) + D * T := by gcongr
    _ ≤ D * T + 3 := by linarith

set_option maxHeartbeats 400000 in
/-- **Main martingale sup² bound for gammaCompiled.**
Decomposes `M = M* + (M − M*)` and uses the triangle inequality
`‖a‖² ≤ 2‖b‖² + 2‖a−b‖²` pointwise, then takes sup and expectation.
Combines `gammaCompiled_generatorMP_sup_sq_bound` (M* Doob L²)
with `gammaCompiled_drift_mismatch_sup_sq_bound` (drift error). -/
theorem gammaCompiled_mart_sup_bound {T : ℝ} (hT : 0 < T) :
    ∃ C_qv : ℝ, 0 < C_qv ∧
    ∀ (N : ℕ) (hN : 0 < N)
    (x₀ : Fin 21 → Fin (N + 1))
    (_hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀)
    (_hclose : ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ ≤ 1 / ↑N),
    ∫ records, ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
      ‖(DensityDepCTMC.mk N hN gammaCompiledRateSpec).frozenMartingalePart
        (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalPathMap s records‖ ^ 2
    ∂(DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalRecordMeasure x₀
    ≤ C_qv * T / ↑N := by
  obtain ⟨C_doob, hC_doob_pos, hDoob⟩ := gammaCompiled_generatorMP_sup_sq_bound hT
  obtain ⟨C_drift, hC_drift_pos, hDrift⟩ := gammaCompiled_drift_mismatch_sup_sq_bound hT
  refine ⟨2 * C_doob + 2 * C_drift, by positivity, fun N hN x₀ hinit hclose => ?_⟩
  obtain ⟨hDoob_int, hDoob_N⟩ := hDoob N hN x₀ hinit hclose
  obtain ⟨hDrift_int, hDrift_N⟩ := hDrift N hN x₀ hinit hclose
  let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
  let μ := M.canonicalRecordMeasure x₀
  let F_M := fun records : M.canonicalRecordΩ => ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
    ‖M.frozenMartingalePart M.canonicalPathMap s records‖ ^ 2
  let F_star := fun records : M.canonicalRecordΩ => ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
    ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
  let F_diff := fun records : M.canonicalRecordΩ => ⨆ (s : ℝ) (_ : 0 ≤ s ∧ s ≤ T),
    ‖M.frozenMartingalePart M.canonicalPathMap s records -
     M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2
  have hF_M_int : MeasureTheory.Integrable F_M μ := by
    simpa [F_M, μ, M] using M.canonical_frozen_martingale_sup_sq_integrable x₀ T hT
  have hRHS_int : MeasureTheory.Integrable (fun records => 2 * F_star records + 2 * F_diff records) μ :=
    (hDoob_int.const_mul 2).add (hDrift_int.const_mul 2)
  have hpointwise : ∀ records : M.canonicalRecordΩ,
      F_M records ≤ 2 * F_star records + 2 * F_diff records := by
    intro records
    dsimp [F_M]
    have hF_star_nonneg : 0 ≤ F_star records :=
      Real.iSup_nonneg fun s => Real.iSup_nonneg fun _ => sq_nonneg _
    have hF_diff_nonneg : 0 ≤ F_diff records :=
      Real.iSup_nonneg fun s => Real.iSup_nonneg fun _ => sq_nonneg _
    have hbound_nonneg : (0 : ℝ) ≤ 2 * F_star records + 2 * F_diff records := by linarith
    refine Real.iSup_le (fun s => ?_) hbound_nonneg
    refine Real.iSup_le (fun ⟨hs0, hsT⟩ => ?_) hbound_nonneg
    have hpt := norm_sq_le_two_add_two_sub
      (M.frozenMartingalePart M.canonicalPathMap s records)
      (M.frozenGeneratorMartingalePart M.canonicalPathMap s records)
    have h_star_le : ‖M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2 ≤
        F_star records := by
      dsimp [F_star]; exact le_real_iSup₂_of_bounded hs0 hsT (by
        obtain ⟨K_star, hK_star_pos, hK_star⟩ :=
          exists_frozenGeneratorMP_norm_bound M M.canonicalPathMap T (le_of_lt hT)
        exact ⟨K_star ^ 2, by positivity, fun t ht0 htT =>
          pow_le_pow_left₀ (norm_nonneg _) (hK_star t records ht0 htT) 2⟩)
    have h_diff_le : ‖M.frozenMartingalePart M.canonicalPathMap s records -
        M.frozenGeneratorMartingalePart M.canonicalPathMap s records‖ ^ 2 ≤
        F_diff records := by
      dsimp [F_diff]; exact le_real_iSup₂_of_bounded hs0 hsT (by
        obtain ⟨K, hK_pos, hK⟩ := M.exists_frozenMartingalePart_norm_bound M.canonicalPathMap T (le_of_lt hT)
        obtain ⟨K_star, hK_star_pos, hK_star⟩ :=
          exists_frozenGeneratorMP_norm_bound M M.canonicalPathMap T (le_of_lt hT)
        refine ⟨(K + K_star) ^ 2, by positivity, fun t ht0 htT => ?_⟩
        have : ‖M.frozenMartingalePart M.canonicalPathMap t records -
            M.frozenGeneratorMartingalePart M.canonicalPathMap t records‖ ≤ K + K_star :=
          (norm_sub_le _ _).trans (add_le_add (hK t records ht0 htT) (hK_star t records ht0 htT))
        exact pow_le_pow_left₀ (norm_nonneg _) this 2)
    linarith
  have hmono : ∫ records, F_M records ∂μ ≤ ∫ records, (2 * F_star records + 2 * F_diff records) ∂μ :=
    MeasureTheory.integral_mono_ae hF_M_int hRHS_int
      (Filter.Eventually.of_forall hpointwise)
  have hsplit : ∫ records, (2 * F_star records + 2 * F_diff records) ∂μ =
      2 * ∫ records, F_star records ∂μ + 2 * ∫ records, F_diff records ∂μ := by
    rw [MeasureTheory.integral_add (hDoob_int.const_mul 2) (hDrift_int.const_mul 2)]
    rw [MeasureTheory.integral_const_mul, MeasureTheory.integral_const_mul]
  calc ∫ records, F_M records ∂μ
      ≤ ∫ records, (2 * F_star records + 2 * F_diff records) ∂μ := hmono
    _ = 2 * ∫ records, F_star records ∂μ + 2 * ∫ records, F_diff records ∂μ := hsplit
    _ ≤ 2 * (C_doob * T / ↑N) + 2 * (C_drift * T / ↑N) := by
        gcongr
    _ = (2 * C_doob + 2 * C_drift) * T / ↑N := by ring

/-- **Kurtz Convergence for the Compiled Gamma System.**
The stochastic density-dependent CTMC converges (in probability, uniformly on [0,T])
to the compiled gamma ODE solution.

Uses `kurtz_finite_horizon_generic_v3` which takes the QV bound only for
x₀ close to the mean-field initial condition (needed because
boundary-compatibility fails for this system). -/
theorem gammaCompiled_kurtz_convergence
    {T : ℝ} (hT : 0 < T) :
    ∀ ε > 0, ∃ N₀ : ℕ, ∀ N ≥ N₀, ∀ (hN : 0 < N)
    (x₀ : Fin 21 → Fin (N + 1))
    (hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀)
    (_hinit_close :
      ‖(fun i => (↑(x₀ i) : ℝ) / ↑N) - gammaCompiledInit‖ ≤ 1 / ↑N),
    (DensityDepCTMC.mk N hN gammaCompiledRateSpec).canonicalRecordMeasure x₀
      {ω | ⨆ (t : ℝ) (_ : 0 ≤ t ∧ t ≤ T),
        ‖(gammaCompiled_frozenDensityProcess N hN x₀ hinit).process t ω -
          gammaCompiledSol t‖ > ε} ≤ ENNReal.ofReal ε := by
  intro ε hε
  obtain ⟨C_qv, hC_qv_pos, hqv⟩ := gammaCompiled_mart_sup_bound hT
  obtain ⟨N₀, hN₀⟩ := kurtz_finite_horizon_generic_v3
    gammaCompiledRateSpec gammaCompiledMeanField
    (fun N hN => gammaCompiled_driftZeroAtAbsorbingOnSimplex N hN)
    (fun N hN => gammaCompiled_conservativeJumps N hN)
    gammaCompiledSol_norm_le_one
    gammaCompiledSol_measurable
    gammaCompiledSol_drift_intervalIntegrable
    hT hC_qv_pos hqv ε hε ε hε
  exact ⟨N₀, fun N hN_ge hN x₀ hinit hinit_close => hN₀ N hN_ge hN x₀ hinit hinit_close⟩

