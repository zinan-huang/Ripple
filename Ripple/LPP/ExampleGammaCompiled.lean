/-- Species 19 is constant along canonical CTMC paths a.e., because no reaction
touches it (gammaCompiledJump k 19 = 0 for all k). -/
private lemma gammaCompiled_stateSeq_19_const_ae (N : ℕ) (hN : 0 < N)
    (x₀ : Fin 21 → Fin (N + 1))
    (hinit : (DensityDepCTMC.mk N hN gammaCompiledRateSpec).InSimplex x₀) :
    let M := DensityDepCTMC.mk N hN gammaCompiledRateSpec
    ∀ᵐ records ∂M.canonicalRecordMeasure x₀,
      ∀ n, (M.canonicalPathMap records).stateSeq n 19 = x₀ 19 := by
  intro M
  filter_upwards
    [M.toQMatrix.canonicalRecordMeasure_record_zero_eq_init_ae x₀,
      M.toQMatrix.canonicalRecordMeasure_all_next_state_eq_current_ae_of_absorbing x₀,
      M.toQMatrix.canonicalRecordMeasure_all_next_rate_pos_ae_of_nonabsorbing x₀]
    with records hrecord0 hstay hrate
  intro n
  induction n with
  | zero =>
      simpa [DensityDepCTMC.canonicalPathMap, hrecord0]
  | succ n ih =>
      let curr := (M.canonicalPathMap records).stateSeq n
      let next := (M.canonicalPathMap records).stateSeq (n + 1)
      have hcur :
          QMatrix.currentStateFromHistory
              (S := Fin 21 → Fin (N + 1)) n (Preorder.frestrictLe n records) =
            curr := by
        simp [curr, DensityDepCTMC.canonicalPathMap, QMatrix.currentStateFromHistory_frestrictLe]
      by_cases habs : M.toQMatrix.IsAbsorbing curr
      · have hnext_record :
            (records (n + 1)).2 =
              QMatrix.currentStateFromHistory
                (S := Fin 21 → Fin (N + 1)) n (Preorder.frestrictLe n records) :=
          hstay n (by simpa [hcur] using habs)
        have hnext_eq : next = curr := by
          simpa [next, curr, DensityDepCTMC.canonicalPathMap, hcur] using hnext_record
        show next 19 = x₀ 19
        rw [hnext_eq]; exact ih
      · have hq : 0 < M.toQMatrix.rate curr next := by
          have hraw := hrate n (by simpa [hcur] using habs)
          simpa [curr, next, DensityDepCTMC.canonicalPathMap, hcur,
            QMatrix.recordTrajectoryToPath_stateSeq] using hraw
        have hpos : 0 < M.offDiagRate curr next :=
          M.offDiagRate_pos_of_toQMatrix_rate_pos hq
        obtain ⟨ℓ, hℓ, hmatch⟩ := M.exists_jump_of_offDiagRate_pos hpos
        have hℓ19 : ℓ 19 = 0 := by
          simp only [M, gammaCompiledRateSpec] at hℓ
          rw [Finset.mem_image] at hℓ
          obtain ⟨k, _, rfl⟩ := hℓ
          exact_mod_cast gammaCompiledJump_19_eq_zero k
        show next 19 = x₀ 19
        have h := hmatch 19; rw [hℓ19] at h
        have h19eq : next 19 = curr 19 := by
          have hint : ((next 19 : ℕ) : ℤ) = ((curr 19 : ℕ) : ℤ) := sub_eq_zero.mp h
          exact Fin.ext (Int.ofNat.inj hint)
        rw [h19eq]; exact ih

