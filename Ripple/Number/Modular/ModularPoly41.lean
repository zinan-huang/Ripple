import Mathlib.Tactic

/-!
# Modular polynomial Φ₄₁ diagonal — computational verification

Encodes `Φ₄₁(X,X)` and its cofactor `g(X) = Φ₄₁(X,X) / (X + 640320³)²` via Horner
evaluation, and verifies computationally:
- `-640320³` is a root of `Φ₄₁(X,X)`.
- The cofactor satisfies `g(-640320³) ≠ 0` (multiplicity exactly 2).

Coefficients generated by PARI/GP: `polmodular(41); subst(%, y, x)`.
-/

set_option linter.style.longLine false
set_option maxRecDepth 65536

namespace Ripple.Number.Modular

open Polynomial

/-- A sparse integer bivariate monomial `coeff * X^xPow * Y^yPow`. -/
structure SparseBivarTerm where
  coeff : ℤ
  xPow : ℕ
  yPow : ℕ

/-- Evaluate a sparse integer bivariate polynomial over a commutative ring. -/
def evalSparseBivar {R : Type*} [CommRing R] :
    List SparseBivarTerm → R → R → R
  | [], _, _ => 0
  | t :: ts, x, y =>
      (t.coeff : R) * x ^ t.xPow * y ^ t.yPow + evalSparseBivar ts x y

theorem map_evalSparseBivar {R S : Type*} [CommRing R] [CommRing S]
    (f : R →+* S) (terms : List SparseBivarTerm) (x y : R) :
    f (evalSparseBivar terms x y) =
      evalSparseBivar terms (f x) (f y) := by
  induction terms with
  | nil => simp [evalSparseBivar]
  | cons t ts ih =>
      simp [evalSparseBivar, ih]

/-- Evaluate a sparse integer bivariate polynomial over `ℂ`. -/
def evalSparseBivarC : List SparseBivarTerm → ℂ → ℂ → ℂ
  | [], _, _ => 0
  | t :: ts, x, y =>
      (t.coeff : ℂ) * x ^ t.xPow * y ^ t.yPow + evalSparseBivarC ts x y

theorem evalSparseBivarC_eq_evalSparseBivar
    (terms : List SparseBivarTerm) (x y : ℂ) :
    evalSparseBivarC terms x y = evalSparseBivar terms x y := by
  induction terms with
  | nil => rfl
  | cons t ts ih =>
      simp [evalSparseBivarC, evalSparseBivar, ih]

/-- Swap the two variables in a sparse bivariate monomial. -/
def swapSparseBivarTerm (t : SparseBivarTerm) : SparseBivarTerm :=
  ⟨t.coeff, t.yPow, t.xPow⟩

theorem evalSparseBivarC_swapTerms (terms : List SparseBivarTerm) (x y : ℂ) :
    evalSparseBivarC (terms.map swapSparseBivarTerm) x y =
      evalSparseBivarC terms y x := by
  induction terms with
  | nil => rfl
  | cons t ts ih =>
      simp [evalSparseBivarC, swapSparseBivarTerm, ih]
      ring

theorem evalSparseBivarC_of_perm {terms terms' : List SparseBivarTerm}
    (hperm : terms.Perm terms') (x y : ℂ) :
    evalSparseBivarC terms x y = evalSparseBivarC terms' x y := by
  induction hperm with
  | nil => rfl
  | cons t h ih =>
      simp [evalSparseBivarC, ih]
  | swap t u ts =>
      simp [evalSparseBivarC]
      ring
  | trans _ _ ih₁ ih₂ =>
      exact ih₁.trans ih₂

/-- Evaluate the numerator obtained after substituting
`x = xNum / xDen`, `y = yNum / yDen` into a sparse bivariate polynomial and
clearing denominators by `xDen ^ xMax * yDen ^ yMax`. -/
def evalSparseBivarCleared {R : Type*} [CommRing R] :
    List SparseBivarTerm → ℕ → ℕ → R → R → R → R → R
  | [], _, _, _, _, _, _ => 0
  | t :: ts, xMax, yMax, xNum, xDen, yNum, yDen =>
      (t.coeff : R) * xNum ^ t.xPow * xDen ^ (xMax - t.xPow) *
          yNum ^ t.yPow * yDen ^ (yMax - t.yPow) +
        evalSparseBivarCleared ts xMax yMax xNum xDen yNum yDen

theorem map_evalSparseBivarCleared {R S : Type*} [CommRing R] [CommRing S]
    (f : R →+* S) (terms : List SparseBivarTerm) (xMax yMax : ℕ)
    (xNum xDen yNum yDen : R) :
    f (evalSparseBivarCleared terms xMax yMax xNum xDen yNum yDen) =
      evalSparseBivarCleared terms xMax yMax
        (f xNum) (f xDen) (f yNum) (f yDen) := by
  induction terms with
  | nil => simp [evalSparseBivarCleared]
  | cons t ts ih =>
      simp [evalSparseBivarCleared, ih]

/-- Evaluate the numerator obtained after substituting
`x = xNum / xDen`, `y = yNum / yDen` into a sparse bivariate polynomial and
clearing denominators by `xDen ^ xMax * yDen ^ yMax` over `ℂ`. -/
def evalSparseBivarClearedC :
    List SparseBivarTerm → ℕ → ℕ → ℂ → ℂ → ℂ → ℂ → ℂ
  | [], _, _, _, _, _, _ => 0
  | t :: ts, xMax, yMax, xNum, xDen, yNum, yDen =>
      (t.coeff : ℂ) * xNum ^ t.xPow * xDen ^ (xMax - t.xPow) *
          yNum ^ t.yPow * yDen ^ (yMax - t.yPow) +
        evalSparseBivarClearedC ts xMax yMax xNum xDen yNum yDen

theorem evalSparseBivarClearedC_eq_evalSparseBivarCleared
    (terms : List SparseBivarTerm) (xMax yMax : ℕ)
    (xNum xDen yNum yDen : ℂ) :
    evalSparseBivarClearedC terms xMax yMax xNum xDen yNum yDen =
      evalSparseBivarCleared terms xMax yMax xNum xDen yNum yDen := by
  induction terms with
  | nil => rfl
  | cons t ts ih =>
      simp [evalSparseBivarClearedC, evalSparseBivarCleared, ih]

private theorem pow_mul_div_pow_eq_pow_sub {num den : ℂ} {n m : ℕ}
    (hnm : n ≤ m) (hden : den ≠ 0) :
    den ^ m * (num / den) ^ n = num ^ n * den ^ (m - n) := by
  rw [div_eq_mul_inv, mul_pow]
  rw [show den ^ m = den ^ n * den ^ (m - n) by
    rw [← pow_add, Nat.add_sub_of_le hnm]]
  rw [show den ^ n * den ^ (m - n) * (num ^ n * den⁻¹ ^ n) =
      num ^ n * den ^ (m - n) * (den ^ n * den⁻¹ ^ n) by ring]
  rw [← mul_pow, mul_inv_cancel₀ hden, one_pow]
  ring

theorem evalSparseBivarClearedC_eq_den_mul_eval
    (terms : List SparseBivarTerm) (xMax yMax : ℕ) (xNum xDen yNum yDen : ℂ)
    (hxDen : xDen ≠ 0) (hyDen : yDen ≠ 0)
    (hdeg : ∀ t ∈ terms, t.xPow ≤ xMax ∧ t.yPow ≤ yMax) :
    evalSparseBivarClearedC terms xMax yMax xNum xDen yNum yDen =
      xDen ^ xMax * yDen ^ yMax *
        evalSparseBivarC terms (xNum / xDen) (yNum / yDen) := by
  induction terms with
  | nil => simp [evalSparseBivarClearedC, evalSparseBivarC]
  | cons t ts ih =>
      have htdeg : t.xPow ≤ xMax ∧ t.yPow ≤ yMax := hdeg t (by simp)
      have htsdeg : ∀ u ∈ ts, u.xPow ≤ xMax ∧ u.yPow ≤ yMax := by
        intro u hu
        exact hdeg u (by simp [hu])
      rw [evalSparseBivarClearedC, evalSparseBivarC, ih htsdeg]
      rw [mul_add]
      have hterm :
          (t.coeff : ℂ) * xNum ^ t.xPow * xDen ^ (xMax - t.xPow) *
              yNum ^ t.yPow * yDen ^ (yMax - t.yPow) =
            xDen ^ xMax * yDen ^ yMax *
              ((t.coeff : ℂ) * (xNum / xDen) ^ t.xPow *
                (yNum / yDen) ^ t.yPow) := by
        symm
        calc
          xDen ^ xMax * yDen ^ yMax *
              ((t.coeff : ℂ) * (xNum / xDen) ^ t.xPow *
                (yNum / yDen) ^ t.yPow)
              = (t.coeff : ℂ) *
                  (xDen ^ xMax * (xNum / xDen) ^ t.xPow) *
                    (yDen ^ yMax * (yNum / yDen) ^ t.yPow) := by
                    ring
          _ = (t.coeff : ℂ) *
                (xNum ^ t.xPow * xDen ^ (xMax - t.xPow)) *
                  (yNum ^ t.yPow * yDen ^ (yMax - t.yPow)) := by
                rw [pow_mul_div_pow_eq_pow_sub htdeg.1 hxDen,
                  pow_mul_div_pow_eq_pow_sub htdeg.2 hyDen]
          _ = (t.coeff : ℂ) * xNum ^ t.xPow * xDen ^ (xMax - t.xPow) *
                yNum ^ t.yPow * yDen ^ (yMax - t.yPow) := by
                ring
      rw [hterm]

/-- Evaluate the diagonal specialization of a sparse integer bivariate
polynomial over `ℂ`, combining `X^i Y^j` into `Z^(i+j)`. -/
def evalSparseBivarDiagC : List SparseBivarTerm → ℂ → ℂ
  | [], _ => 0
  | t :: ts, z =>
      (t.coeff : ℂ) * z ^ (t.xPow + t.yPow) + evalSparseBivarDiagC ts z

theorem evalSparseBivarC_diag (terms : List SparseBivarTerm) (z : ℂ) :
    evalSparseBivarC terms z z = evalSparseBivarDiagC terms z := by
  induction terms with
  | nil => rfl
  | cons t ts ih =>
      simp [evalSparseBivarC, evalSparseBivarDiagC, ih, pow_add]
      ring

/-- Evaluate an ascending integer coefficient list
`c₀ + c₁ Z + c₂ Z² + ...` over `ℂ`. -/
def evalCoeffListC : List ℤ → ℂ → ℂ
  | [], _ => 0
  | c :: cs, z => (c : ℂ) + z * evalCoeffListC cs z

/-- Add two ascending integer coefficient lists. -/
def addCoeffLists : List ℤ → List ℤ → List ℤ
  | [], ds => ds
  | cs, [] => cs
  | c :: cs, d :: ds => (c + d) :: addCoeffLists cs ds

theorem evalCoeffListC_addCoeffLists (cs ds : List ℤ) (z : ℂ) :
    evalCoeffListC (addCoeffLists cs ds) z =
      evalCoeffListC cs z + evalCoeffListC ds z := by
  induction cs generalizing ds with
  | nil => simp [addCoeffLists, evalCoeffListC]
  | cons c cs ih =>
      cases ds with
      | nil => simp [addCoeffLists, evalCoeffListC]
      | cons d ds =>
          simp [addCoeffLists, evalCoeffListC, ih]
          ring

/-- Scale an ascending integer coefficient list. -/
def scaleCoeffList (c : ℤ) : List ℤ → List ℤ
  | [] => []
  | d :: ds => (c * d) :: scaleCoeffList c ds

theorem evalCoeffListC_scaleCoeffList (c : ℤ) (ds : List ℤ) (z : ℂ) :
    evalCoeffListC (scaleCoeffList c ds) z =
      (c : ℂ) * evalCoeffListC ds z := by
  induction ds with
  | nil => simp [scaleCoeffList, evalCoeffListC]
  | cons d ds ih =>
      simp [scaleCoeffList, evalCoeffListC, ih]
      ring

/-- Multiply ascending integer coefficient lists. -/
def mulCoeffLists : List ℤ → List ℤ → List ℤ
  | [], _ => []
  | c :: cs, ds =>
      addCoeffLists (scaleCoeffList c ds) (0 :: mulCoeffLists cs ds)

theorem evalCoeffListC_mulCoeffLists (cs ds : List ℤ) (z : ℂ) :
    evalCoeffListC (mulCoeffLists cs ds) z =
      evalCoeffListC cs z * evalCoeffListC ds z := by
  induction cs with
  | nil => simp [mulCoeffLists, evalCoeffListC]
  | cons c cs ih =>
      simp [mulCoeffLists, evalCoeffListC, evalCoeffListC_addCoeffLists,
        evalCoeffListC_scaleCoeffList, ih]
      ring

/-- Compose an ascending coefficient list with another ascending coefficient
list: `coeffListComp cs ds` represents `cs(ds(X))`. -/
def coeffListComp : List ℤ → List ℤ → List ℤ
  | [], _ => []
  | c :: cs, ds => addCoeffLists [c] (mulCoeffLists ds (coeffListComp cs ds))

theorem evalCoeffListC_coeffListComp (cs ds : List ℤ) (z : ℂ) :
    evalCoeffListC (coeffListComp cs ds) z =
      evalCoeffListC cs (evalCoeffListC ds z) := by
  induction cs with
  | nil => simp [coeffListComp, evalCoeffListC]
  | cons c cs ih =>
      simp [coeffListComp, evalCoeffListC, evalCoeffListC_addCoeffLists,
        evalCoeffListC_mulCoeffLists, ih]

theorem evalCoeffListC_append_zero (cs : List ℤ) (z : ℂ) :
    evalCoeffListC (cs ++ [0]) z = evalCoeffListC cs z := by
  induction cs with
  | nil => simp [evalCoeffListC]
  | cons c cs ih =>
      simp [evalCoeffListC, ih]

/-- Add an integer coefficient into an ascending coefficient list, extending
the list with zeroes if necessary. -/
def addCoeffAt : ℕ → ℤ → List ℤ → List ℤ
  | 0, c, [] => [c]
  | 0, c, d :: ds => (d + c) :: ds
  | n + 1, c, [] => 0 :: addCoeffAt n c []
  | n + 1, c, d :: ds => d :: addCoeffAt n c ds

theorem evalCoeffListC_addCoeffAt (n : ℕ) (c : ℤ) (cs : List ℤ) (z : ℂ) :
    evalCoeffListC (addCoeffAt n c cs) z =
      (c : ℂ) * z ^ n + evalCoeffListC cs z := by
  induction n generalizing cs with
  | zero =>
      cases cs with
      | nil => simp [addCoeffAt, evalCoeffListC]
      | cons d ds =>
          simp [addCoeffAt, evalCoeffListC]
          ring
  | succ n ih =>
      cases cs with
      | nil =>
          simp [addCoeffAt, evalCoeffListC, ih, pow_succ]
          ring
      | cons d ds =>
          simp [addCoeffAt, evalCoeffListC, ih, pow_succ]
          ring

/-- Fold a sparse bivariate polynomial into the ascending coefficient list of
its diagonal specialization. -/
def sparseBivarDiagCoeffList : List SparseBivarTerm → List ℤ
  | [] => []
  | t :: ts => addCoeffAt (t.xPow + t.yPow) t.coeff (sparseBivarDiagCoeffList ts)

theorem eval_sparseBivarDiagCoeffList (terms : List SparseBivarTerm) (z : ℂ) :
    evalCoeffListC (sparseBivarDiagCoeffList terms) z =
      evalSparseBivarDiagC terms z := by
  induction terms with
  | nil => simp [sparseBivarDiagCoeffList, evalCoeffListC, evalSparseBivarDiagC]
  | cons t ts ih =>
      simp [sparseBivarDiagCoeffList, evalSparseBivarDiagC,
        evalCoeffListC_addCoeffAt, ih]

/-- The diagonal specialization of a sparse bivariate integer polynomial as an
ordinary complex polynomial. -/
noncomputable def sparseBivarDiagPolynomialC : List SparseBivarTerm → ℂ[X]
  | [] => 0
  | t :: ts =>
      C (t.coeff : ℂ) * X ^ (t.xPow + t.yPow) + sparseBivarDiagPolynomialC ts

theorem eval_sparseBivarDiagPolynomialC (terms : List SparseBivarTerm) (z : ℂ) :
    Polynomial.eval z (sparseBivarDiagPolynomialC terms) = evalSparseBivarDiagC terms z := by
  induction terms with
  | nil => simp [sparseBivarDiagPolynomialC, evalSparseBivarDiagC]
  | cons t ts ih =>
      simp [sparseBivarDiagPolynomialC, evalSparseBivarDiagC, ih]

