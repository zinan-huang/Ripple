-- Generated 80-term integer comparison for Taylor domination.
theorem phi41CofactorShift_tail_lt_const :
    taylorTailAbsSum phi41CofactorShiftTail < phi41CofactorShiftConst.natAbs := by
  decide

/-- Taylor domination: the cofactor has no zero in the open unit disk around
`j163Val`. -/
theorem phi41DiagCofactorShift_ne_zero_of_norm_lt_one {w : ℂ} (hw : ‖w‖ < 1) :
    evalPhi41DiagCofactorShiftC w ≠ 0 := by
  intro hzero
  have htail : evalTaylorTailC phi41CofactorShiftTail w =
      -(phi41CofactorShiftConst : ℂ) := by
    have h := congrArg (fun z : ℂ => z - (phi41CofactorShiftConst : ℂ)) hzero
    simpa [evalPhi41DiagCofactorShiftC, sub_eq_add_neg, add_comm, add_left_comm,
      add_assoc] using h
  have hnorm : ‖evalTaylorTailC phi41CofactorShiftTail w‖ =
      ‖(phi41CofactorShiftConst : ℂ)‖ := by
    rw [htail, norm_neg]
  have hle := evalTaylorTailC_norm_le_absSum phi41CofactorShiftTail (le_of_lt hw)
  have hlt_nat : taylorTailAbsSum phi41CofactorShiftTail <
      phi41CofactorShiftConst.natAbs := phi41CofactorShift_tail_lt_const
  have hlt : (taylorTailAbsSum phi41CofactorShiftTail : ℝ) <
      ‖(phi41CofactorShiftConst : ℂ)‖ := by
    rw [norm_intCast_natAbs phi41CofactorShiftConst]
    exact_mod_cast hlt_nat
  rw [hnorm] at hle
  linarith

/-- Root isolation for the centered diagonal `Φ₄₁` factorization near the
Chudnovsky integer.  Once the modular equation gives the isolated polynomial
value `0`, the q-expansion bound `< 1` selects the unique nearby root. -/
theorem eq_j163Val_of_evalPhi41DiagIsolatedC_eq_zero_of_norm_sub_lt_one {z : ℂ}
    (hmod : evalPhi41DiagIsolatedC z = 0) (hclose : ‖z - (j163Val : ℂ)‖ < 1) :
    z = (j163Val : ℂ) := by
  have hcof : evalPhi41DiagCofactorShiftC (z - (j163Val : ℂ)) ≠ 0 :=
    phi41DiagCofactorShift_ne_zero_of_norm_lt_one hclose
  unfold evalPhi41DiagIsolatedC at hmod
  have hsquare : (z - (j163Val : ℂ)) ^ 2 = 0 := by
    rcases mul_eq_zero.mp hmod with hs | hc
    · exact hs
    · exact (hcof hc).elim
  have hdiff : z - (j163Val : ℂ) = 0 := by
    have hmul : (z - (j163Val : ℂ)) * (z - (j163Val : ℂ)) = 0 := by
      simpa [pow_two] using hsquare
    rcases mul_eq_zero.mp hmul with h | h <;> exact h
  exact sub_eq_zero.mp hdiff

