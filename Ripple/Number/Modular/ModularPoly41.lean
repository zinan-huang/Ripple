/-- Tail evaluator for a Taylor expansion over `ℂ`, storing coefficients of
`w, w², ...` in ascending order. -/
def evalTaylorTailC : List ℤ → ℂ → ℂ
  | [], _ => 0
  | c :: cs, w => w * ((c : ℂ) + evalTaylorTailC cs w)

/-- `evalTaylorTailC` stores powers `w, w², ...`; `evalCoeffListC` stores
powers `1, w, ...`. -/
theorem evalTaylorTailC_eq_mul_evalCoeffListC (cs : List ℤ) (w : ℂ) :
    evalTaylorTailC cs w = w * evalCoeffListC cs w := by
  induction cs with
  | nil => simp [evalTaylorTailC, evalCoeffListC]
  | cons c cs ih =>
      simp [evalTaylorTailC, evalCoeffListC, ih]

/-- Polynomial counterpart of `evalTaylorTailC`. -/
noncomputable def taylorTailPolynomialC : List ℤ → ℂ[X]
  | [] => 0
  | c :: cs => X * (C (c : ℂ) + taylorTailPolynomialC cs)

theorem eval_taylorTailPolynomialC (cs : List ℤ) (w : ℂ) :
    Polynomial.eval w (taylorTailPolynomialC cs) = evalTaylorTailC cs w := by
  induction cs with
  | nil => simp [taylorTailPolynomialC, evalTaylorTailC]
  | cons c cs ih =>
      simp [taylorTailPolynomialC, evalTaylorTailC, ih]

/-- Sum of absolute values of the integer coefficients used by `evalTaylorTailC`. -/
def taylorTailAbsSum : List ℤ → ℕ
  | [] => 0
  | c :: cs => c.natAbs + taylorTailAbsSum cs

lemma norm_intCast_natAbs (c : ℤ) : ‖(c : ℂ)‖ = (c.natAbs : ℝ) := by
  rw [Complex.norm_intCast, ← Int.cast_abs]
  exact (Nat.cast_natAbs (α := ℝ) c).symm

lemma evalTaylorTailC_norm_le_absSum (cs : List ℤ) {w : ℂ} (hw : ‖w‖ ≤ 1) :
    ‖evalTaylorTailC cs w‖ ≤ (taylorTailAbsSum cs : ℝ) := by
  induction cs with
  | nil => simp [evalTaylorTailC, taylorTailAbsSum]
  | cons c cs ih =>
      calc
        ‖evalTaylorTailC (c :: cs) w‖
            = ‖w‖ * ‖(c : ℂ) + evalTaylorTailC cs w‖ := by
                simp [evalTaylorTailC]
        _ ≤ 1 * (‖(c : ℂ)‖ + ‖evalTaylorTailC cs w‖) := by
                exact mul_le_mul hw (norm_add_le _ _) (norm_nonneg _) (by norm_num)
        _ ≤ 1 * ((c.natAbs : ℝ) + (taylorTailAbsSum cs : ℝ)) := by
                rw [norm_intCast_natAbs c]
                simpa [add_comm, add_left_comm, add_assoc] using
                  add_le_add_left ih (c.natAbs : ℝ)
        _ = (taylorTailAbsSum (c :: cs) : ℝ) := by
                simp [taylorTailAbsSum]

